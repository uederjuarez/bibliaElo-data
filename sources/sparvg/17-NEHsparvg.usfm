\v 1 Las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* \w Nehemías|strong="H5166"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hacalías. \w Aconteció|strong="H1961"\w* en \w el|strong="H1121"\w* \w mes|strong="H2320"\w* \w de|strong="H1121"\w* Quisleu, en \w el|strong="H1121"\w* \w año|strong="H8141"\w* \w veinte|strong="H6242"\w*, \w estando|strong="H1961"\w* yo en \w Susán|strong="H7800"\w*, \w capital|strong="H1002"\w* del \w reino|strong="H1961"\w*,   
\m
\v 2 \w que|strong="H4480"\w* vino \w Hanani|strong="H2607"\w*, uno \w de|strong="H4480"\w* mis hermanos, \w él|strong="H1931"\w* \w y|strong="H5921"\w* ciertos varones \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w pregunté|strong="H7592"\w* \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* \w que|strong="H4480"\w* habían escapado, \w que|strong="H4480"\w* habían quedado \w de|strong="H4480"\w* \w la|strong="H1931"\w* cautividad, \w y|strong="H5921"\w* \w por|strong="H5921"\w* Jerusalén.   
\m
\v 3 \w Y|strong="H3068"\w* \w me|strong="H4480"\w* dijeron: El remanente, los \w que|strong="H4480"\w* \w quedaron|strong="H7604"\w* \w de|strong="H4480"\w* la cautividad \w allí|strong="H8033"\w* \w en|strong="H4480"\w* la \w provincia|strong="H4082"\w*, \add están\add* \w en|strong="H4480"\w* \w gran|strong="H1419"\w* aflicción y \w oprobio|strong="H2781"\w*, y el \w muro|strong="H2346"\w* \w de|strong="H4480"\w* Jerusalén \add está\add* \w derribado|strong="H6555"\w*, y sus \w puertas|strong="H8179"\w* están \w quemadas|strong="H3341"\w* \w a|strong="H3068"\w* fuego.   
\m
\v 4 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1697"\w*, \w cuando|strong="H3117"\w* yo \w oí|strong="H8085"\w* estas \w palabras|strong="H1697"\w*, me senté y \w lloré|strong="H1058"\w*, \w e|strong="H3068"\w* hice duelo \w por|strong="H1697"\w* algunos \w días|strong="H3117"\w*, y ayuné y \w oré|strong="H6419"\w* \w delante|strong="H6440"\w* del Dios del \w cielo|strong="H8064"\w*.   
\m
\v 5 \w Y|strong="H3068"\w* dije: Te ruego, oh \w Jehová|strong="H3068"\w*, \w Dios|strong="H3068"\w* del \w cielo|strong="H8064"\w*, fuerte, \w grande|strong="H1419"\w* y \w terrible|strong="H3372"\w*, que \w guarda|strong="H8104"\w* el \w pacto|strong="H1285"\w* y \w la|strong="H8104"\w* \w misericordia|strong="H2617"\w* \w a|strong="H3068"\w* los que le aman y \w guardan|strong="H8104"\w* sus \w mandamientos|strong="H4687"\w*;   
\m
\v 6 \w Esté|strong="H1961"\w* \w ahora|strong="H4994"\w* \w atento|strong="H7183"\w* tu \w oído|strong="H8085"\w*, \w y|strong="H5921"\w* tus \w ojos|strong="H5869"\w* \w abiertos|strong="H6605"\w*, \w para|strong="H5921"\w* \w oír|strong="H8085"\w* \w la|strong="H5921"\w* \w oración|strong="H8605"\w* \w de|strong="H5921"\w* tu \w siervo|strong="H5650"\w*, \w que|strong="H4994"\w* \w yo|strong="H4994"\w* \w hago|strong="H6419"\w* \w ahora|strong="H4994"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w día|strong="H3117"\w* \w y|strong="H5921"\w* \w noche|strong="H3915"\w*, \w por|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* tus \w siervos|strong="H5650"\w*; \w y|strong="H5921"\w* \w confieso|strong="H3034"\w* \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H4994"\w* hemos \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* cometido; \w sí|strong="H6440"\w*, \w yo|strong="H4994"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre hemos \w pecado|strong="H2403"\w*.   
\m
\v 7 En extremo nos hemos corrompido contra ti, y \w no|strong="H3808"\w* hemos \w guardado|strong="H8104"\w* los \w mandamientos|strong="H4687"\w*, \w ni|strong="H3808"\w* los \w estatutos|strong="H2706"\w* \w ni|strong="H3808"\w* los \w juicios|strong="H4941"\w* \w que|strong="H3808"\w* \w mandaste|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* tu \w siervo|strong="H5650"\w*.   
