\v 29 \w Y|strong="H3068"\w* \w los|strong="H1992"\w* amonestaste \w para|strong="H5414"\w* \w que|strong="H3808"\w* volviesen \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w ley|strong="H8451"\w*; \w mas|strong="H2421"\w* \w ellos|strong="H1992"\w* fueron soberbios, y \w no|strong="H3808"\w* \w oyeron|strong="H8085"\w* tus \w mandamientos|strong="H4687"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w pecaron|strong="H2398"\w* contra tus \w juicios|strong="H4941"\w*, \w los|strong="H1992"\w* cuales \w si|strong="H3808"\w* \w el|strong="H6213"\w* hombre \w hiciere|strong="H6213"\w*, en \w ellos|strong="H1992"\w* \w vivirá|strong="H2421"\w*. Pero \w ellos|strong="H1992"\w* \w dieron|strong="H5414"\w* la espalda, y endurecieron \w su|strong="H1992"\w* \w cerviz|strong="H6203"\w*, y \w no|strong="H3808"\w* \w escucharon|strong="H8085"\w*.   
\m
\v 30 \w Los|strong="H5921"\w* soportaste \w muchos|strong="H7227"\w* \w años|strong="H8141"\w*, \w y|strong="H5921"\w* \w les|strong="H5921"\w* amonestaste \w con|strong="H5921"\w* tu \w Espíritu|strong="H7307"\w* \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* tus \w profetas|strong="H5030"\w*, \w mas|strong="H5921"\w* \w no|strong="H3808"\w* escucharon; \w por|strong="H5921"\w* \w lo|strong="H3808"\w* cual \w los|strong="H5921"\w* \w entregaste|strong="H5414"\w* \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.   
\m
\v 31 \w Mas|strong="H3588"\w* \w por|strong="H3588"\w* tus \w muchas|strong="H7227"\w* \w misericordias|strong="H7356"\w* \w no|strong="H3808"\w* \w los|strong="H3588"\w* consumiste, \w ni|strong="H3808"\w* \w los|strong="H3588"\w* \w desamparaste|strong="H5800"\w*; \w porque|strong="H3588"\w* eres Dios \w clemente|strong="H2587"\w* \w y|strong="H3588"\w* \w misericordioso|strong="H7349"\w*.   
\m
\v 32 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, Dios nuestro, Dios \w grande|strong="H1419"\w*, \w fuerte|strong="H1368"\w* \w y|strong="H5704"\w* \w terrible|strong="H3372"\w*, \w que|strong="H6258"\w* \w guardas|strong="H8104"\w* \w el|strong="H3605"\w* \w pacto|strong="H1285"\w* \w y|strong="H5704"\w* \w la|strong="H8104"\w* \w misericordia|strong="H2617"\w*, \w no|strong="H6440"\w* sea tenida \w en|strong="H5704"\w* \w poco|strong="H4591"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti \w toda|strong="H3605"\w* \w la|strong="H8104"\w* aflicción \w que|strong="H6258"\w* ha venido sobre \w nosotros|strong="H3605"\w*, sobre nuestros \w reyes|strong="H4428"\w*, sobre nuestros \w príncipes|strong="H8269"\w*, sobre nuestros \w sacerdotes|strong="H3548"\w*, sobre nuestros \w profetas|strong="H5030"\w*, sobre nuestros padres \w y|strong="H5704"\w* sobre \w todo|strong="H3605"\w* tu \w pueblo|strong="H5971"\w*, \w desde|strong="H5704"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H6440"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* \w de|strong="H6440"\w* Asiria \w hasta|strong="H5704"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w*.   
\m
\v 33 \w Pero|strong="H3588"\w* \w tú|strong="H6213"\w* eres \w justo|strong="H6662"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* ha venido \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w*; \w porque|strong="H3588"\w* rectamente has \w hecho|strong="H6213"\w*, \w mas|strong="H3588"\w* \w nosotros|strong="H3605"\w* hemos \w hecho|strong="H6213"\w* \w lo|strong="H5921"\w* malo.   
\m
\v 34 \w Y|strong="H3068"\w* nuestros \w reyes|strong="H4428"\w*, nuestros \w príncipes|strong="H8269"\w*, nuestros \w sacerdotes|strong="H3548"\w*, y nuestros padres, \w no|strong="H3808"\w* \w pusieron|strong="H6213"\w* \w por|strong="H4428"\w* \w obra|strong="H6213"\w* \w tu|strong="H6213"\w* \w ley|strong="H8451"\w*, \w ni|strong="H3808"\w* \w atendieron|strong="H7181"\w* \w a|strong="H3068"\w* tus \w mandamientos|strong="H4687"\w* y \w a|strong="H3068"\w* tus testimonios, con \w que|strong="H3808"\w* les amonestabas.   
\m
\v 35 \w Y|strong="H3068"\w* \w ellos|strong="H1992"\w*, en \w su|strong="H1992"\w* \w reino|strong="H4438"\w* y en \w los|strong="H1992"\w* \w muchos|strong="H7227"\w* bienes \w que|strong="H3808"\w* tú \w les|strong="H1992"\w* \w diste|strong="H5414"\w*, y en la tierra \w espaciosa|strong="H7342"\w* y fértil \w que|strong="H3808"\w* \w entregaste|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H1992"\w*, \w no|strong="H3808"\w* te \w sirvieron|strong="H5647"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* convirtieron \w de|strong="H6440"\w* \w sus|strong="H1992"\w* \w malas|strong="H7451"\w* \w obras|strong="H4611"\w*.   
\m
\v 36 He \w aquí|strong="H2009"\w*, \w hoy|strong="H3117"\w* somos \w siervos|strong="H5650"\w*, \w aquí|strong="H2009"\w* estamos, \add somos\add* \w siervos|strong="H5650"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* \w diste|strong="H5414"\w* \w a|strong="H3068"\w* nuestros padres \w para|strong="H5921"\w* \w que|strong="H5921"\w* comiesen su \w fruto|strong="H6529"\w* \w y|strong="H5921"\w* su \w bien|strong="H2898"\w*.   
\m
\v 37 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* \w multiplica|strong="H7235"\w* su \w fruto|strong="H8393"\w* \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w que|strong="H5921"\w* tú \w has|strong="H5414"\w* \w puesto|strong="H5414"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* nuestro \w pecado|strong="H2403"\w*. \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* \w se|strong="H5921"\w* enseñorean \w sobre|strong="H5921"\w* nuestros \w cuerpos|strong="H1472"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* nuestro ganado, \w como|strong="H5921"\w* \w les|strong="H5921"\w* place, \w y|strong="H5921"\w* estamos \w en|strong="H5921"\w* \w grande|strong="H1419"\w* \w angustia|strong="H6869"\w*.   
\m
\v 38 \w A|strong="H3068"\w* causa, pues, de todo eso nosotros hacemos fiel \add pacto\add*, y lo escribimos, firmado por nuestros príncipes, por nuestros levitas, y por nuestros sacerdotes.   
\c 10
\m
\v 1 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* firmaron \add fueron\add*, Nehemías \w el|strong="H5921"\w* Tirsata, hijo \w de|strong="H5921"\w* Hacalías, \w y|strong="H5921"\w* Sedequías,   
