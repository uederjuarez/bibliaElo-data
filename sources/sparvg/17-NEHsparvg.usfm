\m
\v 38 \w Y|strong="H3068"\w* \w que|strong="H1992"\w* estaría \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w*, hijo de Aarón, con \w los|strong="H1992"\w* \w levitas|strong="H3881"\w*, cuando \w los|strong="H1992"\w* \w levitas|strong="H3881"\w* recibirían \w el|strong="H3605"\w* diezmo: y \w que|strong="H1992"\w* \w los|strong="H1992"\w* \w levitas|strong="H3881"\w* llevarían \w el|strong="H3605"\w* diezmo del diezmo \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de nuestro Dios, \w a|strong="H3068"\w* \w las|strong="H1992"\w* \w cámaras|strong="H3957"\w* en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* del tesoro.   
\m
\v 39 Porque \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Israel y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Leví|strong="H3881"\w* llevarán la ofrenda \w del|strong="H5973"\w* grano, \w del|strong="H5973"\w* \w vino|strong="H1961"\w* nuevo y \w del|strong="H5973"\w* aceite \w a|strong="H3068"\w* las \w cámaras|strong="H3957"\w*, donde \w están|strong="H1961"\w* las vasos \w del|strong="H5973"\w* santuario, y \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H1121"\w* ministran, y \w los|strong="H1121"\w* porteros, y \w los|strong="H1121"\w* cantantes: y \w nosotros|strong="H5973"\w* \w no|strong="H1961"\w* abandonaremos la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* nuestro Dios.   
\c 11
\m
\v 1 \w Y|strong="H3068"\w* \w los|strong="H3427"\w* \w príncipes|strong="H8269"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w habitaron|strong="H3427"\w* \w en|strong="H4480"\w* Jerusalén; \w mas|strong="H4480"\w* \w el|strong="H5307"\w* resto \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w echó|strong="H5307"\w* \w suertes|strong="H1486"\w* \w para|strong="H4480"\w* traer uno \w de|strong="H4480"\w* \w diez|strong="H6235"\w* \w que|strong="H4480"\w* morase \w en|strong="H4480"\w* Jerusalén, \w ciudad|strong="H5892"\w* \w santa|strong="H6944"\w*, y las \w nueve|strong="H8672"\w* \w partes|strong="H3027"\w* \w en|strong="H4480"\w* las otras \w ciudades|strong="H5892"\w*.   
\m
