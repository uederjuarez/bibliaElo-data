\v 30 \w Jehová|strong="H3068"\w* vuestro \w Dios|strong="H3068"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w va|strong="H3068"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros, \w Él|strong="H1931"\w* \w peleará|strong="H3898"\w* \w por|strong="H6440"\w* vosotros, \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H1931"\w* \w hizo|strong="H6213"\w* \w por|strong="H6440"\w* vosotros en \w Egipto|strong="H4714"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vuestros \w ojos|strong="H5869"\w*;   
