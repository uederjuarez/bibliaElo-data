\v 1 Estas \add son\add* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w habló|strong="H1696"\w* \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* este \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w* en \w el|strong="H3605"\w* \w desierto|strong="H4057"\w*, en \w la|strong="H3605"\w* llanura frente al \add Mar\add* Rojo, entre \w Parán|strong="H6290"\w*, y Tofel, y \w Labán|strong="H3837"\w*, y Haserot y Dizahab.   
\m
\v 2 Once \w jornadas|strong="H3117"\w* \add hay\add* \w desde|strong="H5704"\w* \w Horeb|strong="H2722"\w*, \w camino|strong="H1870"\w* del \w monte|strong="H2022"\w* \w de|strong="H5704"\w* \w Seir|strong="H8165"\w*, \w hasta|strong="H5704"\w* \w Cades-barnea|strong="H6947"\w*.   
\m
\v 3 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* cuarenta \w años|strong="H8141"\w*, en \w el|strong="H3605"\w* \w mes|strong="H2320"\w* \w undécimo|strong="H6249"\w*, al primer \add día\add* del \w mes|strong="H2320"\w*, \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* conforme \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H1121"\w* \w Jehová|strong="H3068"\w* le \w había|strong="H1961"\w* \w mandado|strong="H6680"\w* \w acerca|strong="H1696"\w* \w de|strong="H1121"\w* \w ellos|strong="H3605"\w*;   
\m
\v 4 \w Después|strong="H3427"\w* que \w hirió|strong="H5221"\w* \w a|strong="H3068"\w* \w Sehón|strong="H5511"\w*, \w rey|strong="H4428"\w* de \w los|strong="H3427"\w* amorreos, que \w habitaba|strong="H3427"\w* \w en|strong="H5221"\w* \w Hesbón|strong="H2809"\w*, y \w a|strong="H3068"\w* \w Og|strong="H5747"\w*, \w rey|strong="H4428"\w* de \w Basán|strong="H1316"\w*, que \w habitaba|strong="H3427"\w* \w en|strong="H5221"\w* Astarot \w en|strong="H5221"\w* Edrei.   
\m
\v 5 De \w este|strong="H2063"\w* \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, en tierra de \w Moab|strong="H4124"\w*, comenzó \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* declarar \w esta|strong="H2063"\w* \w ley|strong="H8451"\w*, diciendo:   
\m
