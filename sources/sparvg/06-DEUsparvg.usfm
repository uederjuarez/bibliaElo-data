\m
\v 16 \w Y|strong="H3068"\w* \w entonces|strong="H6256"\w* \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* vuestros \w jueces|strong="H8199"\w*, diciendo: \w Oíd|strong="H8085"\w* \add las querellas\add* entre vuestros hermanos, y \w juzgad|strong="H8199"\w* \w justamente|strong="H6664"\w* entre \w el|strong="H1931"\w* hombre y \w su|strong="H1931"\w* hermano, y \w el|strong="H1931"\w* \w extranjero|strong="H1616"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* con \w él|strong="H1931"\w*.   
\m
\v 17 \w No|strong="H3808"\w* hagáis acepción \w de|strong="H4480"\w* personas \w en|strong="H4480"\w* \w el|strong="H1931"\w* \w juicio|strong="H4941"\w*; \w así|strong="H3588"\w* \w al|strong="H4480"\w* \w pequeño|strong="H6996"\w* \w como|strong="H3588"\w* \w al|strong="H4480"\w* \w grande|strong="H1419"\w* \w oiréis|strong="H8085"\w*: \w No|strong="H3808"\w* tendréis temor \w del|strong="H4480"\w* hombre, \w porque|strong="H3588"\w* \w el|strong="H1931"\w* \w juicio|strong="H4941"\w* \w es|strong="H1931"\w* \w de|strong="H4480"\w* Dios. \w Y|strong="H3068"\w* \w el|strong="H1931"\w* caso \w que|strong="H3588"\w* \w os|strong="H4480"\w* fuere difícil, \w lo|strong="H1931"\w* traeréis \w a|strong="H3068"\w* mí, \w y|strong="H3588"\w* \w yo|strong="H4480"\w* \w lo|strong="H1931"\w* \w oiré|strong="H8085"\w*.   
\m
\v 18 Os \w mandé|strong="H6680"\w*, \w pues|strong="H1931"\w*, en \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* habíais \w de|strong="H1697"\w* \w hacer|strong="H6213"\w*.   
