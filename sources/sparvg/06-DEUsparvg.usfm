\v 31 \w Y|strong="H3068"\w* \w en|strong="H5704"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w* has \w visto|strong="H7200"\w* \w que|strong="H5704"\w* \w Jehová|strong="H3068"\w* tu \w Dios|strong="H3068"\w* te ha traído, \w como|strong="H5704"\w* trae \w el|strong="H3605"\w* \w hombre|strong="H1121"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w*, \w por|strong="H1870"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w que|strong="H5704"\w* habéis \w andado|strong="H1980"\w*, \w hasta|strong="H5704"\w* llegar \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.   
