\m
\v 7 \w Volveos|strong="H6437"\w*, \w e|strong="H3068"\w* id \w a|strong="H3068"\w* \w la|strong="H3605"\w* montaña del amorreo, \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* sus ciudades vecinas, \w en|strong="H5704"\w* \w el|strong="H3605"\w* llano, \w en|strong="H5704"\w* \w los|strong="H3605"\w* collados, \w en|strong="H5704"\w* \w los|strong="H3605"\w* valles, \w en|strong="H5704"\w* \w el|strong="H3605"\w* sur, \w en|strong="H5704"\w* \w la|strong="H3605"\w* costa del \w mar|strong="H3220"\w*, \w en|strong="H5704"\w* \w la|strong="H3605"\w* tierra del \w cananeo|strong="H3669"\w* \w y|strong="H5704"\w* \w el|strong="H3605"\w* \w Líbano|strong="H3844"\w*, \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w gran|strong="H1419"\w* \w río|strong="H5104"\w*, \w el|strong="H3605"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*.   
\m
\v 8 \w Mirad|strong="H7200"\w*, yo he \w puesto|strong="H5414"\w* la tierra \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros; entrad y poseed la tierra que \w Jehová|strong="H3068"\w* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* vuestros padres Abraham, \w Isaac|strong="H3327"\w* y \w Jacob|strong="H3290"\w*, que les \w daría|strong="H5414"\w* \w a|strong="H3068"\w* ellos y \w a|strong="H3068"\w* su \w simiente|strong="H2233"\w* después \w de|strong="H6440"\w* ellos.   
\m
\v 9 \w Y|strong="H3068"\w* yo os hablé \w entonces|strong="H6256"\w*, diciendo: Yo \w solo|strong="H1931"\w* \w no|strong="H3808"\w* \w puedo|strong="H3201"\w* \w llevaros|strong="H5375"\w*.   
\m
\v 10 \w Jehová|strong="H3068"\w* vuestro \w Dios|strong="H3068"\w* os ha multiplicado, y he \w aquí|strong="H2009"\w* \w hoy|strong="H3117"\w* vosotros \add sois\add* como las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w* en \w multitud|strong="H7230"\w*.   
\m
\v 11 ¡\w Jehová|strong="H3068"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* vuestros padres \w os|strong="H5921"\w* haga mil \w veces|strong="H6471"\w* \w más|strong="H3254"\w* \w de|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* sois, \w y|strong="H5921"\w* \w os|strong="H5921"\w* \w bendiga|strong="H1288"\w*, \w como|strong="H5921"\w* \w os|strong="H5921"\w* ha prometido!   
\m
\v 12 ¿Cómo \w llevaré|strong="H5375"\w* yo solo vuestras molestias, vuestras cargas y vuestros pleitos?   
\m
\v 13 \w Dadme|strong="H3051"\w* de entre vosotros, de vuestras \w tribus|strong="H7626"\w*, varones \w sabios|strong="H2450"\w* y \w entendidos|strong="H3045"\w* y expertos, para \w que|strong="H3045"\w* yo \w los|strong="H2450"\w* \w ponga|strong="H7760"\w* por vuestros \w jefes|strong="H7218"\w*.   
\m
\v 14 \w Y|strong="H3068"\w* me \w respondisteis|strong="H6030"\w*, y dijisteis: \w Bueno|strong="H2896"\w* \add es\add* \w hacer|strong="H6213"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* has \w dicho|strong="H1696"\w*.   
\m
