\v 6 \w Subió|strong="H5927"\w*, pues, \w Salomón|strong="H8010"\w* \w allá|strong="H8033"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Jehová|strong="H3068"\w*, \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* bronce \w que|strong="H5921"\w* \add estaba\add* \w en|strong="H5921"\w* \w el|strong="H5921"\w* tabernáculo \w de|strong="H5921"\w* \w la|strong="H5921"\w* congregación, \w y|strong="H5921"\w* \w ofreció|strong="H5927"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* mil \w holocaustos|strong="H5930"\w*.   
