\m
\v 11 \w Y|strong="H3068"\w* dijo Dios \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*: \w Por|strong="H5921"\w* \w cuanto|strong="H3282"\w* \w esto|strong="H2063"\w* \w fue|strong="H1961"\w* \w en|strong="H5921"\w* \w tu|strong="H8199"\w* \w corazón|strong="H3824"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w pediste|strong="H7592"\w* \w riquezas|strong="H6239"\w*, \w ni|strong="H3808"\w* posesiones, \w ni|strong="H3808"\w* \w gloria|strong="H3519"\w*, \w ni|strong="H3808"\w* \w la|strong="H5921"\w* \w vida|strong="H5315"\w* \w de|strong="H5921"\w* tus \w enemigos|strong="H8130"\w*, \w ni|strong="H3808"\w* \w pediste|strong="H7592"\w* larga \w vida|strong="H5315"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w has|strong="H4427"\w* pedido \w para|strong="H5921"\w* \w ti|strong="H5921"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H1571"\w* entendimiento \w para|strong="H5921"\w* \w gobernar|strong="H8199"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w cual|strong="H5315"\w* \w te|strong="H5921"\w* he puesto \w por|strong="H5921"\w* \w rey|strong="H4427"\w*,   
\m
\v 12 \w sabiduría|strong="H2451"\w* \w y|strong="H3519"\w* entendimiento te \w son|strong="H1961"\w* \w dados|strong="H5414"\w*; \w y|strong="H3519"\w* \w también|strong="H3651"\w* te \w daré|strong="H5414"\w* \w riquezas|strong="H6239"\w*, posesiones \w y|strong="H3519"\w* \w gloria|strong="H3519"\w*, cual \w nunca|strong="H3808"\w* \w hubo|strong="H1961"\w* en \w los|strong="H1961"\w* \w reyes|strong="H4428"\w* \w que|strong="H3808"\w* \add han sido\add* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* ti, \w ni|strong="H3808"\w* \w después|strong="H1961"\w* \w de|strong="H6440"\w* ti \w habrá|strong="H1961"\w*.   
\m
\v 13 \w Y|strong="H3068"\w* volvió \w Salomón|strong="H8010"\w* \w a|strong="H3068"\w* Jerusalén \w del|strong="H5921"\w* lugar alto \w que|strong="H5921"\w* \add estaba\add* \w en|strong="H5921"\w* \w Gabaón|strong="H1391"\w*, \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* tabernáculo \w de|strong="H5921"\w* \w la|strong="H5921"\w* congregación; \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\m
\v 14 \w Y|strong="H3068"\w* reunió \w Salomón|strong="H8010"\w* \w carros|strong="H7393"\w* y gente \w de|strong="H5973"\w* \w a|strong="H3068"\w* caballo; y \w tenía|strong="H1961"\w* \w mil|strong="H3967"\w* cuatrocientos \w carros|strong="H7393"\w*, y \w doce|strong="H8147"\w* \w mil|strong="H3967"\w* \w jinetes|strong="H6571"\w*, \w los|strong="H5973"\w* cuales \w puso|strong="H3240"\w* \w en|strong="H5973"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w carros|strong="H7393"\w*, y \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* \w en|strong="H5973"\w* Jerusalén.   
\m
\v 15 \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* acumuló \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w* en Jerusalén como piedras, y cedro en \w abundancia|strong="H7230"\w* como los sicómoros que \add hay\add* en los valles.   
\m
\v 16 \w Y|strong="H3068"\w* \w Salomón|strong="H8010"\w* tenía \w caballos|strong="H5483"\w* y lienzos finos traídos de \w Egipto|strong="H4714"\w*; pues los \w mercaderes|strong="H5503"\w* del \w rey|strong="H4428"\w* adquirían los lienzos finos \w por|strong="H4428"\w* \w precio|strong="H4242"\w*.   
\m
\v 17 \w Y|strong="H3068"\w* \w subían|strong="H5927"\w*, y compraban \w en|strong="H3318"\w* \w Egipto|strong="H4714"\w*, un \w carro|strong="H4818"\w* \w por|strong="H3027"\w* \w seiscientas|strong="H8337"\w* \add piezas\add* de \w plata|strong="H3701"\w*, y un \w caballo|strong="H5483"\w* \w por|strong="H3027"\w* \w ciento|strong="H3967"\w* \w cincuenta|strong="H2572"\w*; y \w así|strong="H3651"\w* \w se|strong="H3651"\w* compraban \w por|strong="H3027"\w* \w medio|strong="H3027"\w* de \w ellos|strong="H3027"\w* para \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de \w los|strong="H3605"\w* heteos, y para \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de Siria.   
\c 2
\m
\v 1 Determinó, pues, \w Salomón|strong="H8010"\w* edificar casa \w al|strong="H5921"\w* nombre \w de|strong="H5921"\w* Jehová, \w y|strong="H5921"\w* una casa \w para|strong="H5921"\w* su reino.   
\m
\v 2 \w Y|strong="H3068"\w* contó \w Salomón|strong="H8010"\w* setenta mil hombres \w para|strong="H5973"\w* llevar cargas, y ochenta mil hombres \w para|strong="H5973"\w* cortar \w en|strong="H5973"\w* la montaña, y tres mil seiscientos \w para|strong="H5973"\w* supervisarlos.   
\m
\v 3 \w Y|strong="H3068"\w* envió \w a|strong="H3068"\w* decir Salomón \w a|strong="H3068"\w* Hiram rey \w de|strong="H5921"\w* Tiro: Haz conmigo \w como|strong="H5921"\w* hiciste \w con|strong="H5921"\w* David \w mi|strong="H5921"\w* padre, enviándole cedros \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w edificara|strong="H1129"\w* \w para|strong="H5921"\w* \w sí|strong="H6440"\w* una \w casa|strong="H1004"\w* \w donde|strong="H5921"\w* morar.   
\m
\v 4 He aquí \w yo|strong="H3588"\w* \w edifico|strong="H1129"\w* \w casa|strong="H1004"\w* al nombre \w de|strong="H3588"\w* Jehová mi Dios, \w para|strong="H3588"\w* consagrársela, \w para|strong="H3588"\w* quemar incienso aromático delante \w de|strong="H3588"\w* \w Él|strong="H3588"\w*, \w y|strong="H3588"\w* \w para|strong="H3588"\w* \w la|strong="H3588"\w* colocación continua \w de|strong="H3588"\w* \w los|strong="H3605"\w* panes \w de|strong="H3588"\w* \w la|strong="H3588"\w* proposición, \w y|strong="H3588"\w* \w para|strong="H3588"\w* holocaustos \w a|strong="H3068"\w* mañana \w y|strong="H3588"\w* tarde, \w y|strong="H3588"\w* \w los|strong="H3605"\w* sábados, \w y|strong="H3588"\w* lunas nuevas, \w y|strong="H3588"\w* festividades \w de|strong="H3588"\w* Jehová nuestro Dios. Esto \add será ordenanza\add* perpetua \w en|strong="H3588"\w* Israel.   
\m
\v 5 \w Y|strong="H3068"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \add que voy a\add* \w edificar|strong="H1129"\w* \add será\add* grande; \w porque|strong="H3588"\w* nuestro Dios \add es\add* grande sobre todos \w los|strong="H3588"\w* dioses.   
\m
\v 6 Pero ¿\w Quién|strong="H6213"\w* podrá edificarle casa, siendo \w que|strong="H6258"\w* \w el|strong="H5973"\w* cielo, y \w el|strong="H5973"\w* cielo \w de|strong="H5973"\w* \w los|strong="H5973"\w* cielos \w no|strong="H6213"\w* \w le|strong="H5973"\w* pueden contener? ¿\w Quién|strong="H6213"\w*, \w pues|strong="H6258"\w*, soy \w yo|strong="H6213"\w*, \w para|strong="H5973"\w* \w que|strong="H6258"\w* \w le|strong="H5973"\w* edifique casa, aunque sólo sea \w para|strong="H5973"\w* quemar incienso \w delante|strong="H5973"\w* \w de|strong="H5973"\w* \w Él|strong="H5973"\w*?   
\m
\v 7 \w Envíame|strong="H7971"\w*, \w pues|strong="H3588"\w*, \w ahora|strong="H2009"\w* un hombre hábil \w que|strong="H3588"\w* \w sepa|strong="H3045"\w* trabajar \w en|strong="H5973"\w* oro, \w en|strong="H5973"\w* plata, \w en|strong="H5973"\w* bronce, \w en|strong="H5973"\w* hierro, \w en|strong="H5973"\w* púrpura, \w en|strong="H5973"\w* grana \w y|strong="H3588"\w* \w en|strong="H5973"\w* azul, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w sepa|strong="H3045"\w* esculpir \w con|strong="H5973"\w* \w los|strong="H5973"\w* maestros \w que|strong="H3588"\w* \add están\add* \w conmigo|strong="H5973"\w* \w en|strong="H5973"\w* Judá \w y|strong="H3588"\w* \w en|strong="H5973"\w* Jerusalén, \w los|strong="H5973"\w* cuales dispuso \w mi|strong="H2009"\w* padre.   
\m
\v 8 Envíame también del Líbano, \w madera|strong="H6086"\w* \w de|strong="H3588"\w* cedro, \w de|strong="H3588"\w* abeto \w y|strong="H3588"\w* \w de|strong="H3588"\w* sándalo; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* sé \w que|strong="H3588"\w* tus siervos saben cortar \w madera|strong="H6086"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* Líbano; \w y|strong="H3588"\w* he aquí, mis siervos \add estarán\add* \w con|strong="H3588"\w* tus siervos,   
\m
\v 9 \w para|strong="H5414"\w* que me preparen mucha \w madera|strong="H6086"\w*, \w porque|strong="H2009"\w* la casa que voy \w a|strong="H3068"\w* edificar \add será\add* grande y portentosa.   
\m
\v 10 \w Y|strong="H3068"\w* he aquí, \w daré|strong="H5414"\w* \w a|strong="H3068"\w* tus siervos, \w los|strong="H5921"\w* cortadores \w de|strong="H5921"\w* madera, veinte mil coros \w de|strong="H5921"\w* trigo \w en|strong="H5921"\w* grano, \w y|strong="H5921"\w* veinte mil coros \w de|strong="H5921"\w* cebada, \w y|strong="H5921"\w* veinte mil batos \w de|strong="H5921"\w* vino \w y|strong="H5921"\w* veinte mil batos \w de|strong="H5921"\w* aceite.   
\m
\v 11 Entonces \w Hiram|strong="H2361"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Tiro, respondió \w por|strong="H5414"\w* un escrito \w que|strong="H3045"\w* envió \w a|strong="H3068"\w* \w Salomón|strong="H4428"\w*: \w Porque|strong="H1732"\w* \w Jehová|strong="H3068"\w* amó \w a|strong="H3068"\w* su pueblo, te ha \w puesto|strong="H5414"\w* \w por|strong="H5414"\w* \w rey|strong="H4428"\w* sobre ellos.   
\m
\v 12 \w Y|strong="H3068"\w* además decía \w Hiram|strong="H2361"\w*: Bendito sea Jehová, el Dios de Israel, \w que|strong="H6258"\w* hizo el cielo y la tierra, y \w que|strong="H6258"\w* dio al rey David hijo \w sabio|strong="H2450"\w*, \w entendido|strong="H3045"\w*, cuerdo y prudente, \w que|strong="H6258"\w* edifique casa \w a|strong="H3068"\w* Jehová, y casa \w para|strong="H6258"\w* su reino.   
\m
\v 13 \w Yo|strong="H4480"\w*, \w pues|strong="H4480"\w*, \w te|strong="H4480"\w* he enviado un \w hombre|strong="H1121"\w* \w hábil|strong="H2450"\w* y \w entendido|strong="H3045"\w*, \w que|strong="H4480"\w* fue \w de|strong="H4480"\w* Hiram mi padre,   
\m
\v 14 hijo de una mujer de las hijas de Dan, \w mas|strong="H6258"\w* su padre \add era\add* un hombre de Tiro; el cual es hábil \w para|strong="H6258"\w* trabajar en oro y en plata, en bronce, en hierro, en piedra, en madera, en púrpura, en azul, en lino fino y en carmesí; también \w para|strong="H6258"\w* esculpir toda clase de figuras, y sacar toda forma de diseño \w que|strong="H6258"\w* se le propusiere, y estará con tus hombres peritos y con los de mi señor David tu padre.   
\m
\v 15 Ahora, \w pues|strong="H4480"\w*, envíe \w mi|strong="H5921"\w* señor \w a|strong="H3068"\w* sus siervos \w el|strong="H5921"\w* trigo, \w la|strong="H5921"\w* cebada, \w el|strong="H5921"\w* aceite \w y|strong="H5921"\w* \w el|strong="H5921"\w* vino \w que|strong="H4480"\w* ha dicho;   
\m
\v 16 y \w nosotros|strong="H3605"\w* cortaremos en \w el|strong="H3605"\w* Líbano \w la|strong="H3605"\w* madera \w que|strong="H1616"\w* necesites, y te \w la|strong="H3605"\w* traeremos en balsas por \w el|strong="H3605"\w* mar hasta Jope, y tú \w la|strong="H3605"\w* harás llevar hasta Jerusalén.   
\m
\v 17 \w Y|strong="H3068"\w* contó Salomón todos \w los|strong="H1992"\w* hombres extranjeros \w que|strong="H5971"\w* \add estaban\add* en la tierra \w de|strong="H5971"\w* Israel, después \w de|strong="H5971"\w* haberlos ya contado David \w su|strong="H1992"\w* padre, y fueron hallados \w ciento|strong="H3967"\w* cincuenta y \w tres|strong="H7969"\w* \w mil|strong="H3967"\w* \w seiscientos|strong="H8337"\w*.   
\m
\v 18 \w Y|strong="H3068"\w* señaló de ellos setenta mil cargadores, y ochenta mil canteros en la montaña, y tres mil seiscientos supervisores para hacer trabajar al pueblo.   
\c 3
\m
