\m
\v 6 \w Y|strong="H3068"\w* \w ellos|strong="H4480"\w* le \w respondieron|strong="H1696"\w*: \w Encontramos|strong="H7125"\w* un varón \w que|strong="H3588"\w* \w nos|strong="H4480"\w* \w dijo|strong="H1696"\w*: \w Id|strong="H3212"\w*, \w y|strong="H3588"\w* \w volveos|strong="H7725"\w* \w al|strong="H4480"\w* \w rey|strong="H4428"\w* \w que|strong="H3588"\w* \w os|strong="H4480"\w* \w envió|strong="H7971"\w*, \w y|strong="H3588"\w* \w decidle|strong="H1696"\w*: \w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w Jehová|strong="H3068"\w*: ¿Acaso \w no|strong="H3808"\w* \add hay\add* \w Dios|strong="H3068"\w* \w en|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w que|strong="H3588"\w* tú \w envías|strong="H7971"\w* \w a|strong="H3068"\w* consultar \w a|strong="H3068"\w* Baal-zebub, \w dios|strong="H3068"\w* \w de|strong="H4480"\w* \w Ecrón|strong="H6138"\w*? \w Por|strong="H3588"\w* \w tanto|strong="H3651"\w*, \w del|strong="H4480"\w* lecho \w en|strong="H4480"\w* \w que|strong="H3588"\w* \w subiste|strong="H5927"\w* \w no|strong="H3808"\w* \w descenderás|strong="H3381"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w de|strong="H4480"\w* \w cierto|strong="H3588"\w* \w morirás|strong="H4191"\w*.   
