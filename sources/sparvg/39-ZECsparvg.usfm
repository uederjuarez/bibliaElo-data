\mt1 Zacarías  
\c 1
\m
\v 1 En \w el|strong="H1121"\w* \w mes|strong="H2320"\w* \w octavo|strong="H8066"\w*, en \w el|strong="H1121"\w* \w año|strong="H8141"\w* \w segundo|strong="H8147"\w* \w de|strong="H1121"\w* \w Darío|strong="H1867"\w*, \w vino|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* \w Jehová|strong="H3068"\w* al \w profeta|strong="H5030"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Iddo|strong="H5714"\w*, diciendo:   
\m
\v 2 \w Jehová|strong="H3068"\w* \w está|strong="H5921"\w* muy \w enojado|strong="H7107"\w* \w contra|strong="H5921"\w* vuestros padres.   
\m
\v 3 Por tanto, diles: \w Así|strong="H3541"\w* \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w* de los \w ejércitos|strong="H6635"\w*: \w Volveos|strong="H7725"\w* \w a|strong="H3068"\w* mí, \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w* de los \w ejércitos|strong="H6635"\w*, \w y|strong="H3541"\w* yo \w me|strong="H3541"\w* \w volveré|strong="H7725"\w* \w a|strong="H3068"\w* vosotros, \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w* de los \w ejércitos|strong="H6635"\w*.   
\m
\v 4 \w No|strong="H3808"\w* \w seáis|strong="H1961"\w* \w como|strong="H1961"\w* vuestros padres, \w a|strong="H3068"\w* \w los|strong="H1961"\w* cuales hablaron \w los|strong="H1961"\w* antiguos \w profetas|strong="H5030"\w*, diciendo: \w Así|strong="H3541"\w* \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w* \w de|strong="H7451"\w* \w los|strong="H1961"\w* \w ejércitos|strong="H6635"\w*: \w Volveos|strong="H7725"\w* \w ahora|strong="H4994"\w* \w de|strong="H7451"\w* vuestros \w malos|strong="H7451"\w* \w caminos|strong="H1870"\w*, \w y|strong="H3541"\w* \add de\add* vuestras \w malas|strong="H7451"\w* \w obras|strong="H4611"\w*; pero \w no|strong="H3808"\w* \w atendieron|strong="H7181"\w*, \w ni|strong="H3808"\w* \w me|strong="H3541"\w* \w escucharon|strong="H8085"\w*, \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w*.   
\m
\v 5 Vuestros padres, ¿dónde están? \w Y|strong="H3068"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* ¿han de \w vivir|strong="H2421"\w* para \w siempre|strong="H5769"\w*?   
\m
\v 6 Pero mis \w palabras|strong="H1697"\w* y mis \w ordenanzas|strong="H2706"\w* \w que|strong="H3808"\w* \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* mis \w siervos|strong="H5650"\w* los \w profetas|strong="H5030"\w*, ¿\w no|strong="H3808"\w* \w alcanzaron|strong="H5381"\w* \w a|strong="H3068"\w* vuestros padres? \w Y|strong="H3068"\w* ellos \w se|strong="H3808"\w* \w volvieron|strong="H7725"\w* y \w dijeron|strong="H1697"\w*: \w Así|strong="H3651"\w* \w como|strong="H3651"\w* \w Jehová|strong="H3068"\w* \w de|strong="H1697"\w* los \w ejércitos|strong="H6635"\w* \w pensó|strong="H2161"\w* \w hacer|strong="H6213"\w* con nosotros conforme \w a|strong="H3068"\w* nuestros \w caminos|strong="H1870"\w* y conforme \w a|strong="H3068"\w* nuestras \w obras|strong="H4611"\w*, \w así|strong="H3651"\w* \w ha|strong="H3808"\w* \w hecho|strong="H6213"\w* con nosotros.   
\m
\v 7 \w El|strong="H1931"\w* \w día|strong="H3117"\w* \w veinticuatro|strong="H6242"\w* del \w mes|strong="H2320"\w* \w undécimo|strong="H6249"\w*, \w que|strong="H1931"\w* \add es\add* \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w de|strong="H1121"\w* Sebat, en \w el|strong="H1931"\w* \w año|strong="H8141"\w* \w segundo|strong="H8147"\w* \w de|strong="H1121"\w* \w Darío|strong="H1867"\w*, \w vino|strong="H1961"\w* \w la|strong="H1931"\w* \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* \w Jehová|strong="H3068"\w* al \w profeta|strong="H5030"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Iddo|strong="H5714"\w*, diciendo:   
\m
\v 8 \w Vi|strong="H7200"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* un varón \w que|strong="H1931"\w* \w cabalgaba|strong="H7392"\w* \w sobre|strong="H5921"\w* un \w caballo|strong="H5483"\w* alazán, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w estaba|strong="H5975"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* mirtos \w que|strong="H1931"\w* \add había\add* \w en|strong="H5921"\w* \w la|strong="H1931"\w* hondura; \w y|strong="H5921"\w* detrás \w de|strong="H5921"\w* \w él|strong="H1931"\w* \add había\add* \w caballos|strong="H5483"\w* alazanes, overos \w y|strong="H5921"\w* \w blancos|strong="H3836"\w*.   
\m
\v 9 Entonces \w dije|strong="H1696"\w*: ¿\w Qué|strong="H4100"\w* \add son\add* \w estos|strong="H1992"\w*, Señor mío? \w Y|strong="H3068"\w* me \w dijo|strong="H1696"\w* \w el|strong="H1992"\w* \w Ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo: Yo te enseñaré \w qué|strong="H4100"\w* son \w éstos|strong="H1992"\w*.   
\m
\v 10 \w Y|strong="H3068"\w* aquel varón que \w estaba|strong="H5975"\w* entre los mirtos \w respondió|strong="H6030"\w*, y dijo: Estos \add son\add* los que \w Jehová|strong="H3068"\w* ha \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* recorrer la tierra.   
\m
\v 11 \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* \w respondieron|strong="H6030"\w* al \w Ángel|strong="H4397"\w* de \w Jehová|strong="H3068"\w* \w que|strong="H3605"\w* \w estaba|strong="H5975"\w* entre \w los|strong="H3427"\w* mirtos, y dijeron: Hemos recorrido \w la|strong="H3605"\w* tierra, y he \w aquí|strong="H2009"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w está|strong="H5975"\w* reposada y quieta.   
\m
\v 12 \w Y|strong="H3068"\w* \w respondió|strong="H6030"\w* el \w Ángel|strong="H4397"\w* \w de|strong="H5704"\w* \w Jehová|strong="H3068"\w*, \w y|strong="H5704"\w* dijo: Oh \w Jehová|strong="H3068"\w* \w de|strong="H5704"\w* los \w ejércitos|strong="H6635"\w*, ¿\w hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* \w no|strong="H3808"\w* tendrás piedad \w de|strong="H5704"\w* Jerusalén, \w y|strong="H5704"\w* \w de|strong="H5704"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w con|strong="H5704"\w* las cuales has estado indignado \w estos|strong="H2088"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*?   
\m
\v 13 \w Y|strong="H3068"\w* \w Jehová|strong="H3068"\w* \w respondió|strong="H6030"\w* \w buenas|strong="H2896"\w* \w palabras|strong="H1697"\w*, \w palabras|strong="H1697"\w* consoladoras, al \w Ángel|strong="H4397"\w* \w que|strong="H1697"\w* \w hablaba|strong="H1696"\w* conmigo.   
\m
\v 14 \w Y|strong="H3068"\w* \w me|strong="H3541"\w* \w dijo|strong="H1696"\w* el \w Ángel|strong="H4397"\w* \w que|strong="H3541"\w* \w hablaba|strong="H1696"\w* conmigo: \w Clama|strong="H7121"\w*, \w diciendo|strong="H1696"\w*: \w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w Jehová|strong="H3068"\w* de los \w ejércitos|strong="H6635"\w*: \w Celé|strong="H7065"\w* \w a|strong="H3068"\w* Jerusalén \w y|strong="H3541"\w* \w a|strong="H3068"\w* \w Sión|strong="H6726"\w* \w con|strong="H7065"\w* \w gran|strong="H1419"\w* \w celo|strong="H7068"\w*:   
\m
\v 15 \w Y|strong="H3068"\w* estoy muy indignado \w contra|strong="H5921"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w* \w que|strong="H5921"\w* \add están\add* \w reposadas|strong="H7600"\w*; \w porque|strong="H5921"\w* \add cuando\add* yo estaba \w enojado|strong="H7107"\w* un \w poco|strong="H4592"\w*, \w ellos|strong="H1992"\w* \w ayudaron|strong="H5826"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w*.   
\m
\v 16 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w*: Yo \w me|strong="H5921"\w* he \w vuelto|strong="H7725"\w* \w a|strong="H3068"\w* Jerusalén \w con|strong="H5921"\w* misericordia; \w en|strong="H5921"\w* \w ella|strong="H5921"\w* será \w edificada|strong="H1129"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w*, \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w ejércitos|strong="H6635"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* cordel será tendido \w sobre|strong="H5921"\w* Jerusalén.   
\m
\v 17 \w Clama|strong="H7121"\w* \w aún|strong="H5750"\w*, diciendo: \w Así|strong="H3541"\w* dice \w Jehová|strong="H3068"\w* \w de|strong="H5750"\w* los \w ejércitos|strong="H6635"\w*: \w Aún|strong="H5750"\w* serán ensanchadas mis \w ciudades|strong="H5892"\w* \w por|strong="H5750"\w* la abundancia del \w bien|strong="H2896"\w*; \w y|strong="H3541"\w* \w aún|strong="H5750"\w* \w consolará|strong="H5162"\w* \w Jehová|strong="H3068"\w* \w a|strong="H3068"\w* \w Sión|strong="H6726"\w*, \w y|strong="H3541"\w* escogerá \w todavía|strong="H5750"\w* \w a|strong="H3068"\w* Jerusalén.   
\m
\v 18 Después alcé mis ojos y miré, y he aquí cuatro cuernos.   
\m
\v 19 \w Y|strong="H3068"\w* dije al ángel que hablaba conmigo: ¿Qué \add son\add* estos? \w Y|strong="H3068"\w* me respondió: Estos \add son\add* los cuernos que dispersaron \w a|strong="H3068"\w* Judá, \w a|strong="H3068"\w* Israel y \w a|strong="H3068"\w* Jerusalén.   
\m
\v 20 \w Y|strong="H3068"\w* Jehová me mostró cuatro carpinteros.   
\m
\v 21 \w Y|strong="H3068"\w* yo dije: ¿Qué vienen \w a|strong="H3068"\w* hacer estos? \w Y|strong="H3068"\w* me respondió, diciendo: Estos \add son\add* los cuernos que dispersaron \w a|strong="H3068"\w* Judá, tanto que ninguno alzó su cabeza; mas estos han venido para hacerlos temblar, para derribar los cuernos de las naciones, que alzaron el cuerno sobre la tierra de Judá para dispersarla.   
\c 2
\m
\v 1 \w Alcé|strong="H5375"\w* otra vez \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w*, y \w miré|strong="H7200"\w* y he \w aquí|strong="H2009"\w* un varón que tenía en su mano un cordel \w de|strong="H5869"\w* medir.   
\m
\v 2 \w Y|strong="H3068"\w* le \w dije|strong="H1696"\w*: ¿\w A|strong="H3068"\w* dónde vas? \w Y|strong="H3068"\w* Él me respondió: \w A|strong="H3068"\w* medir \w a|strong="H3068"\w* Jerusalén, para ver \w cuánta|strong="H4100"\w* \add es su\add* anchura, y \w cuánta|strong="H4100"\w* \add su\add* longitud.   
\m
\v 3 \w Y|strong="H3068"\w* he aquí, salía aquel Ángel que hablaba conmigo, y otro ángel le salió al encuentro,   
\m
\v 4 y le dijo: Corre, habla \w a|strong="H3068"\w* este joven, diciendo: \w Sin|strong="H3808"\w* muros \w será|strong="H3808"\w* habitada Jerusalén \w a|strong="H3068"\w* causa de la multitud de hombres y de ganado en medio de ella.   
\m
\v 5 \w Yo|strong="H2009"\w* seré para ella, dice Jehová, muro \w de|strong="H5869"\w* fuego en derredor, y seré la gloria en \w medio|strong="H3027"\w* \w de|strong="H5869"\w* ella.   
\m
\v 6 ¡Eh, \w eh|strong="H3068"\w*!, salid y huid de la tierra del norte, dice Jehová, \w porque|strong="H4100"\w* yo os he esparcido \w como|strong="H4100"\w* los cuatro vientos del cielo, dice Jehová.   
\m
\v 7 Oh Sión, la que moras \add con\add* la hija de Babilonia, escápate.   
\m
\v 8 Porque \w así|strong="H1696"\w* \w dice|strong="H1696"\w* Jehová de \w los|strong="H3427"\w* ejércitos: \w Después|strong="H3427"\w* de la gloria \w Él|strong="H3427"\w* me ha enviado \w a|strong="H3068"\w* las naciones que os despojaron; porque \w el|strong="H3427"\w* que os toca, toca \w a|strong="H3068"\w* la niña de su ojo.   
\m
\v 9 Porque he aquí yo alzo \w mi|strong="H1961"\w* mano \w sobre|strong="H1961"\w* ellos, \w y|strong="H3519"\w* \w serán|strong="H1961"\w* despojo \w a|strong="H3068"\w* sus siervos, \w y|strong="H3519"\w* sabréis \w que|strong="H1961"\w* \w Jehová|strong="H3068"\w* de \w los|strong="H1961"\w* ejércitos me ha enviado.   
\m
\v 10 Canta \w y|strong="H3588"\w* alégrate, hija \w de|strong="H3588"\w* Sión: \w porque|strong="H3588"\w* he aquí vengo, \w y|strong="H3588"\w* moraré \w en|strong="H3588"\w* medio \w de|strong="H3588"\w* ti, \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w*.   
\m
\v 11 \w Y|strong="H3068"\w* muchas naciones se unirán \w a|strong="H3068"\w* Jehová en aquel día, y serán mi pueblo, y \w moraré|strong="H3427"\w* en medio de ti; y entonces conocerás \w que|strong="H1323"\w* Jehová de \w los|strong="H3427"\w* ejércitos me ha enviado \w a|strong="H3068"\w* ti.   
\m
\v 12 \w Y|strong="H3068"\w* \w Jehová|strong="H3068"\w* poseerá \w a|strong="H3068"\w* Judá, \w su|strong="H3588"\w* porción \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra santa, \w y|strong="H3588"\w* escogerá \w aún|strong="H3588"\w* \w a|strong="H3068"\w* Jerusalén.   
\m
\v 13 Calle \w toda|strong="H5921"\w* carne \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w Jehová|strong="H3068"\w*, \w porque|strong="H3588"\w* \w Él|strong="H5921"\w* \w se|strong="H3045"\w* ha levantado \w de|strong="H5921"\w* \w su|strong="H3588"\w* santa habitación.   
\c 3
\m
\v 1 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* \w mostró|strong="H7200"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w el|strong="H5921"\w* \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w*, \w el|strong="H5921"\w* cual \w estaba|strong="H5975"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* \w Jehová|strong="H3068"\w*; \w y|strong="H5921"\w* Satanás \w estaba|strong="H5975"\w* \w a|strong="H3068"\w* su mano \w derecha|strong="H3225"\w* \w para|strong="H5921"\w* acusarle.   
\m
\v 2 \w Y|strong="H3068"\w* \w Jehová|strong="H3068"\w* dijo \w a|strong="H3068"\w* Satanás: \w Jehová|strong="H3068"\w* te reprenda, oh Satanás; \w Jehová|strong="H3068"\w* \w que|strong="H3808"\w* \w ha|strong="H3808"\w* escogido \w a|strong="H3068"\w* Jerusalén te reprenda; ¿\w No|strong="H3808"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* un tizón \w arrebatado|strong="H5337"\w* del fuego?   
\m
\v 3 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* \w estaba|strong="H1961"\w* \w vestido|strong="H3847"\w* \w de|strong="H6440"\w* vestiduras \w viles|strong="H6674"\w*, y \w estaba|strong="H1961"\w* \w delante|strong="H6440"\w* del \w Ángel|strong="H4397"\w*.   
\m
\v 4 \w Y|strong="H3068"\w* \w habló|strong="H6030"\w* \w el|strong="H5921"\w* \add Ángel\add*, \w y|strong="H5921"\w* mandó \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w estaban|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Él|strong="H5921"\w*, diciendo: \w Quitadle|strong="H5493"\w* esas vestiduras \w viles|strong="H6674"\w*. \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* dijo: \w Mira|strong="H7200"\w* \w que|strong="H5921"\w* he hecho \w pasar|strong="H5674"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* tu \w pecado|strong="H5771"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w vestiré|strong="H3847"\w* \w con|strong="H5921"\w* ropas \w de|strong="H5921"\w* \w gala|strong="H4254"\w*.   
\m
\v 5 \w Después|strong="H5921"\w* dijo: \w Pongan|strong="H7760"\w* \w mitra|strong="H6797"\w* \w limpia|strong="H2889"\w* \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*. \w Y|strong="H3068"\w* \w pusieron|strong="H7760"\w* una \w mitra|strong="H6797"\w* \w limpia|strong="H2889"\w* \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*, \w y|strong="H5921"\w* \w le|strong="H5921"\w* vistieron \w las|strong="H5921"\w* ropas. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* \w Jehová|strong="H3068"\w* \w estaba|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w*.   
\m
\v 6 \w Y|strong="H3068"\w* el \w Ángel|strong="H4397"\w* de \w Jehová|strong="H3068"\w* amonestó \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, diciendo:   
\m
\v 7 \w Así|strong="H3541"\w* dice \w Jehová|strong="H3068"\w* \w de|strong="H5414"\w* los \w ejércitos|strong="H6635"\w*: \w Si|strong="H1571"\w* \w anduvieres|strong="H3212"\w* \w por|strong="H1870"\w* \w mis|strong="H5414"\w* \w caminos|strong="H1870"\w*, \w y|strong="H1571"\w* \w si|strong="H1571"\w* \w guardares|strong="H8104"\w* mi \w ordenanza|strong="H4931"\w*, \w también|strong="H1571"\w* tú gobernarás mi \w casa|strong="H1004"\w*, \w también|strong="H1571"\w* tú \w guardarás|strong="H8104"\w* \w mis|strong="H5414"\w* \w atrios|strong="H2691"\w*, \w y|strong="H1571"\w* entre \w estos|strong="H1571"\w* \w que|strong="H1571"\w* \w aquí|strong="H3541"\w* están te \w daré|strong="H5414"\w* \w plaza|strong="H4108"\w*.   
\m
\v 8 \w Escucha|strong="H8085"\w* \w pues|strong="H3588"\w*, \w ahora|strong="H4994"\w*, \w Josué|strong="H3091"\w*, \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w*, tú \w y|strong="H3588"\w* tus \w amigos|strong="H7453"\w* \w que|strong="H3588"\w* \w se|strong="H1992"\w* sientan \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti; \w porque|strong="H3588"\w* \add son\add* \w varones|strong="H3588"\w* admirables: He \w aquí|strong="H2005"\w*, \w yo|strong="H3588"\w* traigo \w a|strong="H3068"\w* \w mi|strong="H4994"\w* \w siervo|strong="H5650"\w*, \w el|strong="H3588"\w* \w RENUEVO|strong="H6780"\w*.   
\m
