\v 8 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w el|strong="H5307"\w* \w siguiente|strong="H4283"\w* \w día|strong="H1121"\w*, \w que|strong="H1121"\w* \w viniendo|strong="H1961"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w a|strong="H3068"\w* despojar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w muertos|strong="H2491"\w*, \w hallaron|strong="H4672"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y \w a|strong="H3068"\w* sus \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w* \w tendidos|strong="H5307"\w* en \w el|strong="H5307"\w* \w monte|strong="H2022"\w* \w de|strong="H1121"\w* Gilboa;   
\m
\v 9 \w Y|strong="H3068"\w* le \w cortaron|strong="H3772"\w* la \w cabeza|strong="H7218"\w*, y le despojaron \w de|strong="H5971"\w* sus \w armas|strong="H3627"\w*; y \w enviaron|strong="H7971"\w* \add mensajeros\add* por toda la tierra \w de|strong="H5971"\w* los \w filisteos|strong="H6430"\w*, \w para|strong="H5971"\w* \w que|strong="H5971"\w* lo publicaran en el \w templo|strong="H1004"\w* \w de|strong="H5971"\w* sus \w ídolos|strong="H6091"\w*, y en el \w pueblo|strong="H5971"\w*.   
\m
\v 10 \w Y|strong="H3068"\w* \w pusieron|strong="H7760"\w* sus \w armas|strong="H3627"\w* en el \w templo|strong="H1004"\w* de Astarot, y colgaron su cuerpo en el \w muro|strong="H2346"\w* de Bet-seán.   
\m
\v 11 Mas \w oyendo|strong="H8085"\w* \w los|strong="H3427"\w* de \w Jabes|strong="H3003"\w* de \w Galaad|strong="H1568"\w* \w esto|strong="H6213"\w* que \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w* \w hicieron|strong="H6213"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*,   
\m
\v 12 \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w* se \w levantaron|strong="H6965"\w*, y \w anduvieron|strong="H3212"\w* \w toda|strong="H3605"\w* aquella \w noche|strong="H3915"\w*, y quitaron \w el|strong="H3605"\w* cuerpo \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w* y \w los|strong="H1121"\w* \w cuerpos|strong="H1472"\w* \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* del \w muro|strong="H2346"\w* \w de|strong="H1121"\w* Bet-seán; y viniendo \w a|strong="H3068"\w* \w Jabes|strong="H3003"\w*, \w los|strong="H1121"\w* quemaron \w allí|strong="H8033"\w*.   
\m
\v 13 \w Y|strong="H3068"\w* \w tomando|strong="H3947"\w* sus \w huesos|strong="H6106"\w*, \add los\add* \w sepultaron|strong="H6912"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* un árbol \w en|strong="H6912"\w* \w Jabes|strong="H3003"\w*, y ayunaron \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.   