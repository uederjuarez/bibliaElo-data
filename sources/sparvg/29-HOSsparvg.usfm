\v 11 Efraín es \w becerra|strong="H5697"\w* \w domada|strong="H3925"\w*, amadora \w del|strong="H5921"\w* trillar; \w mas|strong="H5921"\w* yo \w pasaré|strong="H5674"\w* \w sobre|strong="H5921"\w* su lozana \w cerviz|strong="H6676"\w*; yo haré llevar \w yugo|strong="H5921"\w* \w a|strong="H3068"\w* Efraín; \w arará|strong="H2790"\w* \w Judá|strong="H3063"\w*, \w quebrará|strong="H7702"\w* sus terrones \w Jacob|strong="H3290"\w*.   
\m
\v 12 \w Sembrad|strong="H2232"\w* \w para|strong="H5704"\w* vosotros \w en|strong="H5704"\w* \w justicia|strong="H6664"\w*, \w segad|strong="H7114"\w* \w para|strong="H5704"\w* vosotros \w en|strong="H5704"\w* \w misericordia|strong="H2617"\w*; \w arad|strong="H5215"\w* \w para|strong="H5704"\w* vosotros \w barbecho|strong="H5214"\w*; porque \add es\add* \w tiempo|strong="H6256"\w* \w de|strong="H5704"\w* buscar \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* venga \w y|strong="H5704"\w* \w os|strong="H5704"\w* \w enseñe|strong="H3384"\w* \w justicia|strong="H6664"\w*.   
\m
\v 13 Habéis arado \w impiedad|strong="H7562"\w*, \w segasteis|strong="H7114"\w* \w iniquidad|strong="H5766"\w*; comeréis \w fruto|strong="H6529"\w* \w de|strong="H3588"\w* \w mentira|strong="H3585"\w*; \w porque|strong="H3588"\w* confiaste \w en|strong="H3588"\w* tu \w camino|strong="H1870"\w*, \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w multitud|strong="H7230"\w* \w de|strong="H3588"\w* tus \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*.   
\m
\v 14 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w en|strong="H5921"\w* tus \w pueblos|strong="H5971"\w* \w se|strong="H5921"\w* \w levantará|strong="H6965"\w* \w alboroto|strong="H7588"\w*, \w y|strong="H5921"\w* \w todas|strong="H3605"\w* tus fortalezas serán destruidas, \w como|strong="H5921"\w* destruyó \w Salmán|strong="H8020"\w* \w a|strong="H3068"\w* Betarbel \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w*; \add cuando\add* \w la|strong="H5921"\w* madre fue estrellada \w sobre|strong="H5921"\w* \add sus\add* \w hijos|strong="H1121"\w*.   
\m
\v 15 \w Así|strong="H3602"\w* \w hará|strong="H6213"\w* \w a|strong="H3068"\w* vosotros Betel \w por|strong="H6440"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* vuestra gran \w maldad|strong="H7451"\w*; \w al|strong="H4428"\w* amanecer \w será|strong="H6213"\w* del todo \w cortado|strong="H1820"\w* \w el|strong="H1008"\w* \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.   
\c 11
\m
\v 1 \w Cuando|strong="H3588"\w* \w Israel|strong="H3478"\w* \add era\add* \w muchacho|strong="H5288"\w*, \w yo|strong="H3588"\w* lo amé, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w llamé|strong="H7121"\w* \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w*.   
\m
\v 2 \w Cuanto|strong="H3651"\w* más los \w llamaban|strong="H7121"\w*, \w así|strong="H3651"\w* ellos \w se|strong="H3651"\w* \w iban|strong="H1980"\w* \w de|strong="H6440"\w* su \w presencia|strong="H6440"\w*; \w a|strong="H3068"\w* los Baales \w sacrificaban|strong="H2076"\w*, y \w a|strong="H3068"\w* los \w ídolos|strong="H6456"\w* quemaban incienso.   
\m
\v 3 \w Yo|strong="H3588"\w* \w con|strong="H5921"\w* todo enseñé \w a|strong="H3068"\w* caminar \w a|strong="H3068"\w* Efraín, tomándolo \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w brazos|strong="H2220"\w*; \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w conocieron|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w los|strong="H5921"\w* cuidaba.   
\m
\v 4 \w Con|strong="H5921"\w* \w cuerdas|strong="H5688"\w* \w de|strong="H5921"\w* hombre \w los|strong="H5921"\w* atraje, \w con|strong="H5921"\w* \w cuerdas|strong="H5688"\w* \w de|strong="H5921"\w* amor; \w y|strong="H5921"\w* \w fui|strong="H1961"\w* \w para|strong="H5921"\w* \w ellos|strong="H5921"\w* \w como|strong="H1961"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* alzan \w el|strong="H5921"\w* \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* su cerviz, \w y|strong="H5921"\w* puse comida \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
\m
\v 5 \w No|strong="H3808"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H1931"\w* asirio \w será|strong="H1931"\w* \w su|strong="H1931"\w* \w rey|strong="H4428"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* \w quisieron|strong="H3985"\w* \w convertir|strong="H7725"\w*.   
\m
\v 6 \w Y|strong="H3068"\w* caerá \w espada|strong="H2719"\w* sobre sus \w ciudades|strong="H5892"\w*, y \w consumirá|strong="H3615"\w* sus aldeas; las \w consumirá|strong="H3615"\w* \w a|strong="H3068"\w* causa de sus propios \w consejos|strong="H4156"\w*.   
\m
\v 7 \w Entre|strong="H3808"\w* tanto, mi \w pueblo|strong="H5971"\w* está inclinado \w a|strong="H3068"\w* rebelarse contra mí; \w aunque|strong="H3808"\w* ellos \w invocan|strong="H7121"\w* al Altísimo, \w ninguno|strong="H3808"\w* \w absolutamente|strong="H3162"\w* quiere enaltecerle.   
\m
\v 8 ¿\w Cómo|strong="H5921"\w* he \w de|strong="H5921"\w* dejarte, oh Efraín? ¿He \w de|strong="H5921"\w* entregarte yo, \w Israel|strong="H3478"\w*? ¿\w Cómo|strong="H5921"\w* podré yo hacerte \w como|strong="H5921"\w* Adma, \w o|strong="H3068"\w* ponerte \w como|strong="H5921"\w* \w a|strong="H3068"\w* Zeboim? \w Mi|strong="H5921"\w* \w corazón|strong="H3820"\w* \w se|strong="H5921"\w* conmueve \w dentro|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w se|strong="H5921"\w* inflama \w toda|strong="H5921"\w* \w mi|strong="H5921"\w* compasión.   
\m
\v 9 \w No|strong="H3808"\w* \w ejecutaré|strong="H6213"\w* \w el|strong="H3588"\w* \w furor|strong="H2740"\w* \w de|strong="H3588"\w* mi \w ira|strong="H2740"\w*, \w no|strong="H3808"\w* \w volveré|strong="H7725"\w* \w para|strong="H3588"\w* \w destruir|strong="H7843"\w* \w a|strong="H3068"\w* Efraín; \w porque|strong="H3588"\w* Dios soy, \w y|strong="H3588"\w* \w no|strong="H3808"\w* hombre; \w el|strong="H3588"\w* \w Santo|strong="H6918"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* ti; \w y|strong="H3588"\w* \w no|strong="H3808"\w* entraré \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*.   
\m
\v 10 \w En|strong="H3588"\w* pos \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w* \w caminarán|strong="H3212"\w*, \w Él|strong="H1931"\w* \w rugirá|strong="H7580"\w* \w como|strong="H3588"\w* león, \w de|strong="H3588"\w* \w cierto|strong="H3588"\w* \w rugirá|strong="H7580"\w*; \w y|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* vendrán temblando desde \w el|strong="H1931"\w* occidente.   
\m
\v 11 \w De|strong="H5921"\w* \w Egipto|strong="H4714"\w* vendrán temblando \w como|strong="H5921"\w* \w ave|strong="H6833"\w*, \w y|strong="H5921"\w* \w como|strong="H5921"\w* \w paloma|strong="H3123"\w*, \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Asiria; \w y|strong="H5921"\w* yo \w los|strong="H3427"\w* \w pondré|strong="H3427"\w* \w en|strong="H5921"\w* sus \w casas|strong="H1004"\w*, \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w*.   
\m
\v 12 Efraín me ha rodeado con mentira, y la casa de Israel con engaño; mas Judá aún gobierna con Dios, y es fiel con los santos.   
\c 12
\m
\v 1 Efraín se apacienta \w de|strong="H5973"\w* viento, y sigue al viento solano; \w mentira|strong="H3585"\w* y destrucción aumenta continuamente; porque hicieron alianza \w con|strong="H5973"\w* \w los|strong="H5973"\w* asirios, y \w el|strong="H5973"\w* aceite es llevado \w a|strong="H3068"\w* Egipto.   
\m
\v 2 Jehová tiene controversia \w con|strong="H5973"\w* Judá, y castigará \w a|strong="H3068"\w* Jacob conforme \w a|strong="H3068"\w* sus caminos; \w le|strong="H5973"\w* pagará conforme \w a|strong="H3068"\w* sus obras.   
\m
\v 3 \w En|strong="H5921"\w* \w el|strong="H5921"\w* vientre tomó \w por|strong="H5921"\w* \w el|strong="H5921"\w* calcañar \w a|strong="H3068"\w* su hermano, \w y|strong="H5921"\w* \w con|strong="H5973"\w* su poder luchó \w con|strong="H5973"\w* \w Dios|strong="H3068"\w*.   
\m
\v 4 Sí, luchó con el Ángel, y prevaleció; lloró, y le rogó; le encontró en Betel, y allí habló con nosotros.   
\m
\v 5 \w Mas|strong="H1058"\w* Jehová \add es\add* \w el|strong="H5973"\w* Dios \w de|strong="H5973"\w* \w los|strong="H5973"\w* ejércitos; Jehová \add es\add* su memorial.   
\m
\v 6 Tú, pues, vuélvete \w a|strong="H3068"\w* tu \w Dios|strong="H3068"\w*; guarda misericordia y juicio, y en tu \w Dios|strong="H3068"\w* espera siempre.   
\m
\v 7 Es mercader que tiene en su mano peso falso, amador de opresión.   
\m
\v 8 \w Y|strong="H3068"\w* dijo Efraín: Ciertamente yo he enriquecido, he hallado riquezas para mí: nadie hallará en mí iniquidad, ni pecado en todos mis trabajos.   
\m
\v 9 \w Y|strong="H3068"\w* yo \add que soy\add* Jehová tu Dios desde \w la|strong="H3605"\w* tierra de Egipto \w aún|strong="H3808"\w* te haré morar en tiendas, \w como|strong="H5771"\w* en \w los|strong="H3605"\w* días de \w la|strong="H3605"\w* fiesta solemne.   
\m
\v 10 \w Y|strong="H3068"\w* he hablado \w a|strong="H3068"\w* \w los|strong="H3427"\w* profetas, y yo aumenté la profecía, y \w por|strong="H5750"\w* medio \w de|strong="H5750"\w* \w los|strong="H3427"\w* profetas puse semejanzas.   
\m
\v 11 ¿\add Hay\add* iniquidad \add en\add* Galaad? Ciertamente vanidad han sido; \w en|strong="H5921"\w* Gilgal sacrificaron bueyes; \w y|strong="H5921"\w* aún sus altares son \w como|strong="H5921"\w* montones \w en|strong="H5921"\w* \w los|strong="H5921"\w* surcos \w del|strong="H5921"\w* campo.   
\m
\v 12 \w Mas|strong="H1571"\w* Jacob huyó \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Aram, \w y|strong="H1571"\w* sirvió Israel \w por|strong="H5921"\w* esposa, \w y|strong="H1571"\w* \w por|strong="H5921"\w* esposa \w fue|strong="H1961"\w* pastor.   
\m
\v 13 \w Y|strong="H3068"\w* por un profeta Jehová sacó \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* de Egipto, y por un profeta fue preservado.   
\m
\v 14 Efraín ha provocado \add a Dios\add* con amarguras; por tanto, su sangre se derramará sobre \w él|strong="H5030"\w*, y su \w Señor|strong="H3068"\w* le pagará su oprobio.   
\c 13
\m
\v 1 Cuando Efraín \w hablaba|strong="H1696"\w*, hubo temor; \w se|strong="H1931"\w* exaltó en \w Israel|strong="H3478"\w*; \w mas|strong="H4191"\w* pecó en \w Baal|strong="H1168"\w*, y \w murió|strong="H4191"\w*.   
\m
\v 2 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* \w añadieron|strong="H3254"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w pecado|strong="H2398"\w*, y de \w su|strong="H1992"\w* \w plata|strong="H3701"\w* \w se|strong="H1992"\w* han \w hecho|strong="H6213"\w* según \w su|strong="H1992"\w* \w entendimiento|strong="H8394"\w*, \w estatuas|strong="H4541"\w* de \w fundición|strong="H4541"\w*, \w ídolos|strong="H6091"\w*, \w toda|strong="H3605"\w* \w obra|strong="H4639"\w* de \w artífices|strong="H2796"\w*; acerca de \w los|strong="H1992"\w* cuales dicen \w a|strong="H3068"\w* \w los|strong="H1992"\w* hombres \w que|strong="H6258"\w* \w sacrifican|strong="H2076"\w*, \w que|strong="H6258"\w* besen \w los|strong="H1992"\w* \w becerros|strong="H5695"\w*.   
\m
\v 3 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w serán|strong="H1961"\w* \w como|strong="H1961"\w* la niebla de la \w mañana|strong="H1242"\w*, y \w como|strong="H1961"\w* el \w rocío|strong="H2919"\w* de la madrugada \w que|strong="H1961"\w* \w se|strong="H1961"\w* pasa; \w como|strong="H1961"\w* el tamo \w que|strong="H1961"\w* la tempestad arroja de la \w era|strong="H1961"\w*, y \w como|strong="H1961"\w* el \w humo|strong="H6227"\w* \w que|strong="H1961"\w* sale de la chimenea.   
\m
\v 4 \w Mas|strong="H3808"\w* yo \add soy\add* \w Jehová|strong="H3068"\w* tu \w Dios|strong="H3068"\w* desde la tierra \w de|strong="H2108"\w* \w Egipto|strong="H4714"\w*; \w no|strong="H3808"\w* \w conocerás|strong="H3045"\w* \w dios|strong="H3068"\w* \w fuera|strong="H2108"\w* \w de|strong="H2108"\w* \w mí|strong="H1115"\w*, \w ni|strong="H3808"\w* otro \w salvador|strong="H3467"\w* \w sino|strong="H3808"\w* \w a|strong="H3068"\w* \w mí|strong="H1115"\w*.   
\m
\v 5 Yo te \w conocí|strong="H3045"\w* en el \w desierto|strong="H4057"\w*, en la tierra de gran sequía.   
\m
\v 6 \w En|strong="H5921"\w* sus pastos \w se|strong="H5921"\w* saciaron, \w se|strong="H5921"\w* llenaron, \w y|strong="H5921"\w* \w se|strong="H5921"\w* ensoberbeció su \w corazón|strong="H3820"\w*; \w por|strong="H5921"\w* \w esta|strong="H3651"\w* causa \w se|strong="H5921"\w* \w olvidaron|strong="H7911"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\m
\v 7 \w Por|strong="H5921"\w* \w tanto|strong="H3644"\w*, yo \w seré|strong="H1961"\w* \w para|strong="H5921"\w* \w ellos|strong="H5921"\w* \w como|strong="H3644"\w* \w león|strong="H7826"\w*; \w como|strong="H3644"\w* un leopardo \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w los|strong="H5921"\w* espiaré.   
\m
\v 8 Como osa que ha sido privada de \add sus cachorros\add* los \w encontraré|strong="H6298"\w*, y desgarraré las telas de su \w corazón|strong="H3820"\w*, y \w allí|strong="H8033"\w* los devoraré como león; fiera del \w campo|strong="H7704"\w* los despedazará.   
\m
\v 9 \w Te|strong="H3588"\w* destruiste \w a|strong="H3068"\w* ti mismo, oh \w Israel|strong="H3478"\w*, \w mas|strong="H3588"\w* \w en|strong="H3588"\w* mí \add está\add* tu \w ayuda|strong="H5828"\w*.   
\m
\v 10 Yo seré \w tu|strong="H8199"\w* \w Rey|strong="H4428"\w*; ¿dónde hay \add otro\add* \w que|strong="H3605"\w* pueda salvarte en \w todas|strong="H3605"\w* tus \w ciudades|strong="H5892"\w*; y tus \w jueces|strong="H8199"\w*, \w de|strong="H8269"\w* \w los|strong="H3605"\w* cuales dijiste: \w Dame|strong="H5414"\w* \w rey|strong="H4428"\w* y \w príncipes|strong="H8269"\w*?   
\m
\v 11 Te \w di|strong="H5414"\w* \w rey|strong="H4428"\w* en mi furor, y lo quité en mi ira.   
\m
\v 12 \w Atada|strong="H6887"\w* \add está\add* la \w maldad|strong="H5771"\w* de Efraín; su \w pecado|strong="H2403"\w* está guardado.   
\m
\v 13 \w Dolores|strong="H2256"\w* \w de|strong="H3588"\w* mujer \w de|strong="H3588"\w* parto \w le|strong="H1931"\w* vendrán; \w es|strong="H1931"\w* un \w hijo|strong="H1121"\w* \w no|strong="H3808"\w* \w sabio|strong="H2450"\w*, \w que|strong="H3588"\w* \w de|strong="H3588"\w* otra manera \w no|strong="H3808"\w* \w se|strong="H1931"\w* detuviera tanto \w en|strong="H3588"\w* \w el|strong="H1931"\w* \w tiempo|strong="H6256"\w* del nacimiento \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w*.   
\m
\v 14 \w De|strong="H5869"\w* la \w mano|strong="H3027"\w* del \w sepulcro|strong="H7585"\w* los \w redimiré|strong="H1350"\w*, los libraré \w de|strong="H5869"\w* la \w muerte|strong="H4194"\w*. Oh \w muerte|strong="H4194"\w*, yo seré tu \w muerte|strong="H4194"\w*; y seré tu destrucción, oh \w sepulcro|strong="H7585"\w*; el \w arrepentimiento|strong="H5164"\w* será \w escondido|strong="H5641"\w* \w de|strong="H5869"\w* mis \w ojos|strong="H5869"\w*.   
\m
\v 15 \w Aunque|strong="H3588"\w* \w él|strong="H1931"\w* fructifique \w entre|strong="H3588"\w* \add sus\add* hermanos, \w vendrá|strong="H5927"\w* \w el|strong="H1931"\w* \w viento|strong="H7307"\w* \w solano|strong="H6921"\w*, \w viento|strong="H7307"\w* \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w*, \w subiendo|strong="H5927"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* parte del \w desierto|strong="H4057"\w*, \w y|strong="H3588"\w* \w se|strong="H1931"\w* secará \w su|strong="H1931"\w* \w manantial|strong="H4726"\w*, \w y|strong="H3588"\w* \w se|strong="H1931"\w* agotará \w su|strong="H1931"\w* \w fuente|strong="H4599"\w*; \w él|strong="H1931"\w* \w saqueará|strong="H8154"\w* \w el|strong="H1931"\w* tesoro \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w vasos|strong="H3627"\w* preciosos.   
\m
\v 16 Samaria será asolada, porque se rebeló contra su Dios; caerán \w a|strong="H3068"\w* espada; sus niños serán estrellados, y sus mujeres encintas serán abiertas.   
\c 14
\m
\v 1 Vuelve, oh Israel, \w a|strong="H3068"\w* Jehová tu Dios; \w pues|strong="H3588"\w* \w por|strong="H3588"\w* tu pecado has \w caído|strong="H5307"\w*.   
\m
\v 2 Tomad \w con|strong="H3588"\w* vosotros palabras, \w y|strong="H3588"\w* \w volved|strong="H7725"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \w y|strong="H3588"\w* decidle: \w Quita|strong="H7725"\w* toda \w iniquidad|strong="H5771"\w*, \w y|strong="H3588"\w* acéptanos \w con|strong="H3588"\w* gracia, \w y|strong="H3588"\w* daremos becerros \w de|strong="H3588"\w* nuestros labios.   
\m
\v 3 No nos librará Asiria; no montaremos sobre caballos, \w ni|strong="H5973"\w* nunca más diremos \w a|strong="H3068"\w* \w la|strong="H3605"\w* obra \w de|strong="H5973"\w* nuestras manos: \add Vosotros sois\add* nuestros dioses; porque \w en|strong="H5973"\w* \w ti|strong="H5973"\w* \w el|strong="H5973"\w* huérfano alcanzará misericordia.   
\m
\v 4 Yo sanaré su rebelión, \w los|strong="H5921"\w* amaré \w de|strong="H5921"\w* pura gracia; \w porque|strong="H5921"\w* \w mi|strong="H5921"\w* ira \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \w ellos|strong="H3027"\w*.   
\m
\v 5 \w Yo|strong="H4480"\w* seré \w a|strong="H3068"\w* Israel \w como|strong="H3588"\w* rocío; \w él|strong="H3588"\w* florecerá \w como|strong="H3588"\w* lirio, \w y|strong="H3588"\w* extenderá sus raíces \w como|strong="H3588"\w* \w el|strong="H3588"\w* Líbano.   
\m
\v 6 \w Se|strong="H1961"\w* extenderán sus ramas, y \w será|strong="H1961"\w* su gloria \w como|strong="H1961"\w* la del olivo, y su fragancia \w como|strong="H1961"\w* el \w Líbano|strong="H3844"\w*.   
\m
\v 7 Volverán, y \w se|strong="H1961"\w* sentarán bajo su sombra; \w serán|strong="H1961"\w* vivificados \w como|strong="H1961"\w* trigo, y florecerán \w como|strong="H1961"\w* la vid; su \w olor|strong="H7381"\w* \add será\add* \w como|strong="H1961"\w* el del \w vino|strong="H3212"\w* del \w Líbano|strong="H3844"\w*.   
\m
\v 8 Efraín \add dirá\add*: ¿Qué \w más|strong="H2421"\w* tendré ya con \w los|strong="H3427"\w* ídolos? Yo lo oiré, y miraré; yo \add seré\add* \w a|strong="H3068"\w* \w él|strong="H3427"\w* como \w el|strong="H3427"\w* ciprés verde; de mí será hallado tu fruto.   
\m
\v 9 ¿\w Quién|strong="H4100"\w* \add es\add* sabio \w para|strong="H4480"\w* \w que|strong="H4100"\w* entienda esto, y prudente \w para|strong="H4480"\w* \w que|strong="H4100"\w* \w lo|strong="H4100"\w* sepa? \w Porque|strong="H4100"\w* los caminos \w de|strong="H4480"\w* Jehová \add son\add* rectos, y los justos andarán \w por|strong="H4480"\w* \w ellos|strong="H4480"\w*; \w mas|strong="H5750"\w* los rebeldes tropezarán \w en|strong="H4480"\w* \w ellos|strong="H4480"\w*.   