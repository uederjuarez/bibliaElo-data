\v 15 \w Toda|strong="H3605"\w* \w la|strong="H5921"\w* \w maldad|strong="H7451"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w fue|strong="H3808"\w* \w en|strong="H5921"\w* \w Gilgal|strong="H1537"\w*; \w allí|strong="H8033"\w*, \w pues|strong="H3588"\w*, \w les|strong="H5921"\w* tomé aversión; \w por|strong="H5921"\w* \w la|strong="H5921"\w* perversidad \w de|strong="H5921"\w* sus \w obras|strong="H4611"\w* \w los|strong="H5921"\w* \w echaré|strong="H3254"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w*; \w no|strong="H3808"\w* \w los|strong="H5921"\w* amaré \w más|strong="H3588"\w*; \w todos|strong="H3605"\w* sus \w príncipes|strong="H8269"\w* \add son\add* desleales.   
\m
\v 16 Efraín \w fue|strong="H1571"\w* herido, se \w secó|strong="H3001"\w* \w su|strong="H3588"\w* raíz, \w no|strong="H1097"\w* \w dará|strong="H3205"\w* \w más|strong="H3588"\w* \w fruto|strong="H6529"\w*; \w aunque|strong="H3588"\w* \w engendren|strong="H3205"\w*, \w yo|strong="H3588"\w* \w mataré|strong="H4191"\w* \w el|strong="H3588"\w* amado \add fruto\add* \w de|strong="H3588"\w* \w su|strong="H3588"\w* vientre.   
\m
\v 17 \w Mi|strong="H1961"\w* Dios \w los|strong="H1961"\w* desechará, \w porque|strong="H3588"\w* ellos \w no|strong="H3808"\w* le \w oyeron|strong="H8085"\w*; \w y|strong="H3588"\w* \w andarán|strong="H1961"\w* errantes \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w*.   
\c 10
\m
\v 1 \w Israel|strong="H3478"\w* \add es\add* una \w viña|strong="H1612"\w* \w vacía|strong="H1238"\w* que da \w fruto|strong="H6529"\w* para sí mismo; conforme \w a|strong="H3068"\w* la multiplicación de su \w fruto|strong="H6529"\w* \w multiplicó|strong="H7235"\w* los \w altares|strong="H4196"\w*, conforme \w a|strong="H3068"\w* la bondad de su tierra aumentaron sus imágenes.   
\m
\v 2 \w Su|strong="H1931"\w* \w corazón|strong="H3820"\w* \w está|strong="H1931"\w* dividido. \w Ahora|strong="H6258"\w* \w serán|strong="H1931"\w* hallados culpables; \w Él|strong="H1931"\w* derribará \w sus|strong="H1931"\w* \w altares|strong="H4196"\w*, \w asolará|strong="H7703"\w* \w sus|strong="H1931"\w* imágenes.   
