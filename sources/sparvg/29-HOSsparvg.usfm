\v 8 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* \w altares|strong="H4196"\w* \w de|strong="H5921"\w* Avén serán \w destruidos|strong="H8045"\w*, \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*; \w crecerá|strong="H5927"\w* \w sobre|strong="H5921"\w* sus \w altares|strong="H4196"\w* \w espino|strong="H6975"\w* \w y|strong="H5921"\w* cardo. \w Y|strong="H3068"\w* dirán \w a|strong="H3068"\w* \w las|strong="H5921"\w* montañas: \w Cubridnos|strong="H3680"\w*; \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w collados|strong="H1389"\w*: \w Caed|strong="H5307"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*.   
\m
\v 9 \w Desde|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w Gabaa|strong="H1390"\w* has \w pecado|strong="H2398"\w*, \w oh|strong="H1121"\w* \w Israel|strong="H3478"\w*; \w allí|strong="H8033"\w* \w estuvieron|strong="H5975"\w*; \w no|strong="H3808"\w* \w los|strong="H1121"\w* tomó \w la|strong="H5921"\w* \w batalla|strong="H4421"\w* \w en|strong="H5921"\w* \w Gabaa|strong="H1390"\w* \w contra|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* iniquidad.   
