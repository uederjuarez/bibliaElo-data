\v 44 \w Y|strong="H3068"\w* cuando \w murió|strong="H4191"\w* \w Bela|strong="H1106"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Jobab|strong="H3103"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* \w Zera|strong="H2226"\w*, \w de|strong="H8478"\w* \w Bosra|strong="H1224"\w*.   
