\v 40 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sobal|strong="H7732"\w*: Alván, y Manahat, y \w Ebal|strong="H5858"\w*, Sefo y Onam. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zibeón|strong="H6649"\w*: Aja y \w Ana|strong="H6034"\w*.   
\m
\v 41 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ana|strong="H6034"\w* fue \w Disón|strong="H1787"\w*. \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Disón|strong="H1787"\w*; \w Hamrán|strong="H2566"\w*, y Esbán, \w e|strong="H3068"\w* Itrán y Querán.   
