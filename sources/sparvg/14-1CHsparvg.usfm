\v 20 \w Y|strong="H3068"\w* \w Joctán|strong="H3355"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Elmodad, \w a|strong="H3068"\w* Selef, \w a|strong="H3068"\w* Hazarmavet, y \w a|strong="H3068"\w* Jera;   
\m
\v 21 también \w a|strong="H3068"\w* Adoram, \w a|strong="H3068"\w* Uzal, \w a|strong="H3068"\w* \w Dicla|strong="H1853"\w*,   
\m
\v 22 \w a|strong="H3068"\w* \w Ebal|strong="H5858"\w*, \w a|strong="H3068"\w* Abimael, \w a|strong="H3068"\w* \w Seba|strong="H7614"\w*,   
\m
\v 23 \w a|strong="H3068"\w* Ofir, \w a|strong="H3068"\w* \w Havila|strong="H2341"\w* y \w a|strong="H3068"\w* \w Jobab|strong="H3103"\w*; \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* \add fueron\add* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Joctán|strong="H3355"\w*.   
