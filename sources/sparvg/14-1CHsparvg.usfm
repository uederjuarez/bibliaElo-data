\v 46 \w Y|strong="H3068"\w* cuando \w murió|strong="H4191"\w* \w Husam|strong="H2367"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* Hadad, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Bedad, \w el|strong="H1121"\w* cual \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w Madián|strong="H4080"\w* \w en|strong="H8478"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w* \w de|strong="H8478"\w* \w Moab|strong="H4124"\w*; y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su \w ciudad|strong="H5892"\w* \add fue\add* Avit.   
\m
\v 47 \w Y|strong="H3068"\w* cuando \w murió|strong="H4191"\w* Hadad, \w Samla|strong="H8072"\w*, \w de|strong="H8478"\w* Masreca \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w*.   
\m
\v 48 \w Y|strong="H3068"\w* cuando \w murió|strong="H4191"\w* \w Samla|strong="H8072"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Saúl|strong="H7586"\w* \w de|strong="H8478"\w* Rehobot, que está \add junto al\add* \w río|strong="H5104"\w*.   
\m
\v 49 \w Y|strong="H3068"\w* cuando \w murió|strong="H4191"\w* \w Saúl|strong="H7586"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Baal-hanán|strong="H1177"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Acbor.   
\m
\v 50 \w Y|strong="H3068"\w* cuando \w murió|strong="H4191"\w* \w Baal-hanán|strong="H1177"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* Hadad, el \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* cuya \w ciudad|strong="H5892"\w* \add fue\add* Pai; y el \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su esposa, Mehetabel, \w hija|strong="H1323"\w* \w de|strong="H8478"\w* Matred, \w hija|strong="H1323"\w* \w de|strong="H8478"\w* Mezaab.   
\m
\v 51 \w Murió|strong="H4191"\w* también Hadad. \w Y|strong="H3068"\w* \w los|strong="H1961"\w* duques de Edom \w fueron|strong="H1961"\w*; el duque \w Timna|strong="H8555"\w*, el duque Alva, el duque Jetet,   
\m
\v 52 el duque Aholibama, el duque Ela, el duque Pinón,   
\m
\v 53 el duque Cenaz, el duque \w Temán|strong="H8487"\w*, el duque Mibzar,   
\m
\v 54 el duque \w Magdiel|strong="H4025"\w* y el duque Iram. Estos \add fueron\add* los duques de Edom.   
\c 2
\m
\v 1 Estos \add son\add* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: \w Rubén|strong="H7205"\w*, \w Simeón|strong="H8095"\w*, \w Leví|strong="H3878"\w*, \w Judá|strong="H3063"\w*, Isacar, y \w Zabulón|strong="H2074"\w*,   
\m
\v 2 \w Dan|strong="H1835"\w*, \w José|strong="H3130"\w*, y \w Benjamín|strong="H1144"\w*, Neftalí, \w Gad|strong="H1410"\w* y Aser.   
\m
\v 3 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*: \w Er|strong="H6147"\w*, y Onán y \w Sela|strong="H7956"\w*. \add Estos\add* \w tres|strong="H7969"\w* \w le|strong="H5869"\w* \w nacieron|strong="H3205"\w* \w de|strong="H1121"\w* la \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Súa, \w cananea|strong="H3669"\w*. \w Y|strong="H3068"\w* \w Er|strong="H6147"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w fue|strong="H1961"\w* \w malo|strong="H7451"\w* \w delante|strong="H5869"\w* \w de|strong="H1121"\w* \w Jehová|strong="H3068"\w*; y \w Él|strong="H1121"\w* lo \w mató|strong="H4191"\w*.   
\m
\v 4 \w Y|strong="H3068"\w* Tamar su \w nuera|strong="H3618"\w* le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Fares y \w a|strong="H3068"\w* \w Zera|strong="H2226"\w*. \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Judá|strong="H3063"\w* \add fueron\add* \w cinco|strong="H2568"\w*.   
\m
\v 5 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Fares: \w Hezrón|strong="H2696"\w* y Hamul.   
\m
\v 6 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Zera|strong="H2226"\w*; \w Zimri|strong="H2174"\w*, y Etán, y \w Hemán|strong="H1968"\w*, y Calcol y Darda; \w cinco|strong="H2568"\w* en total.   
\m
\v 7 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carmi|strong="H3756"\w* fue Acar, \w el|strong="H1121"\w* \w que|strong="H1121"\w* perturbó \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, porque \w prevaricó|strong="H4603"\w* en \w el|strong="H1121"\w* \w anatema|strong="H2764"\w*.   
\m
\v 8 \w Azarías|strong="H5838"\w* fue \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Etán.   
\m
\v 9 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w que|strong="H1121"\w* \w nacieron|strong="H3205"\w* \w a|strong="H3068"\w* \w Hezrón|strong="H2696"\w*: \w Jerameel|strong="H3396"\w*, y \w Ram|strong="H7410"\w* y Quelubai.   
\m
\v 10 \w Y|strong="H3068"\w* \w Ram|strong="H7410"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Aminadab|strong="H5992"\w*; y \w Aminadab|strong="H5992"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Naasón|strong="H5177"\w*, \w príncipe|strong="H5387"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*;   
\m
\v 11 y \w Naasón|strong="H5177"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Salma|strong="H8007"\w*, y \w Salma|strong="H8007"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Boaz|strong="H1162"\w*;   
\m
\v 12 y \w Boaz|strong="H1162"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Obed|strong="H5744"\w*, y \w Obed|strong="H5744"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w*;   
\m
\v 13 \w e|strong="H3068"\w* \w Isaí|strong="H3448"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Eliab, su \w primogénito|strong="H1060"\w*, y el \w segundo|strong="H8145"\w* Abinadab, y Sima el \w tercero|strong="H7992"\w*;   
\m
\v 14 el \w cuarto|strong="H7243"\w* Natanael, el \w quinto|strong="H2549"\w* \w Radai|strong="H7288"\w*;   
\m
\v 15 el \w sexto|strong="H8345"\w* Osem, el \w séptimo|strong="H7637"\w* \w David|strong="H1732"\w*;   
\m
\v 16 \w de|strong="H1121"\w* \w los|strong="H1121"\w* cuales Sarvia y Abigail fueron hermanas. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia \add fueron\add* \w tres|strong="H7969"\w*: \w Abisai|strong="H7969"\w*, \w Joab|strong="H3097"\w* y \w Asael|strong="H6214"\w*.   
\m
