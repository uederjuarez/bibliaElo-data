\c 1
\m
\v 1 Adán, Set, Enós,   
\m
\v 2 \w Cainán|strong="H7018"\w*, \w Mahalaleel|strong="H4111"\w*, \w Jared|strong="H3382"\w*,   
\m
\v 3 Enoc, Matusalén, Lamec,   
\m
\v 4 \w Noé|strong="H5146"\w*, \w Sem|strong="H8035"\w*, Cam y Jafet.   
\m
\v 5 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jafet: \w Gomer|strong="H1586"\w*, y \w Magog|strong="H4031"\w*, y Madai, y \w Javán|strong="H3120"\w*, \w Tubal|strong="H8422"\w*, y \w Mesec|strong="H4902"\w* y Tiras.   
\m
\v 6 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gomer|strong="H1586"\w*: Askenaz, y Rifat y Togarma.   
\m
\v 7 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Javán|strong="H3120"\w*: Elisa, y \w Tarsis|strong="H8659"\w*, Quitim y Dodanim.   
\m
\v 8 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cam: Cus, y Mizraim, Fut y \w Canaán|strong="H3667"\w*.   
\m
\v 9 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cus: \w Seba|strong="H7614"\w*, y \w Havila|strong="H2341"\w*, y Sabta, Raama y Sabteca. \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Raama: \w Seba|strong="H7614"\w* y \w Dedán|strong="H1719"\w*.   
\m
\v 10 \w Y|strong="H3068"\w* Cus \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Nimrod; \w este|strong="H1931"\w* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* ser \w poderoso|strong="H1368"\w* en \w la|strong="H1931"\w* tierra.   
\m
\v 11 \w Y|strong="H3068"\w* Mizraim \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Ludim, y \w a|strong="H3068"\w* \w Ananim|strong="H6047"\w*, y \w a|strong="H3068"\w* Lehabim, y \w a|strong="H3068"\w* Naftuhim,   
\m
\v 12 y \w a|strong="H3068"\w* Patrusim y \w a|strong="H3068"\w* Casluhim; de estos \w salieron|strong="H3318"\w* los \w filisteos|strong="H6430"\w*, y los caftoreos.   
\m
\v 13 \w Canaán|strong="H3667"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sidón|strong="H6721"\w*, su \w primogénito|strong="H1060"\w*; y \w a|strong="H3068"\w* Het,   
\m
\v 14 también al \w jebuseo|strong="H2983"\w*, y al amorreo, y al gergeseo;   
\m
\v 15 y al \w heveo|strong="H2340"\w*, y al araceo, y al sineo;   
\m
\v 16 y al arvadeo, y al samareo y al hamateo.   
\m
\v 17 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sem|strong="H8035"\w*: \w Elam|strong="H5867"\w*, y Asur, y Arfaxad, y \w Lud|strong="H3865"\w*, y Aram, y \w Uz|strong="H5780"\w*, y \w Hul|strong="H2343"\w*, y Geter y \w Mesec|strong="H4902"\w*.   
\m
\v 18 \w Y|strong="H3068"\w* Arfaxad \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sela|strong="H7974"\w*, y \w Sela|strong="H7974"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w*.   
\m
\v 19 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w* le \w nacieron|strong="H3205"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*; \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* del uno \add fue\add* \w Peleg|strong="H6389"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w en|strong="H3588"\w* sus \w días|strong="H3117"\w* fue dividida \w la|strong="H3588"\w* tierra; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermano \add fue\add* \w Joctán|strong="H3355"\w*.   
