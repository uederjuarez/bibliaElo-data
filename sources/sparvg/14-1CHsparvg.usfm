\v 3 el \w quinto|strong="H2549"\w*, Sefatías, de Abital; el \w sexto|strong="H8345"\w*, \w Itream|strong="H3507"\w*, de Egla su esposa.   
\m
\v 4 \add Estos\add* \w seis|strong="H8337"\w* le \w nacieron|strong="H3205"\w* en \w Hebrón|strong="H2275"\w*, \w donde|strong="H8033"\w* \w reinó|strong="H4427"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* y \w seis|strong="H8337"\w* \w meses|strong="H2320"\w*; y en Jerusalén \w reinó|strong="H4427"\w* \w treinta|strong="H7970"\w* y \w tres|strong="H7969"\w* \w años|strong="H8141"\w*.   
\m
\v 5 Estos cuatro le \w nacieron|strong="H3205"\w* en Jerusalén: Sima, \w Sobab|strong="H7727"\w*, Natán y \w Salomón|strong="H8010"\w*, de Bet-súa \w hija|strong="H1323"\w* de Amiel.   
\m
\v 6 También Elisama, y Elifelet,   
\m
\v 7 y \w Noga|strong="H5052"\w*, y Nefeg, y Jafía.   
\m
\v 8 \w Y|strong="H3068"\w* Elisama, y Eliada y Elifelet, \w nueve|strong="H8672"\w* \add en total\add*.   
\m
\v 9 \w Todos|strong="H3605"\w* \add estos fueron\add* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, además \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* las \w concubinas|strong="H6370"\w*. \w Y|strong="H3068"\w* Tamar fue hermana \w de|strong="H1121"\w* \w ellos|strong="H3605"\w*.   
\m
