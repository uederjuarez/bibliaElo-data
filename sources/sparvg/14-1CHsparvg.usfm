\v 24 \w Sem|strong="H8035"\w*, Arfaxad, \w Sela|strong="H7974"\w*,   
\m
\v 25 \w Heber|strong="H5677"\w*, \w Peleg|strong="H6389"\w*, \w Reu|strong="H7466"\w*,   
\m
\v 26 \w Serug|strong="H8286"\w*, Nacor, Taré,   
\m
\v 27 y Abram, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \add es\add* Abraham.   
