\c 3
\m
\v 1 Estos \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* en \w Hebrón|strong="H2275"\w*: Amnón \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, \w de|strong="H1121"\w* Ahinoam \w jezreelita|strong="H3159"\w*; \w el|strong="H1121"\w* \w segundo|strong="H8145"\w* \w Daniel|strong="H1840"\w*, \w de|strong="H1121"\w* Abigail la carmelita;   
\m
\v 2 \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*, Absalón, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maaca, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Talmai, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Gesur; \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w*, Adonías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Haguit;   
