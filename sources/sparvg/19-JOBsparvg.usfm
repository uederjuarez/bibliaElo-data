\v 10 \w Abrieron|strong="H6473"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* su \w boca|strong="H6310"\w*; \w hirieron|strong="H5221"\w* mis mejillas \w con|strong="H5921"\w* \w afrenta|strong="H2781"\w*; \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w se|strong="H5921"\w* juntaron \w todos|strong="H3162"\w*.   
