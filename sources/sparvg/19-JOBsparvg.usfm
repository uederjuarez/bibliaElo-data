\v 7 He \w aquí|strong="H2005"\w* yo \w clamo|strong="H6817"\w* \w agravio|strong="H2555"\w*, y \w no|strong="H3808"\w* soy oído; doy \w voces|strong="H6817"\w*, y \w no|strong="H3808"\w* \add hay\add* \w juicio|strong="H4941"\w*.   
\m
\v 8 \w Él|strong="H5921"\w* \w ha|strong="H3808"\w* cercado \w mi|strong="H5921"\w* camino, \w y|strong="H5921"\w* \w no|strong="H3808"\w* puedo \w pasar|strong="H5674"\w*; \w y|strong="H5921"\w* \w ha|strong="H3808"\w* puesto \w oscuridad|strong="H2822"\w* \w en|strong="H5921"\w* mis sendas.   
