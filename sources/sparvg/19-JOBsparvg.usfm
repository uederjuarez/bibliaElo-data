\v 8 \w Los|strong="H5921"\w* \w rectos|strong="H3477"\w* \w se|strong="H5921"\w* maravillarán \w de|strong="H5921"\w* \w esto|strong="H2063"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w inocente|strong="H5355"\w* \w se|strong="H5921"\w* levantará \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w hipócrita|strong="H2611"\w*.   
