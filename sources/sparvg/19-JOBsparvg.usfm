\v 17 \w A|strong="H3068"\w* pesar \w de|strong="H5921"\w* \w no|strong="H3808"\w* \w haber|strong="H3808"\w* \w iniquidad|strong="H2555"\w* \w en|strong="H5921"\w* mis \w manos|strong="H3709"\w*, \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w haber|strong="H3808"\w* sido \w pura|strong="H2134"\w* \w mi|strong="H5921"\w* \w oración|strong="H8605"\w*.   
