\v 7 \w Él|strong="H5921"\w* \w extiende|strong="H5186"\w* \w el|strong="H5921"\w* \w norte|strong="H6828"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w vacío|strong="H8414"\w*, \w cuelga|strong="H8518"\w* \w la|strong="H5921"\w* tierra \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w nada|strong="H1099"\w*.   
