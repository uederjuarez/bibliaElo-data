\v 35 \add Entonces\add* \w yo|strong="H3588"\w* \w hablaría|strong="H1696"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* le temería; \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w es|strong="H3588"\w* \w así|strong="H3651"\w* \w conmigo|strong="H5978"\w*.   
\c 10
\m
\v 1 \w Mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w está|strong="H5921"\w* hastiada \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w vida|strong="H5315"\w*: Daré \w yo|strong="H5315"\w* rienda suelta \w a|strong="H3068"\w* \w mi|strong="H5921"\w* queja \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*, \w hablaré|strong="H1696"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w amargura|strong="H4751"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*.   
\m
\v 2 Diré \w a|strong="H3068"\w* Dios: \w No|strong="H5921"\w* \w me|strong="H5921"\w* condenes; hazme entender \w por|strong="H5921"\w* \w qué|strong="H4100"\w* contiendes conmigo.   
\m
\v 3 ¿\w Te|strong="H5921"\w* parece \w bien|strong="H2896"\w* \w que|strong="H3588"\w* \w oprimas|strong="H6231"\w*, \w que|strong="H3588"\w* \w deseches|strong="H3988"\w* \w la|strong="H5921"\w* obra \w de|strong="H5921"\w* tus \w manos|strong="H3709"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* resplandezcas \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w consejo|strong="H6098"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w impíos|strong="H7563"\w*?   
\m
