\v 27 También \w os|strong="H5921"\w* arrojáis \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w huérfano|strong="H3490"\w*, \w y|strong="H5921"\w* caváis \add un hoyo\add* \w para|strong="H5921"\w* vuestro \w amigo|strong="H7453"\w*.   
\m
\v 28 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w si|strong="H6440"\w* queréis, \w miradme|strong="H6437"\w*, \w y|strong="H5921"\w* ved \w si|strong="H6440"\w* \w miento|strong="H3576"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* vosotros.   
\m
\v 29 \w Tornad|strong="H7725"\w* \w ahora|strong="H4994"\w*, y \w no|strong="H1961"\w* \w haya|strong="H1961"\w* \w iniquidad|strong="H5766"\w*; \w volved|strong="H7725"\w* \w aún|strong="H5750"\w* \w a|strong="H3068"\w* considerar \w mi|strong="H1961"\w* \w justicia|strong="H6664"\w* \w en|strong="H5750"\w* esto.   
\m
\v 30 ¿\w Hay|strong="H3426"\w* \w iniquidad|strong="H5766"\w* en mi \w lengua|strong="H3956"\w*? ¿\w No|strong="H3808"\w* puede mi paladar discernir las cosas depravadas?   
\c 7
\m
\v 1 ¿Acaso \w no|strong="H3808"\w* \add hay\add* un \w tiempo|strong="H3117"\w* determinado \w para|strong="H5921"\w* \w el|strong="H5921"\w* hombre \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra? ¿\add No son\add* sus \w días|strong="H3117"\w* \w como|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* un jornalero?   
\m
\v 2 Como el \w siervo|strong="H5650"\w* \w anhela|strong="H7602"\w* la \w sombra|strong="H6738"\w*, y como el jornalero \w espera|strong="H6960"\w* \add la paga\add* de su trabajo,   
\m
\v 3 \w así|strong="H3651"\w* he tenido que poseer \w meses|strong="H3391"\w* de \w vanidad|strong="H7723"\w*, y \w noches|strong="H3915"\w* de congoja me fueron asignadas.   
\m
\v 4 \w Cuando|strong="H4970"\w* estoy \w acostado|strong="H7901"\w*, digo: ¿\w Cuándo|strong="H4970"\w* me \w levantaré|strong="H6965"\w*, \w y|strong="H5704"\w* se acabará \w la|strong="H7646"\w* noche? \w Y|strong="H3068"\w* estoy harto \w de|strong="H5704"\w* darme vueltas \w hasta|strong="H5704"\w* el alba.   
\m
\v 5 Mi \w carne|strong="H1320"\w* está vestida \w de|strong="H3847"\w* \w gusanos|strong="H7415"\w*, y \w de|strong="H3847"\w* costras \w de|strong="H3847"\w* \w polvo|strong="H6083"\w*; mi \w piel|strong="H5785"\w* \w hendida|strong="H7280"\w* y abominable.   
\m
\v 6 \w Y|strong="H3068"\w* mis \w días|strong="H3117"\w* son \w más|strong="H4480"\w* ligeros \w que|strong="H4480"\w* la lanzadera \w del|strong="H4480"\w* tejedor, y fenecen sin \w esperanza|strong="H8615"\w*.   
\m
\v 7 \w Acuérdate|strong="H2142"\w* \w que|strong="H3588"\w* mi \w vida|strong="H2416"\w* \add es\add* un \w soplo|strong="H7307"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* mis \w ojos|strong="H5869"\w* \w no|strong="H3808"\w* \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w el|strong="H3588"\w* \w bien|strong="H2896"\w*.   
\m
\v 8 Los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* los \w que|strong="H3808"\w* me ven, \w no|strong="H3808"\w* me verán \add más\add*; fijarás en mí tus \w ojos|strong="H5869"\w*, y dejaré \w de|strong="H5869"\w* ser.   
\m
\v 9 \add Como\add* la \w nube|strong="H6051"\w* \w se|strong="H3808"\w* desvanece, y \w se|strong="H3808"\w* \w va|strong="H3068"\w*; \w así|strong="H3651"\w* el \w que|strong="H3808"\w* \w desciende|strong="H3381"\w* al \w sepulcro|strong="H7585"\w* \add ya\add* \w no|strong="H3808"\w* \w subirá|strong="H5927"\w*;   
\m
\v 10 \w No|strong="H3808"\w* \w volverá|strong="H7725"\w* \w más|strong="H5750"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*, \w ni|strong="H3808"\w* su \w lugar|strong="H4725"\w* le conocerá \w más|strong="H5750"\w*.   
\m
\v 11 Por tanto, \w yo|strong="H5315"\w* \w no|strong="H3808"\w* refrenaré \w mi|strong="H5315"\w* \w boca|strong="H6310"\w*; \w hablaré|strong="H1696"\w* en \w la|strong="H1571"\w* \w angustia|strong="H6862"\w* de \w mi|strong="H5315"\w* \w espíritu|strong="H7307"\w*, \w y|strong="H1571"\w* me quejaré \w con|strong="H1571"\w* \w la|strong="H1571"\w* \w amargura|strong="H4751"\w* de \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*.   
\m
\v 12 ¿\add Soy\add* \w yo|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w o|strong="H3068"\w* \w ballena|strong="H8577"\w*, \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w me|strong="H5921"\w* \w pongas|strong="H7760"\w* \w guarda|strong="H4929"\w*?   
\m
\v 13 \w Cuando|strong="H3588"\w* digo: \w Me|strong="H3588"\w* \w consolará|strong="H5162"\w* \w mi|strong="H5375"\w* \w cama|strong="H4904"\w*, \w mi|strong="H5375"\w* lecho \w atenuará|strong="H5375"\w* \w mis|strong="H5375"\w* quejas;   
\m
\v 14 Entonces me aterras con \w sueños|strong="H2472"\w*, y me turbas con \w visiones|strong="H2384"\w*.   
\m
\v 15 \w Y|strong="H3068"\w* así \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* tuvo por mejor el estrangulamiento, y la \w muerte|strong="H4194"\w*, más que la \w vida|strong="H5315"\w*.   
\m
\v 16 Desvanezco; \w no|strong="H3808"\w* he \w de|strong="H4480"\w* \w vivir|strong="H2421"\w* \w para|strong="H3588"\w* \w siempre|strong="H5769"\w*; \w déjame|strong="H2308"\w*, \w pues|strong="H3588"\w* mis \w días|strong="H3117"\w* \w son|strong="H3588"\w* \w vanidad|strong="H1892"\w*.   
\m
\v 17 ¿\w Qué|strong="H3588"\w* \add es\add* \w el|strong="H3588"\w* hombre, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w lo|strong="H4100"\w* engrandezcas, \w y|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w pongas|strong="H7896"\w* sobre \w él|strong="H3588"\w* tu \w corazón|strong="H3820"\w*,   
\m
\v 18 y lo visites todas las mañanas, y \w a|strong="H3068"\w* cada \w momento|strong="H7281"\w* lo pruebes?   
\m
\v 19 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4100"\w* \w no|strong="H3808"\w* \w te|strong="H4480"\w* apartarás \w de|strong="H4480"\w* mí, \w y|strong="H5704"\w* \w no|strong="H3808"\w* \w me|strong="H4480"\w* soltarás \w ni|strong="H3808"\w* siquiera \w para|strong="H5704"\w* \w que|strong="H4100"\w* \w trague|strong="H1104"\w* mi saliva?   
\m
\v 20 \w Pequé|strong="H2398"\w*, ¿\w qué|strong="H4100"\w* \w te|strong="H5921"\w* hago yo, \w oh|strong="H4100"\w* \w Guarda|strong="H5341"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* hombres? ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w me|strong="H5921"\w* has puesto \w como|strong="H4100"\w* blanco tuyo, \w de|strong="H5921"\w* modo \w que|strong="H4100"\w* \w soy|strong="H1961"\w* una \w carga|strong="H4853"\w* \w para|strong="H5921"\w* \w mí|strong="H5921"\w* mismo?   
\m
\v 21 ¿\w Y|strong="H3068"\w* \w por|strong="H3588"\w* \w qué|strong="H3588"\w* \w no|strong="H3808"\w* perdonas \w mi|strong="H5375"\w* \w rebelión|strong="H6588"\w*, \w y|strong="H3588"\w* \w quitas|strong="H5375"\w* \w mi|strong="H5375"\w* \w iniquidad|strong="H5771"\w*? \w Porque|strong="H3588"\w* \w ahora|strong="H6258"\w* \w dormiré|strong="H7901"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w polvo|strong="H6083"\w*, \w y|strong="H3588"\w* \w si|strong="H3588"\w* \w me|strong="H3588"\w* buscares \w de|strong="H3588"\w* mañana, \w ya|strong="H6258"\w* \w no|strong="H3808"\w* \add estaré\add*.   
\c 8
\m
\v 1 Entonces \w respondió|strong="H6030"\w* \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w*, y dijo:   
\m
\v 2 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* \w hablarás|strong="H4448"\w* tales cosas, \w y|strong="H5704"\w* las \w palabras|strong="H6310"\w* \w de|strong="H5704"\w* tu \w boca|strong="H6310"\w* \w serán|strong="H6310"\w* \w como|strong="H5704"\w* un \w viento|strong="H7307"\w* impetuoso?   
\m
\v 3 ¿Acaso \w pervertirá|strong="H5791"\w* Dios el \w juicio|strong="H4941"\w*, \w o|strong="H3068"\w* el \w Todopoderoso|strong="H7706"\w* \w pervertirá|strong="H5791"\w* la \w justicia|strong="H6664"\w*?   
\m
\v 4 Si tus \w hijos|strong="H1121"\w* \w pecaron|strong="H2398"\w* contra \w Él|strong="H1121"\w*, \w Él|strong="H1121"\w* \w los|strong="H1121"\w* \w echó|strong="H7971"\w* en \w el|strong="H1121"\w* lugar \w de|strong="H1121"\w* su \w pecado|strong="H2398"\w*.   
\m
\v 5 Si tú de mañana buscares \w a|strong="H3068"\w* Dios, y suplicares al \w Todopoderoso|strong="H7706"\w*;   
\m
\v 6 \w Si|strong="H3588"\w* \add fueres\add* \w limpio|strong="H2134"\w* \w y|strong="H3588"\w* \w recto|strong="H3477"\w*, \w ciertamente|strong="H3588"\w* \w luego|strong="H6258"\w* \w se|strong="H5921"\w* \w despertará|strong="H5782"\w* \w por|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H3588"\w* hará próspera \w la|strong="H5921"\w* \w morada|strong="H5116"\w* \w de|strong="H5921"\w* tu \w justicia|strong="H6664"\w*.   
\m
\v 7 Aunque tu \w principio|strong="H7225"\w* \w haya|strong="H1961"\w* \w sido|strong="H1961"\w* \w pequeño|strong="H4705"\w*, tu postrimería \w será|strong="H1961"\w* \w muy|strong="H3966"\w* \w grande|strong="H3966"\w*.   
\m
\v 8 \w Porque|strong="H3588"\w* \w pregunta|strong="H7592"\w* \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* edad pasada, \w y|strong="H3588"\w* disponte \w a|strong="H3068"\w* inquirir \w de|strong="H3588"\w* \w los|strong="H3588"\w* padres \w de|strong="H3588"\w* ellos;   
\m
