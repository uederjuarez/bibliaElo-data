\v 26 \w Ellos|strong="H5921"\w* \w yacerán|strong="H7901"\w* \w igualmente|strong="H3162"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w gusanos|strong="H7415"\w* \w los|strong="H5921"\w* \w cubrirán|strong="H3680"\w*.   
\m
\v 27 He \w aquí|strong="H2005"\w*, yo \w conozco|strong="H3045"\w* vuestros \w pensamientos|strong="H4284"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* imaginaciones \w que|strong="H5921"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* forjáis.   
\m
\v 28 \w Porque|strong="H3588"\w* decís: ¿\w Qué|strong="H3588"\w* \w es|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* del príncipe, \w y|strong="H3588"\w* \w qué|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tienda \w de|strong="H3588"\w* las \w moradas|strong="H4908"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w impíos|strong="H7563"\w*?   
\m
\v 29 ¿\w No|strong="H3808"\w* habéis preguntado \w a|strong="H3068"\w* los \w que|strong="H3808"\w* \w pasan|strong="H5674"\w* \w por|strong="H1870"\w* los \w caminos|strong="H1870"\w*, y \w no|strong="H3808"\w* habéis conocido sus señalamientos,   
\m
\v 30 \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w malo|strong="H7451"\w* \w es|strong="H3588"\w* reservado \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* destrucción? Presentados serán \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* ira.   
\m
\v 31 ¿\w Quién|strong="H4310"\w* \w le|strong="H1931"\w* \w denunciará|strong="H5046"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w cara|strong="H6440"\w* \w su|strong="H1931"\w* \w camino|strong="H1870"\w*? \w Y|strong="H3068"\w* \w de|strong="H5921"\w* \w lo|strong="H1931"\w* \w que|strong="H4310"\w* \w él|strong="H1931"\w* \w hizo|strong="H6213"\w*, ¿\w quién|strong="H4310"\w* \w le|strong="H1931"\w* \w dará|strong="H7999"\w* \w el|strong="H1931"\w* pago?   
\m
\v 32 \w Porque|strong="H5921"\w* \w será|strong="H1931"\w* \w llevado|strong="H2986"\w* \w al|strong="H5921"\w* \w sepulcro|strong="H6913"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* tumba permanecerá.   
\m
\v 33 \w Los|strong="H3605"\w* terrones del valle le serán dulces; y tras \w de|strong="H6440"\w* \w él|strong="H3605"\w* será llevado \w todo|strong="H3605"\w* hombre, y \w antes|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H3605"\w* han ido innumerables.   
\m
\v 34 ¿Cómo, pues, me consoláis en \w vano|strong="H1892"\w*, viniendo \w a|strong="H3068"\w* parar vuestras respuestas en falacia?   
\c 22
\m
\v 1 Entonces \w respondió|strong="H6030"\w* Elifaz el \w temanita|strong="H8489"\w*, y dijo:   
\m
\v 2 ¿Traerá \w el|strong="H5921"\w* \w hombre|strong="H1397"\w* \w provecho|strong="H5532"\w* \w a|strong="H3068"\w* Dios, podrá \w el|strong="H5921"\w* sabio ser \w de|strong="H5921"\w* \w provecho|strong="H5532"\w* \w a|strong="H3068"\w* \w sí|strong="H3588"\w* mismo?   
\m
\v 3 ¿Tiene \w contentamiento|strong="H2656"\w* \w el|strong="H3588"\w* \w Todopoderoso|strong="H7706"\w* \w en|strong="H3588"\w* \w que|strong="H3588"\w* tú seas justo, gana algo \w con|strong="H3588"\w* \w que|strong="H3588"\w* tú hagas perfectos tus \w caminos|strong="H1870"\w*?   
\m
\v 4 ¿\w Te|strong="H5973"\w* castigará acaso, \w o|strong="H3068"\w* vendrá \w contigo|strong="H5973"\w* \w a|strong="H3068"\w* \w juicio|strong="H4941"\w* \w porque|strong="H3198"\w* \w te|strong="H5973"\w* teme?   
\m
\v 5 ¿Acaso \w no|strong="H3808"\w* \add es\add* \w grande|strong="H7227"\w* tu \w maldad|strong="H5771"\w*, y tus \w iniquidades|strong="H5771"\w* \w sin|strong="H3808"\w* \w fin|strong="H7093"\w*?   
\m
\v 6 \w Porque|strong="H3588"\w* sin causa tomaste prenda \w de|strong="H3588"\w* tus hermanos, \w y|strong="H3588"\w* despojaste \w de|strong="H3588"\w* sus ropas al \w desnudo|strong="H6174"\w*.   
\m
\v 7 \w No|strong="H3808"\w* diste \w de|strong="H4325"\w* \w beber|strong="H8248"\w* \w agua|strong="H4325"\w* al \w cansado|strong="H5889"\w*, y detuviste el \w pan|strong="H3899"\w* al hambriento.   
\m
\v 8 Pero \w el|strong="H3427"\w* hombre pudiente \w tuvo|strong="H5375"\w* la tierra; y \w habitó|strong="H3427"\w* en ella \w el|strong="H3427"\w* distinguido.   
\m
\v 9 \w A|strong="H3068"\w* las viudas \w enviaste|strong="H7971"\w* \w vacías|strong="H7387"\w*, y los \w brazos|strong="H2220"\w* de los \w huérfanos|strong="H3490"\w* fueron quebrados.   
\m
\v 10 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* hay \w lazos|strong="H6341"\w* \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* turba \w espanto|strong="H6343"\w* \w repentino|strong="H6597"\w*;   
\m
\v 11 \w o|strong="H3068"\w* \w tinieblas|strong="H2822"\w*, para \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w veas|strong="H7200"\w*; y abundancia \w de|strong="H4325"\w* \w agua|strong="H4325"\w* te \w cubre|strong="H3680"\w*.   
\m
\v 12 ¿\w No|strong="H3808"\w* está Dios \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w altura|strong="H1363"\w* del \w cielo|strong="H8064"\w*? \w Mira|strong="H7200"\w* \w lo|strong="H3808"\w* encumbrado \w de|strong="H3588"\w* las \w estrellas|strong="H3556"\w*, \w cuán|strong="H3588"\w* \w elevadas|strong="H7311"\w* están.   
\m
\v 13 ¿\w Y|strong="H3068"\w* dirás \w tú|strong="H8199"\w*: \w Qué|strong="H4100"\w* \w sabe|strong="H3045"\w* Dios? ¿Puede Él juzgar \w a|strong="H3068"\w* través de la densa \w oscuridad|strong="H6205"\w*?   
\m
\v 14 Las densas \w nubes|strong="H5645"\w* le cubren, y \w no|strong="H3808"\w* \w ve|strong="H1980"\w*; y por el circuito del \w cielo|strong="H8064"\w* \w se|strong="H3808"\w* \w pasea|strong="H1980"\w*.   
\m
\v 15 ¿Quieres tú \w guardar|strong="H8104"\w* \w la|strong="H8104"\w* senda \w antigua|strong="H5769"\w*, \w que|strong="H1869"\w* \w pisaron|strong="H1869"\w* los \w hombres|strong="H4962"\w* perversos?   
\m
\v 16 Los cuales fueron cortados antes \w de|strong="H6256"\w* \w tiempo|strong="H6256"\w*, cuyo \w fundamento|strong="H3247"\w* \w fue|strong="H3808"\w* como un \w río|strong="H5104"\w* \w derramado|strong="H3332"\w*:   
\m
\v 17 \w Que|strong="H4100"\w* decían \w a|strong="H3068"\w* Dios: \w Apártate|strong="H5493"\w* \w de|strong="H4480"\w* nosotros. ¿\w Y|strong="H3068"\w* \w qué|strong="H4100"\w* les había hecho el \w Todopoderoso|strong="H7706"\w*?   
\m
\v 18 Les había colmado \w de|strong="H4480"\w* bienes \w sus|strong="H1931"\w* \w casas|strong="H1004"\w*. \w Lejos|strong="H7368"\w* sea \w de|strong="H4480"\w* mí \w el|strong="H1931"\w* \w consejo|strong="H6098"\w* \w de|strong="H4480"\w* \w los|strong="H1931"\w* \w impíos|strong="H7563"\w*.   
\m
\v 19 \w Verán|strong="H7200"\w* los \w justos|strong="H6662"\w* \w y|strong="H5355"\w* se gozarán; \w y|strong="H5355"\w* el \w inocente|strong="H5355"\w* los escarnecerá, diciendo:   
\m
\v 20 Ciertamente nuestra \w sustancia|strong="H7009"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* sido \w cortada|strong="H3582"\w*, \w mas|strong="H3499"\w* el fuego \w ha|strong="H3808"\w* consumido \w lo|strong="H3808"\w* \w que|strong="H3808"\w* quedó de ellos.   
\m
\v 21 Amístate \w ahora|strong="H4994"\w* \w con|strong="H5973"\w* \w Él|strong="H5973"\w*, y tendrás \w paz|strong="H7999"\w*; y por ello \w te|strong="H5973"\w* vendrá \w bien|strong="H2896"\w*.   
\m
\v 22 \w Toma|strong="H3947"\w* \w ahora|strong="H4994"\w* la \w ley|strong="H8451"\w* de su \w boca|strong="H6310"\w*, y \w pon|strong="H7760"\w* sus \w palabras|strong="H6310"\w* en tu \w corazón|strong="H3824"\w*.   
\m
\v 23 Si te \w volvieres|strong="H7725"\w* \w al|strong="H5704"\w* \w Todopoderoso|strong="H7706"\w*, serás \w edificado|strong="H1129"\w*; \w alejarás|strong="H7368"\w* \w de|strong="H5704"\w* tu tienda la aflicción;   
\m
\v 24 entonces tendrás \w oro|strong="H1220"\w* \w como|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*, \w y|strong="H5921"\w* \w oro|strong="H1220"\w* \w de|strong="H5921"\w* Ofir \w como|strong="H5921"\w* \w las|strong="H5921"\w* piedras \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w arroyos|strong="H5158"\w*;   
\m
\v 25 y el \w Todopoderoso|strong="H7706"\w* \w será|strong="H1961"\w* tu defensa, y \w tendrás|strong="H1961"\w* \w plata|strong="H3701"\w* en abundancia.   
\m
\v 26 \w Porque|strong="H3588"\w* \w entonces|strong="H3588"\w* \w te|strong="H5921"\w* deleitarás \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w Todopoderoso|strong="H7706"\w*, \w y|strong="H3588"\w* alzarás \w a|strong="H3068"\w* Dios tu \w rostro|strong="H6440"\w*.   
\m
\v 27 \w Orarás|strong="H6279"\w* \w a|strong="H3068"\w* Él, y Él te \w oirá|strong="H8085"\w*; y tú pagarás tus \w votos|strong="H5088"\w*.   
\m
\v 28 \w Determinarás|strong="H1504"\w* asimismo una cosa, \w y|strong="H5921"\w* \w te|strong="H5921"\w* será \w firme|strong="H6965"\w*; \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* tus \w caminos|strong="H1870"\w* \w resplandecerá|strong="H5050"\w* \w la|strong="H5921"\w* luz.   
\m
\v 29 \w Cuando|strong="H3588"\w* fueren abatidos, \w entonces|strong="H3588"\w* tú dirás: \w Ensalzamiento|strong="H1466"\w* habrá; \w y|strong="H3588"\w* \w Él|strong="H3588"\w* \w salvará|strong="H3467"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* persona humilde.   
\m
\v 30 Él libertará la isla del \w inocente|strong="H5355"\w*; \w y|strong="H5355"\w* por la pureza de tus \w manos|strong="H3709"\w* será librada.   
\c 23
\m
\v 1 Entonces \w respondió|strong="H6030"\w* Job, y dijo:   
\m
\v 2 \w Hoy|strong="H3117"\w* \w también|strong="H1571"\w* \w hablaré|strong="H7879"\w* \w con|strong="H5921"\w* amargura; \w porque|strong="H5921"\w* \w es|strong="H3027"\w* \w más|strong="H1571"\w* grave \w mi|strong="H5921"\w* llaga \w que|strong="H5921"\w* \w mi|strong="H5921"\w* gemido.   
\m
\v 3 ¡\w Quién|strong="H4310"\w* \w me|strong="H4310"\w* \w diera|strong="H5414"\w* \w el|strong="H4310"\w* \w saber|strong="H3045"\w* dónde \w hallar|strong="H4672"\w* \w a|strong="H3068"\w* \add Dios\add*! Yo iría \w hasta|strong="H5704"\w* su silla.   
\m
\v 4 Expondría mi \w causa|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Él, y llenaría mi \w boca|strong="H6310"\w* \w de|strong="H6440"\w* argumentos.   
\m
\v 5 Yo sabría las \w palabras|strong="H4405"\w* \w que|strong="H4100"\w* Él me respondiera, y entendería \w lo|strong="H4100"\w* \w que|strong="H4100"\w* Él me dijera.   
\m
\v 6 ¿Contendería \w conmigo|strong="H5978"\w* \w con|strong="H5978"\w* \add su\add* \w gran|strong="H7227"\w* \w fuerza|strong="H3581"\w*? \w No|strong="H3808"\w*; antes \w Él|strong="H1931"\w* pondría \add fuerza\add* en mí.   
\m
\v 7 \w Allí|strong="H8033"\w* \w el|strong="H5973"\w* justo \w razonaría|strong="H3198"\w* \w con|strong="H5973"\w* \w Él|strong="H5973"\w*, y yo sería liberado \w para|strong="H5973"\w* siempre \w de|strong="H5973"\w* mi \w Juez|strong="H8199"\w*.   
\m
\v 8 He \w aquí|strong="H2005"\w* yo \w iré|strong="H1980"\w* al \w oriente|strong="H6924"\w*, y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* hallaré; y al occidente, y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* percibiré:   
\m
\v 9 \w Si|strong="H3808"\w* al norte \w Él|strong="H6213"\w* actuare, \w yo|strong="H6213"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w veré|strong="H7200"\w*; al sur \w se|strong="H3808"\w* esconderá, y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w veré|strong="H7200"\w*.   
\m
\v 10 \w Mas|strong="H3588"\w* \w Él|strong="H3588"\w* \w conoce|strong="H3045"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* donde voy; \w me|strong="H3588"\w* probará, \w y|strong="H3588"\w* \w saldré|strong="H3318"\w* \w como|strong="H3588"\w* \w oro|strong="H2091"\w*.   
\m
\v 11 Mis \w pies|strong="H7272"\w* han seguido sus pisadas; \w guardé|strong="H8104"\w* su \w camino|strong="H1870"\w*, y \w no|strong="H3808"\w* \w decliné|strong="H5186"\w*.   
\m
\v 12 Del \w mandamiento|strong="H6310"\w* de sus \w labios|strong="H8193"\w* \w nunca|strong="H3808"\w* me he apartado; he estimado las \w palabras|strong="H6310"\w* de su \w boca|strong="H6310"\w* \w más|strong="H3808"\w* \w que|strong="H3808"\w* mi comida.   
\m
\v 13 Pero \w si|strong="H1931"\w* \w Él|strong="H1931"\w* determina una \w cosa|strong="H5315"\w*, ¿\w quién|strong="H4310"\w* \w le|strong="H1931"\w* \w hará|strong="H6213"\w* desistir? \w Lo|strong="H1931"\w* \w que|strong="H4310"\w* \w su|strong="H1931"\w* \w alma|strong="H5315"\w* desea, \w eso|strong="H1931"\w* \w hace|strong="H6213"\w*.   
\m
\v 14 \w Él|strong="H5973"\w*, \w pues|strong="H3588"\w*, cumplirá \w lo|strong="H2007"\w* \w que|strong="H3588"\w* ha determinado \w de|strong="H3588"\w* mí: \w y|strong="H3588"\w* \w muchas|strong="H7227"\w* \add cosas\add* \w como|strong="H3588"\w* \w estas|strong="H2007"\w* \add hay\add* \w en|strong="H5973"\w* \w Él|strong="H5973"\w*.   
\m
\v 15 \w Por|strong="H5921"\w* \w lo|strong="H5921"\w* cual \w yo|strong="H4480"\w* tiemblo \w en|strong="H5921"\w* su \w presencia|strong="H6440"\w*; cuando \w lo|strong="H5921"\w* considero, \w tengo|strong="H5921"\w* \w miedo|strong="H6342"\w* \w de|strong="H4480"\w* \w Él|strong="H5921"\w*.   
\m
\v 16 Dios ha suavizado mi \w corazón|strong="H3820"\w*, y me ha turbado el \w Todopoderoso|strong="H7706"\w*.   
\m
\v 17 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w no|strong="H3808"\w* \w fui|strong="H3808"\w* \w yo|strong="H3588"\w* cortado \w delante|strong="H6440"\w* \w de|strong="H3588"\w* las \w tinieblas|strong="H2822"\w*, \add ni\add* \w cubrió|strong="H3680"\w* \w con|strong="H3588"\w* \w oscuridad|strong="H2822"\w* mi \w rostro|strong="H6440"\w*?   
\c 24
\m
\v 1 Puesto \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w son|strong="H3808"\w* ocultos los \w tiempos|strong="H3117"\w* \w al|strong="H6256"\w* \w Todopoderoso|strong="H7706"\w*, ¿\w Por|strong="H4069"\w* \w qué|strong="H3808"\w* los \w que|strong="H3808"\w* le \w conocen|strong="H3045"\w* \w no|strong="H3808"\w* \w ven|strong="H2372"\w* sus \w días|strong="H3117"\w*?   
\m
\v 2 \w Traspasan|strong="H5381"\w* los términos, \w roban|strong="H1497"\w* los ganados y se alimentan de ellos.   
\m
\v 3 Se llevan el \w asno|strong="H2543"\w* de los \w huérfanos|strong="H3490"\w*; \w y|strong="H7794"\w* toman en prenda el \w buey|strong="H7794"\w* de la viuda.   
\m
\v 4 Hacen apartar del \w camino|strong="H1870"\w* \w a|strong="H3068"\w* los menesterosos; y \w todos|strong="H3162"\w* los pobres de la tierra se esconden.   
\m
\v 5 He \w aquí|strong="H2005"\w*, como asnos monteses \w en|strong="H3318"\w* el \w desierto|strong="H4057"\w*, \w salen|strong="H3318"\w* \w a|strong="H3068"\w* su \w obra|strong="H6467"\w* \w madrugando|strong="H7836"\w* para robar; el \w desierto|strong="H4057"\w* \w es|strong="H6467"\w* \w mantenimiento|strong="H3899"\w* de sus hijos.   
\m
\v 6 En el \w campo|strong="H7704"\w* \w siegan|strong="H7114"\w* su pasto, y los \w impíos|strong="H7563"\w* \w vendimian|strong="H3953"\w* la \w viña|strong="H3754"\w* ajena.   
\m
\v 7 Al \w desnudo|strong="H6174"\w* hacen dormir \w sin|strong="H1097"\w* ropa, y que en \w el|strong="H3885"\w* frío \w no|strong="H1097"\w* tenga \w cobertura|strong="H3682"\w*.   
\m
\v 8 Mojados están con las lluvias de las montañas, y se abrazan \w a|strong="H3068"\w* la \w roca|strong="H6697"\w* por falta de abrigo.   
\m
\v 9 \w Quitan|strong="H1497"\w* el pecho \w a|strong="H3068"\w* los \w huérfanos|strong="H3490"\w*, y de sobre el \w pobre|strong="H6041"\w* toman la prenda;   
\m
\v 10 lo hacen \w andar|strong="H1980"\w* \w desnudo|strong="H6174"\w*, \w sin|strong="H1097"\w* ropa, y al hambriento \w quitan|strong="H5375"\w* las gavillas.   
\m
\v 11 Dentro de sus paredes exprimen el aceite, \w pisan|strong="H1869"\w* los lagares, y sufren de \w sed|strong="H6770"\w*.   
\m
\v 12 De la \w ciudad|strong="H5892"\w* \w gimen|strong="H5008"\w* los \w hombres|strong="H4962"\w*, y \w claman|strong="H7768"\w* las \w almas|strong="H5315"\w* de los \w heridos|strong="H2491"\w* de muerte; \w mas|strong="H3808"\w* Dios \w no|strong="H3808"\w* \w puso|strong="H7760"\w* estorbo.   
\m
\v 13 \w Ellos|strong="H1992"\w* \w son|strong="H1961"\w* de \w los|strong="H1992"\w* \w que|strong="H3808"\w* \w se|strong="H1961"\w* rebelan \w contra|strong="H1961"\w* la luz; \w no|strong="H3808"\w* conocen \w sus|strong="H1992"\w* \w caminos|strong="H1870"\w*, \w ni|strong="H3808"\w* permanecen en \w sus|strong="H1992"\w* sendas.   
\m
\v 14 \w A|strong="H3068"\w* la luz \w se|strong="H1961"\w* levanta el matador, \w mata|strong="H6991"\w* al \w pobre|strong="H6041"\w* y al necesitado, y de \w noche|strong="H3915"\w* \w es|strong="H1961"\w* \w como|strong="H1961"\w* un \w ladrón|strong="H1590"\w*.   
\m
\v 15 El \w ojo|strong="H5869"\w* del adúltero espera el anochecer, diciendo: \w Ningún|strong="H3808"\w* \w ojo|strong="H5869"\w* me verá; y disfraza su \w rostro|strong="H6440"\w*.   
\m
\v 16 En las \w tinieblas|strong="H2822"\w* \w minan|strong="H2864"\w* las \w casas|strong="H1004"\w*, \w que|strong="H3808"\w* de \w día|strong="H3119"\w* para \w sí|strong="H3808"\w* señalaron; \w no|strong="H3808"\w* \w conocen|strong="H3045"\w* la luz.   
