\v 4 \w También|strong="H1571"\w* \w yo|strong="H5315"\w* \w hablaría|strong="H1696"\w* \w como|strong="H1571"\w* \w vosotros|strong="H3426"\w*. \w Si|strong="H3863"\w* vuestra \w alma|strong="H5315"\w* \w estuviera|strong="H3426"\w* \w en|strong="H5921"\w* \w lugar|strong="H8478"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*, \w yo|strong="H5315"\w* podría hilvanar \w palabras|strong="H1696"\w* \w contra|strong="H5921"\w* \w vosotros|strong="H3426"\w*, \w y|strong="H1571"\w* \w sobre|strong="H5921"\w* \w vosotros|strong="H3426"\w* movería \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*.   
