\v 13 \w Así|strong="H3588"\w* se \w sentaron|strong="H3427"\w* \w con|strong="H3588"\w* \w él|strong="H3588"\w* \w en|strong="H3588"\w* tierra \w por|strong="H3588"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w y|strong="H3588"\w* \w siete|strong="H7651"\w* \w noches|strong="H3915"\w*, \w y|strong="H3588"\w* ninguno le \w hablaba|strong="H1696"\w* \w palabra|strong="H1697"\w*, \w porque|strong="H3588"\w* \w veían|strong="H7200"\w* \w que|strong="H3588"\w* \add su\add* dolor era \w muy|strong="H3966"\w* \w grande|strong="H3966"\w*.   
\c 3
\m
\v 1 Después de \w esto|strong="H3651"\w* \w abrió|strong="H6605"\w* Job su \w boca|strong="H6310"\w*, y \w maldijo|strong="H7043"\w* su \w día|strong="H3117"\w*.   
\m
\v 2 \w Y|strong="H3068"\w* exclamó Job, y dijo:   
\m
\v 3 Perezca el \w día|strong="H3117"\w* en \w que|strong="H3117"\w* yo \w nací|strong="H3205"\w*, y la \w noche|strong="H3915"\w* \add en que\add* se dijo: \w Varón|strong="H1397"\w* es concebido.   
\m
\v 4 \w Sea|strong="H1961"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w sombrío|strong="H2822"\w*, \w y|strong="H5921"\w* \w no|strong="H1961"\w* \w cuide|strong="H1875"\w* \w de|strong="H5921"\w* \w él|strong="H1931"\w* Dios \w desde|strong="H5921"\w* \w arriba|strong="H4605"\w*, ni \w claridad|strong="H5105"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* \w resplandezca|strong="H3313"\w*.   
\m
\v 5 \w Aféenlo|strong="H1350"\w* \w tinieblas|strong="H2822"\w* \w y|strong="H5921"\w* sombra \w de|strong="H5921"\w* \w muerte|strong="H6757"\w*; \w repose|strong="H7931"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* nublado, \w que|strong="H5921"\w* \w lo|strong="H5921"\w* haga horrible \w como|strong="H5921"\w* \w día|strong="H3117"\w* tenebroso.   
\m
\v 6 \w Ocupe|strong="H3947"\w* \w la|strong="H1931"\w* oscuridad \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*; \w que|strong="H1931"\w* no sea contada entre \w los|strong="H1931"\w* \w días|strong="H3117"\w* del \w año|strong="H8141"\w*, ni venga en \w el|strong="H1931"\w* \w número|strong="H4557"\w* de \w los|strong="H1931"\w* \w meses|strong="H3391"\w*.   
\m
\v 7 ¡Oh, \w que|strong="H1931"\w* \w fuera|strong="H1961"\w* solitaria \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*, \w que|strong="H1931"\w* \w no|strong="H1961"\w* viniera \w canción|strong="H7445"\w* alguna en \w ella|strong="H1931"\w*!   
\m
\v 8 \w Maldíganla|strong="H5344"\w* los \w que|strong="H3117"\w* maldicen el \w día|strong="H3117"\w*, los \w que|strong="H3117"\w* se alistan para levantar su llanto.   
\m
\v 9 Que se oscurezcan las \w estrellas|strong="H3556"\w* de su ocaso; Que \w espere|strong="H6960"\w* la luz, y no venga; y no \w vea|strong="H7200"\w* el amanecer del día:   
\m
\v 10 \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w no|strong="H3808"\w* \w cerró|strong="H5462"\w* las \w puertas|strong="H1817"\w* del vientre \add de mi madre\add*, \w ni|strong="H3808"\w* \w escondió|strong="H5641"\w* \w de|strong="H3588"\w* mis \w ojos|strong="H5869"\w* \w la|strong="H3588"\w* miseria.   
\m
\v 11 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w no|strong="H3808"\w* \w morí|strong="H4191"\w* yo \w en|strong="H3318"\w* la \w matriz|strong="H7358"\w*, \w o|strong="H3068"\w* entregué el espíritu al \w salir|strong="H3318"\w* del vientre?   
\m
\v 12 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w me|strong="H3588"\w* recibieron las \w rodillas|strong="H1290"\w*? ¿\w Y|strong="H3068"\w* \w para|strong="H3588"\w* \w qué|strong="H3588"\w* \w los|strong="H3588"\w* \w pechos|strong="H7699"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* dieron \w de|strong="H3588"\w* mamar?   
\m
\v 13 \w Pues|strong="H3588"\w* \w ahora|strong="H6258"\w* yacería \w yo|strong="H3588"\w*, \w y|strong="H3588"\w* reposaría; dormiría, \w y|strong="H3588"\w* \w entonces|strong="H3588"\w* tendría \w reposo|strong="H5117"\w*,   
\m
\v 14 \w con|strong="H5973"\w* \w los|strong="H5973"\w* \w reyes|strong="H4428"\w* y \w con|strong="H5973"\w* \w los|strong="H5973"\w* \w consejeros|strong="H3289"\w* \w de|strong="H5973"\w* la tierra, que \w edifican|strong="H1129"\w* \w para|strong="H5973"\w* sí lugares desolados;   
\m
\v 15 \w o|strong="H3068"\w* \w con|strong="H5973"\w* \w los|strong="H1992"\w* \w príncipes|strong="H8269"\w* \w que|strong="H1992"\w* poseían \w el|strong="H5973"\w* \w oro|strong="H2091"\w*, \w que|strong="H1992"\w* llenaban \w sus|strong="H1992"\w* \w casas|strong="H1004"\w* \w de|strong="H5973"\w* \w plata|strong="H3701"\w*.   
\m
\v 16 \w O|strong="H3068"\w* ¿por \w qué|strong="H3808"\w* \w no|strong="H3808"\w* \w fui|strong="H1961"\w* escondido \w como|strong="H1961"\w* abortado, \w como|strong="H1961"\w* \w los|strong="H1961"\w* pequeñitos \add que\add* \w nunca|strong="H3808"\w* \w vieron|strong="H7200"\w* la luz?   
\m
\v 17 \w Allí|strong="H8033"\w* los \w impíos|strong="H7563"\w* \w dejan|strong="H2308"\w* de perturbar, y \w allí|strong="H8033"\w* \w descansan|strong="H5117"\w* los de agotadas \w fuerzas|strong="H3581"\w*.   
\m
\v 18 Allí reposan \w juntos|strong="H3162"\w* los cautivos; \w no|strong="H3808"\w* \w oyen|strong="H8085"\w* la \w voz|strong="H6963"\w* del opresor.   
\m
\v 19 \w Allí|strong="H8033"\w* están \w el|strong="H1931"\w* chico y \w el|strong="H1931"\w* \w grande|strong="H1419"\w*; y \w el|strong="H1931"\w* \w siervo|strong="H5650"\w* \add es\add* \w libre|strong="H2670"\w* de \w su|strong="H1931"\w* señor.   
\m
\v 20 ¿\w Para|strong="H5414"\w* \w qué|strong="H4100"\w* \w se|strong="H4100"\w* \w da|strong="H5414"\w* luz al trabajado, y \w vida|strong="H5315"\w* al amargado \w de|strong="H5414"\w* \w alma|strong="H5315"\w*,   
\m
\v 21 que esperan la \w muerte|strong="H4194"\w*, y ella no \add llega\add*, aunque la buscan más que \w a|strong="H3068"\w* \w tesoros|strong="H4301"\w* escondidos;   
\m
\v 22 \w que|strong="H3588"\w* se \w alegran|strong="H8055"\w* sobremanera, \add y\add* se gozan, \w cuando|strong="H3588"\w* \w hallan|strong="H4672"\w* \w el|strong="H3588"\w* \w sepulcro|strong="H6913"\w*?   
\m
\v 23 ¿\add Para qué se da luz\add* \w al|strong="H1157"\w* \w hombre|strong="H1397"\w* \w que|strong="H1157"\w* \w no|strong="H1870"\w* \w sabe|strong="H5641"\w* \w por|strong="H1157"\w* dónde \w va|strong="H3068"\w*, y \w al|strong="H1157"\w* cual Dios ha acorralado?   
\m
\v 24 \w Pues|strong="H3588"\w* \w antes|strong="H6440"\w* \w que|strong="H3588"\w* mi \w comida|strong="H3899"\w* viene mi suspiro; \w y|strong="H3588"\w* mis gemidos \w corren|strong="H5413"\w* \w como|strong="H3588"\w* \w aguas|strong="H4325"\w*.   
\m
\v 25 \w Porque|strong="H3588"\w* aquello \w que|strong="H3588"\w* tanto \w me|strong="H3588"\w* espantaba, ha venido sobre mí, \w y|strong="H3588"\w* \w me|strong="H3588"\w* ha acontecido lo \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w temía|strong="H3025"\w*.   
\m
\v 26 \w No|strong="H3808"\w* estaba seguro, \w ni|strong="H3808"\w* descansaba, \w ni|strong="H3808"\w* estaba \w quieto|strong="H8252"\w*; \w sin|strong="H3808"\w* embargo, vino turbación.   
\c 4
\m
\v 1 Entonces \w respondió|strong="H6030"\w* Elifaz el \w temanita|strong="H8489"\w*, y dijo:   
\m
\v 2 \add Si\add* probáremos \w a|strong="H3068"\w* hablarte, te será molesto; pero, ¿\w quién|strong="H4310"\w* \w podrá|strong="H3201"\w* \w detener|strong="H6113"\w* las \w palabras|strong="H1697"\w*?   
\m
\v 3 He \w aquí|strong="H2009"\w*, tú has instruido \w a|strong="H3068"\w* \w muchos|strong="H7227"\w*, y las \w manos|strong="H3027"\w* débiles has fortalecido;   
\m
\v 4 Al que tropezaba, levantaban tus \w palabras|strong="H4405"\w*, y fortalecías las \w rodillas|strong="H1290"\w* que decaían.   
\m
\v 5 \w Pero|strong="H3588"\w* \w ahora|strong="H6258"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* mal ha venido sobre ti, \w te|strong="H3588"\w* desalientas; \w y|strong="H3588"\w* \w cuando|strong="H3588"\w* ha \w llegado|strong="H5060"\w* \w hasta|strong="H5704"\w* ti, \w te|strong="H3588"\w* turbas.   
\m
\v 6 ¿Es \add este\add* tu temor, tu confianza, tu \w esperanza|strong="H8615"\w*, y la \w integridad|strong="H8537"\w* de tus \w caminos|strong="H1870"\w*?   
\m
\v 7 \w Recapacita|strong="H2142"\w* \w ahora|strong="H4994"\w*, ¿\w quién|strong="H4310"\w* \w siendo|strong="H1931"\w* \w inocente|strong="H5355"\w* pereció? ¿\w O|strong="H3068"\w* \w dónde|strong="H1931"\w* \w los|strong="H1931"\w* \w rectos|strong="H3477"\w* fueron cortados?   
\m
\v 8 Como yo he \w visto|strong="H7200"\w*, los que aran iniquidad y siembran maldad, eso mismo cosechan.   
\m
\v 9 Perecen por el \w soplo|strong="H7307"\w* \w de|strong="H5397"\w* Dios, y por el aliento \w de|strong="H5397"\w* su nariz son consumidos.   
\m
\v 10 El rugido del \w león|strong="H7826"\w*, y la \w voz|strong="H6963"\w* del fiero \w león|strong="H7826"\w*, y los \w dientes|strong="H8127"\w* de los leoncillos son quebrantados.   
\m
\v 11 \w El|strong="H1121"\w* león viejo perece por falta \w de|strong="H1121"\w* presa, y \w los|strong="H1121"\w* cachorros del león son dispersados.   
\m
\v 12 Un \w asunto|strong="H1697"\w* \w me|strong="H4480"\w* fue traído \w en|strong="H4480"\w* secreto; y mi oído percibió un \w poco|strong="H8102"\w* \w de|strong="H4480"\w* ello.   
\m
\v 13 \w En|strong="H5921"\w* imaginaciones \w de|strong="H5921"\w* \w visiones|strong="H2384"\w* \w nocturnas|strong="H3915"\w*, cuando \w el|strong="H5921"\w* sueño profundo \w cae|strong="H5307"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* hombres,   
\m
\v 14 \w Temor|strong="H6343"\w* me sobrevino, y un temblor \w que|strong="H6343"\w* estremeció \w todos|strong="H7230"\w* mis \w huesos|strong="H6106"\w*.   
\m
\v 15 Entonces un \w espíritu|strong="H7307"\w* pasó \w por|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w que|strong="H5921"\w* hizo \w se|strong="H5921"\w* erizara \w el|strong="H5921"\w* pelo \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w carne|strong="H1320"\w*;   
\m
\v 16 \w se|strong="H3808"\w* \w quedó|strong="H5975"\w* inmóvil, pero \w no|strong="H3808"\w* pude discernir su forma, una \w imagen|strong="H8544"\w* \w estaba|strong="H5975"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* mis \w ojos|strong="H5869"\w*, hubo silencio, y \w oí|strong="H8085"\w* una \w voz|strong="H6963"\w* \w que|strong="H3808"\w* \add decía\add*:   
\m
\v 17 ¿\w Será|strong="H6213"\w* \w el|strong="H6213"\w* \w hombre|strong="H1397"\w* mortal más justo que Dios? ¿\w Será|strong="H6213"\w* \w el|strong="H6213"\w* \w hombre|strong="H1397"\w* más puro que su \w Hacedor|strong="H6213"\w*?   
\m
\v 18 He \w aquí|strong="H2005"\w* \w que|strong="H3808"\w* en sus \w siervos|strong="H5650"\w* \w no|strong="H3808"\w* confía, y notó \w necedad|strong="H8417"\w* en sus \w ángeles|strong="H4397"\w*.   
\m
\v 19 ¡Cuánto más en los que \w habitan|strong="H7931"\w* en \w casas|strong="H1004"\w* \w de|strong="H6440"\w* \w barro|strong="H2563"\w*, cuyo \w fundamento|strong="H3247"\w* \add está\add* en el \w polvo|strong="H6083"\w*, \add y que\add* serán quebrantados \w por|strong="H6440"\w* la \w polilla|strong="H6211"\w*!   
\m
\v 20 De la \w mañana|strong="H1242"\w* \w a|strong="H3068"\w* la \w tarde|strong="H6153"\w* son destruidos, perecen para siempre, \w sin|strong="H1097"\w* haber quien \add lo\add* considere.   
\m
\v 21 Su excelencia, ¿\w no|strong="H3808"\w* \w se|strong="H3808"\w* pierde con ellos mismos? \w Mueren|strong="H4191"\w*, \w aun|strong="H3808"\w* \w sin|strong="H3808"\w* \w sabiduría|strong="H2451"\w*.   
\c 5
\m
\v 1 \w Llama|strong="H7121"\w* \w ahora|strong="H4994"\w*, \w si|strong="H4994"\w* \w hay|strong="H3426"\w* \w quien|strong="H4310"\w* te \w responda|strong="H6030"\w*; ¿\w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w cuál|strong="H4310"\w* de los \w santos|strong="H6918"\w* te volverás?   
\m
\v 2 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* ira \w mata|strong="H4191"\w* al hombre necio, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w envidia|strong="H7068"\w* \w consume|strong="H4191"\w* al ingenuo.   
\m
\v 3 \w Yo|strong="H5344"\w* he \w visto|strong="H7200"\w* al necio echar raíces, pero de repente \w maldije|strong="H5344"\w* su habitación.   
\m
\v 4 Sus \w hijos|strong="H1121"\w* están \w lejos|strong="H7368"\w* \w de|strong="H1121"\w* la seguridad, en la \w puerta|strong="H8179"\w* son quebrantados, y no \add hay\add* quien \w los|strong="H1121"\w* \w libre|strong="H5337"\w*.   
\m
\v 5 Su \w mies|strong="H7105"\w* comen los hambrientos, y la sacan aun de entre los espinos, y el atracador devora su hacienda.   
\m
\v 6 \w Aunque|strong="H3588"\w* \w la|strong="H3588"\w* aflicción \w no|strong="H3808"\w* \w sale|strong="H3318"\w* del \w polvo|strong="H6083"\w*, \w ni|strong="H3808"\w* \w la|strong="H3588"\w* angustia \w brota|strong="H6779"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w tierra|strong="H6083"\w*.   
\m
\v 7 \w Pero|strong="H3588"\w* \w como|strong="H3588"\w* las chispas se levantan \w para|strong="H3588"\w* volar \w por|strong="H3588"\w* \w el|strong="H3588"\w* aire, \w así|strong="H3588"\w* \w el|strong="H3588"\w* \w hombre|strong="H1121"\w* \w nace|strong="H3205"\w* \w para|strong="H3588"\w* \w la|strong="H3588"\w* aflicción.   
\m
\v 8 \w Ciertamente|strong="H1875"\w* yo \w buscaría|strong="H1875"\w* \w a|strong="H3068"\w* Dios, y \w a|strong="H3068"\w* Dios encomendaría mi causa:   
\m
\v 9 \w El|strong="H6213"\w* cual \w hace|strong="H6213"\w* cosas \w grandes|strong="H1419"\w* \w e|strong="H3068"\w* inescrutables, \w y|strong="H5704"\w* \w maravillas|strong="H6381"\w* sin \w número|strong="H4557"\w*;   
\m
\v 10 \w Que|strong="H5921"\w* \w da|strong="H5414"\w* \w la|strong="H5921"\w* \w lluvia|strong="H4306"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w envía|strong="H7971"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* campos:   
\m
\v 11 Para poner en \w alto|strong="H7682"\w* \w a|strong="H3068"\w* los humildes, y levantar \w a|strong="H3068"\w* seguridad \w a|strong="H3068"\w* los enlutados.   
\m
\v 12 \w Él|strong="H6213"\w* frustra los \w pensamientos|strong="H4284"\w* de los astutos, para \w que|strong="H3808"\w* sus \w manos|strong="H3027"\w* \w no|strong="H3808"\w* \w hagan|strong="H6213"\w* \w nada|strong="H3808"\w*;   
\m
\v 13 Él prende \w a|strong="H3068"\w* \w los|strong="H2450"\w* \w sabios|strong="H2450"\w* en su propia astucia, y entontece el \w consejo|strong="H6098"\w* de \w los|strong="H2450"\w* perversos;   
\m
\v 14 De \w día|strong="H3119"\w* tropiezan con \w tinieblas|strong="H2822"\w*, y \w a|strong="H3068"\w* medio \w día|strong="H3119"\w* andan \w a|strong="H3068"\w* tientas como de \w noche|strong="H3915"\w*.   
\m
\v 15 Pero Él \w salva|strong="H3467"\w* al pobre de la \w espada|strong="H2719"\w*, de la \w boca|strong="H6310"\w*, y de la \w mano|strong="H3027"\w* del poderoso.   
\m
\v 16 Por tanto, el \w pobre|strong="H1800"\w* \w tiene|strong="H1961"\w* \w esperanza|strong="H8615"\w*, y la \w iniquidad|strong="H5766"\w* cierra su \w boca|strong="H6310"\w*.   
\m
\v 17 He \w aquí|strong="H2009"\w*, bienaventurado es el hombre \w a|strong="H3068"\w* quien Dios \w corrige|strong="H3198"\w*; por tanto, no menosprecies el castigo del \w Todopoderoso|strong="H7706"\w*.   
\m
\v 18 \w Porque|strong="H3588"\w* \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w quien|strong="H1931"\w* hace \w la|strong="H1931"\w* llaga, \w y|strong="H3588"\w* \w Él|strong="H1931"\w* \w la|strong="H1931"\w* venda: \w Él|strong="H1931"\w* \w hiere|strong="H4272"\w*, \w y|strong="H3588"\w* \w sus|strong="H1931"\w* \w manos|strong="H3027"\w* sanan.   
\m
\v 19 En \w seis|strong="H8337"\w* \w tribulaciones|strong="H6869"\w* te \w librará|strong="H5337"\w*, y en la séptima \w no|strong="H3808"\w* te \w tocará|strong="H5060"\w* el \w mal|strong="H7451"\w*.   
\m
\v 20 En el \w hambre|strong="H7458"\w* te \w redimirá|strong="H6299"\w* de la \w muerte|strong="H4194"\w*, y en la \w guerra|strong="H4421"\w*, del \w poder|strong="H3027"\w* de la \w espada|strong="H2719"\w*.   
\m
\v 21 Del \w azote|strong="H7752"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w lengua|strong="H3956"\w* serás encubierto; \w no|strong="H3808"\w* \w temerás|strong="H3372"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w destrucción|strong="H7701"\w* \w cuando|strong="H3588"\w* viniere.   
\m
\v 22 \w De|strong="H3372"\w* la \w destrucción|strong="H7701"\w* y del hambre te reirás, y no \w temerás|strong="H3372"\w* \w de|strong="H3372"\w* las fieras del campo;   
