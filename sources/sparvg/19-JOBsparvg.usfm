\v 15 \w entonces|strong="H3588"\w* \w levantarás|strong="H5375"\w* tu \w rostro|strong="H6440"\w* limpio \w de|strong="H3588"\w* \w mancha|strong="H3971"\w*, \w y|strong="H3588"\w* \w serás|strong="H1961"\w* \w fuerte|strong="H3332"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w temerás|strong="H3372"\w*;   
