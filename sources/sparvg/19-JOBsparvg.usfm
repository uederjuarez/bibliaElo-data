\v 22 \add Dios\add*, pues, descargará \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w perdonará|strong="H2550"\w*; \w hará|strong="H1272"\w* \w él|strong="H5921"\w* \w por|strong="H5921"\w* huir \w de|strong="H5921"\w* su \w mano|strong="H3027"\w*.   
