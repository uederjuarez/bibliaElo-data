\m
\v 20 ¿Le intimidarás tú como \w a|strong="H3068"\w* langosta? El resoplido de su nariz es formidable:   
\m
\v 21 \w Escarba|strong="H2658"\w* la tierra, se alegra \w en|strong="H3318"\w* su \w fuerza|strong="H3581"\w*, \w sale|strong="H3318"\w* al encuentro del hombre armado:   
\m
\v 22 \w Se|strong="H3808"\w* burla del \w miedo|strong="H6343"\w*, y \w no|strong="H3808"\w* tiene \w temor|strong="H6343"\w*, \w ni|strong="H3808"\w* retrocede \w ante|strong="H6440"\w* la \w espada|strong="H2719"\w*.   
\m
\v 23 \w Contra|strong="H5921"\w* \w él|strong="H5921"\w* suena \w la|strong="H5921"\w* aljaba, \w la|strong="H5921"\w* \w lanza|strong="H2595"\w* reluciente \w y|strong="H5921"\w* \w el|strong="H5921"\w* escudo;   
\m
\v 24 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* \w con|strong="H3588"\w* ímpetu \w y|strong="H3588"\w* furor \w escarba|strong="H1572"\w* \w la|strong="H3588"\w* tierra, \w sin|strong="H3808"\w* \w importarle|strong="H3588"\w* \w el|strong="H3588"\w* \w sonido|strong="H6963"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w trompeta|strong="H7782"\w*;   
\m
\v 25 Antes como que dice \w entre|strong="H1767"\w* las \w trompetas|strong="H7782"\w*: ¡\w Ea|strong="H1889"\w*, \w Ea|strong="H1889"\w*! \w Y|strong="H3068"\w* \w desde|strong="H1767"\w* \w lejos|strong="H7350"\w* olfatea la \w batalla|strong="H4421"\w*, el estruendo \w de|strong="H8269"\w* los \w capitanes|strong="H8269"\w*, y el \w vocerío|strong="H8643"\w*.   
\m
\v 26 ¿Vuela el halcón por tu sabiduría, y \w extiende|strong="H6566"\w* hacia el sur sus \w alas|strong="H3671"\w*?   
\m
\v 27 ¿\w Se|strong="H5921"\w* remonta \w el|strong="H5921"\w* águila \w por|strong="H5921"\w* tu \w mandamiento|strong="H6310"\w*, \w y|strong="H3588"\w* hace \w en|strong="H5921"\w* \w alto|strong="H7311"\w* \w su|strong="H3588"\w* \w nido|strong="H7064"\w*?   
\m
\v 28 \w Ella|strong="H5921"\w* \w habita|strong="H7931"\w* \w y|strong="H5921"\w* permanece \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w roca|strong="H5553"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* cumbre \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w roca|strong="H5553"\w*, \w en|strong="H5921"\w* lugar seguro.   
\m
\v 29 Desde \w allí|strong="H8033"\w* \w acecha|strong="H2658"\w* la presa; sus \w ojos|strong="H5869"\w* \w observan|strong="H5027"\w* desde muy \w lejos|strong="H7350"\w*.   
\m
\v 30 \w Sus|strong="H1931"\w* polluelos \w chupan|strong="H5966"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w*; y \w donde|strong="H8033"\w* \add están\add* \w los|strong="H1931"\w* \w muertos|strong="H2491"\w*, \w allí|strong="H8033"\w* \add está\add* \w ella|strong="H1931"\w*.   
\c 40
\m
\v 1 Además \w respondió|strong="H6030"\w* \w Jehová|strong="H3068"\w* \w a|strong="H3068"\w* Job y dijo:   
\m
\v 2 ¿Es sabiduría \w contender|strong="H7378"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w Omnipotente|strong="H7706"\w*? \w El|strong="H5973"\w* que \w disputa|strong="H7378"\w* \w con|strong="H5973"\w* Dios, \w responda|strong="H6030"\w* \w a|strong="H3068"\w* esto.   
\m
\v 3 \w Y|strong="H3068"\w* \w respondió|strong="H6030"\w* Job \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, y dijo:   
\m
\v 4 He \w aquí|strong="H2005"\w* \w que|strong="H4100"\w* yo soy vil, ¿\w qué|strong="H4100"\w* te responderé? Mi \w mano|strong="H3027"\w* \w pongo|strong="H7760"\w* sobre mi \w boca|strong="H6310"\w*.   
\m
\v 5 Una vez \w hablé|strong="H1696"\w*, \w mas|strong="H3254"\w* \w no|strong="H3808"\w* \w responderé|strong="H6030"\w*: \w Aun|strong="H3254"\w* \w dos|strong="H8147"\w* veces, pero \w no|strong="H3808"\w* \w añadiré|strong="H3254"\w* \w más|strong="H3254"\w*.   
\m
\v 6 Entonces \w respondió|strong="H6030"\w* \w Jehová|strong="H3068"\w* \w a|strong="H3068"\w* Job \w desde|strong="H4480"\w* el torbellino, y dijo:   
\m
\v 7 Cíñete \w ahora|strong="H4994"\w* como \w hombre|strong="H1397"\w* tus \w lomos|strong="H2504"\w*; \w Yo|strong="H4994"\w* te \w preguntaré|strong="H7592"\w*, y tú me lo declararás.   
\m
\v 8 ¿\w Invalidarás|strong="H6565"\w* tú también mi \w juicio|strong="H4941"\w*? ¿Me condenarás \w a|strong="H3068"\w* mí, \w para|strong="H4616"\w* justificarte tú?   
\m
\v 9 ¿Tienes tú un \w brazo|strong="H2220"\w* \w como|strong="H3644"\w* Dios? ¿\w Y|strong="H3068"\w* tronarás tú con \w voz|strong="H6963"\w* \w como|strong="H3644"\w* Él?   
\m
\v 10 Atavíate \w ahora|strong="H4994"\w* \w de|strong="H3847"\w* majestad y \w de|strong="H3847"\w* alteza; y \w vístete|strong="H3847"\w* \w de|strong="H3847"\w* \w honra|strong="H1935"\w* y \w de|strong="H3847"\w* \w hermosura|strong="H1926"\w*.   
\m
\v 11 \w Esparce|strong="H6327"\w* \w el|strong="H3605"\w* furor de tu ira; y \w mira|strong="H7200"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w soberbio|strong="H1343"\w*, y abátelo.   
\m
\v 12 \w Mira|strong="H7200"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w soberbio|strong="H1343"\w*, y humíllalo, y pisotea \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w impíos|strong="H7563"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w*.   
\m
\v 13 Escóndelos \w juntos|strong="H3162"\w* en el \w polvo|strong="H6083"\w*, \add y\add* venda sus \w rostros|strong="H6440"\w* en oscuridad;   
\m
\v 14 \w Entonces|strong="H3588"\w* \w yo|strong="H3588"\w* \w también|strong="H1571"\w* \w te|strong="H3588"\w* \w confesaré|strong="H3034"\w* \w que|strong="H3588"\w* tu \w diestra|strong="H3225"\w* \w te|strong="H3588"\w* puede \w salvar|strong="H3467"\w*.   
\m
\v 15 He \w aquí|strong="H2009"\w* \w ahora|strong="H4994"\w* behemot, al \w cual|strong="H5973"\w* \w yo|strong="H2009"\w* \w hice|strong="H6213"\w* \w contigo|strong="H5973"\w*; \w él|strong="H5973"\w* come \w hierba|strong="H2682"\w* \w como|strong="H5973"\w* un buey.   
\m
\v 16 He \w aquí|strong="H2009"\w* \w ahora|strong="H4994"\w* \w que|strong="H4994"\w* su \w fuerza|strong="H3581"\w* está en sus \w lomos|strong="H4975"\w*, y su \w vigor|strong="H3581"\w* en el ombligo de su vientre.   
\m
\v 17 Su \w cola|strong="H2180"\w* \w mueve|strong="H2654"\w* \w como|strong="H3644"\w* un cedro, y los nervios de sus genitales están entretejidos.   
\m
\v 18 Sus \w huesos|strong="H6106"\w* son fuertes como bronce, y sus miembros como barras de \w hierro|strong="H1270"\w*.   
\m
\v 19 \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* principal de \w los|strong="H1931"\w* \w caminos|strong="H1870"\w* de Dios: \w El|strong="H1931"\w* \w que|strong="H1931"\w* \w lo|strong="H1931"\w* \w hizo|strong="H6213"\w*, puede \w hacer|strong="H6213"\w* \w que|strong="H1931"\w* \w su|strong="H1931"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w se|strong="H1931"\w* acerque.   
\m
\v 20 \w Ciertamente|strong="H3588"\w* las montañas \w producen|strong="H5375"\w* alimento \w para|strong="H3588"\w* \w él|strong="H3588"\w*; \w y|strong="H3588"\w* \w todas|strong="H3605"\w* las \w bestias|strong="H2416"\w* del \w campo|strong="H7704"\w* retozan \w allí|strong="H8033"\w*.   
\m
\v 21 Se echará \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* las sombras, \w en|strong="H8478"\w* lo oculto \w de|strong="H8478"\w* las \w cañas|strong="H7070"\w*, y \w de|strong="H8478"\w* los lugares húmedos.   
\m
\v 22 Los árboles sombríos lo cubren con su sombra; los sauces del \w arroyo|strong="H5158"\w* lo rodean.   
\m
\v 23 He \w aquí|strong="H2005"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* bebe un \w río|strong="H5104"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* inmuta; \w y|strong="H3588"\w* confía \w que|strong="H3588"\w* puede pasarse \w el|strong="H3588"\w* \w Jordán|strong="H3383"\w* \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w boca|strong="H6310"\w*.   
\m
\v 24 Él lo \w toma|strong="H3947"\w* con sus \w ojos|strong="H5869"\w*; y \add su\add* nariz atraviesa los \w lazos|strong="H4170"\w*.   
\c 41
\m
\v 1 ¿Sacarás tú al leviatán \w con|strong="H1571"\w* \w el|strong="H1571"\w* anzuelo, \w o|strong="H3068"\w* \w con|strong="H1571"\w* \w la|strong="H1571"\w* cuerda \w que|strong="H1571"\w* le eches en su lengua?   
\m
\v 2 ¿Pondrás tú garfio \w en|strong="H3588"\w* \w sus|strong="H1931"\w* narices, \w y|strong="H3588"\w* horadarás \w con|strong="H3588"\w* espina \w su|strong="H1931"\w* quijada?   
\m
\v 3 ¿Multiplicará \w él|strong="H1931"\w* ruegos para contigo? ¿Te hablará \w él|strong="H1931"\w* lisonjas?   
\m
\v 4 ¿Hará pacto contigo? ¿Le tomarás \w por|strong="H1697"\w* siervo para siempre?   
\m
\v 5 ¿Jugarás tú con \w él|strong="H4310"\w* como con un pájaro, \w o|strong="H3068"\w* lo atarás para tus doncellas?   
\m
\v 6 ¿Harán \w de|strong="H6440"\w* \w él|strong="H4310"\w* banquete los compañeros? ¿Lo repartirán entre los mercaderes?   
\m
\v 7 ¿Cortarás tú con cuchillo su piel, \w o|strong="H3068"\w* con arpón de pescadores su cabeza?   
\m
\v 8 Pon tu mano sobre \w él|strong="H5066"\w*; te acordarás de la batalla, y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* volverás \w a|strong="H3068"\w* hacer.   
\m
\v 9 He aquí \w que|strong="H3808"\w* la esperanza acerca de él \w será|strong="H3808"\w* burlada; \w porque|strong="H3808"\w* con solo verlo \w se|strong="H3808"\w* desmayarán.   
\m
\v 10 \w Nadie|strong="H5869"\w* hay tan osado que lo despierte: ¿Quién, pues, podrá estar \w delante|strong="H5869"\w* \w de|strong="H5869"\w* mí?   
\m
\v 11 ¿Quién me ha dado \w a|strong="H3068"\w* mi primero, para \w que|strong="H6310"\w* yo \add se lo\add* restituya? Todo lo \w que|strong="H6310"\w* hay debajo del cielo es mío.   
\m
\v 12 Yo no callaré \w en|strong="H3318"\w* cuanto \w a|strong="H3068"\w* sus miembros, ni lo de sus fuerzas y la gracia de su proporción.   
\m
\v 13 ¿Quién descubrirá la delantera de su vestidura? ¿Quién se acercará \w a|strong="H3068"\w* él con freno doble?   
\m
\v 14 ¿Quién abrirá las puertas \w de|strong="H6440"\w* su \w rostro|strong="H6440"\w*? Las hileras \w de|strong="H6440"\w* sus dientes espantan.   
\m
\v 15 Sus escamas son su orgullo, cerradas \w entre|strong="H5921"\w* \w sí|strong="H5921"\w* estrechamente.   
\m
\v 16 La una se junta con la \w otra|strong="H3644"\w*, que viento no entra entre ellas.   
\m
\v 17 Unida está la una con la otra, están trabadas entre sí, que no se pueden separar.   
\m
\v 18 Con sus estornudos encienden lumbre, y sus ojos son como los párpados del alba.   
\m
\v 19 De su boca salen antorchas de fuego, centellas de fuego proceden.   
\m
\v 20 \w De|strong="H1121"\w* sus narices sale humo, como \w de|strong="H1121"\w* una olla \w o|strong="H3068"\w* caldero \w que|strong="H3808"\w* hierve.   
\m
\v 21 Su aliento enciende los carbones, y de su boca sale llama.   
\m
\v 22 \w En|strong="H5921"\w* su cerviz mora \w la|strong="H5921"\w* fortaleza, \w y|strong="H5921"\w* \w la|strong="H5921"\w* tristeza \w se|strong="H5921"\w* convierte \w en|strong="H5921"\w* gozo \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*.   
\m
\v 23 Las pliegues de su carne están unidos, firmes están en él; no pueden ser movidos.   
\m
\v 24 Su corazón es firme como una piedra, y fuerte como la muela de abajo.   
\m
\v 25 Cuando \w él|strong="H5921"\w* \w se|strong="H5921"\w* levanta, \w los|strong="H5921"\w* poderosos tiemblan, \w y|strong="H5921"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* su desfallecimiento \w se|strong="H5921"\w* purifican.   
\m
\v 26 \w La|strong="H1931"\w* espada \w que|strong="H1931"\w* \w lo|strong="H1931"\w* alcance \w no|strong="H5921"\w* prevalecerá \w contra|strong="H5921"\w* \w él|strong="H1931"\w*: ni lanza, ni dardo, ni coselete.   
\m
\v 27 Estima el hierro como paja, y el bronce como leño podrido.   
\m
\v 28 Saeta no le hace huir; las piedras de honda se le tornan paja.   
\m
\v 29 Los dardos cuenta como rastrojo, se ríe del blandir de la jabalina.   
\m
\v 30 Por debajo tiene agudas conchas; Imprime su agudeza en el suelo.   
\m
\v 31 Hace hervir las profundidades como una olla, hace el mar como un frasco de ungüento.   
\m
\v 32 En pos de sí hace resplandecer la senda, que parece que el abismo sea cano.   
\m
\v 33 No hay sobre la tierra semejante \w a|strong="H3068"\w* él, que es hecho libre de temor.   
\m
\v 34 Menosprecia toda cosa alta: Es rey sobre todos los soberbios.   
\c 42
\m
\v 1 Entonces \w respondió|strong="H6030"\w* Job \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, y dijo:   
\m
\v 2 \w Yo|strong="H4480"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w puedes|strong="H3201"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* hay \w pensamiento|strong="H4209"\w* \w que|strong="H3588"\w* \w se|strong="H3045"\w* esconda \w de|strong="H4480"\w* \w ti|strong="H4480"\w*.   
\m
\v 3 ¿\w Quién|strong="H4310"\w* \w es|strong="H2088"\w* \w el|strong="H4310"\w* \w que|strong="H4480"\w* oscurece \w el|strong="H4310"\w* \w consejo|strong="H6098"\w* \w sin|strong="H3808"\w* \w conocimiento|strong="H1847"\w*? \w Por|strong="H4480"\w* \w tanto|strong="H3651"\w*, \w yo|strong="H4480"\w* hablaba \w lo|strong="H2088"\w* \w que|strong="H4480"\w* \w no|strong="H3808"\w* \w entendía|strong="H3045"\w*; \w cosas|strong="H3045"\w* muy \w maravillosas|strong="H6381"\w* \w para|strong="H4480"\w* mí, \w que|strong="H4480"\w* \w yo|strong="H4480"\w* \w no|strong="H3808"\w* \w sabía|strong="H3045"\w*.   
\m
\v 4 \w Oye|strong="H8085"\w* te \w ruego|strong="H4994"\w*, y \w hablaré|strong="H1696"\w*; te \w preguntaré|strong="H7592"\w*, y tú me enseñarás.   
\m
\v 5 \w De|strong="H5869"\w* oídas \w te|strong="H5869"\w* había \w oído|strong="H8085"\w*; \w mas|strong="H6258"\w* \w ahora|strong="H6258"\w* mis \w ojos|strong="H5869"\w* \w te|strong="H5869"\w* \w ven|strong="H7200"\w*.   
\m
\v 6 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* \w me|strong="H5921"\w* \w aborrezco|strong="H3988"\w*, \w y|strong="H5921"\w* \w me|strong="H5921"\w* arrepiento \w en|strong="H5921"\w* \w polvo|strong="H6083"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* ceniza.   
\m
\v 7 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w después|strong="H1961"\w* \w que|strong="H3588"\w* \w Jehová|strong="H3068"\w* \w habló|strong="H1696"\w* estas \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* Job, \w Jehová|strong="H3068"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* Elifaz \w temanita|strong="H8489"\w*: \w Mi|strong="H1961"\w* ira \w se|strong="H1961"\w* encendió \w contra|strong="H1961"\w* ti \w y|strong="H3588"\w* tus \w dos|strong="H8147"\w* \w compañeros|strong="H7453"\w*; \w porque|strong="H3588"\w* \w no|strong="H3808"\w* habéis \w hablado|strong="H1696"\w* \w de|strong="H3588"\w* \w mí|strong="H1961"\w* \w lo|strong="H1697"\w* \w recto|strong="H3559"\w*, \w como|strong="H3588"\w* \w mi|strong="H1961"\w* \w siervo|strong="H5650"\w* Job.   
\m
\v 8 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \w tomaos|strong="H3947"\w* \w siete|strong="H7651"\w* \w becerros|strong="H6499"\w* \w y|strong="H3588"\w* \w siete|strong="H7651"\w* carneros, \w e|strong="H3068"\w* \w id|strong="H3212"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* Job, \w y|strong="H3588"\w* ofreced \w holocausto|strong="H5930"\w* \w por|strong="H5921"\w* \w vosotros|strong="H5973"\w*, \w y|strong="H3588"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* Job \w orará|strong="H6419"\w* \w por|strong="H5921"\w* \w vosotros|strong="H5973"\w*; \w porque|strong="H3588"\w* \w de|strong="H5921"\w* \w cierto|strong="H3588"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* atenderé \w para|strong="H5921"\w* \w no|strong="H3808"\w* \w trataros|strong="H6213"\w* \w según|strong="H5921"\w* vuestra insensatez, \w por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w no|strong="H3808"\w* habéis \w hablado|strong="H1696"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w con|strong="H5973"\w* \w rectitud|strong="H3559"\w*, \w como|strong="H3588"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* Job.   
\m
\v 9 \w Fueron|strong="H3212"\w*, pues, Elifaz \w temanita|strong="H8489"\w*, y \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w*, y Zofar \w naamatita|strong="H5284"\w*, \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* como \w Jehová|strong="H3068"\w* les \w dijo|strong="H1696"\w*: y \w Jehová|strong="H3068"\w* aceptó \w a|strong="H3068"\w* Job.   
\m
\v 10 \w Y|strong="H3068"\w* \w Jehová|strong="H3068"\w* mudó \w la|strong="H3605"\w* aflicción de Job, cuando \w él|strong="H3605"\w* \w oró|strong="H6419"\w* \w por|strong="H1157"\w* sus \w amigos|strong="H7453"\w*. \w Y|strong="H3068"\w* \w Jehová|strong="H3068"\w* aumentó \w al|strong="H1157"\w* doble \w todas|strong="H3605"\w* las cosas \w que|strong="H1157"\w* habían sido de Job.   
