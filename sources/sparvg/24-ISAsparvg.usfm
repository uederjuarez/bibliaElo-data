\v 12 \w el|strong="H6213"\w* \w que|strong="H4325"\w* los \w guió|strong="H3212"\w* \w por|strong="H6440"\w* la \w diestra|strong="H3225"\w* \w de|strong="H6440"\w* \w Moisés|strong="H4872"\w* con \w el|strong="H6213"\w* \w brazo|strong="H2220"\w* \w de|strong="H6440"\w* su \w gloria|strong="H8597"\w*; \w el|strong="H6213"\w* \w que|strong="H4325"\w* dividió las \w aguas|strong="H4325"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos, \w haciéndose|strong="H6213"\w* así \w nombre|strong="H8034"\w* \w perpetuo|strong="H5769"\w*,   
