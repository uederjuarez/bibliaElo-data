\m
\v 1 \w La|strong="H5921"\w* \w visión|strong="H2377"\w* \w de|strong="H5921"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz, \w la|strong="H5921"\w* cual \w vio|strong="H2372"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* Jerusalén, \w en|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Uzías, Jotam, Acaz \add y\add* Ezequías, \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\m
\v 2 \w Oíd|strong="H8085"\w*, \w cielos|strong="H8064"\w*, \w y|strong="H3588"\w* \w escucha|strong="H8085"\w* tú, tierra; \w porque|strong="H3588"\w* \w habla|strong="H1696"\w* \w Jehová|strong="H3068"\w*: \w Crié|strong="H1431"\w* \w hijos|strong="H1121"\w* \w y|strong="H3588"\w* \w los|strong="H1992"\w* \w engrandecí|strong="H1431"\w*, \w y|strong="H3588"\w* \w ellos|strong="H1992"\w* \w se|strong="H1992"\w* rebelaron contra \w mí|strong="H1431"\w*.   
\m
\v 3 El \w buey|strong="H7794"\w* \w conoce|strong="H3045"\w* \w a|strong="H3068"\w* su \w dueño|strong="H1167"\w*, \w y|strong="H7794"\w* el \w asno|strong="H2543"\w* el pesebre \w de|strong="H5971"\w* su señor: \add Pero\add* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* \w conoce|strong="H3045"\w*, mi \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* \w tiene|strong="H7069"\w* entendimiento.   
\m
\v 4 ¡\w Oh|strong="H1945"\w* \w gente|strong="H1471"\w* \w pecadora|strong="H2398"\w*, \w pueblo|strong="H5971"\w* \w cargado|strong="H3515"\w* \w de|strong="H1121"\w* \w maldad|strong="H5771"\w*, \w generación|strong="H2233"\w* \w de|strong="H1121"\w* \w malignos|strong="H7489"\w*, \w hijos|strong="H1121"\w* \w depravados|strong="H7843"\w*! \w Dejaron|strong="H5800"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, provocaron \w a|strong="H3068"\w* ira al \w Santo|strong="H6918"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w se|strong="H5971"\w* volvieron atrás.   
\m
\v 5 ¿\w Para|strong="H5921"\w* \w qué|strong="H4100"\w* habéis \w de|strong="H5921"\w* ser castigados \w aún|strong="H5750"\w*? ¿\w Todavía|strong="H5750"\w* \w os|strong="H5921"\w* rebelaréis? \w Toda|strong="H3605"\w* \w cabeza|strong="H7218"\w* \w está|strong="H5921"\w* enferma, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w corazón|strong="H3824"\w* \w doliente|strong="H1742"\w*.   
\m
\v 6 \w Desde|strong="H5704"\w* la planta del \w pie|strong="H7272"\w* \w hasta|strong="H5704"\w* la \w cabeza|strong="H7218"\w* \w no|strong="H3808"\w* hay \w en|strong="H5704"\w* él cosa sana, \add sino\add* \w herida|strong="H6482"\w*, \w hinchazón|strong="H2250"\w* \w y|strong="H5704"\w* podrida \w llaga|strong="H2250"\w*; \w no|strong="H3808"\w* están curadas, \w ni|strong="H3808"\w* \w vendadas|strong="H2280"\w*, \w ni|strong="H3808"\w* \w suavizadas|strong="H7401"\w* \w con|strong="H5704"\w* \w aceite|strong="H8081"\w*.   
\m
\v 7 Vuestra tierra está destruida, vuestras \w ciudades|strong="H5892"\w* \w puestas|strong="H8313"\w* \w a|strong="H3068"\w* fuego, vuestra tierra la devoran extranjeros \w delante|strong="H5048"\w* \w de|strong="H5048"\w* vosotros, y \add es\add* \w asolada|strong="H8077"\w* como \w asolamiento|strong="H8077"\w* \w de|strong="H5048"\w* extraños.   
\m
\v 8 \w Y|strong="H3068"\w* \w queda|strong="H3498"\w* la \w hija|strong="H1323"\w* de \w Sión|strong="H6726"\w* como choza en \w viña|strong="H3754"\w*, y como cabaña en melonar, como \w ciudad|strong="H5892"\w* \w asolada|strong="H5341"\w*.   
\m
\v 9 \w Si|strong="H3884"\w* \w Jehová|strong="H3068"\w* de \w los|strong="H1961"\w* \w ejércitos|strong="H6635"\w* \w no|strong="H3884"\w* nos \w hubiese|strong="H1961"\w* dejado un pequeño remanente, seríamos \w como|strong="H1961"\w* \w Sodoma|strong="H5467"\w*, y semejantes \w a|strong="H3068"\w* \w Gomorra|strong="H6017"\w*.   
\m
\v 10 \w Príncipes|strong="H7101"\w* \w de|strong="H5971"\w* \w Sodoma|strong="H5467"\w*, \w oíd|strong="H8085"\w* la \w palabra|strong="H1697"\w* \w de|strong="H5971"\w* \w Jehová|strong="H3068"\w*; \w escuchad|strong="H8085"\w* la \w ley|strong="H8451"\w* \w de|strong="H5971"\w* nuestro \w Dios|strong="H3068"\w*, \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w Gomorra|strong="H6017"\w*.   
\m
\v 11 ¿Para \w qué|strong="H4100"\w* me sirven \w a|strong="H3068"\w* mí, dice \w Jehová|strong="H3068"\w*, \w la|strong="H7646"\w* \w multitud|strong="H7230"\w* \w de|strong="H1818"\w* vuestros \w sacrificios|strong="H2077"\w*? Harto estoy \w de|strong="H1818"\w* \w holocaustos|strong="H5930"\w* \w de|strong="H1818"\w* carneros, y \w de|strong="H1818"\w* \w sebo|strong="H2459"\w* \w de|strong="H1818"\w* animales gordos; \w no|strong="H3808"\w* \w quiero|strong="H2654"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* \w bueyes|strong="H6499"\w*, \w ni|strong="H3808"\w* \w de|strong="H1818"\w* ovejas, \w ni|strong="H3808"\w* \w de|strong="H1818"\w* machos cabríos.   
\m
\v 12 ¿\w Quién|strong="H4310"\w* demanda \w esto|strong="H2063"\w* \w de|strong="H3588"\w* vuestras \w manos|strong="H3027"\w*, \w cuando|strong="H3588"\w* venís \w a|strong="H3068"\w* presentaros \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w mí|strong="H1245"\w*, \w para|strong="H3588"\w* hollar mis \w atrios|strong="H2691"\w*?   
\m
\v 13 \w No|strong="H3808"\w* me traigáis \w más|strong="H3254"\w* \w vana|strong="H7723"\w* \w ofrenda|strong="H4503"\w*; \w el|strong="H1931"\w* incienso me \w es|strong="H1931"\w* \w abominación|strong="H8441"\w*; lunas \w nuevas|strong="H2320"\w*, \w sábados|strong="H7676"\w*, \w el|strong="H1931"\w* convocar \w asambleas|strong="H4744"\w*, \w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w puedo|strong="H3201"\w* soportar; \add son\add* iniquidad vuestras fiestas solemnes.   
\m
\v 14 Vuestras lunas \w nuevas|strong="H2320"\w* \w y|strong="H5921"\w* vuestras fiestas solemnes \w aborrece|strong="H8130"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*; \w me|strong="H5921"\w* \w son|strong="H1961"\w* \w gravosas|strong="H2960"\w*; \w cansado|strong="H3811"\w* \w estoy|strong="H1961"\w* \w de|strong="H5921"\w* soportarlas.   
\m
\v 15 \w Cuando|strong="H3588"\w* extendiereis vuestras \w manos|strong="H3027"\w*, \w yo|strong="H4480"\w* esconderé \w de|strong="H4480"\w* \w vosotros|strong="H8085"\w* mis \w ojos|strong="H5869"\w*; \w asimismo|strong="H1571"\w* \w cuando|strong="H3588"\w* multiplicareis \w la|strong="H1571"\w* \w oración|strong="H8605"\w*, \w yo|strong="H4480"\w* \w no|strong="H3588"\w* \w oiré|strong="H8085"\w*; \w llenas|strong="H4390"\w* están \w de|strong="H4480"\w* \w sangre|strong="H1818"\w* vuestras \w manos|strong="H3027"\w*.   
\m
\v 16 Lavaos, limpiaos; \w quitad|strong="H5493"\w* la iniquidad \w de|strong="H5048"\w* vuestras \w obras|strong="H4611"\w* \w de|strong="H5048"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* mis \w ojos|strong="H5869"\w*; \w dejad|strong="H5493"\w* \w de|strong="H5048"\w* hacer lo malo.   
\m
\v 17 \w Aprended|strong="H3925"\w* \w a|strong="H3068"\w* hacer el \w bien|strong="H3190"\w*; \w buscad|strong="H1875"\w* \w juicio|strong="H4941"\w*, restituid al agraviado, haced \w justicia|strong="H4941"\w* al \w huérfano|strong="H3490"\w*, abogad por la viuda.   
\m
\v 18 \w Venid|strong="H3212"\w* \w luego|strong="H4994"\w*, dice \w Jehová|strong="H3068"\w*, y estemos \w a|strong="H3068"\w* cuenta; \w si|strong="H4994"\w* vuestros \w pecados|strong="H2399"\w* \w fueren|strong="H1961"\w* \w como|strong="H1961"\w* la grana, \w como|strong="H1961"\w* la nieve \w serán|strong="H1961"\w* emblanquecidos; \w si|strong="H4994"\w* \w fueren|strong="H1961"\w* rojos \w como|strong="H1961"\w* el carmesí, vendrán \w a|strong="H3068"\w* ser \w como|strong="H1961"\w* blanca \w lana|strong="H6785"\w*.   
\m
\v 19 Si quisiereis y \w obedeciereis|strong="H8085"\w*, comeréis el \w bien|strong="H2898"\w* de la tierra:   
\m
\v 20 \w Si|strong="H3588"\w* \w no|strong="H3985"\w* quisiereis \w y|strong="H3588"\w* fuereis \w rebeldes|strong="H4784"\w*, seréis consumidos \w a|strong="H3068"\w* \w espada|strong="H2719"\w*; \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w* lo ha \w dicho|strong="H6310"\w*.   
\m
\v 21 ¡\w Cómo|strong="H1961"\w* \w se|strong="H1961"\w* ha convertido en \w ramera|strong="H2181"\w* la \w ciudad|strong="H7151"\w* fiel! Llena \w estuvo|strong="H1961"\w* de \w juicio|strong="H4941"\w*, en ella habitó \w justicia|strong="H6664"\w*, \w mas|strong="H6258"\w* \w ahora|strong="H6258"\w*, \w homicidas|strong="H7523"\w*.   
\m
\v 22 Tu \w plata|strong="H3701"\w* \w se|strong="H1961"\w* ha convertido en \w escoria|strong="H5509"\w*, tu \w vino|strong="H1961"\w* con \w agua|strong="H4325"\w* \w está|strong="H1961"\w* \w mezclado|strong="H4107"\w*.   
\m
\v 23 Tus \w príncipes|strong="H8269"\w*, \w son|strong="H3808"\w* rebeldes y compañeros \w de|strong="H8269"\w* \w ladrones|strong="H1590"\w*; \w todos|strong="H3605"\w* aman \w el|strong="H3605"\w* \w soborno|strong="H7810"\w*, y van tras las recompensas; \w no|strong="H3808"\w* oyen en \w juicio|strong="H7379"\w* al \w huérfano|strong="H3490"\w*, \w ni|strong="H3808"\w* llega \w a|strong="H3068"\w* \w ellos|strong="H3605"\w* \w la|strong="H3605"\w* \w causa|strong="H7379"\w* \w de|strong="H8269"\w* \w la|strong="H3605"\w* viuda.   
\m
\v 24 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w dice|strong="H5002"\w* el \w Señor|strong="H3068"\w*, \w Jehová|strong="H3068"\w* de los \w ejércitos|strong="H6635"\w*, el Poderoso de \w Israel|strong="H3478"\w*: Ea, \w tomaré|strong="H1945"\w* \w satisfacción|strong="H5162"\w* de mis \w enemigos|strong="H6862"\w*, me vengaré de mis \w adversarios|strong="H6862"\w*:   
\m
\v 25 \w Y|strong="H3068"\w* \w volveré|strong="H7725"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* limpiaré \w hasta|strong="H5921"\w* \w lo|strong="H5921"\w* \w más|strong="H5921"\w* puro tus \w escorias|strong="H5509"\w*, \w y|strong="H5921"\w* \w quitaré|strong="H5493"\w* \w todo|strong="H3605"\w* tu estaño:   
\m
\v 26 \w Y|strong="H3068"\w* restituiré tus \w jueces|strong="H8199"\w* \w como|strong="H3651"\w* al principio, y tus \w consejeros|strong="H3289"\w* \w como|strong="H3651"\w* de \w primero|strong="H7223"\w*: \w entonces|strong="H3651"\w* te \w llamarán|strong="H7121"\w* \w Ciudad|strong="H5892"\w* de \w Justicia|strong="H6664"\w*, \w Ciudad|strong="H5892"\w* Fiel.   
\m
\v 27 \w Sión|strong="H6726"\w* con \w juicio|strong="H4941"\w* será rescatada, y los convertidos de ella con \w justicia|strong="H6666"\w*.   
\m
\v 28 Mas los rebeldes y \w pecadores|strong="H2400"\w* \w a|strong="H3068"\w* una serán quebrantados, y los que dejan \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* serán consumidos.   
\m
\v 29 \w Entonces|strong="H3588"\w* os avergonzarán las encinas \w que|strong="H3588"\w* \w amasteis|strong="H2530"\w*, \w y|strong="H3588"\w* seréis confundidos \w por|strong="H3588"\w* \w los|strong="H3588"\w* bosques \w que|strong="H3588"\w* habéis escogido.   
\m
\v 30 \w Porque|strong="H3588"\w* \w seréis|strong="H1961"\w* \w como|strong="H3588"\w* \w la|strong="H3588"\w* encina \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* le \w cae|strong="H5034"\w* \w la|strong="H3588"\w* hoja, \w y|strong="H3588"\w* \w como|strong="H3588"\w* huerto al \w que|strong="H3588"\w* le falta \w el|strong="H3588"\w* \w agua|strong="H4325"\w*.   
\m
\v 31 \w Y|strong="H3068"\w* el fuerte \w será|strong="H1961"\w* \w como|strong="H1961"\w* estopa, \w y|strong="H1197"\w* lo \w que|strong="H1961"\w* hizo \w como|strong="H1961"\w* centella; \w y|strong="H1197"\w* \w ambos|strong="H8147"\w* \w serán|strong="H1961"\w* \w encendidos|strong="H1197"\w* \w juntamente|strong="H3162"\w*, \w y|strong="H1197"\w* \w no|strong="H1961"\w* \w habrá|strong="H1961"\w* quien apague.   
\c 2
\m
\v 1 \w La|strong="H5921"\w* \w palabra|strong="H1697"\w* \w que|strong="H5921"\w* \w vio|strong="H2372"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz, tocante \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Jerusalén.   
\m
\v 2 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* en \w los|strong="H3605"\w* postreros \w días|strong="H3117"\w*, \w que|strong="H3117"\w* \w será|strong="H1961"\w* \w establecido|strong="H3559"\w* \w el|strong="H3605"\w* \w monte|strong="H2022"\w* de \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de \w Jehová|strong="H3068"\w* en \w la|strong="H3605"\w* \w cumbre|strong="H7218"\w* de las montañas, y \w será|strong="H1961"\w* exaltado \w sobre|strong="H1961"\w* \w los|strong="H3605"\w* \w collados|strong="H1389"\w*; y \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* correrán \w a|strong="H3068"\w* \w él|strong="H3605"\w*.   
\m
\v 3 \w Y|strong="H3068"\w* vendrán \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*, \w y|strong="H3588"\w* dirán: \w Venid|strong="H3212"\w*, \w y|strong="H3588"\w* \w subamos|strong="H5927"\w* al \w monte|strong="H2022"\w* \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w*, \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* del \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*; \w y|strong="H3588"\w* \w Él|strong="H3588"\w* nos \w enseñará|strong="H3384"\w* \w en|strong="H3588"\w* sus \w caminos|strong="H1870"\w*, \w y|strong="H3588"\w* caminaremos \w por|strong="H3588"\w* sus sendas. \w Porque|strong="H3588"\w* \w de|strong="H3588"\w* \w Sión|strong="H6726"\w* \w saldrá|strong="H3318"\w* \w la|strong="H3588"\w* \w ley|strong="H8451"\w*, \w y|strong="H3588"\w* \w de|strong="H3588"\w* Jerusalén \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w*.   
\m
\v 4 \w Y|strong="H3068"\w* \w juzgará|strong="H8199"\w* \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w*, y \w reprenderá|strong="H3198"\w* \w a|strong="H3068"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*; y volverán sus \w espadas|strong="H2719"\w* \w en|strong="H5750"\w* rejas \w de|strong="H5750"\w* arado, y sus lanzas \w en|strong="H5750"\w* hoces; \w no|strong="H3808"\w* \w alzará|strong="H5375"\w* \w espada|strong="H2719"\w* \w nación|strong="H1471"\w* contra \w nación|strong="H1471"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* adiestrarán \w más|strong="H5750"\w* \w para|strong="H5971"\w* la \w guerra|strong="H4421"\w*.   
\m
\v 5 \w Venid|strong="H3212"\w*, oh \w casa|strong="H1004"\w* de \w Jacob|strong="H3290"\w*, y caminemos \w a|strong="H3068"\w* la luz de \w Jehová|strong="H3068"\w*.   
\m
\v 6 \w Ciertamente|strong="H3588"\w* tú has dejado \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*, \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*, \w porque|strong="H3588"\w* están \w llenos|strong="H4390"\w* \w de|strong="H3588"\w* \add maldades\add* del \w oriente|strong="H6924"\w*, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w agoreros|strong="H6049"\w*, \w como|strong="H3588"\w* \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w*; \w y|strong="H3588"\w* hacen pacto \w con|strong="H3588"\w* \w hijos|strong="H3206"\w* \w de|strong="H3588"\w* extranjeros.   
\m
\v 7 Su tierra está \w llena|strong="H4390"\w* de \w plata|strong="H3701"\w* y de \w oro|strong="H2091"\w* y sus tesoros no tienen fin. También su tierra está \w llena|strong="H4390"\w* de \w caballos|strong="H5483"\w*, y sus \w carros|strong="H4818"\w* son innumerables.   
\m
\v 8 Además su tierra está \w llena|strong="H4390"\w* de ídolos y \w adoran|strong="H7812"\w* la \w obra|strong="H4639"\w* de sus \w manos|strong="H3027"\w*, aquello \w que|strong="H3027"\w* sus propios dedos \w fabricaron|strong="H6213"\w*.   
\m
\v 9 \w Y|strong="H3068"\w* el hombre vil se ha inclinado, y el hombre altivo se ha humillado; por tanto, no los \w perdones|strong="H5375"\w*.   
\m
\v 10 Métete en la \w roca|strong="H6697"\w*, \w escóndete|strong="H2934"\w* en el \w polvo|strong="H6083"\w*, \w por|strong="H6440"\w* el \w temor|strong="H6343"\w* \w de|strong="H6440"\w* \w Jehová|strong="H3068"\w*, y \w por|strong="H6440"\w* la \w gloria|strong="H1926"\w* \w de|strong="H6440"\w* su majestad.   
\m
