\v 19 \w Nosotros|strong="H5921"\w* \w somos|strong="H1961"\w* tuyos. Tú \w nunca|strong="H3808"\w* señoreaste \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w ellos|strong="H5921"\w* \w nunca|strong="H3808"\w* \w fueron|strong="H1961"\w* \w llamados|strong="H7121"\w* \w por|strong="H5921"\w* tu \w nombre|strong="H8034"\w*.   
\c 64
\m
\v 1 ¡Oh \w que|strong="H3045"\w* rompieras los cielos, y descendieras, y \w ante|strong="H6440"\w* tu \w presencia|strong="H6440"\w* \w se|strong="H3045"\w* deslizaran las montañas,   
\m
\v 2 como fuego abrasador \w de|strong="H6440"\w* fundiciones, fuego \w que|strong="H3808"\w* \w hace|strong="H6213"\w* hervir las aguas, para \w que|strong="H3808"\w* dieras \w a|strong="H3068"\w* conocer \w tu|strong="H6213"\w* nombre \w a|strong="H3068"\w* tus adversarios, \add y\add* las naciones temblaran \w ante|strong="H6440"\w* \w tu|strong="H6213"\w* \w presencia|strong="H6440"\w*!   
\m
\v 3 Cuando \w hiciste|strong="H6213"\w* cosas terribles, \add que\add* \w no|strong="H3808"\w* esperábamos, descendiste \add y\add* \w se|strong="H3808"\w* deslizaron las montañas ante \w tu|strong="H6213"\w* presencia.   
\m
\v 4 Porque desde \w el|strong="H6213"\w* principio del mundo \w el|strong="H6213"\w* hombre \w no|strong="H6213"\w* ha escuchado, ni \w el|strong="H6213"\w* oído ha percibido, ni \w el|strong="H6213"\w* ojo ha visto, \w a|strong="H3068"\w* un Dios, fuera de ti, que \w hiciese|strong="H6213"\w* \add tanto\add* \w por|strong="H1870"\w* \w el|strong="H6213"\w* que en \w Él|strong="H6213"\w* espera.   
\m
\v 5 Saliste al encuentro del \w que|strong="H1961"\w* con alegría hacía \w justicia|strong="H6666"\w*, de \add los que\add* \w se|strong="H1961"\w* acordaban de ti en tus caminos: (he aquí, tú te enojaste porque pecamos:) en \w ellos|strong="H3605"\w* \w hay|strong="H1961"\w* perpetuidad, y \w nosotros|strong="H3605"\w* \w seremos|strong="H1961"\w* salvos.   
\m
\v 6 \w Si|strong="H3588"\w* \w bien|strong="H3588"\w* todos nosotros somos \w como|strong="H3588"\w* suciedad, \w y|strong="H3588"\w* todas nuestras justicias \w como|strong="H3588"\w* trapo \w de|strong="H4480"\w* inmundicia; \w y|strong="H3588"\w* caímos todos nosotros \w como|strong="H3588"\w* \w la|strong="H3588"\w* hoja, \w y|strong="H3588"\w* nuestras \w maldades|strong="H5771"\w* \w nos|strong="H4480"\w* llevaron \w como|strong="H3588"\w* viento.   
\m
\v 7 \w Y|strong="H3068"\w* \w nadie|strong="H3605"\w* hay \w que|strong="H6258"\w* invoque tu nombre, \w que|strong="H6258"\w* se despierte \w para|strong="H6258"\w* asirse de ti; porque escondiste de \w nosotros|strong="H3605"\w* tu rostro, y nos has consumido \w a|strong="H3068"\w* causa de nuestras iniquidades.   
\m
\v 8 Pero \w ahora|strong="H4994"\w*, oh \w Jehová|strong="H3068"\w*, tú eres nuestro Padre; \w nosotros|strong="H3605"\w* \add somos\add* \w el|strong="H3605"\w* barro, \w y|strong="H5704"\w* tú nuestro alfarero; obra \w de|strong="H5704"\w* tus manos somos \w todos|strong="H3605"\w* \w nosotros|strong="H3605"\w*.   
\m
\v 9 \w No|strong="H1961"\w* te enojes sobremanera, oh Jehová, ni tengas perpetua memoria de la iniquidad; he aquí mira ahora, pueblo tuyo \w somos|strong="H1961"\w* todos nosotros.   
\m
\v 10 Tus \w santas|strong="H6944"\w* ciudades \w están|strong="H1961"\w* \w desiertas|strong="H2723"\w*, Sión \w es|strong="H1961"\w* un desierto, Jerusalén una soledad.   
\m
\v 11 \w La|strong="H5921"\w* casa \w de|strong="H5921"\w* nuestro santuario \w y|strong="H5921"\w* \w de|strong="H5921"\w* nuestra gloria, \w en|strong="H5921"\w* \w la|strong="H5921"\w* cual \w te|strong="H5921"\w* alabaron nuestros padres, fue consumida \w al|strong="H5921"\w* fuego; \w y|strong="H5921"\w* todas nuestras cosas preciosas han sido destruidas.   
\m
\v 12 ¿Te quedarás quieto, oh Jehová, sobre estas cosas? ¿Callarás, y nos afligirás sobremanera?   
\c 65
\m
\v 1 \w Fui|strong="H3808"\w* buscado de los \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w preguntaban|strong="H7592"\w* por \w mí|strong="H1245"\w*; \w fui|strong="H3808"\w* \w hallado|strong="H4672"\w* de los \w que|strong="H3808"\w* \w no|strong="H3808"\w* me buscaban. Dije \w a|strong="H3068"\w* \w una|strong="H4672"\w* \w nación|strong="H1471"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w invocaba|strong="H7121"\w* \w mi|strong="H1245"\w* \w nombre|strong="H8034"\w*: Heme \w aquí|strong="H2005"\w*, heme \w aquí|strong="H2005"\w*.   
\m
\v 2 \w Extendí|strong="H6566"\w* mis \w manos|strong="H3027"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w a|strong="H3068"\w* un \w pueblo|strong="H5971"\w* \w rebelde|strong="H5637"\w*, \w que|strong="H3808"\w* \w anda|strong="H1980"\w* \w por|strong="H1870"\w* \w camino|strong="H1870"\w* \w no|strong="H3808"\w* \w bueno|strong="H2896"\w*, en pos \w de|strong="H5971"\w* sus \w pensamientos|strong="H4284"\w*;   
\m
\v 3 \w Pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w cara|strong="H6440"\w* \w me|strong="H5921"\w* provoca \w de|strong="H5921"\w* \w continuo|strong="H8548"\w* \w a|strong="H3068"\w* ira, \w que|strong="H5921"\w* \w sacrifica|strong="H2076"\w* \w en|strong="H5921"\w* \w huertos|strong="H1593"\w*, \w y|strong="H5921"\w* quema incienso \w sobre|strong="H5921"\w* altares \w de|strong="H5921"\w* \w ladrillo|strong="H3843"\w*;   
\m
\v 4 que se quedan en \w los|strong="H3427"\w* \w sepulcros|strong="H6913"\w*, y en lugares escondidos pasan la noche; que comen \w carne|strong="H1320"\w* de puerco, y en sus ollas hay caldo de cosas inmundas;   
\m
\v 5 \w que|strong="H3588"\w* dicen: Estate \w en|strong="H3588"\w* tu lugar, \w no|strong="H3588"\w* \w te|strong="H3588"\w* acerques \w a|strong="H3068"\w* mí, \w porque|strong="H3588"\w* soy \w más|strong="H3588"\w* \w santo|strong="H6942"\w* \w que|strong="H3588"\w* tú. \w Estos|strong="H3605"\w* \w son|strong="H3588"\w* \w humo|strong="H6227"\w* \w en|strong="H3588"\w* mi furor, fuego \w que|strong="H3588"\w* arde \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w*.   
\m
\v 6 He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w está|strong="H5921"\w* \w escrito|strong="H3789"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*; \w no|strong="H3808"\w* \w callaré|strong="H2814"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* recompensaré, \w y|strong="H3588"\w* daré \w el|strong="H5921"\w* pago \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w seno|strong="H2436"\w*,   
\m
\v 7 \w por|strong="H5921"\w* vuestras \w iniquidades|strong="H5771"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w iniquidades|strong="H5771"\w* \w de|strong="H5921"\w* vuestros padres \w juntamente|strong="H3162"\w*, dice \w Jehová|strong="H3068"\w*, \w los|strong="H5921"\w* cuales quemaron incienso \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* montañas, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w collados|strong="H1389"\w* \w me|strong="H5921"\w* \w afrentaron|strong="H2778"\w*; \w por|strong="H5921"\w* \w tanto|strong="H5921"\w*, yo \w les|strong="H5921"\w* mediré su \w obra|strong="H6468"\w* \w antigua|strong="H7223"\w* \w en|strong="H5921"\w* su \w seno|strong="H2436"\w*.   
\m
\v 8 \w Así|strong="H3541"\w* dice \w Jehová|strong="H3068"\w*: \w Como|strong="H3588"\w* \w si|strong="H3588"\w* \w alguno|strong="H3605"\w* \w hallase|strong="H4672"\w* \w mosto|strong="H8492"\w* \w en|strong="H3588"\w* un racimo, \w y|strong="H3588"\w* dijese: \w No|strong="H6213"\w* \w lo|strong="H6213"\w* desperdicies, \w porque|strong="H3588"\w* \w bendición|strong="H1293"\w* hay \w en|strong="H3588"\w* \w él|strong="H3588"\w*; \w así|strong="H3541"\w* \w haré|strong="H6213"\w* \w yo|strong="H3588"\w* \w por|strong="H3588"\w* mis \w siervos|strong="H5650"\w*, \w que|strong="H3588"\w* \w no|strong="H6213"\w* \w lo|strong="H6213"\w* \w destruiré|strong="H7843"\w* \w todo|strong="H3605"\w*.   
\m
\v 9 Mas sacaré \w simiente|strong="H2233"\w* de \w Jacob|strong="H3290"\w*, y de \w Judá|strong="H3063"\w* \w heredero|strong="H3423"\w* de mis montañas; y mis escogidos \w poseerán|strong="H3423"\w* por \w heredad|strong="H3423"\w* la tierra, y mis \w siervos|strong="H5650"\w* \w habitarán|strong="H7931"\w* \w allí|strong="H8033"\w*.   
\m
\v 10 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w Sarón|strong="H8289"\w* \w para|strong="H1961"\w* habitación \w de|strong="H5971"\w* \w ovejas|strong="H6629"\w*, \w y|strong="H1241"\w* el \w valle|strong="H6010"\w* \w de|strong="H5971"\w* Acor \w para|strong="H1961"\w* majada \w de|strong="H5971"\w* \w vacas|strong="H1241"\w*, \w para|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* me \w buscó|strong="H1875"\w*.   
\m
\v 11 Pero vosotros \add sois\add* los que dejáis \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, que olvidáis mi \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*, que ponéis \w mesa|strong="H7979"\w* para esa tropa, y suministráis \w libaciones|strong="H4469"\w* para ese número.   
\m
\v 12 \w Por|strong="H3282"\w* tanto, \w yo|strong="H6213"\w* \w os|strong="H5869"\w* designaré \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w espada|strong="H2719"\w*, y \w todos|strong="H3605"\w* \w vosotros|strong="H8085"\w* \w os|strong="H5869"\w* inclinaréis al matadero; \w por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w llamé|strong="H7121"\w*, y \w no|strong="H3808"\w* \w respondisteis|strong="H6030"\w*; \w hablé|strong="H1696"\w*, y \w no|strong="H3808"\w* \w oísteis|strong="H8085"\w*; \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w hicisteis|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* \w delante|strong="H5869"\w* \w de|strong="H5869"\w* mis \w ojos|strong="H5869"\w*, y escogisteis \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* me agrada.   
\m
\v 13 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice el Señor \w Jehová|strong="H3069"\w*: He \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* mis \w siervos|strong="H5650"\w* comerán, \w y|strong="H3541"\w* vosotros tendréis \w hambre|strong="H7456"\w*; he \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* mis \w siervos|strong="H5650"\w* \w beberán|strong="H8354"\w*, \w y|strong="H3541"\w* vosotros tendréis \w sed|strong="H6770"\w*; he \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* mis \w siervos|strong="H5650"\w* \w se|strong="H3651"\w* alegrarán, \w y|strong="H3541"\w* vosotros seréis avergonzados;   
\m
\v 14 he \w aquí|strong="H2009"\w* que mis \w siervos|strong="H5650"\w* \w cantarán|strong="H7442"\w* por el júbilo del \w corazón|strong="H3820"\w*, y vosotros \w clamaréis|strong="H6817"\w* por el dolor del \w corazón|strong="H3820"\w*, y por el \w quebrantamiento|strong="H7667"\w* de \w espíritu|strong="H7307"\w* \w aullaréis|strong="H3213"\w*.   
\m
