\v 16 \w Pero|strong="H3588"\w* tú eres nuestro Padre, \w si|strong="H3588"\w* \w bien|strong="H3588"\w* Abraham nos ignora, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* nos \w conoce|strong="H3045"\w*; tú, oh \w Jehová|strong="H3068"\w*, eres nuestro Padre; nuestro \w Redentor|strong="H1350"\w*, tu \w nombre|strong="H8034"\w* \w es|strong="H3588"\w* desde \w la|strong="H3588"\w* \w eternidad|strong="H5769"\w*.   
\m
\v 17 ¿\w Por|strong="H1870"\w* \w qué|strong="H4100"\w*, \w oh|strong="H4100"\w* \w Jehová|strong="H3068"\w*, \w nos|strong="H4100"\w* has hecho \w errar|strong="H8582"\w* de tus \w caminos|strong="H1870"\w*, y endureciste nuestro \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* tu \w temor|strong="H3374"\w*? \w Vuélvete|strong="H7725"\w* \w por|strong="H1870"\w* amor \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w*, las \w tribus|strong="H7626"\w* de tu \w heredad|strong="H5159"\w*.   
