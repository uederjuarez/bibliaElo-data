\m
\v 3 \w Y|strong="H3068"\w* \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* \w Jonás|strong="H3124"\w*, y \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, conforme \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* \w Jehová|strong="H3068"\w*. \w Y|strong="H3068"\w* \w Nínive|strong="H5210"\w* \w era|strong="H1961"\w* una \w ciudad|strong="H5892"\w* \w grande|strong="H1419"\w* \w en|strong="H3212"\w* extremo, \w de|strong="H1697"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w de|strong="H1697"\w* \w camino|strong="H4109"\w*.   
\m
\v 4 \w Y|strong="H3068"\w* \w comenzó|strong="H2490"\w* \w Jonás|strong="H3124"\w* \w a|strong="H3068"\w* entrar \w por|strong="H5750"\w* la \w ciudad|strong="H5892"\w*, \w camino|strong="H4109"\w* \w de|strong="H5750"\w* un \w día|strong="H3117"\w*, y pregonaba diciendo: \w De|strong="H5750"\w* aquí \w a|strong="H3068"\w* cuarenta \w días|strong="H3117"\w* \w Nínive|strong="H5210"\w* será destruida.   
\m
\v 5 \w Y|strong="H3068"\w* los hombres \w de|strong="H5704"\w* \w Nínive|strong="H5210"\w* creyeron \w a|strong="H3068"\w* Dios, \w y|strong="H5704"\w* pregonaron \w ayuno|strong="H6685"\w*, \w y|strong="H5704"\w* se vistieron \w de|strong="H5704"\w* cilicio \w desde|strong="H5704"\w* el \w mayor|strong="H1419"\w* \w de|strong="H5704"\w* ellos \w hasta|strong="H5704"\w* el \w menor|strong="H6996"\w* \w de|strong="H5704"\w* ellos.   
\m
\v 6 \w Y|strong="H3068"\w* \w llegó|strong="H5060"\w* \w la|strong="H5921"\w* noticia \w hasta|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Nínive|strong="H5210"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w de|strong="H5921"\w* su silla, \w y|strong="H5921"\w* \w echó|strong="H5060"\w* \w de|strong="H5921"\w* \w sí|strong="H5921"\w* su vestidura, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w cubrió|strong="H3680"\w* \w de|strong="H5921"\w* cilicio, \w y|strong="H5921"\w* \w se|strong="H5921"\w* sentó \w sobre|strong="H5921"\w* ceniza.   
