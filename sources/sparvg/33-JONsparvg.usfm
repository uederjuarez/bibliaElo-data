\v 1 \w Y|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* \w Jehová|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amitai, diciendo:   
\m
\v 2 \w Levántate|strong="H6965"\w*, \w y|strong="H3588"\w* \w ve|strong="H3212"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, \w la|strong="H5921"\w* \w gran|strong="H1419"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H3588"\w* \w pregona|strong="H7121"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*; \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w maldad|strong="H7451"\w* ha \w subido|strong="H5927"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\m
\v 3 \w Y|strong="H3068"\w* \w Jonás|strong="H3124"\w* se \w levantó|strong="H6965"\w* \w para|strong="H5414"\w* huir \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \w Jehová|strong="H3068"\w* \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*, y \w descendió|strong="H3381"\w* \w a|strong="H3068"\w* Jope; y \w halló|strong="H4672"\w* un navío que partía \w para|strong="H5414"\w* \w Tarsis|strong="H8659"\w*; y pagando su pasaje, \w entró|strong="H3381"\w* \w en|strong="H5973"\w* \w él|strong="H5973"\w*, \w para|strong="H5414"\w* irse \w con|strong="H5973"\w* ellos \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Jehová|strong="H3068"\w*.   
\m
\v 4 Pero \w Jehová|strong="H3068"\w* hizo levantar un \w gran|strong="H1419"\w* \w viento|strong="H7307"\w* en el \w mar|strong="H3220"\w*, y \w se|strong="H1961"\w* hizo una tan \w gran|strong="H1419"\w* \w tempestad|strong="H5591"\w* en el \w mar|strong="H3220"\w*, \w que|strong="H1961"\w* \w se|strong="H1961"\w* pensó \w se|strong="H1961"\w* rompería la nave.   
\m
\v 5 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* marineros tuvieron \w miedo|strong="H3372"\w*, \w y|strong="H5921"\w* cada uno \w clamaba|strong="H2199"\w* \w a|strong="H3068"\w* su dios; \w y|strong="H5921"\w* echaron \w al|strong="H5921"\w* \w mar|strong="H3220"\w* \w los|strong="H5921"\w* \w enseres|strong="H3627"\w* \w que|strong="H5921"\w* \add había\add* \w en|strong="H5921"\w* \w la|strong="H5921"\w* nave, \w para|strong="H5921"\w* descargarla \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*. Pero \w Jonás|strong="H3124"\w* \w se|strong="H5921"\w* había bajado \w a|strong="H3068"\w* \w los|strong="H5921"\w* lados \w del|strong="H5921"\w* buque, \w y|strong="H5921"\w* \w se|strong="H5921"\w* había \w echado|strong="H7901"\w* \w a|strong="H3068"\w* dormir.   
\m
\v 6 \w Y|strong="H3068"\w* el maestre de la nave \w vino|strong="H4100"\w* \w a|strong="H3068"\w* él y le dijo: ¿\w Qué|strong="H4100"\w* tienes, \w dormilón|strong="H7290"\w*? \w Levántate|strong="H6965"\w*, y \w clama|strong="H7121"\w* \w a|strong="H3068"\w* tu Dios; quizá Dios tendrá compasión de nosotros, y \w no|strong="H3808"\w* pereceremos.   
\m
\v 7 \w Y|strong="H3068"\w* dijeron cada uno \w a|strong="H3068"\w* su \w compañero|strong="H7453"\w*: \w Venid|strong="H3212"\w*, \w y|strong="H5921"\w* echemos \w suertes|strong="H1486"\w*, \w para|strong="H5921"\w* \w saber|strong="H3045"\w* \w por|strong="H5921"\w* \w quién|strong="H4310"\w* \w nos|strong="H5921"\w* ha venido \w este|strong="H2063"\w* \w mal|strong="H7451"\w*. \w Y|strong="H3068"\w* \w echaron|strong="H5307"\w* \w suertes|strong="H1486"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w suerte|strong="H1486"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w Jonás|strong="H3124"\w*.   
\m
\v 8 Entonces \w le|strong="H4310"\w* dijeron ellos: \w Decláranos|strong="H5046"\w* \w ahora|strong="H4994"\w* \w por|strong="H2088"\w* \w qué|strong="H4100"\w* \w nos|strong="H4100"\w* ha venido \w este|strong="H2088"\w* \w mal|strong="H7451"\w*. ¿\w Qué|strong="H4100"\w* \w oficio|strong="H4399"\w* tienes, y \w de|strong="H5971"\w* dónde vienes? ¿\w Cuál|strong="H4100"\w* \add es\add* tu tierra, y \w de|strong="H5971"\w* \w qué|strong="H4100"\w* \w pueblo|strong="H5971"\w* \add eres\add*?   
\m
\v 9 \w Y|strong="H3068"\w* \w él|strong="H6213"\w* les respondió: Soy \w hebreo|strong="H5680"\w*, y temo \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \w el|strong="H6213"\w* \w Dios|strong="H3068"\w* del \w cielo|strong="H8064"\w*, que \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w mar|strong="H3220"\w* y la \w tierra|strong="H3004"\w* \add seca\add*.   
\m
\v 10 \w Y|strong="H3068"\w* \w aquellos|strong="H1992"\w* hombres \w temieron|strong="H3372"\w* \w sobremanera|strong="H1419"\w*, \w y|strong="H3588"\w* \w le|strong="H1931"\w* dijeron: ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* has \w hecho|strong="H6213"\w* \w esto|strong="H2063"\w*? \w Porque|strong="H3588"\w* \w ellos|strong="H1992"\w* \w entendieron|strong="H3045"\w* \w que|strong="H3588"\w* \w huía|strong="H1272"\w* \w de|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w*, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w se|strong="H3045"\w* \w los|strong="H1992"\w* \w había|strong="H3588"\w* \w declarado|strong="H5046"\w*.   
\m
\v 11 \w Y|strong="H3068"\w* \w le|strong="H5921"\w* dijeron: ¿\w Qué|strong="H3588"\w* \w te|strong="H5921"\w* \w haremos|strong="H6213"\w*, \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H5921"\w* \w nos|strong="H5921"\w* aquiete? \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H5921"\w* embravecía \w más|strong="H3588"\w* \w y|strong="H3588"\w* \w más|strong="H3588"\w*.   
\m
\v 12 \w Él|strong="H5921"\w* \w les|strong="H5921"\w* respondió: \w Tomadme|strong="H5375"\w*, \w y|strong="H3588"\w* echadme \w al|strong="H5921"\w* \w mar|strong="H3220"\w*, \w y|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H3045"\w* \w os|strong="H5921"\w* aquietará; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w por|strong="H5921"\w* \w mi|strong="H5921"\w* causa \add ha venido\add* \w esta|strong="H2088"\w* \w gran|strong="H1419"\w* \w tempestad|strong="H5591"\w* \w sobre|strong="H5921"\w* vosotros.   
\m
\v 13 \w Y|strong="H3068"\w* aquellos hombres \w trabajaron|strong="H2864"\w* \w por|strong="H5921"\w* \w tornar|strong="H7725"\w* \w la|strong="H5921"\w* nave \w a|strong="H3068"\w* \w tierra|strong="H3004"\w*; \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w*, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w iba|strong="H1980"\w* \w a|strong="H3068"\w* \w más|strong="H3588"\w*, \w y|strong="H3588"\w* \w se|strong="H5921"\w* embravecía \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
