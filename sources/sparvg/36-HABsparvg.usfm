\v 1 \w Oración|strong="H8605"\w* \w del|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Habacuc|strong="H2265"\w*, \w sobre|strong="H5921"\w* Sigionot.   
\m
\v 2 Oh \w Jehová|strong="H3068"\w*, he \w oído|strong="H8085"\w* tu palabra, y \w temí|strong="H3372"\w*: Oh \w Jehová|strong="H3068"\w*, \w aviva|strong="H2421"\w* tu \w obra|strong="H6467"\w* en \w medio|strong="H7130"\w* \w de|strong="H3372"\w* los \w tiempos|strong="H8141"\w*, en \w medio|strong="H7130"\w* \w de|strong="H3372"\w* los \w tiempos|strong="H8141"\w* hazla conocer; En la ira \w acuérdate|strong="H2142"\w* \w de|strong="H3372"\w* la \w misericordia|strong="H7355"\w*.   
\m
\v 3 Dios viene de \w Temán|strong="H8487"\w*, y el \w Santo|strong="H6918"\w* del \w monte|strong="H2022"\w* de \w Parán|strong="H6290"\w* (\w Selah|strong="H5542"\w*). Su \w gloria|strong="H1935"\w* \w cubrió|strong="H3680"\w* los \w cielos|strong="H8064"\w*, y la tierra se \w llenó|strong="H4390"\w* de su \w alabanza|strong="H8416"\w*.   
\m
\v 4 Su \w resplandor|strong="H5051"\w* \w era|strong="H1961"\w* \w como|strong="H1961"\w* la luz, \w y|strong="H5797"\w* \w cuernos|strong="H7161"\w* salían de su \w mano|strong="H3027"\w*; \w allí|strong="H8033"\w* \w estaba|strong="H1961"\w* escondido su \w poder|strong="H3027"\w*.   
\m
\v 5 \w Delante|strong="H6440"\w* \w de|strong="H6440"\w* su \w rostro|strong="H6440"\w* \w iba|strong="H3212"\w* \w mortandad|strong="H1698"\w*, y \w a|strong="H3068"\w* sus \w pies|strong="H7272"\w* \w salían|strong="H3318"\w* carbones encendidos.   
\m
\v 6 Se paró, y midió la tierra; \w miró|strong="H7200"\w*, \w e|strong="H3068"\w* hizo temblar \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*; las montañas \w eternas|strong="H5769"\w* fueron desmenuzadas, y los \w collados|strong="H1389"\w* \w perpetuos|strong="H5769"\w* se humillaron. Sus caminos \add son\add* \w eternos|strong="H5769"\w*.   
\m
\v 7 He \w visto|strong="H7200"\w* las tiendas \w de|strong="H8478"\w* Cusán \w en|strong="H8478"\w* aflicción; las tiendas \w de|strong="H8478"\w* la tierra \w de|strong="H8478"\w* \w Madián|strong="H4080"\w* \w temblaron|strong="H7264"\w*.   
\m
\v 8 ¿\w Se|strong="H5921"\w* airó \w Jehová|strong="H3068"\w* \w contra|strong="H5921"\w* \w los|strong="H5921"\w* ríos? ¿\w Contra|strong="H5921"\w* \w los|strong="H5921"\w* ríos \add fue\add* tu enojo? ¿Tu ira \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w cuando|strong="H3588"\w* \w subiste|strong="H7392"\w* \w sobre|strong="H5921"\w* tus \w caballos|strong="H5483"\w*, \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* tus \w carros|strong="H4818"\w* \w de|strong="H5921"\w* salvación?   
\m
\v 9 Se descubrió \w enteramente|strong="H6181"\w* tu \w arco|strong="H7198"\w*, los juramentos \w a|strong="H3068"\w* las \w tribus|strong="H4294"\w*, palabra segura (\w Selah|strong="H5542"\w*). \w Hendiste|strong="H1234"\w* la tierra con ríos.   
\m
\v 10 Te \w vieron|strong="H7200"\w* las montañas \add y\add* temblaron; \w pasó|strong="H5674"\w* \w el|strong="H5674"\w* desbordamiento \w de|strong="H5414"\w* las \w aguas|strong="H4325"\w*; \w el|strong="H5674"\w* \w abismo|strong="H8415"\w* \w dio|strong="H5414"\w* su \w voz|strong="H6963"\w*, \add y\add* \w levantó|strong="H5375"\w* en alto sus \w manos|strong="H3027"\w*.   
\m
\v 11 El \w sol|strong="H8121"\w* \add y\add* la \w luna|strong="H3394"\w* se pararon \w en|strong="H5975"\w* su estancia; \w a|strong="H3068"\w* la luz de tus \w saetas|strong="H2671"\w* \w anduvieron|strong="H1980"\w*, y al \w resplandor|strong="H5051"\w* de tu fulgente \w lanza|strong="H2595"\w*.   
\m
\v 12 Con ira \w hollaste|strong="H6805"\w* la tierra, con \w furor|strong="H2195"\w* trillaste las \w naciones|strong="H1471"\w*.   
\m
\v 13 \w Saliste|strong="H3318"\w* \w para|strong="H5704"\w* salvar \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*, \w para|strong="H5704"\w* salvar \w con|strong="H5704"\w* tu \w ungido|strong="H4899"\w*. \w Traspasaste|strong="H4272"\w* la \w cabeza|strong="H7218"\w* \w de|strong="H5704"\w* la \w casa|strong="H1004"\w* del \w impío|strong="H7563"\w*, \w desnudando|strong="H6168"\w* el cimiento \w hasta|strong="H5704"\w* el \w cuello|strong="H6677"\w* (\w Selah|strong="H5542"\w*).   
\m
\v 14 \w Horadaste|strong="H5344"\w* con sus propias \w varas|strong="H4294"\w* las \w cabezas|strong="H7218"\w* de sus villas, que \w como|strong="H3644"\w* tempestad acometieron para dispersarme; su regocijo \add era\add* \w como|strong="H3644"\w* para devorar al \w pobre|strong="H6041"\w* \w encubiertamente|strong="H4565"\w*.   
\m
\v 15 Hiciste camino en el \w mar|strong="H3220"\w* \w a|strong="H3068"\w* tus \w caballos|strong="H5483"\w*, \add por\add* montón \w de|strong="H4325"\w* \w grandes|strong="H7227"\w* \w aguas|strong="H4325"\w*.   
\m
\v 16 \w Oí|strong="H8085"\w*, y \w se|strong="H5971"\w* conmovieron mis entrañas; \w a|strong="H3068"\w* la \w voz|strong="H6963"\w* \w temblaron|strong="H7264"\w* mis \w labios|strong="H8193"\w*; \w pudrición|strong="H7538"\w* entró \w en|strong="H8478"\w* mis \w huesos|strong="H6106"\w*, y dentro \w de|strong="H8478"\w* mí me estremecí; si bien estaré quieto \w en|strong="H8478"\w* el \w día|strong="H3117"\w* \w de|strong="H8478"\w* la \w angustia|strong="H6869"\w*, \w cuando|strong="H3117"\w* \w suba|strong="H5927"\w* \w al|strong="H8478"\w* \w pueblo|strong="H5971"\w* el \w que|strong="H5971"\w* lo invadirá con sus tropas.   
\m
\v 17 \w Aunque|strong="H3588"\w* \w la|strong="H3588"\w* higuera \w no|strong="H3808"\w* florezca, \w ni|strong="H3808"\w* \add haya\add* fruto \w en|strong="H3588"\w* las \w viñas|strong="H1612"\w*; \w aunque|strong="H3588"\w* falte \w el|strong="H3588"\w* fruto del olivo, \w y|strong="H3588"\w* \w los|strong="H3588"\w* labrados \w no|strong="H3808"\w* den mantenimiento; \w y|strong="H3588"\w* las \w ovejas|strong="H6629"\w* sean quitadas del redil, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \add haya\add* \w vacas|strong="H1241"\w* \w en|strong="H3588"\w* \w los|strong="H3588"\w* corrales;   
\m
\v 18 Con todo, yo me alegraré en \w Jehová|strong="H3068"\w*, y me gozaré en el \w Dios|strong="H3068"\w* de mi salvación.   
\m
\v 19 \w El|strong="H5921"\w* Señor \w Jehová|strong="H3069"\w* \add es\add* \w mi|strong="H5921"\w* \w fortaleza|strong="H2428"\w*, \w Él|strong="H5921"\w* \w hará|strong="H7760"\w* mis \w pies|strong="H7272"\w* \w como|strong="H5921"\w* \w de|strong="H5921"\w* ciervas, \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w hará|strong="H7760"\w* andar \w sobre|strong="H5921"\w* mis alturas. (\w Al|strong="H5921"\w* principal \w de|strong="H5921"\w* \w los|strong="H5921"\w* cantores, \w sobre|strong="H5921"\w* mis instrumentos \w de|strong="H5921"\w* cuerdas)   