\v 6 \w Porque|strong="H3588"\w* he \w aquí|strong="H2005"\w*, \w yo|strong="H3588"\w* \w levanto|strong="H6965"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w caldeos|strong="H3778"\w*, \w gente|strong="H1471"\w* \w amarga|strong="H4751"\w* \w y|strong="H3588"\w* presurosa, \w que|strong="H3588"\w* \w camina|strong="H1980"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* anchura \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w para|strong="H3588"\w* poseer las habitaciones \w ajenas|strong="H3808"\w*.   
