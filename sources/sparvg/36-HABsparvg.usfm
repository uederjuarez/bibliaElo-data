\m
\v 1 \w Sobre|strong="H5921"\w* \w mi|strong="H5921"\w* guarda \w estaré|strong="H5975"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w fortaleza|strong="H4692"\w* \w estaré|strong="H5975"\w* firme; \w y|strong="H5921"\w* velaré \w para|strong="H5921"\w* \w ver|strong="H7200"\w* \w qué|strong="H4100"\w* \w habrá|strong="H5975"\w* \w de|strong="H5921"\w* decirme, \w y|strong="H5921"\w* \w qué|strong="H4100"\w* habré \w de|strong="H5921"\w* \w responder|strong="H7725"\w* \w cuando|strong="H4100"\w* yo sea reprendido.   
