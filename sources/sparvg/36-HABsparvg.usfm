\v 16 \w Por|strong="H5921"\w* \w esto|strong="H3651"\w* hará \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* red, \w y|strong="H3588"\w* \w quemará|strong="H6999"\w* incienso \w a|strong="H3068"\w* \w sus|strong="H1992"\w* mallas; \w porque|strong="H3588"\w* \w con|strong="H5921"\w* \w ellos|strong="H1992"\w* engordó \w su|strong="H1992"\w* porción, \w y|strong="H3588"\w* engrasó \w su|strong="H1992"\w* \w comida|strong="H3978"\w*.   
\m
\v 17 ¿Vaciará \w por|strong="H5921"\w* \w eso|strong="H3651"\w* su red, \w o|strong="H3068"\w* tendrá piedad \w de|strong="H5921"\w* matar \w gentes|strong="H1471"\w* \w continuamente|strong="H8548"\w*?   
