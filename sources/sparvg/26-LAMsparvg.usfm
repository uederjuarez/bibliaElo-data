\v 11 \w Violaron|strong="H6031"\w* \w a|strong="H3068"\w* las mujeres en \w Sión|strong="H6726"\w*, \w a|strong="H3068"\w* las \w vírgenes|strong="H1330"\w* en las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w*.   
\m
\v 12 \w Príncipes|strong="H8269"\w* han sido \w colgados|strong="H8518"\w* \w por|strong="H6440"\w* su \w mano|strong="H3027"\w*; \w no|strong="H3808"\w* \w respetaron|strong="H1921"\w* el \w rostro|strong="H6440"\w* \w de|strong="H6440"\w* los \w viejos|strong="H2205"\w*.   
\m
\v 13 \w Llevaron|strong="H5375"\w* los jóvenes \w a|strong="H3068"\w* moler, y los muchachos \w desfallecieron|strong="H3782"\w* bajo \add el peso\add* de la \w leña|strong="H6086"\w*.   
\m
\v 14 Los \w ancianos|strong="H2205"\w* \w cesaron|strong="H7673"\w* de la \w puerta|strong="H8179"\w*, los jóvenes de sus canciones.   
\m
\v 15 \w Cesó|strong="H7673"\w* el \w gozo|strong="H4885"\w* de nuestro \w corazón|strong="H3820"\w*; nuestra danza se cambió en luto.   
\m
\v 16 \w Cayó|strong="H5307"\w* \w la|strong="H3588"\w* \w corona|strong="H5850"\w* \w de|strong="H3588"\w* nuestra \w cabeza|strong="H7218"\w*: ¡Ay \w ahora|strong="H4994"\w* \w de|strong="H3588"\w* nosotros! \w porque|strong="H3588"\w* \w pecamos|strong="H2398"\w*.   
\m
\v 17 \w Por|strong="H5921"\w* \w esto|strong="H2088"\w* \w fue|strong="H1961"\w* \w entristecido|strong="H1739"\w* nuestro \w corazón|strong="H3820"\w*, \w por|strong="H5921"\w* \w esto|strong="H2088"\w* \w se|strong="H1961"\w* entenebrecieron nuestros \w ojos|strong="H5869"\w*:   
\m
\v 18 \w Por|strong="H5921"\w* \w la|strong="H5921"\w* montaña \w de|strong="H5921"\w* \w Sión|strong="H6726"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w asolada|strong="H8074"\w*; \w zorras|strong="H7776"\w* \w andan|strong="H1980"\w* \w por|strong="H5921"\w* \w ella|strong="H5921"\w*.   
\m
\v 19 Mas tú, oh \w Jehová|strong="H3068"\w*, \w permanecerás|strong="H3427"\w* para \w siempre|strong="H5769"\w*; tu \w trono|strong="H3678"\w* de \w generación|strong="H1755"\w* en \w generación|strong="H1755"\w*.   
\m
\v 20 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* te olvidarás para siempre \w de|strong="H7911"\w* nosotros, y \w nos|strong="H4100"\w* \w dejarás|strong="H5800"\w* \w por|strong="H4100"\w* largos \w días|strong="H3117"\w*?   
\m
\v 21 \w Vuélvenos|strong="H7725"\w* \w a|strong="H3068"\w* ti, oh \w Jehová|strong="H3068"\w*, y nos \w volveremos|strong="H7725"\w*: \w Renueva|strong="H2318"\w* nuestros \w días|strong="H3117"\w* como al principio.   
\m
\v 22 \w Pero|strong="H3588"\w* tú \w nos|strong="H5921"\w* has \w desechado|strong="H3988"\w* totalmente; \w en|strong="H5921"\w* \w gran|strong="H3966"\w* \w manera|strong="H3966"\w* estás \w enojado|strong="H7107"\w* \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*.   