\v 19 ¿\w Todavía|strong="H5750"\w* \w está|strong="H2088"\w* la semilla \w en|strong="H4480"\w* el granero? \w Aunque|strong="H5704"\w* la \w vid|strong="H1612"\w*, la higuera, el granado \w y|strong="H5704"\w* el \w árbol|strong="H6086"\w* \w de|strong="H4480"\w* olivo \w aún|strong="H5750"\w* \w no|strong="H3808"\w* han \w florecido|strong="H5375"\w*; \w sin|strong="H3808"\w* embargo \w desde|strong="H4480"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w* \add os\add* \w daré|strong="H1288"\w* \w bendición|strong="H1288"\w*.   
\m
\v 20 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w otra|strong="H8145"\w* vez la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* \w Jehová|strong="H3068"\w* \w a|strong="H3068"\w* Hageo, el día \w veinticuatro|strong="H6242"\w* del \w mes|strong="H2320"\w*, diciendo:   
\m
\v 21 Habla \w a|strong="H3068"\w* \w Zorobabel|strong="H2216"\w*, \w gobernador|strong="H6346"\w* de \w Judá|strong="H3063"\w*, diciendo: Yo haré \w temblar|strong="H7493"\w* los \w cielos|strong="H8064"\w* y la tierra;   
\m
\v 22 y trastornaré el \w trono|strong="H3678"\w* de los \w reinos|strong="H4467"\w*, y \w destruiré|strong="H8045"\w* la fuerza del \w reino|strong="H4467"\w* de las \w naciones|strong="H1471"\w*; y trastornaré el \w carro|strong="H4818"\w*, y los que en él suben; y vendrán abajo los \w caballos|strong="H5483"\w*, y los que en ellos montan, cada cual por la \w espada|strong="H2719"\w* de su hermano.   
\m
\v 23 \w En|strong="H3588"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w ejércitos|strong="H6635"\w*, \w te|strong="H3588"\w* \w tomaré|strong="H3947"\w*, \w oh|strong="H1121"\w* \w Zorobabel|strong="H2216"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Salatiel, \w siervo|strong="H5650"\w* mío, \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w*, \w y|strong="H3588"\w* \w te|strong="H3588"\w* \w pondré|strong="H7760"\w* \w como|strong="H3588"\w* anillo \w de|strong="H3588"\w* sellar; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H3588"\w* escogí, \w dice|strong="H5002"\w* \w Jehová|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w ejércitos|strong="H6635"\w*.   