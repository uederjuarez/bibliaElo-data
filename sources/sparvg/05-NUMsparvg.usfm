\m
\v 11 \w Y|strong="H3068"\w* \w lo|strong="H5921"\w* \w hizo|strong="H5414"\w* \w Moisés|strong="H4872"\w*; \w como|strong="H3588"\w* \w le|strong="H5921"\w* mandó \w Jehová|strong="H3068"\w*, \w así|strong="H3588"\w* \w hizo|strong="H5414"\w*.   
\m
\v 12 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* Israel \w hablaron|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*: He \w aquí|strong="H2009"\w* \w nosotros|strong="H5921"\w* somos \w muertos|strong="H2490"\w*, perecemos, todos \w nosotros|strong="H5921"\w* perecemos.   
\m
\v 13 Cualquiera que viene y se acerca al tabernáculo de Jehová ha de \w morir|strong="H4191"\w*; ¿hemos de perecer todos?   
\c 18
\m
\v 1 \w Y|strong="H3068"\w* \w Jehová|strong="H3068"\w* dijo \w a|strong="H3068"\w* Aarón: Tú y tus \w hijos|strong="H1121"\w*, y la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* tu padre contigo, \w llevaréis|strong="H5375"\w* \w el|strong="H1121"\w* \w pecado|strong="H5771"\w* del \w santuario|strong="H4720"\w*: y tú y tus \w hijos|strong="H1121"\w* contigo \w llevaréis|strong="H5375"\w* \w el|strong="H1121"\w* \w pecado|strong="H5771"\w* \w de|strong="H1121"\w* vuestro \w sacerdocio|strong="H3550"\w*.   
\m
