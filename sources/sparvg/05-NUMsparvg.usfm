\v 4 \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* \w se|strong="H5921"\w* juntarán \w contigo|strong="H5921"\w*, \w y|strong="H5921"\w* \w tendrán|strong="H8104"\w* \w el|strong="H5921"\w* cargo \w del|strong="H5921"\w* tabernáculo \w de|strong="H5921"\w* \w la|strong="H5921"\w* congregación \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* servicio \w del|strong="H5921"\w* tabernáculo; \w ningún|strong="H3605"\w* extranjero \w se|strong="H5921"\w* acercará \w a|strong="H3068"\w* vosotros.   
\m
\v 5 \w Y|strong="H3068"\w* \w tendréis|strong="H1961"\w* \w la|strong="H5921"\w* \w guarda|strong="H8104"\w* \w del|strong="H5921"\w* \w santuario|strong="H6944"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w guarda|strong="H8104"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w la|strong="H5921"\w* \w ira|strong="H7110"\w* \w no|strong="H3808"\w* \w venga|strong="H1961"\w* \w más|strong="H5750"\w* \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\m
\v 6 \w Porque|strong="H2009"\w* he \w aquí|strong="H2009"\w* \w yo|strong="H2009"\w* he \w tomado|strong="H3947"\w* \w a|strong="H3068"\w* \w vuestros|strong="H5647"\w* hermanos \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w de|strong="H1121"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w dados|strong="H5414"\w* \add a vosotros\add* \w en|strong="H8432"\w* don \w de|strong="H1121"\w* \w Jehová|strong="H3068"\w*, \w para|strong="H5414"\w* \w que|strong="H1121"\w* sirvan \w en|strong="H8432"\w* \w el|strong="H1121"\w* \w ministerio|strong="H5656"\w* del tabernáculo \w de|strong="H1121"\w* la congregación.   
\m
\v 7 \w Mas|strong="H4191"\w* tú y tus \w hijos|strong="H1121"\w* contigo \w guardaréis|strong="H8104"\w* vuestro \w sacerdocio|strong="H3550"\w* en \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* concerniente al \w altar|strong="H4196"\w*, y \w del|strong="H4196"\w* velo \w adentro|strong="H1004"\w*, y ministraréis. Yo os he \w dado|strong="H5414"\w* en don \w el|strong="H3605"\w* servicio \w de|strong="H1121"\w* vuestro \w sacerdocio|strong="H3550"\w*; y \w el|strong="H3605"\w* \w extraño|strong="H1121"\w* \w que|strong="H1697"\w* se acercare, \w morirá|strong="H4191"\w*.   
