\m
\v 10 En \w el|strong="H3605"\w* \w santuario|strong="H6944"\w* \w la|strong="H3605"\w* comerás; \w todo|strong="H3605"\w* \w varón|strong="H2145"\w* comerá de \w ella|strong="H3605"\w*: \w cosa|strong="H3605"\w* \w santa|strong="H6944"\w* \w será|strong="H1961"\w* \w para|strong="H1961"\w* ti.   
\m
\v 11 \w Esto|strong="H2088"\w* \w también|strong="H2088"\w* \w será|strong="H5414"\w* tuyo: \w la|strong="H3605"\w* \w ofrenda|strong="H8641"\w* \w elevada|strong="H8641"\w* \w de|strong="H1121"\w* sus dones, y \w todas|strong="H3605"\w* las \w ofrendas|strong="H8641"\w* mecidas \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, he \w dado|strong="H5414"\w* \w a|strong="H3068"\w* ti, y \w a|strong="H3068"\w* tus \w hijos|strong="H1121"\w*, y \w a|strong="H3068"\w* tus \w hijas|strong="H1323"\w* contigo, \w por|strong="H2088"\w* \w estatuto|strong="H2706"\w* \w perpetuo|strong="H5769"\w*: \w todo|strong="H3605"\w* \w limpio|strong="H2889"\w* en tu \w casa|strong="H1004"\w* comerá \w de|strong="H1121"\w* ellas.   
\m
\v 12 \w De|strong="H5414"\w* \w aceite|strong="H3323"\w*, y \w de|strong="H5414"\w* \w mosto|strong="H8492"\w*, y \w de|strong="H5414"\w* \w trigo|strong="H1715"\w*, \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* más escogido, las \w primicias|strong="H7225"\w* \w de|strong="H5414"\w* ello, \w que|strong="H3605"\w* \w presentarán|strong="H5414"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \w a|strong="H3068"\w* ti las he \w dado|strong="H5414"\w*.   
\m
