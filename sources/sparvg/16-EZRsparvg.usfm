\v 17 \w Y|strong="H3068"\w* \w ahora|strong="H3705"\w*, \w si|strong="H2006"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w* parece \w bien|strong="H2869"\w*, \w búsquese|strong="H1240"\w* \w en|strong="H5922"\w* la \w casa|strong="H1005"\w* \w de|strong="H4481"\w* los tesoros \w del|strong="H4481"\w* \w rey|strong="H4430"\w* \w que|strong="H1768"\w* \w está|strong="H1836"\w* \w allí|strong="H8536"\w* \w en|strong="H5922"\w* Babilonia, \w si|strong="H2006"\w* es \w así|strong="H1836"\w* \w que|strong="H1768"\w* \w por|strong="H4481"\w* el \w rey|strong="H4430"\w* \w Ciro|strong="H3567"\w* había sido dado \w mandamiento|strong="H2942"\w* \w para|strong="H5922"\w* reedificar \w esta|strong="H1836"\w* \w casa|strong="H1005"\w* \w de|strong="H4481"\w* Dios \w en|strong="H5922"\w* Jerusalén, y envíenos \w a|strong="H3068"\w* decir la voluntad \w del|strong="H4481"\w* \w rey|strong="H4430"\w* \w sobre|strong="H5922"\w* \w esto|strong="H1836"\w*.   
\c 6
