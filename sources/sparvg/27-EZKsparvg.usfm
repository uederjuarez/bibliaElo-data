\v 2 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w di|strong="H5414"\w* al \w príncipe|strong="H5057"\w* \w de|strong="H1121"\w* \w Tiro|strong="H6865"\w*: \w Así|strong="H3541"\w* dice \w el|strong="H1121"\w* Señor \w Jehová|strong="H3069"\w*: \w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w se|strong="H3808"\w* enalteció tu \w corazón|strong="H3820"\w* \w y|strong="H3541"\w* dijiste: Yo soy \w Dios|strong="H3069"\w*; en la silla \w de|strong="H1121"\w* \w Dios|strong="H3069"\w* estoy \w sentado|strong="H3427"\w* en medio \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w mares|strong="H3220"\w* (siendo tú \w hombre|strong="H1121"\w* \w y|strong="H3541"\w* \w no|strong="H3808"\w* \w Dios|strong="H3069"\w*), \w y|strong="H3541"\w* \w has|strong="H5414"\w* \w puesto|strong="H5414"\w* tu \w corazón|strong="H3820"\w* como \w corazón|strong="H3820"\w* \w de|strong="H1121"\w* \w Dios|strong="H3069"\w*.   
\m
