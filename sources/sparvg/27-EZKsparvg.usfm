\v 42 \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \add soy\add* \w Jehová|strong="H3068"\w*, \w cuando|strong="H3588"\w* os hubiere metido \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w alcé|strong="H5375"\w* \w mi|strong="H5375"\w* \w mano|strong="H3027"\w* \add jurando\add* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w daría|strong="H5414"\w* \w a|strong="H3068"\w* vuestros padres.   
\m
\v 43 \w Y|strong="H3068"\w* \w allí|strong="H8033"\w* os acordaréis \w de|strong="H6440"\w* vuestros \w caminos|strong="H1870"\w*, y \w de|strong="H6440"\w* \w todos|strong="H3605"\w* vuestros \w hechos|strong="H6213"\w* en \w que|strong="H3605"\w* os contaminasteis; y os detestaréis \w a|strong="H3068"\w* vosotros mismos \w por|strong="H1870"\w* \w todos|strong="H3605"\w* vuestros pecados \w que|strong="H3605"\w* \w cometisteis|strong="H6213"\w*.   
\m
\v 44 \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy \w Jehová|strong="H3068"\w* \w cuando|strong="H3588"\w* \w haga|strong="H6213"\w* \w con|strong="H3588"\w* vosotros \w por|strong="H3588"\w* amor \w a|strong="H3068"\w* mi \w nombre|strong="H8034"\w*, \w no|strong="H3808"\w* según vuestros \w malos|strong="H7451"\w* \w caminos|strong="H1870"\w*, \w ni|strong="H3808"\w* según vuestras perversas \w obras|strong="H5949"\w*, oh \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* \w Jehová|strong="H3068"\w*.   
\m
\v 45 \w Y|strong="H3068"\w* vino \w a|strong="H3068"\w* mí la palabra de Jehová, diciendo:   
\m
\v 46 Hijo de hombre, pon tu rostro hacia el sur, y derrama \add tu palabra\add* hacia la parte austral, y profetiza contra el bosque de la región del sur.   
\m
\v 47 \w Y|strong="H3068"\w* dirás al bosque del sur: Oye la palabra de Jehová: Así dice el Señor Jehová: He aquí que yo enciendo en ti fuego, el cual consumirá en ti todo árbol verde, y todo árbol seco; no se apagará la llama del fuego; y serán quemados en ella todos los rostros, desde el sur hasta el norte.   
\m
\v 48 \w Y|strong="H3068"\w* verá toda carne que yo Jehová lo encendí; no se apagará.   
\m
\v 49 \w Y|strong="H3068"\w* dije: ¡Ah, Señor Jehová! ellos dicen de mí: ¿No profiere este parábolas?   
\c 21
\m
\v 1 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* \w Jehová|strong="H3068"\w*, diciendo:   
\m
\v 2 \w Hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w hombre|strong="H1121"\w*, \w pon|strong="H7760"\w* tu \w rostro|strong="H6440"\w* \w contra|strong="H6440"\w* Jerusalén, y derrama \add palabra\add* sobre \w los|strong="H1121"\w* santuarios, y \w profetiza|strong="H5012"\w* \w contra|strong="H6440"\w* la tierra \w de|strong="H6440"\w* Israel.   
\m
\v 3 \w Y|strong="H3068"\w* dirás \w a|strong="H3068"\w* \w la|strong="H3605"\w* tierra \w de|strong="H6440"\w* Israel: \w Así|strong="H3541"\w* \w dice|strong="H1697"\w* \w Jehová|strong="H3068"\w*: He \w aquí|strong="H3541"\w*, \w que|strong="H3808"\w* yo \w contra|strong="H6440"\w* ti, \w y|strong="H3541"\w* sacaré mi espada \w de|strong="H6440"\w* su vaina, \w y|strong="H3541"\w* cortaré \w de|strong="H6440"\w* ti al justo \w y|strong="H3541"\w* al impío.   
\m
\v 4 \w Y|strong="H3068"\w* \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* he \w de|strong="H3588"\w* cortar \w de|strong="H3588"\w* ti al justo \w y|strong="H3588"\w* al impío, \w por|strong="H3588"\w* tanto, mi espada saldrá \w de|strong="H3588"\w* \w su|strong="H3588"\w* vaina contra \w toda|strong="H3605"\w* \w carne|strong="H1320"\w*, desde \w el|strong="H3588"\w* sur hasta \w el|strong="H3588"\w* norte.   
\m
\v 5 \w Y|strong="H3068"\w* sabrá toda carne \w que|strong="H1931"\w* yo \w Jehová|strong="H3069"\w* saqué mi espada de \w su|strong="H1931"\w* vaina; \w no|strong="H3808"\w* volverá ya \w más|strong="H3808"\w*.   
\m
\v 6 \w Y|strong="H3068"\w* tú, hijo \w de|strong="H1697"\w* hombre, gime con quebrantamiento \w de|strong="H1697"\w* \add tus\add* lomos, y con amargura; gime delante \w de|strong="H1697"\w* \w los|strong="H1961"\w* ojos \w de|strong="H1697"\w* ellos.   
\m
\v 7 \w Y|strong="H3068"\w* será, \w que|strong="H1121"\w* cuando te dijeren: ¿\w Por|strong="H6440"\w* \w qué|strong="H1121"\w* gimes tú? dirás: \w Por|strong="H6440"\w* la noticia \w que|strong="H1121"\w* viene; y todo corazón desfallecerá, y toda mano se debilitará, y se angustiará todo espíritu, y toda rodilla será débil \add como\add* \w el|strong="H1121"\w* agua; he aquí \w que|strong="H1121"\w* viene, y se \w hará|strong="H7760"\w*, dice \w el|strong="H1121"\w* Señor Jehová.   
\m
\v 8 La palabra \w de|strong="H4480"\w* \w Jehová|strong="H3068"\w* vino \w a|strong="H3068"\w* mí otra vez, diciendo:   
\m
\v 9 Hijo \w de|strong="H4480"\w* hombre, profetiza, y di: \w Así|strong="H3651"\w* dice Jehová: Di: \w La|strong="H3605"\w* \w espada|strong="H2719"\w*, \w la|strong="H3605"\w* \w espada|strong="H2719"\w* \w está|strong="H3651"\w* afilada, y \w también|strong="H3651"\w* pulida.   
\m
\v 10 \w Para|strong="H3588"\w* \w la|strong="H3605"\w* matanza está afilada, pulida está \w para|strong="H3588"\w* \w que|strong="H3588"\w* relumbre. ¿Hemos \w de|strong="H3588"\w* alegrarnos? Al cetro \w de|strong="H3588"\w* mi hijo \w ha|strong="H3808"\w* menospreciado \add como\add* \w a|strong="H3068"\w* una vara \w cualquiera|strong="H3605"\w*.   
\m
\v 11 \w Y|strong="H3068"\w* la dio \w a|strong="H3068"\w* pulir para tenerla \w a|strong="H3068"\w* mano: la espada está afilada, y pulida está ella, para entregarla en mano del matador.   
\m
\v 12 Clama \w y|strong="H3588"\w* gime, \w oh|strong="H4100"\w* hijo \w de|strong="H5921"\w* hombre; \w porque|strong="H3588"\w* \w esta|strong="H1961"\w* \add será\add* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* pueblo, \w será|strong="H1961"\w* \w ella|strong="H5921"\w* \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* príncipes \w de|strong="H5921"\w* Israel. Temores \w de|strong="H5921"\w* espada \w serán|strong="H1961"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* pueblo: \w por|strong="H5921"\w* \w tanto|strong="H5921"\w*, hiere \w el|strong="H5921"\w* muslo;   
\m
\v 13 porque \add está\add* probado. ¿\w Y|strong="H3068"\w* \w qué|strong="H1697"\w*, \w si|strong="H1961"\w* la espada desprecia aun el cetro? Él \w no|strong="H1961"\w* \w será|strong="H1961"\w* \add más\add*, \w dice|strong="H1697"\w* el \w Señor|strong="H3068"\w* \w Jehová|strong="H3068"\w*.   
\m
\v 14 Tú, \w pues|strong="H1571"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w profetiza|strong="H5012"\w* \w y|strong="H1571"\w* bate una mano \w con|strong="H1571"\w* otra, \w que|strong="H1571"\w* sea duplicada \w la|strong="H1571"\w* \w espada|strong="H2719"\w* \w la|strong="H1571"\w* tercera vez, \w la|strong="H1571"\w* \w espada|strong="H2719"\w* para \w los|strong="H1121"\w* muertos; \w la|strong="H1571"\w* \w espada|strong="H2719"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* grandes \add hombres que han sido\add* muertos, \w que|strong="H1571"\w* entra \w a|strong="H3068"\w* sus cámaras,   
\m
\v 15 \w para|strong="H4616"\w* \w que|strong="H1121"\w* \w el|strong="H3605"\w* corazón desmaye y \w los|strong="H1121"\w* estragos \w se|strong="H1961"\w* multipliquen; en \w todas|strong="H3605"\w* las puertas \w de|strong="H1121"\w* \w ellos|strong="H3605"\w* he puesto espanto \w de|strong="H1121"\w* espada. ¡Ah! dispuesta \w está|strong="H1961"\w* \w para|strong="H4616"\w* \w que|strong="H1121"\w* relumbre, y preparada \w para|strong="H4616"\w* \w degollar|strong="H2874"\w*.   
\m
\v 16 Ponte \w a|strong="H3068"\w* una parte, ya sea \w a|strong="H3068"\w* \w la|strong="H1931"\w* derecha, \add o\add* \w a|strong="H3068"\w* \w la|strong="H1931"\w* izquierda, hacia \w donde|strong="H1931"\w* tu rostro \w se|strong="H1931"\w* determine.   
\m
\v 17 \w Y|strong="H3068"\w* \w yo|strong="H3588"\w* \w también|strong="H3651"\w* batiré \w mi|strong="H1961"\w* \w mano|strong="H1931"\w* \w con|strong="H3588"\w* \w mi|strong="H1961"\w* \w mano|strong="H1931"\w*, \w y|strong="H3588"\w* haré reposar \w mi|strong="H1961"\w* ira. \w Yo|strong="H3588"\w* Jehová he hablado.   
\m
\v 18 \w La|strong="H1571"\w* palabra \w de|strong="H3588"\w* \w Jehová|strong="H3069"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* otra vez, diciendo:   
\m
\v 19 \w Y|strong="H3068"\w* tú, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, señálate dos caminos por \w donde|strong="H1931"\w* venga \w la|strong="H1931"\w* \w espada|strong="H2719"\w* del \w rey|strong="H5221"\w* \w de|strong="H1121"\w* Babilonia; \w de|strong="H1121"\w* una \w misma|strong="H1931"\w* tierra salgan ambos; y elige un lugar; escógelo \w en|strong="H5221"\w* \w el|strong="H1931"\w* principio del camino \w que|strong="H1931"\w* conduce \w a|strong="H3068"\w* \w la|strong="H1931"\w* ciudad.   
\m
\v 20 \w El|strong="H5921"\w* camino señalarás \w por|strong="H5921"\w* \w donde|strong="H5921"\w* venga \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* Rabá \w de|strong="H5921"\w* \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* Amón, \w y|strong="H5921"\w* \w a|strong="H3068"\w* Judá \w contra|strong="H5921"\w* Jerusalén \w la|strong="H5921"\w* fortificada.   
\m
\v 21 \w Porque|strong="H6440"\w* el rey \w de|strong="H6440"\w* Babilonia se paró \w en|strong="H3259"\w* una encrucijada, al principio \w de|strong="H6440"\w* \w dos|strong="H6440"\w* caminos, para tomar adivinación; acicaló las saetas, consultó \w en|strong="H3259"\w* ídolos, miró el hígado.   
\m
\v 22 \w La|strong="H1571"\w* adivinación señaló \w a|strong="H3068"\w* su \w mano|strong="H3709"\w* derecha, sobre Jerusalén, para poner capitanes, para abrir \w la|strong="H1571"\w* boca \w a|strong="H3068"\w* \w la|strong="H1571"\w* matanza, para levantar \w la|strong="H1571"\w* voz \w en|strong="H5221"\w* grito de guerra, para poner arietes contra las puertas, para levantar baluarte, \add y\add* edificar fuerte.   
\m
\v 23 \w Y|strong="H3068"\w* les \w será|strong="H1961"\w* \w como|strong="H1961"\w* adivinación mentirosa en sus ojos, \w por|strong="H1697"\w* estar juramentados con juramento \w a|strong="H3068"\w* ellos; pero él trae \w a|strong="H3068"\w* la memoria la maldad \w de|strong="H1697"\w* ellos, \w para|strong="H1961"\w* prenderlos.   
\m
\v 24 \w Por|strong="H1870"\w* tanto, así dice \w el|strong="H1121"\w* Señor Jehová: \w Por|strong="H1870"\w* cuanto habéis hecho venir \w en|strong="H3318"\w* memoria vuestras maldades, manifestando vuestras traiciones, y descubriendo vuestros pecados \w en|strong="H3318"\w* todas vuestras obras; \w por|strong="H1870"\w* cuanto habéis venido \w en|strong="H3318"\w* memoria, seréis apresados \w por|strong="H1870"\w* \add su\add* \w mano|strong="H3027"\w*.   
\m
\v 25 \w Y|strong="H3068"\w* tú, profano \w e|strong="H3068"\w* impío príncipe \w de|strong="H1121"\w* Israel, cuyo \w día|strong="H1121"\w* \w vino|strong="H1870"\w* en \w el|strong="H1121"\w* tiempo \w de|strong="H1121"\w* la consumación \w de|strong="H1121"\w* la maldad;   
\m
\v 26 \w así|strong="H3588"\w* dice \w el|strong="H3588"\w* Señor Jehová: Depón \w la|strong="H3588"\w* diadema, quita \w la|strong="H3588"\w* corona; \w esta|strong="H5975"\w* ya \w no|strong="H3588"\w* \add será\add* \w la|strong="H3588"\w* misma; sea exaltado lo bajo, \w y|strong="H3588"\w* lo alto sea humillado.   
\m
\v 27 \w La|strong="H5921"\w* derribaré, derribaré, derribaré, \w y|strong="H5921"\w* ya \w no|strong="H1961"\w* \w será|strong="H1961"\w* \add más\add*, \w hasta|strong="H5921"\w* \w que|strong="H5921"\w* \w venga|strong="H1961"\w* Aquél \w a|strong="H3068"\w* quien pertenece \w el|strong="H5921"\w* \w derecho|strong="H3225"\w*, \w y|strong="H5921"\w* \w se|strong="H1961"\w* \w la|strong="H5921"\w* entregaré.   
\m
\v 28 \w Y|strong="H3068"\w* tú, hijo \w de|strong="H5869"\w* hombre, profetiza, y di: \w Así|strong="H1931"\w* dice \w el|strong="H1931"\w* Señor Jehová \w sobre|strong="H1961"\w* \w los|strong="H1931"\w* hijos \w de|strong="H5869"\w* Amón, y \w su|strong="H1931"\w* oprobio. Dirás, \w pues|strong="H1931"\w*: \w La|strong="H1931"\w* espada, \w la|strong="H1931"\w* espada \w está|strong="H1931"\w* desenvainada \w para|strong="H1961"\w* degollar, \w para|strong="H1961"\w* consumir; pulida con resplandor.   
\m
\v 29 Te profetizan vanidad, \w y|strong="H3541"\w* te adivinan mentira, \w para|strong="H3282"\w* entregarte con \w los|strong="H3605"\w* cuellos de \w los|strong="H3605"\w* malos sentenciados \w a|strong="H3068"\w* muerte, cuyo día vino en tiempo de \w la|strong="H3605"\w* consumación de \w la|strong="H3605"\w* \w maldad|strong="H5771"\w*.   
\m
\v 30 ¿La volveré \w a|strong="H3068"\w* su vaina? En el lugar donde te criaste, en la tierra donde has vivido, te juzgaré.   
\m
\v 31 \w Y|strong="H3068"\w* derramaré sobre ti mi ira; el fuego de mi enojo haré encender sobre ti, \w y|strong="H3541"\w* te entregaré \w en|strong="H5493"\w* mano de hombres temerarios, artífices de destrucción.   
\m
\v 32 \w Serás|strong="H1961"\w* pasto \w para|strong="H5704"\w* \w el|strong="H1571"\w* fuego; tu sangre \w quedará|strong="H1961"\w* \w en|strong="H5704"\w* medio \w de|strong="H5704"\w* \w la|strong="H1571"\w* tierra, \add y\add* \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* \add más\add* memoria \w de|strong="H5704"\w* ti; \w porque|strong="H3808"\w* yo Jehová he hablado.   
\c 22
\m
\v 1 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* \w Jehová|strong="H3068"\w*, diciendo:   
\m
\v 2 \w Y|strong="H3068"\w* \w tú|strong="H8199"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, ¿no \w juzgarás|strong="H8199"\w* \w tú|strong="H8199"\w*, no \w juzgarás|strong="H8199"\w* \w tú|strong="H8199"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* derramadora \w de|strong="H1121"\w* \w sangre|strong="H1818"\w*? Sí, \w tú|strong="H8199"\w* le mostrarás \w todas|strong="H3605"\w* sus \w abominaciones|strong="H8441"\w*.   
\m
\v 3 Dirás, pues: \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor \w Jehová|strong="H3069"\w*: ¡\w Ciudad|strong="H5892"\w* \w derramadora|strong="H8210"\w* \w de|strong="H5921"\w* \w sangre|strong="H1818"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w sí|strong="H5921"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* venga su \w hora|strong="H6256"\w*, \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w* \w ídolos|strong="H1544"\w* \w contra|strong="H5921"\w* \w sí|strong="H5921"\w* misma \w para|strong="H5921"\w* contaminarse!   
\m
\v 4 \w En|strong="H5921"\w* \w tu|strong="H6213"\w* \w sangre|strong="H1818"\w* \w que|strong="H5921"\w* \w derramaste|strong="H8210"\w* \w has|strong="H5414"\w* pecado, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w has|strong="H5414"\w* \w contaminado|strong="H2930"\w* \w en|strong="H5921"\w* tus \w ídolos|strong="H1544"\w* \w que|strong="H5921"\w* \w hiciste|strong="H6213"\w*; \w y|strong="H5921"\w* \w has|strong="H5414"\w* \w hecho|strong="H6213"\w* acercar tus \w días|strong="H3117"\w*, \w y|strong="H5921"\w* \w has|strong="H5414"\w* llegado \w al|strong="H5921"\w* término \w de|strong="H5921"\w* tus \w años|strong="H8141"\w*; \w por|strong="H5921"\w* \w tanto|strong="H3651"\w* \w te|strong="H5921"\w* he \w dado|strong="H5414"\w* \w en|strong="H5921"\w* \w oprobio|strong="H2781"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* escarnio \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* tierras.   
\m
\v 5 \add Las que están\add* \w cerca|strong="H7138"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w* y las \w que|strong="H4480"\w* están \w lejos|strong="H7350"\w* \w se|strong="H4480"\w* reirán \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, \add que eres\add* \w amancillada|strong="H2931"\w* \w de|strong="H4480"\w* \w nombre|strong="H8034"\w* \add y\add* \w de|strong="H4480"\w* \w gran|strong="H7227"\w* \w turbación|strong="H4103"\w*.   
\m
