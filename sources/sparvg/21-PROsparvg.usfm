\m
\v 3 en el lugar de las \w puertas|strong="H8179"\w*, \w a|strong="H3068"\w* la \w entrada|strong="H3996"\w* de la ciudad, \w a|strong="H3068"\w* la \w entrada|strong="H3996"\w* de las \w puertas|strong="H8179"\w* da voces:   
\m
\v 4 \w Oh|strong="H1121"\w* \w hombres|strong="H1121"\w*, \w a|strong="H3068"\w* vosotros \w clamo|strong="H7121"\w*; y mi \w voz|strong="H6963"\w* \add se dirige\add* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*.   
