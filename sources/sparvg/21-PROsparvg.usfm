\m
\v 25 \w No|strong="H1870"\w* se aparte tu \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* sus \w caminos|strong="H1870"\w*; \w no|strong="H1870"\w* \w yerres|strong="H8582"\w* en sus \w veredas|strong="H5410"\w*.   
\m
