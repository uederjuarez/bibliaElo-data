\v 11 \w Las|strong="H5921"\w* \w riquezas|strong="H1952"\w* \w de|strong="H5921"\w* \w vanidad|strong="H1892"\w* disminuirán; \w mas|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w las|strong="H5921"\w* acumula \w por|strong="H5921"\w* \w mano|strong="H3027"\w* laboriosa \w las|strong="H5921"\w* \w aumentará|strong="H7235"\w*.   
