\m
\v 22 Enseguida se \w va|strong="H3068"\w* en pos de ella, como \w va|strong="H3068"\w* el \w buey|strong="H7794"\w* al degolladero, \w o|strong="H3068"\w* como el necio \w a|strong="H3068"\w* las prisiones para ser castigado;   
\m
\v 23 \w como|strong="H3588"\w* \w el|strong="H1931"\w* \w ave|strong="H6833"\w* \w que|strong="H3588"\w* \w se|strong="H3045"\w* apresura \w a|strong="H3068"\w* \w la|strong="H1931"\w* red, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w sabe|strong="H3045"\w* \w que|strong="H3588"\w* \w es|strong="H1931"\w* contra \w su|strong="H1931"\w* \w vida|strong="H5315"\w*, \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w la|strong="H1931"\w* \w saeta|strong="H2671"\w* traspasa \w su|strong="H1931"\w* \w hígado|strong="H3516"\w*.   
\m
