\v 10 \w Recibid|strong="H3947"\w* mi \w enseñanza|strong="H4148"\w*, y no \w plata|strong="H3701"\w*; y entendimiento antes que el oro escogido.   
\m
\v 11 \w Porque|strong="H3588"\w* \w mejor|strong="H2896"\w* \add es\add* \w la|strong="H3588"\w* \w sabiduría|strong="H2451"\w* \w que|strong="H3588"\w* las piedras preciosas; \w y|strong="H3588"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H3588"\w* \w se|strong="H3808"\w* pueden desear, \w no|strong="H3808"\w* \w son|strong="H3588"\w* \w de|strong="H3588"\w* comparar \w con|strong="H3588"\w* \w ella|strong="H3605"\w*.   
\m
\v 12 Yo, \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*, \w habito|strong="H7931"\w* con \w la|strong="H2451"\w* prudencia, y \w hallo|strong="H4672"\w* el \w conocimiento|strong="H1847"\w* en los consejos.   
\m
\v 13 El \w temor|strong="H3374"\w* \w de|strong="H7451"\w* \w Jehová|strong="H3068"\w* \add es\add* aborrecer el \w mal|strong="H7451"\w*; la \w soberbia|strong="H1347"\w* y la arrogancia, el \w mal|strong="H7451"\w* \w camino|strong="H1870"\w*, y la \w boca|strong="H6310"\w* \w perversa|strong="H8419"\w* \w aborrezco|strong="H8130"\w*.   
\m
\v 14 Mío es el \w consejo|strong="H6098"\w* y la sana \w sabiduría|strong="H8454"\w*; yo soy la inteligencia; mía es la \w fortaleza|strong="H1369"\w*.   
\m
