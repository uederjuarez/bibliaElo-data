\mt1 Proverbios  
\c 1
\m
\v 1 \w Los|strong="H1121"\w* \w proverbios|strong="H4912"\w* \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*:   
\m
\v 2 Para conocer \w sabiduría|strong="H2451"\w* \w e|strong="H3068"\w* instrucción; para percibir las palabras de entendimiento;   
\m
\v 3 para \w recibir|strong="H3947"\w* la instrucción de sabiduría, \w justicia|strong="H6664"\w*, \w juicio|strong="H4941"\w* y equidad;   
\m
\v 4 \w para|strong="H5414"\w* \w dar|strong="H5414"\w* sagacidad \w a|strong="H3068"\w* los \w simples|strong="H6612"\w*, y \w a|strong="H3068"\w* los jóvenes \w conocimiento|strong="H1847"\w* y discreción.   
\m
\v 5 \w Oirá|strong="H8085"\w* el \w sabio|strong="H2450"\w*, y \w aumentará|strong="H3254"\w* el saber; y el entendido \w adquirirá|strong="H7069"\w* \w sabios|strong="H2450"\w* consejos.   
\m
\v 6 Para entender proverbio y la interpretación; las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w los|strong="H2450"\w* \w sabios|strong="H2450"\w*, y sus enigmas.   
\m
\v 7 El \w principio|strong="H7225"\w* de \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* \add es\add* el \w temor|strong="H3374"\w* de \w Jehová|strong="H3068"\w*: Los insensatos desprecian \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* y \w la|strong="H2451"\w* instrucción.   
\m
\v 8 \w Oye|strong="H8085"\w*, \w hijo|strong="H1121"\w* mío, la instrucción \w de|strong="H1121"\w* tu padre, y no \w dejes|strong="H5203"\w* la \w ley|strong="H8451"\w* \w de|strong="H1121"\w* tu madre:   
\m
\v 9 \w Porque|strong="H3588"\w* \w adorno|strong="H3880"\w* \w de|strong="H3588"\w* \w gracia|strong="H2580"\w* \add serán\add* \w a|strong="H3068"\w* tu \w cabeza|strong="H7218"\w*, \w y|strong="H3588"\w* collares \w a|strong="H3068"\w* tu cuello.   
\m
\v 10 \w Hijo|strong="H1121"\w* mío, si \w los|strong="H1121"\w* \w pecadores|strong="H2400"\w* te quisieren engañar, no consientas.   
\m
\v 11 Si dijeren: \w Ven|strong="H3212"\w* con nosotros, pongamos asechanzas para \add derramar\add* \w sangre|strong="H1818"\w*, \w acechemos|strong="H6845"\w* sin motivo al \w inocente|strong="H5355"\w*;   
\m
\v 12 los tragaremos \w vivos|strong="H2416"\w* como el \w sepulcro|strong="H7585"\w*, y enteros, como los que caen \w en|strong="H8549"\w* sima.   
\m
\v 13 \w Hallaremos|strong="H4672"\w* \w riquezas|strong="H1952"\w* de \w toda|strong="H3605"\w* clase, llenaremos nuestras \w casas|strong="H1004"\w* de \w despojos|strong="H7998"\w*;   
\m
\v 14 \w echa|strong="H5307"\w* tu \w suerte|strong="H1486"\w* \w entre|strong="H8432"\w* \w nosotros|strong="H3605"\w*; \w tengamos|strong="H1961"\w* \w todos|strong="H3605"\w* una sola \w bolsa|strong="H3599"\w*.   
\m
\v 15 \w Hijo|strong="H1121"\w* mío, \w no|strong="H1870"\w* \w andes|strong="H3212"\w* \w en|strong="H3212"\w* \w camino|strong="H1870"\w* con ellos; \w aparta|strong="H4513"\w* tu \w pie|strong="H7272"\w* \w de|strong="H1121"\w* sus \w veredas|strong="H5410"\w*:   
\m
\v 16 \w Porque|strong="H3588"\w* sus \w pies|strong="H7272"\w* \w corren|strong="H7323"\w* hacia \w el|strong="H3588"\w* \w mal|strong="H7451"\w*, \w y|strong="H3588"\w* se apresuran \w a|strong="H3068"\w* derramar \w sangre|strong="H1818"\w*.   
\m
\v 17 \w Porque|strong="H3588"\w* \w en|strong="H3588"\w* \w vano|strong="H2600"\w* se tenderá \w la|strong="H3588"\w* \w red|strong="H7568"\w* ante \w los|strong="H1167"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w ave|strong="H1167"\w*;   
\m
\v 18 mas \w ellos|strong="H1992"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* propia \w sangre|strong="H1818"\w* ponen asechanzas, y \w a|strong="H3068"\w* \w sus|strong="H1992"\w* propias \w vidas|strong="H5315"\w* tienden lazo.   
\m
\v 19 \w Tales|strong="H3651"\w* son las sendas de \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* es dado \w a|strong="H3068"\w* \w la|strong="H3605"\w* codicia, \w la|strong="H3605"\w* \w cual|strong="H5315"\w* \w quita|strong="H3947"\w* \w la|strong="H3605"\w* \w vida|strong="H5315"\w* de sus poseedores.   
\m
\v 20 La \w sabiduría|strong="H2454"\w* \w clama|strong="H7442"\w* \w de|strong="H5414"\w* \w fuera|strong="H2351"\w*, \w da|strong="H5414"\w* su \w voz|strong="H6963"\w* en las \w plazas|strong="H7339"\w*:   
\m
\v 21 \w Clama|strong="H7121"\w* en los \w principales|strong="H7218"\w* \w lugares|strong="H5892"\w* de concurso; en las entradas de las \w puertas|strong="H8179"\w* de la \w ciudad|strong="H5892"\w* pronuncia sus palabras, \add diciendo\add*:   
\m
\v 22 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w*, oh \w simples|strong="H6612"\w*, amaréis la simpleza, \w y|strong="H5704"\w* \w los|strong="H1992"\w* \w burladores|strong="H3944"\w* desearán \w el|strong="H1992"\w* burlar, \w y|strong="H5704"\w* \w los|strong="H1992"\w* insensatos \w aborrecerán|strong="H8130"\w* \w el|strong="H1992"\w* \w conocimiento|strong="H1847"\w*?   
\m
\v 23 \w Volveos|strong="H7725"\w* \w a|strong="H3068"\w* \w mi|strong="H2009"\w* \w reprensión|strong="H8433"\w*: He \w aquí|strong="H2009"\w*, \w yo|strong="H2009"\w* derramaré \w mi|strong="H2009"\w* \w espíritu|strong="H7307"\w* sobre vosotros, y os daré \w a|strong="H3068"\w* conocer mis \w palabras|strong="H1697"\w*.   
\m
\v 24 \w Porque|strong="H3282"\w* \w llamé|strong="H7121"\w*, y \w no|strong="H3985"\w* quisisteis \add oír\add*: \w Extendí|strong="H5186"\w* mi \w mano|strong="H3027"\w*, y \w no|strong="H3985"\w* hubo quien atendiese;   
\m
\v 25 antes desechasteis \w todo|strong="H3605"\w* \w consejo|strong="H6098"\w* mío, y mi \w reprensión|strong="H8433"\w* \w no|strong="H3808"\w* quisisteis:   
\m
\v 26 \w También|strong="H1571"\w* yo me reiré de vuestra calamidad; me burlaré \w cuando|strong="H1571"\w* os venga lo \w que|strong="H1571"\w* teméis;   
\m
\v 27 cuando venga cual destrucción \w lo|strong="H5921"\w* \w que|strong="H5921"\w* teméis, \w y|strong="H5921"\w* vuestra calamidad llegue \w como|strong="H5921"\w* un \w torbellino|strong="H5492"\w*; cuando \w sobre|strong="H5921"\w* vosotros venga \w tribulación|strong="H6869"\w* \w y|strong="H5921"\w* \w angustia|strong="H6869"\w*.   
\m
\v 28 Entonces me \w llamarán|strong="H7121"\w*, pero \w no|strong="H3808"\w* \w responderé|strong="H6030"\w*; me buscarán de mañana, y \w no|strong="H3808"\w* me hallarán;   
\m
\v 29 \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w aborrecieron|strong="H8130"\w* \w la|strong="H3588"\w* \w sabiduría|strong="H1847"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* escogieron \w el|strong="H3588"\w* \w temor|strong="H3374"\w* \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w*,   
\m
\v 30 \w ni|strong="H3808"\w* quisieron mi \w consejo|strong="H6098"\w*, y menospreciaron \w toda|strong="H3605"\w* \w reprensión|strong="H8433"\w* mía:   
\m
\v 31 \w Por|strong="H1870"\w* tanto comerán del \w fruto|strong="H6529"\w* \w de|strong="H7646"\w* su propio \w camino|strong="H1870"\w*, y se hastiarán \w de|strong="H7646"\w* sus propios \w consejos|strong="H4156"\w*.   
\m
\v 32 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* descarrío \w de|strong="H3588"\w* \w los|strong="H3588"\w* ignorantes \w los|strong="H3588"\w* \w matará|strong="H2026"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* prosperidad \w de|strong="H3588"\w* \w los|strong="H3588"\w* necios \w los|strong="H3588"\w* destruirá.   
\m
\v 33 Mas el \w que|strong="H6343"\w* me \w oyere|strong="H8085"\w* \w habitará|strong="H7931"\w* seguro, y vivirá tranquilo, sin \w temor|strong="H6343"\w* del \w mal|strong="H7451"\w*.   
\c 2
\m
\v 1 \w Hijo|strong="H1121"\w* mío, si recibieres mis palabras, y mis \w mandamientos|strong="H4687"\w* atesorares dentro \w de|strong="H1121"\w* ti,   
\m
\v 2 de manera que inclines tu oído \w a|strong="H3068"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*, y apliques tu \w corazón|strong="H3820"\w* al \w entendimiento|strong="H3820"\w*;   
\m
\v 3 \w si|strong="H3588"\w* \w clamares|strong="H7121"\w* al conocimiento, \w y|strong="H3588"\w* al \w entendimiento|strong="H8394"\w* alzares tu \w voz|strong="H6963"\w*;   
\m
\v 4 si como \w a|strong="H3068"\w* la \w plata|strong="H3701"\w* lo \w buscares|strong="H1245"\w*, y lo procurares como \w a|strong="H3068"\w* \w tesoros|strong="H4301"\w* escondidos;   
\m
\v 5 Entonces entenderás el \w temor|strong="H3374"\w* de \w Jehová|strong="H3068"\w*, y \w hallarás|strong="H4672"\w* el \w conocimiento|strong="H1847"\w* de \w Dios|strong="H3068"\w*.   
\m
\v 6 \w Porque|strong="H3588"\w* \w Jehová|strong="H3068"\w* \w da|strong="H5414"\w* \w la|strong="H3588"\w* \w sabiduría|strong="H2451"\w*, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w boca|strong="H6310"\w* \add viene\add* \w el|strong="H3588"\w* \w conocimiento|strong="H1847"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w entendimiento|strong="H8394"\w*.   
\m
\v 7 Él reserva la sana \w sabiduría|strong="H8454"\w* para los \w rectos|strong="H3477"\w*; es \w escudo|strong="H4043"\w* \w a|strong="H3068"\w* los que \w caminan|strong="H1980"\w* en rectitud.   
\m
\v 8 Él \w guarda|strong="H8104"\w* las sendas del \w juicio|strong="H4941"\w*, y preserva el \w camino|strong="H1870"\w* de sus \w santos|strong="H2623"\w*.   
\m
\v 9 Entonces entenderás \w justicia|strong="H6664"\w*, \w juicio|strong="H4941"\w* y equidad, y \w todo|strong="H3605"\w* \w buen|strong="H2896"\w* \w camino|strong="H4570"\w*.   
\m
\v 10 \w Cuando|strong="H3588"\w* \w la|strong="H3588"\w* \w sabiduría|strong="H2451"\w* entrare \w en|strong="H3588"\w* tu \w corazón|strong="H3820"\w*, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w conocimiento|strong="H1847"\w* fuere \w dulce|strong="H5276"\w* \w a|strong="H3068"\w* tu \w alma|strong="H5315"\w*,   
\m
\v 11 \w la|strong="H5921"\w* discreción \w te|strong="H5921"\w* \w guardará|strong="H8104"\w*, \w te|strong="H5921"\w* preservará \w el|strong="H5921"\w* \w entendimiento|strong="H8394"\w*,   
\m
\v 12 para librarte del \w camino|strong="H1870"\w* del \add hombre\add* \w malo|strong="H7451"\w*, del hombre que \w habla|strong="H1696"\w* \w cosas|strong="H7451"\w* perversas;   
\m
\v 13 Del que \w deja|strong="H5800"\w* las sendas \w derechas|strong="H3476"\w*, para \w andar|strong="H3212"\w* \w en|strong="H3212"\w* \w caminos|strong="H1870"\w* tenebrosos;   
\m
\v 14 que se alegra \w haciendo|strong="H6213"\w* \w el|strong="H6213"\w* \w mal|strong="H7451"\w*, que se deleita en las \w perversidades|strong="H8419"\w* del vicio;   
\m
\v 15 cuyas veredas son torcidas, y torcidos sus \w caminos|strong="H4570"\w*.   
\m
\v 16 Para librarte de la mujer \w extraña|strong="H5237"\w*, de la \w ajena|strong="H5237"\w* que halaga con sus palabras;   
\m
\v 17 que abandona al compañero \w de|strong="H7911"\w* su \w juventud|strong="H5271"\w*, y se olvida del \w pacto|strong="H1285"\w* \w de|strong="H7911"\w* su Dios.   
\m
\v 18 \w Por|strong="H3588"\w* lo \w cual|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w* está inclinada \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w*, \w y|strong="H3588"\w* sus veredas hacia \w los|strong="H3588"\w* \w muertos|strong="H7496"\w*.   
\m
\v 19 \w Ninguno|strong="H3808"\w* de \w los|strong="H3605"\w* \w que|strong="H3808"\w* \w a|strong="H3068"\w* \w ella|strong="H3605"\w* entraren \w volverán|strong="H7725"\w*, \w ni|strong="H3808"\w* \w tomarán|strong="H5381"\w* las sendas de \w la|strong="H3605"\w* \w vida|strong="H2416"\w*.   
\m
\v 20 \w Para|strong="H4616"\w* \w que|strong="H4616"\w* \w andes|strong="H3212"\w* \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* \w de|strong="H6662"\w* los \w buenos|strong="H2896"\w*, y \w guardes|strong="H8104"\w* las sendas \w de|strong="H6662"\w* los \w justos|strong="H6662"\w*.   
\m
\v 21 \w Porque|strong="H3588"\w* \w los|strong="H3588"\w* \w rectos|strong="H3477"\w* \w habitarán|strong="H7931"\w* \w la|strong="H3588"\w* tierra, \w y|strong="H3588"\w* \w los|strong="H3588"\w* perfectos \w permanecerán|strong="H3498"\w* \w en|strong="H8549"\w* ella;   
\m
\v 22 \w mas|strong="H4480"\w* los \w impíos|strong="H7563"\w* serán cortados \w de|strong="H4480"\w* la tierra, y los prevaricadores serán desarraigados \w de|strong="H4480"\w* \w ella|strong="H4480"\w*.   
\c 3
\m
\v 1 \w Hijo|strong="H1121"\w* mío, no te \w olvides|strong="H7911"\w* \w de|strong="H1121"\w* mi \w ley|strong="H8451"\w*, y tu \w corazón|strong="H3820"\w* \w guarde|strong="H5341"\w* mis \w mandamientos|strong="H4687"\w*;   
\m
\v 2 \w porque|strong="H3588"\w* largura \w de|strong="H3588"\w* \w días|strong="H3117"\w*, \w y|strong="H3588"\w* \w años|strong="H8141"\w* \w de|strong="H3588"\w* \w vida|strong="H2416"\w* \w y|strong="H3588"\w* \w paz|strong="H7965"\w* \w te|strong="H3588"\w* \w añadirán|strong="H3254"\w*.   
\m
\v 3 \w Misericordia|strong="H2617"\w* \w y|strong="H5921"\w* verdad \w no|strong="H5921"\w* \w se|strong="H5921"\w* aparten \w de|strong="H5921"\w* \w ti|strong="H5921"\w*; \w átalas|strong="H7194"\w* \w a|strong="H3068"\w* tu cuello, \w escríbelas|strong="H3789"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tabla \w de|strong="H5921"\w* tu \w corazón|strong="H3820"\w*;   
\m
\v 4 y \w hallarás|strong="H4672"\w* \w gracia|strong="H2580"\w* y \w buen|strong="H2896"\w* \w entendimiento|strong="H7922"\w* ante los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Dios y \w de|strong="H5869"\w* los hombres.   
\m
\v 5 Confía en \w Jehová|strong="H3068"\w* con \w todo|strong="H3605"\w* tu \w corazón|strong="H3820"\w*, y no te apoyes en tu propia prudencia.   
\m
\v 6 \w Reconócelo|strong="H3045"\w* en \w todos|strong="H3605"\w* tus \w caminos|strong="H1870"\w*, y \w Él|strong="H1931"\w* \w enderezará|strong="H3474"\w* tus sendas.   
\m
\v 7 \w No|strong="H1961"\w* \w seas|strong="H1961"\w* \w sabio|strong="H2450"\w* \w en|strong="H5493"\w* tu propia opinión: \w Teme|strong="H3372"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, y \w apártate|strong="H5493"\w* del \w mal|strong="H7451"\w*;   
\m
\v 8 Porque \w será|strong="H1961"\w* \w medicina|strong="H7500"\w* \w a|strong="H3068"\w* tu \w ombligo|strong="H8270"\w*, y tuétano \w a|strong="H3068"\w* tus \w huesos|strong="H6106"\w*.   
\m
\v 9 \w Honra|strong="H3513"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* con tu sustancia, y con las \w primicias|strong="H7225"\w* de \w todos|strong="H3605"\w* tus \w frutos|strong="H8393"\w*;   
\m
\v 10 y serán \w llenos|strong="H4390"\w* tus graneros con abundancia, y tus lagares \w rebosarán|strong="H6555"\w* de \w mosto|strong="H8492"\w*.   
\m
\v 11 \w Hijo|strong="H1121"\w* mío, no menosprecies, \w el|strong="H1121"\w* castigo \w de|strong="H1121"\w* \w Jehová|strong="H3068"\w*; ni te fatigues \w de|strong="H1121"\w* su \w corrección|strong="H4148"\w*;   
\m
\v 12 \w porque|strong="H3588"\w* \w Jehová|strong="H3068"\w* al \w que|strong="H3588"\w* ama \w corrige|strong="H3198"\w*, \w como|strong="H3588"\w* \w el|strong="H3588"\w* padre al \w hijo|strong="H1121"\w* \w en|strong="H3588"\w* quien se deleita.   
\m
\v 13 Bienaventurado el hombre que \w halla|strong="H4672"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*, y que obtiene \w la|strong="H2451"\w* \w inteligencia|strong="H8394"\w*;   
\m
\v 14 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* mercadería \add es\add* \w mejor|strong="H2896"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* mercadería \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w plata|strong="H3701"\w*, \w y|strong="H3588"\w* sus \w frutos|strong="H8393"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* oro fino.   
\m
\v 15 \w Es|strong="H1931"\w* \w más|strong="H3808"\w* \w preciosa|strong="H3368"\w* \w que|strong="H1931"\w* las piedras \w preciosas|strong="H3368"\w*; y \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* puedes desear, \w no|strong="H3808"\w* \w se|strong="H1931"\w* puede comparar \w a|strong="H3068"\w* \w ella|strong="H1931"\w*.   
\m
\v 16 Largura de \w días|strong="H3117"\w* está en su mano \w derecha|strong="H3225"\w*; en su \w izquierda|strong="H8040"\w* \w riquezas|strong="H6239"\w* \w y|strong="H3519"\w* \w honra|strong="H3519"\w*.   
\m
\v 17 Sus \w caminos|strong="H1870"\w* \add son\add* \w caminos|strong="H1870"\w* \w deleitosos|strong="H5278"\w*, y \w todas|strong="H3605"\w* sus sendas \add son\add* \w paz|strong="H7965"\w*.   
\m
\v 18 \w Ella|strong="H1931"\w* \add es\add* \w árbol|strong="H6086"\w* de \w vida|strong="H2416"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* abrazan, y bienaventurados son \w los|strong="H1931"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* retienen.   
\m
\v 19 \w Jehová|strong="H3068"\w* con \w sabiduría|strong="H2451"\w* \w fundó|strong="H3245"\w* \w la|strong="H2451"\w* tierra; con \w entendimiento|strong="H8394"\w* estableció los \w cielos|strong="H8064"\w*.   
\m
