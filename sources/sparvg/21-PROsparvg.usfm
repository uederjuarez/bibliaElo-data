\v 17 Los \w ojos|strong="H5869"\w* \w altivos|strong="H7311"\w*, la \w lengua|strong="H3956"\w* \w mentirosa|strong="H8267"\w*, \w y|strong="H5355"\w* las \w manos|strong="H3027"\w* \w que|strong="H3027"\w* derraman \w sangre|strong="H1818"\w* \w inocente|strong="H5355"\w*,   
