\v 6 \w Y|strong="H3068"\w* cuando \w la|strong="H5921"\w* \w abrió|strong="H6605"\w*, \w vio|strong="H7200"\w* \w al|strong="H5921"\w* \w niño|strong="H5288"\w*; \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w niño|strong="H5288"\w* \w lloraba|strong="H1058"\w*. \w Y|strong="H3068"\w* teniendo compasión \w de|strong="H5921"\w* \w él|strong="H5921"\w*, dijo: \w De|strong="H5921"\w* \w los|strong="H5921"\w* \w niños|strong="H5288"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w hebreos|strong="H5680"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w*.   
\m
\v 7 Entonces su hermana dijo \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* \w de|strong="H4480"\w* \w Faraón|strong="H6547"\w*: ¿\w Iré|strong="H3212"\w* \w a|strong="H3068"\w* llamarte \w a|strong="H3068"\w* una nodriza \w de|strong="H4480"\w* las \w hebreas|strong="H5680"\w*, \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w te|strong="H4480"\w* críe este niño?   
\m
\v 8 \w Y|strong="H3068"\w* la \w hija|strong="H1323"\w* de \w Faraón|strong="H6547"\w* respondió: \w Ve|strong="H3212"\w*. Entonces \w fue|strong="H3212"\w* la doncella, y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* la madre del niño;   
\m
\v 9 \w a|strong="H3068"\w* la cual dijo la \w hija|strong="H1323"\w* \w de|strong="H5414"\w* \w Faraón|strong="H6547"\w*: \w Lleva|strong="H3212"\w* \w este|strong="H2088"\w* niño, y críamelo, y yo te \w lo|strong="H2088"\w* \w pagaré|strong="H5414"\w*. \w Y|strong="H3068"\w* la mujer \w tomó|strong="H3947"\w* al niño, y \w lo|strong="H2088"\w* crió.   
\m
\v 10 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w creció|strong="H1431"\w* \w el|strong="H3588"\w* niño, \w ella|strong="H4480"\w* lo trajo \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H4480"\w* \w Faraón|strong="H6547"\w*, \w la|strong="H3588"\w* \w cual|strong="H3588"\w* lo prohijó, \w y|strong="H3588"\w* le puso \w por|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Moisés|strong="H4872"\w*, diciendo: \w Porque|strong="H3588"\w* \w de|strong="H4480"\w* las \w aguas|strong="H4325"\w* lo saqué.   
\m
\v 11 \w Y|strong="H3068"\w* \w en|strong="H3318"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3117"\w*, \w crecido|strong="H1431"\w* ya \w Moisés|strong="H4872"\w*, \w salió|strong="H3318"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanos, y \w vio|strong="H7200"\w* \w sus|strong="H1992"\w* cargas: y \w vio|strong="H7200"\w* \w a|strong="H3068"\w* un \w egipcio|strong="H4713"\w* \w que|strong="H3117"\w* \w hería|strong="H5221"\w* \w a|strong="H3068"\w* uno de \w los|strong="H1992"\w* \w hebreos|strong="H5680"\w*, \w sus|strong="H1992"\w* hermanos.   
\m
\v 12 \w Y|strong="H3068"\w* \w miró|strong="H7200"\w* \w a|strong="H3068"\w* todas partes, \w y|strong="H3588"\w* \w viendo|strong="H7200"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* parecía nadie, \w mató|strong="H5221"\w* al \w egipcio|strong="H4713"\w*, \w y|strong="H3588"\w* lo \w escondió|strong="H2934"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* arena.   
\m
\v 13 \w Y|strong="H3068"\w* \w salió|strong="H3318"\w* al \w día|strong="H3117"\w* \w siguiente|strong="H8145"\w*, y viendo \w a|strong="H3068"\w* \w dos|strong="H8147"\w* \w hebreos|strong="H5680"\w* \w que|strong="H4100"\w* reñían, dijo al \w que|strong="H4100"\w* hacía la injuria: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* hieres \w a|strong="H3068"\w* tu \w prójimo|strong="H7453"\w*?   
\m
\v 14 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* respondió: ¿\w Quién|strong="H4310"\w* \w te|strong="H5921"\w* ha puesto \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w por|strong="H5921"\w* \w príncipe|strong="H8269"\w* \w y|strong="H5921"\w* \w juez|strong="H8199"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*? ¿Piensas \w matarme|strong="H2026"\w* \w como|strong="H5921"\w* \w mataste|strong="H2026"\w* \w al|strong="H5921"\w* \w egipcio|strong="H4713"\w*? Entonces \w Moisés|strong="H4872"\w* \w tuvo|strong="H3372"\w* \w miedo|strong="H3372"\w*, \w y|strong="H5921"\w* dijo: Ciertamente \w esta|strong="H5921"\w* \w cosa|strong="H1697"\w* \w es|strong="H1697"\w* descubierta.   
\m
\v 15 \w Y|strong="H3068"\w* cuando \w Faraón|strong="H6547"\w* \w escuchó|strong="H8085"\w* \w esto|strong="H2088"\w*, \w procuró|strong="H1245"\w* matar \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*; pero \w Moisés|strong="H4872"\w* \w huyó|strong="H1272"\w* \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H5921"\w* \w habitó|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*; \w y|strong="H5921"\w* \w se|strong="H5921"\w* sentó \w junto|strong="H5921"\w* \w a|strong="H3068"\w* un pozo.   
\m
\v 16 \w Y|strong="H3068"\w* el \w sacerdote|strong="H3548"\w* de \w Madián|strong="H4080"\w* tenía \w siete|strong="H7651"\w* \w hijas|strong="H1323"\w*, las cuales vinieron \w a|strong="H3068"\w* sacar \add agua\add*, para llenar las pilas y dar de \w beber|strong="H8248"\w* al \w rebaño|strong="H6629"\w* de su padre.   
\m
\v 17 Mas los \w pastores|strong="H7462"\w* vinieron, y las echaron: Entonces \w Moisés|strong="H4872"\w* se \w levantó|strong="H6965"\w* y las defendió, y abrevó su \w rebaño|strong="H6629"\w*.   
\m
\v 18 \w Y|strong="H3068"\w* volviendo ellas \w a|strong="H3068"\w* \w Reuel|strong="H7467"\w* su padre, les dijo él: ¿\w Por|strong="H4069"\w* \w qué|strong="H3117"\w* habéis venido \w hoy|strong="H3117"\w* tan \w pronto|strong="H4116"\w*?   
