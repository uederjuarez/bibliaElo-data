\v 8 Entretanto, \w se|strong="H3045"\w* \w levantó|strong="H6965"\w* un \w nuevo|strong="H2319"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w conocía|strong="H3045"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*,   
\m
\v 9 y dijo \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*: He \w aquí|strong="H2009"\w*, \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* es \w más|strong="H4480"\w* \w grande|strong="H7227"\w* y \w más|strong="H4480"\w* \w fuerte|strong="H6099"\w* \w que|strong="H4480"\w* nosotros:   
\m
\v 10 Ahora, \w pues|strong="H3588"\w*, \w seamos|strong="H1961"\w* sabios \w para|strong="H5921"\w* \w con|strong="H5921"\w* \w él|strong="H1931"\w*, \w no|strong="H6435"\w* \w sea|strong="H1961"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* multiplique, \w y|strong="H1571"\w* acontezca \w que|strong="H3588"\w* \w viniendo|strong="H1961"\w* \w guerra|strong="H4421"\w*, \w él|strong="H1931"\w* \w también|strong="H1571"\w* \w se|strong="H1961"\w* una \w con|strong="H5921"\w* nuestros \w enemigos|strong="H8130"\w*, \w y|strong="H1571"\w* pelee \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w y|strong="H1571"\w* \w se|strong="H1961"\w* \w vaya|strong="H5927"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* tierra.   
