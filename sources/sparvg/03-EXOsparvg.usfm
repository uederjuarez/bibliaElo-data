\v 5 \w Y|strong="H3068"\w* \w todas|strong="H3605"\w* las \w almas|strong="H5315"\w* de \w los|strong="H3605"\w* \w que|strong="H1961"\w* \w salieron|strong="H3318"\w* de \w los|strong="H3605"\w* lomos de \w Jacob|strong="H3290"\w*, \w fueron|strong="H1961"\w* \w setenta|strong="H7657"\w*. \w Y|strong="H3068"\w* \w José|strong="H3130"\w* \w estaba|strong="H1961"\w* \w en|strong="H3318"\w* \w Egipto|strong="H4714"\w*.   
