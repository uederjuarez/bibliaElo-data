\v 5 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w descendió|strong="H3381"\w* \w a|strong="H3068"\w* lavarse \w al|strong="H5921"\w* \w río|strong="H2975"\w*, \w y|strong="H5921"\w* paseándose sus \w doncellas|strong="H5291"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* ribera \w del|strong="H5921"\w* \w río|strong="H2975"\w*, \w vio|strong="H7200"\w* \w ella|strong="H5921"\w* \w la|strong="H5921"\w* arquilla \w en|strong="H5921"\w* \w el|strong="H5921"\w* carrizal, \w y|strong="H5921"\w* \w envió|strong="H7971"\w* una criada suya \w a|strong="H3068"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w tomase|strong="H3947"\w*.   
