\v 26 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* alguno \w hiriere|strong="H5221"\w* \w el|strong="H3588"\w* \w ojo|strong="H5869"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w siervo|strong="H5650"\w*, \w o|strong="H3068"\w* \w el|strong="H3588"\w* \w ojo|strong="H5869"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* sierva, \w y|strong="H3588"\w* lo dañare, \w le|strong="H5869"\w* dará \w libertad|strong="H2670"\w* \w por|strong="H3588"\w* razón \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w ojo|strong="H5869"\w*.   
