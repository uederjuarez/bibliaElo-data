\m
\v 29 Pero \w si|strong="H1571"\w* \w el|strong="H1931"\w* \w buey|strong="H7794"\w* \w ya|strong="H1571"\w* había acorneado en \w el|strong="H1931"\w* pasado, \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w dueño|strong="H1167"\w* \w se|strong="H1931"\w* \w le|strong="H1931"\w* había amonestado \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w lo|strong="H1931"\w* había \w guardado|strong="H8104"\w*, \w y|strong="H1571"\w* \w matare|strong="H4191"\w* \w a|strong="H3068"\w* un hombre \w o|strong="H3068"\w* \w a|strong="H3068"\w* una mujer, \w el|strong="H1931"\w* \w buey|strong="H7794"\w* \w será|strong="H1931"\w* \w apedreado|strong="H5619"\w*, \w y|strong="H1571"\w* \w su|strong="H1931"\w* \w dueño|strong="H1167"\w* \w también|strong="H1571"\w* \w morirá|strong="H4191"\w*.   
\m
\v 30 \w Si|strong="H5921"\w* \w le|strong="H5921"\w* fuere impuesto \w rescate|strong="H3724"\w*, entonces \w dará|strong="H5414"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w rescate|strong="H3724"\w* \w de|strong="H5921"\w* su \w vida|strong="H5315"\w* \w cuanto|strong="H5921"\w* \w le|strong="H5921"\w* fuere impuesto.   
