\v 32 Si el \w buey|strong="H7794"\w* \w acorneare|strong="H5055"\w* \w a|strong="H3068"\w* un \w siervo|strong="H5650"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* una sierva, \add el dueño\add* \w pagará|strong="H5414"\w* \w treinta|strong="H7970"\w* \w siclos|strong="H8255"\w* \w de|strong="H5414"\w* \w plata|strong="H3701"\w* \w a|strong="H3068"\w* su señor, \w y|strong="H7794"\w* el \w buey|strong="H7794"\w* \w será|strong="H5619"\w* \w apedreado|strong="H5619"\w*.   
\m
\v 33 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w alguno|strong="H5307"\w* \w abriere|strong="H6605"\w* hoyo, \w o|strong="H3068"\w* \w cavare|strong="H3738"\w* cisterna, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w la|strong="H3588"\w* cubriere, \w y|strong="H3588"\w* \w cayere|strong="H5307"\w* \w allí|strong="H8033"\w* \w buey|strong="H7794"\w* \w o|strong="H3068"\w* \w asno|strong="H2543"\w*,   
\m
\v 34 el \w dueño|strong="H1167"\w* de la cisterna \w pagará|strong="H7999"\w* el \w dinero|strong="H3701"\w*, \w resarciendo|strong="H7725"\w* \w a|strong="H3068"\w* su \w dueño|strong="H1167"\w*, y lo \w que|strong="H1961"\w* \w fue|strong="H1961"\w* \w muerto|strong="H4191"\w* \w será|strong="H1961"\w* suyo.   
\m
\v 35 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w el|strong="H3588"\w* \w buey|strong="H7794"\w* \w de|strong="H3588"\w* uno hiere al \w de|strong="H3588"\w* \w otro|strong="H7453"\w*, \w y|strong="H1571"\w* este muere, \w entonces|strong="H3588"\w* \w venderán|strong="H4376"\w* \w el|strong="H3588"\w* \w buey|strong="H7794"\w* \w vivo|strong="H2416"\w*, \w y|strong="H1571"\w* dividirán \w el|strong="H3588"\w* \w dinero|strong="H3701"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* dividirán \w el|strong="H3588"\w* \add buey\add* \w muerto|strong="H4191"\w*.   
\m
\v 36 \w Mas|strong="H3588"\w* \w si|strong="H3588"\w* \w era|strong="H1961"\w* notorio \w que|strong="H3588"\w* \w el|strong="H1931"\w* \w buey|strong="H7794"\w* \w era|strong="H1961"\w* acorneador \w en|strong="H3588"\w* tiempo pasado, \w y|strong="H3588"\w* \w su|strong="H1931"\w* \w dueño|strong="H1167"\w* \w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w había|strong="H1961"\w* \w guardado|strong="H8104"\w*, \w pagará|strong="H7999"\w* \w buey|strong="H7794"\w* \w por|strong="H3588"\w* \w buey|strong="H7794"\w*, \w y|strong="H3588"\w* \w el|strong="H1931"\w* \w muerto|strong="H4191"\w* \w será|strong="H1961"\w* \w suyo|strong="H1931"\w*.   
\c 22
\m
\v 1 Si alguno hurtare un buey \w o|strong="H3068"\w* \w una|strong="H4672"\w* oveja, y lo \w matare|strong="H4191"\w* \w o|strong="H3068"\w* lo vendiere, por el buey pagará cinco bueyes, y por la oveja, cuatro ovejas.   
\m
\v 2 \w Si|strong="H5921"\w* un ladrón fuere sorprendido forzando una casa, \w y|strong="H5921"\w* fuere herido \w y|strong="H5921"\w* muriere, \w no|strong="H5921"\w* \add se derramará\add* \w sangre|strong="H1818"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w*.   
\m
\v 3 \w Y|strong="H3068"\w* si el sol ya \w había|strong="H4672"\w* salido sobre él; se \add derramará\add* sangre \w por|strong="H5704"\w* él; porque él debe hacer \w una|strong="H4672"\w* completa restitución; si no tuviere \w con|strong="H5704"\w* \w qué|strong="H5704"\w*, será vendido \w por|strong="H5704"\w* su hurto.   
\m
\v 4 \w Si|strong="H3588"\w* \w el|strong="H3588"\w* hurto fuere hallado vivo \w en|strong="H3588"\w* \w su|strong="H3588"\w* mano, ya sea buey, asno u oveja, \w pagará|strong="H7999"\w* \w el|strong="H3588"\w* doble.   
\m
\v 5 \w Si|strong="H3588"\w* alguno hiciere pastar \w campo|strong="H7704"\w* \w o|strong="H3068"\w* viña, \w y|strong="H3588"\w* metiere \w su|strong="H3588"\w* bestia, \w y|strong="H3588"\w* comiere \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* otro, \w pagará|strong="H7999"\w* restitución \w de|strong="H3588"\w* lo mejor \w de|strong="H3588"\w* \w su|strong="H3588"\w* propia tierra \w y|strong="H3588"\w* \w de|strong="H3588"\w* lo mejor \w de|strong="H3588"\w* \w su|strong="H3588"\w* propia viña.   
\m
\v 6 \w Cuando|strong="H3588"\w* un fuego se extendiere \w y|strong="H3588"\w* tomare espinas, \w y|strong="H3588"\w* quemare gavillas amontonadas, \w o|strong="H3068"\w* \w en|strong="H3588"\w* pie, \w o|strong="H3068"\w* campo, \w el|strong="H3588"\w* \w que|strong="H3588"\w* encendió \w el|strong="H3588"\w* fuego \w pagará|strong="H7999"\w* lo quemado.   
\m
\v 7 Cuando alguno diere \w a|strong="H3068"\w* su \w prójimo|strong="H7453"\w* plata \w o|strong="H3068"\w* alhajas \w a|strong="H3068"\w* guardar, y \w fuere|strong="H4672"\w* hurtado de la \w casa|strong="H1004"\w* de aquel hombre, \w si|strong="H3808"\w* el \w ladrón|strong="H1590"\w* \w se|strong="H3808"\w* \w hallare|strong="H4672"\w*, pagará el doble.   
\m
\v 8 \w Si|strong="H3588"\w* \w el|strong="H1931"\w* ladrón \w no|strong="H3588"\w* \w se|strong="H1931"\w* hallare, \w entonces|strong="H3588"\w* \w el|strong="H1931"\w* dueño \w de|strong="H5921"\w* \w la|strong="H1931"\w* casa \w será|strong="H1931"\w* presentado \w a|strong="H3068"\w* \w los|strong="H5921"\w* jueces, \w para|strong="H5704"\w* ver \w si|strong="H3588"\w* ha metido \w su|strong="H1931"\w* \w mano|strong="H1931"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* bienes \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w prójimo|strong="H7453"\w*.   
\m
\v 9 Sobre \w todo|strong="H3605"\w* asunto \w de|strong="H3588"\w* fraude, sobre \w buey|strong="H7794"\w*, sobre \w asno|strong="H2543"\w*, sobre \w oveja|strong="H7716"\w*, sobre vestido \w o|strong="H3068"\w* sobre \w cualquier|strong="H3605"\w* \w cosa|strong="H3605"\w* perdida, \w cuando|strong="H3588"\w* uno dijere: Esto \w es|strong="H3588"\w* mío, \w la|strong="H3588"\w* causa \w de|strong="H3588"\w* ambos \w será|strong="H7665"\w* traída ante \w los|strong="H3605"\w* jueces; \w y|strong="H3588"\w* \w aquel|strong="H3605"\w* \w a|strong="H3068"\w* \w quien|strong="H3605"\w* \w los|strong="H3605"\w* jueces condenaren, \w pagará|strong="H5414"\w* \w el|strong="H3588"\w* doble \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w prójimo|strong="H7453"\w*.   
\m
\v 10 \w Si|strong="H3808"\w* alguno \w hubiere|strong="H1961"\w* dado \w a|strong="H3068"\w* su \w prójimo|strong="H7453"\w* asno, \w o|strong="H3068"\w* buey, u oveja, \w o|strong="H3068"\w* cualquier \w otro|strong="H7453"\w* animal \w a|strong="H3068"\w* guardar, y \w se|strong="H1961"\w* muriere \w o|strong="H3068"\w* \w se|strong="H1961"\w* perniquebrare, \w o|strong="H3068"\w* \w fuere|strong="H1961"\w* llevado \w sin|strong="H3808"\w* verlo \w nadie|strong="H3808"\w*;   
\m
\v 11 \add Entonces\add* un juramento \w de|strong="H5973"\w* Jehová tendrá lugar \w entre|strong="H5973"\w* ambos \w de|strong="H5973"\w* que no echó su mano \w a|strong="H3068"\w* \w los|strong="H1167"\w* bienes \w de|strong="H5973"\w* su prójimo; y su \w dueño|strong="H1167"\w* lo aceptará, y \w el|strong="H5973"\w* otro no \w pagará|strong="H7999"\w*.   
\m
\v 12 \w Mas|strong="H3808"\w* \w si|strong="H3808"\w* le hubiere sido hurtado, \w resarcirá|strong="H7999"\w* \w a|strong="H3068"\w* su dueño.   
\m
\v 13 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w le|strong="H5973"\w* hubiere sido arrebatado \w por|strong="H3588"\w* fiera, \w le|strong="H5973"\w* traerá testimonio, \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w pagará|strong="H7999"\w* lo arrebatado.   
\m
\v 14 Pero \w si|strong="H3808"\w* alguno hubiere tomado prestada bestia \w de|strong="H5973"\w* \w su|strong="H1931"\w* prójimo, y fuere estropeada \w o|strong="H3068"\w* muerta, ausente \w su|strong="H1931"\w* \w dueño|strong="H1167"\w*, \w deberá|strong="H7999"\w* pagarla.   
\m
\v 15 \w Si|strong="H3588"\w* \w el|strong="H5973"\w* dueño \w estaba|strong="H7901"\w* presente, \w no|strong="H3808"\w* \w la|strong="H3588"\w* pagará. \w Si|strong="H3588"\w* era alquilada, \w él|strong="H5973"\w* vendrá \w por|strong="H3588"\w* \w su|strong="H3588"\w* alquiler.   
\m
\v 16 \w Y|strong="H3068"\w* si alguno engañare \w a|strong="H3068"\w* alguna doncella que \w no|strong="H3985"\w* fuere desposada, y se acostare con ella, deberá dotarla y tomarla \w por|strong="H5414"\w* esposa.   
\m
\v 17 \w Si|strong="H3808"\w* su padre \w no|strong="H3808"\w* quisiere dársela, él le pesará plata conforme \w a|strong="H3068"\w* la dote de las vírgenes.   
\m
\v 18 \w A|strong="H3068"\w* \w la|strong="H3605"\w* hechicera no dejarás \w que|strong="H3605"\w* viva.   
\m
\v 19 Cualquiera \w que|strong="H1115"\w* tuviere ayuntamiento con bestia, morirá.   
\m
\v 20 \w El|strong="H3588"\w* \w que|strong="H3588"\w* sacrificare \w a|strong="H3068"\w* \add cualquier\add* dios, excepto \w a|strong="H3068"\w* sólo Jehová, \w será|strong="H1961"\w* muerto.   
\m
\v 21 \w Y|strong="H3068"\w* al extranjero \w no|strong="H3808"\w* engañarás, \w ni|strong="H3808"\w* oprimirás, \w porque|strong="H3808"\w* extranjeros fuisteis vosotros en \w la|strong="H3605"\w* tierra de Egipto.   
\m
\v 22 \w A|strong="H3068"\w* ninguna viuda ni huérfano \w afligiréis|strong="H6031"\w*.   
\m
\v 23 \w Que|strong="H1121"\w* \w si|strong="H1961"\w* tú llegas \w a|strong="H3068"\w* afligirles, y ellos clamaren \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, ciertamente oiré yo su clamor;   
\m
\v 24 \w y|strong="H5921"\w* \w se|strong="H1961"\w* encenderá \w mi|strong="H5921"\w* ira \w y|strong="H5921"\w* \w os|strong="H5921"\w* mataré \w a|strong="H3068"\w* espada, \w y|strong="H5921"\w* vuestras esposas quedarán viudas \w y|strong="H5921"\w* huérfanos vuestros hijos.   
\m
\v 25 Si prestares dinero \w a|strong="H3068"\w* algún pobre \w de|strong="H5704"\w* los \w de|strong="H5704"\w* mi pueblo \w que|strong="H5704"\w* está contigo, no serás usurero \w para|strong="H5704"\w* \w con|strong="H5704"\w* él; no le impondrás usura.   
\m
\v 26 \w Si|strong="H3588"\w* tomares \w en|strong="H3588"\w* prenda \w la|strong="H1931"\w* vestidura \w de|strong="H3588"\w* tu prójimo, \w a|strong="H3068"\w* \w la|strong="H1931"\w* puesta del sol \w se|strong="H1961"\w* \w la|strong="H1931"\w* devolverás:   
\m
\v 27 \w Porque|strong="H3808"\w* sólo aquella es su cubierta, es la vestidura \w para|strong="H5971"\w* cubrir su piel. ¿En \w qué|strong="H3808"\w* dormirá? \w Y|strong="H3068"\w* \w será|strong="H3808"\w* \w que|strong="H3808"\w* cuando él \w a|strong="H3068"\w* mí clamare, yo entonces le oiré, \w porque|strong="H3808"\w* soy misericordioso.   
\m
\v 28 \w No|strong="H3808"\w* injuriarás \w a|strong="H3068"\w* \w los|strong="H1121"\w* jueces, \w ni|strong="H3808"\w* maldecirás al príncipe \w de|strong="H1121"\w* tu pueblo.   
\m
\v 29 \w No|strong="H6213"\w* demorarás \add en dar\add* la primicia \w de|strong="H5973"\w* \w tu|strong="H6213"\w* cosecha, \w ni|strong="H5973"\w* \w de|strong="H5973"\w* \w tu|strong="H6213"\w* lagar. \w Me|strong="H5973"\w* \w darás|strong="H5414"\w* \w el|strong="H5973"\w* primogénito \w de|strong="H5973"\w* tus hijos.   
\m
\v 30 Así harás con el de tu buey y de tu oveja; siete días \w estará|strong="H1961"\w* con su madre, y al octavo día me \w lo|strong="H3808"\w* darás.   
\m
\v 31 \w Y|strong="H3068"\w* habéis de serme varones santos: y no comeréis carne arrebatada de las fieras en el campo; \w a|strong="H3068"\w* los perros la echaréis.   
\c 23
\m
\v 1 \w No|strong="H3808"\w* \w admitirás|strong="H5375"\w* \w falso|strong="H7723"\w* \w rumor|strong="H8088"\w*. \w No|strong="H3808"\w* \w te|strong="H5973"\w* concertarás \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w impío|strong="H7563"\w* \w para|strong="H1961"\w* ser \w testigo|strong="H5707"\w* \w falso|strong="H7723"\w*.   
\m
\v 2 \w No|strong="H3808"\w* \w seguirás|strong="H1961"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w muchos|strong="H7227"\w* \w para|strong="H5921"\w* hacer \w el|strong="H5921"\w* \w mal|strong="H7451"\w*; \w ni|strong="H3808"\w* \w responderás|strong="H6030"\w* \w en|strong="H5921"\w* \w litigio|strong="H7379"\w* inclinándote \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w más|strong="H5921"\w* \w para|strong="H5921"\w* torcer \w el|strong="H5921"\w* \add juicio\add*;   
\m
\v 3 \w ni|strong="H3808"\w* al \w pobre|strong="H1800"\w* \w distinguirás|strong="H1921"\w* en su \w causa|strong="H7379"\w*.   
\m
\v 4 \w Si|strong="H3588"\w* \w encontrares|strong="H6293"\w* \w extraviado|strong="H8582"\w* \w el|strong="H3588"\w* \w buey|strong="H7794"\w* \w de|strong="H3588"\w* tu enemigo \w o|strong="H3068"\w* \w su|strong="H3588"\w* \w asno|strong="H2543"\w*, \w vuelve|strong="H7725"\w* \w a|strong="H3068"\w* llevárselo.   
\m
\v 5 \w Si|strong="H3588"\w* \w vieres|strong="H7200"\w* \w el|strong="H5973"\w* \w asno|strong="H2543"\w* \w del|strong="H5973"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* \w aborrece|strong="H8130"\w* \w caído|strong="H7257"\w* \w debajo|strong="H8478"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w carga|strong="H4853"\w*, ¿\w le|strong="H5973"\w* \w dejarás|strong="H5800"\w* \w entonces|strong="H3588"\w* \w desamparado|strong="H5800"\w*? Sin \w falta|strong="H2308"\w* \w le|strong="H5973"\w* \w ayudarás|strong="H5800"\w* \w a|strong="H3068"\w* levantarlo.   
\m
\v 6 \w No|strong="H3808"\w* \w pervertirás|strong="H5186"\w* el \w derecho|strong="H4941"\w* de tu pobre en su \w pleito|strong="H7379"\w*.   
\m
