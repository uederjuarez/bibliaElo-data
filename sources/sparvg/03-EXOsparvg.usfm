\v 13 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w egipcios|strong="H4713"\w* hicieron \w servir|strong="H5647"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* con dureza;   
