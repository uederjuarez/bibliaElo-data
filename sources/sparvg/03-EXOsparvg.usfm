\v 7 \w Y|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w envió|strong="H7971"\w*, \w y|strong="H5704"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* del \w ganado|strong="H4735"\w* \w de|strong="H5704"\w* los hijos \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* había \w muerto|strong="H4191"\w* uno. \w Mas|strong="H4191"\w* el \w corazón|strong="H3820"\w* \w de|strong="H5704"\w* \w Faraón|strong="H6547"\w* \w se|strong="H3808"\w* endureció, \w y|strong="H5704"\w* \w no|strong="H3808"\w* \w dejó|strong="H7971"\w* \w ir|strong="H7971"\w* \w al|strong="H5704"\w* \w pueblo|strong="H5971"\w*.   
