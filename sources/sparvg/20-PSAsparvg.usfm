\v 3 \w No|strong="H7563"\w* \w me|strong="H5973"\w* arrebates \w a|strong="H3068"\w* una \w con|strong="H5973"\w* \w los|strong="H5973"\w* \w malos|strong="H7451"\w*, y \w con|strong="H5973"\w* \w los|strong="H5973"\w* obradores \w de|strong="H5973"\w* iniquidad; \w los|strong="H5973"\w* cuales \w hablan|strong="H1696"\w* \w paz|strong="H7965"\w* \w con|strong="H5973"\w* su \w prójimo|strong="H7453"\w*, pero la \w maldad|strong="H7451"\w* \add está\add* \w en|strong="H5973"\w* su \w corazón|strong="H3824"\w*.   
\m
\v 4 \w Dales|strong="H5414"\w* conforme \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w obras|strong="H4639"\w*, y conforme \w a|strong="H3068"\w* la \w maldad|strong="H7455"\w* \w de|strong="H5414"\w* \w sus|strong="H1992"\w* \w hechos|strong="H4611"\w*: \w Dales|strong="H5414"\w* conforme \w a|strong="H3068"\w* la \w obra|strong="H4639"\w* \w de|strong="H5414"\w* \w sus|strong="H1992"\w* \w manos|strong="H3027"\w*, \w dales|strong="H5414"\w* \w su|strong="H1992"\w* paga.   
\m
\v 5 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* atienden \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w hechos|strong="H4639"\w* \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* sus \w manos|strong="H3027"\w*, \w Él|strong="H3588"\w* \w los|strong="H3588"\w* destruirá, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H3588"\w* \w edificará|strong="H1129"\w*.   
\m
\v 6 \w Bendito|strong="H1288"\w* \add sea\add* \w Jehová|strong="H3068"\w*, \w que|strong="H3588"\w* \w oyó|strong="H8085"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* mis súplicas.   
\m
\v 7 \w Jehová|strong="H3068"\w* \add es\add* mi \w fortaleza|strong="H5797"\w* \w y|strong="H5797"\w* mi \w escudo|strong="H4043"\w*: En Él confió mi \w corazón|strong="H3820"\w*, \w y|strong="H5797"\w* fui ayudado; por tanto, en gran manera se regocija mi \w corazón|strong="H3820"\w*, \w y|strong="H5797"\w* con mi \w canción|strong="H7892"\w* le \w alabaré|strong="H3034"\w*.   
\m
\v 8 \w Jehová|strong="H3068"\w* \add es\add* \w la|strong="H1931"\w* \w fortaleza|strong="H5797"\w* de \add su pueblo\add*, \w y|strong="H5797"\w* \w la|strong="H1931"\w* fuerza salvadora de \w su|strong="H1931"\w* \w ungido|strong="H4899"\w*.   
\m
\v 9 \w Salva|strong="H3467"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*, \w y|strong="H5704"\w* \w bendice|strong="H1288"\w* \w a|strong="H3068"\w* tu \w heredad|strong="H5159"\w*; pastoréalos \w y|strong="H5704"\w* enaltécelos \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.   
\c 29
\d Salmo de David  
\m
\v 1 \w Dad|strong="H3051"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \w oh|strong="H1121"\w* poderosos, \w dad|strong="H3051"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* la \w gloria|strong="H3519"\w* \w y|strong="H3519"\w* la \w fortaleza|strong="H5797"\w*.   
\m
\v 2 \w Dad|strong="H3051"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* la \w gloria|strong="H3519"\w* debida \w a|strong="H3068"\w* su \w nombre|strong="H8034"\w*: Adorad \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* en la hermosura \w de|strong="H1927"\w* la \w santidad|strong="H6944"\w*.   
\m
\v 3 \w La|strong="H5921"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* \w Jehová|strong="H3068"\w* \add está\add* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*; truena \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w gloria|strong="H3519"\w*; \w Jehová|strong="H3068"\w* \add está\add* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*.   
\m
\v 4 La \w voz|strong="H6963"\w* de \w Jehová|strong="H3068"\w* \add es\add* poderosa; la \w voz|strong="H6963"\w* de \w Jehová|strong="H3068"\w* \add es\add* majestuosa.   
\m
\v 5 La \w voz|strong="H6963"\w* de \w Jehová|strong="H3068"\w* quiebra los cedros; quiebra \w Jehová|strong="H3068"\w* los cedros del \w Líbano|strong="H3844"\w*.   
\m
\v 6 \w Los|strong="H1121"\w* hace saltar \w como|strong="H3644"\w* \w becerros|strong="H5695"\w*; al \w Líbano|strong="H3844"\w* y al \w Sirión|strong="H8303"\w* \w como|strong="H3644"\w* cría \w de|strong="H1121"\w* \w unicornio|strong="H7214"\w*.   
\m
\v 7 La \w voz|strong="H6963"\w* de \w Jehová|strong="H3068"\w* derrama \w llamas|strong="H3852"\w* de fuego.   
\m
\v 8 La \w voz|strong="H6963"\w* de \w Jehová|strong="H3068"\w* hace temblar el \w desierto|strong="H4057"\w*; \w Jehová|strong="H3068"\w* hace temblar el \w desierto|strong="H4057"\w* de \w Cades|strong="H6946"\w*.   
\m
\v 9 \w La|strong="H3605"\w* \w voz|strong="H6963"\w* de \w Jehová|strong="H3068"\w* hace parir \w a|strong="H3068"\w* las ciervas, \w y|strong="H3519"\w* descubre \w los|strong="H3605"\w* bosques; \w y|strong="H3519"\w* en su \w templo|strong="H1964"\w* \w todos|strong="H3605"\w* hablan de \add su\add* \w gloria|strong="H3519"\w*.   
\m
\v 10 \w Jehová|strong="H3068"\w* \w preside|strong="H3427"\w* en \w el|strong="H3427"\w* \w diluvio|strong="H3999"\w*; y se sienta \w Jehová|strong="H3068"\w* como \w Rey|strong="H4428"\w* para \w siempre|strong="H5769"\w*.   
\m
\v 11 \w Jehová|strong="H3068"\w* \w dará|strong="H5414"\w* \w fortaleza|strong="H5797"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*: \w Jehová|strong="H3068"\w* \w bendecirá|strong="H1288"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* en \w paz|strong="H7965"\w*.   
\c 30
\d Salmo cantado en la dedicación de la casa de David  
\m
\v 1 Te exaltaré, oh Jehová; \w porque|strong="H1732"\w* me has levantado, y no permitiste que mis enemigos se alegraran sobre mí.   
\m
\v 2 Oh \w Jehová|strong="H3068"\w* \w Dios|strong="H3068"\w* mío, \w a|strong="H3068"\w* ti clamé, \w y|strong="H3588"\w* tú \w me|strong="H3588"\w* sanaste.   
\m
\v 3 Oh \w Jehová|strong="H3068"\w*, hiciste subir mi alma del sepulcro; me diste vida, para que no descendiese \w a|strong="H3068"\w* la fosa.   
\m
\v 4 Cantad \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, vosotros sus santos, y dad gracias \w a|strong="H3068"\w* la memoria \w de|strong="H4480"\w* su santidad.   
\m
\v 5 Porque por un momento \add durará\add* su furor; \add mas\add* en su voluntad \add está\add* la vida: Por la noche durará el lloro, pero \w a|strong="H3068"\w* la mañana \add vendrá\add* la alegría.   
\m
\v 6 \w Y|strong="H3068"\w* dije \w yo|strong="H3588"\w* \w en|strong="H3588"\w* mi prosperidad: \w No|strong="H3588"\w* seré movido jamás;   
\m
\v 7 Jehová, \w por|strong="H5769"\w* tu favor has hecho que mi montaña permanezca fuerte. Escondiste tu rostro, y fui conturbado.   
\m
\v 8 \w A|strong="H3068"\w* ti clamé, oh \w Jehová|strong="H3068"\w*; \w y|strong="H5797"\w* \w a|strong="H3068"\w* ti \w Jehová|strong="H3068"\w* he suplicado.   
\m
\v 9 ¿Qué provecho hay en mi sangre, cuando yo descienda al sepulcro? ¿Te alabará el polvo? ¿Anunciará tu verdad?   
\m
\v 10 Oye, \w oh|strong="H4100"\w* Jehová, y ten misericordia \w de|strong="H1818"\w* mí: Jehová, \w sé|strong="H4100"\w* tú mi ayudador.   
\m
\v 11 Has cambiado \w mi|strong="H1961"\w* lamento en danza; desataste \w mi|strong="H1961"\w* cilicio, y me ceñiste de alegría.   
\m
\v 12 Por tanto \w a|strong="H3068"\w* ti cantaré, gloria mía, y no estaré callado. Oh Jehová Dios mío, te daré gracias por siempre.   
\c 31
\d Al Músico principal: Salmo de David  
\m
\v 1 En ti, oh Jehová, he confiado; no sea yo avergonzado jamás: Líbrame en tu justicia.   
\m
\v 2 Inclina \w a|strong="H3068"\w* mí tu oído, \w líbrame|strong="H6403"\w* pronto; sé tú mi Roca fuerte, mi Fortaleza para salvarme.   
\m
\v 3 Porque tú \add eres\add* \w mi|strong="H1961"\w* \w Roca|strong="H6697"\w* y \w mi|strong="H1961"\w* \w Fortaleza|strong="H4581"\w*; y por amor \w a|strong="H3068"\w* tu nombre condúceme y guíame.   
\m
\v 4 \w Me|strong="H3588"\w* sacarás \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w red|strong="H4686"\w* \w que|strong="H3588"\w* han escondido \w para|strong="H4616"\w* mí; \w porque|strong="H3588"\w* tú \add eres\add* mi fortaleza.   
\m
\v 5 \w En|strong="H3588"\w* tu mano encomiendo mi espíritu: Tú \w me|strong="H3588"\w* has redimido, oh Jehová, Dios \w de|strong="H3588"\w* verdad.   
\m
\v 6 Aborrecí \w a|strong="H3068"\w* los \w que|strong="H3027"\w* esperan en vanidades ilusorias; pero yo confío en \w Jehová|strong="H3068"\w*.   
\m
\v 7 Me gozaré y alegraré en tu misericordia; \w porque|strong="H8130"\w* has visto mi aflicción; has conocido mi alma en \w la|strong="H8104"\w* adversidad;   
\m
\v 8 y no me has encerrado en mano del enemigo; has puesto mis pies en lugar espacioso.   
\m
\v 9 Ten misericordia de mí, oh Jehová, \w que|strong="H3808"\w* \w estoy|strong="H5975"\w* \w en|strong="H5975"\w* angustia; de pesar \w se|strong="H3808"\w* han consumido mis ojos, mi alma, y mi vientre.   
\m
\v 10 \w Porque|strong="H3588"\w* \w mi|strong="H5315"\w* \w vida|strong="H5315"\w* se \w va|strong="H3068"\w* gastando \w de|strong="H3588"\w* dolor, \w y|strong="H3588"\w* mis años \w de|strong="H3588"\w* suspirar; se ha debilitado \w mi|strong="H5315"\w* fuerza \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w mi|strong="H5315"\w* iniquidad, \w y|strong="H3588"\w* mis huesos se han consumido.   
\m
\v 11 \w De|strong="H3588"\w* \w todos|strong="H8141"\w* mis enemigos he sido oprobio, \w más|strong="H3588"\w* \w de|strong="H3588"\w* mis vecinos, \w y|strong="H3588"\w* horror \w a|strong="H3068"\w* mis conocidos; \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* veían afuera, huían \w de|strong="H3588"\w* \w mí|strong="H3015"\w*.   
\m
\v 12 He \w sido|strong="H1961"\w* olvidado \w como|strong="H1961"\w* un muerto \w fuera|strong="H2351"\w* \w de|strong="H4480"\w* su memoria; \w soy|strong="H1961"\w* \w como|strong="H1961"\w* un vaso quebrado.   
\m
\v 13 Porque he oído la calumnia \w de|strong="H7911"\w* muchos; miedo por todas partes, mientras consultan juntos \w contra|strong="H1961"\w* \w mí|strong="H1961"\w*, y traman quitarme la vida.   
\m
\v 14 \w Mas|strong="H3588"\w* \w yo|strong="H3588"\w* \w en|strong="H5921"\w* \w ti|strong="H5921"\w* confié, oh Jehová; \w yo|strong="H3588"\w* dije: Tú eres \w mi|strong="H5921"\w* Dios.   
\m
\v 15 \w En|strong="H5921"\w* tu mano están mis tiempos: Líbrame \w de|strong="H5921"\w* \w la|strong="H5921"\w* mano \w de|strong="H5921"\w* mis enemigos, \w y|strong="H5921"\w* \w de|strong="H5921"\w* mis perseguidores.   
\m
\v 16 Haz resplandecer tu rostro sobre tu siervo: Sálvame \w por|strong="H3027"\w* tu misericordia.   
\m
\v 17 \w No|strong="H5921"\w* sea yo avergonzado, oh Jehová, ya \w que|strong="H5921"\w* \w te|strong="H5921"\w* he invocado; sean avergonzados \w los|strong="H5921"\w* impíos, guarden silencio \w en|strong="H5921"\w* \w el|strong="H5921"\w* sepulcro.   
\m
\v 18 \w Enmudezcan|strong="H1826"\w* \w los|strong="H3588"\w* labios mentirosos, \w que|strong="H3588"\w* hablan contra \w el|strong="H3588"\w* \w justo|strong="H7563"\w* cosas duras, \w con|strong="H3588"\w* soberbia \w y|strong="H3588"\w* menosprecio.   
\m
\v 19 ¡Cuán grande \add es\add* tu bondad, \w que|strong="H5921"\w* has guardado \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* temen, \w que|strong="H5921"\w* has mostrado \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w en|strong="H5921"\w* \w ti|strong="H5921"\w* confían \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* \w los|strong="H5921"\w* hombres!   
\m
\v 20 \w Los|strong="H1121"\w* esconderás en \w el|strong="H1121"\w* \w secreto|strong="H6845"\w* \w de|strong="H5048"\w* tu presencia \w de|strong="H5048"\w* las arrogancias del \w hombre|strong="H1121"\w*; \w los|strong="H1121"\w* pondrás en un tabernáculo \w a|strong="H3068"\w* cubierto \w de|strong="H5048"\w* contención \w de|strong="H5048"\w* lenguas.   
\m
\v 21 Bendito \add sea\add* Jehová, \w porque|strong="H6440"\w* me ha mostrado su maravillosa misericordia en ciudad fuerte.   
\m
\v 22 \w Y|strong="H3068"\w* decía \w yo|strong="H3588"\w* \w en|strong="H3588"\w* mi premura: Cortado soy \w de|strong="H3588"\w* delante \w de|strong="H3588"\w* tus ojos; \w mas|strong="H3588"\w* tú oíste \w la|strong="H3588"\w* voz \w de|strong="H3588"\w* mis súplicas, \w cuando|strong="H3588"\w* \w a|strong="H3068"\w* ti clamé.   
\m
\v 23 Amad \w a|strong="H3068"\w* Jehová todos \w vosotros|strong="H8085"\w* sus santos: Jehová guarda \w a|strong="H3068"\w* los fieles, y paga abundantemente al que obra con soberbia.   
\m
\v 24 Esforzaos \w todos|strong="H3605"\w* vosotros \w los|strong="H5921"\w* \w que|strong="H5921"\w* esperáis \w en|strong="H5921"\w* \w Jehová|strong="H3068"\w*, \w y|strong="H5921"\w* \w Él|strong="H5921"\w* fortalecerá vuestro corazón.   
\c 32
\d \add Salmo\add* de David: Masquil  
\m
\v 1 Bienaventurado aquel cuya transgresión ha sido perdonada, y cubierto su \w pecado|strong="H2401"\w*.   
\m
\v 2 Bienaventurado el hombre \w a|strong="H3068"\w* quien \w Jehová|strong="H3068"\w* \w no|strong="H3808"\w* culpa de \w iniquidad|strong="H5771"\w*, y en cuyo \w espíritu|strong="H7307"\w* \w no|strong="H3808"\w* hay \w engaño|strong="H7423"\w*.   
\m
\v 3 \w Mientras|strong="H3605"\w* \w callé|strong="H2790"\w*, se envejecieron mis \w huesos|strong="H6106"\w* \w en|strong="H3588"\w* mi gemir \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w*.   
\m
\v 4 \w Porque|strong="H3588"\w* \w de|strong="H5921"\w* \w día|strong="H3119"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w se|strong="H5921"\w* \w agravó|strong="H3513"\w* tu \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*; \w mi|strong="H5921"\w* verdor \w se|strong="H5921"\w* \w volvió|strong="H2015"\w* \w en|strong="H5921"\w* sequía \w de|strong="H5921"\w* \w verano|strong="H7019"\w*. (\w Selah|strong="H5542"\w*)   
\m
\v 5 \w Mi|strong="H5921"\w* \w pecado|strong="H2403"\w* \w te|strong="H5921"\w* \w declaré|strong="H3045"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w encubrí|strong="H3680"\w* \w mi|strong="H5921"\w* \w iniquidad|strong="H5771"\w*. Dije: \w Confesaré|strong="H3034"\w* \w mis|strong="H5375"\w* transgresiones \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*; \w y|strong="H5921"\w* tú \w perdonaste|strong="H5375"\w* \w la|strong="H5921"\w* \w maldad|strong="H5771"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pecado|strong="H2403"\w*. (\w Selah|strong="H5542"\w*)   
\m
\v 6 \w Por|strong="H5921"\w* \w esto|strong="H2063"\w* \w orará|strong="H6419"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w todo|strong="H3605"\w* \w santo|strong="H2623"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5921"\w* poder hallarte: \w Ciertamente|strong="H7535"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* inundación \w de|strong="H5921"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w* \w no|strong="H3808"\w* \w llegarán|strong="H5060"\w* \w estas|strong="H2063"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*.   
\m
\v 7 Tú eres mi refugio; me \w guardarás|strong="H5341"\w* de la \w angustia|strong="H6862"\w*: Con cánticos de liberación me rodearás. (\w Selah|strong="H5542"\w*)   
\m
\v 8 \w Te|strong="H5869"\w* haré \w entender|strong="H7919"\w*, \w y|strong="H5921"\w* \w te|strong="H5869"\w* enseñaré \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w en|strong="H5921"\w* \w que|strong="H2098"\w* debes \w andar|strong="H3212"\w*: \w Sobre|strong="H5921"\w* \w ti|strong="H5921"\w* fijaré mis \w ojos|strong="H5869"\w*.   
\m
\v 9 \w No|strong="H1077"\w* \w seáis|strong="H1961"\w* \w como|strong="H1961"\w* el \w caballo|strong="H5483"\w*, \w o|strong="H3068"\w* \w como|strong="H1961"\w* el mulo, sin entendimiento: Cuya boca ha de ser sujetada con cabestro y con freno, \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w no|strong="H1077"\w* \w se|strong="H1961"\w* acerquen \w a|strong="H3068"\w* ti.   
\m
\v 10 \w Muchos|strong="H7227"\w* \w dolores|strong="H4341"\w* \add habrá\add* para el \w impío|strong="H7563"\w*; \w mas|strong="H7227"\w* al que confía en \w Jehová|strong="H3068"\w*, le rodeará la \w misericordia|strong="H2617"\w*.   
\m
\v 11 \w Alegraos|strong="H8055"\w* en \w Jehová|strong="H3068"\w*, y \w regocijaos|strong="H7442"\w*, \w justos|strong="H6662"\w*; \w Y|strong="H3068"\w* dad voces \w de|strong="H6662"\w* júbilo \w todos|strong="H3605"\w* vosotros, \w los|strong="H3605"\w* \w rectos|strong="H3477"\w* \w de|strong="H6662"\w* \w corazón|strong="H3820"\w*.   
\c 33
\m
\v 1 \w Alegraos|strong="H7442"\w*, oh \w justos|strong="H6662"\w*, en \w Jehová|strong="H3068"\w*: \w A|strong="H3068"\w* los \w rectos|strong="H3477"\w* es \w hermosa|strong="H5000"\w* la \w alabanza|strong="H8416"\w*.   
\m
\v 2 \w Alabad|strong="H3034"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* con \w arpa|strong="H3658"\w*, \w cantadle|strong="H2167"\w* con \w salterio|strong="H5035"\w* y con instrumento \w de|strong="H5035"\w* diez cuerdas.   
\m
