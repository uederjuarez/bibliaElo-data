\v 1 \w Jehová|strong="H3068"\w* \w dijo|strong="H5002"\w* \w a|strong="H3068"\w* mi \w Señor|strong="H3068"\w*: \w Siéntate|strong="H3427"\w* \w a|strong="H3068"\w* mi \w diestra|strong="H3225"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w ponga|strong="H7896"\w* \w a|strong="H3068"\w* tus enemigos \w por|strong="H5704"\w* \w estrado|strong="H1916"\w* \w de|strong="H5704"\w* tus \w pies|strong="H7272"\w*.   
