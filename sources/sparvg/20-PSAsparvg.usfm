\m
\v 4 ¿Hasta cuándo pronunciarán y \w hablarán|strong="H1696"\w* cosas duras, y se vanagloriarán \w todos|strong="H3605"\w* \w los|strong="H3605"\w* obradores de iniquidad?   
\m
\v 5 \w A|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*, oh \w Jehová|strong="H3068"\w*, \w quebrantan|strong="H1792"\w*, y \w a|strong="H3068"\w* tu \w heredad|strong="H5159"\w* \w afligen|strong="H6031"\w*.   
\m
\v 6 \w A|strong="H3068"\w* la viuda y al \w extranjero|strong="H1616"\w* matan, y \w a|strong="H3068"\w* los \w huérfanos|strong="H3490"\w* quitan la vida.   
\m
\v 7 \w Y|strong="H3068"\w* dicen: \w No|strong="H3808"\w* \w mirará|strong="H7200"\w* \w Jehová|strong="H3050"\w*, \w ni|strong="H3808"\w* hará caso el Dios de \w Jacob|strong="H3290"\w*.   
\m
\v 8 \w Entended|strong="H7919"\w*, necios del \w pueblo|strong="H5971"\w*; \w y|strong="H1197"\w* vosotros fatuos, ¿\w cuándo|strong="H4970"\w* seréis sabios?   
\m
\v 9 El \w que|strong="H3808"\w* \w plantó|strong="H5193"\w* el \w oído|strong="H8085"\w*, ¿\w no|strong="H3808"\w* \w oirá|strong="H8085"\w*? El \w que|strong="H3808"\w* \w formó|strong="H3335"\w* el \w ojo|strong="H5869"\w*, ¿\w no|strong="H3808"\w* \w verá|strong="H5027"\w*?   
\m
\v 10 El \w que|strong="H3808"\w* \w castiga|strong="H3198"\w* \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*, ¿\w no|strong="H3808"\w* \w reprenderá|strong="H3198"\w*? El \w que|strong="H3808"\w* enseña el \w conocimiento|strong="H1847"\w* al hombre, ¿\add no sabrá\add*?   
\m
\v 11 \w Jehová|strong="H3068"\w* \w conoce|strong="H3045"\w* \w los|strong="H1992"\w* \w pensamientos|strong="H4284"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* hombres, \w que|strong="H3588"\w* \add son\add* \w vanidad|strong="H1892"\w*.   
\m
\v 12 Bienaventurado el \w hombre|strong="H1397"\w* \w a|strong="H3068"\w* quien tú, oh \w Jehová|strong="H3050"\w*, \w corriges|strong="H3256"\w*, y en tu \w ley|strong="H8451"\w* lo instruyes;   
\m
\v 13 \w Para|strong="H5704"\w* darle \w reposo|strong="H8252"\w* \w de|strong="H5704"\w* los \w días|strong="H3117"\w* \w de|strong="H5704"\w* aflicción, \w en|strong="H5704"\w* tanto \w que|strong="H5704"\w* \w para|strong="H5704"\w* \w el|strong="H8252"\w* \w impío|strong="H7563"\w* se \w cava|strong="H3738"\w* \w el|strong="H8252"\w* hoyo.   
\m
