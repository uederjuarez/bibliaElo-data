\v 2 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* entres \w en|strong="H3588"\w* \w juicio|strong="H4941"\w* \w con|strong="H3588"\w* tu \w siervo|strong="H5650"\w*; \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w justificará|strong="H6663"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti \w ningún|strong="H3605"\w* \w viviente|strong="H2416"\w*.   
