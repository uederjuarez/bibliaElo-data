\v 9 \w Porque|strong="H3588"\w* \w los|strong="H1992"\w* \w malignos|strong="H7489"\w* \w serán|strong="H1992"\w* cortados, \w mas|strong="H3588"\w* \w los|strong="H1992"\w* \w que|strong="H3588"\w* \w esperan|strong="H6960"\w* \w en|strong="H3588"\w* \w Jehová|strong="H3068"\w*, \w ellos|strong="H1992"\w* \w heredarán|strong="H3423"\w* \w la|strong="H3588"\w* tierra.   
