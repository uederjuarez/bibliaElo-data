\v 4 Hemos venido \w a|strong="H3068"\w* ser \w oprobio|strong="H2781"\w* \w a|strong="H3068"\w* nuestros \w vecinos|strong="H7934"\w*, escarnio y burla \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w que|strong="H1961"\w* nos \w rodean|strong="H5439"\w*.   
\m
\v 5 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4100"\w*, \w Jehová|strong="H3068"\w*? ¿Estarás enojado \w para|strong="H5704"\w* siempre? ¿\w Arderá|strong="H1197"\w* \w como|strong="H4100"\w* fuego tu \w celo|strong="H7068"\w*?   
\m
\v 6 \w Derrama|strong="H8210"\w* tu \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* \w conocen|strong="H3045"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w invocan|strong="H7121"\w* tu \w nombre|strong="H8034"\w*.   
\m
\v 7 \w Porque|strong="H3588"\w* han devorado \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, \w y|strong="H3588"\w* han \w asolado|strong="H8074"\w* \w su|strong="H3588"\w* \w morada|strong="H5116"\w*.   
\m
\v 8 \w No|strong="H3588"\w* \w recuerdes|strong="H2142"\w* contra nosotros las \w iniquidades|strong="H5771"\w* \w antiguas|strong="H7223"\w*: Anticípennos \w pronto|strong="H3966"\w* tus \w misericordias|strong="H7356"\w*, \w porque|strong="H3588"\w* estamos \w muy|strong="H3966"\w* \w abatidos|strong="H1809"\w*.   
\m
\v 9 \w Ayúdanos|strong="H5826"\w*, oh Dios \w de|strong="H5921"\w* nuestra salvación, \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* tu \w nombre|strong="H8034"\w*; \w líbranos|strong="H5337"\w* \w y|strong="H5921"\w* perdona nuestros \w pecados|strong="H2403"\w* \w por|strong="H5921"\w* amor \w a|strong="H3068"\w* tu \w nombre|strong="H8034"\w*.   
\m
\v 10 \w Porque|strong="H4100"\w* dirán las \w naciones|strong="H1471"\w*: ¿Dónde está su Dios? Sea notoria entre las \w naciones|strong="H1471"\w*, \w delante|strong="H5869"\w* \w de|strong="H1818"\w* nuestros \w ojos|strong="H5869"\w*, la \w venganza|strong="H5360"\w* \w de|strong="H1818"\w* la \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* tus \w siervos|strong="H5650"\w* \w que|strong="H4100"\w* fue derramada.   
\m
\v 11 Entre \w ante|strong="H6440"\w* tu \w presencia|strong="H6440"\w* \w el|strong="H1121"\w* gemido \w de|strong="H6440"\w* \w los|strong="H1121"\w* presos; conforme \w a|strong="H3068"\w* la \w grandeza|strong="H1433"\w* \w de|strong="H6440"\w* tu \w brazo|strong="H2220"\w* \w preserva|strong="H3498"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* sentenciados \w a|strong="H3068"\w* muerte.   
\m
\v 12 \w Y|strong="H3068"\w* \w da|strong="H7725"\w* \w a|strong="H3068"\w* nuestros \w vecinos|strong="H7934"\w* en su \w seno|strong="H2436"\w* \w siete|strong="H7659"\w* tantos de su \w oprobio|strong="H2781"\w*, con que te han deshonrado, oh Señor.   
\m
\v 13 \w Y|strong="H3068"\w* nosotros, \w pueblo|strong="H5971"\w* \w tuyo|strong="H5971"\w*, y \w ovejas|strong="H6629"\w* \w de|strong="H5971"\w* tu \w prado|strong="H4830"\w*, te daremos gracias \w para|strong="H5971"\w* \w siempre|strong="H5769"\w*: \w Cantaremos|strong="H5608"\w* tu \w alabanza|strong="H8416"\w* \w a|strong="H3068"\w* \w todas|strong="H1755"\w* las \w generaciones|strong="H1755"\w*.   
\c 80
\d Al Músico principal: sobre Sosanim-edut: Salmo de Asaf  
\m
\v 1 Oh Pastor de Israel, escucha: Tú que pastoreas como un rebaño \w a|strong="H3068"\w* José, Tú que habitas \add entre\add* querubines, resplandece.   
\m
\v 2 Despierta tu poder delante de Efraín, y de Benjamín, y de Manasés, y ven \w a|strong="H3068"\w* salvarnos.   
\m
\v 3 Oh Dios, restáuranos; y haz resplandecer tu \w rostro|strong="H6440"\w*, y seremos salvos.   
\m
\v 4 Oh Jehová, Dios \w de|strong="H6440"\w* los ejércitos, ¿Hasta cuándo estarás enojado \w contra|strong="H6440"\w* la oración \w de|strong="H6440"\w* tu pueblo?   
\m
\v 5 Les diste \w a|strong="H3068"\w* comer pan \w de|strong="H5704"\w* lágrimas, \w y|strong="H5704"\w* les diste \w a|strong="H3068"\w* beber lágrimas \w en|strong="H5704"\w* gran abundancia.   
\m
\v 6 Nos pusiste por contienda \w a|strong="H3068"\w* nuestros vecinos; y nuestros enemigos se burlan entre sí.   
\m
\v 7 Oh Dios de los ejércitos, restáuranos; haz resplandecer tu rostro, \w y|strong="H4066"\w* seremos salvos.   
\m
\v 8 Hiciste venir una vid \w de|strong="H6440"\w* Egipto; echaste \w a|strong="H3068"\w* las naciones, y la plantaste.   
\m
\v 9 Preparaste \add el terreno\add* delante de ella, \w e|strong="H3068"\w* hiciste arraigar sus raíces, y llenó la tierra.   
\m
\v 10 Los collados fueron cubiertos \w de|strong="H6440"\w* su sombra; y sus sarmientos \add fueron como\add* cedros \w de|strong="H6440"\w* Dios.   
\m
\v 11 Extendió sus vástagos hasta el mar, y hasta el río sus renuevos.   
\m
\v 12 ¿\w Por|strong="H5704"\w* \w qué|strong="H5704"\w* has derribado sus vallados, \w de|strong="H5704"\w* modo \w que|strong="H5704"\w* la arranquen todos los \w que|strong="H5704"\w* \w pasan|strong="H7971"\w* \w por|strong="H5704"\w* el camino?   
\m
\v 13 \w La|strong="H3605"\w* estropea \w el|strong="H3605"\w* puerco montés, y \w la|strong="H3605"\w* devora \w la|strong="H3605"\w* bestia del campo.   
\m
\v 14 Oh Dios de los ejércitos, vuelve ahora: Mira desde el cielo, y considera, y visita esta vid,   
\m
\v 15 y \w la|strong="H2063"\w* \w viña|strong="H1612"\w* \w que|strong="H4994"\w* plantó tu diestra, y el renuevo \w que|strong="H4994"\w* para ti afirmaste.   
\m
\v 16 \w Está|strong="H5921"\w* quemada \w a|strong="H3068"\w* fuego, asolada: Perecen \w por|strong="H5921"\w* \w la|strong="H5921"\w* reprensión \w de|strong="H5921"\w* tu rostro.   
\m
\v 17 Sea tu mano sobre el varón \w de|strong="H6440"\w* tu diestra, sobre el hijo del hombre que para ti corroboraste.   
\m
\v 18 Así \w no|strong="H1961"\w* \w nos|strong="H5921"\w* apartaremos \w de|strong="H5921"\w* \w ti|strong="H5921"\w*: Vida \w nos|strong="H5921"\w* darás, \w e|strong="H3068"\w* invocaremos tu nombre.   
\m
\v 19 Oh Jehová, Dios \w de|strong="H4480"\w* los ejércitos, ¡restáuranos! Haz resplandecer tu rostro, y seremos salvos.   
\c 81
\d Al Músico principal: sobre Gitit: Salmo de Asaf  
\m
\v 1 Cantad \w con|strong="H5921"\w* gozo \w a|strong="H3068"\w* Dios, fortaleza nuestra: Aclamad \w con|strong="H5921"\w* júbilo \w al|strong="H5921"\w* Dios \w de|strong="H5921"\w* Jacob.   
\m
\v 2 Entonad salmos, \w y|strong="H5797"\w* tañed el pandero, el arpa deliciosa con el salterio.   
\m
\v 3 Tocad la trompeta \w en|strong="H5973"\w* la luna nueva, \w en|strong="H5973"\w* \w el|strong="H5973"\w* día señalado, \w en|strong="H5973"\w* \w el|strong="H5973"\w* día \w de|strong="H5973"\w* nuestra fiesta solemne.   
\m
\v 4 Porque estatuto es para Israel, ordenanza del Dios de Jacob.   
\m
\v 5 \w Por|strong="H3588"\w* testimonio \w en|strong="H3588"\w* José \w lo|strong="H1931"\w* ha constituido, \w cuando|strong="H3588"\w* salió \w por|strong="H3588"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* Egipto; \add Donde\add* oí lenguaje \add que\add* \w no|strong="H3588"\w* entendía.   
\m
\v 6 Aparté su hombro \w de|strong="H5921"\w* debajo \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w carga|strong="H7760"\w*; sus manos fueron liberadas \w de|strong="H5921"\w* \w los|strong="H5921"\w* cestos.   
\m
\v 7 \w En|strong="H5493"\w* la calamidad clamaste, y yo te libré; te respondí \w en|strong="H5493"\w* \w el|strong="H5674"\w* secreto del trueno; te probé \w sobre|strong="H5674"\w* las aguas de Meriba. (Selah)   
\m
\v 8 Oye, pueblo \w mío|strong="H5921"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* protestaré. ¡Oh Israel, \w si|strong="H5921"\w* \w me|strong="H5921"\w* oyeres!   
\m
\v 9 No habrá en ti dios ajeno, ni adorarás \w a|strong="H3068"\w* dios extraño.   
\m
\v 10 Yo \w soy|strong="H1961"\w* Jehová tu Dios, \w que|strong="H3808"\w* te hice subir de la tierra de Egipto: Abre bien tu boca, y la llenaré.   
\m
\v 11 Mas mi pueblo no oyó mi voz, \w e|strong="H3068"\w* Israel no me quiso \w a|strong="H3068"\w* mí.   
\m
\v 12 Los entregué, por tanto, \w a|strong="H3068"\w* la dureza \w de|strong="H5971"\w* su corazón: Caminaron en sus propios consejos.   
\m
\v 13 ¡Oh, si me hubiera oído mi pueblo, si Israel hubiera andado \w en|strong="H3212"\w* mis caminos!   
\m
\v 14 En un instante habría yo subyugado \w a|strong="H3068"\w* sus enemigos, y vuelto mi mano \w contra|strong="H3478"\w* sus adversarios.   
\m
\v 15 \w Los|strong="H5921"\w* aborrecedores \w de|strong="H5921"\w* Jehová \w se|strong="H5921"\w* \w le|strong="H5921"\w* hubieran sometido; \w y|strong="H5921"\w* \w el|strong="H5921"\w* tiempo \w de|strong="H5921"\w* \w ellos|strong="H3027"\w* fuera \w para|strong="H5921"\w* \w siempre|strong="H5921"\w*.   
\m
\v 16 Él \w los|strong="H1961"\w* hubiera alimentado con lo mejor del trigo; y con miel \w de|strong="H6256"\w* la roca te hubiera saciado.   
\c 82
\d Salmo de Asaf  
\m
\v 1 Dios \w está|strong="H5324"\w* en la congregación de los poderosos; En \w medio|strong="H7130"\w* de los dioses \w juzga|strong="H8199"\w*.   
\m
\v 2 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* \w juzgaréis|strong="H8199"\w* \w injustamente|strong="H5766"\w*, \w Y|strong="H3068"\w* aceptaréis las personas \w de|strong="H6440"\w* los \w impíos|strong="H7563"\w*? (\w Selah|strong="H5542"\w*)   
\m
\v 3 \w Defended|strong="H8199"\w* al \w pobre|strong="H1800"\w* y al \w huérfano|strong="H3490"\w*: Haced justicia al \w afligido|strong="H6041"\w* y necesitado.   
\m
\v 4 \w Librad|strong="H6403"\w* al afligido y necesitado; \w libradlo|strong="H5337"\w* de \w mano|strong="H3027"\w* de los \w impíos|strong="H7563"\w*.   
\m
\v 5 \w No|strong="H3808"\w* \w saben|strong="H3045"\w*, \w no|strong="H3808"\w* entienden, \w andan|strong="H1980"\w* en tinieblas. Vacilan \w todos|strong="H3605"\w* \w los|strong="H3605"\w* cimientos de \w la|strong="H3605"\w* tierra.   
\m
\v 6 Yo dije: Vosotros \add sois\add* dioses; y \w todos|strong="H3605"\w* vosotros \add sois\add* \w hijos|strong="H1121"\w* del \w Altísimo|strong="H5945"\w*.   
\m
\v 7 Pero como hombres \w moriréis|strong="H4191"\w*; y \w caeréis|strong="H5307"\w* como cualquiera \w de|strong="H8269"\w* los \w príncipes|strong="H8269"\w*.   
\m
\v 8 \w Levántate|strong="H6965"\w*, oh Dios, \w juzga|strong="H8199"\w* \w la|strong="H3588"\w* tierra; \w porque|strong="H3588"\w* \w tú|strong="H8199"\w* \w heredarás|strong="H5157"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w*.   
\c 83
\d Canción: Salmo de Asaf  
\m
\v 1 Oh Dios no guardes silencio, no calles, oh Dios, ni te estés quieto.   
\m
\v 2 Porque he aquí que rugen tus enemigos; y los que te aborrecen alzan cabeza.   
\m
\v 3 Sobre tu pueblo han consultado astuta \w y|strong="H3588"\w* secretamente, \w y|strong="H3588"\w* han entrado \w en|strong="H3588"\w* consejo contra tus protegidos.   
\m
\v 4 Han dicho: Venid, \w y|strong="H5921"\w* cortémoslos \w de|strong="H5921"\w* \add ser\add* nación, \w y|strong="H5921"\w* \w no|strong="H5921"\w* haya \w más|strong="H5921"\w* memoria \w del|strong="H5921"\w* nombre \w de|strong="H5921"\w* Israel.   
\m
\v 5 \w Porque|strong="H3808"\w* han conspirado \w a|strong="H3068"\w* una, \w de|strong="H5750"\w* común, \w contra|strong="H3478"\w* ti han hecho alianza;   
\m
\v 6 \w Las|strong="H5921"\w* tiendas \w de|strong="H5921"\w* Edom \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* ismaelitas, Moab \w y|strong="H3588"\w* \w los|strong="H5921"\w* agarenos;   
\m
\v 7 Gebal, y Amón, y Amalec; los filisteos con los habitantes de Tiro.   
\m
\v 8 También \w el|strong="H5973"\w* asirio se ha juntado \w con|strong="H5973"\w* ellos: Han dado la mano \w a|strong="H3068"\w* \w los|strong="H3427"\w* hijos \w de|strong="H5973"\w* Lot. (Selah)   
\m
\v 9 Hazles \w como|strong="H1571"\w* \w a|strong="H3068"\w* Madián; \w como|strong="H1571"\w* \w a|strong="H3068"\w* Sísara, \w como|strong="H1571"\w* \w a|strong="H3068"\w* Jabín \w en|strong="H5973"\w* \w el|strong="H5973"\w* arroyo \w de|strong="H5973"\w* Cisón;   
\m
\v 10 \w que|strong="H1992"\w* perecieron en Endor, fueron \w hechos|strong="H6213"\w* como estiércol para la tierra.   
\m
\v 11 Pon \w a|strong="H3068"\w* sus nobles \w como|strong="H1961"\w* \w a|strong="H3068"\w* Oreb y \w como|strong="H1961"\w* \w a|strong="H3068"\w* Zeeb; y \w como|strong="H1961"\w* \w a|strong="H3068"\w* Zeba y \w como|strong="H1961"\w* \w a|strong="H3068"\w* Zalmuna, \w a|strong="H3068"\w* todos sus príncipes;   
\m
\v 12 \w Que|strong="H3605"\w* han dicho: Heredemos para \w nosotros|strong="H3605"\w* las moradas de Dios.   
\m
\v 13 Dios mío, ponlos como \w a|strong="H3068"\w* torbellinos; como \w a|strong="H3068"\w* hojarascas delante del viento.   
\m
\v 14 Como fuego que quema el bosque, y como llama que incendia las montañas.   
\m
\v 15 Persíguelos así con tu tempestad, \w y|strong="H1197"\w* atérralos con tu torbellino.   
\m
\v 16 Llena sus rostros de vergüenza; para \w que|strong="H5591"\w* busquen tu nombre, oh Jehová.   
\m
\v 17 Sean afrentados y turbados para siempre; Sean avergonzados, y perezcan.   
\m
\v 18 \w Para|strong="H5704"\w* \w que|strong="H5704"\w* los \add hombres\add* sepan \w que|strong="H5704"\w* solo tú, cuyo nombre es Jehová; eres el Altísimo sobre toda la tierra.   
\c 84
\d Al Músico principal: sobre Gitit: Salmo para los hijos de Coré  
\m
\v 1 ¡Cuán amables son tus moradas, \w oh|strong="H1121"\w* Jehová \w de|strong="H5921"\w* \w los|strong="H1121"\w* ejércitos!   
\m
\v 2 Anhela mi alma, y aun ardientemente desea los atrios de \w Jehová|strong="H3068"\w*: Mi corazón y mi carne cantan al \w Dios|strong="H3068"\w* vivo.   
\m
\v 3 \w Aun|strong="H1571"\w* \w el|strong="H1571"\w* gorrión halla casa, \w y|strong="H1571"\w* \w la|strong="H1571"\w* golondrina nido para \w sí|strong="H1571"\w*, donde ponga sus polluelos, en tus altares, oh \w Jehová|strong="H3068"\w* de los ejércitos, Rey mío, \w y|strong="H1571"\w* \w Dios|strong="H3068"\w* mío.   
\m
\v 4 Bienaventurados los \w que|strong="H1571"\w* habitan en tu \w casa|strong="H1004"\w*: Perpetuamente te alabarán. (Selah)   
\m
\v 5 Bienaventurado \w el|strong="H3427"\w* hombre que tiene su fortaleza \w en|strong="H5750"\w* ti; \w en|strong="H5750"\w* cuyo corazón \add están\add* tus caminos.   
\m
\v 6 Atravesando el valle de lágrimas lo convierten en fuente, cuando la lluvia llena los estanques.   
\m
\v 7 Irán de fortaleza en fortaleza, verán \w a|strong="H3068"\w* Dios en Sión.   
\m
\v 8 Oh Jehová Dios de los \w ejércitos|strong="H2428"\w*, oye mi oración: Escucha, oh Dios de Jacob. (Selah)   
\m
\v 9 Mira, oh \w Dios|strong="H3068"\w*, escudo nuestro, y pon los ojos en el rostro de tu ungido.   
\m
\v 10 \w Porque|strong="H6440"\w* mejor es un día en tus atrios que mil fuera \w de|strong="H6440"\w* ellos: Escogería \w antes|strong="H6440"\w* estar \w a|strong="H3068"\w* la puerta \w de|strong="H6440"\w* la casa \w de|strong="H6440"\w* mi Dios, que habitar en las moradas \w de|strong="H6440"\w* maldad.   
\m
\v 11 \w Porque|strong="H3588"\w* sol \w y|strong="H3588"\w* escudo \w es|strong="H3588"\w* Jehová Dios: Gracia \w y|strong="H3588"\w* gloria dará Jehová: \w No|strong="H3588"\w* quitará \w el|strong="H3588"\w* \w bien|strong="H2896"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* integridad andan.   
\m
\v 12 Oh \w Jehová|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* ejércitos, dichoso \w el|strong="H3588"\w* hombre \w que|strong="H3588"\w* \w en|strong="H8549"\w* ti confía.   
\c 85
\d Al Músico principal: Salmo para los hijos de Coré  
\m
\v 1 Jehová, tú has sido propicio \w a|strong="H3068"\w* tu tierra; tú hiciste volver la cautividad \w de|strong="H1121"\w* Jacob.   
\m
\v 2 Perdonaste la iniquidad de tu pueblo; cubriste todos sus pecados. (Selah)   
\m
\v 3 Dejaste \w todo|strong="H3605"\w* tu enojo; te volviste \w de|strong="H5971"\w* \w la|strong="H3605"\w* ira \w de|strong="H5971"\w* tu furor.   
\m
\v 4 Restáuranos, oh Dios, salvación nuestra, y haz cesar tu \w ira|strong="H2740"\w* de sobre \w nosotros|strong="H3605"\w*.   
\m
\v 5 ¿Estarás enojado \w contra|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w para|strong="H5973"\w* siempre? ¿Extenderás tu ira \w de|strong="H5973"\w* generación \w en|strong="H5973"\w* generación?   
\m
\v 6 ¿No volverás \w a|strong="H3068"\w* darnos vida, para que tu pueblo se regocije en ti?   
\m
\v 7 Muéstranos, oh Jehová, tu misericordia, y danos tu salvación.   
\m
\v 8 Escucharé lo que hable \w Jehová|strong="H3068"\w* \w Dios|strong="H3068"\w*: Porque hablará paz \w a|strong="H3068"\w* su pueblo y \w a|strong="H3068"\w* sus santos, \w para|strong="H5414"\w* que no se vuelvan \w a|strong="H3068"\w* la locura.   
\m
\v 9 \w Ciertamente|strong="H3588"\w* cercana \add está\add* \w su|strong="H3588"\w* salvación \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* le temen; \w Para|strong="H3588"\w* \w que|strong="H3588"\w* habite \w la|strong="H3588"\w* gloria \w en|strong="H3588"\w* nuestra tierra.   
\m
\v 10 La misericordia \w y|strong="H3519"\w* la verdad se encontraron: La justicia \w y|strong="H3519"\w* la paz se besaron.   
\m
\v 11 La verdad brotará de la tierra; y la \w justicia|strong="H6664"\w* mirará desde el cielo.   
\m
\v 12 Sí, Jehová dará lo que es bueno, y nuestra tierra dará su fruto.   
\m
\v 13 \w La|strong="H1571"\w* justicia irá delante \w de|strong="H5414"\w* \w Él|strong="H1571"\w*, \w y|strong="H1571"\w* nos \w pondrá|strong="H5414"\w* en \w el|strong="H1571"\w* camino \w de|strong="H5414"\w* sus pasos.   
\c 86
\d Oración de David  
\m
\v 1 \w Inclina|strong="H5186"\w*, oh \w Jehová|strong="H3068"\w*, tu oído, \w y|strong="H3588"\w* \w óyeme|strong="H6030"\w*; \w porque|strong="H3588"\w* estoy \w afligido|strong="H6041"\w* \w y|strong="H3588"\w* necesitado.   
\m
\v 2 \w Guarda|strong="H8104"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*, \w porque|strong="H3588"\w* soy piadoso: \w Salva|strong="H3467"\w* tú, oh Dios mío, \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* ti confía.   
\m
\v 3 Ten \w misericordia|strong="H2603"\w* \w de|strong="H3588"\w* mí, oh Jehová: \w Porque|strong="H3588"\w* \w a|strong="H3068"\w* ti \w clamo|strong="H7121"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w*.   
\m
\v 4 \w Alegra|strong="H8055"\w* \w el|strong="H3588"\w* \w alma|strong="H5315"\w* \w de|strong="H3588"\w* tu \w siervo|strong="H5650"\w*: \w Porque|strong="H3588"\w* \w a|strong="H3068"\w* ti, oh Señor, \w levanto|strong="H5375"\w* \w mi|strong="H5375"\w* \w alma|strong="H5315"\w*.   
\m
\v 5 \w Porque|strong="H3588"\w* tú, Señor, eres \w bueno|strong="H2896"\w* \w y|strong="H3588"\w* perdonador, \w y|strong="H3588"\w* \w grande|strong="H7227"\w* \w en|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w para|strong="H3588"\w* \w con|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* \w invocan|strong="H7121"\w*.   
\m
\v 6 \w Escucha|strong="H7181"\w*, oh \w Jehová|strong="H3068"\w*, mi \w oración|strong="H8605"\w*, y está \w atento|strong="H7181"\w* \w a|strong="H3068"\w* la \w voz|strong="H6963"\w* de mis \w ruegos|strong="H8469"\w*.   
\m
\v 7 \w En|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w mi|strong="H6030"\w* \w angustia|strong="H6869"\w* \w te|strong="H3588"\w* \w llamaré|strong="H7121"\w*; \w porque|strong="H3588"\w* tú \w me|strong="H3588"\w* \w respondes|strong="H6030"\w*.   
\m
\v 8 Oh Señor, ninguno \add hay\add* \w como|strong="H3644"\w* tú entre los dioses, ni \add hay\add* \w obras|strong="H4639"\w* que igualen tus \w obras|strong="H4639"\w*.   
\m
\v 9 \w Todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w que|strong="H3605"\w* \w hiciste|strong="H6213"\w* vendrán y adorarán \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, oh Señor; y glorificarán \w tu|strong="H6213"\w* \w nombre|strong="H8034"\w*.   
\m
\v 10 \w Porque|strong="H3588"\w* \w tú|strong="H6213"\w* \add eres\add* \w grande|strong="H1419"\w*, \w y|strong="H3588"\w* \w hacedor|strong="H6213"\w* \w de|strong="H3588"\w* \w maravillas|strong="H6381"\w*: Sólo \w tú|strong="H6213"\w* \add eres\add* Dios.   
\m
\v 11 \w Enséñame|strong="H3384"\w*, oh \w Jehová|strong="H3068"\w*, tu \w camino|strong="H1870"\w*; \w caminaré|strong="H1980"\w* yo en tu verdad: Consolida mi \w corazón|strong="H3824"\w* para que \w tema|strong="H3372"\w* tu \w nombre|strong="H8034"\w*.   
\m
\v 12 Te \w alabaré|strong="H3034"\w*, oh Señor Dios mío, con \w todo|strong="H3605"\w* mi \w corazón|strong="H3824"\w*; y glorificaré tu \w nombre|strong="H8034"\w* para \w siempre|strong="H5769"\w*.   
\m
\v 13 \w Porque|strong="H3588"\w* tu \w misericordia|strong="H2617"\w* \w es|strong="H3588"\w* \w grande|strong="H1419"\w* \w para|strong="H5921"\w* conmigo; \w y|strong="H3588"\w* has \w librado|strong="H5337"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w del|strong="H5921"\w* \w más|strong="H3588"\w* \w profundo|strong="H8482"\w* infierno.   
\m
\v 14 Oh Dios, \w soberbios|strong="H2086"\w* \w se|strong="H3808"\w* \w levantaron|strong="H6965"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* conspiración \w de|strong="H5921"\w* \add hombres\add* violentos \w ha|strong="H3808"\w* buscado \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* \w pusieron|strong="H7760"\w* \w delante|strong="H5048"\w* \w de|strong="H5921"\w* \w sí|strong="H3808"\w*.   
\m
\v 15 \w Mas|strong="H7227"\w* tú, oh Señor, \add eres\add* Dios \w misericordioso|strong="H7349"\w* y \w clemente|strong="H2587"\w*, lento para la ira y \w grande|strong="H7227"\w* en \w misericordia|strong="H2617"\w* y verdad;   
\m
\v 16 \w Mírame|strong="H6437"\w*, \w y|strong="H5797"\w* ten \w misericordia|strong="H2603"\w* \w de|strong="H1121"\w* mí: \w Da|strong="H5414"\w* tu \w fortaleza|strong="H5797"\w* \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w*, \w y|strong="H5797"\w* guarda al \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* tu sierva.   
\m
\v 17 \w Haz|strong="H6213"\w* \w conmigo|strong="H5973"\w* señal \w para|strong="H3588"\w* \w bien|strong="H2896"\w*, \w y|strong="H3588"\w* véanla \w los|strong="H5973"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w aborrecen|strong="H8130"\w*, \w y|strong="H3588"\w* sean avergonzados; \w porque|strong="H3588"\w* \w tú|strong="H6213"\w*, \w Jehová|strong="H3068"\w*, \w me|strong="H3588"\w* has ayudado \w y|strong="H3588"\w* consolado.   
\c 87
\d A los hijos de Coré: Salmo: Canción  
\m
\v 1 Su cimiento \add está\add* en \w el|strong="H1121"\w* \w monte|strong="H6944"\w* \w santo|strong="H6944"\w*.   
\m
\v 2 Ama \w Jehová|strong="H3068"\w* las \w puertas|strong="H8179"\w* de \w Sión|strong="H6726"\w* más \w que|strong="H3605"\w* \w todas|strong="H3605"\w* las \w moradas|strong="H4908"\w* de \w Jacob|strong="H3290"\w*.   
\m
\v 3 Cosas gloriosas se \w dicen|strong="H1696"\w* de ti, oh \w ciudad|strong="H5892"\w* de Dios. (\w Selah|strong="H5542"\w*)   
\m
\v 4 Mencionaré \w a|strong="H3068"\w* Rahab y \w a|strong="H3068"\w* Babilonia \w entre|strong="H5973"\w* \w los|strong="H5973"\w* \w que|strong="H3045"\w* \w me|strong="H5973"\w* \w conocen|strong="H3045"\w*. He \w aquí|strong="H2009"\w* \w Filistea|strong="H6429"\w*, y \w Tiro|strong="H6865"\w*, \w con|strong="H5973"\w* \w Etiopía|strong="H3568"\w*: \w Este|strong="H2088"\w* \w nació|strong="H3205"\w* \w allá|strong="H8033"\w*.   
\m
\v 5 \w Y|strong="H3068"\w* de \w Sión|strong="H6726"\w* \w se|strong="H1931"\w* dirá: \w Este|strong="H1931"\w* y \w aquél|strong="H1931"\w* \w nacieron|strong="H3205"\w* en \w ella|strong="H1931"\w*; y \w el|strong="H1931"\w* \w Altísimo|strong="H5945"\w* \w mismo|strong="H1931"\w* \w la|strong="H1931"\w* establecerá.   
\m
\v 6 \w Jehová|strong="H3068"\w* \w contará|strong="H5608"\w* cuando Él inscriba \w a|strong="H3068"\w* los \w pueblos|strong="H5971"\w*: \w Este|strong="H2088"\w* \w nació|strong="H3205"\w* \w allí|strong="H8033"\w*. (\w Selah|strong="H5542"\w*)   
\m
\v 7 \w Y|strong="H3068"\w* \w cantores|strong="H7891"\w* y tañedores \add en ella dirán\add*: \w Todas|strong="H3605"\w* mis fuentes estarán en ti.   
\c 88
\d Canción: Salmo para los hijos de Coré; al Músico principal; para cantar sobre Mahalat; Masquil de Hemán ezraíta.  
\m
\v 1 \w Oh|strong="H1121"\w* Jehová, Dios \w de|strong="H5921"\w* \w mi|strong="H5921"\w* salvación, \w día|strong="H1121"\w* \w y|strong="H5921"\w* noche clamo \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*.   
\m
\v 2 Llegue mi oración \w a|strong="H3068"\w* tu presencia: Inclina tu oído \w a|strong="H3068"\w* mi clamor.   
\m
\v 3 \w Porque|strong="H6440"\w* mi alma está harta \w de|strong="H6440"\w* males, y mi vida se acerca al sepulcro.   
\m
\v 4 Soy contado \w con|strong="H3588"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* descienden \w a|strong="H3068"\w* \w la|strong="H3588"\w* fosa, soy \w como|strong="H3588"\w* hombre sin fuerza:   
\m
\v 5 Libre \w entre|strong="H5973"\w* \w los|strong="H1961"\w* difuntos, \w como|strong="H5973"\w* \w los|strong="H1961"\w* muertos \w que|strong="H1961"\w* yacen \w en|strong="H5973"\w* \w el|strong="H5973"\w* sepulcro, \w que|strong="H1961"\w* \w no|strong="H1961"\w* \w te|strong="H5973"\w* acuerdas más \w de|strong="H5973"\w* ellos, y \w que|strong="H1961"\w* \w son|strong="H1961"\w* cortados \w de|strong="H5973"\w* tu mano.   
\m
\v 6 Me \w has|strong="H4191"\w* puesto \w en|strong="H5750"\w* \w el|strong="H1992"\w* hoyo \w más|strong="H5750"\w* profundo, \w en|strong="H5750"\w* tinieblas, \w en|strong="H5750"\w* lugares profundos.   
\m
\v 7 Sobre mí descarga tu ira, y me has afligido con todas tus ondas. (Selah)   
\m
\v 8 Has alejado \w de|strong="H5921"\w* \w mí|strong="H5921"\w* mis conocidos; \w me|strong="H5921"\w* has puesto \w por|strong="H5921"\w* abominación \w a|strong="H3068"\w* \w ellos|strong="H5921"\w*: Encerrado estoy, \w y|strong="H5921"\w* \w no|strong="H5921"\w* puedo salir.   
\m
\v 9 Mis ojos enfermaron \w a|strong="H3068"\w* causa \w de|strong="H4480"\w* mi aflicción: \w Te|strong="H4480"\w* he llamado, oh Jehová, cada día; he extendido \w a|strong="H3068"\w* \w ti|strong="H4480"\w* mis manos.   
\m
\v 10 ¿Mostrarás maravillas \w a|strong="H3068"\w* \w los|strong="H3605"\w* muertos? ¿\w Se|strong="H4480"\w* levantarán \w los|strong="H3605"\w* muertos y \w te|strong="H5869"\w* alabarán? (Selah)   
\m
\v 11 ¿\w Será|strong="H6213"\w* contada en \w el|strong="H6213"\w* sepulcro \w tu|strong="H6213"\w* misericordia, \w o|strong="H3068"\w* \w tu|strong="H6213"\w* fidelidad en la destrucción?   
\m
\v 12 ¿Serán conocidas en las tinieblas tus maravillas, y tu justicia en la tierra del olvido?   
\m
\v 13 Mas yo \w a|strong="H3068"\w* ti he clamado, oh Jehová; y de mañana mi oración sale \w a|strong="H3068"\w* tu encuentro.   
\m
\v 14 ¿Por qué, oh \w Jehová|strong="H3068"\w*, desechas mi alma? ¿\add Por qué\add* escondes de mí tu rostro?   
\m
\v 15 \w Yo|strong="H4480"\w* estoy afligido y \w a|strong="H3068"\w* punto \w de|strong="H4480"\w* morir; \w desde|strong="H4480"\w* la juventud he sufrido tus terrores, estoy perplejo.   
\m
\v 16 Sobre \w mí|strong="H5375"\w* han pasado tus iras; tus terrores me han cortado.   
\m
\v 17 \w Me|strong="H5921"\w* han rodeado \w como|strong="H5921"\w* aguas \w de|strong="H5921"\w* continuo; \w a|strong="H3068"\w* una \w me|strong="H5921"\w* han cercado.   
\m
\v 18 Has alejado \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w al|strong="H5921"\w* amigo \w y|strong="H5921"\w* \w al|strong="H5921"\w* compañero; \add y\add* mis conocidos pusiste \w en|strong="H5921"\w* tinieblas.   
\c 89
\d Masquil de Etán ezraíta  
\m
\v 1 Las misericordias de Jehová cantaré por siempre; con mi boca daré \w a|strong="H3068"\w* conocer tu fidelidad \w a|strong="H3068"\w* todas las generaciones.   
\m
\v 2 Porque dije: Para \w siempre|strong="H5769"\w* será edificada \w misericordia|strong="H2617"\w*; en los mismos cielos establecerás tu fidelidad.   
\m
\v 3 Hice pacto \w con|strong="H3588"\w* mi escogido; Juré \w a|strong="H3068"\w* David mi siervo, diciendo:   
\m
\v 4 Para siempre confirmaré tu simiente, y edificaré tu trono por todas las generaciones. (Selah)   
\m
\v 5 Los cielos celebrarán tus maravillas, oh Jehová; tu fidelidad también \w en|strong="H5704"\w* la congregación \w de|strong="H5704"\w* los santos.   
\m
\v 6 Porque ¿quién en el \w cielo|strong="H8064"\w* se comparará \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*? ¿Quién será semejante \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* entre los hijos de los poderosos?   
\m
\v 7 \w Dios|strong="H3068"\w* debe ser muy temido \w en|strong="H3588"\w* \w la|strong="H3588"\w* asamblea \w de|strong="H3588"\w* \w los|strong="H1121"\w* santos, \w y|strong="H3588"\w* ser tenido \w en|strong="H3588"\w* reverencia \w por|strong="H3588"\w* todos \w los|strong="H1121"\w* \w que|strong="H3588"\w* están \w a|strong="H3068"\w* \w su|strong="H3588"\w* alrededor.   
\m
\v 8 Oh Jehová, Dios \w de|strong="H5921"\w* \w los|strong="H5921"\w* ejércitos, ¿\w Quién|strong="H3605"\w* \add es\add* poderoso \w como|strong="H5921"\w* tú, oh Jehová? \w Y|strong="H3068"\w* tu fidelidad \w te|strong="H5921"\w* rodea.   
\m
\v 9 Tú tienes dominio sobre la braveza del mar; cuando se levantan sus ondas, tú las sosiegas.   
\m
\v 10 Tú quebrantaste \w a|strong="H3068"\w* Rahab como \w a|strong="H3068"\w* un muerto; con tu brazo fuerte esparciste \w a|strong="H3068"\w* tus enemigos.   
\m
\v 11 Tuyos son los cielos, tuya también la tierra: El mundo \w y|strong="H5797"\w* su plenitud, tú lo fundaste.   
\m
\v 12 Al norte y al sur tú los creaste: Tabor y Hermón se regocijarán en tu nombre.   
\m
\v 13 Tú tienes brazo fuerte; poderosa es tu mano, exaltada es tu \w diestra|strong="H3225"\w*.   
\m
\v 14 Justicia y juicio \add son\add* \w el|strong="H5973"\w* fundamento \w de|strong="H5973"\w* tu trono: Misericordia y verdad van \w delante|strong="H5973"\w* \w de|strong="H5973"\w* tu rostro.   
\m
\v 15 Bienaventurado el pueblo que sabe aclamarte: Andará, oh Jehová, \w a|strong="H3068"\w* la luz \w de|strong="H6440"\w* tu \w rostro|strong="H6440"\w*.   
\m
\v 16 En tu nombre \w se|strong="H3045"\w* alegrarán todo el día; y en tu justicia serán exaltados.   
\m
\v 17 Porque tú \add eres\add* \w la|strong="H3605"\w* \w gloria|strong="H3605"\w* de su fortaleza; y por tu buena voluntad exaltarás nuestro cuerno.   
\m
\v 18 \w Porque|strong="H3588"\w* Jehová \add es\add* nuestra defensa; \w y|strong="H3588"\w* nuestro Rey \w es|strong="H3588"\w* \w el|strong="H3588"\w* Santo \w de|strong="H3588"\w* Israel.   
\m
\v 19 \w Entonces|strong="H3588"\w* hablaste \w en|strong="H3588"\w* visión \w a|strong="H3068"\w* tu \w santo|strong="H6918"\w*, \w y|strong="H3588"\w* dijiste: He \w puesto|strong="H3588"\w* \w el|strong="H3588"\w* socorro sobre \add uno que es\add* poderoso; he enaltecido \w a|strong="H3068"\w* un escogido \w de|strong="H3588"\w* mi pueblo.   
\m
\v 20 Hallé \w a|strong="H3068"\w* David \w mi|strong="H5921"\w* siervo; \w lo|strong="H5921"\w* ungí \w con|strong="H5921"\w* \w mi|strong="H5921"\w* óleo \w santo|strong="H2623"\w*.   
\m
\v 21 Mi mano será firme con él, mi brazo también lo fortalecerá.   
\m
\v 22 No lo avasallará enemigo, \w ni|strong="H5973"\w* hijo \w de|strong="H5973"\w* iniquidad lo quebrantará.   
\m
\v 23 \w Mas|strong="H3808"\w* yo aplastaré \w a|strong="H3068"\w* sus enemigos delante \w de|strong="H1121"\w* \w él|strong="H1121"\w*, y heriré \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H3808"\w* le aborrecen.   
\m
\v 24 \w Y|strong="H3068"\w* mi fidelidad y mi misericordia \add serán\add* con él; y en mi nombre será exaltado su cuerno.   
\m
\v 25 Asimismo pondré su mano sobre \w el|strong="H5973"\w* mar, y sobre \w los|strong="H5973"\w* ríos su diestra.   
\m
\v 26 Él clamará \w a|strong="H3068"\w* mí: Mi Padre \add eres\add* tú, mi Dios y la Roca de mi salvación.   
\m
\v 27 Yo también \w lo|strong="H1931"\w* haré \add mi\add* primogénito, más excelso \w que|strong="H1931"\w* \w los|strong="H1931"\w* reyes de \w la|strong="H1931"\w* tierra.   
\m
\v 28 \w Para|strong="H5414"\w* siempre le conservaré mi misericordia; y mi pacto \w será|strong="H5414"\w* firme con él.   
\m
\v 29 \w Y|strong="H3068"\w* estableceré su simiente para \w siempre|strong="H5769"\w*, y su trono como los días del cielo.   
\m
\v 30 Si dejaren sus \w hijos|strong="H2233"\w* mi ley, y no anduvieren en mis juicios;   
\m
\v 31 \w Si|strong="H3808"\w* quebrantaren mis estatutos, y \w no|strong="H3808"\w* guardaren mis mandamientos;   
\m
\v 32 Entonces visitaré con vara su rebelión, y con azotes su iniquidad.   
\m
\v 33 \w Mas|strong="H6485"\w* no quitaré de él mi misericordia, ni falsearé mi fidelidad.   
\m
\v 34 \w No|strong="H3808"\w* quebrantaré mi pacto, \w ni|strong="H3808"\w* mudaré \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w ha|strong="H3808"\w* salido \w de|strong="H5973"\w* mis labios.   
\m
\v 35 Una vez he jurado por \w mi|strong="H2490"\w* santidad, \w que|strong="H3808"\w* \w no|strong="H3808"\w* mentiré \w a|strong="H3068"\w* David.   
\m
\v 36 Su simiente será para siempre, y su trono como el sol delante de mí.   
\m
\v 37 \w Como|strong="H1961"\w* la luna \w será|strong="H1961"\w* firme \w para|strong="H1961"\w* \w siempre|strong="H5769"\w*, y \w como|strong="H1961"\w* un testigo fiel en el cielo. (Selah)   
\m
\v 38 Mas tú desechaste y menospreciaste \w a|strong="H3068"\w* tu ungido; y te has airado con él.   
\m
\v 39 Rompiste \w el|strong="H5973"\w* pacto \w de|strong="H5973"\w* tu siervo; has profanado su corona hasta la tierra.   
\m
\v 40 \w Rompiste|strong="H5010"\w* todos sus vallados; has convertido en ruinas sus fortalezas.   
\m
\v 41 \w Lo|strong="H3605"\w* saquean \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* pasan por \w el|strong="H3605"\w* camino: Es oprobio \w a|strong="H3068"\w* sus vecinos.   
\m
\v 42 Has exaltado \w la|strong="H3605"\w* diestra de sus enemigos; has alegrado \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus adversarios.   
\m
\v 43 Embotaste asimismo \w el|strong="H3605"\w* filo de su espada, y no \w lo|strong="H3605"\w* levantaste en \w la|strong="H3605"\w* batalla.   
\m
\v 44 Hiciste cesar su gloria, y echaste su trono por tierra.   
\m
\v 45 Has acortado los días de su juventud; le has cubierto de afrenta. (Selah)   
\m
\v 46 ¿\w Hasta|strong="H5921"\w* \w cuándo|strong="H3117"\w*, oh Jehová? ¿\w Te|strong="H5921"\w* esconderás \w para|strong="H5921"\w* \w siempre|strong="H5921"\w*? ¿Arderá tu ira \w como|strong="H5921"\w* \w el|strong="H5921"\w* fuego?   
\m
\v 47 Acuérdate \w de|strong="H5704"\w* \w cuán|strong="H4100"\w* breve es mi tiempo: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* habrás creado \w en|strong="H5704"\w* vano \w a|strong="H3068"\w* todos los hijos del hombre?   
\m
\v 48 ¿\w Qué|strong="H4100"\w* \w hombre|strong="H1121"\w* podrá vivir \w y|strong="H5921"\w* \w no|strong="H5921"\w* ver \w la|strong="H5921"\w* muerte? ¿Podrá librar su \w alma|strong="H3605"\w* \w del|strong="H5921"\w* poder \w del|strong="H5921"\w* sepulcro? (Selah)   
\m
\v 49 Señor, ¿dónde están tus antiguas misericordias, \w que|strong="H4310"\w* juraste \w a|strong="H3068"\w* David en tu verdad?   
\m
\v 50 Señor, acuérdate del oprobio de tus siervos; \add oprobio\add* de muchos pueblos, que llevo en mi seno.   
\m
\v 51 Porque tus enemigos, oh Jehová, han deshonrado, han deshonrado \w los|strong="H3605"\w* pasos \w de|strong="H5971"\w* tu ungido.   
\m
\v 52 Bendito \add sea\add* \w Jehová|strong="H3068"\w* para siempre. Amén y amén.   
\c 90
\d Oración de Moisés varón de Dios  
\m
\v 1 Señor, tú nos has \w sido|strong="H1961"\w* refugio de \w generación|strong="H1755"\w* en \w generación|strong="H1755"\w*.   
\m
\v 2 \w Antes|strong="H2962"\w* \w que|strong="H5704"\w* naciesen las montañas \w y|strong="H5704"\w* formases la tierra \w y|strong="H5704"\w* el \w mundo|strong="H8398"\w*; \w Desde|strong="H5704"\w* la \w eternidad|strong="H5769"\w* \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* la \w eternidad|strong="H5769"\w*, tú eres Dios.   
\m
\v 3 \w Vuelves|strong="H7725"\w* \w al|strong="H5704"\w* \w hombre|strong="H1121"\w* \w hasta|strong="H5704"\w* ser quebrantado, \w y|strong="H5704"\w* dices: \w Convertíos|strong="H7725"\w*, \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*.   
\m
\v 4 \w Porque|strong="H3588"\w* mil \w años|strong="H8141"\w* \w delante|strong="H5869"\w* \w de|strong="H3588"\w* tus \w ojos|strong="H5869"\w*, \add son\add* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* ayer, \w que|strong="H3588"\w* \w pasó|strong="H5674"\w*, \w y|strong="H3588"\w* \w como|strong="H3588"\w* una vigilia \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w noche|strong="H3915"\w*.   
\m
\v 5 \w Los|strong="H1961"\w* haces pasar \w como|strong="H1961"\w* avenida de aguas; \w son|strong="H1961"\w* \add como\add* un \w sueño|strong="H8142"\w*; \w como|strong="H1961"\w* la \w hierba|strong="H2682"\w* \w que|strong="H1961"\w* crece en la \w mañana|strong="H1242"\w*:   
\m
\v 6 En la \w mañana|strong="H1242"\w* \w florece|strong="H6692"\w* y crece; \w A|strong="H3068"\w* la \w tarde|strong="H6153"\w* es cortada, y se \w seca|strong="H3001"\w*.   
\m
\v 7 \w Porque|strong="H3588"\w* \w con|strong="H3588"\w* tu \w furor|strong="H2534"\w* somos consumidos, \w y|strong="H3588"\w* \w con|strong="H3588"\w* tu \w ira|strong="H2534"\w* somos turbados.   
\m
\v 8 \w Pusiste|strong="H7896"\w* nuestras \w maldades|strong="H5771"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, nuestros \add pecados\add* secretos \w a|strong="H3068"\w* la luz \w de|strong="H6440"\w* tu \w rostro|strong="H6440"\w*.   
\m
\v 9 \w Porque|strong="H3588"\w* \w todos|strong="H3605"\w* nuestros \w días|strong="H3117"\w* \w declinan|strong="H6437"\w* \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* tu ira; \w acabamos|strong="H3615"\w* nuestros \w años|strong="H8141"\w* \w como|strong="H3588"\w* un pensamiento.   
\m
\v 10 \w Los|strong="H3588"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* nuestra \w edad|strong="H3117"\w* \w son|strong="H3588"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*; \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w los|strong="H3588"\w* \w más|strong="H3588"\w* robustos \w son|strong="H3588"\w* \w ochenta|strong="H8084"\w* \w años|strong="H8141"\w*, \w con|strong="H3588"\w* todo, \w su|strong="H3588"\w* \w fortaleza|strong="H1369"\w* \w es|strong="H3588"\w* \w molestia|strong="H5999"\w* \w y|strong="H3588"\w* \w trabajo|strong="H5999"\w*; \w porque|strong="H3588"\w* pronto \w es|strong="H3588"\w* cortado, \w y|strong="H3588"\w* volamos.   
\m
\v 11 ¿\w Quién|strong="H4310"\w* \w conoce|strong="H3045"\w* \w el|strong="H4310"\w* poder de tu ira, \w y|strong="H5797"\w* tu indignación según \w que|strong="H4310"\w* debes ser temido?   
\m
\v 12 \w Enséñanos|strong="H3045"\w* de \w tal|strong="H3651"\w* modo \w a|strong="H3068"\w* contar nuestros \w días|strong="H3117"\w*, \w que|strong="H3045"\w* traigamos al \w corazón|strong="H3824"\w* \w sabiduría|strong="H2451"\w*.   
\m
\v 13 \w Vuelve|strong="H7725"\w*, oh \w Jehová|strong="H3068"\w*; ¿\w hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w*? \w Y|strong="H3068"\w* aplácate \w para|strong="H5704"\w* \w con|strong="H5921"\w* tus \w siervos|strong="H5650"\w*.   
\m
\v 14 \w De|strong="H7646"\w* \w mañana|strong="H1242"\w* \w sácianos|strong="H7646"\w* \w de|strong="H7646"\w* tu \w misericordia|strong="H2617"\w*; y cantaremos y nos \w alegraremos|strong="H8055"\w* \w todos|strong="H3605"\w* nuestros \w días|strong="H3117"\w*.   
\m
\v 15 \w Alégranos|strong="H8055"\w* conforme \w a|strong="H3068"\w* los \w días|strong="H3117"\w* \w que|strong="H3117"\w* nos \w afligiste|strong="H6031"\w*, y los \w años|strong="H8141"\w* \w que|strong="H3117"\w* \w vimos|strong="H7200"\w* el \w mal|strong="H7451"\w*.   
\m
\v 16 \w Aparezca|strong="H7200"\w* \w en|strong="H5921"\w* tus \w siervos|strong="H5650"\w* tu \w obra|strong="H6467"\w*, \w y|strong="H5921"\w* tu \w gloria|strong="H1926"\w* \w sobre|strong="H5921"\w* sus \w hijos|strong="H1121"\w*.   
\m
\v 17 \w Sea|strong="H1961"\w* \w la|strong="H5921"\w* hermosura \w de|strong="H5921"\w* Jehová nuestro Dios \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*; \w y|strong="H5921"\w* \w confirma|strong="H3559"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w la|strong="H5921"\w* \w obra|strong="H4639"\w* \w de|strong="H5921"\w* nuestras \w manos|strong="H3027"\w*; \w Sí|strong="H1961"\w*, \w la|strong="H5921"\w* \w obra|strong="H4639"\w* \w de|strong="H5921"\w* nuestras \w manos|strong="H3027"\w* \w confirma|strong="H3559"\w*.   
\c 91
\m
\v 1 \w El|strong="H3427"\w* que \w habita|strong="H3427"\w* al abrigo del \w Altísimo|strong="H5945"\w*, \w morará|strong="H3427"\w* bajo la \w sombra|strong="H6738"\w* del \w Omnipotente|strong="H7706"\w*.   
\m
\v 2 Diré yo de \w Jehová|strong="H3068"\w*: Él es mi refugio y mi fortaleza; mi \w Dios|strong="H3068"\w*, en Él confiaré.   
\m
\v 3 \w Él|strong="H1931"\w* \w te|strong="H3588"\w* \w librará|strong="H5337"\w* del \w lazo|strong="H6341"\w* del cazador; \w de|strong="H3588"\w* \w la|strong="H1931"\w* peste destructora.   
\m
\v 4 Con sus plumas te cubrirá, y \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* sus \w alas|strong="H3671"\w* estarás seguro: \w Escudo|strong="H6793"\w* y adarga es su verdad.   
\m
\v 5 \w No|strong="H3808"\w* tendrás \w temor|strong="H3372"\w* \w de|strong="H3372"\w* \w espanto|strong="H6343"\w* nocturno, \add ni\add* \w de|strong="H3372"\w* \w saeta|strong="H2671"\w* \w que|strong="H3808"\w* \w vuele|strong="H5774"\w* \w de|strong="H3372"\w* \w día|strong="H3119"\w*;   
\m
\v 6 \add Ni\add* de \w pestilencia|strong="H1698"\w* que ande en oscuridad, \add ni\add* de \w mortandad|strong="H1698"\w* que en medio del día destruya.   
\m
\v 7 \w Caerán|strong="H5307"\w* \w a|strong="H3068"\w* tu \w lado|strong="H6654"\w* \w mil|strong="H7233"\w*, y diez \w mil|strong="H7233"\w* \w a|strong="H3068"\w* tu \w diestra|strong="H3225"\w*; \w mas|strong="H3808"\w* \w a|strong="H3068"\w* ti \w no|strong="H3808"\w* \w llegará|strong="H5066"\w*.   
\m
\v 8 \w Ciertamente|strong="H7535"\w* con tus \w ojos|strong="H5869"\w* \w mirarás|strong="H7200"\w* y \w verás|strong="H7200"\w* la recompensa \w de|strong="H5869"\w* los \w impíos|strong="H7563"\w*.   
\m
\v 9 \w Porque|strong="H3588"\w* has \w puesto|strong="H3588"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \w que|strong="H3588"\w* \w es|strong="H3588"\w* mi refugio, al \w Altísimo|strong="H5945"\w*, \w por|strong="H3588"\w* tu \w habitación|strong="H4583"\w*,   
\m
\v 10 \w No|strong="H3808"\w* te sobrevendrá \w mal|strong="H7451"\w*, \w ni|strong="H3808"\w* \w plaga|strong="H5061"\w* \w tocará|strong="H7126"\w* tu morada.   
\m
\v 11 \w Pues|strong="H3588"\w* \w a|strong="H3068"\w* sus \w ángeles|strong="H4397"\w* \w mandará|strong="H6680"\w* acerca \w de|strong="H3588"\w* ti, \w que|strong="H3588"\w* \w te|strong="H3588"\w* \w guarden|strong="H8104"\w* \w en|strong="H3588"\w* \w todos|strong="H3605"\w* tus \w caminos|strong="H1870"\w*.   
\m
\v 12 \w En|strong="H5921"\w* \add sus\add* \w manos|strong="H3709"\w* \w te|strong="H5921"\w* sostendrán, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w no|strong="H6435"\w* tropieces \w con|strong="H5921"\w* tu \w pie|strong="H7272"\w* \w en|strong="H5921"\w* piedra.   
\m
\v 13 \w Sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w león|strong="H7826"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* serpiente \w pisarás|strong="H1869"\w*; \w Hollarás|strong="H1869"\w* \w al|strong="H5921"\w* cachorro \w del|strong="H5921"\w* \w león|strong="H7826"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w dragón|strong="H8577"\w*.   
\m
\v 14 \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w en|strong="H3588"\w* mí ha \w puesto|strong="H3588"\w* \w su|strong="H3588"\w* amor, \w yo|strong="H3588"\w* también lo libraré; lo pondré \w en|strong="H3588"\w* \w alto|strong="H7682"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* ha \w conocido|strong="H3045"\w* mi \w nombre|strong="H8034"\w*.   
\m
\v 15 \w Me|strong="H5973"\w* \w invocará|strong="H7121"\w*, y yo \w le|strong="H5973"\w* \w responderé|strong="H6030"\w*; \w con|strong="H5973"\w* \w él|strong="H5973"\w* \add estaré\add* yo \w en|strong="H5973"\w* la \w angustia|strong="H6869"\w*; lo libraré y lo honraré.   
\m
\v 16 Lo \w saciaré|strong="H7646"\w* \w de|strong="H7646"\w* larga \w vida|strong="H3117"\w* y le \w mostraré|strong="H7200"\w* mi salvación.   
\c 92
\d Salmo: Canción para el día del sábado  
\m
\v 1 Bueno \add es\add* dar gracias \w a|strong="H3068"\w* Jehová, y cantar salmos \w a|strong="H3068"\w* tu nombre, oh Altísimo;   
\m
\v 2 Anunciar por la mañana tu misericordia, y tu fidelidad en las noches,   
\m
\v 3 en el decacordio y en el salterio, en tono suave con el arpa.   
\m
\v 4 \w Por|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w me|strong="H5921"\w* has alegrado, oh Jehová, \w con|strong="H5921"\w* tus obras; \w en|strong="H5921"\w* \w las|strong="H5921"\w* obras \w de|strong="H5921"\w* tus manos \w me|strong="H5921"\w* gozo.   
\m
\v 5 ¡\w Cuán|strong="H3588"\w* grandes \w son|strong="H3588"\w* tus \w obras|strong="H4639"\w*, oh \w Jehová|strong="H3068"\w*! Muy profundos \w son|strong="H3588"\w* tus pensamientos.   
\m
\v 6 El hombre necio \w no|strong="H4100"\w* sabe, y el insensato \w no|strong="H4100"\w* entiende esto:   
\m
\v 7 \w Que|strong="H3808"\w* brotan los impíos como \w la|strong="H2063"\w* hierba, y florecen todos los obradores de iniquidad, para ser destruidos para siempre.   
\m
\v 8 \w Mas|strong="H5704"\w* tú, Jehová, \w para|strong="H5704"\w* \w siempre|strong="H3605"\w* \add eres\add* Altísimo.   
\m
\v 9 Porque he aquí tus enemigos, oh \w Jehová|strong="H3068"\w*, porque he aquí, perecerán tus enemigos; serán disipados todos los obradores de iniquidad.   
\m
\v 10 \w Pero|strong="H3588"\w* tú exaltarás \w mi|strong="H2009"\w* cuerno \w como|strong="H3588"\w* \w el|strong="H3588"\w* del unicornio; seré ungido \w con|strong="H3588"\w* aceite fresco.   
\m
\v 11 \w Y|strong="H3068"\w* mis ojos mirarán \add mi deseo\add* sobre mis enemigos; oirán mis oídos de los que se levantaron contra mí, de los malignos.   
\m
\v 12 \w El|strong="H5921"\w* justo florecerá \w como|strong="H5921"\w* \w la|strong="H5921"\w* palmera; crecerá \w como|strong="H5921"\w* cedro \w en|strong="H5921"\w* \w el|strong="H5921"\w* Líbano.   
\m
\v 13 Los que están plantados en la casa \w de|strong="H6662"\w* Jehová, en los atrios \w de|strong="H6662"\w* nuestro Dios \w florecerán|strong="H6524"\w*.   
\m
\v 14 Aun en la vejez darán fruto; estarán vigorosos y verdes,   
\m
\v 15 \w para|strong="H1961"\w* anunciar \w que|strong="H1961"\w* Jehová \w es|strong="H1961"\w* recto: \add Él es\add* \w mi|strong="H1961"\w* Roca, y \w en|strong="H5750"\w* Él \w no|strong="H1961"\w* \w hay|strong="H1961"\w* injusticia.   
\c 93
\m
\v 1 \w Jehová|strong="H3068"\w* \w reina|strong="H4427"\w*, se \w vistió|strong="H3847"\w* \w de|strong="H3847"\w* majestad, se \w vistió|strong="H3847"\w* \w Jehová|strong="H3068"\w*, se ciñó \w de|strong="H3847"\w* \w fortaleza|strong="H5797"\w*; \w afirmó|strong="H3559"\w* también el \w mundo|strong="H8398"\w*, para que \w no|strong="H1077"\w* sea movido.   
\m
\v 2 \w Firme|strong="H3559"\w* es tu \w trono|strong="H3678"\w* desde la antigüedad: Tú \add eres\add* desde la \w eternidad|strong="H5769"\w*.   
\m
\v 3 \w Alzaron|strong="H5375"\w* los ríos, oh \w Jehová|strong="H3068"\w*, \w alzaron|strong="H5375"\w* los ríos su \w sonido|strong="H6963"\w*; \w alzaron|strong="H5375"\w* los ríos sus ondas.   
\m
\v 4 \w Jehová|strong="H3068"\w* en las \w alturas|strong="H4791"\w* \add es\add* \w más|strong="H7227"\w* poderoso \w que|strong="H4325"\w* el \w estruendo|strong="H6963"\w* \w de|strong="H4325"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*, \add más que\add* las recias olas del \w mar|strong="H3220"\w*.   
\m
\v 5 Tus testimonios son \w muy|strong="H3966"\w* firmes; la \w santidad|strong="H6944"\w* \w conviene|strong="H4998"\w* \w a|strong="H3068"\w* tu \w casa|strong="H1004"\w*, eternamente oh \w Jehová|strong="H3068"\w*.   
\c 94
\m
\v 1 Oh \w Jehová|strong="H3068"\w*, \w Dios|strong="H3068"\w* de las \w venganzas|strong="H5360"\w*, oh \w Dios|strong="H3068"\w* de las \w venganzas|strong="H5360"\w*, manifiéstate.   
\m
\v 2 Levántate, oh \w Juez|strong="H8199"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra; \w da|strong="H7725"\w* \w el|strong="H5921"\w* \w pago|strong="H1576"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* soberbios.   
\m
