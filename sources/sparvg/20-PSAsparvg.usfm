\v 24 \w Cuando|strong="H3588"\w* \w caiga|strong="H5307"\w*, \w no|strong="H3808"\w* quedará \w postrado|strong="H5307"\w*, \w porque|strong="H3588"\w* \w Jehová|strong="H3068"\w* \w sostiene|strong="H5564"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*.   
\m
\v 25 Joven \w fui|strong="H1961"\w*, \w y|strong="H1571"\w* he \w envejecido|strong="H2204"\w*, \w y|strong="H1571"\w* \w no|strong="H3808"\w* he \w visto|strong="H7200"\w* \w justo|strong="H6662"\w* \w desamparado|strong="H5800"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* su \w simiente|strong="H2233"\w* mendigando \w pan|strong="H3899"\w*.   
