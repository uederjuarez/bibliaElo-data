\id PSA
\h Salmos 
\toc1 Salmos 
\toc2 Salmos 
\mt1 Salmos  
\c 1
\d \add El piadoso será prosperado, el impío perecerá\add*  
\m
\v 1 Bienaventurado \w el|strong="H3427"\w* hombre \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w anda|strong="H1980"\w* \w en|strong="H5975"\w* \w consejo|strong="H6098"\w* de malos, \w ni|strong="H3808"\w* \w está|strong="H5975"\w* \w en|strong="H5975"\w* \w camino|strong="H1870"\w* de \w pecadores|strong="H2400"\w*, \w ni|strong="H3808"\w* \w en|strong="H5975"\w* silla de escarnecedores \w está|strong="H5975"\w* \w sentado|strong="H3427"\w*;   
\m
\v 2 \w Sino|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w ley|strong="H8451"\w* \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w* está \w su|strong="H3588"\w* delicia, \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w ley|strong="H8451"\w* \w medita|strong="H1897"\w* \w de|strong="H3588"\w* \w día|strong="H3119"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w noche|strong="H3915"\w*.   
\m
\v 3 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w árbol|strong="H6086"\w* \w plantado|strong="H8362"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* corrientes \w de|strong="H5921"\w* \w agua|strong="H4325"\w*, \w que|strong="H3808"\w* \w da|strong="H5414"\w* su \w fruto|strong="H6529"\w* \w en|strong="H5921"\w* su \w tiempo|strong="H6256"\w*, \w y|strong="H5921"\w* su hoja \w no|strong="H3808"\w* \w cae|strong="H5034"\w*; \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w hace|strong="H6213"\w*, \w prosperará|strong="H6743"\w*.   
\m
\v 4 \w No|strong="H3808"\w* \w así|strong="H3651"\w* \w los|strong="H3588"\w* malos, \w que|strong="H3588"\w* \add son\add* \w como|strong="H3588"\w* \w el|strong="H3588"\w* tamo \w que|strong="H3588"\w* arrebata \w el|strong="H3588"\w* \w viento|strong="H7307"\w*.   
\m
\v 5 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w no|strong="H3808"\w* \w se|strong="H5921"\w* levantarán \w los|strong="H5921"\w* malos \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w juicio|strong="H4941"\w*, \w ni|strong="H3808"\w* \w los|strong="H5921"\w* \w pecadores|strong="H2400"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w justos|strong="H6662"\w*.   
\m
\v 6 \w Porque|strong="H3588"\w* \w Jehová|strong="H3068"\w* \w conoce|strong="H3045"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w justos|strong="H6662"\w*; \w mas|strong="H3588"\w* \w la|strong="H3588"\w* senda \w de|strong="H3588"\w* \w los|strong="H3588"\w* malos perecerá.   
\c 2
\m
\v 1 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w se|strong="H4100"\w* amotinan las \w naciones|strong="H1471"\w*, y los \w pueblos|strong="H3816"\w* \w piensan|strong="H1897"\w* vanidad?   
\m
\v 2 \w Se|strong="H5921"\w* levantan \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w los|strong="H5921"\w* gobernantes consultan \w unidos|strong="H3162"\w* \w contra|strong="H5921"\w* \w Jehová|strong="H3068"\w* \w y|strong="H5921"\w* \w contra|strong="H5921"\w* su \w ungido|strong="H4899"\w*, \add diciendo\add*:   
\m
\v 3 \w Rompamos|strong="H5423"\w* sus \w coyundas|strong="H4147"\w*, y echemos \w de|strong="H4480"\w* nosotros sus \w cuerdas|strong="H5688"\w*.   
\m
\v 4 \w El|strong="H3427"\w* que \w está|strong="H3427"\w* \w sentado|strong="H3427"\w* en \w los|strong="H3427"\w* \w cielos|strong="H8064"\w* se reirá; \w el|strong="H3427"\w* Señor se burlará de ellos.   
\m
\v 5 Entonces les \w hablará|strong="H1696"\w* en su \w ira|strong="H2740"\w*, y los turbará en su \w furor|strong="H2740"\w*.   
\m
\v 6 Pero yo he puesto \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w Rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Sión|strong="H6726"\w*, \w mi|strong="H5921"\w* \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*.   
\m
\v 7 Yo publicaré \w el|strong="H1121"\w* decreto: \w Jehová|strong="H3068"\w* me ha dicho: Mi \w Hijo|strong="H1121"\w* eres tú; yo te he engendrado \w hoy|strong="H3117"\w*.   
\m
\v 8 \w Pídeme|strong="H7592"\w*, y \w te|strong="H4480"\w* \w daré|strong="H5414"\w* las \w naciones|strong="H1471"\w* \w por|strong="H4480"\w* \w herencia|strong="H5159"\w*, y \w por|strong="H4480"\w* \w posesión|strong="H5159"\w* tuya los confines \w de|strong="H4480"\w* la tierra.   
\m
\v 9 Tú los quebrantarás con \w vara|strong="H7626"\w* de \w hierro|strong="H1270"\w*; como \w vaso|strong="H3627"\w* de alfarero los desmenuzarás.   
\m
\v 10 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, oh \w reyes|strong="H4428"\w*, sed sabios: Sed instruidos, \w jueces|strong="H8199"\w* de la tierra.   
\m
\v 11 \w Servid|strong="H5647"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* con \w temor|strong="H3374"\w*, y \w alegraos|strong="H1523"\w* con \w temblor|strong="H7461"\w*.   
\m
\v 12 Besad al \w Hijo|strong="H1248"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H6435"\w* \w se|strong="H6435"\w* enoje, \w y|strong="H3588"\w* perezcáis \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w*, \w cuando|strong="H3588"\w* \w se|strong="H6435"\w* encendiere un \w poco|strong="H4592"\w* \w su|strong="H3588"\w* furor. Bienaventurados \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w Él|strong="H3588"\w* confían.   
\c 3
\d Salmo de David, cuando huía de Absalón su hijo  
\m
\v 1 ¡\w Oh|strong="H1121"\w* Jehová, cuánto se han multiplicado \w los|strong="H1121"\w* \w que|strong="H1121"\w* me atribulan! Muchos se levantan \w contra|strong="H6440"\w* mí.   
\m
\v 2 \w Muchos|strong="H7227"\w* dicen \w de|strong="H5921"\w* \w mi|strong="H5921"\w* alma: \w No|strong="H5921"\w* hay \w para|strong="H5921"\w* \w él|strong="H5921"\w* ayuda \w en|strong="H5921"\w* \w Dios|strong="H3068"\w*. (Selah)   
\m
\v 3 Pero tú, oh Jehová, \add eres\add* escudo alrededor de \w mí|strong="H5315"\w*, \w mi|strong="H5315"\w* gloria, y el que levanta \w mi|strong="H5315"\w* cabeza.   
\m
\v 4 Con mi voz clamé \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \w y|strong="H3519"\w* Él me respondió \w desde|strong="H1157"\w* su monte santo. (Selah)   
\m
\v 5 Yo me acosté y dormí, y desperté, porque \w Jehová|strong="H3068"\w* me sostuvo.   
\m
\v 6 \w No|strong="H3588"\w* temeré \w de|strong="H3588"\w* diez millares \w de|strong="H3588"\w* pueblos \w que|strong="H3588"\w* pusieren sitio contra mí.   
\m
\v 7 Levántate, oh Jehová; sálvame, oh Dios \w mío|strong="H5921"\w*; \w porque|strong="H5921"\w* tú has herido \w a|strong="H3068"\w* todos mis enemigos \w en|strong="H5921"\w* \w la|strong="H5921"\w* quijada; has quebrado \w los|strong="H5921"\w* dientes \w de|strong="H5921"\w* \w los|strong="H5921"\w* malos.   
\m
\v 8 \w De|strong="H3588"\w* \w Jehová|strong="H3068"\w* \w es|strong="H3588"\w* \w la|strong="H3588"\w* salvación: Sobre tu pueblo \add es\add* tu bendición. (Selah)   
\c 4
\d Al Músico principal: sobre Neginot: Salmo de David  
\m
\v 1 Escúchame cuando clamo, oh Dios de mi justicia; cuando yo estaba en angustia, tú me ensanchaste; ten misericordia de mí, y escucha mi oración.   
\m
\v 2 Oh hijos de los hombres, ¿hasta cuándo \add volveréis\add* \w mi|strong="H6030"\w* gloria en vergüenza? ¿\add Hasta cuándo\add* amaréis la vanidad, y buscaréis la mentira? (Selah)   
\m
\v 3 Sabed, \w pues|strong="H4100"\w*, \w que|strong="H4100"\w* Jehová apartó \w al|strong="H5704"\w* piadoso \w para|strong="H5704"\w* sí; Jehová oirá \w cuando|strong="H4100"\w* yo \w a|strong="H3068"\w* \w Él|strong="H1121"\w* clamare.   
\m
\v 4 Asombraos, \w y|strong="H3588"\w* \w no|strong="H3588"\w* pequéis: Meditad \w en|strong="H3588"\w* vuestro corazón sobre vuestra cama, \w y|strong="H3588"\w* callad. (Selah)   
\m
\v 5 Ofreced sacrificios \w de|strong="H5921"\w* justicia, \w y|strong="H5921"\w* confiad \w en|strong="H5921"\w* Jehová.   
\m
\v 6 Muchos dicen: ¿Quién nos mostrará el bien? Alza sobre nosotros, oh \w Jehová|strong="H3068"\w*, la luz de tu rostro.   
\m
\v 7 Tú pusiste alegría \w en|strong="H5921"\w* \w mi|strong="H5921"\w* corazón, \w mayor|strong="H7227"\w* \w que|strong="H4310"\w* \w la|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* tiempo \w que|strong="H4310"\w* \w se|strong="H5921"\w* multiplicó su grano \w y|strong="H5921"\w* su vino.   
\m
\v 8 En paz me acostaré, y asimismo dormiré; porque solo tú, Jehová, me haces vivir seguro.   
\c 5
\d Al Músico principal: sobre Nehilot: Salmo de David  
\m
\v 1 Escucha, oh Jehová, mis palabras; considera mi meditación.   
\m
\v 2 Está atento \w a|strong="H3068"\w* la voz de mi clamor, Rey mío y \w Dios|strong="H3068"\w* mío, porque \w a|strong="H3068"\w* ti oraré.   
\m
\v 3 Oh Jehová, \w de|strong="H3588"\w* mañana oirás mi \w voz|strong="H6963"\w*; \w de|strong="H3588"\w* mañana presentaré \add mi oración\add* delante \w de|strong="H3588"\w* ti, \w y|strong="H3588"\w* esperaré.   
\m
\v 4 Porque tú no eres un \w Dios|strong="H3068"\w* que se complace en la maldad; el mal no habitará junto \w a|strong="H3068"\w* ti.   
\m
\v 5 \w Los|strong="H3588"\w* insensatos \w no|strong="H3808"\w* estarán delante \w de|strong="H3588"\w* tus ojos; aborreces \w a|strong="H3068"\w* todos \w los|strong="H3588"\w* obradores \w de|strong="H3588"\w* iniquidad.   
\m
\v 6 Destruirás \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H3808"\w* hablan mentira; al hombre sanguinario y engañador aborrecerá Jehová.   
\m
\v 7 Pero en cuanto \w a|strong="H3068"\w* mí, por la multitud \w de|strong="H1818"\w* tu misericordia entraré \add en\add* tu casa; \add y\add* en tu temor adoraré hacia tu santo templo.   
\m
\v 8 Guíame, oh Jehová, en tu justicia \w a|strong="H3068"\w* causa de mis enemigos; endereza delante de mí tu camino.   
\m
\v 9 \w Porque|strong="H6440"\w* en su boca \w no|strong="H1870"\w* hay fidelidad; sus entrañas \add son\add* perversidad; sepulcro abierto \add es\add* su garganta; con su lengua hablan lisonjas.   
\m
\v 10 Destrúyelos, oh Dios; caigan \w por|strong="H3588"\w* sus propios consejos; \w por|strong="H3588"\w* \w la|strong="H3588"\w* multitud \w de|strong="H3588"\w* sus transgresiones échalos fuera, \w porque|strong="H3588"\w* se rebelaron contra ti.   
\m
\v 11 \w Pero|strong="H3588"\w* alégrense \w todos|strong="H7230"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* ti confían; \w para|strong="H3588"\w* siempre den voces \w de|strong="H3588"\w* júbilo, \w porque|strong="H3588"\w* tú \w los|strong="H3588"\w* defiendes: \w En|strong="H3588"\w* ti se regocijen \w los|strong="H3588"\w* \w que|strong="H3588"\w* aman tu nombre.   
\m
\v 12 \w Porque|strong="H5921"\w* tú, Jehová, bendecirás \w al|strong="H5921"\w* justo; \w lo|strong="H5921"\w* rodearás \w de|strong="H5921"\w* benevolencia \w como|strong="H5921"\w* \add con\add* un escudo.   
\c 6
\d Al Músico principal: sobre Neginot sobre Seminit: Salmo de David  
\m
\v 1 Oh Jehová, \w no|strong="H5921"\w* \w me|strong="H5921"\w* reprendas \w en|strong="H5921"\w* tu furor, ni \w me|strong="H5921"\w* castigues \w en|strong="H5921"\w* tu ira.   
\m
\v 2 Ten misericordia de mí, oh \w Jehová|strong="H3068"\w*, \w porque|strong="H3198"\w* estoy debilitado; sáname, oh \w Jehová|strong="H3068"\w*, \w porque|strong="H3198"\w* mis huesos están conmovidos.   
\m
\v 3 Mi alma también está muy angustiada; \w y|strong="H3588"\w* tú, oh \w Jehová|strong="H3068"\w*, ¿hasta \w cuándo|strong="H3588"\w*?   
\m
\v 4 Vuélvete, oh \w Jehová|strong="H3068"\w*, libra \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*; sálvame \w por|strong="H5704"\w* tu misericordia.   
\m
\v 5 \w Porque|strong="H4616"\w* en la muerte no \add hay\add* memoria de ti; en el sepulcro, ¿quién \w te|strong="H5315"\w* \w dará|strong="H7725"\w* gracias?   
\m
\v 6 Fatigado estoy \w de|strong="H3588"\w* mi gemir; toda \w la|strong="H3588"\w* noche hago nadar mi cama, riego mi lecho \w con|strong="H3588"\w* mis lágrimas.   
\m
\v 7 Mis ojos están consumidos de sufrir; se han envejecido \w a|strong="H3068"\w* causa de \w todos|strong="H3605"\w* mis angustiadores.   
\m
\v 8 Apartaos \w de|strong="H5869"\w* mí, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* obradores \w de|strong="H5869"\w* iniquidad; porque Jehová ha oído \w la|strong="H3605"\w* voz \w de|strong="H5869"\w* mi llanto.   
\m
\v 9 \w Jehová|strong="H3068"\w* ha escuchado mi súplica; \w Jehová|strong="H3068"\w* recibirá mi oración.   
\m
\v 10 Sean avergonzados y muy aterrados todos mis enemigos; que se vuelvan \add y\add* súbitamente sean avergonzados.   
\c 7
\d Sigaión de David, que cantó a Jehová sobre las palabras de Cus, hijo de Benjamín  
\m
\v 1 Oh \w Jehová|strong="H3068"\w* \w Dios|strong="H3068"\w* \w mío|strong="H5921"\w*, \w en|strong="H5921"\w* \w ti|strong="H5921"\w* confío: Sálvame \w de|strong="H5921"\w* todos \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* persiguen, \w y|strong="H5921"\w* líbrame;   
\m
\v 2 no sea \w que|strong="H3605"\w* desgarren mi \w alma|strong="H3605"\w* como león, despedazándola, sin \w que|strong="H3605"\w* haya \w quien|strong="H3605"\w* \w libre|strong="H5337"\w*.   
\m
\v 3 Oh Jehová Dios mío, \w si|strong="H6435"\w* \w yo|strong="H5315"\w* he \w hecho|strong="H5315"\w* esto, \w si|strong="H6435"\w* hay iniquidad en mis manos;   
\m
\v 4 \w si|strong="H3426"\w* pagué mal al que estaba en paz \w conmigo|strong="H6213"\w* (Hasta he librado al que sin causa era mi enemigo),   
\m
\v 5 que el \w enemigo|strong="H6887"\w* persiga mi alma, y la alcance; que pisotee en tierra mi vida, y mi honra ponga en el polvo. (Selah)   
\m
\v 6 Levántate, oh Jehová, en tu ira; levántate \w a|strong="H3068"\w* causa de la furia de mis enemigos, \w y|strong="H3519"\w* despierta en favor mío el juicio que mandaste.   
\m
\v 7 Así te rodeará congregación de pueblos; por causa de ellos vuelve \w a|strong="H3068"\w* levantarte en alto.   
\m
\v 8 Jehová juzgará \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w pueblos|strong="H3816"\w*: Júzgame, oh Jehová, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* justicia \w y|strong="H5921"\w* \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* integridad.   
\m
\v 9 Oh, \w que|strong="H5921"\w* \w se|strong="H5921"\w* acabe \w la|strong="H5921"\w* maldad \w de|strong="H5921"\w* \w los|strong="H5921"\w* impíos, pero establece \w tú|strong="H8199"\w* \w al|strong="H5921"\w* justo; \w porque|strong="H5921"\w* \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* justo prueba \w la|strong="H5921"\w* mente \w y|strong="H5921"\w* \w el|strong="H5921"\w* corazón.   
\m
\v 10 \w Mi|strong="H4994"\w* defensa \add está\add* en Dios, \w que|strong="H4994"\w* salva \w a|strong="H3068"\w* los rectos \w de|strong="H6662"\w* \w corazón|strong="H3826"\w*.   
\m
\v 11 Dios es \w el|strong="H5921"\w* \w que|strong="H5921"\w* juzga \w al|strong="H5921"\w* justo; \w y|strong="H5921"\w* Dios \w está|strong="H5921"\w* airado todos \w los|strong="H5921"\w* días \add contra el impío\add*.   
\m
\v 12 Si no se convierte, \w Él|strong="H3605"\w* afilará su espada: Ha tensado ya su arco, y \w lo|strong="H3605"\w* ha preparado.   
\m
\v 13 También \w ha|strong="H3808"\w* preparado para él los instrumentos de muerte; \w ha|strong="H3808"\w* ordenado sus saetas contra los perseguidores.   
\m
\v 14 He aquí, \add el impío\add* ha gestado iniquidad; concibió maldad, y dio \w a|strong="H3068"\w* luz engaño.   
\m
\v 15 Ha cavado un pozo, y lo ha ahondado; y en el pozo \add que\add* hizo caerá.   
\m
\v 16 Su maldad se volverá sobre su cabeza, y su agravio \w caerá|strong="H5307"\w* sobre su propia coronilla.   
\m
\v 17 Alabaré \w a|strong="H3068"\w* Jehová \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* su justicia, \w y|strong="H5921"\w* cantaré alabanzas \w al|strong="H5921"\w* nombre \w de|strong="H5921"\w* Jehová, \w el|strong="H5921"\w* Altísimo.   
\c 8
\d Al Músico principal: sobre Gitit: Salmo de David  
\m
\v 1 Oh Jehová, Señor nuestro, ¡Cuán grande es tu nombre \w en|strong="H5921"\w* \w toda|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w que|strong="H5921"\w* has puesto tu gloria \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* cielos!   
\m
\v 2 \w De|strong="H5921"\w* \w la|strong="H5921"\w* boca \w de|strong="H5921"\w* \w los|strong="H5921"\w* niños \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H4100"\w* maman, fundaste \w la|strong="H5921"\w* fortaleza, \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* tus enemigos, \w para|strong="H5921"\w* hacer cesar \w al|strong="H5921"\w* enemigo \w y|strong="H5921"\w* \w al|strong="H5921"\w* vengativo.   
\m
\v 3 Cuando veo tus cielos, obra de tus dedos, la luna \w y|strong="H5797"\w* las estrellas \w que|strong="H6310"\w* tú formaste:   
\m
\v 4 Digo: ¿\w Qué|strong="H3588"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* hombre, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w* \w te|strong="H3588"\w* acuerdes, \w y|strong="H3588"\w* \w el|strong="H3588"\w* hijo del hombre, \w para|strong="H3588"\w* \w que|strong="H3588"\w* lo visites?   
\m
\v 5 \w Lo|strong="H4100"\w* has hecho un poco menor \w que|strong="H3588"\w* \w los|strong="H1121"\w* ángeles, \w y|strong="H3588"\w* \w lo|strong="H4100"\w* has coronado \w de|strong="H3588"\w* gloria \w y|strong="H3588"\w* \w de|strong="H3588"\w* honra.   
\m
\v 6 Le hiciste señorear sobre las obras de tus manos; todo lo pusiste debajo de sus pies;   
\m
\v 7 ovejas y bueyes, \w todo|strong="H3605"\w* ello; y también las bestias del campo,   
\m
\v 8 las aves del cielo \w y|strong="H1571"\w* \w los|strong="H3605"\w* peces del mar; \add todo cuanto\add* pasa por \w los|strong="H3605"\w* senderos del mar.   
\m
\v 9 Oh Jehová, Señor nuestro, ¡Cuán grande \add es\add* tu nombre en toda la tierra!   
\c 9
\d Al Músico principal: sobre Mutlaben: Salmo de David  
\m
\v 1 Te alabaré, oh Jehová, con todo mi corazón; Contaré todas tus obras maravillosas.   
\m
\v 2 Me alegraré y me regocijaré en ti; \w cantaré|strong="H3034"\w* alabanzas \w a|strong="H3068"\w* tu nombre, oh Altísimo;   
\m
\v 3 Cuando mis enemigos vuelvan atrás; caerán y perecerán ante tu presencia.   
\m
\v 4 \w Porque|strong="H6440"\w* tú has sostenido mi derecho y mi \w causa|strong="H6440"\w*; te sientas en el trono juzgando \add con\add* justicia.   
\m
\v 5 Reprendiste \w a|strong="H3068"\w* las naciones, destruiste al malo, has borrado \w el|strong="H3588"\w* nombre \w de|strong="H3588"\w* ellos eternamente \w y|strong="H3588"\w* \w para|strong="H3588"\w* siempre.   
\m
\v 6 Oh enemigo, se han acabado \w para|strong="H5703"\w* \w siempre|strong="H5769"\w* los asolamientos, y las ciudades que derribaste; su memoria pereció con ellas.   
\m
\v 7 Mas Jehová \w permanecerá|strong="H5331"\w* para siempre; ha preparado \w su|strong="H1992"\w* trono para juicio.   
\m
\v 8 \w Y|strong="H3068"\w* \w Él|strong="H3427"\w* juzgará al mundo con \w justicia|strong="H4941"\w*; y juzgará \w a|strong="H3068"\w* \w los|strong="H3427"\w* pueblos con \w rectitud|strong="H3559"\w*.   
\m
\v 9 Jehová \w será|strong="H1931"\w* refugio al oprimido, refugio en \w los|strong="H1931"\w* tiempos de angustia.   
\m
\v 10 \w Los|strong="H1961"\w* \w que|strong="H1961"\w* conocen tu nombre pondrán su confianza en ti; porque tú, oh \w Jehová|strong="H3068"\w*, \w no|strong="H1961"\w* has abandonado \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w que|strong="H1961"\w* te buscan.   
\m
\v 11 Cantad alabanzas \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \w que|strong="H3588"\w* habita \w en|strong="H3588"\w* Sión; proclamad \w entre|strong="H3808"\w* \w los|strong="H3588"\w* pueblos sus obras.   
\m
\v 12 Cuando demanda la sangre, \w se|strong="H5971"\w* acuerda \w de|strong="H5971"\w* ellos; no \w se|strong="H5971"\w* olvida del clamor \w de|strong="H5971"\w* \w los|strong="H3427"\w* humildes.   
\m
\v 13 Ten misericordia \w de|strong="H3588"\w* mí, oh Jehová; mira mi aflicción \w que|strong="H3588"\w* padezco \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* aborrecen, tú \w que|strong="H3588"\w* \w me|strong="H3588"\w* levantas \w de|strong="H3588"\w* las puertas \w de|strong="H3588"\w* \w la|strong="H3588"\w* muerte;   
\m
\v 14 Para que cuente yo todas tus alabanzas en las \w puertas|strong="H8179"\w* de la hija de Sión: Me regocijaré en tu salvación.   
\m
\v 15 Se hundieron las naciones en \w el|strong="H3605"\w* pozo \w que|strong="H1323"\w* hicieron; en \w la|strong="H3605"\w* red \w que|strong="H1323"\w* escondieron fue atrapado su pie.   
\m
\v 16 Jehová es conocido por \w el|strong="H6213"\w* juicio \w que|strong="H2098"\w* ejecuta; en la \w obra|strong="H6213"\w* de sus propias manos es atrapado \w el|strong="H6213"\w* impío. (Higaion. Selah)   
\m
\v 17 Los malos \w serán|strong="H4941"\w* trasladados al infierno, \add y\add* todas las naciones \w que|strong="H3045"\w* \w se|strong="H3045"\w* olvidan de \w Dios|strong="H3068"\w*.   
\m
\v 18 Porque \w el|strong="H3605"\w* pobre \w no|strong="H7563"\w* será olvidado para \w siempre|strong="H3605"\w*; ni \w la|strong="H3605"\w* esperanza de \w los|strong="H3605"\w* pobres perecerá eternamente.   
\m
\v 19 Levántate, oh Jehová; \w no|strong="H3808"\w* prevalezca \w el|strong="H3588"\w* hombre; sean juzgadas las naciones delante \w de|strong="H3588"\w* ti.   
\m
\v 20 Pon, oh \w Jehová|strong="H3068"\w*, temor \w en|strong="H5921"\w* \w ellos|strong="H5921"\w*; \add para que\add* conozcan \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H5921"\w* \w no|strong="H5921"\w* son sino hombres. (Selah)   
\c 10
\m
\v 1 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w estás|strong="H5975"\w* \w lejos|strong="H7350"\w*, \w oh|strong="H4100"\w* \w Jehová|strong="H3068"\w*, y te escondes \w en|strong="H5975"\w* el \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* la \w tribulación|strong="H6869"\w*?   
\m
\v 2 Con arrogancia el malo \w persigue|strong="H1814"\w* al \w pobre|strong="H6041"\w*; sean atrapados en los artificios \w que|strong="H2098"\w* han ideado.   
\m
\v 3 \w Porque|strong="H3588"\w* \w el|strong="H5921"\w* malo \w se|strong="H5921"\w* jacta \w del|strong="H5921"\w* \w deseo|strong="H8378"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w corazón|strong="H5315"\w*, \w y|strong="H3588"\w* \w bendice|strong="H1288"\w* \w al|strong="H5921"\w* codicioso \add al cual\add* aborrece \w Jehová|strong="H3068"\w*.   
\m
\v 4 \w El|strong="H3605"\w* malo, por \w la|strong="H3605"\w* altivez de su rostro, \w no|strong="H1077"\w* \w busca|strong="H1875"\w* \add a Dios\add*; Dios \w no|strong="H1077"\w* está en \w ninguno|strong="H3605"\w* de sus pensamientos.   
\m
\v 5 Sus \w caminos|strong="H1870"\w* son torcidos en \w todo|strong="H3605"\w* \w tiempo|strong="H6256"\w*; tus \w juicios|strong="H4941"\w* \w los|strong="H3605"\w* tiene muy lejos \w de|strong="H5048"\w* su vista, y desprecia \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus enemigos.   
\m
\v 6 Dice en su \w corazón|strong="H3820"\w*: \w No|strong="H3808"\w* \w seré|strong="H3808"\w* movido: \w Nunca|strong="H3808"\w* \add me alcanzará\add* la adversidad.   
\m
\v 7 Su \w boca|strong="H6310"\w* está \w llena|strong="H4390"\w* \w de|strong="H8478"\w* maldición, \w de|strong="H8478"\w* \w engaño|strong="H4820"\w* y \w de|strong="H8478"\w* fraude; \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* su \w lengua|strong="H3956"\w* \add hay\add* malicia y vanidad.   
\m
\v 8 Se sienta al acecho \w en|strong="H5355"\w* las \w aldeas|strong="H2691"\w*; \w en|strong="H5355"\w* \w los|strong="H3427"\w* escondrijos \w mata|strong="H2026"\w* al \w inocente|strong="H5355"\w*; sus \w ojos|strong="H5869"\w* \w están|strong="H3427"\w* acechando al pobre.   
\m
\v 9 Acecha en oculto, como el león desde su cueva; acecha para atrapar al \w pobre|strong="H6041"\w*; atrapa al \w pobre|strong="H6041"\w* \w trayéndolo|strong="H4900"\w* \w a|strong="H3068"\w* su \w red|strong="H7568"\w*.   
\m
\v 10 Se agazapa, se encoge, y \w caen|strong="H5307"\w* en sus garras muchos desdichados.   
\m
\v 11 Dice en su \w corazón|strong="H3820"\w*: Dios se ha olvidado, ha \w escondido|strong="H5641"\w* su \w rostro|strong="H6440"\w*; \w nunca|strong="H5331"\w* lo \w verá|strong="H7200"\w*.   
\m
\v 12 \w Levántate|strong="H6965"\w*, oh \w Jehová|strong="H3068"\w*. oh \w Dios|strong="H3068"\w*, \w alza|strong="H5375"\w* tu \w mano|strong="H3027"\w*, no te \w olvides|strong="H7911"\w* \w de|strong="H7911"\w* los humildes.   
\m
\v 13 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w el|strong="H5921"\w* malo desprecia \w a|strong="H3068"\w* Dios? \w Ha|strong="H3808"\w* dicho \w en|strong="H5921"\w* su \w corazón|strong="H3820"\w*: Tú \w no|strong="H3808"\w* pedirás cuentas.   
\m
\v 14 Tú \w lo|strong="H5921"\w* \w has|strong="H5414"\w* \w visto|strong="H7200"\w*; \w porque|strong="H3588"\w* tú miras \w la|strong="H5921"\w* maldad \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w vejación|strong="H5999"\w*, \w para|strong="H5921"\w* cobrar venganza \w con|strong="H5921"\w* tu \w mano|strong="H3027"\w*: \w En|strong="H5921"\w* \w ti|strong="H5921"\w* \w se|strong="H1961"\w* refugia \w el|strong="H5921"\w* pobre, tú \w eres|strong="H1961"\w* \w el|strong="H5921"\w* amparo \w del|strong="H5921"\w* \w huérfano|strong="H3490"\w*.   
\m
\v 15 Quiebra tú el \w brazo|strong="H2220"\w* del \w impío|strong="H7563"\w* y del \add hombre\add* maligno; persigue su \w maldad|strong="H7451"\w*, \add hasta que\add* \w no|strong="H1077"\w* \w halles|strong="H4672"\w* ninguna.   
\m
\v 16  \w Jehová|strong="H3068"\w* \add es\add* \w Rey|strong="H4428"\w* \w eternamente|strong="H5769"\w* y \w para|strong="H5703"\w* \w siempre|strong="H5769"\w*; de su tierra han perecido las \w naciones|strong="H1471"\w*.   
\m
\v 17 El \w deseo|strong="H8378"\w* de los humildes has \w oído|strong="H8085"\w*: oh \w Jehová|strong="H3068"\w*: Tú prepararás su \w corazón|strong="H3820"\w*, \w e|strong="H3068"\w* inclinarás tu \w oído|strong="H8085"\w* para \w oír|strong="H8085"\w*;   
\m
\v 18 \w para|strong="H4480"\w* juzgar \w al|strong="H4480"\w* \w huérfano|strong="H3490"\w* y \w al|strong="H4480"\w* oprimido, \w para|strong="H4480"\w* \w que|strong="H4480"\w* el hombre \w de|strong="H4480"\w* la tierra \w no|strong="H1077"\w* oprima \w más|strong="H5750"\w*.   
\c 11
\d Al Músico principal: \add Salmo\add* de David  
\m
\v 1 En \w Jehová|strong="H3068"\w* he confiado; ¿Cómo decís \w a|strong="H3068"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*: Escapa \w a|strong="H3068"\w* tu montaña \add cual\add* \w ave|strong="H6833"\w*?   
\m
\v 2 \w Porque|strong="H3588"\w* he \w aquí|strong="H2009"\w*, \w los|strong="H5921"\w* malos tensan \w el|strong="H5921"\w* \w arco|strong="H7198"\w*, \w preparan|strong="H3559"\w* \w su|strong="H3588"\w* \w saeta|strong="H2671"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* cuerda, \w para|strong="H5921"\w* disparar \w en|strong="H5921"\w* oculto \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w rectos|strong="H3477"\w* \w de|strong="H5921"\w* \w corazón|strong="H3820"\w*.   
\m
\v 3 \w Si|strong="H3588"\w* \w los|strong="H3588"\w* fundamentos fueren \w destruidos|strong="H2040"\w*, ¿\w Qué|strong="H3588"\w* podrá hacer \w el|strong="H3588"\w* \w justo|strong="H6662"\w*?   
\m
\v 4 \w Jehová|strong="H3068"\w* \add está\add* en su \w santo|strong="H6944"\w* \w templo|strong="H1964"\w*: \w El|strong="H1121"\w* \w trono|strong="H3678"\w* \w de|strong="H1121"\w* \w Jehová|strong="H3068"\w* \add está\add* en \w el|strong="H1121"\w* \w cielo|strong="H8064"\w*: Sus \w ojos|strong="H5869"\w* \w ven|strong="H2372"\w*, sus \w párpados|strong="H6079"\w* examinan \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*.   
\m
\v 5 \w Jehová|strong="H3068"\w* prueba al \w justo|strong="H6662"\w*; pero al \w malo|strong="H2555"\w* y al que ama la \w violencia|strong="H2555"\w*, su \w alma|strong="H5315"\w* \w aborrece|strong="H8130"\w*.   
\m
\v 6 \w Sobre|strong="H5921"\w* \w los|strong="H5921"\w* malos \w lloverá|strong="H4305"\w* \w lazos|strong="H6341"\w*; fuego, \w azufre|strong="H1614"\w* \w y|strong="H5921"\w* terrible tempestad; \add esta será\add* \w la|strong="H5921"\w* porción \w de|strong="H5921"\w* su copa.   
\m
\v 7 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w justo|strong="H6662"\w* \w Jehová|strong="H3068"\w* ama \w la|strong="H3588"\w* \w justicia|strong="H6666"\w*; \w su|strong="H3588"\w* \w rostro|strong="H6440"\w* contempla \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w rectos|strong="H3477"\w*.   
\c 12
\d Al Músico principal: sobre Seminit: Salmo de David  
\m
\v 1 Salva, oh Jehová, \w porque|strong="H5921"\w* \w se|strong="H5921"\w* acabaron \w los|strong="H5921"\w* piadosos; \w porque|strong="H5921"\w* han desaparecido \w los|strong="H5921"\w* fieles \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* \w los|strong="H5921"\w* hombres.   
\m
\v 2 Mentira habla cada uno \w con|strong="H3588"\w* \w su|strong="H3588"\w* prójimo; hablan \add con\add* labios lisonjeros \add y\add* \w con|strong="H3588"\w* doblez \w de|strong="H3588"\w* corazón.   
\m
\v 3 Jehová cortará todo \w labio|strong="H8193"\w* lisonjero, \add y\add* la \w lengua|strong="H8193"\w* que \w habla|strong="H1696"\w* soberbias;   
\m
\v 4 \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* han \w dicho|strong="H1696"\w*: Por nuestra \w lengua|strong="H3956"\w* prevaleceremos; nuestros \w labios|strong="H8193"\w* \add son\add* nuestros; ¿\w quién|strong="H3605"\w* es \w señor|strong="H3068"\w* sobre \w nosotros|strong="H3605"\w*?   
\m
\v 5 Por la opresión del pobre, por \w el|strong="H4310"\w* gemido del necesitado, ahora \w me|strong="H4310"\w* levantaré, dice Jehová; \w le|strong="H4310"\w* pondré \w a|strong="H3068"\w* salvo del \w que|strong="H4310"\w* hace alarde contra \w él|strong="H4310"\w*.   
\m
\v 6 Las palabras de \w Jehová|strong="H3068"\w* \add son\add* palabras puras; \add como\add* plata refinada en horno de tierra, purificada siete veces.   
\m
\v 7 Tú, oh \w Jehová|strong="H3068"\w*, las guardarás; tú las preservarás de esta generación para siempre.   
\m
\v 8 Asediando andan los malos, cuando son exaltados los \w más|strong="H4480"\w* viles \w de|strong="H4480"\w* los hombres.   
\c 13
\d Al Músico principal: Salmo de David  
\m
\v 1 ¿\w Hasta|strong="H5329"\w* cuándo, oh Jehová? ¿Me olvidarás para siempre? ¿\w Hasta|strong="H5329"\w* cuándo esconderás tu rostro de mí?   
\m
\v 2 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* pondré consejos \w en|strong="H4480"\w* mi alma, \add con\add* ansiedad \w en|strong="H4480"\w* mi corazón cada día? ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* será enaltecido mi enemigo \w sobre|strong="H4480"\w* mí?   
\m
\v 3 Mira, óyeme, oh Jehová Dios \w mío|strong="H5921"\w*; alumbra mis ojos, \w para|strong="H5704"\w* \w que|strong="H5921"\w* \w no|strong="H5921"\w* duerma \w en|strong="H5921"\w* muerte;   
\m
\v 4 Para \w que|strong="H6435"\w* \w no|strong="H6435"\w* diga \w mi|strong="H6030"\w* enemigo: Lo he vencido: Mis enemigos \w se|strong="H6435"\w* alegrarán, \w si|strong="H6435"\w* yo resbalare;   
\m
\v 5 \w mas|strong="H3588"\w* \w yo|strong="H3588"\w* \w en|strong="H3588"\w* tu misericordia he confiado; \w Se|strong="H6435"\w* alegrará mi corazón \w en|strong="H3588"\w* tu salvación.   
\m
\v 6 \w Cantaré|strong="H7891"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \w porque|strong="H3588"\w* \w me|strong="H5921"\w* \w ha|strong="H1580"\w* hecho \w bien|strong="H3588"\w*.   
\c 14
\d Al Músico principal: \add Salmo\add* de David  
\m
\v 1 Dijo \w el|strong="H6213"\w* necio en su \w corazón|strong="H3820"\w*: \w No|strong="H6213"\w* hay Dios. Se corrompieron, \w hicieron|strong="H6213"\w* \w obras|strong="H5949"\w* \w abominables|strong="H8581"\w*; \w no|strong="H6213"\w* hay \w quien|strong="H6213"\w* \w haga|strong="H6213"\w* \w el|strong="H6213"\w* \w bien|strong="H2896"\w*.   
\m
\v 2 \w Jehová|strong="H3068"\w* \w miró|strong="H7200"\w* \w desde|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w* \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*, \w para|strong="H5921"\w* \w ver|strong="H7200"\w* \w si|strong="H5921"\w* \w había|strong="H3426"\w* algún \w entendido|strong="H7919"\w*, \w que|strong="H5921"\w* buscara \w a|strong="H3068"\w* \w Dios|strong="H3068"\w*.   
\m
\v 3 \w Todos|strong="H3605"\w* se han desviado, \w a|strong="H3068"\w* una se han corrompido; \w no|strong="H6213"\w* hay \w quien|strong="H3605"\w* \w haga|strong="H6213"\w* \w el|strong="H3605"\w* \w bien|strong="H2896"\w*, \w no|strong="H6213"\w* hay \w ni|strong="H1571"\w* siquiera uno.   
\m
\v 4 ¿\w No|strong="H3808"\w* tienen \w conocimiento|strong="H3045"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* obradores \w de|strong="H5971"\w* iniquidad, \w que|strong="H3808"\w* devoran \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* \add como\add* \w si|strong="H3808"\w* comieran \w pan|strong="H3899"\w*, y \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* \w no|strong="H3808"\w* \w invocan|strong="H7121"\w*?   
\m
\v 5 \w Allí|strong="H8033"\w* temblaron \w de|strong="H3588"\w* \w espanto|strong="H6343"\w*; \w porque|strong="H3588"\w* Dios \add está\add* \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w generación|strong="H1755"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w justos|strong="H6662"\w*.   
\m
\v 6 Del \w consejo|strong="H6098"\w* del \w pobre|strong="H6041"\w* se han burlado, \w porque|strong="H3588"\w* \w Jehová|strong="H3068"\w* \add es\add* \w su|strong="H3588"\w* refugio.   
\m
\v 7 ¡\w Oh|strong="H4310"\w* \w que|strong="H4310"\w* \w de|strong="H5971"\w* \w Sión|strong="H6726"\w* \add saliera\add* la salvación \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*! Cuando \w Jehová|strong="H3068"\w* \w haga|strong="H5414"\w* \w volver|strong="H7725"\w* \w a|strong="H3068"\w* los cautivos \w de|strong="H5971"\w* su \w pueblo|strong="H5971"\w*, \w se|strong="H5971"\w* gozará \w Jacob|strong="H3290"\w*, y \w se|strong="H5971"\w* alegrará \w Israel|strong="H3478"\w*.   
\c 15
\d Salmo de David  
\m
\v 1 \w Jehová|strong="H3068"\w*, ¿\w quién|strong="H4310"\w* \w habitará|strong="H7931"\w* en tu tabernáculo? ¿\w Quién|strong="H4310"\w* \w morará|strong="H7931"\w* en tu \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*?   
\m
\v 2 El que \w anda|strong="H1980"\w* \w en|strong="H8549"\w* integridad y \w obra|strong="H6466"\w* \w justicia|strong="H6664"\w*, y \w habla|strong="H1696"\w* verdad \w en|strong="H8549"\w* su \w corazón|strong="H3824"\w*.   
\m
\v 3 \add El que\add* \w no|strong="H3808"\w* calumnia \w con|strong="H5921"\w* su \w lengua|strong="H3956"\w*, \w ni|strong="H3808"\w* \w hace|strong="H6213"\w* \w mal|strong="H7451"\w* \w a|strong="H3068"\w* su \w prójimo|strong="H7453"\w*, \w ni|strong="H3808"\w* admite reproche \w contra|strong="H5921"\w* su \w prójimo|strong="H7453"\w*.   
\m
\v 4 \add Aquel\add* \w a|strong="H3068"\w* cuyos \w ojos|strong="H5869"\w* es menospreciado el vil; \w mas|strong="H3808"\w* \w honra|strong="H3513"\w* \w a|strong="H3068"\w* los \w que|strong="H3808"\w* temen \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*; \add el que\add* \w aun|strong="H3808"\w* jurando en daño \add suyo\add*, \w no|strong="H3808"\w* cambia;   
\m
\v 5 \add quien\add* su \w dinero|strong="H3701"\w* \w no|strong="H3808"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w usura|strong="H5392"\w*, \w ni|strong="H3808"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w inocente|strong="H5355"\w* \w tomó|strong="H3947"\w* \w cohecho|strong="H7810"\w*. \w El|strong="H5921"\w* \w que|strong="H3808"\w* \w hace|strong="H6213"\w* \w estas|strong="H6213"\w* cosas, \w jamás|strong="H5769"\w* \w será|strong="H3808"\w* removido.   
\c 16
\d Mictam de David  
\m
\v 1 \w Guárdame|strong="H8104"\w*, oh Dios, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* ti he confiado.   
\m
\v 2 \add Oh alma mía\add*, dijiste \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*: Tú \add eres\add* \w mi|strong="H5921"\w* \w Señor|strong="H3068"\w*; \w mi|strong="H5921"\w* \w bien|strong="H2896"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w no|strong="H1077"\w* aprovecha;   
\m
\v 3 \add sino\add* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w santos|strong="H6918"\w* \w que|strong="H1992"\w* \add están\add* en \w la|strong="H3605"\w* tierra, y \w a|strong="H3068"\w* \w los|strong="H1992"\w* íntegros, en quienes \add está\add* \w toda|strong="H3605"\w* mi complacencia.   
\m
\v 4 \w Se|strong="H5921"\w* multiplicarán \w los|strong="H5921"\w* dolores \w de|strong="H5921"\w* aquellos \w que|strong="H5921"\w* sirven diligentes \w a|strong="H3068"\w* \w otro|strong="H8193"\w* \add dios\add*: \w No|strong="H1077"\w* \w ofreceré|strong="H5262"\w* yo sus \w libaciones|strong="H5262"\w* \w de|strong="H5921"\w* \w sangre|strong="H1818"\w*, \w ni|strong="H1077"\w* \w en|strong="H5921"\w* \w mis|strong="H5375"\w* \w labios|strong="H8193"\w* \w tomaré|strong="H5375"\w* sus \w nombres|strong="H8034"\w*.   
\m
\v 5 \w Jehová|strong="H3068"\w* es la \w porción|strong="H4490"\w* de mi herencia y de mi copa. Tú sustentas mi \w suerte|strong="H1486"\w*.   
\m
\v 6 \w Las|strong="H5921"\w* cuerdas \w me|strong="H5921"\w* \w cayeron|strong="H5307"\w* \w en|strong="H5921"\w* lugares deleitosos, \w y|strong="H5921"\w* es hermosa \w la|strong="H5921"\w* \w heredad|strong="H5159"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* ha tocado.   
\m
\v 7 \w Bendeciré|strong="H1288"\w* \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* que me aconseja; aun en las \w noches|strong="H3915"\w* me enseñan mis \w riñones|strong="H3629"\w*.   
\m
\v 8 \w A|strong="H3068"\w* \w Jehová|strong="H3068"\w* he \w puesto|strong="H3588"\w* \w siempre|strong="H8548"\w* \w delante|strong="H5048"\w* \w de|strong="H3588"\w* mí; \w porque|strong="H3588"\w* está \w a|strong="H3068"\w* mi \w diestra|strong="H3225"\w* \w no|strong="H1077"\w* seré \w conmovido|strong="H4131"\w*.   
\m
\v 9 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, mi \w corazón|strong="H3820"\w* \w se|strong="H3651"\w* \w alegra|strong="H8055"\w*, \w y|strong="H3519"\w* \w se|strong="H3651"\w* goza mi \w gloria|strong="H3519"\w*; \w también|strong="H3651"\w* mi \w carne|strong="H1320"\w* \w reposará|strong="H7931"\w* segura.   
\m
\v 10 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* \w dejarás|strong="H5800"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* infierno; \w ni|strong="H3808"\w* \w permitirás|strong="H5414"\w* \w que|strong="H3588"\w* tu \w Santo|strong="H2623"\w* \w vea|strong="H7200"\w* \w corrupción|strong="H7845"\w*.   
\m
\v 11 Me mostrarás la senda \w de|strong="H6440"\w* la \w vida|strong="H2416"\w*: Plenitud \w de|strong="H6440"\w* \w gozo|strong="H8057"\w* hay en tu \w presencia|strong="H6440"\w*; delicias en tu \w diestra|strong="H3225"\w* para siempre.   
\c 17
\d Oración de David  
\m
\v 1 \w Oye|strong="H8085"\w*, oh \w Jehová|strong="H3068"\w*, el derecho; \w atiende|strong="H7181"\w* \w a|strong="H3068"\w* mi \w clamor|strong="H7440"\w*; \w escucha|strong="H8085"\w* mi \w oración|strong="H8605"\w* hecha de \w labios|strong="H8193"\w* \w sin|strong="H3808"\w* \w engaño|strong="H4820"\w*.   
\m
\v 2 \w De|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* tu \w rostro|strong="H6440"\w* \w salga|strong="H3318"\w* mi \w juicio|strong="H4941"\w*; \w vean|strong="H2372"\w* tus \w ojos|strong="H5869"\w* la rectitud.   
\m
\v 3 Tú has probado mi \w corazón|strong="H3820"\w*, \add me\add* has visitado de \w noche|strong="H3915"\w*: Me has puesto \w a|strong="H3068"\w* prueba, y nada \w hallaste|strong="H4672"\w*; me he propuesto \w que|strong="H6310"\w* mi \w boca|strong="H6310"\w* \w no|strong="H1077"\w* haga transgresión.   
\m
\v 4 En cuanto \w a|strong="H3068"\w* las obras \w de|strong="H1697"\w* los hombres, \w por|strong="H1697"\w* \w la|strong="H8104"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* tus \w labios|strong="H8193"\w* yo me he \w guardado|strong="H8104"\w* \w de|strong="H1697"\w* las sendas del destructor.   
\m
\v 5 \w Sustenta|strong="H8551"\w* mis pasos en tus \w caminos|strong="H4570"\w*, para que mis \w pies|strong="H6471"\w* \w no|strong="H1077"\w* \w resbalen|strong="H4131"\w*.   
\m
\v 6 \w Yo|strong="H3588"\w* \w te|strong="H3588"\w* he \w invocado|strong="H7121"\w*, \w porque|strong="H3588"\w* tú \w me|strong="H3588"\w* \w oirás|strong="H8085"\w*, oh Dios: \w Inclina|strong="H5186"\w* \w a|strong="H3068"\w* \w mí|strong="H6030"\w* tu \w oído|strong="H8085"\w*, \w escucha|strong="H8085"\w* \w mi|strong="H6030"\w* palabra.   
\m
\v 7 Muestra tus maravillosas \w misericordias|strong="H2617"\w*, tú que con tu \w diestra|strong="H3225"\w* salvas \w a|strong="H3068"\w* los que \add en ti\add* confían de los que se \w levantan|strong="H6965"\w* \add contra ellos\add*.   
\m
\v 8 \w Guárdame|strong="H8104"\w* como \w a|strong="H3068"\w* \w la|strong="H8104"\w* niña \w de|strong="H5869"\w* tu \w ojo|strong="H5869"\w*, \w escóndeme|strong="H5641"\w* bajo \w la|strong="H8104"\w* \w sombra|strong="H6738"\w* \w de|strong="H5869"\w* tus \w alas|strong="H3671"\w*,   
\m
\v 9 \w de|strong="H5921"\w* \w la|strong="H5921"\w* vista \w de|strong="H5921"\w* \w los|strong="H5921"\w* malos \w que|strong="H2098"\w* \w me|strong="H5921"\w* oprimen, \w de|strong="H5921"\w* mis enemigos mortales \w que|strong="H2098"\w* \w me|strong="H5921"\w* rodean.   
\m
\v 10 Encerrados están en su propia \w grosura|strong="H2459"\w*; con su \w boca|strong="H6310"\w* \w hablan|strong="H1696"\w* soberbiamente.   
\m
\v 11 \w Ahora|strong="H6258"\w* han cercado nuestros pasos; han puesto sus \w ojos|strong="H5869"\w* inclinados hacia la tierra.   
\m
\v 12 \w Como|strong="H3715"\w* león que desea hacer presa, y \w como|strong="H3715"\w* \w leoncillo|strong="H3715"\w* que acecha en su escondite.   
\m
\v 13 \w Levántate|strong="H6965"\w*, oh \w Jehová|strong="H3068"\w*; sal \w a|strong="H3068"\w* su encuentro, derríbale; \w libra|strong="H6403"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* del malo con tu \w espada|strong="H2719"\w*.   
\m
\v 14 \add Líbrame\add* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H4962"\w*, con tu \w mano|strong="H3027"\w*, \w oh|strong="H1121"\w* \w Jehová|strong="H3068"\w*, \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H4962"\w* del mundo, \w que|strong="H1121"\w* tienen su porción en esta \w vida|strong="H2416"\w* y cuyo vientre \w llenas|strong="H4390"\w* \w de|strong="H1121"\w* tu \add tesoro\add* escondido; están \w llenos|strong="H4390"\w* \w de|strong="H1121"\w* \w hijos|strong="H1121"\w*, y dejan \w el|strong="H1121"\w* \w resto|strong="H3499"\w* \w a|strong="H3068"\w* sus pequeños.   
\m
\v 15 En cuanto \w a|strong="H3068"\w* mí, yo en \w justicia|strong="H6664"\w* \w veré|strong="H2372"\w* tu \w rostro|strong="H6440"\w*; quedaré satisfecho cuando despierte \w a|strong="H3068"\w* tu \w semejanza|strong="H8544"\w*.   
\c 18
\d Al Músico principal: \add Salmo\add* de David, siervo de Jehová, el cual dijo a Jehová las palabras de este cántico el día que Jehová lo libró de la mano de todos sus enemigos, y de la mano de Saúl. Entonces dijo:  
\m
\v 1 Te amaré, oh \w Jehová|strong="H3068"\w*, fortaleza mía.   
\m
\v 2 \w Jehová|strong="H3068"\w* \add es\add* mi Roca, mi castillo y mi Libertador; mi \w Dios|strong="H3068"\w*, mi \w fortaleza|strong="H2391"\w*, en Él confiaré; mi escudo, el cuerno de mi salvación, y mi alto refugio.   
\m
\v 3 Invocaré \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w*, \add quien es digno\add* de ser alabado, y seré salvo de mis enemigos.   
\m
\v 4 \w Me|strong="H4480"\w* rodearon los dolores \w de|strong="H4480"\w* la muerte, y torrentes \w de|strong="H4480"\w* hombres perversos \w me|strong="H4480"\w* atemorizaron.   
\m
\v 5 \w Dolores|strong="H2256"\w* del infierno me rodearon, me previnieron lazos de \w muerte|strong="H4194"\w*.   
\m
\v 6 En mi angustia invoqué \w a|strong="H3068"\w* Jehová, y clamé \w a|strong="H3068"\w* mi Dios: Él oyó mi voz desde su templo, y mi clamor llegó \w delante|strong="H6923"\w* de Él, \w a|strong="H3068"\w* sus oídos.   
\m
\v 7 Entonces se estremeció y tembló la tierra; y los cimientos \w de|strong="H6440"\w* los collados se conmovieron y fueron sacudidos, \w porque|strong="H6440"\w* se indignó Él.   
\m
\v 8 Humo subió \w de|strong="H3588"\w* \w su|strong="H3588"\w* nariz, \w y|strong="H3588"\w* \w el|strong="H3588"\w* fuego \w de|strong="H3588"\w* \w su|strong="H3588"\w* boca consumía; carbones fueron \w por|strong="H3588"\w* \w él|strong="H3588"\w* encendidos.   
\m
\v 9 Inclinó también los cielos, \w y|strong="H1197"\w* descendió; \w y|strong="H1197"\w* densa oscuridad \add había\add* debajo \w de|strong="H4480"\w* sus pies.   
\m
\v 10 \w Y|strong="H3068"\w* cabalgó sobre un querubín, y voló: Voló sobre las alas del viento.   
\m
\v 11 Hizo \w de|strong="H5921"\w* \w las|strong="H5921"\w* tinieblas su lugar secreto; Su pabellón \w alrededor|strong="H5921"\w* \w de|strong="H5921"\w* \w sí|strong="H5921"\w* \add eran\add* aguas oscuras \w y|strong="H5921"\w* densas nubes \w de|strong="H5921"\w* \w los|strong="H5921"\w* cielos.   
\m
\v 12 Por el resplandor \w de|strong="H4325"\w* su presencia, sus densas \w nubes|strong="H5645"\w* pasaron; granizo y carbones encendidos.   
\m
\v 13  Jehová también tronó en los cielos, y \w el|strong="H5674"\w* Altísimo dio su voz; \w granizo|strong="H1259"\w* y \w carbones|strong="H1513"\w* encendidos.   
\m
\v 14 Envió sus saetas, y los dispersó; lanzó relámpagos, y los destruyó.   
\m
\v 15 Entonces aparecieron los senderos de las aguas, y se descubrieron los cimientos del mundo, \w a|strong="H3068"\w* tu reprensión, oh Jehová, por el soplo del aliento de tu nariz.   
\m
\v 16 Envió desde lo alto; me tomó, me sacó \w de|strong="H5397"\w* las muchas \w aguas|strong="H4325"\w*.   
\m
\v 17 Me libró \w de|strong="H4325"\w* mi poderoso enemigo, y \w de|strong="H4325"\w* los \w que|strong="H4325"\w* me aborrecían, \w pues|strong="H7971"\w* ellos eran \w más|strong="H7227"\w* fuertes \w que|strong="H4325"\w* yo.   
\m
\v 18 \w Me|strong="H4480"\w* asaltaron \w en|strong="H4480"\w* \w el|strong="H3588"\w* día \w de|strong="H4480"\w* mi calamidad; \w pero|strong="H3588"\w* Jehová fue mi sostén.   
\m
\v 19 Él me sacó \w a|strong="H3068"\w* lugar espacioso; me libró, porque \w se|strong="H1961"\w* agradó de \w mí|strong="H1961"\w*.   
\m
\v 20 Jehová \w me|strong="H3588"\w* pagó conforme \w a|strong="H3068"\w* mi justicia; conforme \w a|strong="H3068"\w* \w la|strong="H3588"\w* limpieza \w de|strong="H3588"\w* mis manos \w me|strong="H3588"\w* ha recompensado.   
\m
\v 21 Porque yo he guardado los caminos de \w Jehová|strong="H3068"\w*, y no me aparté impíamente de mi \w Dios|strong="H3068"\w*.   
\m
\v 22 \w Pues|strong="H3588"\w* todos sus juicios \add estuvieron\add* delante \w de|strong="H3588"\w* mí, \w y|strong="H3588"\w* \w no|strong="H3808"\w* aparté \w de|strong="H3588"\w* mí sus estatutos.   
\m
\v 23 También \w fui|strong="H3808"\w* íntegro \w delante|strong="H5048"\w* \w de|strong="H4480"\w* \w Él|strong="H3588"\w*, \w y|strong="H3588"\w* \w me|strong="H4480"\w* guardé \w de|strong="H4480"\w* mi iniquidad.   
\m
\v 24 Por tanto, Jehová \w me|strong="H5973"\w* pagó conforme \w a|strong="H3068"\w* \w mi|strong="H1961"\w* justicia; conforme \w a|strong="H3068"\w* \w la|strong="H8104"\w* limpieza \w de|strong="H5973"\w* mis manos \w delante|strong="H5973"\w* \w de|strong="H5973"\w* sus ojos.   
\m
\v 25 Con el misericordioso \w te|strong="H5869"\w* mostrarás misericordioso, y con el hombre íntegro \w te|strong="H5869"\w* mostrarás íntegro.   
\m
\v 26 Puro \w te|strong="H5973"\w* mostrarás \w para|strong="H5973"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* puro, y severo \w te|strong="H5973"\w* mostrarás \w para|strong="H5973"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* perverso.   
\m
\v 27 Porque tú salvarás al \w pueblo|strong="H5973"\w* afligido, y humillarás \w los|strong="H5973"\w* ojos altivos.   
\m
\v 28 \w Porque|strong="H3588"\w* tú encenderás mi lámpara: Jehová mi Dios alumbrará mis tinieblas.   
\m
\v 29 \w Pues|strong="H3588"\w* \w por|strong="H3588"\w* ti he desbaratado ejércitos; \w y|strong="H3588"\w* \w por|strong="H3588"\w* mi \w Dios|strong="H3068"\w* he saltado muros.   
\m
\v 30 \add En cuanto a\add* Dios, perfecto \add es\add* \w su|strong="H3588"\w* camino: \w La|strong="H3588"\w* palabra \w de|strong="H3588"\w* Jehová \w es|strong="H3588"\w* acrisolada: \w Es|strong="H3588"\w* escudo \w a|strong="H3068"\w* todos \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w Él|strong="H3588"\w* confían.   
\m
\v 31 Porque ¿\w quién|strong="H3605"\w* \add es\add* \w Dios|strong="H3068"\w* fuera de \w Jehová|strong="H3068"\w*? ¿\w Y|strong="H3068"\w* \w quién|strong="H3605"\w* \add es\add* una roca \w aparte|strong="H1931"\w* de nuestro \w Dios|strong="H3068"\w*?   
\m
\v 32 \w Dios|strong="H3068"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* ciñe \w de|strong="H3588"\w* poder, \w y|strong="H3588"\w* hace perfecto mi camino;   
\m
\v 33 Él hace \w mis|strong="H5414"\w* pies como \w de|strong="H5414"\w* ciervas, y me hace estar firme sobre \w mis|strong="H5414"\w* alturas;   
\m
\v 34 \w Él|strong="H5921"\w* adiestra mis manos \w para|strong="H5921"\w* \w la|strong="H5921"\w* batalla, \w y|strong="H5921"\w* \w el|strong="H5921"\w* arco \w de|strong="H5921"\w* acero será quebrado \w por|strong="H5921"\w* mis brazos.   
\m
\v 35 Me diste también el escudo de tu salvación, y tu diestra me sustentó, y tu benignidad me ha engrandecido.   
\m
\v 36 Ensanchaste \w mis|strong="H5414"\w* pasos debajo \w de|strong="H5414"\w* mí, \w para|strong="H5414"\w* que \w mis|strong="H5414"\w* pies no resbalasen.   
\m
\v 37 Perseguí \w a|strong="H3068"\w* mis enemigos, y los alcancé, y \w no|strong="H3808"\w* me volví hasta acabarlos.   
\m
\v 38 \w Los|strong="H7291"\w* herí, \w de|strong="H5704"\w* modo \w que|strong="H3808"\w* \w no|strong="H3808"\w* pudieron levantarse; cayeron debajo \w de|strong="H5704"\w* mis pies.   
\m
\v 39 Pues me ceñiste \w de|strong="H8478"\w* fuerza para la batalla; has sometido \w bajo|strong="H8478"\w* mis \w pies|strong="H7272"\w* \w a|strong="H3068"\w* los \w que|strong="H3808"\w* \w se|strong="H3808"\w* \w levantaron|strong="H6965"\w* contra mí.   
\m
\v 40 \w Y|strong="H3068"\w* me has dado la cerviz \w de|strong="H8478"\w* mis enemigos, para que yo destruya \w a|strong="H3068"\w* los que me aborrecen.   
\m
\v 41 Clamaron, pero no hubo quien \add los\add* salvara; \add aun\add* \w a|strong="H3068"\w* Jehová, pero Él no les respondió.   
\m
\v 42  Entonces \w los|strong="H5921"\w* molí \w como|strong="H5921"\w* polvo \w delante|strong="H5921"\w* \w del|strong="H5921"\w* viento; \w los|strong="H5921"\w* eché fuera \w como|strong="H5921"\w* lodo \w de|strong="H5921"\w* \w las|strong="H5921"\w* calles.   
\m
\v 43 \w Me|strong="H5921"\w* libraste \w de|strong="H5921"\w* \w las|strong="H5921"\w* contiendas \w del|strong="H5921"\w* pueblo; \w me|strong="H5921"\w* pusiste \w por|strong="H5921"\w* cabeza \w de|strong="H5921"\w* naciones; pueblo \w que|strong="H5921"\w* yo \w no|strong="H5921"\w* conocía, \w me|strong="H5921"\w* servirá.   
\m
\v 44 Al oír \w de|strong="H5971"\w* mí, me obedecerán; los extranjeros \w se|strong="H3045"\w* someterán \w a|strong="H3068"\w* mí;   
\m
\v 45 \w Los|strong="H1121"\w* \w extranjeros|strong="H1121"\w* se debilitarán, saldrán temblando \w de|strong="H1121"\w* sus escondrijos.   
\m
\v 46 Jehová vive, y bendita \add sea\add* mi Roca; y enaltecido sea \w el|strong="H1121"\w* Dios \w de|strong="H1121"\w* mi salvación:   
\m
\v 47 \add Es\add* \w Dios|strong="H3068"\w* quién por mí cobra venganza, y sujeta pueblos debajo de mí.   
\m
\v 48 Él me libra \w de|strong="H8478"\w* \w mis|strong="H5414"\w* enemigos: Sí, tú me enalteciste sobre los \w que|strong="H5971"\w* \w se|strong="H5971"\w* levantan contra mí; me \w has|strong="H5414"\w* librado del hombre violento.   
\m
\v 49 \w Por|strong="H4480"\w* tanto, \w te|strong="H4480"\w* confesaré \w entre|strong="H4480"\w* las naciones, oh Jehová, y cantaré alabanzas \w a|strong="H3068"\w* tu nombre.   
\m
\v 50 Grandes victorias da \w a|strong="H3068"\w* su rey, \w y|strong="H5921"\w* muestra misericordia \w a|strong="H3068"\w* su ungido, \w a|strong="H3068"\w* David \w y|strong="H5921"\w* \w a|strong="H3068"\w* su simiente, \w para|strong="H5921"\w* \w siempre|strong="H5921"\w*.   
\c 19
\d Al Músico principal: Salmo de David  
\m
\v 1 Los cielos cuentan la gloria de Dios, y el firmamento anuncia la obra de sus manos.   
\m
\v 2 Un día emite palabra \w a|strong="H3068"\w* otro día, \w y|strong="H3519"\w* una noche \w a|strong="H3068"\w* otra noche \w declara|strong="H5046"\w* sabiduría.   
\m
\v 3 No hay habla, ni lenguaje, \add donde\add* su voz no sea oída.   
\m
\v 4 \w Por|strong="H1697"\w* toda la tierra salió su hilo, y \w hasta|strong="H1097"\w* los confines del mundo sus \w palabras|strong="H1697"\w*. En ellos puso tabernáculo para el sol.   
\m
\v 5 \w Y|strong="H3068"\w* este, como un novio \w que|strong="H3605"\w* \w sale|strong="H3318"\w* de su tálamo, se alegra cual gigante para correr \w el|strong="H3605"\w* camino.   
\m
\v 6 De un extremo del cielo \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w salida|strong="H3318"\w*, y \w su|strong="H1931"\w* giro \w hasta|strong="H1931"\w* \w el|strong="H1931"\w* término de \w este|strong="H1931"\w*; y nada hay \w que|strong="H1931"\w* \w se|strong="H1931"\w* esconda de \w su|strong="H1931"\w* calor.   
\m
\v 7 \w La|strong="H5921"\w* ley \w de|strong="H5921"\w* Jehová \add es\add* perfecta, \w que|strong="H5921"\w* convierte \w el|strong="H5921"\w* alma; \w el|strong="H5921"\w* testimonio \w de|strong="H5921"\w* Jehová es fiel, \w que|strong="H5921"\w* hace sabio \w al|strong="H5921"\w* sencillo.   
\m
\v 8 Los mandamientos de \w Jehová|strong="H3068"\w* \add son\add* rectos, que alegran el \w corazón|strong="H5315"\w*; el precepto de \w Jehová|strong="H3068"\w*, \add es\add* puro, que alumbra los ojos.   
\m
\v 9 El temor \w de|strong="H5869"\w* \w Jehová|strong="H3068"\w*, \add es\add* \w limpio|strong="H1249"\w*, que permanece para siempre; los juicios \w de|strong="H5869"\w* \w Jehová|strong="H3068"\w* \add son\add* verdad, todos justos.   
\m
\v 10 Deseables \add son\add* más que el oro, y más que mucho oro afinado; \w Y|strong="H3068"\w* dulces más que la miel, y la que destila del panal.   
\m
\v 11 Además, tu siervo es amonestado con ellos; en guardarlos \add hay\add* \w grande|strong="H7227"\w* galardón.   
\m
\v 12 ¿Quién podrá entender \add sus propios\add* errores? Líbrame de los \w que|strong="H1571"\w* me son ocultos.   
\m
\v 13 Detén asimismo \w a|strong="H3068"\w* tu siervo \add de pecados\add* de soberbia; \w que|strong="H4310"\w* no se enseñoreen de mí: Entonces seré íntegro, y seré inocente de gran transgresión.   
\m
\v 14 \w Que|strong="H1571"\w* los dichos de mi boca \w y|strong="H1571"\w* \w la|strong="H1571"\w* meditación de mi corazón sean gratos delante de ti, oh Jehová, fortaleza mía, \w y|strong="H1571"\w* Redentor mío.   
\c 20
\d Al Músico principal: Salmo de David  
\m
\v 1 Jehová te oiga en el día de la angustia; El nombre del Dios de Jacob te defienda.   
\m
\v 2 Te envíe ayuda desde el santuario, y desde Sión te sostenga.   
\m
\v 3 Haga memoria de todas tus ofrendas, y acepte tu holocausto. (Selah)   
\m
\v 4 Te dé \w conforme|strong="H5930"\w* \w al|strong="H5930"\w* deseo de tu corazón, y cumpla \w todo|strong="H3605"\w* tu consejo.   
\m
\v 5 \w Nosotros|strong="H3605"\w* nos alegraremos en tu salvación, y alzaremos bandera en \w el|strong="H3605"\w* nombre \w de|strong="H5414"\w* nuestro Dios; conceda Jehová \w todas|strong="H3605"\w* tus peticiones.   
\m
\v 6 Ahora entiendo \w que|strong="H3605"\w* \w Jehová|strong="H3068"\w* guarda \w a|strong="H3068"\w* su ungido; \w lo|strong="H3605"\w* oirá desde su santo cielo, con \w la|strong="H3605"\w* fuerza salvadora de su diestra.   
\m
\v 7 Algunos \add confían\add* \w en|strong="H3588"\w* carros, \w y|strong="H3588"\w* otros \w en|strong="H3588"\w* caballos; \w pero|strong="H3588"\w* nosotros del nombre \w de|strong="H3588"\w* \w Jehová|strong="H3068"\w* nuestro \w Dios|strong="H3068"\w* tendremos memoria.   
\m
\v 8 Ellos se doblegaron y cayeron; mas nosotros nos levantamos, y estamos en pie.   
\m
\v 9 Salva, Jehová; \w que|strong="H1992"\w* \w el|strong="H5307"\w* Rey nos oiga \w el|strong="H5307"\w* día \w que|strong="H1992"\w* \w lo|strong="H1992"\w* invoquemos.   
\c 21
\d Al Músico principal: Salmo de David  
\m
\v 1 Se alegrará el rey en tu fortaleza, oh Jehová; y en tu salvación se gozará mucho.   
\m
\v 2 El deseo de su corazón le has concedido, \w y|strong="H5797"\w* \w no|strong="H4100"\w* le has negado la petición de sus labios. (Selah)   
\m
\v 3 Pues le \w has|strong="H5414"\w* salido al encuentro con bendiciones \w de|strong="H5414"\w* bien; corona \w de|strong="H5414"\w* oro fino \w has|strong="H5414"\w* \w puesto|strong="H5414"\w* sobre su cabeza.   
\m
\v 4 Vida \w te|strong="H3588"\w* pidió, \w y|strong="H3588"\w* tú se \w la|strong="H3588"\w* diste: Largura \w de|strong="H3588"\w* días eternamente \w y|strong="H3588"\w* \w para|strong="H3588"\w* siempre.   
\m
\v 5 Grande es su gloria \w en|strong="H4480"\w* tu salvación; honra y majestad \w has|strong="H5414"\w* \w puesto|strong="H5414"\w* \w sobre|strong="H4480"\w* él.   
\m
\v 6 \w Porque|strong="H5921"\w* \w lo|strong="H5921"\w* has bendecido \w para|strong="H5921"\w* \w siempre|strong="H5921"\w*; \w lo|strong="H5921"\w* llenaste \w de|strong="H5921"\w* alegría \w con|strong="H5921"\w* tu rostro.   
\m
\v 7 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* rey confía \w en|strong="H3588"\w* Jehová, \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* misericordia del Altísimo, \w no|strong="H3588"\w* \w será|strong="H1293"\w* conmovido.   
\m
\v 8 Alcanzará tu mano \w a|strong="H3068"\w* todos tus enemigos; tu diestra alcanzará \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* aborrecen.   
\m
\v 9 \w Los|strong="H3605"\w* harás como un horno ardiente en \w el|strong="H3605"\w* tiempo de tu ira: Jehová \w los|strong="H3605"\w* tragará en su ira, y \w el|strong="H3605"\w* fuego \w los|strong="H3605"\w* devorará.   
\m
\v 10 Su fruto destruirás \w de|strong="H6440"\w* la tierra, y su simiente \w de|strong="H6440"\w* entre los hijos \w de|strong="H6440"\w* los hombres.   
\m
\v 11 Porque intentaron \w el|strong="H1121"\w* mal contra ti; fraguaron maquinaciones, mas no prevalecerán.   
\m
\v 12 \w Pues|strong="H3588"\w* tú \w los|strong="H5921"\w* pondrás \w en|strong="H5921"\w* fuga, \w cuando|strong="H3588"\w* aprestares \w en|strong="H5921"\w* tus cuerdas \add las saetas\add* \w contra|strong="H5921"\w* sus rostros.   
\m
\v 13 Engrandécete, oh Jehová, \w con|strong="H5921"\w* tu fortaleza: Cantaremos \w y|strong="H3588"\w* alabaremos tu poder.   
\c 22
\d Al Músico principal, sobre Ajelet-sahar. Salmo de David  
\m
\v 1 Dios \w mío|strong="H5921"\w*, Dios \w mío|strong="H5921"\w*, ¿\w por|strong="H5921"\w* \w qué|strong="H5921"\w* \w me|strong="H5921"\w* has abandonado? ¿\add Por qué estás tan\add* lejos \w de|strong="H5921"\w* \w mi|strong="H5921"\w* salvación, \add y de\add* \w las|strong="H5921"\w* palabras \w de|strong="H5921"\w* \w mi|strong="H5921"\w* clamor?   
\m
\v 2 Dios mío, clamo \w de|strong="H1697"\w* día, y \w no|strong="H4100"\w* \add me\add* escuchas; y \w de|strong="H1697"\w* noche, y \w no|strong="H4100"\w* hay para mí reposo.   
\m
\v 3 Pero tú eres santo, Tú \w que|strong="H3808"\w* habitas \w entre|strong="H3808"\w* las alabanzas de Israel.   
\m
\v 4 En ti confiaron nuestros padres: Confiaron, y tú \w los|strong="H3427"\w* libraste.   
\m
\v 5 Clamaron \w a|strong="H3068"\w* ti, y fueron librados; confiaron en ti, y no fueron avergonzados.   
\m
\v 6 \w Mas|strong="H3808"\w* yo soy gusano, y \w no|strong="H3808"\w* hombre; oprobio de los hombres, y despreciado del pueblo.   
\m
\v 7 Todos los \w que|strong="H3808"\w* me ven, \w se|strong="H3808"\w* burlan \w de|strong="H5971"\w* mí; estiran los labios, menean la cabeza, diciendo:   
\m
\v 8 Confió en Jehová, \w que|strong="H3605"\w* \w Él|strong="H3605"\w* \w lo|strong="H3605"\w* libraría; \w que|strong="H3605"\w* \w lo|strong="H3605"\w* libre, ya \w que|strong="H3605"\w* en \w Él|strong="H3605"\w* se complacía.   
\m
\v 9 \w Pero|strong="H3588"\w* tú \add eres\add* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* sacó del vientre; \w Me|strong="H3588"\w* hiciste estar confiado \add desde que estaba\add* \w a|strong="H3068"\w* \w los|strong="H3588"\w* pechos \w de|strong="H3588"\w* mi madre.   
\m
\v 10 \w Sobre|strong="H5921"\w* \w ti|strong="H5921"\w* fui echado \w desde|strong="H5921"\w* \w la|strong="H5921"\w* matriz; \w desde|strong="H5921"\w* \w el|strong="H5921"\w* vientre \w de|strong="H5921"\w* \w mi|strong="H5921"\w* madre, tú \add eres\add* \w mi|strong="H5921"\w* Dios.   
\m
\v 11 \w No|strong="H5921"\w* \w te|strong="H5921"\w* alejes \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w porque|strong="H5921"\w* \w la|strong="H5921"\w* angustia \w está|strong="H5921"\w* \w cerca|strong="H5921"\w*; \w porque|strong="H5921"\w* \w no|strong="H5921"\w* hay quien ayude.   
\m
\v 12 Muchos toros \w me|strong="H4480"\w* han rodeado; fuertes \add toros\add* \w de|strong="H4480"\w* Basán \w me|strong="H4480"\w* han cercado.   
\m
\v 13 Abrieron sobre mí su boca, \add como\add* un león rapaz y rugiente.   
\m
\v 14 Estoy derramado \w como|strong="H5921"\w* aguas, \w y|strong="H5921"\w* todos mis huesos \w se|strong="H5921"\w* descoyuntaron: \w Mi|strong="H5921"\w* corazón es \w como|strong="H5921"\w* cera, derretido \w en|strong="H5921"\w* medio \w de|strong="H5921"\w* mis entrañas.   
\m
\v 15 \w Se|strong="H1961"\w* secó \w como|strong="H1961"\w* un tiesto \w mi|strong="H1961"\w* vigor, y \w mi|strong="H1961"\w* lengua \w se|strong="H1961"\w* pegó \w a|strong="H3068"\w* \w mi|strong="H1961"\w* paladar; y me has puesto \w en|strong="H8432"\w* \w el|strong="H3605"\w* polvo \w de|strong="H4325"\w* \w la|strong="H3605"\w* muerte.   
\m
\v 16 Porque perros me han rodeado, me ha cercado cuadrilla de malignos; horadaron mis manos y mis pies.   
\m
\v 17 Contar puedo todos mis huesos; \w ellos|strong="H3027"\w* \w me|strong="H3588"\w* miran, \w y|strong="H3588"\w* \w me|strong="H3588"\w* observan.   
\m
\v 18 Repartieron entre sí mis \w vestiduras|strong="H1992"\w*, y sobre mi ropa echaron suertes.   
\m
\v 19 \w Mas|strong="H5921"\w* tú, oh Jehová, \w no|strong="H5921"\w* \w te|strong="H5921"\w* alejes; oh fortaleza mía, apresúrate \w a|strong="H3068"\w* socorrerme.   
\m
\v 20 Libra de la espada mi alma; del poder del perro mi vida.   
\m
\v 21 Sálvame de la boca del león; porque tú me has escuchado de los cuernos de los unicornios.   
\m
\v 22 Anunciaré tu nombre \w a|strong="H3068"\w* mis hermanos; en medio de la congregación te alabaré.   
\m
\v 23 Los \w que|strong="H6951"\w* temen \w a|strong="H3068"\w* Jehová, alábenlo; glorifíquenlo, simiente toda de Jacob; y temedlo, simiente toda de Israel.   
\m
\v 24 Porque no menospreció ni abominó \w la|strong="H3605"\w* aflicción \w del|strong="H4480"\w* afligido, ni \w de|strong="H4480"\w* \w él|strong="H3605"\w* escondió su rostro; sino \w que|strong="H4480"\w* cuando clamó \w a|strong="H3068"\w* \w Él|strong="H3605"\w*, le oyó.   
\m
\v 25 \w De|strong="H4480"\w* \w ti|strong="H4480"\w* \add será\add* mi alabanza \w en|strong="H4480"\w* \w la|strong="H3588"\w* gran congregación; mis votos pagaré \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* le temen.   
\m
\v 26 Los mansos comerán, y serán saciados: Alabarán \w a|strong="H3068"\w* Jehová los \w que|strong="H6951"\w* le buscan: Vivirá vuestro corazón para siempre.   
\m
\v 27 Se acordarán, y se volverán \w a|strong="H3068"\w* \w Jehová|strong="H3068"\w* todos los términos \w de|strong="H7646"\w* \w la|strong="H7646"\w* tierra; y adorarán delante \w de|strong="H7646"\w* ti todas las familias \w de|strong="H7646"\w* las naciones.   
\m
\v 28 \w Porque|strong="H6440"\w* \w de|strong="H6440"\w* \w Jehová|strong="H3068"\w* \add es\add* \w el|strong="H3605"\w* reino; y \w Él|strong="H3605"\w* señorea sobre las \w naciones|strong="H1471"\w*.   
\m
\v 29 Comerán \w y|strong="H3588"\w* adorarán todos \w los|strong="H3588"\w* poderosos \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra; se postrarán delante \w de|strong="H3588"\w* \w Él|strong="H3588"\w* todos \w los|strong="H3588"\w* \w que|strong="H3588"\w* descienden al polvo, \w si|strong="H3588"\w* \w bien|strong="H3588"\w* ninguno puede conservar \w la|strong="H3588"\w* vida \w de|strong="H3588"\w* \w su|strong="H3588"\w* propia alma.   
\m
\v 30 Una simiente le servirá. Esto \w será|strong="H3808"\w* contado del Señor \w por|strong="H6440"\w* una generación.   
\m
\v 31 Vendrán, y anunciarán su justicia \w a|strong="H3068"\w* un pueblo que ha de nacer, le dirán que Él hizo \add esto\add*.   
\c 23
\d Salmo de David  
\m
\v 1 \w Jehová|strong="H3068"\w* \add es\add* mi \w pastor|strong="H7462"\w*; \w nada|strong="H3808"\w* me faltará.   
\m
\v 2 \w En|strong="H5921"\w* lugares \w de|strong="H5921"\w* delicados pastos \w me|strong="H5921"\w* hará descansar; \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w aguas|strong="H4325"\w* \w de|strong="H5921"\w* \w reposo|strong="H4496"\w* \w me|strong="H5921"\w* \w pastoreará|strong="H5095"\w*.   
\m
\v 3 Restaurará \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*; me guiará \w por|strong="H4616"\w* sendas de \w justicia|strong="H6664"\w* \w por|strong="H4616"\w* amor \w a|strong="H3068"\w* su \w nombre|strong="H8034"\w*.   
\m
\v 4 \w Aunque|strong="H3588"\w* \w ande|strong="H3212"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w valle|strong="H1516"\w* \w de|strong="H3588"\w* sombra \w de|strong="H3588"\w* \w muerte|strong="H6757"\w*, \w no|strong="H3808"\w* \w temeré|strong="H3372"\w* \w mal|strong="H7451"\w* alguno; \w porque|strong="H3588"\w* tú estarás \w conmigo|strong="H5978"\w*; tu \w vara|strong="H7626"\w* \w y|strong="H1571"\w* tu \w cayado|strong="H4938"\w* \w me|strong="H3588"\w* infundirán aliento.   
\m
\v 5 Aderezas \w mesa|strong="H7979"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* mí, en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* mis angustiadores; unges mi \w cabeza|strong="H7218"\w* con \w aceite|strong="H8081"\w*; mi copa está rebosando.   
\m
\v 6 Ciertamente \w el|strong="H3605"\w* \w bien|strong="H2896"\w* y \w la|strong="H3605"\w* \w misericordia|strong="H2617"\w* me seguirán \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w días|strong="H3117"\w* de mi \w vida|strong="H2416"\w*; y en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de \w Jehová|strong="H3068"\w* yo \w moraré|strong="H3427"\w* por \w siempre|strong="H3605"\w*.   
\c 24
\d Salmo de David  
\m
\v 1 De \w Jehová|strong="H3068"\w* es la tierra y su plenitud; \w el|strong="H3427"\w* \w mundo|strong="H8398"\w* y \w los|strong="H3427"\w* que en \w él|strong="H3427"\w* \w habitan|strong="H3427"\w*.   
\m
\v 2 \w Porque|strong="H3588"\w* \w Él|strong="H1931"\w* \w la|strong="H1931"\w* \w fundó|strong="H3245"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w mares|strong="H3220"\w*, \w y|strong="H3588"\w* \w la|strong="H1931"\w* \w afirmó|strong="H3559"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* ríos.   
\m
\v 3 ¿\w Quién|strong="H4310"\w* \w subirá|strong="H5927"\w* al \w monte|strong="H2022"\w* de \w Jehová|strong="H3068"\w*? ¿\w O|strong="H3068"\w* \w quién|strong="H4310"\w* \w estará|strong="H6965"\w* en su \w lugar|strong="H4725"\w* \w santo|strong="H6944"\w*?   
\m
\v 4 El \w limpio|strong="H1249"\w* de \w manos|strong="H3709"\w*, \w y|strong="H5355"\w* \w puro|strong="H1249"\w* de \w corazón|strong="H3824"\w*; el \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* elevado su \w alma|strong="H5315"\w* \w a|strong="H3068"\w* la \w vanidad|strong="H7723"\w*, \w ni|strong="H3808"\w* \w jurado|strong="H7650"\w* con \w engaño|strong="H4820"\w*.   
\m
