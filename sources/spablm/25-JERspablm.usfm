\c 31
\p
\v 1 «En \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* — \w dice|strong="H5002"\w* Yahvé —, yo \w seré|strong="H1961"\w* \w el|strong="H1931"\w* \w Dios|strong="H3068"\w* \w de|strong="H5971"\w* \w todas|strong="H3605"\w* \w las|strong="H1992"\w* \w familias|strong="H4940"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*, y \w ellas|strong="H1992"\w* \w serán|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*».   
\p
\v 2 \w Así|strong="H3541"\w* dice Yahvé: «El \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* sobrevivió \w a|strong="H3068"\w* la \w espada|strong="H2719"\w* \w halló|strong="H4672"\w* \w gracia|strong="H2580"\w* en el \w desierto|strong="H4057"\w*; cuando \w Israel|strong="H3478"\w* caminaba hacia su reposo».   
