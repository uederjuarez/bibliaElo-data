\q1
\v 8 ¡\w Huid|strong="H5127"\w*, \w volveos|strong="H6437"\w*!  
\q2 \w Habitad|strong="H3427"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* profundidades, \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* \w Dedán|strong="H1719"\w*;  
