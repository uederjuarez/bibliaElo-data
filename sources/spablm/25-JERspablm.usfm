\q2 \w y|strong="H5921"\w* destruirán sus moradas \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
\q1
\v 21 Del \w estruendo|strong="H6963"\w* de la caída de ellos la tierra \w tembló|strong="H7493"\w*;  
\q2 \w el|strong="H5307"\w* grito se \w oyó|strong="H8085"\w* en \w el|strong="H5307"\w* \w Mar|strong="H3220"\w* Rojo.   
\q1
\v 22 He \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w como|strong="H1961"\w* águila \w subirá|strong="H5927"\w* \w y|strong="H5921"\w* \w volará|strong="H1675"\w*,  
\q2 \w y|strong="H5921"\w* extenderá \w sus|strong="H1931"\w* \w alas|strong="H3671"\w* \w sobre|strong="H5921"\w* \w Bosra|strong="H1224"\w*;  
\q1 \w y|strong="H5921"\w* \w el|strong="H1931"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w valientes|strong="H1368"\w* \w de|strong="H5921"\w* Edom \w será|strong="H1961"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*  
\q2 \w como|strong="H1961"\w* \w el|strong="H1931"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* una mujer \w de|strong="H5921"\w* parto.   
\b  
\p
\v 23 Acerca \w de|strong="H3588"\w* \w Damasco|strong="H1834"\w*:  
\q1 «Hamat \w y|strong="H3588"\w* Arpad \w se|strong="H3808"\w* han avergonzado  
\q2 \w porque|strong="H3588"\w* \w oyeron|strong="H8085"\w* \w malas|strong="H7451"\w* noticias.  
\q1 \w Se|strong="H3808"\w* han derretido \w en|strong="H3588"\w* temores;  
\q2 hay angustia \w como|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w mar|strong="H3220"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w puede|strong="H3201"\w* \w sosegarse|strong="H8252"\w*.   
\q1
\v 24 Se desmayó \w Damasco|strong="H1834"\w*, se \w volvió|strong="H6437"\w* para huir,  
\q2 y le tomó \w temblor|strong="H7374"\w*;  
\q1 \w angustia|strong="H6869"\w* y \w dolores|strong="H2256"\w* se apoderaron de ella,  
\q2 como de mujer de parto.   
\q1
\v 25 ¡Cómo \w ha|strong="H3808"\w* sido \w abandonada|strong="H5800"\w* la \w ciudad|strong="H5892"\w* de la \w alabanza|strong="H8416"\w*,  
\q2 la \w ciudad|strong="H5892"\w* de mi \w gozo|strong="H4885"\w*!   
\q1
\v 26 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w sus|strong="H1931"\w* jóvenes \w caerán|strong="H5307"\w* en \w sus|strong="H1931"\w* \w plazas|strong="H7339"\w*,  
\q2 y \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* hombres de \w guerra|strong="H4421"\w* \w serán|strong="H1931"\w* talados en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*»,  
\q2 \w dice|strong="H5002"\w* Yahvé de \w los|strong="H3605"\w* \w Ejércitos|strong="H6635"\w*.   
\q1
\v 27 «\w Y|strong="H3068"\w* prenderé fuego al \w muro|strong="H2346"\w* de \w Damasco|strong="H1834"\w*,  
\q2 y consumirá los palacios de \w Ben-adad|strong="H1130"\w*».   
\b  
\q1
\v 28 Acerca \w de|strong="H1121"\w* \w Cedar|strong="H6938"\w* \w y|strong="H3541"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w reinos|strong="H4467"\w* \w de|strong="H1121"\w* Hazor, \w a|strong="H3068"\w* \w los|strong="H1121"\w* cuales \w hirió|strong="H5221"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia. \w Así|strong="H3541"\w* dice Yahvé:  
\q1 “\w Levantaos|strong="H6965"\w*, \w subid|strong="H5927"\w* contra \w Cedar|strong="H6938"\w*  
\q2 \w y|strong="H3541"\w* destruid \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w oriente|strong="H6924"\w*.   
