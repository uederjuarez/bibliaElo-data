\v 38 «He \w aquí|strong="H2009"\w* \w que|strong="H3117"\w* vienen \w días|strong="H3117"\w* — \w dice|strong="H5002"\w* Yahvé — en \w que|strong="H3117"\w* la \w ciudad|strong="H5892"\w* será \w edificada|strong="H1129"\w* \w a|strong="H3068"\w* Yahvé, desde la \w torre|strong="H4026"\w* de Hananel \w hasta|strong="H3117"\w* la \w puerta|strong="H8179"\w* del Ángulo.  
\v 39 \w Y|strong="H3068"\w* \w saldrá|strong="H3318"\w* \w más|strong="H5750"\w* allá \w el|strong="H5921"\w* cordel \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w medida|strong="H4060"\w* \w delante|strong="H5048"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w collado|strong="H1389"\w* \w de|strong="H5921"\w* \w Gareb|strong="H1619"\w*, \w y|strong="H5921"\w* rodeará \w a|strong="H3068"\w* Goa.  
\v 40 \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w valle|strong="H6010"\w* \w de|strong="H5750"\w* \w los|strong="H3605"\w* \w cuerpos|strong="H6297"\w* \w muertos|strong="H6297"\w* \w y|strong="H5704"\w* \w de|strong="H5750"\w* \w la|strong="H3605"\w* ceniza, \w y|strong="H5704"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* llanos \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w arroyo|strong="H5158"\w* \w de|strong="H5750"\w* Cedrón, \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* esquina \w de|strong="H5750"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H5750"\w* \w los|strong="H3605"\w* \w Caballos|strong="H5483"\w* \w al|strong="H5704"\w* \w oriente|strong="H4217"\w*, \w será|strong="H3808"\w* \w santo|strong="H6944"\w* \w a|strong="H3068"\w* Yahvé; \w no|strong="H3808"\w* \w será|strong="H3808"\w* arrancada \w ni|strong="H3808"\w* derribada \w más|strong="H5750"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*».   
\c 32
\p
\v 1 \w Esta|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w palabra|strong="H1697"\w* \w que|strong="H1931"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H1697"\w* parte \w de|strong="H1697"\w* Yahvé en \w el|strong="H1931"\w* \w décimo|strong="H6224"\w* \w año|strong="H8141"\w* \w de|strong="H1697"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w*, \w que|strong="H1931"\w* \w era|strong="H1961"\w* \w el|strong="H1931"\w* \w año|strong="H8141"\w* \w dieciocho|strong="H8083"\w* \w de|strong="H1697"\w* \w Nabucodonosor|strong="H5019"\w*.  
\v 2 \w En|strong="H5921"\w* aquel tiempo \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w estaba|strong="H1961"\w* sitiando Jerusalén. \w El|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w estaba|strong="H1961"\w* recluido \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w patio|strong="H2691"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* guardia, \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\p
\v 3 \w Porque|strong="H4069"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*, lo había mandado encerrar, diciendo: “¿\w Por|strong="H4069"\w* \w qué|strong="H3541"\w* \w profetizas|strong="H5012"\w* \w y|strong="H3541"\w* dices: ‘Yahvé dice: «He \w aquí|strong="H3541"\w* \w que|strong="H3541"\w* yo \w entrego|strong="H5414"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* en \w manos|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Babilonia, \w y|strong="H3541"\w* él \w la|strong="H2063"\w* \w tomará|strong="H3920"\w*;  
\v 4 \w y|strong="H3588"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w no|strong="H3808"\w* \w escapará|strong="H4422"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H5973"\w* \w caldeos|strong="H3778"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w será|strong="H3808"\w* \w entregado|strong="H5414"\w* \w sin|strong="H3808"\w* falta \w en|strong="H5973"\w* \w mano|strong="H3027"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia, \w y|strong="H3588"\w* \w hablará|strong="H1696"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* cara \w a|strong="H3068"\w* cara, \w y|strong="H3588"\w* sus \w ojos|strong="H5869"\w* \w verán|strong="H7200"\w* sus \w ojos|strong="H5869"\w*;  
\v 5 \w y|strong="H3588"\w* \w él|strong="H3588"\w* \w llevará|strong="H3212"\w* \w a|strong="H3068"\w* Sedequías \w a|strong="H3068"\w* Babilonia, \w y|strong="H3588"\w* \w allí|strong="H8033"\w* \w estará|strong="H1961"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w lo|strong="H3808"\w* visite — \w dice|strong="H5002"\w* Yahvé —; \w aunque|strong="H3588"\w* luchéis \w contra|strong="H1961"\w* \w los|strong="H1961"\w* \w caldeos|strong="H3778"\w*, \w no|strong="H3808"\w* prosperaréis”’?”   
\p
\v 6 \w Y|strong="H3068"\w* dijo \w Jeremías|strong="H3414"\w*: “\w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 7 ‘He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* Hanamel, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* tu \w tío|strong="H1730"\w* Salum, vendrá \w a|strong="H3068"\w* ti \w para|strong="H3588"\w* decirte: «\w Compra|strong="H7069"\w* \w mi|strong="H2009"\w* \w campo|strong="H7704"\w* \w que|strong="H3588"\w* está \w en|strong="H3588"\w* Anatot; \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w derecho|strong="H4941"\w* \w de|strong="H3588"\w* \w redención|strong="H1353"\w* \w es|strong="H3588"\w* tuyo \w para|strong="H3588"\w* comprarlo» ’”.   
\p
\v 8 \w Y|strong="H3068"\w* vino \w a|strong="H3068"\w* \w mí|strong="H4994"\w* Hanamel, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w mi|strong="H4994"\w* \w tío|strong="H1730"\w*, al \w patio|strong="H2691"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* guardia, \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé, \w y|strong="H3588"\w* \w me|strong="H3588"\w* dijo: «\w Compra|strong="H7069"\w*, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w*, \w mi|strong="H4994"\w* \w campo|strong="H7704"\w* \w que|strong="H3588"\w* \w está|strong="H1931"\w* \w en|strong="H3588"\w* Anatot, \w en|strong="H3588"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w Benjamín|strong="H1144"\w*; \w porque|strong="H3588"\w* tuyo \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w derecho|strong="H4941"\w* \w de|strong="H3588"\w* herencia \w y|strong="H3588"\w* \w a|strong="H3068"\w* ti \w te|strong="H3588"\w* corresponde \w la|strong="H1931"\w* \w redención|strong="H1353"\w*. Cómpralo \w para|strong="H3588"\w* ti».  
\p \w Entonces|strong="H3588"\w* comprendí \w que|strong="H3588"\w* \w esta|strong="H1931"\w* \w era|strong="H1931"\w* \w la|strong="H1931"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé.  
\v 9 \w Y|strong="H3068"\w* compré \w el|strong="H1121"\w* \w campo|strong="H7704"\w* \w de|strong="H1121"\w* Hanamel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* mi \w tío|strong="H1730"\w*, \w el|strong="H1121"\w* cual estaba en Anatot, y le \w pesé|strong="H8254"\w* \w el|strong="H1121"\w* \w dinero|strong="H3701"\w*: \w diecisiete|strong="H7651"\w* \w siclos|strong="H8255"\w*\f + \fr 32:9 \ft Un siclo equivale a unos 10 gramos o a unas 0,35 onzas.\f* \w de|strong="H1121"\w* \w plata|strong="H3701"\w*.  
\v 10 Firmé la \w escritura|strong="H3789"\w* y la sellé, llamé \w a|strong="H3068"\w* \w testigos|strong="H5707"\w* y \w pesé|strong="H8254"\w* el \w dinero|strong="H3701"\w* en la balanza.  
\v 11 \w Tomé|strong="H3947"\w* luego la escritura de venta, tanto la \w sellada|strong="H2856"\w* conforme \w a|strong="H3068"\w* la \w ley|strong="H2706"\w* y los \w estatutos|strong="H2706"\w*, como la copia abierta.  
\v 12 \w Y|strong="H3068"\w* \w entregué|strong="H5414"\w* \w la|strong="H3605"\w* \w escritura|strong="H3789"\w* \w de|strong="H1121"\w* venta \w a|strong="H3068"\w* Baruc, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Nerías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maasías, en presencia \w de|strong="H1121"\w* Hanamel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* mi \w tío|strong="H1730"\w*, y en presencia \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w testigos|strong="H5707"\w* \w que|strong="H1121"\w* habían suscrito \w la|strong="H3605"\w* \w escritura|strong="H3789"\w* \w de|strong="H1121"\w* venta, \w delante|strong="H5869"\w* \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w judíos|strong="H3064"\w* \w que|strong="H1121"\w* \w estaban|strong="H3427"\w* \w sentados|strong="H3427"\w* en \w el|strong="H3605"\w* \w patio|strong="H2691"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* guardia.   
\p
\v 13 \w Y|strong="H3068"\w* di órdenes \w a|strong="H3068"\w* Baruc en presencia \w de|strong="H5869"\w* ellos, diciendo:  
\v 14 “\w Así|strong="H3541"\w* dice Yahvé \w de|strong="H5414"\w* los \w Ejércitos|strong="H6635"\w*, el \w Dios|strong="H3068"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*: ‘\w Toma|strong="H3947"\w* \w estas|strong="H5975"\w* escrituras, \w esta|strong="H2088"\w* escritura \w de|strong="H5414"\w* venta \w que|strong="H3117"\w* \w está|strong="H2088"\w* \w sellada|strong="H2856"\w* \w y|strong="H3541"\w* \w esta|strong="H2088"\w* escritura \w que|strong="H3117"\w* \w está|strong="H2088"\w* abierta, \w y|strong="H3541"\w* ponlas \w en|strong="H5975"\w* una \w vasija|strong="H3627"\w* \w de|strong="H5414"\w* barro \w para|strong="H4616"\w* \w que|strong="H3117"\w* se conserven \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*’.  
\v 15 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H3588"\w* \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: ‘\w Aún|strong="H5750"\w* se \w comprarán|strong="H7069"\w* \w casas|strong="H1004"\w*, \w campos|strong="H7704"\w* \w y|strong="H3588"\w* viñedos \w en|strong="H3588"\w* \w esta|strong="H2063"\w* tierra’”.   
\p
\v 16 \w Y|strong="H3068"\w* después \w que|strong="H1121"\w* \w entregué|strong="H5414"\w* la escritura \w de|strong="H1121"\w* venta \w a|strong="H3068"\w* Baruc, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Nerías, \w oré|strong="H6419"\w* \w a|strong="H3068"\w* Yahvé, diciendo:   
\b  
\mi
\v 17 “¡Ah, Señor Yahvé! He \w aquí|strong="H2009"\w* \w que|strong="H4480"\w* \w tú|strong="H6213"\w* \w hiciste|strong="H6213"\w* \w el|strong="H3605"\w* \w cielo|strong="H8064"\w* y \w la|strong="H3605"\w* tierra \w con|strong="H4480"\w* \w tu|strong="H6213"\w* \w gran|strong="H1419"\w* \w poder|strong="H3581"\w* y \w con|strong="H4480"\w* \w tu|strong="H6213"\w* \w brazo|strong="H2220"\w* \w extendido|strong="H5186"\w*; \w no|strong="H3808"\w* hay \w nada|strong="H3808"\w* \w que|strong="H4480"\w* sea \w difícil|strong="H6381"\w* \w para|strong="H4480"\w* \w ti|strong="H4480"\w*.  
\v 18 \w Tú|strong="H6213"\w* \w haces|strong="H6213"\w* \w misericordia|strong="H2617"\w* \w a|strong="H3068"\w* millares, y castigas la \w iniquidad|strong="H5771"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* padres en \w el|strong="H1121"\w* \w seno|strong="H2436"\w* \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* después \w de|strong="H1121"\w* ellos. \w Dios|strong="H3068"\w* \w grande|strong="H1419"\w*, \w poderoso|strong="H1368"\w*, Yahvé \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w* es \w tu|strong="H6213"\w* \w nombre|strong="H8034"\w*:  
\v 19 \w grande|strong="H1419"\w* \w en|strong="H5921"\w* \w consejo|strong="H6098"\w* \w y|strong="H5921"\w* magnífico \w en|strong="H5921"\w* \w hechos|strong="H4611"\w*; \w porque|strong="H5921"\w* tus \w ojos|strong="H5869"\w* están abiertos \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w caminos|strong="H1870"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*, \w para|strong="H5921"\w* \w dar|strong="H5414"\w* \w a|strong="H3068"\w* \w cada|strong="H3605"\w* uno \w según|strong="H5921"\w* sus \w caminos|strong="H1870"\w* \w y|strong="H5921"\w* \w según|strong="H5921"\w* \w el|strong="H5921"\w* \w fruto|strong="H6529"\w* \w de|strong="H5921"\w* sus \w obras|strong="H4611"\w*.  
\v 20 \w Tú|strong="H6213"\w* \w hiciste|strong="H6213"\w* señales \w y|strong="H5704"\w* \w prodigios|strong="H4159"\w* \w en|strong="H5704"\w* la tierra \w de|strong="H5704"\w* \w Egipto|strong="H4714"\w* \w hasta|strong="H5704"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w*, \w y|strong="H5704"\w* \w también|strong="H2088"\w* \w en|strong="H5704"\w* \w Israel|strong="H3478"\w* \w y|strong="H5704"\w* entre los demás hombres; \w y|strong="H5704"\w* te has \w hecho|strong="H6213"\w* \w nombre|strong="H8034"\w*, \w como|strong="H5704"\w* se ve \w en|strong="H5704"\w* \w el|strong="H6213"\w* \w día|strong="H3117"\w* \w de|strong="H5704"\w* \w hoy|strong="H3117"\w*.  
\v 21 \w Y|strong="H3068"\w* \w sacaste|strong="H3318"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w* \w de|strong="H5971"\w* la tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w* con señales y portentos, con \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w* y brazo \w extendido|strong="H5186"\w*, y con \w gran|strong="H1419"\w* terror;  
\v 22 y les \w diste|strong="H5414"\w* \w esta|strong="H2063"\w* tierra, \w de|strong="H5414"\w* \w la|strong="H2063"\w* cual \w juraste|strong="H7650"\w* \w a|strong="H3068"\w* sus padres que se \w la|strong="H2063"\w* darías, tierra que mana \w leche|strong="H2461"\w* y \w miel|strong="H1706"\w*.  
\v 23 Entraron y \w la|strong="H2063"\w* \w poseyeron|strong="H3423"\w*; pero \w no|strong="H3808"\w* \w escucharon|strong="H8085"\w* \w tu|strong="H6213"\w* \w voz|strong="H6963"\w* \w ni|strong="H3808"\w* \w anduvieron|strong="H1980"\w* en \w tu|strong="H6213"\w* \w ley|strong="H8451"\w*. \w No|strong="H3808"\w* \w hicieron|strong="H6213"\w* \w nada|strong="H3808"\w* \w de|strong="H7451"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w les|strong="H6680"\w* \w mandaste|strong="H6680"\w* \w hacer|strong="H6213"\w*; por tanto, has \w hecho|strong="H6213"\w* \w venir|strong="H1980"\w* sobre \w ellos|strong="H3605"\w* \w todo|strong="H3605"\w* \w este|strong="H2063"\w* \w mal|strong="H7451"\w*.   
\mi
\v 24 He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* terraplenes \w de|strong="H5921"\w* asedio han llegado ya \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w para|strong="H5921"\w* \w tomarla|strong="H3898"\w*; \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w va|strong="H3068"\w* \w a|strong="H3068"\w* ser \w entregada|strong="H5414"\w* \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w* \w que|strong="H5921"\w* \w pelean|strong="H3898"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*, \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*, \w del|strong="H5921"\w* \w hambre|strong="H7458"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* peste. \w Lo|strong="H5921"\w* \w que|strong="H5921"\w* tú \w dijiste|strong="H1696"\w* ha sucedido, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* tú \w lo|strong="H5921"\w* estás \w viendo|strong="H7200"\w*.  
\v 25 ¡\w Y|strong="H3068"\w* tú, oh Señor Yahvé, me \w has|strong="H5414"\w* dicho: ‘\w Cómprate|strong="H7069"\w* el \w campo|strong="H7704"\w* \w por|strong="H3027"\w* \w dinero|strong="H3701"\w* y \w pon|strong="H5414"\w* \w testigos|strong="H5707"\w*’, \w a|strong="H3068"\w* pesar \w de|strong="H5414"\w* \w que|strong="H3027"\w* la \w ciudad|strong="H5892"\w* sea \w entregada|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* los \w caldeos|strong="H3778"\w*!”.   
\p
\v 26 Entonces \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, diciendo:  
\v 27 «He \w aquí|strong="H2009"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* soy Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H4480"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w*; ¿habrá \w algo|strong="H1697"\w* \w que|strong="H4480"\w* sea \w difícil|strong="H6381"\w* \w para|strong="H4480"\w* \w mí|strong="H2009"\w*?  
