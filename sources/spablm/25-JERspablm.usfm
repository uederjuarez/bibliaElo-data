\v 25 \w Y|strong="H3068"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* un oficial \w que|strong="H4480"\w* \w era|strong="H1961"\w* \w jefe|strong="H8269"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* hombres \w de|strong="H4480"\w* \w guerra|strong="H4421"\w*, \w a|strong="H3068"\w* \w siete|strong="H7651"\w* hombres \w de|strong="H4480"\w* \w los|strong="H5921"\w* consejeros íntimos \w del|strong="H4480"\w* \w rey|strong="H4428"\w* \w que|strong="H4480"\w* \w se|strong="H1961"\w* \w hallaron|strong="H4672"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w al|strong="H5921"\w* \w escriba|strong="H5608"\w* \w del|strong="H4480"\w* \w jefe|strong="H8269"\w* \w del|strong="H4480"\w* \w ejército|strong="H6635"\w* \w que|strong="H4480"\w* alistaba \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w sesenta|strong="H8346"\w* hombres \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra \w que|strong="H4480"\w* \w se|strong="H1961"\w* \w hallaron|strong="H4672"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.  
\v 26 Los \w tomó|strong="H3947"\w*, pues, \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* de la guardia, y los \w llevó|strong="H3947"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de Babilonia, \w a|strong="H3068"\w* Ribla.  
\v 27 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w los|strong="H5921"\w* \w hirió|strong="H5221"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w mató|strong="H4191"\w* \w en|strong="H5921"\w* Ribla, \w en|strong="H5921"\w* tierra \w de|strong="H5921"\w* Hamat.  
\p Así \w Judá|strong="H3063"\w* \w fue|strong="H3063"\w* transportado cautivo lejos \w de|strong="H5921"\w* su tierra.  
\v 28 \w Este|strong="H2088"\w* \w es|strong="H2088"\w* el \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w Nabucodonosor|strong="H5019"\w* transportó cautivo:  
\m En el \w año|strong="H8141"\w* \w séptimo|strong="H7651"\w*, \w tres|strong="H7969"\w* mil \w veintitrés|strong="H6242"\w* \w judíos|strong="H3064"\w*.   
\m
\v 29 En el \w año|strong="H8141"\w* \w dieciocho|strong="H8083"\w* de \w Nabucodonosor|strong="H5019"\w*, él transportó de Jerusalén \w a|strong="H3068"\w* \w ochocientas|strong="H8083"\w* \w treinta|strong="H7970"\w* y \w dos|strong="H8147"\w* \w personas|strong="H5315"\w*.   
\m
\v 30 En \w el|strong="H3605"\w* \w año|strong="H8141"\w* \w veintitrés|strong="H6242"\w* \w de|strong="H2568"\w* \w Nabucodonosor|strong="H5019"\w*, \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H2568"\w* \w la|strong="H3605"\w* guardia, transportó cautivas \w a|strong="H3068"\w* \w setecientas|strong="H7651"\w* cuarenta y \w cinco|strong="H2568"\w* \w personas|strong="H5315"\w* \w de|strong="H2568"\w* \w los|strong="H3605"\w* \w judíos|strong="H3064"\w*; \w todas|strong="H3605"\w* las \w personas|strong="H5315"\w* fueron cuatro \w mil|strong="H3967"\w* \w seiscientas|strong="H8337"\w*.   
\p
\v 31 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w en|strong="H3318"\w* el \w año|strong="H8141"\w* \w treinta|strong="H7970"\w* y \w siete|strong="H7651"\w* del \w cautiverio|strong="H1546"\w* \w de|strong="H2568"\w* Joaquín, \w rey|strong="H4428"\w* \w de|strong="H2568"\w* \w Judá|strong="H3063"\w*, \w en|strong="H3318"\w* el \w mes|strong="H2320"\w* \w duodécimo|strong="H8147"\w*, \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w veinticinco|strong="H6242"\w* días del \w mes|strong="H2320"\w*, Evil-merodac, \w rey|strong="H4428"\w* \w de|strong="H2568"\w* Babilonia, \w en|strong="H3318"\w* el \w año|strong="H8141"\w* primero \w de|strong="H2568"\w* su \w reinado|strong="H4428"\w*, indultó \w a|strong="H3068"\w* Joaquín, \w rey|strong="H4428"\w* \w de|strong="H2568"\w* \w Judá|strong="H3063"\w*, y lo \w sacó|strong="H3318"\w* \w de|strong="H2568"\w* la cárcel.  
\v 32 Le \w habló|strong="H1696"\w* con benevolencia y \w puso|strong="H5414"\w* su \w trono|strong="H3678"\w* \w por|strong="H5414"\w* \w encima|strong="H4605"\w* del \w trono|strong="H3678"\w* \w de|strong="H5414"\w* los \w reyes|strong="H4428"\w* que estaban con él en Babilonia.  
\v 33 Le cambió las vestiduras \w de|strong="H6440"\w* prisión, y Joaquín comió \w siempre|strong="H8548"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H3605"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H6440"\w* su \w vida|strong="H2416"\w*.  
\v 34 \w Y|strong="H3068"\w* su \w ración|strong="H1697"\w* le fue \w dada|strong="H5414"\w* \w continuamente|strong="H8548"\w* \w por|strong="H1697"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H5704"\w* Babilonia, \w cada|strong="H3605"\w* \w día|strong="H3117"\w* su porción, \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w de|strong="H5704"\w* su \w muerte|strong="H4194"\w*, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H5704"\w* su \w vida|strong="H2416"\w*.   