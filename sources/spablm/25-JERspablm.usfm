\v 16 \w Entonces|strong="H7725"\w* \w Johanán|strong="H3110"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Carea|strong="H7143"\w* y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H4480"\w* las fuerzas \w que|strong="H4480"\w* \w estaban|strong="H5971"\w* \w con|strong="H4480"\w* \w él|strong="H3605"\w* \w tomaron|strong="H3947"\w* \w de|strong="H4480"\w* \w Mizpa|strong="H4709"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w resto|strong="H7611"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w que|strong="H4480"\w* habían recobrado \w de|strong="H4480"\w* \w Ismael|strong="H3458"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Netanías, después \w que|strong="H4480"\w* este \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Ahicam: \w hombres|strong="H1121"\w* \w de|strong="H4480"\w* \w guerra|strong="H4421"\w*, mujeres, \w niños|strong="H2945"\w* y oficiales \w que|strong="H4480"\w* habían \w vuelto|strong="H7725"\w* \w de|strong="H4480"\w* \w Gabaón|strong="H1391"\w*.  
\v 17 \w Y|strong="H3068"\w* \w partieron|strong="H3212"\w* y \w habitaron|strong="H3427"\w* \w en|strong="H3212"\w* Gerut Quimam, que \w está|strong="H3427"\w* cerca de Belén, para \w ir|strong="H3212"\w* y entrar \w en|strong="H3212"\w* \w Egipto|strong="H4714"\w*,  
\v 18 \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w caldeos|strong="H3778"\w*; \w porque|strong="H3588"\w* les tenían \w miedo|strong="H3372"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w Ismael|strong="H3458"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Netanías \w había|strong="H3588"\w* \w muerto|strong="H5221"\w* \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Ahicam, \w a|strong="H3068"\w* quien \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia \w había|strong="H3588"\w* \w puesto|strong="H3588"\w* \w por|strong="H3588"\w* gobernador sobre \w la|strong="H3588"\w* tierra.   
\c 42
\p
\v 1 Entonces \w se|strong="H5971"\w* acercaron \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w capitanes|strong="H8269"\w* \w de|strong="H5704"\w* las fuerzas, \w Johanán|strong="H3110"\w* \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Carea|strong="H7143"\w*, Jezanías \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Oseas, \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w desde|strong="H5704"\w* \w el|strong="H3605"\w* \w más|strong="H5704"\w* \w pequeño|strong="H6996"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w más|strong="H5704"\w* \w grande|strong="H1419"\w*,  
\v 2 \w y|strong="H3588"\w* dijeron \w al|strong="H5704"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*: «Sea aceptada \w ahora|strong="H4994"\w* nuestra \w súplica|strong="H8467"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti, \w y|strong="H3588"\w* \w ruega|strong="H6419"\w* \w por|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w a|strong="H3068"\w* Yahvé vuestro \w Dios|strong="H3068"\w* \w por|strong="H3588"\w* \w todo|strong="H3605"\w* \w este|strong="H2063"\w* remanente (\w pues|strong="H3588"\w* hemos quedado unos \w pocos|strong="H4592"\w* \w de|strong="H3588"\w* \w entre|strong="H3588"\w* \w muchos|strong="H7235"\w*, \w como|strong="H3588"\w* \w lo|strong="H5704"\w* \w ven|strong="H7200"\w* tus \w ojos|strong="H5869"\w*),  
\v 3 para \w que|strong="H1697"\w* Yahvé vuestro \w Dios|strong="H3068"\w* nos enseñe \w el|strong="H6213"\w* \w camino|strong="H1870"\w* \w por|strong="H1870"\w* donde debemos \w andar|strong="H3212"\w* y \w lo|strong="H1697"\w* \w que|strong="H1697"\w* debemos \w hacer|strong="H6213"\w*».   
\p
\v 4 \w El|strong="H3605"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* les \w dijo|strong="H5046"\w*: «\w Os|strong="H4480"\w* he \w oído|strong="H8085"\w*. He \w aquí|strong="H2005"\w* \w que|strong="H4480"\w* voy \w a|strong="H3068"\w* orar \w a|strong="H3068"\w* Yahvé vuestro \w Dios|strong="H3068"\w*, conforme \w a|strong="H3068"\w* \w vuestras|strong="H1697"\w* \w palabras|strong="H1697"\w*; y \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H4480"\w* Yahvé \w os|strong="H4480"\w* \w responda|strong="H6030"\w*, \w os|strong="H4480"\w* \w lo|strong="H1697"\w* declararé. \w No|strong="H3808"\w* \w os|strong="H4480"\w* ocultaré \w nada|strong="H3808"\w*».   
\p
\v 5 \w Ellos|strong="H1992"\w* \w dijeron|strong="H1697"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: «Yahvé \w sea|strong="H1961"\w* \w entre|strong="H3808"\w* \w nosotros|strong="H3605"\w* \w testigo|strong="H5707"\w* fiel y verdadero, \w si|strong="H3808"\w* \w no|strong="H3808"\w* hiciéramos conforme \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w palabra|strong="H1697"\w* \w que|strong="H3808"\w* Yahvé vuestro \w Dios|strong="H3068"\w* te \w envíe|strong="H7971"\w* \w a|strong="H3068"\w* decirnos.  
\v 6 Sea \w bueno|strong="H2896"\w* \w o|strong="H3068"\w* sea \w malo|strong="H7451"\w*, \w obedeceremos|strong="H8085"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w*, al \w cual|strong="H3588"\w* \w te|strong="H3588"\w* \w enviamos|strong="H7971"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* nos vaya \w bien|strong="H2896"\w* al \w obedecer|strong="H8085"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w*».   
\p
\v 7 Acontecieron \w diez|strong="H6235"\w* \w días|strong="H3117"\w*, y \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*.  
\v 8 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Johanán|strong="H3110"\w* \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Carea|strong="H7143"\w*, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* oficiales \w de|strong="H5704"\w* las fuerzas \w que|strong="H5704"\w* \w con|strong="H5704"\w* \w él|strong="H3605"\w* \w estaban|strong="H5971"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w desde|strong="H5704"\w* \w el|strong="H3605"\w* \w más|strong="H5704"\w* \w pequeño|strong="H6996"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w más|strong="H5704"\w* \w grande|strong="H1419"\w*;  
\v 9 \w y|strong="H3541"\w* les dijo: “\w Así|strong="H3541"\w* dice Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, al cual \w me|strong="H3541"\w* enviasteis para presentar vuestra \w súplica|strong="H8467"\w* en su \w presencia|strong="H6440"\w*:  
\v 10 ‘\w Si|strong="H3588"\w* os quedáis \w quietos|strong="H7725"\w* \w en|strong="H3588"\w* \w esta|strong="H2063"\w* tierra, os \w edificaré|strong="H1129"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* os \w destruiré|strong="H2040"\w*; os \w plantaré|strong="H5193"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* os \w arrancaré|strong="H5428"\w*; \w porque|strong="H3588"\w* \w me|strong="H3588"\w* pesa \w el|strong="H3588"\w* \w mal|strong="H7451"\w* \w que|strong="H3588"\w* os he \w hecho|strong="H6213"\w*.  
\v 11 \w No|strong="H3588"\w* \w temáis|strong="H3372"\w* \w al|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* Babilonia, \w de|strong="H4480"\w* quien tenéis \w miedo|strong="H3372"\w*; \w no|strong="H3588"\w* le \w temáis|strong="H3372"\w* — \w dice|strong="H5002"\w* Yahvé —, \w porque|strong="H3588"\w* \w con|strong="H4480"\w* vosotros estoy \w yo|strong="H4480"\w* \w para|strong="H3588"\w* salvaros \w y|strong="H3588"\w* \w libraros|strong="H5337"\w* \w de|strong="H4480"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*.  
\v 12 \w Y|strong="H3068"\w* tendré \w de|strong="H5414"\w* vosotros \w misericordia|strong="H7355"\w*, y él tendrá \w misericordia|strong="H7355"\w* \w de|strong="H5414"\w* vosotros y os \w hará|strong="H5414"\w* restituir \w a|strong="H3068"\w* vuestra tierra’.   
\p
\v 13 ‘\w Mas|strong="H3808"\w* \w si|strong="H3808"\w* decís: «\w No|strong="H3808"\w* \w moraremos|strong="H3427"\w* en \w esta|strong="H2063"\w* tierra», \w no|strong="H3808"\w* \w obedeciendo|strong="H8085"\w* \w así|strong="H2063"\w* \w la|strong="H2063"\w* \w voz|strong="H6963"\w* de Yahvé vuestro \w Dios|strong="H3068"\w*,  
\v 14 \w y|strong="H3588"\w* diciendo: «\w No|strong="H3808"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* nos iremos \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w donde|strong="H8033"\w* \w no|strong="H3808"\w* \w veremos|strong="H7200"\w* \w guerra|strong="H4421"\w*, \w ni|strong="H3808"\w* \w oiremos|strong="H8085"\w* \w sonido|strong="H6963"\w* \w de|strong="H3588"\w* \w trompeta|strong="H7782"\w*, \w ni|strong="H3808"\w* tendremos \w hambre|strong="H7456"\w* \w de|strong="H3588"\w* \w pan|strong="H3899"\w*, \w y|strong="H3588"\w* \w allí|strong="H8033"\w* \w moraremos|strong="H3427"\w*»;  
\v 15 \w ahora|strong="H6258"\w* \w por|strong="H1697"\w* \w eso|strong="H3651"\w*, \w oíd|strong="H8085"\w* la \w palabra|strong="H1697"\w* \w de|strong="H6440"\w* Yahvé, remanente \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*. \w Así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé \w de|strong="H6440"\w* los \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*: «\w Si|strong="H6440"\w* \w vosotros|strong="H8085"\w* volvéis vuestros \w rostros|strong="H6440"\w* \w para|strong="H6258"\w* entrar en \w Egipto|strong="H4714"\w*, \w y|strong="H3541"\w* entráis \w para|strong="H6258"\w* morar \w allí|strong="H8033"\w*,  
\v 16 \w sucederá|strong="H1961"\w* \w que|strong="H4480"\w* la \w espada|strong="H2719"\w* \w que|strong="H4480"\w* \w teméis|strong="H3372"\w* \w os|strong="H4480"\w* \w alcanzará|strong="H5381"\w* \w allí|strong="H8033"\w* \w en|strong="H4480"\w* la tierra \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*, y el \w hambre|strong="H7458"\w* \w de|strong="H4480"\w* \w que|strong="H4480"\w* tenéis \w miedo|strong="H3372"\w* \w os|strong="H4480"\w* perseguirá \w allí|strong="H8033"\w* \w en|strong="H4480"\w* \w Egipto|strong="H4714"\w*; y \w allí|strong="H8033"\w* \w moriréis|strong="H4191"\w*.  
\v 17 Así \w acontecerá|strong="H1961"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* hombres \w que|strong="H3808"\w* volvieren sus \w rostros|strong="H6440"\w* \w para|strong="H5921"\w* entrar \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w para|strong="H5921"\w* morar \w allí|strong="H8033"\w*: \w morirán|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w de|strong="H5921"\w* \w hambre|strong="H7458"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* peste; \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w quien|strong="H3605"\w* \w quede|strong="H1961"\w* \w ni|strong="H3808"\w* \w quien|strong="H3605"\w* escape \w del|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H3808"\w* traeré yo \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*» ’.  
\v 18 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: ‘\w Como|strong="H3588"\w* \w se|strong="H1961"\w* derramó \w mi|strong="H5921"\w* \w enojo|strong="H2534"\w* \w y|strong="H3588"\w* \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén, \w así|strong="H3541"\w* \w se|strong="H1961"\w* derramará \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* vosotros \w cuando|strong="H3588"\w* entréis \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w*; \w y|strong="H3588"\w* \w seréis|strong="H1961"\w* objeto \w de|strong="H5921"\w* execración, \w de|strong="H5921"\w* \w espanto|strong="H8047"\w*, \w de|strong="H5921"\w* \w maldición|strong="H7045"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w oprobio|strong="H2781"\w*; \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w veréis|strong="H7200"\w* \w más|strong="H5750"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*’.   
\p
\v 19 “Yahvé ha \w hablado|strong="H1696"\w* \w sobre|strong="H5921"\w* vosotros, remanente \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*: ‘\w No|strong="H3588"\w* vayáis \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*’. \w Sabed|strong="H3045"\w* \w ciertamente|strong="H3588"\w* \w que|strong="H3588"\w* \w os|strong="H5921"\w* \w lo|strong="H5921"\w* he advertido \w hoy|strong="H3117"\w*.  
\v 20 \w Porque|strong="H3588"\w* habéis usado \w de|strong="H3588"\w* engaño contra vuestras mismas \w almas|strong="H5315"\w*; \w pues|strong="H3588"\w* vosotros \w me|strong="H3588"\w* enviasteis \w a|strong="H3068"\w* Yahvé vuestro \w Dios|strong="H3068"\w*, diciendo: ‘\w Ruega|strong="H6419"\w* \w por|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w a|strong="H3068"\w* Yahvé nuestro \w Dios|strong="H3068"\w*, \w y|strong="H3588"\w* dinos \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w* dijere, \w y|strong="H3588"\w* \w lo|strong="H6213"\w* \w haremos|strong="H6213"\w*’.  
\v 21 Os \w lo|strong="H3808"\w* he \w declarado|strong="H5046"\w* \w hoy|strong="H3117"\w*, y \w no|strong="H3808"\w* habéis obedecido \w la|strong="H3605"\w* \w voz|strong="H6963"\w* de Yahvé vuestro \w Dios|strong="H3068"\w*, en \w ninguna|strong="H3605"\w* \w cosa|strong="H3605"\w* de las \w que|strong="H3808"\w* me \w envió|strong="H7971"\w* \w a|strong="H3068"\w* deciros.  
\v 22 \w Sabed|strong="H3045"\w*, \w pues|strong="H3588"\w*, \w ahora|strong="H6258"\w* \w ciertamente|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w de|strong="H3588"\w* \w hambre|strong="H7458"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* peste \w moriréis|strong="H4191"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \w deseasteis|strong="H2654"\w* entrar \w para|strong="H3588"\w* morar \w allí|strong="H8033"\w*”.   
\c 43
\p
\v 1 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H5971"\w* \w cuando|strong="H1961"\w* \w Jeremías|strong="H3414"\w* \w acabó|strong="H3615"\w* \w de|strong="H5971"\w* \w hablar|strong="H1696"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w de|strong="H5971"\w* Yahvé su \w Dios|strong="H3068"\w*, \w todas|strong="H3605"\w* estas \w palabras|strong="H1697"\w* con las cuales Yahvé su \w Dios|strong="H3068"\w* le \w había|strong="H1961"\w* \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* \w ellos|strong="H3605"\w*,  
\v 2 \w dijeron|strong="H1696"\w* \w Azarías|strong="H5838"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Oseas, \w Johanán|strong="H3110"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w* y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* varones \w soberbios|strong="H2086"\w*, \w diciendo|strong="H1696"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: “Habláis en \w falso|strong="H8267"\w*; \w no|strong="H3808"\w* te \w ha|strong="H3808"\w* \w enviado|strong="H7971"\w* Yahvé nuestro \w Dios|strong="H3068"\w* para decir: ‘\w No|strong="H3808"\w* vayáis \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* para morar \w allí|strong="H8033"\w*’,  
\v 3 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* Baruc \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Nerías \w te|strong="H3588"\w* incita contra nosotros, \w para|strong="H4616"\w* entregarnos \w en|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w caldeos|strong="H3778"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* nos maten \w o|strong="H3068"\w* nos transporten \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* Babilonia”.   
\p
\v 4 \w No|strong="H3808"\w* \w obedeció|strong="H8085"\w*, pues, \w Johanán|strong="H3110"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w*, \w ni|strong="H3808"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* oficiales \w de|strong="H1121"\w* las fuerzas, \w ni|strong="H3808"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w voz|strong="H6963"\w* \w de|strong="H1121"\w* Yahvé \w para|strong="H5971"\w* quedarse en \w la|strong="H3605"\w* tierra \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*,  
\v 5 sino \w que|strong="H1121"\w* \w Johanán|strong="H3110"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w* y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* oficiales \w de|strong="H1121"\w* las fuerzas \w tomaron|strong="H3947"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* remanente \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* \w que|strong="H1121"\w* se había \w vuelto|strong="H7725"\w* \w de|strong="H1121"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* adonde había sido arrojado, para morar en \w la|strong="H3605"\w* tierra \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*:  
\v 6 \w a|strong="H3068"\w* \w hombres|strong="H1121"\w*, \w mujeres|strong="H1323"\w* y \w niños|strong="H2945"\w*, \w a|strong="H3068"\w* las \w hijas|strong="H1323"\w* del \w rey|strong="H4428"\w* y \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w persona|strong="H5315"\w* \w que|strong="H1121"\w* \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* guardia, había dejado con \w Gedalías|strong="H1436"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán, y \w al|strong="H4428"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* y \w a|strong="H3068"\w* Baruc \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Nerías.  
\v 7 \w Y|strong="H3068"\w* entraron \w en|strong="H5704"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w obedecieron|strong="H8085"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* Yahvé; \w y|strong="H3588"\w* llegaron \w hasta|strong="H5704"\w* Tafnes.   
\p
\v 8 Entonces \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* en Tafnes, diciendo:  
\v 9 “\w Toma|strong="H3947"\w* en tu \w mano|strong="H3027"\w* piedras \w grandes|strong="H1419"\w* y escóndelas en la argamasa del pavimento \w de|strong="H5869"\w* ladrillo \w que|strong="H3027"\w* está \w a|strong="H3068"\w* la entrada \w de|strong="H5869"\w* la \w casa|strong="H1004"\w* \w de|strong="H5869"\w* \w Faraón|strong="H6547"\w* en Tafnes, \w a|strong="H3068"\w* vista \w de|strong="H5869"\w* los hombres \w de|strong="H5869"\w* Judá;  
\v 10 \w y|strong="H5921"\w* diles: ‘\w Así|strong="H3541"\w* dice Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* yo \w envío|strong="H7971"\w* \w y|strong="H5921"\w* \w tomaré|strong="H3947"\w* \w a|strong="H3068"\w* \w Nabucodonosor|strong="H5019"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w*, \w y|strong="H5921"\w* \w pondré|strong="H7760"\w* su \w trono|strong="H3678"\w* \w sobre|strong="H5921"\w* estas piedras \w que|strong="H5921"\w* he escondido, \w y|strong="H5921"\w* \w él|strong="H5921"\w* \w extenderá|strong="H7971"\w* su pabellón \w real|strong="H4428"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w*.  
\v 11 \w Y|strong="H3068"\w* vendrá y \w herirá|strong="H5221"\w* la tierra de \w Egipto|strong="H4714"\w*: el que \w a|strong="H3068"\w* \w muerte|strong="H4194"\w*, \w a|strong="H3068"\w* \w muerte|strong="H4194"\w*; el que \w a|strong="H3068"\w* \w cautiverio|strong="H7628"\w*, \w a|strong="H3068"\w* \w cautiverio|strong="H7628"\w*; y el que \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.  
\v 12 \w Y|strong="H3068"\w* pondré fuego \w a|strong="H3068"\w* las \w casas|strong="H1004"\w* de los dioses de \w Egipto|strong="H4714"\w*, y él los \w quemará|strong="H8313"\w* y los llevará cautivos; y se envolverá con la tierra de \w Egipto|strong="H4714"\w* como el \w pastor|strong="H7462"\w* se envuelve con su capa, y \w saldrá|strong="H3318"\w* de \w allí|strong="H8033"\w* \w en|strong="H3318"\w* \w paz|strong="H7965"\w*.  
\v 13 Además, \w quebrará|strong="H7665"\w* las \w columnas|strong="H4676"\w* de Bet-semes, que está en la tierra de \w Egipto|strong="H4714"\w*, y las \w casas|strong="H1004"\w* de los dioses de \w Egipto|strong="H4714"\w* \w quemará|strong="H8313"\w* \w a|strong="H3068"\w* fuego’”.   
\c 44
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w acerca|strong="H1697"\w* \w de|strong="H1697"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w judíos|strong="H3064"\w* \w que|strong="H1697"\w* \w moraban|strong="H3427"\w* en \w la|strong="H3605"\w* tierra \w de|strong="H1697"\w* \w Egipto|strong="H4714"\w*, \w los|strong="H3427"\w* cuales \w habitaban|strong="H3427"\w* en \w Migdol|strong="H4024"\w*, en Tafnes, en Menfis y en \w la|strong="H3605"\w* tierra \w de|strong="H1697"\w* Patros, diciendo:  
\v 2 “\w Así|strong="H3541"\w* dice Yahvé \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: ‘Vosotros habéis \w visto|strong="H7200"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H5921"\w* traje \w sobre|strong="H5921"\w* Jerusalén \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*; \w y|strong="H5921"\w* he \w aquí|strong="H2088"\w* \w que|strong="H5921"\w* \w hoy|strong="H3117"\w* \w están|strong="H3427"\w* desoladas, \w y|strong="H5921"\w* \w no|strong="H5921"\w* hay \w quien|strong="H3605"\w* habite \w en|strong="H5921"\w* \w ellas|strong="H5921"\w*,  
\v 3 \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* la \w maldad|strong="H7451"\w* \w que|strong="H3808"\w* \w ellos|strong="H1992"\w* \w cometieron|strong="H6213"\w* para provocarme \w a|strong="H3068"\w* \w ira|strong="H3212"\w*, \w yendo|strong="H3212"\w* \w a|strong="H3068"\w* ofrecer incienso y \w a|strong="H3068"\w* \w servir|strong="H5647"\w* \w a|strong="H3068"\w* dioses ajenos \w que|strong="H3808"\w* \w no|strong="H3808"\w* habían \w conocido|strong="H3045"\w* \w ellos|strong="H1992"\w*, \w ni|strong="H3808"\w* vosotros, \w ni|strong="H3808"\w* \w vuestros|strong="H5647"\w* padres.  
\v 4 \w Y|strong="H3068"\w* \w envié|strong="H7971"\w* \w a|strong="H3068"\w* vosotros \w todos|strong="H3605"\w* mis \w siervos|strong="H5650"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w*, \w madrugando|strong="H7925"\w* y enviándolos sin cesar, para deciros: «\w No|strong="H6213"\w* \w hagáis|strong="H6213"\w* \w esta|strong="H2063"\w* \w cosa|strong="H1697"\w* \w abominable|strong="H8441"\w* \w que|strong="H4994"\w* \w yo|strong="H4994"\w* \w aborrezco|strong="H8130"\w*».  
\v 5 Pero \w no|strong="H3808"\w* \w escucharon|strong="H8085"\w* \w ni|strong="H3808"\w* \w inclinaron|strong="H5186"\w* su \w oído|strong="H8085"\w* para convertirse \w de|strong="H7451"\w* su \w maldad|strong="H7451"\w*, \w a|strong="H3068"\w* fin \w de|strong="H7451"\w* dejar \w de|strong="H7451"\w* ofrecer incienso \w a|strong="H3068"\w* dioses ajenos.  
\v 6 \w Se|strong="H1961"\w* derramó, \w por|strong="H2088"\w* tanto, \w mi|strong="H3389"\w* \w ira|strong="H2534"\w* \w y|strong="H1197"\w* \w mi|strong="H3389"\w* \w furor|strong="H2534"\w*, \w y|strong="H1197"\w* \w se|strong="H1961"\w* encendió en las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w* \w y|strong="H1197"\w* en las \w calles|strong="H2351"\w* de Jerusalén; \w y|strong="H1197"\w* \w quedaron|strong="H1961"\w* \w asoladas|strong="H8077"\w* \w y|strong="H1197"\w* \w desiertas|strong="H2723"\w*, \w como|strong="H1961"\w* \w se|strong="H1961"\w* ve en el \w día|strong="H3117"\w* de \w hoy|strong="H3117"\w*’.   
\p
\v 7 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w así|strong="H3541"\w* dice Yahvé \w de|strong="H7451"\w* los \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H7451"\w* \w Israel|strong="H3478"\w*: ‘¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w hacéis|strong="H6213"\w* tan \w grande|strong="H1419"\w* \w mal|strong="H7451"\w* \w contra|strong="H3478"\w* vuestras \w almas|strong="H5315"\w*, \w para|strong="H6258"\w* \w ser|strong="H5315"\w* cortados \w de|strong="H7451"\w* \w entre|strong="H8432"\w* \w Judá|strong="H3063"\w*, hombres \w y|strong="H3541"\w* mujeres, \w niños|strong="H5768"\w* \w y|strong="H3541"\w* lactantes, hasta \w no|strong="H6213"\w* dejaros remanente \w alguno|strong="H5315"\w*,  
\v 8 provocándome \w a|strong="H3068"\w* ira con las \w obras|strong="H4639"\w* de vuestras \w manos|strong="H3027"\w*, ofreciendo incienso \w a|strong="H3068"\w* dioses ajenos en \w la|strong="H3605"\w* tierra de \w Egipto|strong="H4714"\w*, adonde habéis entrado \w para|strong="H4616"\w* morar, \w para|strong="H4616"\w* \w que|strong="H1961"\w* \w seáis|strong="H1961"\w* cortados y sirváis de \w maldición|strong="H7045"\w* y de escarnio \w entre|strong="H8033"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* de \w la|strong="H3605"\w* tierra?  
\v 9 ¿Acaso os habéis olvidado \w de|strong="H7911"\w* las \w maldades|strong="H7451"\w* \w de|strong="H7911"\w* vuestros padres, \w de|strong="H7911"\w* las \w maldades|strong="H7451"\w* \w de|strong="H7911"\w* los \w reyes|strong="H4428"\w* \w de|strong="H7911"\w* \w Judá|strong="H3063"\w*, \w de|strong="H7911"\w* las \w maldades|strong="H7451"\w* \w de|strong="H7911"\w* sus mujeres, \w de|strong="H7911"\w* vuestras propias \w maldades|strong="H7451"\w* y \w de|strong="H7911"\w* las \w maldades|strong="H7451"\w* \w de|strong="H7911"\w* vuestras mujeres, que \w cometieron|strong="H6213"\w* en la tierra \w de|strong="H7911"\w* \w Judá|strong="H3063"\w* y en las \w calles|strong="H2351"\w* \w de|strong="H7911"\w* Jerusalén?  
