\p
\v 36 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé:  
\q1 «He \w aquí|strong="H3541"\w* \w que|strong="H3541"\w* yo \w juzgo|strong="H7379"\w* tu \w causa|strong="H7379"\w* \w y|strong="H3541"\w* llevaré \w a|strong="H3068"\w* cabo tu \w venganza|strong="H5360"\w*;  
