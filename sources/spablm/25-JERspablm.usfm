\q2 \w y|strong="H3588"\w* \w su|strong="H3588"\w* valentía \w no|strong="H3808"\w* \w es|strong="H1961"\w* recta.   
\q1
\v 11 «\w Porque|strong="H3588"\w* tanto \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w* \w son|strong="H3588"\w* fingidos;  
\q2 \w aun|strong="H1571"\w* \w en|strong="H3588"\w* mi \w casa|strong="H1004"\w* \w hallé|strong="H4672"\w* \w su|strong="H3588"\w* \w maldad|strong="H7451"\w*», \w dice|strong="H5002"\w* Yahvé.   
\q1
\v 12 «\w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w su|strong="H1992"\w* \w camino|strong="H1870"\w* \w será|strong="H1961"\w* \w como|strong="H3588"\w* resbaladeros \w en|strong="H5921"\w* tinieblas;  
\q2 \w serán|strong="H1961"\w* empujados \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w él|strong="H5921"\w* \w caerán|strong="H5307"\w*;  
\q1 \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* traeré \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H1992"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* \w de|strong="H5921"\w* \w su|strong="H1992"\w* \w castigo|strong="H7451"\w*», \w dice|strong="H5002"\w* Yahvé.   
\b  
\q1
\v 13 «En los \w profetas|strong="H5030"\w* \w de|strong="H5971"\w* \w Samaria|strong="H8111"\w* he \w visto|strong="H7200"\w* locura;  
\q2 \w profetizaban|strong="H5012"\w* en nombre \w de|strong="H5971"\w* \w Baal|strong="H1168"\w*,  
\q2 \w e|strong="H3068"\w* hicieron \w errar|strong="H8582"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.   
\q1
\v 14 \w Y|strong="H3068"\w* en \w los|strong="H3427"\w* \w profetas|strong="H5030"\w* \w de|strong="H7451"\w* Jerusalén he \w visto|strong="H7200"\w* \w cosas|strong="H7451"\w* espantosas:  
\q2 cometían adulterios y andaban en \w mentiras|strong="H8267"\w*,  
\q1 y fortalecían las \w manos|strong="H3027"\w* \w de|strong="H7451"\w* \w los|strong="H3427"\w* \w malos|strong="H7451"\w*,  
\q2 \w para|strong="H1961"\w* \w que|strong="H1115"\w* \w ninguno|strong="H3605"\w* \w se|strong="H1961"\w* convirtiese \w de|strong="H7451"\w* su \w maldad|strong="H7451"\w*;  
\q1 me \w fueron|strong="H1961"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3027"\w* \w como|strong="H1961"\w* \w Sodoma|strong="H5467"\w*,  
\q2 y sus \w moradores|strong="H3427"\w* \w como|strong="H1961"\w* \w Gomorra|strong="H6017"\w*».   
\p
\v 15 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* \w contra|strong="H5921"\w* \w aquellos|strong="H3605"\w* \w profetas|strong="H5030"\w*:  
\q1 «He \w aquí|strong="H3541"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w les|strong="H5921"\w* alimento \w con|strong="H5921"\w* ajenjo,  
\q2 \w y|strong="H3588"\w* \w les|strong="H5921"\w* haré \w beber|strong="H8248"\w* \w agua|strong="H4325"\w* \w de|strong="H5921"\w* hiel;  
\q2 \w porque|strong="H3588"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w* \w de|strong="H5921"\w* Jerusalén \w salió|strong="H3318"\w* \w la|strong="H5921"\w* hipocresía \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra».   
\p
\v 16 \w Así|strong="H3541"\w* \w dice|strong="H1696"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w Ejércitos|strong="H6635"\w*:  
\q1 “\w No|strong="H3808"\w* \w escuchéis|strong="H8085"\w* \w las|strong="H1992"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* \w que|strong="H3808"\w* \w os|strong="H5921"\w* \w profetizan|strong="H5012"\w*;  
\q2 \w os|strong="H5921"\w* alimentan \w con|strong="H5921"\w* vanas esperanzas;  
\q2 \w hablan|strong="H1696"\w* \w visión|strong="H2377"\w* \w de|strong="H5921"\w* \w su|strong="H1992"\w* propio \w corazón|strong="H3820"\w*,  
\q2 \w no|strong="H3808"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* Yahvé.   
\q1
\v 17 \w Dicen|strong="H1696"\w* atrevidamente \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H3808"\w* \w me|strong="H5921"\w* irritan:  
\q2 ‘Yahvé \w dijo|strong="H1696"\w*: «\w Paz|strong="H7965"\w* \w tendréis|strong="H1961"\w*»’;  
\q1 \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H3808"\w* \w anda|strong="H1980"\w* tras \w la|strong="H5921"\w* dureza \w de|strong="H5921"\w* su \w corazón|strong="H3820"\w*, \w dicen|strong="H1696"\w*:  
\q2 ‘\w No|strong="H3808"\w* \w vendrá|strong="H1961"\w* \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* vosotros’.   
\q1
\v 18 \w Porque|strong="H3588"\w* ¿\w quién|strong="H4310"\w* \w estuvo|strong="H5975"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* secreto \w de|strong="H3588"\w* Yahvé,  
\q2 \w y|strong="H3588"\w* \w vio|strong="H7200"\w* \w y|strong="H3588"\w* \w oyó|strong="H8085"\w* \w su|strong="H3588"\w* \w palabra|strong="H1697"\w*?  
\q2 ¿\w Quién|strong="H4310"\w* \w estuvo|strong="H5975"\w* \w atento|strong="H7181"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w palabra|strong="H1697"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w oyó|strong="H8085"\w*?   
\q1
\v 19 He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* torbellino \w de|strong="H5921"\w* Yahvé \w sale|strong="H3318"\w* \w con|strong="H5921"\w* \w furor|strong="H2534"\w*;  
\q2 \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w tempestad|strong="H5591"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* prepara,  
\q2 caerá \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* malos.   
\q1
\v 20 \w No|strong="H3808"\w* \w se|strong="H3808"\w* apartará \w el|strong="H6213"\w* furor \w de|strong="H5704"\w* Yahvé \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* haya \w hecho|strong="H6213"\w*  
\q2 \w y|strong="H5704"\w* \w cumplido|strong="H6213"\w* los pensamientos \w de|strong="H5704"\w* su \w corazón|strong="H3820"\w*;  
\q2 \w en|strong="H5704"\w* los postreros \w días|strong="H3117"\w* \w lo|strong="H3808"\w* entenderéis cumplidamente.   
\q1
\v 21 \w No|strong="H3808"\w* \w envié|strong="H7971"\w* yo \w aquellos|strong="H1992"\w* \w profetas|strong="H5030"\w*, pero \w ellos|strong="H1992"\w* \w corrían|strong="H7323"\w*;  
\q2 yo \w no|strong="H3808"\w* \w les|strong="H1992"\w* \w hablé|strong="H1696"\w*, \w mas|strong="H3808"\w* \w ellos|strong="H1992"\w* \w profetizaban|strong="H5012"\w*.   
\q1
\v 22 Pero si ellos hubieran \w estado|strong="H5975"\w* \w en|strong="H5975"\w* mi secreto,  
\q2 habrían hecho \w oír|strong="H8085"\w* mis \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w*,  
\q1 y los habrían hecho \w volver|strong="H7725"\w* \w de|strong="H5971"\w* su \w mal|strong="H7451"\w* \w camino|strong="H1870"\w*,  
\q2 y \w de|strong="H5971"\w* la \w maldad|strong="H7451"\w* \w de|strong="H5971"\w* sus \w obras|strong="H4611"\w*.   
\b  
\q1
\v 23 “¿Soy yo \w Dios|strong="H3068"\w* de \w cerca|strong="H7138"\w* solamente — \w dice|strong="H5002"\w* Yahvé —,  
\q2 y \w no|strong="H3808"\w* \w Dios|strong="H3068"\w* desde \w lejos|strong="H7350"\w*?   
\q1
\v 24 ¿Ocultará alguno, en escondrijos,  
\q2 \w que|strong="H3808"\w* yo \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w vea|strong="H7200"\w*? — \w dice|strong="H5002"\w* Yahvé —.  
\q2 ¿\w No|strong="H3808"\w* \w lleno|strong="H4390"\w* yo, \w dice|strong="H5002"\w* Yahvé, el \w cielo|strong="H8064"\w* y la tierra?   
\p
\v 25 “Yo he \w oído|strong="H8085"\w* lo que aquellos \w profetas|strong="H5030"\w* dijeron, \w profetizando|strong="H5012"\w* \w mentira|strong="H8267"\w* en mi \w nombre|strong="H8034"\w*, diciendo: ‘¡\w Soñé|strong="H2492"\w*, \w soñé|strong="H2492"\w*!’.  
\v 26 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* estará esto \w en|strong="H5704"\w* \w el|strong="H5030"\w* \w corazón|strong="H3820"\w* \w de|strong="H5704"\w* los \w profetas|strong="H5030"\w* \w que|strong="H5704"\w* \w profetizan|strong="H5012"\w* \w mentira|strong="H8267"\w*, \w y|strong="H5704"\w* \w que|strong="H5704"\w* \w profetizan|strong="H5012"\w* \w el|strong="H5030"\w* \w engaño|strong="H8267"\w* \w de|strong="H5704"\w* su \w corazón|strong="H3820"\w*?  
\v 27 ¿No \w piensan|strong="H2803"\w* cómo hacen \w que|strong="H5971"\w* mi \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* olvide \w de|strong="H5971"\w* mi \w nombre|strong="H8034"\w* con sus \w sueños|strong="H2472"\w* \w que|strong="H5971"\w* cada uno \w cuenta|strong="H5608"\w* \w a|strong="H3068"\w* su \w compañero|strong="H7453"\w*, al modo \w que|strong="H5971"\w* sus padres \w se|strong="H5971"\w* \w olvidaron|strong="H7911"\w* \w de|strong="H5971"\w* mi \w nombre|strong="H8034"\w* por \w Baal|strong="H1168"\w*?  
\v 28 \w El|strong="H5030"\w* \w profeta|strong="H5030"\w* \w que|strong="H4100"\w* tuviere un \w sueño|strong="H2472"\w*, \w cuente|strong="H5608"\w* su \w sueño|strong="H2472"\w*; y aquel \w a|strong="H3068"\w* \w quien|strong="H4100"\w* fuere mi \w palabra|strong="H1697"\w*, \w cuente|strong="H5608"\w* mi \w palabra|strong="H1697"\w* verdadera. ¿\w Qué|strong="H4100"\w* tiene \w que|strong="H4100"\w* ver la \w paja|strong="H8401"\w* con \w el|strong="H5030"\w* \w trigo|strong="H1250"\w*?”, \w dice|strong="H5002"\w* Yahvé.  
\v 29 «¿\w No|strong="H3808"\w* \w es|strong="H1697"\w* mi \w palabra|strong="H1697"\w* como fuego — \w dice|strong="H5002"\w* Yahvé —, \w y|strong="H3541"\w* como martillo \w que|strong="H3808"\w* quebranta la \w piedra|strong="H5553"\w*?».   
\p
\v 30 “\w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H2005"\w* yo estoy \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w* — \w dice|strong="H5002"\w* Yahvé — \w que|strong="H5921"\w* hurtan mis \w palabras|strong="H1697"\w* \w cada|strong="H1697"\w* uno \w de|strong="H5921"\w* su \w prójimo|strong="H7453"\w*.  
\v 31 He \w aquí|strong="H2005"\w* yo estoy \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w* — \w dice|strong="H5002"\w* Yahvé — \w que|strong="H5921"\w* endulzan sus lenguas \w y|strong="H5921"\w* dicen: ‘\w Él|strong="H5921"\w* ha \w dicho|strong="H5002"\w*’.  
\v 32 He \w aquí|strong="H2088"\w* \w yo|strong="H6680"\w* estoy \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3808"\w* \w profetizan|strong="H5012"\w* \w sueños|strong="H2472"\w* \w mentirosos|strong="H8267"\w* — \w dice|strong="H5002"\w* Yahvé —, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w cuentan|strong="H5608"\w*, \w y|strong="H5921"\w* hacen \w errar|strong="H8582"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w con|strong="H5921"\w* sus \w mentiras|strong="H8267"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* sus lisonjas, \w y|strong="H5921"\w* \w yo|strong="H6680"\w* \w no|strong="H3808"\w* \w los|strong="H5921"\w* \w envié|strong="H7971"\w* \w ni|strong="H3808"\w* \w les|strong="H5921"\w* \w mandé|strong="H6680"\w*; \w y|strong="H5921"\w* \w ningún|strong="H3808"\w* \w provecho|strong="H3276"\w* traen \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*”, \w dice|strong="H5002"\w* Yahvé.   
\p
\v 33 “\w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w te|strong="H3588"\w* \w preguntare|strong="H7592"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w o|strong="H3068"\w* \w el|strong="H3588"\w* \w profeta|strong="H5030"\w*, \w o|strong="H3068"\w* \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w*, diciendo: ‘¿\w Cuál|strong="H4100"\w* \w es|strong="H2088"\w* \w la|strong="H3588"\w* \w carga|strong="H4853"\w* \w de|strong="H3588"\w* Yahvé?’, les dirás: ‘¿\w Qué|strong="H3588"\w* \w carga|strong="H4853"\w*? Os dejaré’, \w dice|strong="H5002"\w* Yahvé.  
\v 34 \w Y|strong="H3068"\w* \w al|strong="H5921"\w* \w profeta|strong="H5030"\w*, \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w o|strong="H3068"\w* \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H1931"\w* dijere: ‘\w Carga|strong="H4853"\w* \w de|strong="H5921"\w* Yahvé’, yo \w enviaré|strong="H6485"\w* castigo \w sobre|strong="H5921"\w* tal hombre \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* \w casa|strong="H1004"\w*.  
\v 35 \w Así|strong="H3541"\w* diréis cada \w cual|strong="H4100"\w* \w a|strong="H3068"\w* su \w compañero|strong="H7453"\w*, \w y|strong="H5921"\w* cada \w cual|strong="H4100"\w* \w a|strong="H3068"\w* su hermano: ‘¿\w Qué|strong="H4100"\w* \w ha|strong="H3541"\w* respondido Yahvé?’, \w y|strong="H5921"\w*: ‘¿\w Qué|strong="H4100"\w* \w ha|strong="H3541"\w* \w hablado|strong="H1696"\w* Yahvé?’.  
\v 36 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* os acordaréis \w más|strong="H5750"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w carga|strong="H4853"\w* \w de|strong="H3588"\w* Yahvé; \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* \w cada|strong="H1697"\w* uno le \w será|strong="H1961"\w* \w por|strong="H3588"\w* \w carga|strong="H4853"\w*; \w pues|strong="H3588"\w* habéis pervertido las \w palabras|strong="H1697"\w* del \w Dios|strong="H3068"\w* \w vivo|strong="H2416"\w*, \w de|strong="H3588"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* nuestro.  
\v 37 \w Así|strong="H3541"\w* \w dirás|strong="H1696"\w* al \w profeta|strong="H5030"\w*: ‘¿\w Qué|strong="H4100"\w* te \w respondió|strong="H6030"\w* Yahvé, \w y|strong="H3541"\w* \w qué|strong="H4100"\w* \w habló|strong="H1696"\w* Yahvé?’.  
\v 38 \w Mas|strong="H3808"\w* \w si|strong="H3808"\w* dijereis: ‘\w Carga|strong="H4853"\w* \w de|strong="H1697"\w* Yahvé’, \w por|strong="H3282"\w* \w eso|strong="H3651"\w* Yahvé \w dice|strong="H1697"\w* \w así|strong="H3541"\w*: ‘\w Porque|strong="H3282"\w* dijisteis \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*, «\w Carga|strong="H4853"\w* \w de|strong="H1697"\w* Yahvé», habiendo yo \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* deciros: «\w No|strong="H3808"\w* digáis \w Carga|strong="H4853"\w* \w de|strong="H1697"\w* Yahvé»,  
\v 39 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H2005"\w* \w que|strong="H5921"\w* yo \w os|strong="H5921"\w* olvidaré \w del|strong="H5921"\w* todo, \w y|strong="H5921"\w* \w os|strong="H5921"\w* arrancaré \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w presencia|strong="H6440"\w*, \w a|strong="H3068"\w* vosotros \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w que|strong="H5921"\w* \w di|strong="H5414"\w* \w a|strong="H3068"\w* vosotros \w y|strong="H5921"\w* \w a|strong="H3068"\w* vuestros padres;  
\v 40 \w y|strong="H5921"\w* \w pondré|strong="H5414"\w* \w sobre|strong="H5921"\w* vosotros \w oprobio|strong="H2781"\w* \w eterno|strong="H5769"\w*, \w y|strong="H5921"\w* \w eterna|strong="H5769"\w* \w confusión|strong="H3640"\w* \w que|strong="H3808"\w* \w nunca|strong="H3808"\w* borrará \w el|strong="H5921"\w* \w olvido|strong="H7911"\w*’”.   
\c 24
\p
\v 1 \w El|strong="H1121"\w* \w Señor|strong="H3068"\w* me \w mostró|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* \w dos|strong="H8147"\w* cestos \w de|strong="H6440"\w* \w higos|strong="H8384"\w* puestos \w delante|strong="H6440"\w* del \w templo|strong="H1964"\w* del \w Señor|strong="H3068"\w*, después \w que|strong="H1121"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Babilonia, \w hubo|strong="H2009"\w* transportado \w al|strong="H4428"\w* cautiverio \w a|strong="H3068"\w* Jeconías \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Joacim|strong="H3079"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*, y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w príncipes|strong="H8269"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*, con \w los|strong="H1121"\w* artesanos y herreros, \w de|strong="H6440"\w* Jerusalén, y \w los|strong="H1121"\w* \w hubo|strong="H2009"\w* llevado \w a|strong="H3068"\w* Babilonia.  
\v 2 Un cesto tenía \w higos|strong="H8384"\w* \w muy|strong="H3966"\w* \w buenos|strong="H2896"\w*, como los \w higos|strong="H8384"\w* brevales; y el otro cesto tenía \w higos|strong="H8384"\w* \w muy|strong="H3966"\w* \w malos|strong="H7451"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* podían comer \w de|strong="H7451"\w* \w malos|strong="H7451"\w* \w que|strong="H3808"\w* \w eran|strong="H3808"\w*.   
\p
\v 3 Entonces me preguntó Yahvé: «¿\w Qué|strong="H4100"\w* \w ves|strong="H7200"\w*, \w Jeremías|strong="H3414"\w*?»  
\p \w Y|strong="H3068"\w* dije: «\w Higos|strong="H8384"\w*; los \w higos|strong="H8384"\w* \w buenos|strong="H2896"\w* \w son|strong="H3808"\w* \w muy|strong="H3966"\w* \w buenos|strong="H2896"\w*, y los \w malos|strong="H7451"\w* \w muy|strong="H3966"\w* \w malos|strong="H7451"\w*, \w tanto|strong="H3966"\w* \w que|strong="H4100"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* pueden comer».   
\p
\v 4 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 5 “\w Así|strong="H3541"\w* dice Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*: ‘\w Como|strong="H3651"\w* \w a|strong="H3068"\w* \w estos|strong="H2088"\w* \w higos|strong="H8384"\w* \w buenos|strong="H2896"\w*, \w así|strong="H3541"\w* consideraré \w a|strong="H3068"\w* los transportados \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* \w al|strong="H4480"\w* \w cautiverio|strong="H1546"\w*, \w a|strong="H3068"\w* quienes \w eché|strong="H7971"\w* \w de|strong="H4480"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w a|strong="H3068"\w* la tierra \w de|strong="H4480"\w* los \w caldeos|strong="H3778"\w*, \w para|strong="H4480"\w* su \w bien|strong="H2896"\w*.  
\v 6 \w Porque|strong="H5921"\w* \w pondré|strong="H7760"\w* mis \w ojos|strong="H5869"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w para|strong="H5921"\w* \w bien|strong="H2896"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w haré|strong="H7760"\w* \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* tierra; \w los|strong="H5921"\w* \w edificaré|strong="H1129"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w los|strong="H5921"\w* derribaré; \w los|strong="H5921"\w* \w plantaré|strong="H5193"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w los|strong="H5921"\w* \w arrancaré|strong="H5428"\w*.  
\v 7 \w Y|strong="H3068"\w* les \w daré|strong="H5414"\w* un \w corazón|strong="H3820"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w conozcan|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé; \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w serán|strong="H1961"\w* \w por|strong="H3588"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H3588"\w* \w yo|strong="H3588"\w* les \w seré|strong="H1961"\w* \w por|strong="H3588"\w* \w Dios|strong="H3068"\w*; \w porque|strong="H3588"\w* \w se|strong="H3045"\w* \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w*.   
\p
\v 8 ‘\w Y|strong="H3068"\w* \w como|strong="H3588"\w* \w los|strong="H3427"\w* \w higos|strong="H8384"\w* \w malos|strong="H7451"\w*, \w que|strong="H3588"\w* \w de|strong="H3588"\w* \w malos|strong="H7451"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* pueden comer’, \w así|strong="H3541"\w* dice \w ciertamente|strong="H3588"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w*, ‘\w así|strong="H3541"\w* \w entregaré|strong="H5414"\w* \w a|strong="H3068"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* sus \w príncipes|strong="H8269"\w*, \w y|strong="H3588"\w* \w al|strong="H4428"\w* \w resto|strong="H7611"\w* \w de|strong="H3588"\w* Jerusalén \w que|strong="H3588"\w* \w quedó|strong="H7604"\w* \w en|strong="H3588"\w* \w esta|strong="H2063"\w* tierra, \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w habitan|strong="H3427"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.  
\v 9 \w Y|strong="H3068"\w* \w los|strong="H3605"\w* \w entregaré|strong="H5414"\w* \w para|strong="H5414"\w* ser escarnecidos y maltratados \w por|strong="H5414"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reinos|strong="H4467"\w* \w de|strong="H5414"\w* \w la|strong="H3605"\w* tierra; \w para|strong="H5414"\w* \w oprobio|strong="H2781"\w* y proverbio, \w para|strong="H5414"\w* burla y \w maldición|strong="H7045"\w* en \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w lugares|strong="H4725"\w* \w a|strong="H3068"\w* \w donde|strong="H8033"\w* yo \w los|strong="H3605"\w* arroje.  
\v 10 \w Y|strong="H3068"\w* \w enviaré|strong="H7971"\w* \w contra|strong="H5921"\w* \w ellos|strong="H1992"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*, \w el|strong="H5921"\w* \w hambre|strong="H7458"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w pestilencia|strong="H1698"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* sean \w consumidos|strong="H8552"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* \w les|strong="H1992"\w* \w di|strong="H5414"\w* \w a|strong="H3068"\w* \w ellos|strong="H1992"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* padres’”.   
\c 25
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H1931"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w año|strong="H8141"\w* \w cuarto|strong="H7243"\w* \w de|strong="H5921"\w* \w Joacim|strong="H3079"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* (\w que|strong="H1931"\w* \w era|strong="H1961"\w* \w el|strong="H1931"\w* \w año|strong="H8141"\w* primero \w de|strong="H5921"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia),  
\v 2 \w la|strong="H5921"\w* cual \w habló|strong="H1696"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén, \w diciendo|strong="H1696"\w*:  
\v 3 \w Desde|strong="H4480"\w* \w el|strong="H1121"\w* \w año|strong="H8141"\w* \w trece|strong="H7969"\w* \w de|strong="H4480"\w* \w Josías|strong="H2977"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Amón, \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w hasta|strong="H5704"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w*, \w que|strong="H4480"\w* \w son|strong="H1961"\w* \w veintitrés|strong="H6242"\w* \w años|strong="H8141"\w*, \w ha|strong="H3808"\w* venido \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H4480"\w* Yahvé, \w y|strong="H5704"\w* \w os|strong="H4480"\w* he \w hablado|strong="H1696"\w*, \w madrugando|strong="H7925"\w* \w y|strong="H5704"\w* \w hablando|strong="H1696"\w*; pero \w no|strong="H3808"\w* habéis escuchado.   
\p
\v 4 \w Y|strong="H3068"\w* Yahvé os \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w siervos|strong="H5650"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w*, \w madrugando|strong="H7925"\w* y enviándolos; \w mas|strong="H3808"\w* \w no|strong="H3808"\w* habéis escuchado \w ni|strong="H3808"\w* inclinado vuestro \w oído|strong="H8085"\w* para \w oír|strong="H8085"\w*,  
\v 5 \w cuando|strong="H5704"\w* decían: «\w Volved|strong="H7725"\w* \w ahora|strong="H4994"\w* cada uno \w de|strong="H4480"\w* vuestro \w mal|strong="H7451"\w* \w camino|strong="H1870"\w* \w y|strong="H5921"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w maldad|strong="H7451"\w* \w de|strong="H4480"\w* vuestras \w obras|strong="H4611"\w*, \w y|strong="H5921"\w* \w habitad|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H4480"\w* Yahvé \w os|strong="H4480"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* vosotros \w y|strong="H5921"\w* \w a|strong="H3068"\w* vuestros padres \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.  
\v 6 \w No|strong="H3808"\w* \w vayáis|strong="H3212"\w* \w en|strong="H3212"\w* pos de dioses ajenos para servirles y para postraros ante \w ellos|strong="H3027"\w*, \w ni|strong="H3808"\w* me provoquéis \w a|strong="H3068"\w* \w ira|strong="H3212"\w* con la \w obra|strong="H4639"\w* de vuestras \w manos|strong="H3027"\w*; y \w no|strong="H3808"\w* os haré \w mal|strong="H7489"\w*».   
\p
\v 7 «\w Sin|strong="H3808"\w* embargo, \w no|strong="H3808"\w* me habéis escuchado — \w dice|strong="H5002"\w* Yahvé —, \w para|strong="H4616"\w* provocarme \w a|strong="H3068"\w* ira con la \w obra|strong="H4639"\w* \w de|strong="H7451"\w* vuestras \w manos|strong="H3027"\w* \w para|strong="H4616"\w* vuestro propio \w mal|strong="H7451"\w*».   
\p
\v 8 \w Por|strong="H3282"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé \w de|strong="H1697"\w* los \w Ejércitos|strong="H6635"\w*: “\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w no|strong="H3808"\w* habéis \w oído|strong="H8085"\w* mis \w palabras|strong="H1697"\w*,  
\v 9 he \w aquí|strong="H2005"\w* \w enviaré|strong="H7971"\w* \w y|strong="H5921"\w* \w tomaré|strong="H3947"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w familias|strong="H4940"\w* \w del|strong="H5921"\w* \w norte|strong="H6828"\w* — \w dice|strong="H5002"\w* Yahvé —, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w Nabucodonosor|strong="H5019"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w*, \w y|strong="H5921"\w* \w los|strong="H3427"\w* traeré \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* tierra \w y|strong="H5921"\w* \w contra|strong="H5921"\w* sus \w moradores|strong="H3427"\w*, \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w estas|strong="H2063"\w* \w naciones|strong="H1471"\w* \w en|strong="H5921"\w* \w derredor|strong="H5439"\w*; \w y|strong="H5921"\w* \w los|strong="H3427"\w* destruiré \w por|strong="H5921"\w* completo, \w y|strong="H5921"\w* \w los|strong="H3427"\w* \w pondré|strong="H7760"\w* \w por|strong="H5921"\w* escarnio, \w y|strong="H5921"\w* \w por|strong="H5921"\w* silbido \w y|strong="H5921"\w* \w en|strong="H5921"\w* desolación \w perpetua|strong="H5769"\w*.  
\v 10 \w Y|strong="H3068"\w* haré \w que|strong="H1992"\w* perezca entre \w ellos|strong="H1992"\w* la \w voz|strong="H6963"\w* de \w gozo|strong="H8057"\w* y la \w voz|strong="H6963"\w* de \w alegría|strong="H8057"\w*, la \w voz|strong="H6963"\w* del \w esposo|strong="H2860"\w* y la \w voz|strong="H6963"\w* de la \w esposa|strong="H3618"\w*, \w el|strong="H1992"\w* \w ruido|strong="H6963"\w* de \w las|strong="H1992"\w* muelas de molino y la luz de la \w lámpara|strong="H5216"\w*.  
\v 11 \w Toda|strong="H3605"\w* \w esta|strong="H2063"\w* tierra \w será|strong="H1961"\w* puesta en ruinas y en \w espanto|strong="H8047"\w*; y \w servirán|strong="H5647"\w* \w estas|strong="H2063"\w* \w naciones|strong="H1471"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de Babilonia \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*.   
\p
\v 12 «\w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H1931"\w* \w cuando|strong="H1961"\w* \w se|strong="H1961"\w* cumplan \w los|strong="H5921"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*, castigaré \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w aquella|strong="H1931"\w* \w nación|strong="H1471"\w* — \w dice|strong="H5002"\w* Yahvé — \w por|strong="H5921"\w* \w su|strong="H1931"\w* \w maldad|strong="H5771"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w*; \w y|strong="H5921"\w* \w la|strong="H1931"\w* convertiré \w en|strong="H5921"\w* desolaciones \w perpetuas|strong="H5769"\w*.  
\v 13 \w Y|strong="H3068"\w* traeré \w sobre|strong="H5921"\w* \w aquella|strong="H1931"\w* tierra \w todas|strong="H3605"\w* mis \w palabras|strong="H1697"\w* \w que|strong="H1931"\w* he \w hablado|strong="H1696"\w* \w contra|strong="H5921"\w* \w ella|strong="H1931"\w*, \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w está|strong="H2088"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w libro|strong="H5612"\w*, \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w Jeremías|strong="H3414"\w* \w profetizó|strong="H5012"\w* \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.  
\v 14 \w Porque|strong="H3588"\w* \w también|strong="H1571"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w* \w se|strong="H1992"\w* \w servirán|strong="H5647"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w* \w y|strong="H1571"\w* \w grandes|strong="H1419"\w* \w reyes|strong="H4428"\w*; \w y|strong="H1571"\w* \w yo|strong="H3588"\w* \w les|strong="H1992"\w* \w pagaré|strong="H7999"\w* conforme \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w hechos|strong="H4639"\w*, \w y|strong="H1571"\w* conforme \w a|strong="H3068"\w* \w la|strong="H1571"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* \w sus|strong="H1992"\w* \w manos|strong="H3027"\w*».   
\p
\v 15 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* \w me|strong="H3588"\w* dijo Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: «\w Toma|strong="H3947"\w* \w de|strong="H3588"\w* mi \w mano|strong="H3027"\w* \w la|strong="H3588"\w* copa del \w vino|strong="H3196"\w* \w de|strong="H3588"\w* \w este|strong="H2063"\w* \w furor|strong="H2534"\w*, \w y|strong="H3588"\w* da \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w de|strong="H3588"\w* \w ella|strong="H3605"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w a|strong="H3068"\w* las cuales \w yo|strong="H3588"\w* \w te|strong="H3588"\w* \w envío|strong="H7971"\w*.  
\v 16 \w Y|strong="H3068"\w* \w beberán|strong="H8354"\w*, y temblarán y enloquecerán \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* la \w espada|strong="H2719"\w* que yo \w envío|strong="H7971"\w* entre ellas».   
\p
\v 17 \w Y|strong="H3068"\w* \w tomé|strong="H3947"\w* \w la|strong="H3605"\w* copa de \w la|strong="H3605"\w* \w mano|strong="H3027"\w* de Yahvé, y di de \w beber|strong="H8248"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w a|strong="H3068"\w* las cuales Yahvé me había \w enviado|strong="H7971"\w*:  
\v 18 \w a|strong="H3068"\w* Jerusalén, \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H8269"\w* \w Judá|strong="H3063"\w*, \w a|strong="H3068"\w* sus \w reyes|strong="H4428"\w* y \w a|strong="H3068"\w* sus \w príncipes|strong="H8269"\w*, \w para|strong="H5414"\w* ponerlos en desolación, en escarnio, en silbido y en \w maldición|strong="H7045"\w*, como en \w este|strong="H2088"\w* \w día|strong="H3117"\w*;  
\v 19 \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*, \w a|strong="H3068"\w* sus \w siervos|strong="H5650"\w*, \w a|strong="H3068"\w* sus \w príncipes|strong="H8269"\w* y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* su \w pueblo|strong="H5971"\w*;  
