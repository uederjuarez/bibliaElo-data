\p
\v 29 \w Y|strong="H3068"\w* \w esto|strong="H2063"\w* tendréis \w por|strong="H5921"\w* señal — \w dice|strong="H5002"\w* Yahvé — \w de|strong="H5921"\w* \w que|strong="H3588"\w* \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w os|strong="H5921"\w* \w castigo|strong="H7451"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w sepáis|strong="H3045"\w* \w que|strong="H3588"\w* \w de|strong="H5921"\w* \w cierto|strong="H3588"\w* \w permanecerán|strong="H6965"\w* mis \w palabras|strong="H1697"\w* \w para|strong="H4616"\w* \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* vosotros’.  
\v 30 \w Así|strong="H3541"\w* dice Yahvé: ‘He \w aquí|strong="H3541"\w* \w que|strong="H3541"\w* \w yo|strong="H5315"\w* \w entrego|strong="H5414"\w* \w al|strong="H4428"\w* faraón Hofra, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Egipto|strong="H4714"\w*, en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* sus enemigos \w y|strong="H3541"\w* en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* los \w que|strong="H3541"\w* \w buscan|strong="H1245"\w* su \w vida|strong="H5315"\w*, \w así|strong="H3541"\w* como \w entregué|strong="H5414"\w* \w a|strong="H3068"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*, en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Babilonia, su enemigo \w que|strong="H3541"\w* \w buscaba|strong="H1245"\w* su \w vida|strong="H5315"\w*’”.   
\c 45
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* Baruc \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nerías, cuando este \w escribía|strong="H3789"\w* \w en|strong="H5921"\w* un \w libro|strong="H5612"\w* estas \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \w Jeremías|strong="H3414"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* \w cuarto|strong="H7243"\w* \w de|strong="H5921"\w* \w Joacim|strong="H3079"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Así|strong="H3541"\w* \w te|strong="H5921"\w* dice Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, Baruc:  
\v 3 ‘Tú dijiste: «¡Ay \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w ahora|strong="H4994"\w*! \w Porque|strong="H3588"\w* \w ha|strong="H3808"\w* añadido Yahvé \w tristeza|strong="H3015"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* pesar; fatigado estoy \w de|strong="H5921"\w* gemir \w y|strong="H3588"\w* \w no|strong="H3808"\w* he \w hallado|strong="H4672"\w* \w descanso|strong="H4496"\w*» ’.   
\p
\v 4 “\w Así|strong="H3541"\w* \w le|strong="H1931"\w* dirás: ‘Yahvé dice \w así|strong="H3541"\w*: «He \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w yo|strong="H2009"\w* \w destruyo|strong="H2040"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w edifiqué|strong="H1129"\w* \w y|strong="H3541"\w* arranco \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w planté|strong="H5193"\w*, \w y|strong="H3541"\w* \w esto|strong="H1931"\w* en \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra».  
\v 5 ¿\w Y|strong="H3068"\w* tú \w buscas|strong="H1245"\w* \w para|strong="H5921"\w* \w ti|strong="H5921"\w* \w grandezas|strong="H1419"\w*? \w No|strong="H3588"\w* \w las|strong="H5921"\w* \w busques|strong="H1245"\w*; \w porque|strong="H3588"\w* he \w aquí|strong="H8033"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* traigo \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* — \w dice|strong="H5002"\w* Yahvé —, \w pero|strong="H3588"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w te|strong="H5921"\w* \w daré|strong="H5414"\w* tu \w vida|strong="H5315"\w* \w por|strong="H5921"\w* botín \w en|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w lugares|strong="H4725"\w* adonde \w fueres|strong="H3212"\w*’”.   
\c 46
\p
\v 1 \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w que|strong="H5921"\w* \w vino|strong="H1961"\w* \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w contra|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.   
\p
\v 2 \w Acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*: \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* \w del|strong="H5921"\w* faraón Necao, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w* \w en|strong="H5921"\w* Carquemis, \w al|strong="H5921"\w* cual \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, derrotó \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w cuarto|strong="H7243"\w* \w año|strong="H8141"\w* \w de|strong="H5921"\w* \w Joacim|strong="H3079"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\q1
\v 3 «¡Preparad \w el|strong="H5066"\w* broquel y \w el|strong="H5066"\w* \w escudo|strong="H4043"\w*,  
\q2 y acudid \w a|strong="H3068"\w* la \w batalla|strong="H4421"\w*!   
\q1
\v 4 Enjaezad los \w caballos|strong="H5483"\w* y montad, \w jinetes|strong="H6571"\w*;  
\q2 presentaos con vuestros cascos.  
\q1 Bruñid las \w lanzas|strong="H7420"\w*,  
\q2 revestíos \w de|strong="H3847"\w* las corazas.   
\q1
\v 5 ¿\w Qué|strong="H3808"\w* es \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w veo|strong="H7200"\w*?  
\q2 Están aterrados, retroceden.  
\q1 \w Sus|strong="H1992"\w* \w valientes|strong="H1368"\w* han sido deshechos;  
\q2 huyen \w a|strong="H3068"\w* toda prisa \w sin|strong="H3808"\w* \w mirar|strong="H7200"\w* atrás.  
\q1 Hay terror \w por|strong="H4069"\w* \w todas|strong="H5439"\w* \w partes|strong="H5439"\w*»,  
\q2 \w dice|strong="H5002"\w* Yahvé.   
\q1
\v 6 “\w No|strong="H5921"\w* huya \w el|strong="H5921"\w* ligero,  
\q2 ni \w el|strong="H5921"\w* \w valiente|strong="H1368"\w* \w escape|strong="H4422"\w*.  
\q1 \w Al|strong="H5921"\w* \w norte|strong="H6828"\w*, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* ribera \w del|strong="H5921"\w* \w Éufrates|strong="H6578"\w*,  
\q2 \w tropezaron|strong="H3782"\w* \w y|strong="H5921"\w* \w cayeron|strong="H5307"\w*.   
\b  
\q1
\v 7 ¿\w Quién|strong="H4310"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* \w que|strong="H4310"\w* \w sube|strong="H5927"\w* como \w el|strong="H4310"\w* Nilo,  
\q2 cuyas \w aguas|strong="H4325"\w* se agitan como \w ríos|strong="H2975"\w*?   
\q1
\v 8 \w Egipto|strong="H4714"\w* \w sube|strong="H5927"\w* como \w el|strong="H2975"\w* Nilo,  
\q2 y sus \w aguas|strong="H4325"\w* se mueven como \w ríos|strong="H2975"\w*.  
\q1 \w Él|strong="H2975"\w* dijo: ‘Me levantaré, \w cubriré|strong="H3680"\w* la tierra;  
\q2 destruiré las \w ciudades|strong="H5892"\w* y \w a|strong="H3068"\w* sus \w moradores|strong="H3427"\w*’.   
\q1
\v 9 ¡\w Subid|strong="H5927"\w*, \w caballos|strong="H5483"\w*! ¡Arracad, \w carros|strong="H7393"\w*!  
\q2 ¡\w Que|strong="H1869"\w* \w salgan|strong="H3318"\w* los \w valientes|strong="H1368"\w*:  
\q1 los de \w Etiopía|strong="H3568"\w* y los de Libia \w que|strong="H1869"\w* manejan el \w escudo|strong="H4043"\w*,  
\q2 y los de Lidia \w que|strong="H1869"\w* manejan y tensan el \w arco|strong="H7198"\w*!   
\q1
\v 10 \w Mas|strong="H3588"\w* \w ese|strong="H1931"\w* \w día|strong="H3117"\w* \w será|strong="H1931"\w* \w de|strong="H3588"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w*,  
\q2 \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w venganza|strong="H5360"\w* \w para|strong="H3588"\w* vengarse \w de|strong="H3588"\w* \w sus|strong="H1931"\w* \w enemigos|strong="H6862"\w*.  
\q1 \w La|strong="H1931"\w* \w espada|strong="H2719"\w* devorará \w y|strong="H3588"\w* \w se|strong="H1931"\w* saciará,  
\q2 \w y|strong="H3588"\w* \w se|strong="H1931"\w* embriagará \w con|strong="H3588"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* \w de|strong="H3588"\w* \w ellos|strong="H1931"\w*;  
\q1 \w porque|strong="H3588"\w* \w sacrificio|strong="H2077"\w* \w tiene|strong="H1931"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w*  
\q2 \w en|strong="H3588"\w* \w la|strong="H1931"\w* tierra del \w norte|strong="H6828"\w*, junto al \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*.   
\q1
\v 11 \w Sube|strong="H5927"\w* \w a|strong="H3068"\w* \w Galaad|strong="H1568"\w* y \w toma|strong="H3947"\w* \w bálsamo|strong="H6875"\w*, \w virgen|strong="H1330"\w* \w hija|strong="H1323"\w* de \w Egipto|strong="H4714"\w*;  
\q2 en vano multiplicas tus \w medicinas|strong="H7499"\w*;  
\q2 no hay cura para ti.   
\q1
\v 12 Las \w naciones|strong="H1471"\w* \w oyeron|strong="H8085"\w* tu \w afrenta|strong="H7036"\w*  
\q2 \w y|strong="H3588"\w* tu clamor \w llenó|strong="H4390"\w* \w la|strong="H3588"\w* tierra;  
\q1 \w porque|strong="H3588"\w* \w valiente|strong="H1368"\w* \w tropezó|strong="H3782"\w* contra \w valiente|strong="H1368"\w*,  
\q2 \w y|strong="H3588"\w* \w ambos|strong="H8147"\w* \w cayeron|strong="H5307"\w* \w juntos|strong="H3162"\w*”.   
\b  
\p
\v 13 \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w habló|strong="H1696"\w* Yahvé \w al|strong="H4428"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w acerca|strong="H1696"\w* \w de|strong="H1697"\w* la venida \w de|strong="H1697"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* Babilonia, para herir la tierra \w de|strong="H1697"\w* \w Egipto|strong="H4714"\w*:   
\q1
\v 14 “Anunciadlo \w en|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w y|strong="H3588"\w* hacedlo \w saber|strong="H5046"\w* \w en|strong="H3588"\w* \w Migdol|strong="H4024"\w*;  
\q2 hacedlo \w oír|strong="H8085"\w* \w en|strong="H3588"\w* Menfis \w y|strong="H3588"\w* \w en|strong="H3588"\w* Tafnes.  
\q1 Decid: ‘\w Ponte|strong="H3320"\w* \w en|strong="H3588"\w* pie \w y|strong="H3588"\w* prepárate,  
\q2 \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* devora \w a|strong="H3068"\w* tu \w alrededor|strong="H5439"\w*’.   
\q1
\v 15 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* han sido derribados tus valientes?  
\q2 \w No|strong="H3808"\w* \w se|strong="H3808"\w* mantuvieron \w en|strong="H3588"\w* \w pie|strong="H5975"\w* \w porque|strong="H3588"\w* Yahvé \w los|strong="H3588"\w* empujó.   
\q1
\v 16 \w Multiplicó|strong="H7235"\w* los \w que|strong="H1571"\w* tropezaban;  
\q2 cada uno \w cayó|strong="H5307"\w* sobre su \w compañero|strong="H7453"\w*.  
\q1 \w Y|strong="H3068"\w* dijeron: ‘¡\w Levántate|strong="H6965"\w*! \w Volvamos|strong="H7725"\w* \w a|strong="H3068"\w* nuestro \w pueblo|strong="H5971"\w*  
\q2 \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* tierra \w de|strong="H6440"\w* nuestro \w nacimiento|strong="H4138"\w*,  
\q2 \w para|strong="H5971"\w* huir \w de|strong="H6440"\w* \w la|strong="H1571"\w* \w espada|strong="H2719"\w* \w opresora|strong="H3238"\w*’.   
\q1
\v 17 \w Allí|strong="H8033"\w* \w gritaron|strong="H7121"\w*: ‘¡\w Faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* de \w Egipto|strong="H4714"\w*, es puro ruido;  
\q2 dejó \w pasar|strong="H5674"\w* \w el|strong="H5674"\w* \w tiempo|strong="H4150"\w* \w señalado|strong="H4150"\w*!’.   
\b  
\q1
\v 18 ¡\w Vivo|strong="H2416"\w* \w yo|strong="H3588"\w*!, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Rey|strong="H4428"\w*,  
\q2 cuyo \w nombre|strong="H8034"\w* \w es|strong="H3588"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w*,  
\q1 \w que|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w Tabor|strong="H8396"\w* \w entre|strong="H3588"\w* \w los|strong="H3588"\w* \w montes|strong="H2022"\w*  
\q2 \w y|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* Carmelo junto \w al|strong="H4428"\w* \w mar|strong="H3220"\w*, \w así|strong="H3588"\w* vendrá \w el|strong="H3588"\w* invasor.   
\q1
\v 19 Prepara \w tu|strong="H6213"\w* equipaje \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w cautiverio|strong="H1473"\w*,  
\q2 \w hija|strong="H1323"\w* \w que|strong="H3588"\w* \w moras|strong="H3427"\w* \w en|strong="H3588"\w* \w Egipto|strong="H4714"\w*;  
\q1 \w porque|strong="H3588"\w* Menfis \w será|strong="H1961"\w* convertida \w en|strong="H3588"\w* desierto,  
\q2 \w y|strong="H3588"\w* \w será|strong="H1961"\w* \w asolada|strong="H3341"\w* hasta \w no|strong="H6213"\w* \w quedar|strong="H1961"\w* \w morador|strong="H3427"\w*.   
\b  
\q1
\v 20 \w Becerra|strong="H5697"\w* hermosa es \w Egipto|strong="H4714"\w*;  
\q2 mas del \w norte|strong="H6828"\w* viene \w destrucción|strong="H7171"\w*; ¡ya viene!   
\q1
\v 21 \w Sus|strong="H1992"\w* soldados mercenarios \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w* \w son|strong="H3588"\w* \w como|strong="H3588"\w* \w becerros|strong="H5695"\w* \w de|strong="H5921"\w* engorde;  
\q2 \w porque|strong="H3588"\w* \w también|strong="H1571"\w* \w ellos|strong="H1992"\w* \w volvieron|strong="H6437"\w* \w la|strong="H5921"\w* espalda \w y|strong="H1571"\w* \w huyeron|strong="H5127"\w* \w juntos|strong="H3162"\w*.  
\q1 \w No|strong="H3808"\w* \w se|strong="H5921"\w* mantuvieron \w en|strong="H5921"\w* \w pie|strong="H5975"\w*,  
\q2 \w porque|strong="H3588"\w* \w les|strong="H1992"\w* vino \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H1992"\w* quebranto,  
\q2 \w el|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5921"\w* \w su|strong="H1992"\w* castigo.   
\q1
\v 22 \w Su|strong="H3588"\w* \w voz|strong="H6963"\w* \w suena|strong="H6963"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* rastro \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w serpiente|strong="H5175"\w*,  
\q2 \w porque|strong="H3588"\w* vienen \w con|strong="H3588"\w* \w ejército|strong="H2428"\w*;  
\q1 \w con|strong="H3588"\w* hachas vienen contra ella,  
\q2 \w como|strong="H3588"\w* cortadores \w de|strong="H3588"\w* \w leña|strong="H6086"\w*.   
\q1
\v 23 Cortarán \w su|strong="H1992"\w* \w bosque|strong="H3293"\w* — \w dice|strong="H5002"\w* Yahvé —,  
\q2 \w aunque|strong="H3588"\w* sea impenetrable;  
\q1 \w porque|strong="H3588"\w* \w son|strong="H3588"\w* \w más|strong="H3588"\w* numerosos \w que|strong="H3588"\w* \w las|strong="H1992"\w* langostas,  
\q2 \w no|strong="H3808"\w* \w tienen|strong="H1992"\w* \w número|strong="H4557"\w*.   
\q1
\v 24 \w Se|strong="H5971"\w* avergonzará la \w hija|strong="H1323"\w* \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*;  
\q2 \w será|strong="H5414"\w* \w entregada|strong="H5414"\w* en \w mano|strong="H3027"\w* del \w pueblo|strong="H5971"\w* del \w norte|strong="H6828"\w*”.   
\p
\v 25 Dice Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: «He \w aquí|strong="H2005"\w* \w que|strong="H5921"\w* yo castigo \w a|strong="H3068"\w* Amón \w de|strong="H5921"\w* Tebas, \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, \w con|strong="H5921"\w* sus dioses \w y|strong="H5921"\w* sus \w reyes|strong="H4428"\w*; así \w al|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w como|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w en|strong="H5921"\w* \w él|strong="H5921"\w* confían.  
\v 26 \w Y|strong="H3068"\w* los \w entregaré|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* los \w que|strong="H3117"\w* \w buscan|strong="H1245"\w* su \w vida|strong="H5315"\w*, en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* \w Nabucodonosor|strong="H5019"\w* \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Babilonia y en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* sus \w siervos|strong="H5650"\w*; pero después \w será|strong="H5414"\w* habitada \w como|strong="H3651"\w* en los \w días|strong="H3117"\w* \w de|strong="H5414"\w* antaño — \w dice|strong="H5002"\w* Yahvé —.   
\q1
\v 27 \w Y|strong="H3068"\w* tú \w no|strong="H3588"\w* \w temas|strong="H3372"\w*, \w siervo|strong="H5650"\w* mío \w Jacob|strong="H3290"\w*,  
\q2 ni \w desmayes|strong="H2865"\w*, \w Israel|strong="H3478"\w*;  
\q1 \w porque|strong="H3588"\w* he \w aquí|strong="H2005"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H3588"\w* \w salvaré|strong="H3467"\w* \w de|strong="H3588"\w* \w lejos|strong="H7350"\w*,  
\q2 \w y|strong="H3588"\w* \w a|strong="H3068"\w* tu \w descendencia|strong="H2233"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w su|strong="H3588"\w* cautividad.  
\q1 \w Volverá|strong="H7725"\w* \w Jacob|strong="H3290"\w* \w y|strong="H3588"\w* descansará,  
\q2 estará tranquilo \w y|strong="H3588"\w* \w no|strong="H3588"\w* habrá quien \w lo|strong="H7350"\w* espante.   
\q1
\v 28 \w Tú|strong="H6213"\w*, \w siervo|strong="H5650"\w* mío \w Jacob|strong="H3290"\w*, \w no|strong="H3808"\w* \w temas|strong="H3372"\w* — \w dice|strong="H5002"\w* Yahvé —,  
\q2 \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* estoy \w con|strong="H3588"\w* vosotros.  
\q1 Destruiré \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w entre|strong="H3808"\w* las cuales os he dispersado;  
\q2 \w pero|strong="H3588"\w* \w a|strong="H3068"\w* ti \w no|strong="H3808"\w* \w te|strong="H3588"\w* destruiré del \w todo|strong="H3605"\w*,  
\q1 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* \w castigaré|strong="H3256"\w* \w con|strong="H3588"\w* \w justicia|strong="H4941"\w*;  
\q2 \w de|strong="H3588"\w* \w ninguna|strong="H3605"\w* manera \w te|strong="H3588"\w* dejaré impune».   
\c 47
\p
\v 1 \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w que|strong="H1697"\w* \w vino|strong="H1961"\w* al \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w contra|strong="H1961"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*, \w antes|strong="H2962"\w* \w que|strong="H1697"\w* \w Faraón|strong="H6547"\w* \w hiriese|strong="H5221"\w* \w a|strong="H3068"\w* \w Gaza|strong="H5804"\w*.   
\p
\v 2 \w Así|strong="H3541"\w* dice Yahvé:  
\q1 «He \w aquí|strong="H2009"\w* \w que|strong="H4325"\w* \w suben|strong="H5927"\w* \w aguas|strong="H4325"\w* del \w norte|strong="H6828"\w*,  
\q2 \w y|strong="H3541"\w* \w se|strong="H1961"\w* convertirán en \w torrente|strong="H5158"\w* \w inundante|strong="H7857"\w*;  
\q1 inundarán \w la|strong="H3605"\w* tierra \w y|strong="H3541"\w* su plenitud,  
\q2 \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w y|strong="H3541"\w* \w los|strong="H3427"\w* \w que|strong="H4325"\w* en \w ella|strong="H3605"\w* \w habitan|strong="H3427"\w*.  
\q1 \w Los|strong="H3427"\w* hombres \w clamarán|strong="H2199"\w*,  
\q2 \w y|strong="H3541"\w* \w aullará|strong="H3213"\w* \w todo|strong="H3605"\w* \w morador|strong="H3427"\w* \w de|strong="H4325"\w* \w la|strong="H3605"\w* tierra.   
\q1
\v 3 \w Por|strong="H3027"\w* \w el|strong="H1121"\w* estrépito \w de|strong="H1121"\w* \w los|strong="H1121"\w* cascos \w de|strong="H1121"\w* sus \w valientes|strong="H1121"\w* corceles,  
\q2 \w por|strong="H3027"\w* \w el|strong="H1121"\w* \w estruendo|strong="H6963"\w* \w de|strong="H1121"\w* sus \w carros|strong="H7393"\w*,  
\q2 \w por|strong="H3027"\w* \w el|strong="H1121"\w* ruidoso rodar \w de|strong="H1121"\w* sus ruedas,  
\q1 \w los|strong="H1121"\w* padres \w no|strong="H3808"\w* \w volverán|strong="H6437"\w* la cabeza \w por|strong="H3027"\w* sus \w hijos|strong="H1121"\w*,  
\q2 \w a|strong="H3068"\w* causa \w de|strong="H1121"\w* la debilidad \w de|strong="H1121"\w* sus \w manos|strong="H3027"\w*;   
\q1
\v 4 \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w que|strong="H3588"\w* viene \w para|strong="H5921"\w* destruir \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w*,  
\q2 \w para|strong="H5921"\w* talar \w de|strong="H5921"\w* \w Tiro|strong="H6865"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w Sidón|strong="H6721"\w* \w todo|strong="H3605"\w* aliado \w que|strong="H3588"\w* \w les|strong="H5921"\w* quede;  
\q1 \w porque|strong="H3588"\w* Yahvé \w destruirá|strong="H3772"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w*,  
\q2 \w al|strong="H5921"\w* \w resto|strong="H7611"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* isla \w de|strong="H5921"\w* Caftor.   
\q1
\v 5 La calvicie \w llegó|strong="H5704"\w* \w a|strong="H3068"\w* \w Gaza|strong="H5804"\w*;  
\q2 Ascalón ha sido reducida \w a|strong="H3068"\w* silencio.  
\q1 Tú, \w resto|strong="H7611"\w* \w de|strong="H5704"\w* su \w valle|strong="H6010"\w*,  
\q2 ¿\w hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* te sajarás?   
\b  
\q1
\v 6 ¡\w Ah|strong="H1945"\w*, \w espada|strong="H2719"\w* \w de|strong="H5704"\w* Yahvé! ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* \w no|strong="H3808"\w* \w reposarás|strong="H8252"\w*?  
\q2 Vuélvete \w a|strong="H3068"\w* tu vaina,  
\q2 descansa \w y|strong="H5704"\w* sosiégate.   
\b  
\q1
\v 7 ¿Cómo podrá estar quieta,  
\q2 si Yahvé le ha dado una \w orden|strong="H6680"\w*?  
\q1 Contra Ascalón y contra la costa del \w mar|strong="H3220"\w*,  
\q2 \w allí|strong="H8033"\w* la ha designado».   
\c 48
\p
\v 1 Acerca \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*. \w Así|strong="H3541"\w* dice Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*:  
\q1 “¡\w Ay|strong="H1945"\w* \w de|strong="H3588"\w* \w Nebo|strong="H5015"\w*,  
\q2 \w porque|strong="H3588"\w* \w ha|strong="H3541"\w* sido asolada!  
\q1 Quiriataim \w ha|strong="H3541"\w* sido avergonzada \w y|strong="H3588"\w* \w tomada|strong="H3920"\w*;  
\q2 \w Misgab|strong="H4869"\w*\f + \fr 48:1 \ft o, La fortaleza\f* \w ha|strong="H3541"\w* sido humillada \w y|strong="H3588"\w* quebrantada.   
\q1
\v 2 \w Ya|strong="H3068"\w* \w no|strong="H5921"\w* existe \w la|strong="H5921"\w* gloria \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*;  
\q2 \w en|strong="H5921"\w* \w Hesbón|strong="H2809"\w* \w maquinaron|strong="H2803"\w* \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*, diciendo:  
\q2 ‘¡\w Venid|strong="H3212"\w*, \w y|strong="H1571"\w* quitémosla \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*!’.  
\q1 \w También|strong="H1571"\w* tú, Madmén, serás reducida \w al|strong="H5921"\w* silencio;  
\q2 \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w te|strong="H5921"\w* perseguirá.   
\q1
\v 3 ¡\w Voz|strong="H6963"\w* de \w clamor|strong="H6818"\w* de \w Horonaim|strong="H2773"\w*,  
\q2 desolación y \w gran|strong="H1419"\w* \w destrucción|strong="H7701"\w*!   
\q1
\v 4 \w Moab|strong="H4124"\w* ha sido \w quebrantada|strong="H7665"\w*;  
\q2 sus pequeños han hecho \w oír|strong="H8085"\w* su \w clamor|strong="H2201"\w*.   
\q1
\v 5 \w Porque|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* cuesta \w de|strong="H3588"\w* Luhit \w subirán|strong="H5927"\w* \w con|strong="H3588"\w* \w llanto|strong="H1065"\w* continuo;  
\q2 \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* bajada \w de|strong="H3588"\w* \w Horonaim|strong="H2773"\w* han \w oído|strong="H8085"\w* \w el|strong="H3588"\w* grito \w de|strong="H3588"\w* \w angustia|strong="H6862"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* destrucción.   
\q1
\v 6 ¡\w Huid|strong="H5127"\w*, \w salvad|strong="H4422"\w* vuestras \w vidas|strong="H5315"\w*!  
\q2 \w Sed|strong="H1961"\w* \w como|strong="H1961"\w* el enebro en el \w desierto|strong="H4057"\w*.   
\q1
\v 7 \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* confiaste \w en|strong="H3588"\w* vuestras \w obras|strong="H4639"\w* \w y|strong="H1571"\w* \w en|strong="H3588"\w* vuestros tesoros,  
\q2 \w también|strong="H1571"\w* tú serás \w tomada|strong="H3920"\w*.  
\q1 Quemos \w irá|strong="H3318"\w* \w en|strong="H3588"\w* \w cautiverio|strong="H1473"\w*,  
\q2 \w con|strong="H3588"\w* sus \w sacerdotes|strong="H3548"\w* \w y|strong="H1571"\w* sus \w príncipes|strong="H8269"\w* \w juntamente|strong="H3162"\w*.   
\q1
\v 8 Vendrá \w el|strong="H3605"\w* \w destruidor|strong="H7703"\w* \w a|strong="H3068"\w* \w cada|strong="H3605"\w* una de las \w ciudades|strong="H5892"\w*,  
\q2 y \w ninguna|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w escapará|strong="H4422"\w*;  
\q1 \w el|strong="H3605"\w* \w valle|strong="H6010"\w* \w perecerá|strong="H3808"\w* y \w la|strong="H3605"\w* llanura \w será|strong="H3808"\w* \w destruida|strong="H7703"\w*, como \w ha|strong="H3808"\w* dicho Yahvé.   
\q1
\v 9 \w Dadle|strong="H5414"\w* \w alas|strong="H6731"\w* \w a|strong="H3068"\w* \w Moab|strong="H4124"\w*,  
\q2 \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* vaya volando;  
\q1 \w pues|strong="H3588"\w* sus \w ciudades|strong="H5892"\w* \w serán|strong="H1961"\w* puestas \w en|strong="H3588"\w* desolación,  
\q2 hasta \w no|strong="H3588"\w* \w quedar|strong="H1961"\w* \w en|strong="H3588"\w* ellas \w morador|strong="H3427"\w*.   
\b  
\q1
\v 10 Maldito \w el|strong="H6213"\w* que \w hace|strong="H6213"\w* la \w obra|strong="H4399"\w* \w de|strong="H1818"\w* Yahvé con negligencia,  
\q2 y maldito \w el|strong="H6213"\w* que retira su \w espada|strong="H2719"\w* \w de|strong="H1818"\w* la \w sangre|strong="H1818"\w*.   
\b  
\q1
\v 11 \w Quieto|strong="H8252"\w* \w estuvo|strong="H5975"\w* \w Moab|strong="H4124"\w* \w desde|strong="H5921"\w* \w su|strong="H1931"\w* \w juventud|strong="H5271"\w*,  
\q2 \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w sus|strong="H1931"\w* posos \w ha|strong="H3808"\w* \w estado|strong="H5975"\w* \w reposado|strong="H8252"\w*;  
\q1 \w no|strong="H3808"\w* \w fue|strong="H1980"\w* vaciado \w de|strong="H5921"\w* \w vasija|strong="H3627"\w* \w en|strong="H5921"\w* \w vasija|strong="H3627"\w*,  
\q2 \w ni|strong="H3808"\w* \w fue|strong="H1980"\w* \w nunca|strong="H3808"\w* \w al|strong="H5921"\w* \w cautiverio|strong="H1473"\w*;  
\q1 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w su|strong="H1931"\w* \w sabor|strong="H2940"\w* \w quedó|strong="H5975"\w* \w en|strong="H5921"\w* \w él|strong="H1931"\w*,  
\q2 \w y|strong="H5921"\w* \w su|strong="H1931"\w* \w olor|strong="H7381"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* \w ha|strong="H3808"\w* cambiado.   
\q1
\v 12 \w Por|strong="H3651"\w* \w eso|strong="H3651"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H3117"\w* vienen \w días|strong="H3117"\w* — \w dice|strong="H5002"\w* Yahvé —  
\q2 en \w que|strong="H3117"\w* \w yo|strong="H2009"\w* le \w enviaré|strong="H7971"\w* trasvasadores \w que|strong="H3117"\w* lo trasvasarán;  
\q1 vaciarán sus vasijas  
\q2 y romperán sus odres.   
\q1
\v 13 \w Y|strong="H3068"\w* se avergonzará \w Moab|strong="H4124"\w* de Quemos,  
\q2 como la \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w* se avergonzó de Betel, su \w confianza|strong="H4009"\w*.   
\b  
\q1
\v 14 ¿Cómo decís: ‘Somos \w valientes|strong="H1368"\w*  
\q2 y \w hombres|strong="H1368"\w* \w fuertes|strong="H2428"\w* para la \w guerra|strong="H4421"\w*’?   
\q1
\v 15 \w Moab|strong="H4124"\w* ha sido asolado y sus \w ciudades|strong="H5892"\w* han sido invadidas;  
\q2 sus jóvenes \w escogidos|strong="H4005"\w* han descendido \w al|strong="H4428"\w* matadero”,  
\q2 \w dice|strong="H5002"\w* el \w Rey|strong="H4428"\w*, cuyo \w nombre|strong="H8034"\w* es Yahvé de los \w Ejércitos|strong="H6635"\w*.   
\q1
\v 16 “\w Cercano|strong="H7138"\w* está el quebranto \w de|strong="H7451"\w* \w Moab|strong="H4124"\w* para venir,  
\q2 y su aflicción se apresura en \w gran|strong="H3966"\w* \w manera|strong="H3966"\w*.   
\q1
\v 17 \w Compadeceos|strong="H5110"\w* \w de|strong="H5110"\w* \w él|strong="H3605"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3045"\w* estáis \w a|strong="H3068"\w* su \w alrededor|strong="H5439"\w*;  
\q2 \w y|strong="H5797"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3045"\w* \w conocéis|strong="H3045"\w* su \w nombre|strong="H8034"\w*, decid:  
\q1 ‘¡Cómo \w se|strong="H3045"\w* rompió \w el|strong="H3605"\w* báculo \w fuerte|strong="H5797"\w*,  
\q2 \w la|strong="H3605"\w* \w vara|strong="H4294"\w* \w de|strong="H5110"\w* hermosura!’.   
\b  
\q1
\v 18 \w Desciende|strong="H3381"\w* \w de|strong="H3588"\w* tu \w gloria|strong="H3519"\w*, \w siéntate|strong="H3427"\w* \w en|strong="H3588"\w* tierra seca,  
\q2 \w hija|strong="H1323"\w* \w que|strong="H3588"\w* \w moras|strong="H3427"\w* \w en|strong="H3588"\w* \w Dibón|strong="H1769"\w*;  
\q1 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w destruidor|strong="H7703"\w* \w de|strong="H3588"\w* \w Moab|strong="H4124"\w* \w subió|strong="H5927"\w* contra ti  
\q2 \w y|strong="H3588"\w* \w destruyó|strong="H7843"\w* tus fortalezas.   
\q1
\v 19 \w Ponte|strong="H5975"\w* \w en|strong="H5975"\w* \w el|strong="H3427"\w* \w camino|strong="H1870"\w* y \w mira|strong="H6822"\w*, \w oh|strong="H4100"\w* \w moradora|strong="H3427"\w* de \w Aroer|strong="H6177"\w*;  
\q2 \w pregunta|strong="H7592"\w* al \w que|strong="H4100"\w* \w huye|strong="H5127"\w* y \w a|strong="H3068"\w* la \w que|strong="H4100"\w* \w escapa|strong="H4422"\w*;  
\q2 di: ‘¿\w Qué|strong="H4100"\w* ha sucedido?’.   
\q1
\v 20 Se avergonzó \w Moab|strong="H4124"\w*, \w porque|strong="H3588"\w* ha sido quebrantado;  
\q2 ¡\w aullad|strong="H3213"\w* \w y|strong="H3588"\w* clamad!  
\q1 Anunciad \w en|strong="H3588"\w* \w el|strong="H3588"\w* Arnón \w que|strong="H3588"\w* \w Moab|strong="H4124"\w* ha sido asolado.   
\q1
\v 21 Vino \w el|strong="H5921"\w* \w juicio|strong="H4941"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w la|strong="H5921"\w* llanura;  
\q2 \w sobre|strong="H5921"\w* Holón, \w sobre|strong="H5921"\w* Jahaza \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* Mefaat,   
\q2
\v 22 \w sobre|strong="H5921"\w* \w Dibón|strong="H1769"\w*, \w sobre|strong="H5921"\w* \w Nebo|strong="H5015"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* Bet-diblataim,   
\q2
\v 23 \w sobre|strong="H5921"\w* Quiriataim, \w sobre|strong="H5921"\w* Bet-gamul \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* Bet-meón,   
\q2
\v 24 \w sobre|strong="H5921"\w* Queriot \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w Bosra|strong="H1224"\w*,  
\q2 \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, estén \w lejos|strong="H7350"\w* \w o|strong="H3068"\w* \w cerca|strong="H7138"\w*.   
\q1
\v 25 El \w cuerno|strong="H7161"\w* de \w Moab|strong="H4124"\w* ha sido \w cortado|strong="H1438"\w*  
\q2 y su \w brazo|strong="H2220"\w* ha sido \w quebrantado|strong="H7665"\w*”, \w dice|strong="H5002"\w* Yahvé.   
\b  
\q1
\v 26 «Embriagadle,  
