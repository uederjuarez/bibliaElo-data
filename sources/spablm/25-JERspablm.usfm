\q1
\v 2 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H3117"\w* vienen \w días|strong="H3117"\w*», \w dice|strong="H5002"\w* Yahvé,  
\q1 «en \w que|strong="H3117"\w* haré \w que|strong="H3117"\w* \w se|strong="H1961"\w* \w oiga|strong="H8085"\w* \w clamor|strong="H8643"\w* \w de|strong="H1121"\w* \w guerra|strong="H4421"\w* en Rabá \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón;  
