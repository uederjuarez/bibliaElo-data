\q2 junto \w con|strong="H3588"\w* sus hermanos \w y|strong="H3588"\w* sus \w vecinos|strong="H7934"\w*; \w y|strong="H3588"\w* \w él|strong="H3588"\w* ya \w no|strong="H3808"\w* existe.   
\q1
\v 11 \w Deja|strong="H5800"\w* \w a|strong="H3068"\w* tus \w huérfanos|strong="H3490"\w*, yo \w los|strong="H5921"\w* criaré;  
\q2 \w y|strong="H5921"\w* tus viudas confíen \w en|strong="H5921"\w* \w mí|strong="H5921"\w*».   
\p
\v 12 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé: «He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* aquellos \w que|strong="H3588"\w* \w no|strong="H3808"\w* estaban condenados \w a|strong="H3068"\w* \w beber|strong="H8354"\w* \w del|strong="H8354"\w* \w cáliz|strong="H3563"\w*, \w lo|strong="H1931"\w* \w beberán|strong="H8354"\w* \w ciertamente|strong="H3588"\w*; ¿\w y|strong="H3588"\w* has \w de|strong="H3588"\w* quedar tú \w del|strong="H8354"\w* todo impune? \w No|strong="H3808"\w* quedarás impune, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \w lo|strong="H1931"\w* \w beberás|strong="H8354"\w*.  
\v 13 \w Porque|strong="H3588"\w* \w por|strong="H3588"\w* \w mí|strong="H1961"\w* \w mismo|strong="H3605"\w* he \w jurado|strong="H7650"\w* — \w dice|strong="H5002"\w* Yahvé — \w que|strong="H3588"\w* \w Bosra|strong="H1224"\w* \w será|strong="H1961"\w* objeto \w de|strong="H3588"\w* \w espanto|strong="H8047"\w*, \w de|strong="H3588"\w* \w oprobio|strong="H2781"\w*, \w de|strong="H3588"\w* desolación \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w maldición|strong="H7045"\w*; \w y|strong="H3588"\w* \w todas|strong="H3605"\w* sus \w ciudades|strong="H5892"\w* \w serán|strong="H1961"\w* ruinas \w perpetuas|strong="H5769"\w*».   
\q1
\v 14 Una noticia he \w oído|strong="H8085"\w* \w de|strong="H5921"\w* parte \w de|strong="H5921"\w* Yahvé,  
\q2 \w y|strong="H5921"\w* un \w mensajero|strong="H6735"\w* ha sido \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, diciendo:  
\q1 «¡\w Reuníos|strong="H6908"\w* \w y|strong="H5921"\w* venid \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*!  
\q2 ¡\w Levantaos|strong="H6965"\w* \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w*!».   
\b  
\q1
\v 15 «\w Porque|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* he hecho \w pequeño|strong="H6996"\w* \w entre|strong="H6996"\w* las \w naciones|strong="H1471"\w*,  
\q2 menospreciado \w entre|strong="H6996"\w* \w los|strong="H3588"\w* hombres.   
\q1
\v 16 Tu arrogancia \w y|strong="H3588"\w* \w la|strong="H3588"\w* soberbia \w de|strong="H3588"\w* tu \w corazón|strong="H3820"\w* \w te|strong="H3588"\w* engañaron,  
\q2 oh tú \w que|strong="H3588"\w* habitas \w en|strong="H3588"\w* las hendiduras \w de|strong="H3588"\w* las peñas,  
\q1 \w que|strong="H3588"\w* ocupas \w la|strong="H3588"\w* cumbre del monte.  
\q2 \w Aunque|strong="H3588"\w* eleves \w como|strong="H3588"\w* \w el|strong="H3588"\w* águila tu \w nido|strong="H7064"\w*,  
\q1 \w de|strong="H3588"\w* \w allí|strong="H8033"\w* \w te|strong="H3588"\w* haré descender», \w dice|strong="H5002"\w* Yahvé.   
\q1
\v 17 «\w Y|strong="H3068"\w* Edom \w se|strong="H1961"\w* convertirá \w en|strong="H5921"\w* objeto \w de|strong="H5921"\w* \w espanto|strong="H8047"\w*;  
\q2 \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w pase|strong="H5674"\w* \w por|strong="H5921"\w* \w ella|strong="H5921"\w* \w se|strong="H1961"\w* asombrará  
\q2 \w y|strong="H5921"\w* \w silbará|strong="H8319"\w* \w al|strong="H5921"\w* ver \w todas|strong="H3605"\w* sus \w plagas|strong="H4347"\w*.   
\q1
\v 18 Como sucedió en la destrucción \w de|strong="H1121"\w* \w Sodoma|strong="H5467"\w* y \w de|strong="H1121"\w* \w Gomorra|strong="H6017"\w* y \w de|strong="H1121"\w* sus ciudades vecinas», dice Yahvé,  
