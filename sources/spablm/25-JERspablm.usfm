\c 26
\p
\v 1 \w Al|strong="H4428"\w* \w principio|strong="H7225"\w* del \w reinado|strong="H4428"\w* \w de|strong="H1121"\w* \w Joacim|strong="H3079"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w vino|strong="H1961"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé, diciendo:  
\v 2 “\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* Yahvé: ‘\w Ponte|strong="H5975"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w atrio|strong="H2691"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w habla|strong="H1696"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w que|strong="H5921"\w* vienen \w para|strong="H5921"\w* adorar \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé, \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w que|strong="H5921"\w* \w yo|strong="H6680"\w* \w te|strong="H5921"\w* \w mandé|strong="H6680"\w* \w que|strong="H5921"\w* \w les|strong="H5921"\w* \w hables|strong="H1696"\w*; \w no|strong="H5921"\w* omitas ni una \w palabra|strong="H1697"\w*.  
\v 3 Quizá \w escuchen|strong="H8085"\w*, y se convierta cada uno \w de|strong="H6440"\w* su \w mal|strong="H7451"\w* \w camino|strong="H1870"\w*, y me arrepienta \w yo|strong="H6213"\w* del \w mal|strong="H7451"\w* que \w pienso|strong="H2803"\w* \w hacerles|strong="H6213"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* la \w maldad|strong="H7451"\w* \w de|strong="H6440"\w* sus \w obras|strong="H4611"\w*’.  
\v 4 Les dirás, pues: ‘\w Así|strong="H3541"\w* dice Yahvé: \w Si|strong="H3808"\w* \w no|strong="H3808"\w* \w me|strong="H3541"\w* escucháis \w para|strong="H5414"\w* \w andar|strong="H3212"\w* \w en|strong="H3212"\w* mi \w ley|strong="H8451"\w*, la cual \w puse|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w vosotros|strong="H8085"\w*,  
\v 5 \w para|strong="H5921"\w* \w escuchar|strong="H8085"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* mis \w siervos|strong="H5650"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w*, \w que|strong="H3808"\w* yo \w os|strong="H5921"\w* \w envío|strong="H7971"\w* \w madrugando|strong="H7925"\w* \w para|strong="H5921"\w* enviároslos — \w a|strong="H3068"\w* \w los|strong="H5921"\w* cuales \w no|strong="H3808"\w* habéis escuchado —,  
\v 6 yo \w pondré|strong="H5414"\w* \w esta|strong="H2063"\w* \w casa|strong="H1004"\w* como \w Silo|strong="H7887"\w*, y \w daré|strong="H5414"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w por|strong="H2088"\w* \w maldición|strong="H7045"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w de|strong="H5414"\w* \w la|strong="H3605"\w* tierra’”.   
\p
\v 7 \w Y|strong="H3068"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w*, \w los|strong="H3605"\w* \w profetas|strong="H5030"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w oyeron|strong="H8085"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w hablar|strong="H1696"\w* estas \w palabras|strong="H1697"\w* en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Yahvé.  
\v 8 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* \w Jeremías|strong="H3414"\w* terminó \w de|strong="H5971"\w* \w hablar|strong="H1696"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H5971"\w* Yahvé le \w había|strong="H1961"\w* \w mandado|strong="H6680"\w* \w que|strong="H5971"\w* hablase \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w*, \w los|strong="H3605"\w* \w profetas|strong="H5030"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* le echaron mano, \w diciendo|strong="H1696"\w*: “\w De|strong="H5971"\w* \w cierto|strong="H4191"\w* \w morirás|strong="H4191"\w*.  
\v 9 ¿\w Por|strong="H4069"\w* \w qué|strong="H5971"\w* has \w profetizado|strong="H5012"\w* en \w nombre|strong="H8034"\w* \w de|strong="H5971"\w* Yahvé, diciendo: ‘\w Esta|strong="H2063"\w* \w casa|strong="H1004"\w* \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w Silo|strong="H7887"\w*, y \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w será|strong="H1961"\w* \w asolada|strong="H2717"\w* \w hasta|strong="H2088"\w* \w no|strong="H1961"\w* \w quedar|strong="H1961"\w* \w morador|strong="H3427"\w*’?”. \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H1961"\w* \w juntó|strong="H6950"\w* \w contra|strong="H1961"\w* \w Jeremías|strong="H3414"\w* en \w la|strong="H2063"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Yahvé.   
\p
\v 10 \w Y|strong="H3068"\w* \w los|strong="H3427"\w* \w príncipes|strong="H8269"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w* \w oyeron|strong="H8085"\w* estas \w cosas|strong="H1697"\w*, y \w subieron|strong="H5927"\w* \w de|strong="H1697"\w* la \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H1697"\w* Yahvé, y se \w sentaron|strong="H3427"\w* \w a|strong="H3068"\w* la entrada \w de|strong="H1697"\w* la \w puerta|strong="H6607"\w* \w nueva|strong="H2319"\w* \w de|strong="H1697"\w* la \w casa|strong="H1004"\w* \w de|strong="H1697"\w* Yahvé.  
\v 11 \w Entonces|strong="H3588"\w* hablaron \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w príncipes|strong="H8269"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*, diciendo: «\w En|strong="H3588"\w* \w sentencia|strong="H4941"\w* \w de|strong="H3588"\w* \w muerte|strong="H4194"\w* ha incurrido \w este|strong="H2088"\w* hombre, \w porque|strong="H3588"\w* \w profetizó|strong="H5012"\w* contra \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, \w como|strong="H3588"\w* \w vosotros|strong="H8085"\w* habéis \w oído|strong="H8085"\w* \w con|strong="H3588"\w* vuestros \w oídos|strong="H8085"\w*».   
\p
\v 12 \w Y|strong="H3068"\w* \w habló|strong="H1697"\w* \w Jeremías|strong="H3414"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w príncipes|strong="H8269"\w* y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, diciendo: «Yahvé me \w envió|strong="H7971"\w* \w a|strong="H3068"\w* profetizar contra \w esta|strong="H2063"\w* \w casa|strong="H1004"\w* y contra \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w que|strong="H5971"\w* habéis \w oído|strong="H8085"\w*.  
\v 13 Enmendad \w ahora|strong="H6258"\w* vuestros \w caminos|strong="H1870"\w* \w y|strong="H5921"\w* vuestras \w obras|strong="H4611"\w*, \w y|strong="H5921"\w* obedeced \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* Yahvé vuestro \w Dios|strong="H3068"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* arrepentirá Yahvé \w del|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H6258"\w* ha \w hablado|strong="H1696"\w* \w contra|strong="H5921"\w* \w vosotros|strong="H8085"\w*.  
\v 14 En \w lo|strong="H6213"\w* \w que|strong="H3027"\w* \w a|strong="H3068"\w* mí respecta, he \w aquí|strong="H2005"\w* estoy en vuestras \w manos|strong="H3027"\w*; \w haced|strong="H6213"\w* \w de|strong="H5869"\w* mí como \w mejor|strong="H2896"\w* y más \w recto|strong="H3477"\w* \w os|strong="H5869"\w* parezca.  
\v 15 \w Mas|strong="H3588"\w* \w sabed|strong="H3045"\w* \w de|strong="H5921"\w* \w cierto|strong="H3588"\w* \w que|strong="H3588"\w* \w si|strong="H3588"\w* \w me|strong="H5921"\w* matáis, \w sangre|strong="H1818"\w* \w inocente|strong="H5355"\w* \w echaréis|strong="H5414"\w* \w sobre|strong="H5921"\w* vosotros, \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* sus \w moradores|strong="H3427"\w*; \w porque|strong="H3588"\w* \w en|strong="H5921"\w* verdad Yahvé \w me|strong="H5921"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* vosotros \w para|strong="H5921"\w* \w que|strong="H3588"\w* hablase \w todas|strong="H3605"\w* \w estas|strong="H2063"\w* \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* vuestros oídos».   
\p
\v 16 \w Y|strong="H3068"\w* \w dijeron|strong="H1696"\w* \w los|strong="H3605"\w* \w príncipes|strong="H8269"\w* \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w*: «\w No|strong="H3588"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* hombre digno \w de|strong="H3588"\w* \w sentencia|strong="H4941"\w* \w de|strong="H3588"\w* \w muerte|strong="H4194"\w*, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w* nos ha \w hablado|strong="H1696"\w*».   
\p
\v 17 Entonces \w se|strong="H5971"\w* \w levantaron|strong="H6965"\w* algunos \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* tierra y hablaron \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* asamblea del \w pueblo|strong="H5971"\w*, diciendo:  
\v 18 “\w Miqueas|strong="H4320"\w* \w de|strong="H5971"\w* Moréset \w profetizó|strong="H5012"\w* en \w tiempo|strong="H3117"\w* \w de|strong="H5971"\w* Ezequías \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3541"\w* habló \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w Judá|strong="H3063"\w*, diciendo: ‘\w Así|strong="H3541"\w* dice Yahvé \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w Ejércitos|strong="H6635"\w*:  
\q1 \w Sión|strong="H6726"\w* \w será|strong="H1961"\w* \w arada|strong="H2790"\w* \w como|strong="H1961"\w* \w campo|strong="H7704"\w*,  
\q2 \w y|strong="H3541"\w* Jerusalén \w vendrá|strong="H1961"\w* \w a|strong="H3068"\w* ser \w montones|strong="H5856"\w* \w de|strong="H5971"\w* ruinas,  
\q2 \w y|strong="H3541"\w* \w el|strong="H3605"\w* \w monte|strong="H2022"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w como|strong="H1961"\w* las cumbres \w de|strong="H5971"\w* un \w bosque|strong="H3293"\w*’.   
\m
\v 19 ¿Acaso \w le|strong="H5921"\w* \w mataron|strong="H4191"\w* Ezequías \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w*? ¿\w No|strong="H3808"\w* \w temió|strong="H3373"\w* \w él|strong="H5921"\w* \w a|strong="H3068"\w* Yahvé \w y|strong="H5921"\w* suplicó \w el|strong="H5921"\w* favor \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* arrepintió \w del|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H3808"\w* \w había|strong="H6213"\w* \w hablado|strong="H1696"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*? ¿\w Haremos|strong="H6213"\w*, pues, \w nosotros|strong="H3605"\w* un \w mal|strong="H7451"\w* tan \w grande|strong="H1419"\w* \w contra|strong="H5921"\w* nuestras \w almas|strong="H5315"\w*?”.   
\p
\v 20 \w Hubo|strong="H1961"\w* \w también|strong="H1571"\w* un \w hombre|strong="H1121"\w* \w que|strong="H5921"\w* profetizaba \w en|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* Yahvé, Urías \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Semaías|strong="H8098"\w*, \w de|strong="H5921"\w* Quiriat-jearim, \w el|strong="H5921"\w* cual \w profetizó|strong="H5012"\w* \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w y|strong="H1571"\w* \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* tierra \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w Jeremías|strong="H3414"\w*;  
\v 21 y \w oyó|strong="H8085"\w* sus \w palabras|strong="H1697"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Joacim|strong="H3079"\w* con \w todos|strong="H3605"\w* sus \w valientes|strong="H1368"\w* y \w todos|strong="H3605"\w* sus \w príncipes|strong="H8269"\w*, y \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w procuró|strong="H1245"\w* \w matarle|strong="H4191"\w*; \w lo|strong="H1697"\w* cual entendiendo Urías, \w tuvo|strong="H3372"\w* \w temor|strong="H3372"\w*, y \w huyó|strong="H1272"\w* y se fue \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.  
\v 22 \w Y|strong="H3068"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w Joacim|strong="H3079"\w* \w envió|strong="H7971"\w* \w hombres|strong="H1121"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, \w a|strong="H3068"\w* Elnatán \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Acbor y otros \w hombres|strong="H1121"\w* con \w él|strong="H1121"\w*, \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*;  
\v 23 \w los|strong="H1121"\w* cuales \w sacaron|strong="H3318"\w* \w a|strong="H3068"\w* Urías \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w* y lo trajeron \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w Joacim|strong="H3079"\w*, \w el|strong="H1121"\w* cual lo \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, y \w echó|strong="H7993"\w* su \w cuerpo|strong="H5038"\w* \w en|strong="H3318"\w* \w los|strong="H1121"\w* \w sepulcros|strong="H6913"\w* del vulgo.   
\p
\v 24 Pero la \w mano|strong="H3027"\w* \w de|strong="H1121"\w* Ahicam \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán \w estuvo|strong="H1961"\w* con \w Jeremías|strong="H3414"\w* \w para|strong="H5414"\w* \w que|strong="H5971"\w* \w no|strong="H1961"\w* lo entregasen en \w manos|strong="H3027"\w* del \w pueblo|strong="H5971"\w* \w para|strong="H5414"\w* \w matarlo|strong="H4191"\w*.   
\c 27
\p
\v 1 \w Al|strong="H4428"\w* comienzo del \w reinado|strong="H4428"\w* \w de|strong="H1121"\w* \w Joacim|strong="H3079"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, llegó \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* parte \w de|strong="H1121"\w* Yahvé, \w que|strong="H1697"\w* decía:  
\v 2 Yahvé \w me|strong="H5921"\w* dice: “\w Hazte|strong="H6213"\w* \w de|strong="H5921"\w* \w ataduras|strong="H4147"\w* \w y|strong="H5921"\w* \w yugos|strong="H4133"\w*, \w y|strong="H5921"\w* póntelos \w al|strong="H5921"\w* \w cuello|strong="H6677"\w*.  
\v 3 Luego envíalos \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Edom, \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Moab|strong="H4124"\w*, \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón, \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Tiro|strong="H6865"\w* y \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Sidón|strong="H6721"\w*, \w por|strong="H3027"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w mensajeros|strong="H4397"\w* \w que|strong="H1121"\w* vienen \w a|strong="H3068"\w* Jerusalén \w a|strong="H3068"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 4 Dadles una \w orden|strong="H6680"\w* para sus señores, diciendo: “El \w Señor|strong="H3068"\w* de los \w Ejércitos|strong="H6635"\w*, el \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*, dice: “Diréis \w a|strong="H3068"\w* vuestros señores:  
\v 5 ‘\w Yo|strong="H6213"\w* he \w hecho|strong="H6213"\w* \w la|strong="H5921"\w* tierra, \w los|strong="H5921"\w* hombres \w y|strong="H5921"\w* \w los|strong="H5921"\w* animales \w que|strong="H5921"\w* están \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w con|strong="H5921"\w* \w mi|strong="H5921"\w* \w gran|strong="H1419"\w* \w poder|strong="H3581"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w mi|strong="H5921"\w* \w brazo|strong="H2220"\w* \w extendido|strong="H5186"\w*. \w Yo|strong="H6213"\w* \w se|strong="H5921"\w* \w la|strong="H5921"\w* \w doy|strong="H5414"\w* \w a|strong="H3068"\w* \w quien|strong="H6213"\w* \w me|strong="H5921"\w* parece justo.  
\v 6 Yo he \w entregado|strong="H5414"\w* \w todas|strong="H3605"\w* estas \w tierras|strong="H7704"\w* en \w manos|strong="H3027"\w* \w de|strong="H5414"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Babilonia, mi \w siervo|strong="H5650"\w*. \w También|strong="H1571"\w* le he \w dado|strong="H5414"\w* \w los|strong="H3605"\w* \w animales|strong="H2416"\w* del \w campo|strong="H7704"\w* \w para|strong="H5414"\w* \w que|strong="H6258"\w* le sirvan.  
\v 7 \w Todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w le|strong="H1931"\w* \w servirán|strong="H5647"\w* \w a|strong="H3068"\w* \w él|strong="H1931"\w*, \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w hijo|strong="H1121"\w* \w y|strong="H1571"\w* \w al|strong="H5704"\w* \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w su|strong="H1931"\w* \w hijo|strong="H1121"\w*, \w hasta|strong="H5704"\w* \w que|strong="H1931"\w* llegue \w el|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5704"\w* \w su|strong="H1931"\w* propia tierra. \w Entonces|strong="H6256"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w* \w y|strong="H1571"\w* \w grandes|strong="H1419"\w* \w reyes|strong="H4428"\w* \w lo|strong="H1931"\w* \w harán|strong="H5647"\w* \w su|strong="H1931"\w* siervo.   
\p
\v 8 ‘\w Sucederá|strong="H1961"\w* \w que|strong="H1931"\w* castigaré \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w nación|strong="H1471"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w reino|strong="H4467"\w* \w que|strong="H1931"\w* \w no|strong="H3808"\w* sirvan \w al|strong="H5921"\w* \w mismo|strong="H1931"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w y|strong="H5921"\w* \w que|strong="H1931"\w* \w no|strong="H3808"\w* pongan \w su|strong="H1931"\w* \w cuello|strong="H6677"\w* bajo \w el|strong="H1931"\w* \w yugo|strong="H5923"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia’, \w dice|strong="H5002"\w* Yahvé, ‘\w con|strong="H5921"\w* \w espada|strong="H2719"\w*, \w con|strong="H5921"\w* \w hambre|strong="H7458"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w pestilencia|strong="H1698"\w*, \w hasta|strong="H5704"\w* \w que|strong="H1931"\w* \w los|strong="H5921"\w* \w haya|strong="H1961"\w* consumido \w por|strong="H5921"\w* \w su|strong="H1931"\w* \w mano|strong="H3027"\w*.  
\v 9 Pero en cuanto \w a|strong="H3068"\w* \w vosotros|strong="H8085"\w*, \w no|strong="H3808"\w* \w escuchéis|strong="H8085"\w* \w a|strong="H3068"\w* \w vuestros|strong="H5647"\w* \w profetas|strong="H5030"\w*, \w a|strong="H3068"\w* \w vuestros|strong="H5647"\w* \w adivinos|strong="H7080"\w*, \w a|strong="H3068"\w* \w vuestros|strong="H5647"\w* \w sueños|strong="H2472"\w*, \w a|strong="H3068"\w* \w vuestros|strong="H5647"\w* \w agoreros|strong="H6049"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w vuestros|strong="H5647"\w* hechiceros, \w que|strong="H3808"\w* os hablan diciendo: «\w No|strong="H3808"\w* \w serviréis|strong="H5647"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de Babilonia»;  
\v 10 \w porque|strong="H3588"\w* \w os|strong="H5921"\w* \w profetizan|strong="H5012"\w* una \w mentira|strong="H8267"\w*, \w para|strong="H4616"\w* alejaros \w de|strong="H5921"\w* vuestra tierra, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w os|strong="H5921"\w* expulse \w y|strong="H3588"\w* perezcáis.  
\v 11 Pero \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w nación|strong="H1471"\w* \w que|strong="H5921"\w* ponga su \w cuello|strong="H6677"\w* bajo \w el|strong="H5921"\w* \w yugo|strong="H5923"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w sirva|strong="H5647"\w*, \w a|strong="H3068"\w* esa \w nación|strong="H1471"\w* \w la|strong="H5921"\w* dejaré permanecer \w en|strong="H5921"\w* su propia tierra — \w dice|strong="H5002"\w* \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* — \w y|strong="H5921"\w* \w la|strong="H5921"\w* cultivará \w y|strong="H5921"\w* \w habitará|strong="H3427"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w*”.   
\p
\v 12 \w De|strong="H5971"\w* acuerdo con \w todas|strong="H3605"\w* estas \w palabras|strong="H1697"\w*, \w hablé|strong="H1696"\w* \w a|strong="H3068"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Judá|strong="H3063"\w*, \w diciendo|strong="H1696"\w*: “Poned \w vuestros|strong="H5647"\w* cuellos bajo \w el|strong="H3605"\w* \w yugo|strong="H5923"\w* del \w rey|strong="H4428"\w* \w de|strong="H5971"\w* Babilonia, y servidle \w a|strong="H3068"\w* \w él|strong="H3605"\w* y \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*, y \w vivid|strong="H2421"\w*.  
\v 13 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* vais \w a|strong="H3068"\w* \w morir|strong="H4191"\w*, tú y tu \w pueblo|strong="H5971"\w*, \w a|strong="H3068"\w* causa \w de|strong="H5971"\w* la \w espada|strong="H2719"\w*, del \w hambre|strong="H7458"\w* y \w de|strong="H5971"\w* la peste, \w como|strong="H4100"\w* \w lo|strong="H4100"\w* \w ha|strong="H3808"\w* \w dicho|strong="H1696"\w* el \w Señor|strong="H3068"\w* respecto \w a|strong="H3068"\w* la \w nación|strong="H1471"\w* \w que|strong="H4100"\w* \w no|strong="H3808"\w* quiera \w servir|strong="H5647"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H5971"\w* Babilonia?  
\v 14 \w No|strong="H3808"\w* \w escuchéis|strong="H8085"\w* \w las|strong="H1992"\w* \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* \w que|strong="H3588"\w* os \w hablan|strong="H1697"\w* diciendo: «\w No|strong="H3808"\w* \w serviréis|strong="H5647"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia», \w porque|strong="H3588"\w* os \w profetizan|strong="H5012"\w* una \w mentira|strong="H8267"\w*.  
\v 15 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H1992"\w* he \w enviado|strong="H7971"\w* — \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* —, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w ellos|strong="H1992"\w* \w profetizan|strong="H5012"\w* \w falsamente|strong="H8267"\w* \w en|strong="H3588"\w* mi \w nombre|strong="H8034"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* os expulse \w y|strong="H3588"\w* perezcáis, vosotros \w y|strong="H3588"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* \w que|strong="H3588"\w* os \w profetizan|strong="H5012"\w*.”   
\p
\v 16 \w También|strong="H2088"\w* \w hablé|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w diciendo|strong="H1696"\w*: \w El|strong="H3588"\w* \w Señor|strong="H3068"\w* \w dice|strong="H1696"\w*: “\w No|strong="H3588"\w* \w escuchéis|strong="H8085"\w* \w las|strong="H1992"\w* \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* vuestros \w profetas|strong="H5030"\w* \w que|strong="H3588"\w* os \w profetizan|strong="H5012"\w*, \w diciendo|strong="H1696"\w*: ‘He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w los|strong="H1992"\w* utensilios \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé \w volverán|strong="H7725"\w* \w pronto|strong="H4120"\w* \w de|strong="H3588"\w* Babilonia’; \w porque|strong="H3588"\w* os \w profetizan|strong="H5012"\w* una \w mentira|strong="H8267"\w*.  
\v 17 \w No|strong="H1961"\w* les hagáis caso. \w Servid|strong="H5647"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de Babilonia y \w vivid|strong="H2421"\w*. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* ha de convertirse \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* en una desolación?  
\v 18 Pero \w si|strong="H4994"\w* son \w profetas|strong="H5030"\w*, y \w si|strong="H4994"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w está|strong="H3426"\w* con \w ellos|strong="H1992"\w*, \w que|strong="H4994"\w* intercedan \w ahora|strong="H4994"\w* ante Yahvé \w de|strong="H1697"\w* \w los|strong="H1992"\w* \w Ejércitos|strong="H6635"\w* para \w que|strong="H4994"\w* \w los|strong="H1992"\w* utensilios \w que|strong="H4994"\w* quedan en la \w casa|strong="H1004"\w* \w de|strong="H1697"\w* Yahvé, en la \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w* y en Jerusalén, \w no|strong="H1115"\w* vayan \w a|strong="H3068"\w* Babilonia.  
\v 19 \w Porque|strong="H3588"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* dice respecto \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*, respecto \w al|strong="H5921"\w* \w mar|strong="H3220"\w*, respecto \w a|strong="H3068"\w* \w las|strong="H5921"\w* bases \w y|strong="H3588"\w* respecto \w al|strong="H5921"\w* \w resto|strong="H3499"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* utensilios \w que|strong="H3588"\w* quedan \w en|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*,  
\v 20 \w que|strong="H3808"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia, \w no|strong="H3808"\w* \w tomó|strong="H3947"\w* cuando \w llevó|strong="H3947"\w* cautivo \w a|strong="H3068"\w* Jeconías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joacim|strong="H3079"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w de|strong="H1121"\w* Jerusalén \w a|strong="H3068"\w* Babilonia, y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* nobles \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* y \w de|strong="H1121"\w* Jerusalén —  
\v 21 \w sí|strong="H3588"\w*, Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, dice \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w los|strong="H5921"\w* utensilios \w que|strong="H3588"\w* quedan \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3588"\w* \w en|strong="H5921"\w* Jerusalén:  
\v 22 ‘\w Serán|strong="H1961"\w* llevados \w a|strong="H3068"\w* Babilonia, \w y|strong="H5704"\w* \w allí|strong="H8033"\w* \w estarán|strong="H1961"\w* \w hasta|strong="H5704"\w* el \w día|strong="H3117"\w* \w en|strong="H5704"\w* \w que|strong="H5704"\w* yo \w los|strong="H1961"\w* visite — \w dice|strong="H5002"\w* Yahvé — \w entonces|strong="H3117"\w* \w los|strong="H1961"\w* haré \w subir|strong="H5927"\w* \w y|strong="H5704"\w* \w los|strong="H1961"\w* devolveré \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.’”   
\c 28
\p
\v 1 \w Aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w año|strong="H8141"\w*, \w al|strong="H4428"\w* comienzo del \w reinado|strong="H4428"\w* \w de|strong="H1121"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, en \w el|strong="H1931"\w* \w cuarto|strong="H7243"\w* \w año|strong="H8141"\w*, en \w el|strong="H1931"\w* \w quinto|strong="H2549"\w* \w mes|strong="H2320"\w*, \w el|strong="H1931"\w* \w profeta|strong="H5030"\w* \w Hananías|strong="H2608"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Azzur, \w que|strong="H1931"\w* \w era|strong="H1961"\w* \w de|strong="H1121"\w* \w Gabaón|strong="H1391"\w*, me habló en \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Yahvé, en presencia \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* y \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w*, diciendo:  
\v 2 “Yahvé de los \w Ejércitos|strong="H6635"\w*, el \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*, dice: ‘He roto el \w yugo|strong="H5923"\w* del \w rey|strong="H4428"\w* de Babilonia.  
\v 3 \w Dentro|strong="H5750"\w* \w de|strong="H4480"\w* \w dos|strong="H3117"\w* \w años|strong="H8141"\w* completos traeré \w de|strong="H4480"\w* nuevo \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w de|strong="H4480"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H4480"\w* Yahvé \w que|strong="H4480"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H4480"\w* Babilonia, sacó \w de|strong="H4480"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* y \w llevó|strong="H3947"\w* \w a|strong="H3068"\w* Babilonia.  
\v 4 \w Volveré|strong="H7725"\w* \w a|strong="H3068"\w* traer \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w a|strong="H3068"\w* Jeconías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Joacim|strong="H3079"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w con|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* cautivos \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w que|strong="H3588"\w* fueron \w a|strong="H3068"\w* Babilonia — \w dice|strong="H5002"\w* Yahvé —, \w porque|strong="H3588"\w* romperé \w el|strong="H3588"\w* \w yugo|strong="H5923"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia’”.   
\p
\v 5 Entonces \w el|strong="H3605"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* respondió al \w profeta|strong="H5030"\w* \w Hananías|strong="H2608"\w* \w en|strong="H5975"\w* presencia \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w de|strong="H5971"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w estaba|strong="H5975"\w* \w en|strong="H5975"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Yahvé.  
\v 6 \w El|strong="H3605"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* dijo: «¡Amén! \w Que|strong="H1697"\w* Yahvé \w lo|strong="H1697"\w* \w haga|strong="H6213"\w* \w así|strong="H3651"\w*. \w Que|strong="H1697"\w* Yahvé \w cumpla|strong="H6965"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* has \w profetizado|strong="H5012"\w*, para \w hacer|strong="H6213"\w* \w volver|strong="H7725"\w* \w de|strong="H1697"\w* Babilonia \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w los|strong="H3605"\w* utensilios \w de|strong="H1697"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1697"\w* Yahvé y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w cautivos|strong="H1473"\w*.  
\v 7 Sin embargo, \w oíd|strong="H8085"\w* \w ahora|strong="H4994"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w* \w que|strong="H4994"\w* \w hablo|strong="H1696"\w* \w a|strong="H3068"\w* vuestros \w oídos|strong="H8085"\w* y \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w de|strong="H5971"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*:  
\v 8 \w Los|strong="H5921"\w* \w profetas|strong="H5030"\w* \w que|strong="H4480"\w* han \w sido|strong="H1961"\w* \w antes|strong="H6440"\w* \w de|strong="H4480"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w antes|strong="H6440"\w* \w de|strong="H4480"\w* \w ti|strong="H5921"\w*, \w de|strong="H4480"\w* antaño, \w profetizaron|strong="H5012"\w* \w contra|strong="H5921"\w* \w muchos|strong="H7227"\w* países \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w grandes|strong="H1419"\w* \w reinos|strong="H4467"\w* \w acerca|strong="H5921"\w* \w de|strong="H4480"\w* \w guerra|strong="H4421"\w*, \w de|strong="H4480"\w* malicia \w y|strong="H5921"\w* \w de|strong="H4480"\w* \w pestilencia|strong="H1698"\w*.  
\v 9 En cuanto al \w profeta|strong="H5030"\w* \w que|strong="H3045"\w* \w profetiza|strong="H5012"\w* \w de|strong="H1697"\w* \w paz|strong="H7965"\w*, cuando la \w palabra|strong="H1697"\w* del \w profeta|strong="H5030"\w* \w se|strong="H3045"\w* cumpla, entonces \w se|strong="H3045"\w* \w sabrá|strong="H3045"\w* \w que|strong="H3045"\w* Yahvé \w lo|strong="H1697"\w* ha \w enviado|strong="H7971"\w* verdaderamente».   
\p
\v 10 Entonces \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Hananías|strong="H2608"\w* \w tomó|strong="H3947"\w* \w la|strong="H5921"\w* barra \w del|strong="H5921"\w* \w cuello|strong="H6677"\w* \w del|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* rompió.  
\v 11 \w Hananías|strong="H2608"\w* habló \w en|strong="H5921"\w* presencia \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*, diciendo: “Yahvé dice: ‘\w Así|strong="H3541"\w* romperé \w el|strong="H5921"\w* \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w del|strong="H5921"\w* \w cuello|strong="H6677"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w dentro|strong="H5750"\w* \w de|strong="H5921"\w* \w dos|strong="H3117"\w* \w años|strong="H8141"\w* completos’”. \w Entonces|strong="H3117"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w siguió|strong="H3212"\w* su \w camino|strong="H1870"\w*.   
\p
\v 12 Entonces \w vino|strong="H1961"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Hananías|strong="H2608"\w* rompiera \w la|strong="H5921"\w* barra \w del|strong="H5921"\w* \w cuello|strong="H6677"\w* \w del|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*, diciendo:  
\v 13 “\w Ve|strong="H1980"\w* \w y|strong="H3541"\w* di \w a|strong="H3068"\w* \w Hananías|strong="H2608"\w*: ‘Yahvé dice: «\w Tú|strong="H6213"\w* has roto las barras \w de|strong="H8478"\w* \w madera|strong="H6086"\w*, pero has fabricado \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* barras \w de|strong="H8478"\w* \w hierro|strong="H1270"\w*» ’.  
\v 14 \w Porque|strong="H3588"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, dice: ‘He \w puesto|strong="H5414"\w* un \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* \w hierro|strong="H1270"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w cuello|strong="H6677"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* estas \w naciones|strong="H1471"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* sirvan \w a|strong="H3068"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w y|strong="H1571"\w* \w le|strong="H5921"\w* \w servirán|strong="H5647"\w*. \w También|strong="H1571"\w* \w le|strong="H5921"\w* he \w dado|strong="H5414"\w* \w los|strong="H5921"\w* \w animales|strong="H2416"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w*’”.   
\p
\v 15 Entonces \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* dijo \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Hananías|strong="H2608"\w*: “¡\w Escucha|strong="H8085"\w*, \w Hananías|strong="H2608"\w*! \w El|strong="H5921"\w* \w Señor|strong="H3068"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* \w ha|strong="H3808"\w* \w enviado|strong="H7971"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* haces \w que|strong="H3808"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* confíe \w en|strong="H5921"\w* una \w mentira|strong="H8267"\w*.  
\v 16 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* Yahvé \w dice|strong="H1696"\w*: ‘He \w aquí|strong="H3541"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H5921"\w* despido \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra. Este \w año|strong="H8141"\w* \w morirás|strong="H4191"\w*, \w porque|strong="H3588"\w* \w has|strong="H4191"\w* \w hablado|strong="H1696"\w* \w con|strong="H5921"\w* rebeldía \w contra|strong="H5921"\w* Yahvé’”.   
\p
\v 17 \w Así|strong="H1931"\w* \w pues|strong="H1931"\w*, \w el|strong="H1931"\w* \w profeta|strong="H5030"\w* \w Hananías|strong="H2608"\w* \w murió|strong="H4191"\w* \w aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w año|strong="H8141"\w*, en \w el|strong="H1931"\w* \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w*.   
\c 29
\p
\v 1 Estas son las \w palabras|strong="H1697"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* \w carta|strong="H5612"\w* \w que|strong="H5971"\w* \w el|strong="H3605"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w envió|strong="H7971"\w* desde Jerusalén al \w resto|strong="H3499"\w* \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* del \w cautiverio|strong="H1473"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w* y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w Nabucodonosor|strong="H5019"\w* había llevado cautivo \w de|strong="H5971"\w* Jerusalén \w a|strong="H3068"\w* Babilonia.  
\v 2 Esto sucedió después \w de|strong="H8269"\w* que el \w rey|strong="H4428"\w* Jeconías, la \w reina|strong="H4428"\w* madre, los \w eunucos|strong="H5631"\w*, los \w príncipes|strong="H8269"\w* \w de|strong="H8269"\w* \w Judá|strong="H3063"\w* y \w de|strong="H8269"\w* Jerusalén, los artesanos y los herreros hubieran \w salido|strong="H3318"\w* \w de|strong="H8269"\w* Jerusalén.  
\v 3 La carta \w fue|strong="H3063"\w* enviada \w por|strong="H3027"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* Elasá, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán, y \w de|strong="H1121"\w* Gemarías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hilcías|strong="H2518"\w*, \w a|strong="H3068"\w* quienes Sedequías, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Babilonia, \w a|strong="H3068"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia. Decía:   
\mi
\v 4 “Yahvé de \w los|strong="H3605"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*, dice \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w cautivos|strong="H1473"\w* \w que|strong="H3605"\w* hice transportar de Jerusalén \w a|strong="H3068"\w* Babilonia:  
\v 5 ‘Construid \w casas|strong="H1004"\w* y \w habitad|strong="H3427"\w* en ellas; \w plantad|strong="H5193"\w* \w huertos|strong="H1593"\w* y comed de su \w fruto|strong="H6529"\w*.  
\v 6 \w Tomad|strong="H3947"\w* \w mujeres|strong="H1323"\w* y engendrad \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*; \w dad|strong="H5414"\w* \w mujeres|strong="H1323"\w* \w a|strong="H3068"\w* vuestros \w hijos|strong="H1121"\w* y \w entregad|strong="H5414"\w* vuestras \w hijas|strong="H1323"\w* \w a|strong="H3068"\w* maridos \w para|strong="H5414"\w* \w que|strong="H1121"\w* den \w a|strong="H3068"\w* luz \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*. Multiplicaos \w allí|strong="H8033"\w* y no disminuyáis.  
\v 7 \w Buscad|strong="H1875"\w* \w la|strong="H3588"\w* \w paz|strong="H7965"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* os hice transportar \w y|strong="H3588"\w* rogad \w por|strong="H3588"\w* \w ella|strong="H8033"\w* \w a|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w paz|strong="H7965"\w* \w tendréis|strong="H1961"\w* vosotros \w paz|strong="H7965"\w*’.  
\v 8 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H3588"\w* \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: ‘\w No|strong="H3588"\w* os engañen vuestros \w profetas|strong="H5030"\w* \w que|strong="H3588"\w* están \w entre|strong="H7130"\w* \w vosotros|strong="H8085"\w*, ni vuestros \w adivinos|strong="H7080"\w*, ni prestéis atención \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w sueños|strong="H2472"\w* \w que|strong="H3588"\w* ellos sueñan.  
\v 9 \w Porque|strong="H3588"\w* \w falsamente|strong="H8267"\w* os \w profetizan|strong="H5012"\w* \w ellos|strong="H1992"\w* \w en|strong="H3588"\w* mi \w nombre|strong="H8034"\w*; \w yo|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H1992"\w* \w envié|strong="H7971"\w*’, \w dice|strong="H5002"\w* Yahvé.  
\v 10 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé: ‘\w Cuando|strong="H3588"\w* \w se|strong="H5921"\w* cumplan \w los|strong="H5921"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w* \w de|strong="H5921"\w* Babilonia, \w yo|strong="H3588"\w* \w os|strong="H5921"\w* \w visitaré|strong="H6485"\w* \w y|strong="H3588"\w* despertaré \w sobre|strong="H5921"\w* vosotros \w mi|strong="H5921"\w* \w buena|strong="H2896"\w* \w palabra|strong="H1697"\w*, \w para|strong="H5921"\w* haceros \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.  
\v 11 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w los|strong="H5921"\w* \w pensamientos|strong="H4284"\w* \w que|strong="H3588"\w* \w tengo|strong="H5921"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* vosotros — \w dice|strong="H5002"\w* Yahvé —, \w pensamientos|strong="H4284"\w* \w de|strong="H5921"\w* \w paz|strong="H7965"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w de|strong="H5921"\w* \w mal|strong="H7451"\w*, \w para|strong="H5921"\w* daros un porvenir \w y|strong="H3588"\w* una \w esperanza|strong="H8615"\w*.  
\v 12 Entonces me invocaréis, y vendréis y oraréis \w a|strong="H3068"\w* mí, y yo os \w escucharé|strong="H8085"\w*.  
\v 13 \w Me|strong="H3588"\w* buscaréis \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w hallaréis|strong="H4672"\w*, \w porque|strong="H3588"\w* \w me|strong="H3588"\w* buscaréis \w de|strong="H3588"\w* \w todo|strong="H3605"\w* vuestro \w corazón|strong="H3824"\w*.  
\v 14 \w Y|strong="H3068"\w* me dejaré \w hallar|strong="H4672"\w* de vosotros — \w dice|strong="H5002"\w* Yahvé —, y haré \w volver|strong="H7725"\w* vuestro cautiverio, y os reuniré de \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* y de \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w lugares|strong="H4725"\w* adonde os arrojé, \w dice|strong="H5002"\w* Yahvé; y os haré \w volver|strong="H7725"\w* al \w lugar|strong="H4725"\w* de \w donde|strong="H8033"\w* os hice transportar’.   
\mi
\v 15 \w Pero|strong="H3588"\w* \w como|strong="H3588"\w* habéis dicho: ‘Yahvé nos ha levantado \w profetas|strong="H5030"\w* \w en|strong="H3588"\w* Babilonia’,  
\v 16 \w así|strong="H3541"\w* dice Yahvé acerca del \w rey|strong="H4428"\w* \w que|strong="H3588"\w* \w está|strong="H2063"\w* \w sentado|strong="H3427"\w* sobre \w el|strong="H3588"\w* \w trono|strong="H3678"\w* \w de|strong="H3588"\w* \w David|strong="H1732"\w*, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* \w mora|strong="H3427"\w* \w en|strong="H3588"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, vuestros hermanos \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w salieron|strong="H3318"\w* \w con|strong="H3588"\w* vosotros \w en|strong="H3588"\w* \w cautiverio|strong="H1473"\w*;  
\v 17 \w así|strong="H3541"\w* dice Yahvé \w de|strong="H5414"\w* los \w Ejércitos|strong="H6635"\w*: ‘He \w aquí|strong="H3541"\w* \w que|strong="H3808"\w* \w envío|strong="H7971"\w* yo contra ellos \w espada|strong="H2719"\w*, \w hambre|strong="H7458"\w* \w y|strong="H3541"\w* \w pestilencia|strong="H1698"\w*, \w y|strong="H3541"\w* los \w pondré|strong="H5414"\w* como los \w higos|strong="H8384"\w* malos, \w que|strong="H3808"\w* \w de|strong="H5414"\w* tan malos \w no|strong="H3808"\w* \w se|strong="H3808"\w* pueden comer.  
\v 18 \w Los|strong="H3605"\w* \w perseguiré|strong="H7291"\w* con \w espada|strong="H2719"\w*, con \w hambre|strong="H7458"\w* y con \w pestilencia|strong="H1698"\w*, y \w los|strong="H3605"\w* \w entregaré|strong="H5414"\w* \w para|strong="H5414"\w* ser escarnecidos \w por|strong="H5414"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reinos|strong="H4467"\w* \w de|strong="H5414"\w* \w la|strong="H3605"\w* tierra, \w para|strong="H5414"\w* ser objeto \w de|strong="H5414"\w* maldición, \w de|strong="H5414"\w* \w espanto|strong="H8047"\w*, \w de|strong="H5414"\w* burla y \w de|strong="H5414"\w* \w oprobio|strong="H2781"\w* \w entre|strong="H8033"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* adonde \w los|strong="H3605"\w* he arrojado,  
\v 19 \w por|strong="H8478"\w* \w cuanto|strong="H8478"\w* \w no|strong="H3808"\w* \w oyeron|strong="H8085"\w* mis \w palabras|strong="H1697"\w* — \w dice|strong="H5002"\w* Yahvé —, \w que|strong="H3808"\w* les \w envié|strong="H7971"\w* \w por|strong="H8478"\w* mis \w siervos|strong="H5650"\w* los \w profetas|strong="H5030"\w*, \w madrugando|strong="H7925"\w* y enviándolos; y \w no|strong="H3808"\w* habéis escuchado \w vosotros|strong="H8085"\w*’, \w dice|strong="H5002"\w* Yahvé.   
\mi
\v 20 \w Oíd|strong="H8085"\w*, \w pues|strong="H7971"\w*, \w la|strong="H3605"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, \w todos|strong="H3605"\w* \w vosotros|strong="H8085"\w* \w los|strong="H3605"\w* del \w cautiverio|strong="H1473"\w* \w que|strong="H1697"\w* \w envié|strong="H7971"\w* \w de|strong="H1697"\w* Jerusalén \w a|strong="H3068"\w* Babilonia.  
\v 21 \w Así|strong="H3541"\w* dice Yahvé \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H1121"\w* \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, acerca \w de|strong="H1121"\w* Acab, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Colaías, \w y|strong="H3541"\w* acerca \w de|strong="H1121"\w* Sedequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Maasías|strong="H4641"\w*, \w que|strong="H1121"\w* \w os|strong="H5869"\w* \w profetizan|strong="H5012"\w* \w mentira|strong="H8267"\w* \w en|strong="H5221"\w* mi \w nombre|strong="H8034"\w*: ‘He \w aquí|strong="H3541"\w* \w que|strong="H1121"\w* \w los|strong="H1121"\w* \w entrego|strong="H5414"\w* yo \w en|strong="H5221"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia, \w y|strong="H3541"\w* \w él|strong="H1121"\w* \w los|strong="H1121"\w* matará \w delante|strong="H5869"\w* \w de|strong="H1121"\w* vuestros \w ojos|strong="H5869"\w*.  
\v 22 \w Y|strong="H3068"\w* de \w ellos|strong="H1992"\w* \w se|strong="H1992"\w* \w tomará|strong="H3947"\w* una fórmula de \w maldición|strong="H7045"\w* \w por|strong="H4428"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* cautivos de \w Judá|strong="H3063"\w* \w que|strong="H1992"\w* están en Babilonia, diciendo: «Haga Yahvé contigo como con Sedequías y como con Acab, \w a|strong="H3068"\w* quienes \w el|strong="H3605"\w* \w rey|strong="H4428"\w* de Babilonia asó \w al|strong="H4428"\w* fuego»;  
\v 23 \w por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w hicieron|strong="H6213"\w* \w vileza|strong="H5039"\w* en \w Israel|strong="H3478"\w*, y \w cometieron|strong="H6213"\w* adulterio con las mujeres \w de|strong="H1697"\w* sus \w prójimos|strong="H7453"\w*, y \w falsamente|strong="H8267"\w* \w hablaron|strong="H1696"\w* en mi \w nombre|strong="H8034"\w* \w palabra|strong="H1697"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w les|strong="H6680"\w* \w mandé|strong="H6680"\w*; \w lo|strong="H1697"\w* cual \w yo|strong="H6680"\w* \w sé|strong="H3045"\w* y \w de|strong="H1697"\w* ello soy \w testigo|strong="H5707"\w*’, \w dice|strong="H5002"\w* Yahvé.   
\p
\v 24 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w Semaías|strong="H8098"\w* el nehelamita hablarás, diciendo:  
\v 25 “\w Así|strong="H3541"\w* habla Yahvé \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, diciendo: ‘\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w enviaste|strong="H7971"\w* \w cartas|strong="H5612"\w* en tu \w nombre|strong="H8034"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* está en Jerusalén, \w y|strong="H3541"\w* al \w sacerdote|strong="H3548"\w* \w Sofonías|strong="H6846"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Maasías|strong="H4641"\w*, \w y|strong="H3541"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, diciendo:  
\v 26 “Yahvé te ha \w puesto|strong="H5414"\w* \w por|strong="H8478"\w* \w sacerdote|strong="H3548"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* del \w sacerdote|strong="H3548"\w* \w Joiada|strong="H3077"\w*, \w para|strong="H5414"\w* \w que|strong="H1961"\w* \w seáis|strong="H1961"\w* encargados \w en|strong="H8478"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H8478"\w* Yahvé \w de|strong="H8478"\w* \w todo|strong="H3605"\w* hombre loco \w que|strong="H1961"\w* \w profetice|strong="H5012"\w*, \w poniéndolo|strong="H5414"\w* \w en|strong="H8478"\w* \w el|strong="H3605"\w* \w cepo|strong="H4115"\w* y \w en|strong="H8478"\w* \w el|strong="H3605"\w* collar \w de|strong="H8478"\w* hierro.  
\v 27 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w*, \w pues|strong="H6258"\w*, \w no|strong="H3808"\w* habéis \w reprendido|strong="H1605"\w* \w ahora|strong="H6258"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* de Anatot, \w que|strong="H4100"\w* \w se|strong="H3808"\w* os hace pasar \w por|strong="H4100"\w* profeta?  
\v 28 \w Pues|strong="H3588"\w* \w por|strong="H5921"\w* \w eso|strong="H3651"\w* \w nos|strong="H5921"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Babilonia: ‘Largo \w es|strong="H1931"\w* \w el|strong="H1931"\w* cautiverio; \w edificad|strong="H1129"\w* \w casas|strong="H1004"\w* \w y|strong="H3588"\w* habitadlas; \w plantad|strong="H5193"\w* \w huertos|strong="H1593"\w* \w y|strong="H3588"\w* comed \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w fruto|strong="H6529"\w*’” ’.   
\p
\v 29 \w Y|strong="H3068"\w* \w el|strong="H5030"\w* \w sacerdote|strong="H3548"\w* \w Sofonías|strong="H6846"\w* \w leyó|strong="H7121"\w* \w esta|strong="H2088"\w* \w carta|strong="H5612"\w* \w a|strong="H3068"\w* oídos del \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*.  
\v 30 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, diciendo:  
\v 31 “\w Envía|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w cautivos|strong="H1473"\w*: ‘\w Así|strong="H3541"\w* dice Yahvé \w de|strong="H5921"\w* \w Semaías|strong="H8098"\w* \w el|strong="H5921"\w* nehelamita: \w Por|strong="H5921"\w* \w cuanto|strong="H3282"\w* \w os|strong="H5921"\w* \w profetizó|strong="H5012"\w* \w Semaías|strong="H8098"\w*, \w sin|strong="H3808"\w* haberlo yo \w enviado|strong="H7971"\w*, \w y|strong="H5921"\w* \w os|strong="H5921"\w* hizo confiar \w en|strong="H5921"\w* \w mentira|strong="H8267"\w*,  
\v 32 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* \w dice|strong="H5002"\w* Yahvé: He \w aquí|strong="H2088"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* castigaré \w a|strong="H3068"\w* \w Semaías|strong="H8098"\w* \w el|strong="H5921"\w* nehelamita \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w descendencia|strong="H2233"\w*; \w no|strong="H3808"\w* \w tendrá|strong="H1961"\w* varón \w que|strong="H3588"\w* \w more|strong="H3427"\w* \w entre|strong="H8432"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w ni|strong="H3808"\w* \w verá|strong="H7200"\w* \w el|strong="H5921"\w* \w bien|strong="H2896"\w* \w que|strong="H3588"\w* \w haré|strong="H6213"\w* \w yo|strong="H3588"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* — \w dice|strong="H5002"\w* Yahvé —, \w porque|strong="H3588"\w* \w contra|strong="H5921"\w* Yahvé \w ha|strong="H3541"\w* \w hablado|strong="H1696"\w* \w rebelión|strong="H5627"\w*’”.   
\c 30
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H1697"\w* parte \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*: ‘\w Escribe|strong="H3789"\w* en un \w libro|strong="H5612"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* te he \w hablado|strong="H1696"\w*.  
