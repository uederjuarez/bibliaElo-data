\b  
\q1
\v 49 «\w Como|strong="H1571"\w* Babilonia \w hizo|strong="H5307"\w* \w caer|strong="H5307"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w muertos|strong="H2491"\w* de \w Israel|strong="H3478"\w*,  
\q2 \w así|strong="H1571"\w* \w caerán|strong="H5307"\w* en Babilonia \w los|strong="H3605"\w* \w muertos|strong="H2491"\w* de \w toda|strong="H3605"\w* \w la|strong="H1571"\w* tierra.   
\q1
\v 50 \w Los|strong="H5921"\w* \w que|strong="H5921"\w* escapasteis \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*, ¡\w id|strong="H5927"\w*!, \w no|strong="H5921"\w* \w os|strong="H5921"\w* detengáis;  
\q2 \w acordaos|strong="H2142"\w* \w de|strong="H5921"\w* Yahvé \w desde|strong="H5921"\w* \w lejos|strong="H7350"\w*,  
\q2 \w y|strong="H5921"\w* \w que|strong="H5921"\w* Jerusalén \w suba|strong="H5927"\w* \w a|strong="H3068"\w* vuestro pensamiento».   
\b  
\q1
\v 51 «Estamos avergonzados, \w porque|strong="H3588"\w* \w oímos|strong="H8085"\w* \w la|strong="H5921"\w* \w afrenta|strong="H2781"\w*;  
\q2 \w la|strong="H5921"\w* \w confusión|strong="H3639"\w* \w cubrió|strong="H3680"\w* nuestros \w rostros|strong="H6440"\w*,  
\q1 \w porque|strong="H3588"\w* extranjeros han entrado \w en|strong="H5921"\w* \w los|strong="H5921"\w* santuarios \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé».   
\b  
\q1
\v 52 «\w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* vienen \w días|strong="H3117"\w*», \w dice|strong="H5002"\w* Yahvé,  
\q2 «\w en|strong="H5921"\w* \w que|strong="H5921"\w* \w yo|strong="H2009"\w* ejecutaré juicio \w sobre|strong="H5921"\w* sus imágenes talladas,  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w toda|strong="H3605"\w* su tierra gemirán \w los|strong="H5921"\w* \w heridos|strong="H2491"\w*.   
\q1
\v 53 \w Aunque|strong="H3588"\w* \w suba|strong="H5927"\w* Babilonia hasta \w el|strong="H3588"\w* \w cielo|strong="H8064"\w*,  
\q2 \w y|strong="H3588"\w* \w aunque|strong="H3588"\w* fortifique \w en|strong="H3588"\w* lo \w alto|strong="H4791"\w* \w su|strong="H3588"\w* baluarte,  
\q2 \w de|strong="H3588"\w* mi parte vendrán contra ella destruidores» — \w dice|strong="H5002"\w* Yahvé —.   
\b  
\q1
\v 54 «¡\w Voz|strong="H6963"\w* de \w clamor|strong="H2201"\w* desde Babilonia,  
\q2 y \w gran|strong="H1419"\w* quebranto de la tierra de los \w caldeos|strong="H3778"\w*!   
\q1
\v 55 \w Porque|strong="H3588"\w* Yahvé asola \w a|strong="H3068"\w* Babilonia,  
\q2 \w y|strong="H3588"\w* hace cesar \w de|strong="H4480"\w* \w ella|strong="H4480"\w* \w su|strong="H3588"\w* \w gran|strong="H1419"\w* bullicio;  
\q1 braman sus olas \w como|strong="H3588"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*,  
\q2 \w y|strong="H3588"\w* resuena \w el|strong="H3588"\w* estrépito \w de|strong="H4480"\w* \w su|strong="H3588"\w* \w voz|strong="H6963"\w*.   
\q1
\v 56 \w Porque|strong="H3588"\w* \w el|strong="H5921"\w* \w destruidor|strong="H7703"\w* vino \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*, \w contra|strong="H5921"\w* Babilonia,  
