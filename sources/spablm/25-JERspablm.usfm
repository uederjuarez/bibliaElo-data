\mt2 El libro de  
\mt1 Jeramías  
\c 1
\p
\v 1 \w Palabras|strong="H1697"\w* \w de|strong="H4480"\w* \w Jeremías|strong="H3414"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Hilcías|strong="H2518"\w*, uno \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H4480"\w* estaban \w en|strong="H4480"\w* Anatot, \w en|strong="H4480"\w* la tierra \w de|strong="H4480"\w* \w Benjamín|strong="H1144"\w*.  
\v 2 La \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé\f + \fr 1:2 \ft «Yahvé» es el nombre propio de Dios, a veces traducido como «SEÑOR» (en mayúsculas) en otras versiones.\f* le llegó en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amón, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, en \w el|strong="H1121"\w* \w año|strong="H8141"\w* \w trece|strong="H7969"\w* \w de|strong="H1121"\w* su \w reinado|strong="H4427"\w*.  
\v 3 También le \w llegó|strong="H5704"\w* \w en|strong="H5704"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5704"\w* \w Joacim|strong="H3079"\w* \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w hasta|strong="H5704"\w* \w el|strong="H1121"\w* fin del \w undécimo|strong="H6249"\w* \w año|strong="H8141"\w* \w de|strong="H5704"\w* Sedequías \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w cuando|strong="H3117"\w* Jerusalén \w fue|strong="H1961"\w* llevada cautiva \w en|strong="H5704"\w* \w el|strong="H1121"\w* \w quinto|strong="H2549"\w* \w mes|strong="H2320"\w*.  
\v 4 \w Vino|strong="H1961"\w*, \w pues|strong="H1961"\w*, la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, diciendo:   
\q1
\v 5 «\w Antes|strong="H2962"\w* \w de|strong="H5414"\w* \w que|strong="H3045"\w* te formase \w en|strong="H3318"\w* \w el|strong="H5030"\w* vientre, te \w conocí|strong="H3045"\w*.  
\q2 \w Antes|strong="H2962"\w* \w de|strong="H5414"\w* \w que|strong="H3045"\w* nacieses, te santifiqué.  
\q2 Te he \w puesto|strong="H5414"\w* \w por|strong="H5414"\w* \w profeta|strong="H5030"\w* \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*».   
\p
\v 6 \w Y|strong="H3068"\w* \w yo|strong="H3588"\w* \w dije|strong="H1696"\w*: “¡Ah, Señor\f + \fr 1:6 \ft La palabra traducida como «Señor» es «Adonai».\f* Yahvé! He \w aquí|strong="H2009"\w*\f + \fr 1:6 \ft «He aquí», del hebreo «הִנֵּה», significa mirar, fijarse o contemplar; se utiliza a menudo como interjección.\f* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w sé|strong="H3045"\w* \w hablar|strong="H1696"\w*, \w pues|strong="H3588"\w* soy un \w muchacho|strong="H5288"\w*”.   
\p
\v 7 \w Pero|strong="H3588"\w* Yahvé \w me|strong="H5921"\w* \w dijo|strong="H1696"\w*: “\w No|strong="H3588"\w* \w digas|strong="H1696"\w*: ‘Soy un \w muchacho|strong="H5288"\w*’; \w porque|strong="H3588"\w* \w irás|strong="H3212"\w* \w a|strong="H3068"\w* dondequiera \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H5921"\w* \w envíe|strong="H7971"\w*, \w y|strong="H3588"\w* \w dirás|strong="H1696"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H5921"\w* \w mande|strong="H6680"\w*.  
\v 8 \w No|strong="H3588"\w* \w temas|strong="H3372"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ellos, \w porque|strong="H3588"\w* \w contigo|strong="H6440"\w* estoy \w para|strong="H3588"\w* librarte”, \w dice|strong="H5002"\w* Yahvé.   
\p
\v 9 Entonces Yahvé \w extendió|strong="H7971"\w* su \w mano|strong="H3027"\w* \w y|strong="H5921"\w* \w tocó|strong="H5060"\w* \w mi|strong="H5921"\w* \w boca|strong="H6310"\w*. \w Y|strong="H3068"\w* \w me|strong="H5921"\w* dijo Yahvé: «He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* he \w puesto|strong="H5414"\w* \w mis|strong="H5414"\w* \w palabras|strong="H1697"\w* \w en|strong="H5921"\w* tu \w boca|strong="H6310"\w*.  
\v 10 \w Mira|strong="H7200"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* he puesto \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w* \w sobre|strong="H5921"\w* \w naciones|strong="H1471"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w reinos|strong="H4467"\w*, \w para|strong="H5921"\w* arrancar \w y|strong="H5921"\w* \w para|strong="H5921"\w* derribar, \w para|strong="H5921"\w* destruir \w y|strong="H5921"\w* \w para|strong="H5921"\w* arruinar, \w para|strong="H5921"\w* \w edificar|strong="H1129"\w* \w y|strong="H5921"\w* \w para|strong="H5921"\w* plantar».   
\p
\v 11 La \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, diciendo: «¿\w Qué|strong="H4100"\w* \w ves|strong="H7200"\w* tú, \w Jeremías|strong="H3414"\w*?»  
\p Dije: «\w Veo|strong="H7200"\w* una vara \w de|strong="H1697"\w* almendro».   
\p
\v 12 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* dijo Yahvé: «\w Bien|strong="H3190"\w* has \w visto|strong="H7200"\w*; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w velo|strong="H8245"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w palabra|strong="H1697"\w* \w para|strong="H5921"\w* ponerla \w por|strong="H5921"\w* \w obra|strong="H6213"\w*».   
\p
\v 13 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H6440"\w* Yahvé \w por|strong="H1697"\w* \w segunda|strong="H8145"\w* vez, diciendo: «¿\w Qué|strong="H4100"\w* \w ves|strong="H7200"\w* tú?»  
\p Dije: «\w Veo|strong="H7200"\w* una \w olla|strong="H5518"\w* \w que|strong="H4100"\w* hierve; y su \w faz|strong="H6440"\w* \w está|strong="H1961"\w* \w hacia|strong="H6440"\w* el \w norte|strong="H6828"\w*».   
\p
\v 14 \w Me|strong="H5921"\w* dijo Yahvé: «\w Del|strong="H5921"\w* \w norte|strong="H6828"\w* \w se|strong="H5921"\w* desatará \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
\v 15 \w Porque|strong="H3588"\w* he \w aquí|strong="H2005"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w convoco|strong="H7121"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w familias|strong="H4940"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w del|strong="H5921"\w* \w norte|strong="H6828"\w* — \w dice|strong="H5002"\w* Yahvé —.  
\q1 Vendrán, \w y|strong="H3588"\w* \w pondrá|strong="H5414"\w* \w cada|strong="H3605"\w* uno \w su|strong="H3588"\w* \w trono|strong="H3678"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H8179"\w* \w de|strong="H5921"\w* Jerusalén,  
\q2 \w y|strong="H3588"\w* frente \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w muros|strong="H2346"\w* \w en|strong="H5921"\w* \w derredor|strong="H5439"\w*, \w y|strong="H3588"\w* \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\q1
\v 16 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w toda|strong="H3605"\w* su \w maldad|strong="H7451"\w*, \w proferiré|strong="H1696"\w* mis \w juicios|strong="H4941"\w* \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* abandonaron,  
\q2 \w e|strong="H3068"\w* incensaron \w a|strong="H3068"\w* dioses extraños,  
\q2 \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w obra|strong="H4639"\w* \w de|strong="H5921"\w* sus \w manos|strong="H3027"\w* \w adoraron|strong="H7812"\w*.   
\p
\v 17 Tú, pues, cíñete \w la|strong="H3605"\w* cintura, \w levántate|strong="H6965"\w* y \w diles|strong="H1696"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H6435"\w* te \w mande|strong="H6680"\w*. \w No|strong="H6435"\w* te amedrentes \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H3605"\w*, para \w que|strong="H6435"\w* \w no|strong="H6435"\w* te haga \w yo|strong="H6680"\w* quebrantar \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H3605"\w*.  
\v 18 \w Porque|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w yo|strong="H2009"\w* \w te|strong="H5921"\w* he \w puesto|strong="H5414"\w* \w hoy|strong="H3117"\w* \w como|strong="H5921"\w* \w ciudad|strong="H5892"\w* fortificada, \w como|strong="H5921"\w* \w columna|strong="H5982"\w* \w de|strong="H5921"\w* \w hierro|strong="H1270"\w*, \w y|strong="H5921"\w* \w como|strong="H5921"\w* \w muro|strong="H2346"\w* \w de|strong="H5921"\w* bronce \w contra|strong="H5921"\w* \w toda|strong="H3605"\w* \w esta|strong="H5921"\w* tierra, \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, sus \w príncipes|strong="H8269"\w*, sus \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
\v 19 Pelearán contra ti, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* vencerán; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* estoy contigo — \w dice|strong="H5002"\w* Yahvé — \w para|strong="H3588"\w* librarte».   
\c 2
\p
\v 1 La \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, diciendo:  
\v 2 “\w Ve|strong="H3212"\w* \w y|strong="H3541"\w* proclama \w a|strong="H3068"\w* los oídos de Jerusalén, diciendo: ‘\w Así|strong="H3541"\w* dice Yahvé:  
\q1 «Recuerdo \w en|strong="H3212"\w* favor tuyo la lealtad de tu \w juventud|strong="H5271"\w*,  
\q2 el amor de tu desposorio,  
\q1 cómo \w me|strong="H3541"\w* seguiste \w en|strong="H3212"\w* el \w desierto|strong="H4057"\w*,  
\q2 \w en|strong="H3212"\w* tierra \w no|strong="H3808"\w* \w sembrada|strong="H2232"\w*.   
\q1
\v 3 \w Israel|strong="H3478"\w* era \w santidad|strong="H6944"\w* para Yahvé,  
\q2 las \w primicias|strong="H7225"\w* \w de|strong="H7451"\w* su cosecha.  
\q1 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* \w lo|strong="H3605"\w* devoraban eran culpables;  
\q2 \w el|strong="H3605"\w* \w mal|strong="H7451"\w* venía sobre \w ellos|strong="H3605"\w*», \w dice|strong="H5002"\w* Yahvé’”.   
\p
\v 4 ¡\w Escuchad|strong="H8085"\w* \w la|strong="H3605"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, \w casa|strong="H1004"\w* \w de|strong="H1697"\w* \w Jacob|strong="H3290"\w*, y \w todas|strong="H3605"\w* las \w familias|strong="H4940"\w* \w de|strong="H1697"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*!  
\v 5 \w Así|strong="H3541"\w* dice Yahvé:  
\q1 “¿\w Qué|strong="H3588"\w* injusticia \w hallaron|strong="H4672"\w* vuestros padres \w en|strong="H5921"\w* \w mí|strong="H5921"\w*,  
\q2 \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* alejaran \w de|strong="H5921"\w* \w mí|strong="H5921"\w*,  
\q1 \w y|strong="H3588"\w* \w se|strong="H5921"\w* fueran tras \w la|strong="H5921"\w* \w vanidad|strong="H1892"\w*  
\q2 \w y|strong="H3588"\w* \w se|strong="H5921"\w* hicieran \w ellos|strong="H5921"\w* mismos vanos?   
\q1
\v 6 \w No|strong="H3808"\w* dijeron: ‘¿\w Dónde|strong="H8033"\w* \w está|strong="H3427"\w* Yahvé, \w que|strong="H3808"\w* nos \w hizo|strong="H5927"\w* \w subir|strong="H5927"\w* de la tierra de \w Egipto|strong="H4714"\w*,  
\q2 \w que|strong="H3808"\w* nos condujo por \w el|strong="H5674"\w* \w desierto|strong="H4057"\w*,  
\q2 por tierra de páramos y de fosas,  
\q2 por tierra de sequedal y de sombra de \w muerte|strong="H6757"\w*,  
\q2 por tierra por la cual \w no|strong="H3808"\w* \w pasó|strong="H5674"\w* varón,  
\q2 \w ni|strong="H3808"\w* \w en|strong="H3212"\w* \w ella|strong="H8033"\w* \w habitó|strong="H3427"\w* hombre alguno?’.   
\q1
\v 7 \w Y|strong="H3068"\w* os introduje en tierra de abundancia,  
\q2 para que comieseis sus \w frutos|strong="H6529"\w* y sus bienes;  
\q1 pero entrasteis y contaminasteis mi tierra,  
\q2 \w e|strong="H3068"\w* hicisteis de mi \w heredad|strong="H5159"\w* una \w abominación|strong="H8441"\w*.   
\q1
\v 8 Los \w sacerdotes|strong="H3548"\w* \w no|strong="H3808"\w* dijeron: ‘¿Dónde está Yahvé?’,  
\q2 y los \w que|strong="H3808"\w* manejaban la \w ley|strong="H8451"\w* \w no|strong="H3808"\w* me \w conocieron|strong="H3045"\w*.  
\q1 Los \w pastores|strong="H7462"\w* también \w se|strong="H3045"\w* rebelaron contra mí,  
\q2 y los \w profetas|strong="H5030"\w* \w profetizaron|strong="H5012"\w* por \w Baal|strong="H1168"\w*,  
\q2 y \w anduvieron|strong="H1980"\w* tras \w lo|strong="H3808"\w* \w que|strong="H3808"\w* de \w nada|strong="H3808"\w* \w aprovecha|strong="H3276"\w*.   
\q1
\v 9 «\w Por|strong="H5750"\w* \w tanto|strong="H3651"\w*, \w pleitearé|strong="H7378"\w* \w aún|strong="H5750"\w* con vosotros», \w dice|strong="H5002"\w* Yahvé,  
\q2 “y con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5750"\w* vuestros \w hijos|strong="H1121"\w* \w pleitearé|strong="H7378"\w*.   
\q1
\v 10 \w Pues|strong="H3588"\w* \w pasad|strong="H5674"\w* \w a|strong="H3068"\w* las costas \w de|strong="H3588"\w* Quitim \w y|strong="H3588"\w* \w ved|strong="H7200"\w*;  
\q2 \w enviad|strong="H7971"\w* \w a|strong="H3068"\w* \w Cedar|strong="H6938"\w* \w y|strong="H3588"\w* \w considerad|strong="H7200"\w* \w con|strong="H3588"\w* diligencia,  
\q2 \w y|strong="H3588"\w* \w ved|strong="H7200"\w* \w si|strong="H3588"\w* \w se|strong="H1961"\w* ha \w hecho|strong="H1961"\w* \w cosa|strong="H2063"\w* semejante \w a|strong="H3068"\w* \w esta|strong="H2063"\w*.   
\q1
\v 11 ¿\w Ha|strong="H3808"\w* cambiado alguna \w nación|strong="H1471"\w* \w sus|strong="H1992"\w* dioses,  
\q2 \w aunque|strong="H3808"\w* \w ellos|strong="H1992"\w* \w no|strong="H3808"\w* \w son|strong="H3808"\w* dioses?  
\q2 \w Sin|strong="H3808"\w* embargo, mi \w pueblo|strong="H5971"\w* \w ha|strong="H3808"\w* \w trocado|strong="H4171"\w* \w su|strong="H1992"\w* \w gloria|strong="H3519"\w* por \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w aprovecha|strong="H3276"\w*.   
\q1
\v 12 «\w Espantaos|strong="H8074"\w*, \w cielos|strong="H8064"\w*, \w sobre|strong="H5921"\w* \w esto|strong="H2063"\w*,  
\q2 \w y|strong="H5921"\w* horrorizaos;  
\q2 quedad totalmente desolados», \w dice|strong="H5002"\w* Yahvé.   
\q1
\v 13 “\w Porque|strong="H3588"\w* \w dos|strong="H8147"\w* \w males|strong="H7451"\w* \w ha|strong="H3808"\w* \w hecho|strong="H6213"\w* mi \w pueblo|strong="H5971"\w*:  
\q2 \w me|strong="H3588"\w* abandonaron \w a|strong="H3068"\w* mí, \w fuente|strong="H4726"\w* \w de|strong="H3588"\w* \w agua|strong="H4325"\w* \w viva|strong="H2416"\w*,  
\q2 \w y|strong="H3588"\w* cavaron \w para|strong="H3588"\w* \w sí|strong="H3588"\w* cisternas, cisternas \w rotas|strong="H7665"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* retienen \w el|strong="H3588"\w* \w agua|strong="H4325"\w*.   
\q1
\v 14 ¿\w Es|strong="H1931"\w* \w Israel|strong="H3478"\w* un \w siervo|strong="H5650"\w*?  
\q2 ¿\w Es|strong="H1931"\w* un esclavo de nacimiento?  
\q2 ¿\w Por|strong="H4069"\w* \w qué|strong="H1931"\w*, \w pues|strong="H1931"\w*, ha venido \w a|strong="H3068"\w* ser presa?   
\q1
\v 15 \w Los|strong="H3427"\w* cachorros \w del|strong="H5921"\w* león rugieron \w contra|strong="H5921"\w* \w él|strong="H5921"\w*, alzaron su \w voz|strong="H6963"\w*;  
\q2 asolaron su tierra,  
\q2 \w y|strong="H5921"\w* sus \w ciudades|strong="H5892"\w* han sido \w quemadas|strong="H3341"\w* \w hasta|strong="H5921"\w* quedar \w sin|strong="H1097"\w* \w morador|strong="H3427"\w*.   
\q1
\v 16 Incluso \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Menfis \w y|strong="H1571"\w* \w de|strong="H1121"\w* Tafnes te han quebrantado \w la|strong="H1571"\w* coronilla.   
\q1
\v 17 “¿\w No|strong="H3808"\w* te acarreaste \w esto|strong="H2063"\w* \w a|strong="H3068"\w* ti mismo,  
\q2 \w por|strong="H1870"\w* \w haber|strong="H3808"\w* abandonado \w a|strong="H3068"\w* Yahvé \w tu|strong="H6213"\w* \w Dios|strong="H3068"\w*,\f + \fr 2:17 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f*  
\q2 \w cuando|strong="H6256"\w* \w él|strong="H6213"\w* te conducía \w por|strong="H1870"\w* \w el|strong="H6213"\w* \w camino|strong="H1870"\w*?   
\q1
\v 18 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, ¿\w qué|strong="H4100"\w* tienes tú \w que|strong="H4100"\w* ver con el \w camino|strong="H1870"\w* \w de|strong="H4325"\w* \w Egipto|strong="H4714"\w* \w para|strong="H6258"\w* \w beber|strong="H8354"\w* las \w aguas|strong="H4325"\w* \w del|strong="H8354"\w* Sijor?  
\q2 ¿\w Y|strong="H3068"\w* \w qué|strong="H4100"\w* tienes tú \w que|strong="H4100"\w* ver con el \w camino|strong="H1870"\w* \w de|strong="H4325"\w* Asiria \w para|strong="H6258"\w* \w beber|strong="H8354"\w* las \w aguas|strong="H4325"\w* \w del|strong="H8354"\w* \w Río|strong="H5104"\w*?\f + \fr 2:18 \ft Es decir, el río Éufrates.\f*   
\q1
\v 19 «Tu propia \w maldad|strong="H7451"\w* \w te|strong="H3588"\w* \w castigará|strong="H3256"\w*,  
\q2 \w y|strong="H3588"\w* tus apostasías \w te|strong="H3588"\w* condenarán.  
\q1 \w Sabe|strong="H3045"\w*, \w pues|strong="H3588"\w*, \w y|strong="H3588"\w* \w ve|strong="H7200"\w* \w que|strong="H3588"\w* \w es|strong="H3588"\w* cosa \w mala|strong="H7451"\w* \w y|strong="H3588"\w* \w amarga|strong="H4751"\w*  
\q2 \w el|strong="H3588"\w* \w haber|strong="H3808"\w* abandonado tú \w a|strong="H3068"\w* Yahvé tu \w Dios|strong="H3069"\w*,  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w no|strong="H3808"\w* tener mi temor \w en|strong="H3588"\w* ti», \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w*, Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w*.   
\q1
\v 20 “\w Porque|strong="H3588"\w* hace mucho \w que|strong="H3588"\w* rompí tu \w yugo|strong="H5923"\w*  
\q2 \w y|strong="H3588"\w* rompí tus \w coyundas|strong="H4147"\w*,  
\q1 \w y|strong="H3588"\w* dijiste: ‘\w No|strong="H3808"\w* serviré’.  
\q2 \w Porque|strong="H3588"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w collado|strong="H1389"\w* \w alto|strong="H1364"\w* \w y|strong="H3588"\w* \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w frondoso|strong="H7488"\w*  
\q2 \w te|strong="H5921"\w* echabas tú \w como|strong="H3588"\w* una \w ramera|strong="H2181"\w*.   
\q1
\v 21 Yo te \w planté|strong="H5193"\w* como \w vid|strong="H1612"\w* noble,  
\q2 \w simiente|strong="H2233"\w* verdadera \w toda|strong="H3605"\w* \w ella|strong="H3605"\w*;  
\q2 ¿cómo, pues, te me has vuelto sarmiento degenerado de \w vid|strong="H1612"\w* \w extraña|strong="H5237"\w*?   
\q1
\v 22 \w Aunque|strong="H3588"\w* \w te|strong="H3588"\w* laves \w con|strong="H3588"\w* lejía,  
\q2 \w y|strong="H3588"\w* amontones \w jabón|strong="H1287"\w* sobre ti,  
\q2 \w la|strong="H3588"\w* mancha \w de|strong="H3588"\w* tu \w iniquidad|strong="H5771"\w* está \w delante|strong="H6440"\w* \w de|strong="H3588"\w* mí”, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé.   
\q1
\v 23 “¿\w Cómo|strong="H4100"\w* puedes decir: ‘\w No|strong="H3808"\w* soy \w inmunda|strong="H2930"\w*,  
\q2 \w nunca|strong="H3808"\w* \w anduve|strong="H1980"\w* tras los baales’?  
\q1 \w Mira|strong="H7200"\w* tus pasos en \w el|strong="H6213"\w* \w valle|strong="H1516"\w*,  
\q2 \w reconoce|strong="H3045"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* has \w hecho|strong="H6213"\w*,  
\q1 dromedaria ligera \w que|strong="H4100"\w* cruza sus \w caminos|strong="H1870"\w*;  
\v 24 \w asna|strong="H6501"\w* \w montés|strong="H6501"\w* acostumbrada al \w desierto|strong="H4057"\w*, \w que|strong="H4310"\w* olfatea \w el|strong="H3605"\w* \w viento|strong="H7307"\w* en su ardor.  
\q2 De su celo, ¿\w quién|strong="H4310"\w* \w la|strong="H3605"\w* \w podrá|strong="H3808"\w* retraer?  
\q2 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H4310"\w* \w la|strong="H3605"\w* \w busquen|strong="H1245"\w* \w no|strong="H3808"\w* tendrán \w que|strong="H4310"\w* cansarse; en su \w mes|strong="H2320"\w* \w la|strong="H3605"\w* hallarán.   
\q1
\v 25 “Guarda tus \w pies|strong="H7272"\w* \w de|strong="H3588"\w* \w andar|strong="H3212"\w* descalzos  
\q2 \w y|strong="H3588"\w* tu garganta \w de|strong="H3588"\w* \w la|strong="H3588"\w* sed.  
\q1 \w Pero|strong="H3588"\w* dijiste: ‘\w No|strong="H3808"\w* hay remedio;  
\q2 \w no|strong="H3808"\w*, \w porque|strong="H3588"\w* he amado \w a|strong="H3068"\w* extraños  
\q2 \w y|strong="H3588"\w* tras ellos he \w de|strong="H3588"\w* \w ir|strong="H3212"\w*’.   
\q1
\v 26 \w Como|strong="H3588"\w* \w se|strong="H1992"\w* avergüenza \w el|strong="H3588"\w* \w ladrón|strong="H1590"\w* \w cuando|strong="H3588"\w* \w es|strong="H3588"\w* sorprendido,  
\q2 \w así|strong="H3651"\w* \w se|strong="H1992"\w* avergonzará \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*,  
\q2 \w ellos|strong="H1992"\w*, \w sus|strong="H1992"\w* \w reyes|strong="H4428"\w*, \w sus|strong="H1992"\w* \w príncipes|strong="H8269"\w*, \w sus|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w sus|strong="H1992"\w* \w profetas|strong="H5030"\w*,   
\q1
\v 27 \w que|strong="H3588"\w* dicen \w al|strong="H6256"\w* \w leño|strong="H6086"\w*: ‘Mi padre eres tú’,  
\q2 \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* piedra: ‘Tú \w me|strong="H3588"\w* has engendrado’.  
\q1 \w Porque|strong="H3588"\w* \w me|strong="H3588"\w* han vuelto \w la|strong="H3588"\w* espalda  
\q2 \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w el|strong="H3588"\w* \w rostro|strong="H6440"\w*;  
\q2 \w pero|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w tiempo|strong="H6256"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* calamidad dicen: ‘¡\w Levántate|strong="H6965"\w* \w y|strong="H3588"\w* \w sálvanos|strong="H3467"\w*!’.   
\q1
\v 28 “¿\w Y|strong="H3068"\w* dónde \w están|strong="H1961"\w* tus dioses \w que|strong="H3588"\w* \w para|strong="H3588"\w* ti \w hiciste|strong="H6213"\w*?  
\q2 ¡\w Que|strong="H3588"\w* \w se|strong="H1961"\w* levanten ellos, \w a|strong="H3068"\w* ver \w si|strong="H3588"\w* pueden salvarte \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w tiempo|strong="H6256"\w* \w de|strong="H3588"\w* \w tu|strong="H6213"\w* aflicción!  
\q2 \w Porque|strong="H3588"\w* según \w el|strong="H3588"\w* \w número|strong="H4557"\w* \w de|strong="H3588"\w* tus \w ciudades|strong="H5892"\w* \w son|strong="H1961"\w* tus dioses, oh \w Judá|strong="H3063"\w*.   
\q1
\v 29 «¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* altercáis conmigo?  
\q2 \w Todos|strong="H3605"\w* vosotros os habéis rebelado contra mí», \w dice|strong="H5002"\w* Yahvé.   
\q1
\v 30 “\w En|strong="H5221"\w* vano he azotado \w a|strong="H3068"\w* vuestros \w hijos|strong="H1121"\w*;  
\q2 \w no|strong="H3808"\w* han recibido \w corrección|strong="H4148"\w*.  
\q1 Vuestra propia \w espada|strong="H2719"\w* devoró \w a|strong="H3068"\w* vuestros \w profetas|strong="H5030"\w*  
\q2 como león \w destrozador|strong="H7843"\w*.   
\q1
\v 31 ¡Oh \w generación|strong="H1755"\w*!, atended vosotros \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w de|strong="H5750"\w* Yahvé.  
\q2 ¿He \w sido|strong="H1961"\w* yo un \w desierto|strong="H4057"\w* \w para|strong="H1961"\w* \w Israel|strong="H3478"\w*,  
\q2 \w o|strong="H3068"\w* tierra \w de|strong="H5750"\w* tinieblas?  
\q1 ¿\w Por|strong="H4069"\w* \w qué|strong="H3808"\w* \w dice|strong="H1697"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*: ‘\w Somos|strong="H1961"\w* libres,  
\q2 \w no|strong="H3808"\w* vendremos \w más|strong="H5750"\w* \w a|strong="H3068"\w* ti’?   
\q1
\v 32 “¿\w Se|strong="H5971"\w* olvida la \w virgen|strong="H1330"\w* \w de|strong="H5971"\w* sus atavíos,  
\q2 \w o|strong="H3068"\w* la desposada \w de|strong="H5971"\w* su gala?  
\q2 Pero mi \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* ha olvidado \w de|strong="H5971"\w* mí por \w días|strong="H3117"\w* innumerables.   
\q1
\v 33 ¡\w Qué|strong="H4100"\w* \w bien|strong="H3190"\w* \w preparas|strong="H3651"\w* tu \w camino|strong="H1870"\w* para buscar amor!  
\q2 \w Así|strong="H3651"\w*, \w aun|strong="H1571"\w* \w a|strong="H3068"\w* las malvadas \w enseñaste|strong="H3925"\w* tus \w caminos|strong="H1870"\w*.   
\q1
\v 34 \w Aun|strong="H1571"\w* \w en|strong="H5921"\w* tus faldas \w se|strong="H5921"\w* \w halló|strong="H4672"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w almas|strong="H5315"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* pobres inocentes.  
\q2 \w No|strong="H3808"\w* \w los|strong="H5921"\w* \w hallaste|strong="H4672"\w* \w en|strong="H5921"\w* pleno robo,  
\q2 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* estas cosas.   
\q1
\v 35 “\w Y|strong="H3068"\w* todavía dices: ‘Soy inocente,  
\q2 \w de|strong="H4480"\w* \w cierto|strong="H3588"\w* \w su|strong="H3588"\w* ira \w se|strong="H3808"\w* apartó \w de|strong="H4480"\w* \w mí|strong="H5921"\w*’.  
\q1 He \w aquí|strong="H2005"\w*, \w yo|strong="H4480"\w* entraré \w en|strong="H5921"\w* juicio \w contigo|strong="H5921"\w*,  
\q2 \w porque|strong="H3588"\w* dijiste: ‘\w No|strong="H3808"\w* he \w pecado|strong="H2398"\w*’.   
\q1
\v 36 ¿\w Por|strong="H1870"\w* \w qué|strong="H4100"\w* te apresuras \w tanto|strong="H3966"\w* para cambiar tus \w caminos|strong="H1870"\w*?  
\q2 \w También|strong="H1571"\w* \w de|strong="H8138"\w* \w Egipto|strong="H4714"\w* serás avergonzada,  
\q2 \w como|strong="H4100"\w* fuiste avergonzada \w de|strong="H8138"\w* Asiria.   
\q1
\v 37 \w También|strong="H1571"\w* \w de|strong="H5921"\w* allí \w saldrás|strong="H3318"\w* \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w sobre|strong="H5921"\w* tu \w cabeza|strong="H7218"\w*,  
\q2 \w porque|strong="H3588"\w* Yahvé rechazó \w a|strong="H3068"\w* aquellos \w en|strong="H5921"\w* quienes confías,  
\q2 \w y|strong="H1571"\w* \w no|strong="H3808"\w* prosperarás \w con|strong="H5921"\w* \w ellos|strong="H3027"\w*”.   
\c 3
\p
\v 1 “Dicen: «\w Si|strong="H2005"\w* un hombre abandona \w a|strong="H3068"\w* \w su|strong="H1931"\w* mujer, y \w ella|strong="H1931"\w* \w se|strong="H1961"\w* aleja \w de|strong="H5750"\w* \w él|strong="H1931"\w* y pasa \w a|strong="H3068"\w* ser \w de|strong="H5750"\w* \w otro|strong="H5750"\w* hombre, ¿\w volverá|strong="H7725"\w* \w él|strong="H1931"\w* \w a|strong="H3068"\w* \w ella|strong="H1931"\w*? ¿\w No|strong="H3808"\w* estaría \w esa|strong="H1931"\w* tierra totalmente contaminada? \w Pues|strong="H1931"\w* tú has \w fornicado|strong="H2181"\w* con \w muchos|strong="H7227"\w* amantes; ¡pero \w vuelve|strong="H7725"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w*!», \w dice|strong="H5002"\w* Yahvé.   
\p
\v 2 “¡\w Levanta|strong="H5375"\w* tus \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* alturas yermas \w y|strong="H5921"\w* \w mira|strong="H7200"\w*! ¿\w Dónde|strong="H5921"\w* \w no|strong="H3808"\w* \w te|strong="H5869"\w* has entregado? \w Te|strong="H5869"\w* sentabas \w a|strong="H3068"\w* esperarlos \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w camino|strong="H1870"\w*, \w como|strong="H5921"\w* un árabe \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*. Has contaminado \w la|strong="H5921"\w* tierra \w con|strong="H5921"\w* tu ramería \w y|strong="H5921"\w* \w con|strong="H5921"\w* tu \w maldad|strong="H7451"\w*.  
\v 3 Por eso las \w lluvias|strong="H7241"\w* han \w sido|strong="H1961"\w* retenidas y \w no|strong="H3808"\w* \w ha|strong="H3808"\w* habido lluvia \w tardía|strong="H4456"\w*; \w sin|strong="H3808"\w* embargo, has tenido \w frente|strong="H4696"\w* de \w ramera|strong="H2181"\w* y \w no|strong="H3808"\w* quisiste avergonzarte.  
\v 4 ¿\w No|strong="H3808"\w* me gritarás desde \w ahora|strong="H6258"\w*: ‘Padre mío, tú eres el guía de mi \w juventud|strong="H5271"\w*’?   
\p
\v 5 “‘¿\w Guardará|strong="H8104"\w* su ira para \w siempre|strong="H5769"\w*? ¿\w La|strong="H8104"\w* mantendrá hasta \w el|strong="H6213"\w* fin?’. He \w aquí|strong="H2009"\w* que has \w hablado|strong="H1696"\w* y has \w hecho|strong="H6213"\w* \w cosas|strong="H7451"\w* \w malas|strong="H7451"\w*, y te has salido con \w la|strong="H8104"\w* tuya”.   
\p
\v 6 \w Además|strong="H5921"\w*, Yahvé \w me|strong="H5921"\w* dijo \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w Josías|strong="H2977"\w*: “¿Has \w visto|strong="H7200"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* ha \w hecho|strong="H6213"\w* \w la|strong="H1931"\w* rebelde \w Israel|strong="H3478"\w*? \w Se|strong="H1931"\w* ha subido \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w monte|strong="H2022"\w* \w alto|strong="H1364"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w frondoso|strong="H7488"\w*, \w y|strong="H5921"\w* \w allí|strong="H8033"\w* ha \w fornicado|strong="H2181"\w*.  
\v 7 Después de \w haber|strong="H3808"\w* \w hecho|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H6213"\w* cosas, dije: ‘\w Volverá|strong="H7725"\w* \w a|strong="H3068"\w* mí’; pero \w no|strong="H3808"\w* \w volvió|strong="H7725"\w*, y su hermana traidora, \w Judá|strong="H3063"\w*, \w lo|strong="H3808"\w* \w vio|strong="H7200"\w*.  
\v 8 \w Vi|strong="H7200"\w* \w que|strong="H3588"\w*, \w por|strong="H5921"\w* \w esta|strong="H1931"\w* \w misma|strong="H1931"\w* causa, \w la|strong="H1931"\w* rebelde \w Israel|strong="H3478"\w* \w había|strong="H3588"\w* cometido adulterio, \w y|strong="H1571"\w* \w yo|strong="H3588"\w* \w la|strong="H1931"\w* \w había|strong="H3588"\w* repudiado \w dándole|strong="H5414"\w* \w carta|strong="H5612"\w* \w de|strong="H5921"\w* divorcio; \w pero|strong="H3588"\w* \w la|strong="H1931"\w* traicionera \w Judá|strong="H3063"\w*, \w su|strong="H1931"\w* hermana, \w no|strong="H3808"\w* \w tuvo|strong="H3372"\w* \w temor|strong="H3372"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w también|strong="H1571"\w* \w fue|strong="H3212"\w* \w y|strong="H1571"\w* \w se|strong="H1931"\w* \w hizo|strong="H5414"\w* \w ramera|strong="H2181"\w*.  
\v 9 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1961"\w* por la ligereza de su ramería, la tierra \w fue|strong="H1961"\w* contaminada, y ella cometió adulterio con la piedra y con el \w leño|strong="H6086"\w*.  
\v 10 \w Pero|strong="H3588"\w* \w con|strong="H3588"\w* \w todo|strong="H3605"\w* \w esto|strong="H2063"\w*, \w su|strong="H3588"\w* hermana traidora, \w Judá|strong="H3063"\w*, \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* \w vuelto|strong="H7725"\w* \w a|strong="H3068"\w* mí \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w corazón|strong="H3820"\w*, \w sino|strong="H3588"\w* sólo \w en|strong="H3588"\w* apariencia”, \w dice|strong="H5002"\w* Yahvé.   
\p
\v 11 \w Y|strong="H3068"\w* me dijo Yahvé: “La infiel \w Israel|strong="H3478"\w* se ha mostrado más justa que la traicionera \w Judá|strong="H3063"\w*.  
\v 12 \w Ve|strong="H1980"\w* \w y|strong="H3588"\w* proclama estas \w palabras|strong="H1697"\w* \w hacia|strong="H6440"\w* \w el|strong="H3588"\w* \w norte|strong="H6828"\w*, \w y|strong="H3588"\w* di: ‘\w Vuelve|strong="H7725"\w*, oh \w rebelde|strong="H7725"\w* \w Israel|strong="H3478"\w*’, \w dice|strong="H5002"\w* Yahvé; ‘\w no|strong="H3808"\w* haré \w caer|strong="H5307"\w* mi \w ira|strong="H1980"\w* sobre vosotros, \w porque|strong="H3588"\w* soy \w misericordioso|strong="H2623"\w*’, \w dice|strong="H5002"\w* Yahvé. ‘\w No|strong="H3808"\w* \w guardaré|strong="H5201"\w* \w el|strong="H3588"\w* enojo \w para|strong="H3588"\w* \w siempre|strong="H5769"\w*.  
\v 13 Solo \w reconoce|strong="H3045"\w* tu \w iniquidad|strong="H5771"\w*, \w que|strong="H3588"\w* contra Yahvé tu \w Dios|strong="H3068"\w* \w te|strong="H3588"\w* has rebelado, \w y|strong="H3588"\w* tus \w caminos|strong="H1870"\w* has repartido \w a|strong="H3068"\w* \w los|strong="H3605"\w* extraños \w debajo|strong="H8478"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w frondoso|strong="H7488"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* habéis obedecido mi \w voz|strong="H6963"\w*’”, \w dice|strong="H5002"\w* Yahvé.  
\v 14 “\w Volved|strong="H7725"\w*, \w hijos|strong="H1121"\w* descarriados — \w dice|strong="H5002"\w* Yahvé —, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* soy vuestro \w señor|strong="H3068"\w*. Os \w tomaré|strong="H3947"\w*, uno \w de|strong="H3588"\w* una \w ciudad|strong="H5892"\w* \w y|strong="H3588"\w* \w dos|strong="H8147"\w* \w de|strong="H3588"\w* una \w familia|strong="H4940"\w*, \w y|strong="H3588"\w* os introduciré \w en|strong="H3588"\w* \w Sión|strong="H6726"\w*.  
\v 15 \w Y|strong="H3068"\w* os \w daré|strong="H5414"\w* \w pastores|strong="H7462"\w* según mi \w corazón|strong="H3820"\w*, que os apacienten con \w ciencia|strong="H1844"\w* y con \w inteligencia|strong="H7919"\w*.  
\v 16 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w os|strong="H5921"\w* \w multipliquéis|strong="H7235"\w* \w y|strong="H3588"\w* crezcáis \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w en|strong="H5921"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* — \w dice|strong="H5002"\w* Yahvé —, \w no|strong="H3808"\w* \w se|strong="H1961"\w* dirá \w más|strong="H5750"\w*: ‘¡\w El|strong="H5921"\w* arca \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w alianza|strong="H1285"\w* \w de|strong="H5921"\w* Yahvé!’. \w No|strong="H3808"\w* \w vendrá|strong="H1961"\w* \w al|strong="H5921"\w* \w pensamiento|strong="H3820"\w*, \w ni|strong="H3808"\w* \w se|strong="H1961"\w* acordarán \w de|strong="H5921"\w* \w ella|strong="H5921"\w*, \w ni|strong="H3808"\w* \w la|strong="H5921"\w* echarán \w de|strong="H5921"\w* \w menos|strong="H3588"\w*, \w ni|strong="H3808"\w* \w se|strong="H1961"\w* \w hará|strong="H6213"\w* \w otra|strong="H5750"\w*.  
\v 17 \w En|strong="H5750"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w llamarán|strong="H7121"\w* \w a|strong="H3068"\w* Jerusalén ‘\w Trono|strong="H3678"\w* \w de|strong="H5750"\w* Yahvé’; y \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w se|strong="H1931"\w* reunirán \w en|strong="H5750"\w* \w ella|strong="H1931"\w*, \w al|strong="H6256"\w* \w nombre|strong="H8034"\w* \w de|strong="H5750"\w* Yahvé \w en|strong="H5750"\w* Jerusalén; y \w no|strong="H3808"\w* \w andarán|strong="H3212"\w* \w más|strong="H5750"\w* tras \w la|strong="H1931"\w* dureza \w de|strong="H5750"\w* \w su|strong="H1931"\w* \w malvado|strong="H7451"\w* \w corazón|strong="H3820"\w*.  
\v 18 \w En|strong="H5921"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* caminará \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* vendrán \w juntamente|strong="H3162"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w del|strong="H5921"\w* \w norte|strong="H6828"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* di \w en|strong="H5921"\w* heredad \w a|strong="H3068"\w* vuestros padres.   
\p
\v 19 “Yo dije: ‘¡Cómo os pondría \w entre|strong="H3808"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* y os \w daría|strong="H5414"\w* la tierra \w deseable|strong="H2532"\w*, la rica \w heredad|strong="H5159"\w* \w de|strong="H1121"\w* las \w naciones|strong="H1471"\w*!’.   
\p
\v 20 «Pero \w como|strong="H3651"\w* la mujer traiciona \w a|strong="H3068"\w* su \w compañero|strong="H7453"\w*, \w así|strong="H3651"\w* me habéis traicionado vosotros, \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*», \w dice|strong="H5002"\w* Yahvé.  
\v 21 \w Voz|strong="H6963"\w* fue oída \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* alturas yermas, \w llanto|strong="H1065"\w* \w y|strong="H3588"\w* \w ruegos|strong="H8469"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*; \w porque|strong="H3588"\w* han torcido \w su|strong="H3588"\w* \w camino|strong="H1870"\w*, \w se|strong="H5921"\w* han olvidado \w de|strong="H5921"\w* Yahvé \w su|strong="H3588"\w* \w Dios|strong="H3068"\w*.  
\v 22 «\w Volved|strong="H7725"\w*, \w hijos|strong="H1121"\w* descarriados, \w y|strong="H3588"\w* \w sanaré|strong="H7495"\w* vuestra rebelión».  
\p «He \w aquí|strong="H2005"\w* \w que|strong="H3588"\w* venimos \w a|strong="H3068"\w* ti, \w porque|strong="H3588"\w* tú eres Yahvé nuestro \w Dios|strong="H3068"\w*.  
\v 23 Ciertamente vana es la esperanza en los \w collados|strong="H1389"\w* y el bullicio de los \w montes|strong="H2022"\w*; ciertamente en Yahvé nuestro \w Dios|strong="H3068"\w* está la salvación de \w Israel|strong="H3478"\w*.  
\v 24 Lo \w vergonzoso|strong="H1322"\w* devoró \w el|strong="H1121"\w* \w trabajo|strong="H3018"\w* \w de|strong="H1121"\w* nuestros padres desde nuestra \w juventud|strong="H5271"\w*: sus \w ovejas|strong="H6629"\w*, sus \w vacas|strong="H1241"\w*, sus \w hijos|strong="H1121"\w* \w y|strong="H1241"\w* sus \w hijas|strong="H1323"\w*.  
\v 25 Yaceremos \w en|strong="H5704"\w* nuestra \w vergüenza|strong="H3639"\w*, \w y|strong="H3588"\w* nuestra \w confusión|strong="H3639"\w* nos \w cubrirá|strong="H3680"\w*; \w porque|strong="H3588"\w* \w pecamos|strong="H2398"\w* contra Yahvé nuestro \w Dios|strong="H3068"\w*, nosotros \w y|strong="H3588"\w* nuestros padres, \w desde|strong="H5704"\w* nuestra \w juventud|strong="H5271"\w* \w hasta|strong="H5704"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* hemos obedecido \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w*».   
\c 4
\p
\v 1 “\w Si|strong="H3808"\w* te \w volvieres|strong="H7725"\w*, oh \w Israel|strong="H3478"\w* — \w dice|strong="H5002"\w* Yahvé —, \w si|strong="H3808"\w* te \w volvieres|strong="H7725"\w* \w a|strong="H3068"\w* mí y \w quitares|strong="H5493"\w* tus \w abominaciones|strong="H8251"\w* \w de|strong="H6440"\w* mi \w presencia|strong="H6440"\w*, \w no|strong="H3808"\w* serás removido.  
\v 2 \w Y|strong="H3068"\w* \w jurarás|strong="H7650"\w*: ‘\w Vive|strong="H2416"\w* Yahvé’, en verdad, en \w juicio|strong="H4941"\w* y en \w justicia|strong="H6666"\w*; y las \w naciones|strong="H1471"\w* se bendecirán en él, y en él se gloriarán”.   
\p
\v 3 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w varones|strong="H3588"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* Jerusalén: “Romped vuestro \w barbecho|strong="H5214"\w* \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w sembréis|strong="H2232"\w* \w entre|strong="H3588"\w* \w espinos|strong="H6975"\w*.  
\v 4 \w Circuncidaos|strong="H4135"\w* \w a|strong="H3068"\w* Yahvé, \w y|strong="H1197"\w* \w quitad|strong="H5493"\w* \w el|strong="H3427"\w* \w prepucio|strong="H6190"\w* \w de|strong="H6440"\w* vuestro \w corazón|strong="H3824"\w*, varones \w de|strong="H6440"\w* \w Judá|strong="H3063"\w* \w y|strong="H1197"\w* \w moradores|strong="H3427"\w* \w de|strong="H6440"\w* Jerusalén; \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* \w mi|strong="H3389"\w* \w ira|strong="H2534"\w* \w salga|strong="H3318"\w* como fuego, \w y|strong="H1197"\w* \w se|strong="H6435"\w* encienda \w de|strong="H6440"\w* modo \w que|strong="H6435"\w* \w no|strong="H6435"\w* haya quien \w la|strong="H1197"\w* apague, \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w la|strong="H1197"\w* \w maldad|strong="H7455"\w* \w de|strong="H6440"\w* vuestras \w obras|strong="H4611"\w*.  
\v 5 \w Proclamad|strong="H7121"\w* en \w Judá|strong="H3063"\w* y \w haced|strong="H8085"\w* que se \w oiga|strong="H8085"\w* en Jerusalén, y decid: ‘¡\w Tocad|strong="H8628"\w* la \w trompeta|strong="H7782"\w* en la tierra!’. Clamad en alta voz y decid: ‘¡Reuníos! Entremos en las \w ciudades|strong="H5892"\w* fortificadas’.  
\v 6 \w Alzad|strong="H5375"\w* estandarte hacia \w Sión|strong="H6726"\w*; haced \w que|strong="H3588"\w* se pongan \w a|strong="H3068"\w* salvo \w y|strong="H3588"\w* \w no|strong="H3588"\w* os detengáis; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* hago venir del \w norte|strong="H6828"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w* \w y|strong="H3588"\w* una \w gran|strong="H1419"\w* destrucción”.   
\p
\v 7 \w El|strong="H3427"\w* león ha \w subido|strong="H5927"\w* de su espesura, y \w el|strong="H3427"\w* \w destruidor|strong="H7843"\w* de \w naciones|strong="H1471"\w* \w está|strong="H3427"\w* \w en|strong="H3318"\w* marcha; ha \w salido|strong="H3318"\w* de su \w lugar|strong="H4725"\w* para dejar tu tierra desolada; tus \w ciudades|strong="H5892"\w* serán \w asoladas|strong="H8047"\w* hasta quedar sin \w morador|strong="H3427"\w*.  
\v 8 \w Por|strong="H5921"\w* \w esto|strong="H2063"\w*, \w vestíos|strong="H2296"\w* \w de|strong="H4480"\w* cilicio, lamentad \w y|strong="H3588"\w* \w aullad|strong="H3213"\w*; \w porque|strong="H3588"\w* \w el|strong="H5921"\w* ardor \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w ira|strong="H2740"\w* \w de|strong="H4480"\w* Yahvé \w no|strong="H3808"\w* \w se|strong="H5921"\w* \w ha|strong="H3808"\w* apartado \w de|strong="H4480"\w* \w nosotros|strong="H5921"\w*.  
\v 9 «\w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* — \w dice|strong="H5002"\w* Yahvé — \w que|strong="H1931"\w* desfallecerá \w el|strong="H1931"\w* \w corazón|strong="H3820"\w* del \w rey|strong="H4428"\w* y \w el|strong="H1931"\w* \w corazón|strong="H3820"\w* \w de|strong="H8269"\w* \w los|strong="H1931"\w* \w príncipes|strong="H8269"\w*; \w los|strong="H1931"\w* \w sacerdotes|strong="H3548"\w* \w estarán|strong="H1961"\w* \w atónitos|strong="H8539"\w* y \w se|strong="H1961"\w* maravillarán \w los|strong="H1931"\w* \w profetas|strong="H5030"\w*».   
\p
\v 10 Entonces dije: “¡Ah, Señor Yahvé! Verdaderamente has engañado \w en|strong="H5704"\w* gran manera \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* Jerusalén, diciendo: ‘\w Paz|strong="H7965"\w* \w tendréis|strong="H1961"\w*’, \w cuando|strong="H5704"\w* la \w espada|strong="H2719"\w* ha \w llegado|strong="H5060"\w* \w hasta|strong="H5704"\w* el \w alma|strong="H5315"\w*”.   
\p
\v 11 En \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w se|strong="H1931"\w* dirá \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* y \w a|strong="H3068"\w* Jerusalén: «\w Viento|strong="H7307"\w* solano \w de|strong="H5971"\w* las alturas yermas del \w desierto|strong="H4057"\w* viene \w hacia|strong="H1870"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H5971"\w* \w mi|strong="H3389"\w* \w pueblo|strong="H5971"\w*, \w no|strong="H3808"\w* \w para|strong="H5971"\w* aventar \w ni|strong="H3808"\w* \w para|strong="H5971"\w* limpiar.  
\v 12 Un \w viento|strong="H7307"\w* \w más|strong="H1571"\w* impetuoso \w que|strong="H6258"\w* este vendrá \w a|strong="H3068"\w* mi servicio. \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* yo \w también|strong="H1571"\w* pronunciaré mis \w juicios|strong="H4941"\w* contra \w ellos|strong="H1571"\w*».   
\p
\v 13 He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w subirá|strong="H5927"\w* \w como|strong="H3588"\w* \w nube|strong="H6051"\w*, \w y|strong="H3588"\w* sus \w carros|strong="H4818"\w* serán \w como|strong="H3588"\w* \w torbellino|strong="H5492"\w*; \w más|strong="H3588"\w* ligeros \w son|strong="H3588"\w* sus \w caballos|strong="H5483"\w* \w que|strong="H3588"\w* las águilas. ¡Ay \w de|strong="H3588"\w* nosotros, \w porque|strong="H3588"\w* estamos arruinados!  
\v 14 \w Lava|strong="H3526"\w* tu \w corazón|strong="H3820"\w* \w de|strong="H5704"\w* la \w maldad|strong="H7451"\w*, oh Jerusalén, \w para|strong="H5704"\w* \w que|strong="H5704"\w* seas \w salva|strong="H3467"\w*. ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* permitirás \w en|strong="H5704"\w* \w medio|strong="H7130"\w* \w de|strong="H5704"\w* ti tus \w malos|strong="H7451"\w* \w pensamientos|strong="H4284"\w*?  
\v 15 \w Porque|strong="H3588"\w* una \w voz|strong="H6963"\w* anuncia desde \w Dan|strong="H1835"\w* \w y|strong="H3588"\w* publica \w el|strong="H3588"\w* mal desde \w los|strong="H3588"\w* \w montes|strong="H2022"\w* \w de|strong="H3588"\w* Efraín.  
\v 16 “\w Decid|strong="H2142"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*: ‘He \w aquí|strong="H2009"\w*’; \w haced|strong="H8085"\w* \w oír|strong="H8085"\w* \w contra|strong="H5921"\w* Jerusalén: ‘Vienen sitiadores \w de|strong="H5921"\w* tierra \w lejana|strong="H4801"\w*, \w y|strong="H5921"\w* \w darán|strong="H5414"\w* su \w voz|strong="H6963"\w* \w contra|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*’.  
\v 17 \w Como|strong="H3588"\w* \w guardas|strong="H8104"\w* \w de|strong="H5921"\w* \w campo|strong="H7704"\w* \w están|strong="H1961"\w* \w en|strong="H5921"\w* \w derredor|strong="H5439"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*, \w porque|strong="H3588"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w se|strong="H1961"\w* rebeló”, \w dice|strong="H5002"\w* Yahvé.  
\v 18 «\w Tu|strong="H6213"\w* \w camino|strong="H1870"\w* \w y|strong="H3588"\w* tus \w obras|strong="H4611"\w* \w te|strong="H3588"\w* acarrearon \w esto|strong="H2063"\w*; \w esta|strong="H2063"\w* \w es|strong="H3588"\w* \w tu|strong="H6213"\w* \w maldad|strong="H7451"\w*, \w por|strong="H3588"\w* \w lo|strong="H6213"\w* \w cual|strong="H3588"\w* \w es|strong="H3588"\w* \w amarga|strong="H4751"\w*, \w pues|strong="H3588"\w* llega \w hasta|strong="H5704"\w* \w tu|strong="H6213"\w* \w corazón|strong="H3820"\w*».   
\p
\v 19 ¡Mis \w entrañas|strong="H4578"\w*, mis \w entrañas|strong="H4578"\w*! ¡\w Me|strong="H3588"\w* duelen las fibras \w de|strong="H3588"\w* \w mi|strong="H5315"\w* \w corazón|strong="H3820"\w*! \w Mi|strong="H5315"\w* \w corazón|strong="H3820"\w* \w se|strong="H3808"\w* conmueve dentro \w de|strong="H3588"\w* \w mí|strong="H5315"\w*; \w no|strong="H3808"\w* \w callaré|strong="H2790"\w*, \w porque|strong="H3588"\w* \w sonido|strong="H6963"\w* \w de|strong="H3588"\w* \w trompeta|strong="H7782"\w* has \w oído|strong="H8085"\w*, \w alma|strong="H5315"\w* mía, \w pregón|strong="H6963"\w* \w de|strong="H3588"\w* \w guerra|strong="H4421"\w*.  
\v 20 \w Quebrantamiento|strong="H7667"\w* \w sobre|strong="H5921"\w* \w quebrantamiento|strong="H7667"\w* \w es|strong="H3588"\w* anunciado; \w porque|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w es|strong="H3588"\w* devastada. \w De|strong="H5921"\w* repente \w son|strong="H3588"\w* destruidas mis tiendas, \w en|strong="H5921"\w* un \w momento|strong="H7281"\w* mis \w cortinas|strong="H3407"\w*.  
\v 21 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* he \w de|strong="H5704"\w* \w ver|strong="H7200"\w* el estandarte \w y|strong="H5704"\w* \w oír|strong="H8085"\w* el \w sonido|strong="H6963"\w* \w de|strong="H5704"\w* la \w trompeta|strong="H7782"\w*?   
\p
\v 22 «\w Porque|strong="H3588"\w* mi \w pueblo|strong="H5971"\w* \w es|strong="H3588"\w* \w necio|strong="H5530"\w*, \w no|strong="H3808"\w* \w me|strong="H3588"\w* \w conocieron|strong="H3045"\w*; \w son|strong="H3588"\w* \w hijos|strong="H1121"\w* insensatos \w y|strong="H3588"\w* carecen \w de|strong="H3588"\w* entendimiento; \w sabios|strong="H2450"\w* \w son|strong="H3588"\w* \w para|strong="H3588"\w* hacer \w el|strong="H3588"\w* \w mal|strong="H7489"\w*, \w pero|strong="H3588"\w* \w para|strong="H3588"\w* hacer \w el|strong="H3588"\w* \w bien|strong="H3190"\w* \w no|strong="H3808"\w* \w tienen|strong="H1992"\w* \w conocimiento|strong="H3045"\w*».  
\v 23 \w Miré|strong="H7200"\w* la tierra, y he \w aquí|strong="H2009"\w* que \w estaba|strong="H2009"\w* asolada y vacía; y \w a|strong="H3068"\w* los \w cielos|strong="H8064"\w*, y no había en ellos luz.  
\v 24 \w Miré|strong="H7200"\w* \w los|strong="H3605"\w* \w montes|strong="H2022"\w*, y he \w aquí|strong="H2009"\w* \w que|strong="H3605"\w* temblaban, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w collados|strong="H1389"\w* fueron conmovidos.  
\v 25 \w Miré|strong="H7200"\w*, y no había hombre, y \w todas|strong="H3605"\w* las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w* se habían ido.  
\v 26 \w Miré|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* \w que|strong="H3605"\w* \w el|strong="H3605"\w* campo fértil era un \w desierto|strong="H4057"\w*, y \w todas|strong="H3605"\w* sus \w ciudades|strong="H5892"\w* eran asoladas \w ante|strong="H6440"\w* \w la|strong="H3605"\w* \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, \w ante|strong="H6440"\w* \w el|strong="H3605"\w* ardor \w de|strong="H6440"\w* su \w ira|strong="H2740"\w*.  
\v 27 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dijo Yahvé: «\w Toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w será|strong="H1961"\w* \w asolada|strong="H8077"\w*; \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w haré|strong="H6213"\w* \w de|strong="H3588"\w* \w ella|strong="H3605"\w* una destrucción completa.  
\v 28 \w Por|strong="H5921"\w* \w esto|strong="H2063"\w* \w se|strong="H5921"\w* luterá \w la|strong="H5921"\w* tierra, \w y|strong="H3588"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w* \w arriba|strong="H4605"\w* \w se|strong="H5921"\w* oscurecerán, \w porque|strong="H3588"\w* \w yo|strong="H4480"\w* \w hablé|strong="H1696"\w*, \w lo|strong="H3808"\w* \w pensé|strong="H2161"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H4480"\w* arrepentí \w ni|strong="H3808"\w* desistiré \w de|strong="H4480"\w* \w ello|strong="H2063"\w*».   
\p
\v 29 Al \w estruendo|strong="H6963"\w* de \w la|strong="H3605"\w* gente de \w a|strong="H3068"\w* caballo y de \w los|strong="H3427"\w* \w flecheros|strong="H7198"\w* \w huyó|strong="H1272"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w*; se metieron en las espesuras y \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* peñascos. \w Todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w fueron|strong="H5927"\w* abandonadas y no \w quedó|strong="H3427"\w* en ellas hombre \w alguno|strong="H3605"\w*.  
\v 30 \w Y|strong="H3068"\w* \w tú|strong="H6213"\w*, \w destruida|strong="H7703"\w*, ¿\w qué|strong="H3588"\w* \w harás|strong="H6213"\w*? \w Aunque|strong="H3588"\w* \w te|strong="H5869"\w* vistas \w de|strong="H3588"\w* grana, \w aunque|strong="H3588"\w* \w te|strong="H5869"\w* adornes \w con|strong="H3588"\w* atavíos \w de|strong="H3588"\w* \w oro|strong="H2091"\w*, \w aunque|strong="H3588"\w* \w pintes|strong="H7167"\w* \w con|strong="H3588"\w* antimonio tus \w ojos|strong="H5869"\w*, \w en|strong="H3588"\w* vano \w te|strong="H5869"\w* engalanas; \w te|strong="H5869"\w* menosprecian tus amantes, \w buscan|strong="H1245"\w* \w tu|strong="H6213"\w* \w vida|strong="H5315"\w*.  
\v 31 \w Porque|strong="H3588"\w* \w oí|strong="H8085"\w* una \w voz|strong="H6963"\w* \w como|strong="H3588"\w* \w de|strong="H3588"\w* mujer \w que|strong="H3588"\w* está \w de|strong="H3588"\w* parto, \w angustia|strong="H6869"\w* \w como|strong="H3588"\w* \w de|strong="H3588"\w* primeriza; \w voz|strong="H6963"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* \w Sión|strong="H6726"\w* \w que|strong="H3588"\w* jadea \w y|strong="H3588"\w* \w extiende|strong="H6566"\w* sus \w manos|strong="H3709"\w*, diciendo: «¡Ay \w de|strong="H3588"\w* \w mí|strong="H4994"\w* \w ahora|strong="H4994"\w*! \w que|strong="H3588"\w* \w mi|strong="H4994"\w* \w alma|strong="H5315"\w* \w desmaya|strong="H5888"\w* ante \w los|strong="H3588"\w* asesinos».   
\c 5
\p
\v 1 “Corred de \w una|strong="H4672"\w* parte \w a|strong="H3068"\w* \w otra|strong="H6213"\w* por las \w calles|strong="H7339"\w* de Jerusalén; \w ved|strong="H7200"\w* \w ahora|strong="H4994"\w*, \w sabed|strong="H3045"\w* y \w buscad|strong="H1245"\w* en sus \w plazas|strong="H7339"\w* \w si|strong="H4994"\w* \w halláis|strong="H4672"\w* un solo hombre, \w si|strong="H4994"\w* \w hay|strong="H3426"\w* alguien \w que|strong="H4994"\w* actúe con \w justicia|strong="H4941"\w*, \w que|strong="H4994"\w* \w busque|strong="H1245"\w* la verdad; y \w yo|strong="H4994"\w* la \w perdonaré|strong="H5545"\w*.  
\v 2 Aunque digan: ‘\w Vive|strong="H2416"\w* Yahvé’, ciertamente en \w falso|strong="H8267"\w* juran”.   
\p
\v 3 Oh Yahvé, ¿\w no|strong="H3808"\w* \w miran|strong="H2342"\w* tus \w ojos|strong="H5869"\w* la verdad? Los azotaste, y \w no|strong="H3808"\w* les dolió; los consumiste, y \w no|strong="H3808"\w* \w quisieron|strong="H3985"\w* \w recibir|strong="H3947"\w* \w corrección|strong="H4148"\w*; \w endurecieron|strong="H2388"\w* sus \w rostros|strong="H6440"\w* \w más|strong="H3808"\w* \w que|strong="H3808"\w* la \w roca|strong="H5553"\w*, \w no|strong="H3808"\w* \w quisieron|strong="H3985"\w* convertirse.   
\p
\v 4 \w Pero|strong="H3588"\w* \w yo|strong="H3588"\w* dije: «\w Ciertamente|strong="H3588"\w* \w estos|strong="H1992"\w* \w son|strong="H3588"\w* \w pobres|strong="H1800"\w*, han \w enloquecido|strong="H2973"\w*, \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w conocen|strong="H3045"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* Yahvé, \w ni|strong="H3808"\w* \w el|strong="H3588"\w* \w juicio|strong="H4941"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* \w Dios|strong="H3068"\w*.  
\v 5 \w Iré|strong="H3212"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w grandes|strong="H1419"\w* \w y|strong="H3588"\w* \w les|strong="H1992"\w* \w hablaré|strong="H1696"\w*, \w porque|strong="H3588"\w* \w ellos|strong="H1992"\w* \w conocen|strong="H3045"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* Yahvé \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w juicio|strong="H4941"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* \w Dios|strong="H3068"\w*». \w Pero|strong="H3588"\w* \w estos|strong="H1992"\w* \w también|strong="H3162"\w*, \w de|strong="H3588"\w* común acuerdo, \w rompieron|strong="H5423"\w* \w el|strong="H3588"\w* \w yugo|strong="H5923"\w* \w y|strong="H3588"\w* \w rompieron|strong="H5423"\w* \w las|strong="H1992"\w* \w coyundas|strong="H4147"\w*.  
\v 6 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w el|strong="H5921"\w* león \w de|strong="H5921"\w* \w la|strong="H5921"\w* selva \w los|strong="H5921"\w* matará, \w el|strong="H5921"\w* \w lobo|strong="H2061"\w* \w del|strong="H5921"\w* desierto \w los|strong="H5921"\w* \w destruirá|strong="H7703"\w*, \w el|strong="H5921"\w* leopardo \w acechará|strong="H8245"\w* sus \w ciudades|strong="H5892"\w*; \w cualquiera|strong="H3605"\w* \w que|strong="H3588"\w* \w de|strong="H5921"\w* \w ellas|strong="H2007"\w* \w saliere|strong="H3318"\w* será despedazado; \w porque|strong="H3588"\w* sus \w rebeliones|strong="H6588"\w* \w se|strong="H5921"\w* han multiplicado \w y|strong="H3588"\w* sus apostasías \w se|strong="H5921"\w* han aumentado.   
\p
\v 7 “¿Cómo te he \w de|strong="H1121"\w* \w perdonar|strong="H5545"\w* por \w esto|strong="H2063"\w*? Tus \w hijos|strong="H1121"\w* me \w dejaron|strong="H5800"\w* y \w juraron|strong="H7650"\w* por \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w es|strong="H2063"\w* dios. \w Los|strong="H1121"\w* sacié, y adulteraron, y en \w casas|strong="H1004"\w* \w de|strong="H1121"\w* \w rameras|strong="H2181"\w* \w se|strong="H3808"\w* juntaron en tropel.  
\v 8 \w Como|strong="H1961"\w* \w caballos|strong="H5483"\w* bien cebados, cada cual \w relinchaba|strong="H6670"\w* tras la mujer de su \w prójimo|strong="H7453"\w*.  
\v 9 ¿\w No|strong="H3808"\w* he \w de|strong="H5921"\w* castigar \w esto|strong="H2088"\w*? — \w dice|strong="H5002"\w* Yahvé —. ¿\w De|strong="H5921"\w* una \w nación|strong="H1471"\w* \w como|strong="H5921"\w* \w esta|strong="H2088"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* vengará \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*?   
\p
\v 10 “\w Subid|strong="H5927"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* muros \w y|strong="H3588"\w* destruid, \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w hagáis|strong="H6213"\w* destrucción completa; \w quitad|strong="H5493"\w* \w sus|strong="H1992"\w* vástagos, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w son|strong="H3588"\w* \w de|strong="H3588"\w* Yahvé.  
\v 11 \w Porque|strong="H3588"\w* resueltamente se rebelaron \w contra|strong="H3478"\w* mí \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* — \w dice|strong="H5002"\w* Yahvé —.   
\p
\v 12 \w Negaron|strong="H3584"\w* \w a|strong="H3068"\w* Yahvé \w y|strong="H5921"\w* dijeron: ‘\w Él|strong="H1931"\w* \w no|strong="H3808"\w* existe; \w no|strong="H3808"\w* vendrá \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w ni|strong="H3808"\w* \w veremos|strong="H7200"\w* \w espada|strong="H2719"\w* \w ni|strong="H3808"\w* \w hambre|strong="H7458"\w*.  
\v 13 \w Los|strong="H1961"\w* \w profetas|strong="H5030"\w* \w serán|strong="H1961"\w* \w como|strong="H1961"\w* \w viento|strong="H7307"\w*, porque la palabra \w no|strong="H6213"\w* \w está|strong="H1961"\w* en ellos; \w que|strong="H1961"\w* \w se|strong="H1961"\w* \w haga|strong="H6213"\w* \w así|strong="H3541"\w* con ellos’”.   
\p
\v 14 \w Por|strong="H3282"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* \w dice|strong="H1696"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5971"\w* los \w Ejércitos|strong="H6635"\w*: “\w Por|strong="H3282"\w* haber \w hablado|strong="H1696"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*, he \w aquí|strong="H2088"\w* \w que|strong="H5971"\w* yo \w pongo|strong="H5414"\w* \w mis|strong="H5414"\w* \w palabras|strong="H1697"\w* en tu \w boca|strong="H6310"\w* \w por|strong="H3282"\w* fuego, \w y|strong="H3541"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w por|strong="H3282"\w* \w leña|strong="H6086"\w*, \w y|strong="H3541"\w* los consumirá.  
\v 15 He \w aquí|strong="H2005"\w* yo traigo \w sobre|strong="H5921"\w* \w vosotros|strong="H8085"\w* una \w nación|strong="H1471"\w* \w de|strong="H5921"\w* lejos, \w oh|strong="H4100"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* — \w dice|strong="H5002"\w* Yahvé —; \w es|strong="H1931"\w* \w nación|strong="H1471"\w* robusta, \w nación|strong="H1471"\w* \w antigua|strong="H5769"\w*, \w nación|strong="H1471"\w* \w cuya|strong="H1931"\w* \w lengua|strong="H3956"\w* \w ignoras|strong="H3808"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w entenderás|strong="H8085"\w* \w lo|strong="H1931"\w* \w que|strong="H4100"\w* \w hable|strong="H1696"\w*.  
\v 16 Su aljaba es como \w sepulcro|strong="H6913"\w* \w abierto|strong="H6605"\w*; \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* son \w valientes|strong="H1368"\w*.  
\v 17 \w Y|strong="H3068"\w* comerá tu cosecha \w y|strong="H1241"\w* tu \w pan|strong="H3899"\w*, \w que|strong="H1121"\w* habían \w de|strong="H1121"\w* comer tus \w hijos|strong="H1121"\w* \w y|strong="H1241"\w* tus \w hijas|strong="H1323"\w*; comerá tus \w ovejas|strong="H6629"\w* \w y|strong="H1241"\w* tus \w vacas|strong="H1241"\w*, comerá tus \w vides|strong="H1612"\w* \w y|strong="H1241"\w* tus \w higueras|strong="H8384"\w*, \w y|strong="H1241"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* arruinará tus \w ciudades|strong="H5892"\w* fortificadas en \w que|strong="H1121"\w* confías.   
\p
\v 18 “\w Sin|strong="H3808"\w* embargo, en \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* — \w dice|strong="H5002"\w* Yahvé — \w no|strong="H3808"\w* os destruiré del todo.  
\v 19 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* digáis: ‘¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w* \w nos|strong="H4100"\w* \w hizo|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H6213"\w* cosas?’, \w entonces|strong="H3588"\w* les dirás: ‘\w De|strong="H3588"\w* \w la|strong="H3588"\w* manera \w que|strong="H3588"\w* \w me|strong="H3588"\w* abandonasteis \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w y|strong="H3588"\w* servisteis \w a|strong="H3068"\w* dioses \w ajenos|strong="H5236"\w* \w en|strong="H3588"\w* \w vuestra|strong="H1961"\w* tierra, \w así|strong="H3651"\w* \w serviréis|strong="H5647"\w* \w a|strong="H3068"\w* extraños \w en|strong="H3588"\w* tierra \w ajena|strong="H3808"\w*’.   
\p
\v 20 “Anunciad \w esto|strong="H2063"\w* en \w la|strong="H2063"\w* \w casa|strong="H1004"\w* de \w Jacob|strong="H3290"\w* y \w haced|strong="H8085"\w* que se \w oiga|strong="H8085"\w* en \w Judá|strong="H3063"\w*, diciendo:  
\v 21 ‘\w Oíd|strong="H8085"\w* \w ahora|strong="H4994"\w* \w esto|strong="H2063"\w*, \w pueblo|strong="H5971"\w* \w necio|strong="H5530"\w* y \w sin|strong="H3808"\w* \w entendimiento|strong="H3820"\w*, \w que|strong="H3808"\w* tenéis \w ojos|strong="H5869"\w* y \w no|strong="H3808"\w* \w veis|strong="H7200"\w*, \w que|strong="H3808"\w* tenéis \w oídos|strong="H8085"\w* y \w no|strong="H3808"\w* oís:  
\v 22 ¿\w A|strong="H3068"\w* mí \w no|strong="H3808"\w* me \w temeréis|strong="H3372"\w*? — \w dice|strong="H5002"\w* Yahvé —. ¿\w No|strong="H3808"\w* temblaréis \w ante|strong="H6440"\w* mi \w presencia|strong="H6440"\w*, yo \w que|strong="H3808"\w* \w puse|strong="H7760"\w* \w la|strong="H1366"\w* \w arena|strong="H2342"\w* \w por|strong="H6440"\w* límite al \w mar|strong="H3220"\w*, \w por|strong="H6440"\w* ordenación \w eterna|strong="H5769"\w* \w la|strong="H1366"\w* cual \w no|strong="H3808"\w* \w quebrantará|strong="H5674"\w*? \w Se|strong="H3808"\w* levantarán tempestades, \w mas|strong="H3808"\w* \w no|strong="H3808"\w* \w prevalecerán|strong="H3201"\w*; \w bramarán|strong="H1993"\w* sus ondas, \w mas|strong="H3808"\w* \w no|strong="H3808"\w* \w la|strong="H1366"\w* \w pasarán|strong="H5674"\w*’.   
\p
\v 23 “Pero \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w tiene|strong="H1961"\w* \w corazón|strong="H3820"\w* \w falso|strong="H5637"\w* y \w rebelde|strong="H5637"\w*; \w se|strong="H1961"\w* apartaron y \w se|strong="H1961"\w* \w fueron|strong="H1961"\w*.  
\v 24 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* dijeron en su \w corazón|strong="H3824"\w*: ‘\w Temamos|strong="H3372"\w* \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* Yahvé \w Dios|strong="H3068"\w* nuestro, \w que|strong="H3808"\w* \w da|strong="H5414"\w* \w la|strong="H8104"\w* \w lluvia|strong="H1653"\w* temprana y \w la|strong="H8104"\w* \w tardía|strong="H4456"\w* en su \w tiempo|strong="H6256"\w*, y nos \w guarda|strong="H8104"\w* los \w tiempos|strong="H6256"\w* señalados \w de|strong="H3372"\w* \w la|strong="H8104"\w* siega’.   
\p
\v 25 “Vuestras \w iniquidades|strong="H5771"\w* han estorbado estas cosas, y vuestros \w pecados|strong="H2403"\w* \w apartaron|strong="H4513"\w* \w de|strong="H4480"\w* vosotros el \w bien|strong="H2896"\w*.  
\v 26 \w Porque|strong="H3588"\w* \w se|strong="H5971"\w* \w hallaron|strong="H4672"\w* \w en|strong="H3588"\w* mi \w pueblo|strong="H5971"\w* hombres malvados; acechaban \w como|strong="H3588"\w* quien pone \w lazos|strong="H3353"\w*, \w pusieron|strong="H5324"\w* trampa \w para|strong="H3588"\w* cazar hombres.  
\v 27 \w Como|strong="H5921"\w* jaula \w llena|strong="H4392"\w* \w de|strong="H5921"\w* pájaros, \w así|strong="H3651"\w* están sus \w casas|strong="H1004"\w* \w llenas|strong="H4392"\w* \w de|strong="H5921"\w* \w engaño|strong="H4820"\w*; \w así|strong="H3651"\w* \w se|strong="H5921"\w* hicieron \w grandes|strong="H1431"\w* \w y|strong="H5921"\w* ricos.  
\v 28 \w Engordaron|strong="H8080"\w* \w y|strong="H1571"\w* brillan, \w y|strong="H1571"\w* sobrepasaron los \w hechos|strong="H1697"\w* del \w malvado|strong="H7451"\w*; \w no|strong="H3808"\w* \w juzgaron|strong="H1777"\w* \w la|strong="H1571"\w* \w causa|strong="H1697"\w*, \w la|strong="H1571"\w* \w causa|strong="H1697"\w* del \w huérfano|strong="H3490"\w*, para \w que|strong="H3808"\w* prosperase, \w ni|strong="H3808"\w* defendieron \w el|strong="H5674"\w* \w derecho|strong="H4941"\w* \w de|strong="H1697"\w* los pobres.   
\p
\v 29 “¿\w No|strong="H3808"\w* he \w de|strong="H5921"\w* castigar \w esto|strong="H2088"\w*? — \w dice|strong="H5002"\w* Yahvé —. ¿\w De|strong="H5921"\w* una \w nación|strong="H1471"\w* \w como|strong="H5921"\w* \w esta|strong="H2088"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* vengará \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*?   
\p
\v 30 «Cosa espantosa y fea \w es|strong="H1961"\w* hecha en la tierra:  
\v 31 \w los|strong="H5921"\w* \w profetas|strong="H5030"\w* \w profetizaron|strong="H5012"\w* \w mentira|strong="H8267"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w dirigían|strong="H7287"\w* \w por|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w*; \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w así|strong="H3651"\w* \w lo|strong="H4100"\w* quiso. ¿\w Qué|strong="H4100"\w* \w pues|strong="H3651"\w* \w haréis|strong="H6213"\w* \w al|strong="H5921"\w* fin \w de|strong="H5921"\w* ello?».   
\c 6
\p
\v 1 «¡\w Huid|strong="H5756"\w* \w para|strong="H5921"\w* poneros \w a|strong="H3068"\w* salvo, \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Benjamín|strong="H1144"\w*, \w de|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* Jerusalén! \w Tocad|strong="H8628"\w* \w la|strong="H5921"\w* \w trompeta|strong="H7782"\w* \w en|strong="H5921"\w* Tecoa \w y|strong="H3588"\w* \w alzad|strong="H5375"\w* señal \w en|strong="H5921"\w* Bet-Haquerem, \w porque|strong="H3588"\w* \w del|strong="H5921"\w* \w norte|strong="H6828"\w* \w se|strong="H5921"\w* asoma \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w y|strong="H3588"\w* una \w gran|strong="H1419"\w* destrucción.  
\v 2 Destruiré \w a|strong="H3068"\w* la \w hermosa|strong="H5000"\w* y delicada \w hija|strong="H1323"\w* de \w Sión|strong="H6726"\w*.  
\v 3 \w Pastores|strong="H7462"\w* \w con|strong="H5921"\w* sus \w rebaños|strong="H5739"\w* vendrán \w a|strong="H3068"\w* \w ella|strong="H5921"\w*; \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* plantarán sus tiendas \w en|strong="H5921"\w* \w derredor|strong="H5439"\w*; cada uno \w apacentará|strong="H7462"\w* \w en|strong="H5921"\w* su lugar».   
\p
\v 4 «¡Preparad \w la|strong="H5921"\w* \w guerra|strong="H4421"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*! ¡\w Levantaos|strong="H6965"\w*! \w Subamos|strong="H5927"\w* \w al|strong="H5921"\w* mediodía. ¡Ay \w de|strong="H5921"\w* \w nosotros|strong="H5921"\w*!, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* declina, \w porque|strong="H3588"\w* \w las|strong="H5921"\w* sombras \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tarde|strong="H6153"\w* \w se|strong="H5921"\w* han \w extendido|strong="H5186"\w*.  
\v 5 ¡\w Levantaos|strong="H6965"\w*! \w Subamos|strong="H5927"\w* de \w noche|strong="H3915"\w* y \w destruyamos|strong="H7843"\w* sus palacios».  
\v 6 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dijo Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*: «\w Cortad|strong="H3772"\w* árboles \w y|strong="H3588"\w* levantad terraplén \w contra|strong="H5921"\w* Jerusalén. \w Esta|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w que|strong="H3588"\w* \w ha|strong="H3541"\w* \w de|strong="H5921"\w* ser castigada; \w toda|strong="H3605"\w* \w ella|strong="H1931"\w* \w está|strong="H1931"\w* llena \w de|strong="H5921"\w* opresión.  
\v 7 \w Como|strong="H5921"\w* \w el|strong="H5921"\w* pozo brota sus \w aguas|strong="H4325"\w*, \w así|strong="H3651"\w* \w ella|strong="H5921"\w* brota su \w maldad|strong="H7451"\w*. \w Violencia|strong="H2555"\w* \w y|strong="H5921"\w* \w destrucción|strong="H7701"\w* \w se|strong="H5921"\w* \w oyen|strong="H8085"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w*; \w ante|strong="H6440"\w* \w mí|strong="H5921"\w* hay \w continuamente|strong="H8548"\w* \w enfermedades|strong="H2483"\w* \w y|strong="H5921"\w* \w heridas|strong="H4347"\w*.  
\v 8 \w Corrígete|strong="H3256"\w*, Jerusalén, \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* aparte \w mi|strong="H3389"\w* \w alma|strong="H5315"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w no|strong="H3808"\w* \w te|strong="H4480"\w* convierta \w en|strong="H4480"\w* desierto, \w en|strong="H4480"\w* tierra \w no|strong="H3808"\w* \w habitada|strong="H3427"\w*».   
\p
\v 9 \w Así|strong="H3541"\w* dice Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*: «\w Rebuscarán|strong="H5953"\w* \w como|strong="H5921"\w* \w a|strong="H3068"\w* una \w vid|strong="H1612"\w* \w el|strong="H5921"\w* \w resto|strong="H7611"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Vuelve|strong="H7725"\w* tu \w mano|strong="H3027"\w*, \w como|strong="H5921"\w* \w el|strong="H5921"\w* vendimiador, \w a|strong="H3068"\w* \w los|strong="H5921"\w* cestos».   
\p
\v 10 ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* \w hablaré|strong="H1696"\w* \w y|strong="H5921"\w* amonestaré \w para|strong="H5921"\w* \w que|strong="H4310"\w* \w oigan|strong="H8085"\w*? He \w aquí|strong="H2009"\w* \w que|strong="H4310"\w* sus \w oídos|strong="H8085"\w* \w son|strong="H1961"\w* \w incircuncisos|strong="H6189"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w pueden|strong="H3201"\w* \w escuchar|strong="H8085"\w*. He \w aquí|strong="H2009"\w* \w que|strong="H4310"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w les|strong="H5921"\w* \w es|strong="H1961"\w* \w cosa|strong="H1697"\w* \w de|strong="H5921"\w* \w oprobio|strong="H2781"\w*; \w no|strong="H3808"\w* \w tienen|strong="H1961"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* deleite.  
\v 11 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, estoy \w lleno|strong="H4392"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ira|strong="H2534"\w* \w de|strong="H5921"\w* Yahvé; estoy \w cansado|strong="H3811"\w* \w de|strong="H5921"\w* contenerla.  
\q1 “Viértela \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w niños|strong="H5768"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* calle,  
\q2 \w y|strong="H1571"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* reunión \w de|strong="H5921"\w* \w los|strong="H5921"\w* jóvenes \w juntamente|strong="H3162"\w*;  
\q1 \w porque|strong="H3588"\w* \w el|strong="H5921"\w* marido \w con|strong="H5973"\w* \w la|strong="H5921"\w* mujer serán apresados,  
\q2 \w el|strong="H5921"\w* \w anciano|strong="H2205"\w* \w con|strong="H5973"\w* \w el|strong="H5921"\w* \w que|strong="H3588"\w* \w está|strong="H5921"\w* \w lleno|strong="H4392"\w* \w de|strong="H5921"\w* \w días|strong="H3117"\w*.   
\q1
\v 12 Sus \w casas|strong="H1004"\w* serán traspasadas \w a|strong="H3068"\w* otros,  
\q2 sus \w campos|strong="H7704"\w* \w y|strong="H3588"\w* sus mujeres \w juntamente|strong="H3162"\w*;  
\q1 \w porque|strong="H3588"\w* \w extenderé|strong="H5186"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra — \w dice|strong="H5002"\w* Yahvé —.   
\q1
\v 13 \w Porque|strong="H3588"\w* \w desde|strong="H5704"\w* \w el|strong="H3588"\w* \w más|strong="H3588"\w* \w pequeño|strong="H6996"\w* \w de|strong="H3588"\w* \w ellos|strong="H3605"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w más|strong="H3588"\w* \w grande|strong="H1419"\w*, \w cada|strong="H3605"\w* uno \w sigue|strong="H1214"\w* \w la|strong="H3605"\w* codicia;  
\q2 \w y|strong="H3588"\w* \w desde|strong="H5704"\w* \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w*, \w todos|strong="H3605"\w* actúan \w con|strong="H3588"\w* \w engaño|strong="H8267"\w*.   
\q1
\v 14 \w Curan|strong="H7495"\w* \w la|strong="H5921"\w* herida \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w con|strong="H5921"\w* ligereza,  
\q2 diciendo: ‘¡\w Paz|strong="H7965"\w*, \w paz|strong="H7965"\w*!’, \w y|strong="H5921"\w* \w no|strong="H5921"\w* hay \w paz|strong="H7965"\w*.   
\q1
\v 15 ¿\w Se|strong="H3045"\w* han \w avergonzado|strong="H3637"\w* \w de|strong="H3588"\w* \w haber|strong="H3808"\w* cometido \w abominación|strong="H8441"\w*?  
\q2 \w Ciertamente|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* han \w avergonzado|strong="H3637"\w*, \w ni|strong="H3808"\w* \w aun|strong="H1571"\w* \w saben|strong="H3045"\w* \w qué|strong="H3588"\w* \w es|strong="H3588"\w* sonrojarse.  
\q1 \w Por|strong="H3588"\w* \w tanto|strong="H3651"\w*, \w caerán|strong="H5307"\w* \w entre|strong="H3808"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w caigan|strong="H5307"\w*;  
\q2 \w cuando|strong="H3588"\w* \w los|strong="H3588"\w* visite, serán abatidos”, dice Yahvé.   
\p
\v 16 \w Así|strong="H3541"\w* dice Yahvé: “\w Paraos|strong="H5975"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w caminos|strong="H1870"\w* \w y|strong="H5921"\w* \w mirad|strong="H7200"\w*, \w y|strong="H5921"\w* \w preguntad|strong="H7592"\w* \w por|strong="H5921"\w* \w las|strong="H5921"\w* sendas \w antiguas|strong="H5769"\w*: ‘¿\w Cuál|strong="H5315"\w* \w es|strong="H2088"\w* \w el|strong="H5921"\w* \w buen|strong="H2896"\w* \w camino|strong="H1870"\w*?’. \w Y|strong="H3068"\w* \w andad|strong="H3212"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w hallaréis|strong="H4672"\w* descanso \w para|strong="H5921"\w* vuestra \w alma|strong="H5315"\w*”. \w Mas|strong="H5921"\w* \w ellos|strong="H5921"\w* dijeron: ‘\w No|strong="H3808"\w* \w andaremos|strong="H3212"\w*’.  
\v 17 “Puse también \w sobre|strong="H5921"\w* vosotros atalayas \w que|strong="H3808"\w* dijesen: ‘Atended \w al|strong="H5921"\w* \w sonido|strong="H6963"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w trompeta|strong="H7782"\w*’”. \w Mas|strong="H5921"\w* \w ellos|strong="H5921"\w* dijeron: ‘\w No|strong="H3808"\w* atenderemos’.  
\v 18 «\w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w oíd|strong="H8085"\w*, \w naciones|strong="H1471"\w*, y conoced, oh congregación, lo \w que|strong="H3045"\w* hay entre ellos.  
\v 19 \w Oye|strong="H8085"\w*, tierra: He \w aquí|strong="H2009"\w* \w yo|strong="H3588"\w* traigo \w sobre|strong="H5921"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w*, \w el|strong="H5921"\w* \w fruto|strong="H6529"\w* \w de|strong="H5921"\w* sus \w pensamientos|strong="H4284"\w*; \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w atendieron|strong="H7181"\w* \w a|strong="H3068"\w* mis \w palabras|strong="H1697"\w*, \w y|strong="H3588"\w* \w desecharon|strong="H3988"\w* \w mi|strong="H5921"\w* \w ley|strong="H8451"\w*.  
\v 20 ¿Para \w qué|strong="H4100"\w* viene \w a|strong="H3068"\w* mí \w este|strong="H2088"\w* \w incienso|strong="H3828"\w* de Sabá, y la \w caña|strong="H7070"\w* olorosa de tierra \w lejana|strong="H4801"\w*? Vuestros \w holocaustos|strong="H5930"\w* \w no|strong="H3808"\w* \w son|strong="H3808"\w* aceptables, \w ni|strong="H3808"\w* vuestros \w sacrificios|strong="H2077"\w* me agradan».   
\p
\v 21 \w Por|strong="H2088"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé: «He \w aquí|strong="H2088"\w* yo \w pongo|strong="H5414"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w tropiezos|strong="H4383"\w*, \w y|strong="H3541"\w* en ellos \w tropezarán|strong="H3782"\w* \w los|strong="H1121"\w* padres \w y|strong="H3541"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w juntamente|strong="H3162"\w*; \w el|strong="H1121"\w* \w vecino|strong="H7934"\w* \w y|strong="H3541"\w* su \w amigo|strong="H7453"\w* perecerán».  
\v 22 \w Así|strong="H3541"\w* dice Yahvé: «He \w aquí|strong="H2009"\w* \w que|strong="H5971"\w* viene un \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* la tierra del \w norte|strong="H6828"\w*, \w y|strong="H3541"\w* una \w nación|strong="H1471"\w* \w grande|strong="H1419"\w* \w se|strong="H5971"\w* levantará \w de|strong="H5971"\w* los confines \w de|strong="H5971"\w* la tierra.  
\v 23 \w Arco|strong="H7198"\w* \w y|strong="H5921"\w* lanza \w manejarán|strong="H2388"\w*; \w son|strong="H3808"\w* crueles \w y|strong="H5921"\w* \w no|strong="H3808"\w* tendrán \w misericordia|strong="H7355"\w*. \w Su|strong="H1931"\w* \w estruendo|strong="H6963"\w* brama \w como|strong="H5921"\w* \w el|strong="H1931"\w* \w mar|strong="H3220"\w*, \w y|strong="H5921"\w* montan \w a|strong="H3068"\w* \w caballo|strong="H5483"\w*; cada uno \w está|strong="H1931"\w* dispuesto \w como|strong="H5921"\w* hombre \w de|strong="H5921"\w* \w guerra|strong="H4421"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, oh \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Sión|strong="H6726"\w*».   
\p
\v 24 Su fama \w oímos|strong="H8085"\w*, y nuestras \w manos|strong="H3027"\w* se descoyuntaron; se apoderó de nosotros \w angustia|strong="H6869"\w*, \w dolor|strong="H2427"\w* como de mujer de parto.  
\v 25 \w No|strong="H3588"\w* \w salgas|strong="H3318"\w* al \w campo|strong="H7704"\w*, ni \w andes|strong="H3212"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w*; \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* del enemigo \w y|strong="H3588"\w* \w el|strong="H3588"\w* terror están \w por|strong="H3588"\w* \w todas|strong="H5439"\w* \w partes|strong="H5439"\w*.  
\v 26 \w Hija|strong="H1323"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w cíñete|strong="H2296"\w* \w de|strong="H5921"\w* cilicio \w y|strong="H3588"\w* \w revuélcate|strong="H6428"\w* \w en|strong="H5921"\w* ceniza; pon luto \w como|strong="H3588"\w* \w por|strong="H5921"\w* hijo \w único|strong="H3173"\w*, \w llanto|strong="H4553"\w* \w de|strong="H5921"\w* amargura; \w porque|strong="H3588"\w* pronto vendrá \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w el|strong="H5921"\w* \w destruidor|strong="H7703"\w*.   
\p
\v 27 «\w Por|strong="H1870"\w* probador \w de|strong="H5971"\w* metales te he \w puesto|strong="H5414"\w* en mi \w pueblo|strong="H5971"\w*, \w por|strong="H1870"\w* \w fortaleza|strong="H4013"\w*, \w para|strong="H5414"\w* \w que|strong="H5971"\w* conozcas y examines el \w camino|strong="H1870"\w* \w de|strong="H5971"\w* ellos.  
\v 28 \w Todos|strong="H3605"\w* \w ellos|strong="H1992"\w* son rebeldes obstinados, \w andan|strong="H1980"\w* calumniando; son bronce \w e|strong="H3068"\w* \w hierro|strong="H1270"\w*; \w todos|strong="H3605"\w* \w ellos|strong="H1992"\w* son corruptores.  
\v 29 Sopló el fuelle, el plomo \w ha|strong="H3808"\w* sido consumido por el fuego; en vano fundió el \w fundidor|strong="H6884"\w*, pues los malvados \w no|strong="H3808"\w* han sido arrancados.  
\v 30 \w Plata|strong="H3701"\w* \w desechada|strong="H3988"\w* \w los|strong="H3588"\w* \w llamarán|strong="H7121"\w*, \w porque|strong="H3588"\w* Yahvé \w los|strong="H3588"\w* \w desechó|strong="H3988"\w*».   
\c 7
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H1697"\w* parte \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Ponte|strong="H5975"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H1697"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1697"\w* Yahvé y proclama \w allí|strong="H8033"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*, y di: ‘\w Oíd|strong="H8085"\w* \w la|strong="H3605"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w*, \w los|strong="H3605"\w* \w que|strong="H1697"\w* entráis \w por|strong="H1697"\w* \w estas|strong="H5975"\w* \w puertas|strong="H8179"\w* para adorar \w a|strong="H3068"\w* Yahvé’”.   
\p
\v 3 \w Así|strong="H3541"\w* dice Yahvé de los \w Ejércitos|strong="H6635"\w*, el \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*: “Enmendad vuestros \w caminos|strong="H1870"\w* \w y|strong="H3541"\w* vuestras \w obras|strong="H4611"\w*, \w y|strong="H3541"\w* os \w haré|strong="H3190"\w* habitar en \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.  
