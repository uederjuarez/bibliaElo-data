\q2 \w ni|strong="H3808"\w* la \w habitará|strong="H3427"\w* \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w hombre|strong="H1121"\w*».   
\b  
\p
\v 34 \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w al|strong="H4428"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w acerca|strong="H1697"\w* \w de|strong="H1697"\w* \w Elam|strong="H5867"\w*, \w al|strong="H4428"\w* \w principio|strong="H7225"\w* del \w reinado|strong="H4428"\w* \w de|strong="H1697"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w*, diciendo:  
\v 35 “\w Así|strong="H3541"\w* dice Yahvé de los \w Ejércitos|strong="H6635"\w*:  
\q1 ‘He \w aquí|strong="H3541"\w* \w que|strong="H3541"\w* yo quiebro el \w arco|strong="H7198"\w* de \w Elam|strong="H5867"\w*,  
\q2 parte principal de su \w fortaleza|strong="H1369"\w*.   
\q1
\v 36 Traeré \w sobre|strong="H1961"\w* \w Elam|strong="H5867"\w* \w los|strong="H3605"\w* cuatro \w vientos|strong="H7307"\w* de \w los|strong="H3605"\w* cuatro \w puntos|strong="H7098"\w* del \w cielo|strong="H8064"\w*,  
\q2 y \w los|strong="H3605"\w* \w aventaré|strong="H2219"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* \w vientos|strong="H7307"\w*;  
\q1 y \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* \w nación|strong="H1471"\w* adonde \w no|strong="H3808"\w* vayan  
\q2 \w los|strong="H3605"\w* fugitivos de \w Elam|strong="H5867"\w*.   
\q1
\v 37 \w Y|strong="H3068"\w* haré \w que|strong="H5921"\w* \w Elam|strong="H5867"\w* \w se|strong="H5921"\w* acobarde \w delante|strong="H6440"\w* \w de|strong="H5921"\w* sus enemigos  
\q2 \w y|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w buscan|strong="H1245"\w* su \w vida|strong="H5315"\w*;  
\q1 \w y|strong="H5921"\w* traeré \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w mal|strong="H7451"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* ardor \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w ira|strong="H2740"\w*’, \w dice|strong="H5002"\w* Yahvé;  
\q2 ‘\w y|strong="H5921"\w* \w enviaré|strong="H7971"\w* \w en|strong="H5921"\w* pos \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* \w acabe|strong="H3615"\w*.   
\q1
\v 38 \w Y|strong="H3068"\w* \w pondré|strong="H7760"\w* mi \w trono|strong="H3678"\w* en \w Elam|strong="H5867"\w*,  
\q2 y destruiré \w de|strong="H8269"\w* \w allí|strong="H8033"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* y \w a|strong="H3068"\w* los \w príncipes|strong="H8269"\w*’, \w dice|strong="H5002"\w* Yahvé.   
\q1
\v 39 ‘Pero \w acontecerá|strong="H1961"\w* en \w los|strong="H1961"\w* últimos \w días|strong="H3117"\w*  
\q2 \w que|strong="H3117"\w* restauraré la suerte de \w Elam|strong="H5867"\w*’, \w dice|strong="H5002"\w* Yahvé”.   
\c 50
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w habló|strong="H1696"\w* Yahvé contra Babilonia y contra la tierra \w de|strong="H1697"\w* los \w caldeos|strong="H3778"\w*, \w por|strong="H1697"\w* \w mano|strong="H3027"\w* del \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*.   
\q1
\v 2 “Anunciad entre las \w naciones|strong="H1471"\w* y hacedlo \w saber|strong="H5046"\w*;  
\q2 \w alzad|strong="H5375"\w* \w bandera|strong="H5251"\w*, proclamad y no ocultéis nada.  
\q1 Decid: ‘Babilonia ha sido \w tomada|strong="H3920"\w*,  
\q2 \w Bel|strong="H1078"\w* está avergonzado, ¡Merodac ha sido quebrantado!  
\q1 Sus imágenes están confundidas,  
\q2 sus \w ídolos|strong="H1544"\w* han sido deshechos’.   
\q1
\v 3 \w Porque|strong="H3588"\w* \w del|strong="H5921"\w* \w norte|strong="H6828"\w* \w sube|strong="H5927"\w* \w contra|strong="H5921"\w* \w ella|strong="H1931"\w* una \w nación|strong="H1471"\w*  
\q2 \w que|strong="H3588"\w* convertirá \w su|strong="H1931"\w* tierra \w en|strong="H5921"\w* desolación,  
\q2 \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* \w quien|strong="H1931"\w* habite \w en|strong="H5921"\w* \w ella|strong="H1931"\w*.  
\q1 Han huido, \w se|strong="H1961"\w* han ido,  
\q2 \w tanto|strong="H5921"\w* \w los|strong="H3427"\w* hombres \w como|strong="H3588"\w* \w los|strong="H3427"\w* animales.   
\b  
\q1
\v 4 \w En|strong="H3212"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* y \w en|strong="H3212"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* — \w dice|strong="H5002"\w* Yahvé —,  
\q2 vendrán \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*,  
\q2 \w ellos|strong="H1992"\w* y \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* \w juntamente|strong="H3162"\w*;  
\q1 \w irán|strong="H3212"\w* \w llorando|strong="H1058"\w* mientras \w caminan|strong="H1980"\w*  
\q2 y \w buscarán|strong="H1245"\w* \w a|strong="H3068"\w* Yahvé \w su|strong="H1931"\w* \w Dios|strong="H3068"\w*.   
