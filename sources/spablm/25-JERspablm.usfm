\q1
\v 46 \w Y|strong="H3068"\w* \w no|strong="H6435"\w* \w desmaye|strong="H7401"\w* vuestro \w corazón|strong="H3824"\w*, \w ni|strong="H6435"\w* \w temáis|strong="H3372"\w*  
\q2 \w a|strong="H3068"\w* causa \w del|strong="H5921"\w* \w rumor|strong="H8052"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w oirá|strong="H8085"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* tierra;  
\q1 \w porque|strong="H5921"\w* un \w año|strong="H8141"\w* vendrá \w el|strong="H5921"\w* \w rumor|strong="H8052"\w*,  
\q2 \w y|strong="H5921"\w* \w después|strong="H5921"\w* \w en|strong="H5921"\w* \w otro|strong="H8141"\w* \w año|strong="H8141"\w* \w otro|strong="H8141"\w* \w rumor|strong="H8052"\w*,  
\q2 \w y|strong="H5921"\w* habrá \w violencia|strong="H2555"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra, dominador \w contra|strong="H5921"\w* dominador.   
\q1
\v 47 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* vienen \w días|strong="H3117"\w* \w en|strong="H5921"\w* \w que|strong="H5921"\w* \w yo|strong="H2009"\w* castigaré \w las|strong="H5921"\w* imágenes talladas \w de|strong="H5921"\w* Babilonia,  
\q2 \w y|strong="H5921"\w* \w toda|strong="H3605"\w* su tierra será avergonzada,  
\q2 \w y|strong="H5921"\w* \w todos|strong="H3605"\w* sus \w muertos|strong="H2491"\w* \w caerán|strong="H5307"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ella|strong="H3605"\w*.   
\q1
\v 48 \w Los|strong="H5921"\w* \w cielos|strong="H8064"\w* \w y|strong="H3588"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* hay \w en|strong="H5921"\w* \w ellos|strong="H5921"\w*,  
\q2 \w cantarán|strong="H7442"\w* \w de|strong="H5921"\w* gozo \w sobre|strong="H5921"\w* Babilonia;  
