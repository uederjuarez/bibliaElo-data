\q1 sus \w arcos|strong="H7198"\w* fueron \w quebrantados|strong="H2865"\w*;  
\q2 \w porque|strong="H3588"\w* Yahvé \w es|strong="H3588"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* retribuciones, \w de|strong="H5921"\w* \w cierto|strong="H3588"\w* \w dará|strong="H7999"\w* \w el|strong="H5921"\w* pago.   
\q1
\v 57 \w Y|strong="H3068"\w* \w embriagaré|strong="H7937"\w* \w a|strong="H3068"\w* sus \w príncipes|strong="H8269"\w* y \w a|strong="H3068"\w* sus \w sabios|strong="H2450"\w*,  
\q2 \w a|strong="H3068"\w* sus \w capitanes|strong="H8269"\w*, \w a|strong="H3068"\w* sus prefectos y \w a|strong="H3068"\w* sus \w fuertes|strong="H1368"\w*;  
\q1 y dormirán \w sueño|strong="H8142"\w* \w eterno|strong="H5769"\w* y \w no|strong="H3808"\w* despertarán»,  
\q2 \w dice|strong="H5002"\w* el \w Rey|strong="H4428"\w*, cuyo \w nombre|strong="H8034"\w* es Yahvé \w de|strong="H8269"\w* \w los|strong="H2450"\w* \w Ejércitos|strong="H6635"\w*.   
\p
\v 58 \w Así|strong="H3541"\w* dice Yahvé \w de|strong="H5971"\w* los \w Ejércitos|strong="H6635"\w*:  
\q1 «Los \w muros|strong="H2346"\w* anchos \w de|strong="H5971"\w* Babilonia serán derribados por completo,  
\q2 \w y|strong="H3541"\w* sus altas \w puertas|strong="H8179"\w* serán \w quemadas|strong="H3341"\w* con fuego;  
