\q2 — \w dice|strong="H5002"\w* Yahvé —.   
\b  
\q1
\v 40 «\w Los|strong="H5973"\w* haré traer \w como|strong="H5973"\w* \w corderos|strong="H3733"\w* al matadero,  
\q2 \w como|strong="H5973"\w* carneros \w junto|strong="H5973"\w* \w con|strong="H5973"\w* machos cabríos.   
\b  
\q1
\v 41 ¡\w Cómo|strong="H1961"\w* ha \w sido|strong="H1961"\w* \w tomada|strong="H3920"\w* Sesac!  
\q2 ¡\w Cómo|strong="H1961"\w* ha \w sido|strong="H1961"\w* apresada \w la|strong="H3605"\w* \w que|strong="H1961"\w* \w era|strong="H1961"\w* alabada por \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra!  
\q2 ¡\w Cómo|strong="H1961"\w* ha \w sido|strong="H1961"\w* Babilonia objeto de \w espanto|strong="H8047"\w* entre las \w naciones|strong="H1471"\w*!   
\q1
