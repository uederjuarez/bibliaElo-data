\v 13 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H5971"\w* \w cuando|strong="H1961"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* iba con \w Ismael|strong="H3458"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w Johanán|strong="H3110"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carea|strong="H7143"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H1121"\w* las fuerzas \w que|strong="H5971"\w* \w estaban|strong="H1961"\w* con \w él|strong="H3605"\w*, \w se|strong="H1961"\w* alegraron.  
\v 14 \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H4480"\w* \w Ismael|strong="H3458"\w* traía \w cautivo|strong="H7617"\w* \w de|strong="H4480"\w* \w Mizpa|strong="H4709"\w* \w se|strong="H4480"\w* \w volvió|strong="H7725"\w* y regresó \w con|strong="H4480"\w* \w Johanán|strong="H3110"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Carea|strong="H7143"\w*.  
\v 15 Pero \w Ismael|strong="H3458"\w* \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Netanías \w escapó|strong="H4422"\w* \w de|strong="H6440"\w* \w Johanán|strong="H3110"\w* con \w ocho|strong="H8083"\w* \w hombres|strong="H1121"\w* y se \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* Amón.   
