\c 8
\p
\v 1 «\w En|strong="H3318"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* — \w dice|strong="H5002"\w* Yahvé — \w sacarán|strong="H3318"\w* \w de|strong="H8269"\w* \w sus|strong="H1931"\w* \w sepulcros|strong="H6913"\w* \w los|strong="H3427"\w* \w huesos|strong="H6106"\w* \w de|strong="H8269"\w* \w los|strong="H3427"\w* \w reyes|strong="H4428"\w* \w de|strong="H8269"\w* \w Judá|strong="H3063"\w*, \w los|strong="H3427"\w* \w huesos|strong="H6106"\w* \w de|strong="H8269"\w* \w sus|strong="H1931"\w* \w príncipes|strong="H8269"\w*, \w los|strong="H3427"\w* \w huesos|strong="H6106"\w* \w de|strong="H8269"\w* \w los|strong="H3427"\w* \w sacerdotes|strong="H3548"\w*, \w los|strong="H3427"\w* \w huesos|strong="H6106"\w* \w de|strong="H8269"\w* \w los|strong="H3427"\w* \w profetas|strong="H5030"\w* y \w los|strong="H3427"\w* \w huesos|strong="H6106"\w* \w de|strong="H8269"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H8269"\w* Jerusalén.  
\v 2 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* esparcirán \w al|strong="H5921"\w* \w sol|strong="H8121"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w luna|strong="H3394"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w ejército|strong="H6635"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w a|strong="H3068"\w* quienes amaron \w y|strong="H5921"\w* \w a|strong="H3068"\w* quienes \w sirvieron|strong="H5647"\w*, \w en|strong="H5921"\w* pos \w de|strong="H5921"\w* quienes \w caminaron|strong="H1980"\w*, \w a|strong="H3068"\w* quienes \w buscaron|strong="H1875"\w* \w y|strong="H5921"\w* \w ante|strong="H6440"\w* quienes \w se|strong="H1961"\w* postraron. \w No|strong="H3808"\w* \w serán|strong="H1961"\w* recogidos \w ni|strong="H3808"\w* \w enterrados|strong="H6912"\w*; \w serán|strong="H1961"\w* \w como|strong="H1961"\w* estiércol \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
\v 3 \w Y|strong="H3068"\w* elegirá \w la|strong="H2063"\w* \w muerte|strong="H4194"\w* \w antes|strong="H4480"\w* \w que|strong="H4480"\w* \w la|strong="H2063"\w* \w vida|strong="H2416"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w resto|strong="H7611"\w* \w que|strong="H4480"\w* \w quede|strong="H7604"\w* \w de|strong="H4480"\w* \w esta|strong="H2063"\w* malvada \w familia|strong="H4940"\w*, \w en|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w lugares|strong="H4725"\w* \w a|strong="H3068"\w* \w donde|strong="H8033"\w* \w yo|strong="H4480"\w* \w los|strong="H3605"\w* arrojé», \w dice|strong="H5002"\w* Yahvé \w de|strong="H4480"\w* \w los|strong="H3605"\w* \w Ejércitos|strong="H6635"\w*.  
\v 4 “Les dirás \w asimismo|strong="H3541"\w*: ‘\w Así|strong="H3541"\w* dice Yahvé:  
\q1 “‘¿\w El|strong="H5307"\w* \w que|strong="H3808"\w* \w cae|strong="H5307"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* levanta?  
\q2 ¿\w El|strong="H5307"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* desvía \w no|strong="H3808"\w* \w vuelve|strong="H7725"\w* al camino?   
\q1
\v 5 ¿\w Por|strong="H4069"\w* \w qué|strong="H5971"\w*, \w pues|strong="H2088"\w*, \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* Jerusalén \w se|strong="H5971"\w* ha rebelado con rebeldía \w perpetua|strong="H5329"\w*?  
\q2 \w Abrazaron|strong="H2388"\w* el engaño,  
\q2 y \w no|strong="H3985"\w* han querido \w volverse|strong="H7725"\w*.   
\q1
\v 6 \w Escuché|strong="H7181"\w* \w y|strong="H5921"\w* \w oí|strong="H8085"\w*; \w no|strong="H3808"\w* \w hablan|strong="H1696"\w* \w rectamente|strong="H3651"\w*.  
\q2 \w No|strong="H3808"\w* hay hombre \w que|strong="H4100"\w* \w se|strong="H5921"\w* arrepienta \w de|strong="H5921"\w* su \w mal|strong="H7451"\w*, \w diciendo|strong="H1696"\w*: «¿\w Qué|strong="H4100"\w* he \w hecho|strong="H6213"\w*?».  
\q1 \w Cada|strong="H3605"\w* \w cual|strong="H4100"\w* \w se|strong="H5921"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* su carrera,  
\q2 \w como|strong="H4100"\w* \w caballo|strong="H5483"\w* \w que|strong="H4100"\w* arremete \w con|strong="H5921"\w* ímpetu \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w*.   
\q1
\v 7 \w Aun|strong="H1571"\w* \w la|strong="H1571"\w* cigüeña en \w el|strong="H1571"\w* \w cielo|strong="H8064"\w* \w conoce|strong="H3045"\w* sus \w tiempos|strong="H6256"\w*,  
\q2 \w y|strong="H1571"\w* \w la|strong="H1571"\w* tórtola, \w la|strong="H1571"\w* golondrina \w y|strong="H1571"\w* \w la|strong="H1571"\w* grulla \w guardan|strong="H8104"\w* \w el|strong="H1571"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5971"\w* su venida;  
\q2 pero mi \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* \w conoce|strong="H3045"\w* \w el|strong="H1571"\w* \w juicio|strong="H4941"\w* \w de|strong="H5971"\w* Yahvé.   
\b  
\q1
\v 8 “‘¿Cómo decís: «Nosotros somos \w sabios|strong="H2450"\w*, y la \w ley|strong="H8451"\w* de Yahvé está con nosotros»?  
\q2 \w Ciertamente|strong="H2009"\w* la ha cambiado en \w mentira|strong="H8267"\w* \w el|strong="H6213"\w* estilete \w mentiroso|strong="H8267"\w* de \w los|strong="H2450"\w* \w escribas|strong="H5608"\w*.   
\q1
\v 9 \w Los|strong="H2450"\w* \w sabios|strong="H2450"\w* \w se|strong="H4100"\w* avergonzaron,  
\q2 \w se|strong="H4100"\w* espantaron y fueron prendidos.  
\q1 He \w aquí|strong="H2009"\w* \w que|strong="H4100"\w* \w desecharon|strong="H3988"\w* \w la|strong="H2451"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé;  
\q2 ¿y \w qué|strong="H4100"\w* \w sabiduría|strong="H2451"\w* \w tienen|strong="H2451"\w*?   
\q1
\v 10 \w Por|strong="H3588"\w* \w tanto|strong="H3651"\w*, \w daré|strong="H5414"\w* \w a|strong="H3068"\w* otros sus \w mujeres|strong="H5704"\w*,  
\q2 \w y|strong="H3588"\w* sus \w campos|strong="H7704"\w* \w a|strong="H3068"\w* quienes \w los|strong="H3605"\w* conquisten;  
\q1 \w porque|strong="H3588"\w* \w desde|strong="H5704"\w* \w el|strong="H3588"\w* \w más|strong="H3588"\w* \w pequeño|strong="H6996"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w más|strong="H3588"\w* \w grande|strong="H1419"\w*, \w cada|strong="H3605"\w* uno \w sigue|strong="H1214"\w* \w la|strong="H3588"\w* codicia;  
\q2 \w desde|strong="H5704"\w* \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w*, \w todos|strong="H3605"\w* actúan \w con|strong="H3588"\w* \w engaño|strong="H8267"\w*.   
\q1
\v 11 \w Y|strong="H3068"\w* curaron \w la|strong="H5921"\w* herida \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w con|strong="H5921"\w* \w liviandad|strong="H7043"\w*, diciendo:  
\q2 «¡\w Paz|strong="H7965"\w*, \w paz|strong="H7965"\w*!», \w y|strong="H5921"\w* \w no|strong="H5921"\w* hay \w paz|strong="H7965"\w*.   
\q1
\v 12 ¿\w Se|strong="H3045"\w* han \w avergonzado|strong="H3637"\w* \w de|strong="H3588"\w* \w haber|strong="H3808"\w* cometido \w abominación|strong="H8441"\w*?  
\q2 \w Ciertamente|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* han \w avergonzado|strong="H3637"\w*,  
\q2 \w ni|strong="H3808"\w* \w aun|strong="H1571"\w* \w saben|strong="H3045"\w* \w qué|strong="H3588"\w* \w es|strong="H3588"\w* sonrojarse;  
\q1 \w caerán|strong="H5307"\w*, \w por|strong="H3588"\w* \w tanto|strong="H3651"\w*, \w entre|strong="H3808"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w caigan|strong="H5307"\w*;  
\q2 \w cuando|strong="H3588"\w* \w los|strong="H3588"\w* visite, \w caerán|strong="H5307"\w*”, dice Yahvé.   
\b  
\q1
\v 13 “‘\w Los|strong="H1992"\w* cortaré del todo, \w dice|strong="H5002"\w* Yahvé.  
\q2 No habrá \w uvas|strong="H6025"\w* en la \w vid|strong="H1612"\w*,  
\q2 ni \w higos|strong="H8384"\w* en la higuera,  
\q2 y \w se|strong="H1992"\w* marchitará la hoja;  
\q1 y \w lo|strong="H1992"\w* \w que|strong="H1992"\w* \w les|strong="H1992"\w* he \w dado|strong="H5414"\w*,  
\q2 \w les|strong="H1992"\w* \w será|strong="H5414"\w* quitado’”.   
\b  
\q1
\v 14 «¿\w Por|strong="H5921"\w* \w qué|strong="H3588"\w* \w nos|strong="H5921"\w* \w estamos|strong="H3427"\w* \w sentados|strong="H3427"\w*?  
\q2 ¡Reuníos!  
\q2 Entremos \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* fortificadas \w y|strong="H3588"\w* perezcamos \w allí|strong="H8033"\w*;  
\q1 \w porque|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w* \w nos|strong="H5921"\w* ha hecho perecer,  
\q2 \w y|strong="H3588"\w* \w nos|strong="H5921"\w* ha dado \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w agua|strong="H4325"\w* \w de|strong="H5921"\w* hiel,  
\q2 \w porque|strong="H3588"\w* \w pecamos|strong="H2398"\w* \w contra|strong="H5921"\w* Yahvé.   
\q1
\v 15 \w Esperamos|strong="H6960"\w* \w paz|strong="H7965"\w*, y no \w hubo|strong="H2009"\w* \w bien|strong="H2896"\w*;  
\q2 \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* \w salud|strong="H4832"\w*, y he \w aquí|strong="H2009"\w* \w turbación|strong="H1205"\w*.   
\q1
\v 16 Desde \w Dan|strong="H1835"\w* se \w oyó|strong="H8085"\w* \w el|strong="H3605"\w* bufido de sus \w caballos|strong="H5483"\w*;  
\q2 al \w sonido|strong="H6963"\w* de \w los|strong="H3427"\w* relinchos de sus corceles \w tembló|strong="H7493"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra;  
\q1 pues vinieron y devoraron \w la|strong="H3605"\w* tierra y su abundancia,  
\q2 \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* y \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de \w ella|strong="H3605"\w*».   
\q1
\v 17 «\w Porque|strong="H3588"\w* he \w aquí|strong="H2005"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w envío|strong="H7971"\w* sobre vosotros \w serpientes|strong="H5175"\w*,  
\q2 basiliscos contra \w los|strong="H3588"\w* cuales \w no|strong="H3588"\w* hay encantamiento,  
\q2 \w y|strong="H3588"\w* os morderán», \w dice|strong="H5002"\w* Yahvé.   
\q1
\v 18 ¡\w A|strong="H3068"\w* causa \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w dolor|strong="H3015"\w*, busco consuelo!  
\q2 \w Mi|strong="H5921"\w* \w corazón|strong="H3820"\w* \w desfallece|strong="H1742"\w* \w en|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\q1
\v 19 He \w aquí|strong="H2009"\w* la \w voz|strong="H6963"\w* del \w clamor|strong="H7775"\w* \w de|strong="H5971"\w* la \w hija|strong="H1323"\w* \w de|strong="H5971"\w* \w mi|strong="H2009"\w* \w pueblo|strong="H5971"\w* desde tierra \w lejana|strong="H4801"\w*:  
\q2 «¿No está Yahvé en \w Sión|strong="H6726"\w*?  
\q2 ¿No está su \w Rey|strong="H4428"\w* en ella?».  
\b  
\q1 «¿\w Por|strong="H4069"\w* \w qué|strong="H5971"\w* me hicieron airar con sus imágenes talladas,  
\q2 con \w vanidades|strong="H1892"\w* \w ajenas|strong="H5236"\w*?».   
\b  
\q1
\v 20 «\w Pasó|strong="H5674"\w* la siega,  
\q2 terminó \w el|strong="H5674"\w* \w verano|strong="H7019"\w*,  
\q2 y nosotros \w no|strong="H3808"\w* hemos sido salvos».   
\b  
\q1
\v 21 \w Quebrantado|strong="H7665"\w* estoy \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w quebranto|strong="H7665"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*;  
\q2 \w entenebrecido|strong="H6937"\w* estoy,  
\q2 \w el|strong="H5921"\w* \w espanto|strong="H8047"\w* \w se|strong="H5921"\w* ha apoderado \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\q1
\v 22 ¿\w No|strong="H3808"\w* hay \w bálsamo|strong="H6875"\w* \w en|strong="H3588"\w* \w Galaad|strong="H1568"\w*?  
\q2 ¿\w No|strong="H3808"\w* hay \w allí|strong="H8033"\w* \w médico|strong="H7495"\w*?  
\q1 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w*, \w pues|strong="H3588"\w*, \w no|strong="H3808"\w* \w hubo|strong="H5927"\w* medicina \w para|strong="H3588"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*?   
\c 9
\q1
\v 1 ¡\w Oh|strong="H4310"\w*, \w si|strong="H3588"\w* mi cabeza \w se|strong="H5971"\w* hiciese agua,  
\q2 \w y|strong="H3588"\w* \w mis|strong="H5414"\w* ojos manantial \w de|strong="H3588"\w* lágrimas,  
\q1 \w para|strong="H3588"\w* \w que|strong="H3588"\w* llorase día \w y|strong="H3588"\w* noche  
\q2 \w por|strong="H3588"\w* \w los|strong="H3605"\w* muertos \w de|strong="H3588"\w* \w la|strong="H3605"\w* hija \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*!   
\q1
\v 2 ¡Quién \w me|strong="H3588"\w* diese \w en|strong="H3588"\w* \w el|strong="H3588"\w* desierto  
\q2 una posada \w de|strong="H3588"\w* caminantes,  
\q1 \w para|strong="H3588"\w* \w que|strong="H3588"\w* dejase \w a|strong="H3068"\w* mi pueblo  
\q2 \w y|strong="H3588"\w* \w me|strong="H3588"\w* apartase \w de|strong="H3588"\w* ellos!  
\q1 \w Porque|strong="H3588"\w* todos ellos \w son|strong="H3588"\w* adúlteros,  
\q2 congregación \w de|strong="H3588"\w* traidores.   
\q1
\v 3 «Tensaron \w su|strong="H3588"\w* lengua \w como|strong="H3588"\w* un arco \w para|strong="H5921"\w* \w la|strong="H5921"\w* mentira;  
\q2 \w se|strong="H5921"\w* fortalecieron \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w pero|strong="H3588"\w* \w no|strong="H3588"\w* \w para|strong="H5921"\w* \w la|strong="H5921"\w* verdad;  
\q1 \w porque|strong="H3588"\w* \w de|strong="H5921"\w* mal \w en|strong="H5921"\w* mal procedieron,  
\q2 \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w no|strong="H3588"\w* \w me|strong="H5921"\w* conocieron», dice Yahvé.   
\q1
\v 4 «Guardaos cada uno \w de|strong="H3811"\w* su \w prójimo|strong="H7453"\w*,  
\q2 y en \w ningún|strong="H3808"\w* hermano confiéis;  
\q1 \w porque|strong="H3808"\w* todo hermano suplanta con \w engaño|strong="H8267"\w*,  
\q2 y todo \w prójimo|strong="H7453"\w* anda calumniando.   
\q1
\v 5 Cada uno engaña \w a|strong="H3068"\w* su compañero,  
\q2 y \w no|strong="H3985"\w* dicen la verdad;  
\q1 enseñaron su lengua \w a|strong="H3068"\w* hablar mentira,  
\q2 \w se|strong="H3045"\w* afanan por cometer iniquidad.   
\q1
\v 6 \w Tu|strong="H6213"\w* morada \w está|strong="H3651"\w* \w en|strong="H3588"\w* medio del engaño;  
\q2 \w por|strong="H3588"\w* \w causa|strong="H6440"\w* del engaño \w no|strong="H6213"\w* quisieron conocerme», dice Yahvé.   
\p
\v 7 Por tanto, \w así|strong="H1696"\w* \w dice|strong="H1696"\w* Yahvé de los Ejércitos:  
\q1 “He aquí \w que|strong="H6310"\w* yo los fundiré y los probaré;  
\q2 porque ¿\w qué|strong="H6310"\w* \w más|strong="H7453"\w* he de hacer por la hija de mi pueblo?   
\q1
\v 8 Saeta mortífera \w es|strong="H2088"\w* \w la|strong="H5921"\w* lengua \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*; engaño habla.  
\q2 \w Con|strong="H5921"\w* su boca habla paz \w con|strong="H5921"\w* su prójimo,  
\q1 pero \w en|strong="H5921"\w* su interior \w le|strong="H5921"\w* pone acechanza.   
\q1
\v 9 ¿\w No|strong="H3808"\w* \w los|strong="H5921"\w* he \w de|strong="H5921"\w* castigar \w por|strong="H5921"\w* estas cosas? — dice Yahvé —.  
\q2 ¿\w De|strong="H5921"\w* una nación \w como|strong="H3588"\w* \w esta|strong="H5921"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* vengará \w mi|strong="H5921"\w* alma?   
\q1
\v 10 \w Por|strong="H5414"\w* \w los|strong="H3427"\w* montes levantaré lloro y lamentación,  
\q2 y llanto \w por|strong="H5414"\w* \w los|strong="H3427"\w* pastizales del desierto;  
\q1 porque han sido incendiados \w hasta|strong="H1097"\w* \w no|strong="H1097"\w* quedar quien pase \w por|strong="H5414"\w* ellos,  
\q2 \w ni|strong="H1097"\w* se oye ya bramido \w de|strong="H5414"\w* ganado;  
\q1 desde las aves del cielo \w hasta|strong="H1097"\w* las bestias,  
\q2 todas huyeron y se fueron.   
\b  
\q1
\v 11 «Reduciré \w a|strong="H3068"\w* Jerusalén \w a|strong="H3068"\w* montones \w de|strong="H5921"\w* ruinas,  
\q2 \w a|strong="H3068"\w* morada \w de|strong="H5921"\w* chacales;  
\q1 \w y|strong="H5921"\w* asolaré \w las|strong="H5921"\w* ciudades \w de|strong="H5921"\w* Judá  
\q2 \w hasta|strong="H5921"\w* \w que|strong="H4100"\w* queden \w sin|strong="H1097"\w* morador».   
\p
\v 12 ¿Quién es hombre sabio \w que|strong="H3808"\w* \w entienda|strong="H8085"\w* esto? ¿\w Y|strong="H3068"\w* \w a|strong="H3068"\w* quién habló \w la|strong="H5921"\w* boca \w de|strong="H5921"\w* Yahvé, \w para|strong="H5921"\w* \w que|strong="H3808"\w* pueda declararlo? ¿\w Por|strong="H5921"\w* \w qué|strong="H3808"\w* \w causa|strong="H6440"\w* \w ha|strong="H3808"\w* perecido \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w ha|strong="H3808"\w* sido asolada \w como|strong="H5921"\w* desierto, \w hasta|strong="H5921"\w* \w no|strong="H3808"\w* \w haber|strong="H3808"\w* quien pase \w por|strong="H5921"\w* \w ella|strong="H5921"\w*?   
\p
\v 13 \w Y|strong="H3068"\w* dijo Yahvé: «Porque dejaron mi ley, la cual puse delante de ellos, y no obedecieron \w a|strong="H3068"\w* mi voz, ni \w caminaron|strong="H3212"\w* conforme \w a|strong="H3068"\w* ella;  
\v 14 \w antes|strong="H2088"\w* \w bien|strong="H3651"\w*, \w se|strong="H3651"\w* fueron tras la dureza \w de|strong="H5971"\w* su corazón, \w y|strong="H3541"\w* tras los baales, según les enseñaron sus padres».  
\v 15 \w Por|strong="H5704"\w* tanto, \w así|strong="H1992"\w* dice Yahvé \w de|strong="H5704"\w* \w los|strong="H1992"\w* Ejércitos, Dios \w de|strong="H5704"\w* Israel: «He aquí \w que|strong="H3808"\w* \w a|strong="H3068"\w* este \w pueblo|strong="H1992"\w* yo \w les|strong="H1992"\w* daré \w a|strong="H3068"\w* comer ajenjo, \w y|strong="H5704"\w* \w les|strong="H1992"\w* daré \w a|strong="H3068"\w* beber agua \w de|strong="H5704"\w* hiel.  
\v 16 \w Y|strong="H3068"\w* \w los|strong="H2450"\w* dispersaré entre naciones \w que|strong="H3541"\w* ni ellos ni sus padres conocieron; \w y|strong="H3541"\w* \w enviaré|strong="H7971"\w* espada en pos de ellos, hasta \w que|strong="H3541"\w* \w los|strong="H2450"\w* acabe».   
\p
\v 17 Así dice Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* Ejércitos:  
\q1 “Considerad \w y|strong="H5921"\w* llamad \w a|strong="H3068"\w* \w las|strong="H5921"\w* endechadoras \w para|strong="H5921"\w* \w que|strong="H5921"\w* vengan;  
\q2 enviad \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w que|strong="H5921"\w* son hábiles \w en|strong="H5921"\w* su oficio.   
\q1
\v 18 ¡\w Que|strong="H3588"\w* se den prisa  
\q2 \w y|strong="H3588"\w* levanten \w llanto|strong="H5092"\w* \w por|strong="H3588"\w* nosotros!  
\q1 Desháganse nuestros ojos \w en|strong="H3588"\w* lágrimas,  
\q2 \w y|strong="H3588"\w* nuestros párpados fluyan \w en|strong="H3588"\w* aguas.   
\q1
\v 19 \w Porque|strong="H3588"\w* \w de|strong="H3588"\w* Sión se \w oyó|strong="H8085"\w* voz \w de|strong="H3588"\w* \w lamentación|strong="H7015"\w*:  
\q2 ‘¡\w Cómo|strong="H3588"\w* hemos sido arruinados!  
\q1 \w En|strong="H3588"\w* gran \w manera|strong="H1697"\w* hemos sido avergonzados,  
\q2 \w porque|strong="H3588"\w* hemos abandonado \w la|strong="H3588"\w* tierra,  
\q2 \w y|strong="H3588"\w* han derribado nuestras moradas’”.   
\b  
\q1
\v 20 Oíd, \w pues|strong="H3588"\w*, oh mujeres, \w la|strong="H3588"\w* palabra \w de|strong="H3588"\w* Yahvé;  
\q2 recibid vuestros oídos \w la|strong="H3588"\w* palabra \w de|strong="H3588"\w* \w su|strong="H3588"\w* boca.  
\q1 Enseñad endechas \w a|strong="H3068"\w* vuestras hijas,  
\q2 \w y|strong="H3588"\w* cada una lamento \w a|strong="H3068"\w* \w su|strong="H3588"\w* compañera.   
\q1
\v 21 \w Porque|strong="H5921"\w* \w la|strong="H5921"\w* muerte \w ha|strong="H3541"\w* subido \w por|strong="H5921"\w* nuestras ventanas,  
\q2 \w ha|strong="H3541"\w* entrado \w en|strong="H5921"\w* nuestros palacios,  
\q1 \w para|strong="H5921"\w* cortar \w a|strong="H3068"\w* \w los|strong="H5921"\w* niños \w de|strong="H5921"\w* \w las|strong="H5921"\w* calles  
\q2 \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* jóvenes \w de|strong="H5921"\w* \w las|strong="H5921"\w* plazas.   
\p
\v 22 Di: “\w Así|strong="H3541"\w* dice Yahvé:  
\q1 ‘\w Los|strong="H2450"\w* cadáveres de \w los|strong="H2450"\w* \w hombres|strong="H1368"\w* caerán como estiércol sobre \w la|strong="H2451"\w* faz del campo,  
\q2 como manojo tras el segador,  
\q2 \w y|strong="H3541"\w* no habrá quien \w los|strong="H2450"\w* recoja’”.   
\p
\v 23 \w Así|strong="H2063"\w* \w dice|strong="H5002"\w* Yahvé:  
\q1 «\w No|strong="H6213"\w* \w se|strong="H3045"\w* \w alabe|strong="H1984"\w* \w el|strong="H3588"\w* sabio \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w sabiduría|strong="H3045"\w*,  
\q2 ni \w en|strong="H3588"\w* \w su|strong="H3588"\w* valentía \w se|strong="H3045"\w* \w alabe|strong="H1984"\w* \w el|strong="H3588"\w* valiente,  
\q2 ni \w el|strong="H3588"\w* rico \w se|strong="H3045"\w* \w alabe|strong="H1984"\w* \w en|strong="H3588"\w* sus riquezas.   
\q1
\v 24 \w Mas|strong="H5921"\w* alábese \w en|strong="H5921"\w* esto \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* hubiere \w de|strong="H5921"\w* alabar:  
\q2 \w en|strong="H5921"\w* entenderme \w y|strong="H5921"\w* conocerme,  
\q1 \w que|strong="H5921"\w* \w yo|strong="H2009"\w* soy Yahvé, \w que|strong="H5921"\w* hago misericordia, juicio \w y|strong="H5921"\w* justicia \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra;  
\q2 \w porque|strong="H5921"\w* estas cosas quiero», \w dice|strong="H5002"\w* Yahvé.   
\p
\v 25 «He aquí \w que|strong="H3588"\w* vienen días — dice Yahvé — \w en|strong="H5921"\w* \w que|strong="H3588"\w* castigaré \w a|strong="H3068"\w* \w todo|strong="H3605"\w* circuncidado \w que|strong="H3588"\w* \w lo|strong="H5921"\w* \w es|strong="H3588"\w* solo \w en|strong="H5921"\w* \w la|strong="H5921"\w* carne:  
\v 26 \w a|strong="H3068"\w* Egipto y \w a|strong="H3068"\w* Judá, \w a|strong="H3068"\w* Edom y \w a|strong="H3068"\w* los hijos de Amón y de Moab, y \w a|strong="H3068"\w* todos los que se rapan las sienes y habitan en el desierto; porque todas las naciones son incircuncisas, y toda la casa de Israel es incircuncisa de corazón».   
\c 10
\p
\v 1 ¡\w Escuchad|strong="H8085"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w que|strong="H5921"\w* Yahvé \w os|strong="H5921"\w* \w dice|strong="H1696"\w*, \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*!  
\v 2 \w Así|strong="H3541"\w* dice Yahvé:  
\q1 «\w No|strong="H3588"\w* \w aprendáis|strong="H3925"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w*,  
\q2 ni \w de|strong="H3588"\w* \w las|strong="H1992"\w* señales del \w cielo|strong="H8064"\w* tengáis temor,  
\q2 \w aunque|strong="H3588"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w* \w las|strong="H1992"\w* \w teman|strong="H2865"\w*.   
\q1
\v 3 \w Porque|strong="H3588"\w* las costumbres \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w pueblos|strong="H5971"\w* \w son|strong="H3588"\w* \w vanidad|strong="H1892"\w*;  
\q2 \w porque|strong="H3588"\w* un \w leño|strong="H6086"\w* del \w bosque|strong="H3293"\w* cortan,  
\q2 \w obra|strong="H4639"\w* \w de|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w artífice|strong="H2796"\w* \w con|strong="H3588"\w* \w la|strong="H1931"\w* azuela.   
\q1
\v 4 Con \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w* \w lo|strong="H3808"\w* adornan;  
\q2 con clavos y martillos \w lo|strong="H3808"\w* afianzan  
\q2 para \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* mueva.   
\q1
\v 5 Derechos están \w como|strong="H3588"\w* palmera, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w hablan|strong="H1696"\w*;  
\q2 \w son|strong="H3588"\w* llevados,  
\q2 \w porque|strong="H3588"\w* \w no|strong="H3808"\w* pueden andar.  
\q1 \w No|strong="H3808"\w* tengáis \w temor|strong="H3372"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*,  
\q2 \w porque|strong="H3588"\w* \w ni|strong="H3808"\w* pueden hacer \w mal|strong="H7489"\w*,  
\q2 \w ni|strong="H3808"\w* \w para|strong="H3588"\w* hacer \w bien|strong="H3190"\w* \w tienen|strong="H1992"\w* poder».   
\q1
\v 6 No hay nadie semejante \w a|strong="H3068"\w* ti, Yahvé;  
\q2 \w grande|strong="H1419"\w* eres tú,  
\q2 y \w grande|strong="H1419"\w* es tu \w nombre|strong="H8034"\w* en poderío.   
\q1
\v 7 ¿\w Quién|strong="H4310"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w temerá|strong="H3372"\w*,  
\q2 \w oh|strong="H4310"\w* \w Rey|strong="H4428"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w*?  
\q2 \w Porque|strong="H3588"\w* \w a|strong="H3068"\w* ti \w se|strong="H3808"\w* \w te|strong="H3588"\w* debe \w el|strong="H3588"\w* \w temor|strong="H3372"\w*;  
\q1 \w porque|strong="H3588"\w* \w entre|strong="H3808"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w sabios|strong="H2450"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w*  
\q2 \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w todos|strong="H3605"\w* sus \w reinos|strong="H4438"\w*,  
\q2 \w no|strong="H3808"\w* \w hay|strong="H3372"\w* \w nadie|strong="H3808"\w* semejante \w a|strong="H3068"\w* ti.   
\q1
\v 8 Todos \w ellos|strong="H1931"\w* son torpes \w y|strong="H1197"\w* necios;  
\q2 \w la|strong="H1931"\w* \w enseñanza|strong="H4148"\w* de las \w vanidades|strong="H1892"\w*  
\q2 no \w es|strong="H1931"\w* más \w que|strong="H1931"\w* un \w leño|strong="H6086"\w*.   
\q1
\v 9 Traen \w plata|strong="H3701"\w* batida de \w Tarsis|strong="H8659"\w*  
\q2 y \w oro|strong="H2091"\w* de Ufaz,  
\q2 \w obra|strong="H4639"\w* del \w artífice|strong="H2796"\w* y de \w manos|strong="H3027"\w* del \w fundidor|strong="H6884"\w*;  
\q1 de azul y de púrpura son sus vestidos;  
\q2 \w todo|strong="H3605"\w* \w es|strong="H3027"\w* \w obra|strong="H4639"\w* de peritos.   
\q1
\v 10 \w Mas|strong="H1471"\w* Yahvé \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w Dios|strong="H3068"\w* verdadero;  
\q2 \w él|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w Dios|strong="H3068"\w* \w vivo|strong="H2416"\w*  
\q2 y \w el|strong="H1931"\w* \w Rey|strong="H4428"\w* \w eterno|strong="H5769"\w*;  
\q1 ante \w su|strong="H1931"\w* \w ira|strong="H7110"\w* \w tiembla|strong="H7493"\w* \w la|strong="H1931"\w* tierra,  
\q2 y las \w naciones|strong="H1471"\w* \w no|strong="H3808"\w* pueden \w sufrir|strong="H3557"\w* \w su|strong="H1931"\w* indignación.   
\p
\v 11 “Les diréis \w esto|strong="H1836"\w*: ‘Los dioses \w que|strong="H1768"\w* \w no|strong="H3809"\w* \w hicieron|strong="H5648"\w* los cielos \w ni|strong="H3809"\w* la tierra, desaparezcan \w de|strong="H4481"\w* la tierra \w y|strong="H3809"\w* \w de|strong="H4481"\w* \w debajo|strong="H8460"\w* \w de|strong="H4481"\w* los cielos’”.   
\q1
\v 12 \w Él|strong="H6213"\w* es \w el|strong="H6213"\w* \w que|strong="H3581"\w* \w hizo|strong="H6213"\w* \w la|strong="H2451"\w* tierra con su \w poder|strong="H3581"\w*,  
\q2 \w el|strong="H6213"\w* \w que|strong="H3581"\w* puso en orden \w el|strong="H6213"\w* \w mundo|strong="H8398"\w* con su saber,  
\q2 y \w extendió|strong="H5186"\w* los \w cielos|strong="H8064"\w* con su \w inteligencia|strong="H8394"\w*.   
\q1
\v 13 Cuando emite su \w voz|strong="H6963"\w*,  
\q2 hay estrépito \w de|strong="H5414"\w* \w aguas|strong="H4325"\w* \w en|strong="H3318"\w* los \w cielos|strong="H8064"\w*,  
\q2 y \w hace|strong="H6213"\w* \w subir|strong="H5927"\w* las \w nubes|strong="H5387"\w* \w de|strong="H5414"\w* los confines \w de|strong="H5414"\w* la tierra;  
\q1 \w hace|strong="H6213"\w* los \w relámpagos|strong="H1300"\w* con la \w lluvia|strong="H4306"\w*,  
\q2 y \w saca|strong="H3318"\w* \w el|strong="H6213"\w* \w viento|strong="H7307"\w* \w de|strong="H5414"\w* sus depósitos.   
\q1
\v 14 \w Todo|strong="H3605"\w* hombre \w se|strong="H3808"\w* \w ha|strong="H3808"\w* vuelto torpe \w y|strong="H3588"\w* \w sin|strong="H3808"\w* \w ciencia|strong="H1847"\w*;  
\q2 \w todo|strong="H3605"\w* \w fundidor|strong="H6884"\w* \w se|strong="H3808"\w* avergüenza \w de|strong="H3588"\w* \w su|strong="H3588"\w* ídolo,  
\q1 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* estatua \w de|strong="H3588"\w* fundición \w es|strong="H3588"\w* \w mentira|strong="H8267"\w*,  
\q2 \w y|strong="H3588"\w* \w no|strong="H3808"\w* hay aliento \w en|strong="H3588"\w* \w ella|strong="H3605"\w*.   
\q1
\v 15 \w Vanidad|strong="H1892"\w* son, \w obra|strong="H4639"\w* \w de|strong="H6256"\w* escarnio;  
\q2 en \w el|strong="H1992"\w* \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* \w su|strong="H1992"\w* castigo perecerán.   
\q1
\v 16 \w No|strong="H3808"\w* \w es|strong="H1931"\w* \w como|strong="H3588"\w* \w ellos|strong="H1931"\w* \w la|strong="H1931"\w* porción \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*;  
\q2 \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* Hacedor \w de|strong="H3588"\w* \w todo|strong="H3605"\w*,  
\q1 \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w vara|strong="H7626"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w heredad|strong="H5159"\w*;  
\q2 Yahvé \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w Ejércitos|strong="H6635"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w nombre|strong="H8034"\w*.   
\q1
\v 17 Recoged de la tierra vuestros fardos,  
\q2 vosotros que vivís en \w el|strong="H3427"\w* asedio.   
\q1
\v 18 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé:  
\q2 «He \w aquí|strong="H3541"\w* \w que|strong="H3588"\w* \w esta|strong="H2063"\w* \w vez|strong="H6471"\w* arrojaré \w con|strong="H3588"\w* honda \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w moradores|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H2063"\w* tierra,  
\q2 \w y|strong="H3588"\w* \w los|strong="H1992"\w* atribularé \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w lo|strong="H1992"\w* sientan».   
\q1
\v 19 ¡Ay \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w por|strong="H5921"\w* \w mi|strong="H5921"\w* quebranto!  
\q2 \w Mi|strong="H5921"\w* \w llaga|strong="H4347"\w* \w es|strong="H2088"\w* muy dolorosa.  
\q1 Pero yo dije:  
\q2 «Ciertamente \w esta|strong="H2088"\w* \w es|strong="H2088"\w* \w mi|strong="H5921"\w* \w enfermedad|strong="H2483"\w*, \w y|strong="H5921"\w* debo sufrirla».   
\q1
\v 20 Mi tienda ha sido \w destruida|strong="H7703"\w*  
\q2 y \w todas|strong="H3605"\w* mis cuerdas están rotas;  
\q1 mis \w hijos|strong="H1121"\w* se fueron \w de|strong="H5750"\w* mí y ya no existen;  
\q2 no \w hay|strong="H5750"\w* ya \w quien|strong="H3605"\w* extienda mi tienda,  
\q2 ni \w quien|strong="H3605"\w* levante mis \w cortinas|strong="H3407"\w*.   
\q1
\v 21 \w Porque|strong="H3588"\w* \w los|strong="H5921"\w* \w pastores|strong="H7462"\w* \w se|strong="H5921"\w* han vuelto necios  
\q2 \w y|strong="H3588"\w* \w no|strong="H3808"\w* han buscado \w a|strong="H3068"\w* Yahvé;  
\q1 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w no|strong="H3808"\w* \w prosperaron|strong="H7919"\w*  
\q2 \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w su|strong="H3588"\w* rebaño \w se|strong="H5921"\w* dispersó.   
\q1
\v 22 He \w aquí|strong="H2009"\w* que viene \w estruendo|strong="H6963"\w* de noticias,  
\q2 y \w gran|strong="H1419"\w* conmoción de la tierra del \w norte|strong="H6828"\w*,  
\q1 para convertir las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w* en desierto,  
\q2 en \w morada|strong="H4583"\w* de chacales.   
\q1
\v 23 \w Conozco|strong="H3045"\w*, oh Yahvé, \w que|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w no|strong="H3808"\w* \w es|strong="H3588"\w* \w señor|strong="H3068"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w camino|strong="H1870"\w*,  
\q2 \w ni|strong="H3808"\w* del hombre \w que|strong="H3588"\w* \w camina|strong="H1980"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* ordenar sus \w pasos|strong="H6806"\w*.   
\q1
\v 24 \w Castígame|strong="H3256"\w*, oh Yahvé, mas con \w juicio|strong="H4941"\w*;  
\q2 \w no|strong="H6435"\w* con tu furor,  
\q2 para \w que|strong="H6435"\w* \w no|strong="H6435"\w* me aniquiles.   
\q1
\v 25 \w Derrama|strong="H8210"\w* tu \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* \w conocen|strong="H3045"\w*,  
\q2 \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w familias|strong="H4940"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w invocan|strong="H7121"\w* tu \w nombre|strong="H8034"\w*;  
\q1 \w porque|strong="H3588"\w* devoraron \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*,  
\q2 \w lo|strong="H3808"\w* devoraron \w y|strong="H3588"\w* \w lo|strong="H3808"\w* consumieron,  
\q2 \w y|strong="H3588"\w* asolaron \w su|strong="H3588"\w* \w morada|strong="H5116"\w*.   
\c 11
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H1697"\w* parte \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Oíd|strong="H8085"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w este|strong="H2063"\w* \w pacto|strong="H1285"\w*, \w y|strong="H5921"\w* \w hablad|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* varones \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén;  
\v 3 \w y|strong="H3541"\w* les dirás: ‘\w Así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*: Maldito el varón \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w obedeciere|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w este|strong="H2063"\w* \w pacto|strong="H1285"\w*,  
\v 4 \w el|strong="H3605"\w* cual \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* vuestros padres \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w que|strong="H5971"\w* \w los|strong="H3605"\w* \w saqué|strong="H3318"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*, del horno \w de|strong="H5971"\w* \w hierro|strong="H1270"\w*, diciendo: Obedeced \w mi|strong="H1961"\w* \w voz|strong="H6963"\w* y ponedlas por \w obra|strong="H6213"\w*, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H5971"\w* os \w mando|strong="H6680"\w*; y me \w seréis|strong="H1961"\w* por \w pueblo|strong="H5971"\w*, y \w yo|strong="H6680"\w* \w seré|strong="H1961"\w* \w a|strong="H3068"\w* \w vosotros|strong="H8085"\w* por Dios;  
\v 5 \w para|strong="H4616"\w* \w que|strong="H3117"\w* \w confirme|strong="H6965"\w* \w el|strong="H1992"\w* \w juramento|strong="H7621"\w* \w que|strong="H3117"\w* \w hice|strong="H7650"\w* \w a|strong="H3068"\w* vuestros padres, \w que|strong="H3117"\w* \w les|strong="H1992"\w* \w daría|strong="H5414"\w* la tierra \w que|strong="H3117"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* y \w miel|strong="H1706"\w*, como en \w este|strong="H2088"\w* \w día|strong="H3117"\w*’”.  
\p \w Entonces|strong="H3117"\w* \w respondí|strong="H6030"\w* y dije: «Amén, Yahvé».   
\p
\v 6 \w Y|strong="H3068"\w* Yahvé me dijo: “Proclama \w todas|strong="H3605"\w* \w estas|strong="H2063"\w* \w palabras|strong="H1697"\w* en las \w ciudades|strong="H5892"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w* y en las \w calles|strong="H2351"\w* \w de|strong="H1697"\w* Jerusalén, diciendo: ‘\w Oíd|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w este|strong="H2063"\w* \w pacto|strong="H1285"\w*, y ponedlas \w por|strong="H1697"\w* \w obra|strong="H6213"\w*’.  
\v 7 \w Porque|strong="H3588"\w* solemnemente \w protesté|strong="H5749"\w* \w a|strong="H3068"\w* vuestros padres \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w que|strong="H3588"\w* \w los|strong="H3588"\w* hice \w subir|strong="H5927"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H3588"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w hoy|strong="H3117"\w* madrugué \w y|strong="H3588"\w* \w protesté|strong="H5749"\w* diciendo: ‘Obedeced mi \w voz|strong="H6963"\w*’.  
\v 8 Pero \w no|strong="H3808"\w* \w oyeron|strong="H8085"\w*, \w ni|strong="H3808"\w* \w inclinaron|strong="H5186"\w* su \w oído|strong="H8085"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w anduvieron|strong="H3212"\w* \w cada|strong="H3605"\w* uno tras \w la|strong="H5921"\w* dureza \w de|strong="H5921"\w* su \w malvado|strong="H7451"\w* \w corazón|strong="H3820"\w*; \w por|strong="H5921"\w* \w tanto|strong="H5921"\w*, traje \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w este|strong="H2063"\w* \w pacto|strong="H1285"\w*, \w el|strong="H5921"\w* cual \w mandé|strong="H6680"\w* \w que|strong="H3808"\w* \w hiciesen|strong="H6213"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w lo|strong="H1697"\w* \w hicieron|strong="H6213"\w*”.   
\p
\v 9 \w Y|strong="H3068"\w* me dijo Yahvé: «Se ha \w hallado|strong="H4672"\w* conspiración entre \w los|strong="H3427"\w* varones de \w Judá|strong="H3063"\w* y entre \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Jerusalén.  
\v 10 \w Se|strong="H5921"\w* han \w vuelto|strong="H7725"\w* \w a|strong="H3068"\w* \w las|strong="H1992"\w* \w iniquidades|strong="H5771"\w* \w de|strong="H5921"\w* \w sus|strong="H1992"\w* \w primeros|strong="H7223"\w* padres, \w los|strong="H1992"\w* cuales \w no|strong="H3985"\w* \w quisieron|strong="H3985"\w* \w escuchar|strong="H8085"\w* mis \w palabras|strong="H1697"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w fueron|strong="H1980"\w* tras dioses ajenos \w para|strong="H5921"\w* servirles; \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w invalidaron|strong="H6565"\w* \w mi|strong="H5921"\w* \w pacto|strong="H1285"\w*, \w el|strong="H5921"\w* cual yo había concertado \w con|strong="H5921"\w* \w sus|strong="H1992"\w* padres».  
\v 11 \w Por|strong="H4480"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé: “He \w aquí|strong="H3541"\w* \w yo|strong="H4480"\w* traigo \w sobre|strong="H4480"\w* \w ellos|strong="H4480"\w* \w mal|strong="H7451"\w* \w del|strong="H4480"\w* \w que|strong="H4480"\w* \w no|strong="H3808"\w* \w podrán|strong="H3201"\w* escapar; \w y|strong="H3541"\w* \w clamarán|strong="H2199"\w* \w a|strong="H3068"\w* mí, \w y|strong="H3541"\w* \w no|strong="H3808"\w* los \w oiré|strong="H8085"\w*.  
\v 12 \w E|strong="H3068"\w* \w irán|strong="H1980"\w* \w las|strong="H1992"\w* \w ciudades|strong="H5892"\w* \w de|strong="H7451"\w* \w Judá|strong="H3063"\w* y \w los|strong="H1992"\w* \w moradores|strong="H3427"\w* \w de|strong="H7451"\w* Jerusalén, y \w clamarán|strong="H2199"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* dioses \w a|strong="H3068"\w* quienes queman \w ellos|strong="H1992"\w* incienso, \w los|strong="H1992"\w* cuales \w no|strong="H3808"\w* \w los|strong="H1992"\w* podrán \w salvar|strong="H3467"\w* en \w el|strong="H3427"\w* \w tiempo|strong="H6256"\w* \w de|strong="H7451"\w* \w su|strong="H1992"\w* \w mal|strong="H7451"\w*.  
\v 13 \w Porque|strong="H3588"\w* según \w el|strong="H3588"\w* \w número|strong="H4557"\w* \w de|strong="H3588"\w* tus \w ciudades|strong="H5892"\w* \w fueron|strong="H1961"\w* tus dioses, oh \w Judá|strong="H3063"\w*; \w y|strong="H3588"\w* según \w el|strong="H3588"\w* \w número|strong="H4557"\w* \w de|strong="H3588"\w* tus \w calles|strong="H2351"\w*, oh Jerusalén, \w pusiste|strong="H7760"\w* \w altares|strong="H4196"\w* \w a|strong="H3068"\w* lo \w vergonzoso|strong="H1322"\w*, \w altares|strong="H4196"\w* \w para|strong="H3588"\w* ofrecer incienso \w a|strong="H3068"\w* \w Baal|strong="H1168"\w*.   
\p
\v 14 «Tú, \w pues|strong="H3588"\w*, \w no|strong="H3588"\w* \w ores|strong="H6419"\w* \w por|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, ni \w levantes|strong="H5375"\w* \w por|strong="H3588"\w* ellos \w clamor|strong="H7440"\w* ni \w oración|strong="H8605"\w*; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w no|strong="H3588"\w* \w oiré|strong="H8085"\w* \w el|strong="H3588"\w* \w día|strong="H6256"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* aflicción clamen \w a|strong="H3068"\w* \w mí|strong="H5375"\w*.   
\q1
\v 15 ¿\w Qué|strong="H3588"\w* tiene \w mi|strong="H5921"\w* amado \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w*,  
\q2 habiendo cometido \w muchas|strong="H7227"\w* torpezas?  
\q2 ¿Acaso \w las|strong="H5921"\w* \w carnes|strong="H1320"\w* \w santas|strong="H6944"\w* alejarán \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w tu|strong="H6213"\w* \w mal|strong="H7451"\w*?  
\q1 \w Entonces|strong="H3588"\w*, \w cuando|strong="H3588"\w* \w haces|strong="H6213"\w* \w mal|strong="H7451"\w*,  
\q2 ¿\w te|strong="H5921"\w* glorías?».   
\b  
\q1
\v 16 «Olivo \w verde|strong="H7488"\w*, \w hermoso|strong="H3303"\w* \w en|strong="H5921"\w* su \w fruto|strong="H6529"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* su \w parecer|strong="H8389"\w*»,  
\q2 \w llamó|strong="H7121"\w* Yahvé tu \w nombre|strong="H8034"\w*.  
\q1 \w A|strong="H3068"\w* \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* \w gran|strong="H1419"\w* estrépito hizo encender fuego \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* quebrantaron sus ramas.   
\m
\v 17 \w Porque|strong="H5921"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w Ejércitos|strong="H6635"\w*, \w que|strong="H5921"\w* \w te|strong="H5921"\w* \w plantó|strong="H5193"\w*, ha pronunciado \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w maldad|strong="H7451"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* han \w hecho|strong="H6213"\w*, provocándome \w a|strong="H3068"\w* ira \w al|strong="H5921"\w* quemar incienso \w a|strong="H3068"\w* \w Baal|strong="H1168"\w*.   
\p
\v 18 \w Y|strong="H3068"\w* Yahvé me lo hizo \w saber|strong="H3045"\w*, y lo \w conocí|strong="H3045"\w*; entonces me hiciste \w ver|strong="H7200"\w* sus \w obras|strong="H4611"\w*.  
\v 19 \w Y|strong="H3068"\w* \w yo|strong="H3588"\w* era \w como|strong="H3588"\w* \w cordero|strong="H3532"\w* inocente \w que|strong="H3588"\w* llevan \w a|strong="H3068"\w* degollar, \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w entendía|strong="H3045"\w* \w que|strong="H3588"\w* \w maquinaban|strong="H2803"\w* \w designios|strong="H4284"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*, diciendo:  
\q1 «\w Destruyamos|strong="H7843"\w* \w el|strong="H5921"\w* \w árbol|strong="H6086"\w* \w con|strong="H5921"\w* \w su|strong="H3588"\w* fruto,  
\q2 \w y|strong="H3588"\w* cortémoslo \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w vivientes|strong="H2416"\w*,  
\q2 \w y|strong="H3588"\w* \w no|strong="H3808"\w* haya \w más|strong="H5750"\w* \w memoria|strong="H2142"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w*».   
\q1
\v 20 \w Pero|strong="H3588"\w*, oh Yahvé \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w Ejércitos|strong="H6635"\w*, \w que|strong="H3588"\w* juzgas \w con|strong="H3588"\w* \w justicia|strong="H6664"\w*,  
\q2 \w que|strong="H3588"\w* escudriñas \w los|strong="H1992"\w* \w riñones|strong="H3629"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w corazón|strong="H3820"\w*,  
\q1 \w vea|strong="H7200"\w* \w yo|strong="H3588"\w* \w tu|strong="H8199"\w* \w venganza|strong="H5360"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*;  
\q2 \w porque|strong="H3588"\w* ante ti he expuesto mi \w causa|strong="H7379"\w*.   
\p
\v 21 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* varones \w de|strong="H5921"\w* Anatot \w que|strong="H3808"\w* \w buscan|strong="H1245"\w* tu \w vida|strong="H5315"\w*, diciendo: «\w No|strong="H3808"\w* \w profetices|strong="H5012"\w* \w en|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* Yahvé, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* mueras \w a|strong="H3068"\w* nuestras \w manos|strong="H3027"\w*»;  
\v 22 \w así|strong="H3541"\w*, \w pues|strong="H3651"\w*, dice Yahvé \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w*: «He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* yo \w los|strong="H1121"\w* castigaré; \w los|strong="H1121"\w* jóvenes \w morirán|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, sus \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* sus \w hijas|strong="H1323"\w* \w morirán|strong="H4191"\w* \w de|strong="H5921"\w* \w hambre|strong="H7458"\w*,  
\v 23 \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w quedará|strong="H1961"\w* remanente \w de|strong="H3588"\w* ellos; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* traeré \w mal|strong="H7451"\w* \w sobre|strong="H1961"\w* \w los|strong="H1961"\w* \w varones|strong="H3588"\w* \w de|strong="H3588"\w* Anatot \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w año|strong="H8141"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w castigo|strong="H7451"\w*».   
\c 12
\q1
\v 1 \w Justo|strong="H6662"\w* eres tú, Yahvé,  
\q2 \w cuando|strong="H3588"\w* pleiteo contigo;  
\q1 sin embargo, quisiera discutir contigo un \w juicio|strong="H4941"\w*.  
\q2 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* prospera \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* malvados?  
\q2 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* gozan \w de|strong="H3588"\w* paz \w los|strong="H3605"\w* \w que|strong="H3588"\w* actúan \w con|strong="H3588"\w* tanta alevosía?   
\q1
\v 2 Los has \w plantado|strong="H5193"\w*, \w y|strong="H1571"\w* echaron raíces;  
\q2 crecen \w y|strong="H1571"\w* producen \w fruto|strong="H6529"\w*.  
\q1 \w Cerca|strong="H7138"\w* \w estás|strong="H6213"\w* \w tú|strong="H6213"\w* de sus labios,  
\q2 pero \w lejos|strong="H7350"\w* de su corazón.   
\q1
\v 3 Pero tú, Yahvé, me \w conoces|strong="H3045"\w*;  
\q2 me \w ves|strong="H7200"\w* y pruebas mi \w corazón|strong="H3820"\w* para contigo.  
\q1 Arrástralos como \w a|strong="H3068"\w* \w ovejas|strong="H6629"\w* para el matadero,  
\q2 y prepáralos para el \w día|strong="H3117"\w* de la matanza.   
\q1
\v 4 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H3588"\w* \w estará|strong="H3427"\w* \w de|strong="H3588"\w* luto \w la|strong="H3588"\w* tierra,  
\q2 \w y|strong="H3588"\w* \w se|strong="H3808"\w* marchitará \w la|strong="H3588"\w* \w hierba|strong="H6212"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w*?  
\q1 \w Por|strong="H3588"\w* \w la|strong="H3588"\w* \w maldad|strong="H7451"\w* \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w habitan|strong="H3427"\w*,  
\q2 perecen las bestias \w y|strong="H3588"\w* las \w aves|strong="H5775"\w*;  
\q1 \w pues|strong="H3588"\w* dijeron:  
\q2 «\w Él|strong="H3588"\w* \w no|strong="H3808"\w* \w verá|strong="H7200"\w* nuestro fin».   
\q1
\v 5 «\w Si|strong="H3588"\w* \w corriste|strong="H7323"\w* \w con|strong="H3588"\w* \w los|strong="H3588"\w* peones \w y|strong="H3588"\w* \w te|strong="H3588"\w* cansaron,  
\q2 ¿\w cómo|strong="H3588"\w* competirás \w con|strong="H3588"\w* \w los|strong="H3588"\w* \w caballos|strong="H5483"\w*?  
\q1 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w en|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w paz|strong="H7965"\w* \w no|strong="H6213"\w* estabas seguro,  
\q2 ¿\w qué|strong="H3588"\w* \w harás|strong="H6213"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* espesura del \w Jordán|strong="H3383"\w*?   
\q1
\v 6 \w Porque|strong="H3588"\w* incluso tus hermanos \w y|strong="H1571"\w* \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* tu padre,  
\q2 \w aun|strong="H1571"\w* \w ellos|strong="H1992"\w* \w te|strong="H3588"\w* han traicionado;  
\q2 \w aun|strong="H1571"\w* \w ellos|strong="H1992"\w* han gritado tras \w de|strong="H3588"\w* ti \w a|strong="H3068"\w* plena voz.  
\q1 \w No|strong="H3588"\w* \w les|strong="H1992"\w* creas  
\q2 \w aunque|strong="H3588"\w* \w te|strong="H3588"\w* \w hablen|strong="H1696"\w* \w con|strong="H3588"\w* \w palabras|strong="H1696"\w* \w hermosas|strong="H2896"\w*».   
\b  
\q1
\v 7 «He abandonado \w mi|strong="H5315"\w* \w casa|strong="H1004"\w*,  
\q2 he \w desamparado|strong="H5800"\w* \w mi|strong="H5315"\w* \w heredad|strong="H5159"\w*;  
\q2 he \w entregado|strong="H5414"\w* lo que más amaba \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* en \w manos|strong="H3709"\w* \w de|strong="H5414"\w* sus enemigos.   
\q1
\v 8 \w Mi|strong="H5921"\w* \w heredad|strong="H5159"\w* \w se|strong="H1961"\w* ha vuelto \w para|strong="H5921"\w* \w mí|strong="H5921"\w* \w como|strong="H1961"\w* león \w en|strong="H5921"\w* \w la|strong="H5921"\w* selva;  
\q2 \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* lanzó su rugido,  
\q2 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w la|strong="H5921"\w* he aborrecido.   
\q1
\v 9 ¿Es \w mi|strong="H5921"\w* \w heredad|strong="H5159"\w* \w para|strong="H5921"\w* \w mí|strong="H5921"\w* \w como|strong="H5921"\w* un \w ave|strong="H5861"\w* \w de|strong="H5921"\w* rapiña moteada?  
\q2 ¿Están \w las|strong="H5921"\w* \w aves|strong="H5861"\w* \w de|strong="H5921"\w* rapiña \w contra|strong="H5921"\w* \w ella|strong="H3605"\w* \w en|strong="H5921"\w* \w derredor|strong="H5439"\w*?  
\q1 \w Id|strong="H3212"\w*, reunid \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* fieras \w del|strong="H5921"\w* \w campo|strong="H7704"\w*,  
\q2 traedlas \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* devoren.   
\q1
\v 10 \w Muchos|strong="H7227"\w* \w pastores|strong="H7462"\w* han \w destruido|strong="H8077"\w* mi \w viña|strong="H3754"\w*,  
\q2 han hollado mi heredad;  
\q2 han convertido mi \w preciosa|strong="H2532"\w* parcela en un \w desierto|strong="H4057"\w* desolado.   
\q1
\v 11 \w La|strong="H5921"\w* han \w asolado|strong="H8077"\w*;  
\q2 \w y|strong="H3588"\w* estando \w desolada|strong="H8077"\w*, llora ante \w mí|strong="H5921"\w*.  
\q1 \w Toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra ha sido devastada,  
\q2 \w porque|strong="H3588"\w* \w no|strong="H3588"\w* hay \w nadie|strong="H3605"\w* \w que|strong="H3588"\w* reflexione \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w*.   
\q1
\v 12 \w Sobre|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* alturas yermas \w del|strong="H5921"\w* \w desierto|strong="H4057"\w* vinieron destruidores;  
\q2 \w porque|strong="H3588"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w de|strong="H5921"\w* Yahvé devora \w desde|strong="H5704"\w* un \w extremo|strong="H7097"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w otro|strong="H7097"\w*.  
\q2 \w No|strong="H3588"\w* hay \w paz|strong="H7965"\w* \w para|strong="H5704"\w* \w ningún|strong="H3605"\w* mortal.   
\q1
\v 13 \w Sembraron|strong="H2232"\w* \w trigo|strong="H2406"\w* y cosecharon \w espinos|strong="H6975"\w*;  
\q2 \w se|strong="H3808"\w* esforzaron, \w mas|strong="H3808"\w* de \w nada|strong="H3808"\w* les aprovechó.  
\q1 Os avergonzaréis de vuestras cosechas  
\q2 \w a|strong="H3068"\w* causa del ardor de la \w ira|strong="H2740"\w* de Yahvé».   
\b  
\p
\v 14 \w Así|strong="H3541"\w* dice Yahvé: “\w En|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* mis \w malos|strong="H7451"\w* \w vecinos|strong="H7934"\w*, \w que|strong="H5921"\w* tocan \w la|strong="H5921"\w* \w heredad|strong="H5159"\w* \w que|strong="H5921"\w* hice poseer \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*: He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* yo \w los|strong="H5921"\w* \w arrancaré|strong="H5428"\w* \w de|strong="H5921"\w* su tierra, \w y|strong="H5921"\w* \w arrancaré|strong="H5428"\w* \w de|strong="H5921"\w* \w entre|strong="H8432"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 15 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H1961"\w*, \w después|strong="H1961"\w* de haberlos arrancado, \w volveré|strong="H7725"\w* \w a|strong="H3068"\w* \w tener|strong="H1961"\w* \w misericordia|strong="H7355"\w* de ellos; y \w los|strong="H1961"\w* haré \w volver|strong="H7725"\w*, cada uno \w a|strong="H3068"\w* su \w heredad|strong="H5159"\w* y cada cual \w a|strong="H3068"\w* su tierra.  
\v 16 \w Y|strong="H3068"\w* \w si|strong="H1961"\w* \w aprenden|strong="H3925"\w* con diligencia \w los|strong="H1961"\w* \w caminos|strong="H1870"\w* \w de|strong="H5971"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*, \w para|strong="H1961"\w* jurar \w en|strong="H8432"\w* \w mi|strong="H1961"\w* \w nombre|strong="H8034"\w*: ‘\w Vive|strong="H2416"\w* Yahvé’, así \w como|strong="H1961"\w* ellos enseñaron \w a|strong="H3068"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* jurar \w por|strong="H1870"\w* \w Baal|strong="H1168"\w*, entonces \w serán|strong="H1961"\w* establecidos \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5971"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*.  
\v 17 Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* escucharen, \w arrancaré|strong="H5428"\w* \w a|strong="H3068"\w* \w esa|strong="H1931"\w* \w nación|strong="H1471"\w*, arrancándola y destruyéndola”, \w dice|strong="H5002"\w* Yahvé.   
\c 13
\p
\v 1 Yahvé \w me|strong="H5921"\w* dijo \w así|strong="H3541"\w*: «\w Ve|strong="H1980"\w* \w y|strong="H5921"\w* \w cómprate|strong="H7069"\w* un ceñidor \w de|strong="H5921"\w* \w lino|strong="H6593"\w*, cíñetelo \w a|strong="H3068"\w* \w la|strong="H5921"\w* cintura \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* metas \w en|strong="H5921"\w* \w agua|strong="H4325"\w*».   
\p
\v 2 Compré, pues, \w el|strong="H5921"\w* ceñidor \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w lo|strong="H1697"\w* ceñí \w a|strong="H3068"\w* \w la|strong="H5921"\w* cintura.   
\p
\v 3 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w por|strong="H1697"\w* \w segunda|strong="H8145"\w* vez, diciendo:  
\v 4 «\w Toma|strong="H3947"\w* \w el|strong="H5921"\w* ceñidor \w que|strong="H5921"\w* \w compraste|strong="H7069"\w*, \w que|strong="H5921"\w* \w está|strong="H6965"\w* \w sobre|strong="H5921"\w* tu cintura, \w y|strong="H5921"\w* \w levántate|strong="H6965"\w*, \w ve|strong="H3212"\w* \w al|strong="H5921"\w* \w Éufrates|strong="H6578"\w* \w y|strong="H5921"\w* escóndelo \w allí|strong="H8033"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* hendidura \w de|strong="H5921"\w* una \w peña|strong="H5553"\w*».   
\p
\v 5 \w Fui|strong="H3212"\w*, pues, y lo escondí junto al \w Éufrates|strong="H6578"\w*, \w como|strong="H2934"\w* Yahvé me había \w mandado|strong="H6680"\w*.   
\p
\v 6 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H3117"\w* \w después|strong="H1961"\w* de \w muchos|strong="H7227"\w* \w días|strong="H3117"\w* me dijo Yahvé: «\w Levántate|strong="H6965"\w*, \w ve|strong="H3212"\w* al \w Éufrates|strong="H6578"\w* y \w toma|strong="H3947"\w* de \w allí|strong="H8033"\w* el ceñidor \w que|strong="H3117"\w* te \w mandé|strong="H6680"\w* \w que|strong="H3117"\w* escondieses \w allá|strong="H8033"\w*».   
\p
\v 7 Entonces \w fui|strong="H3808"\w* \w al|strong="H4480"\w* \w Éufrates|strong="H6578"\w*, y cavé, y \w tomé|strong="H3947"\w* \w el|strong="H3605"\w* ceñidor \w del|strong="H4480"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \w lo|strong="H3808"\w* había escondido; y he \w aquí|strong="H2009"\w* \w que|strong="H4480"\w* \w el|strong="H3605"\w* ceñidor \w estaba|strong="H2009"\w* podrido; \w para|strong="H4480"\w* \w ninguna|strong="H3605"\w* \w cosa|strong="H3605"\w* era bueno.   
\p
\v 8 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 9 “\w Así|strong="H3541"\w* dice Yahvé: ‘De esta manera haré podrir la \w soberbia|strong="H1347"\w* de \w Judá|strong="H3063"\w* \w y|strong="H3541"\w* la \w mucha|strong="H7227"\w* altivez de Jerusalén.  
\v 10 \w Este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w malo|strong="H7451"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* quiere \w oír|strong="H8085"\w* mis \w palabras|strong="H1697"\w*, \w que|strong="H3808"\w* \w anda|strong="H3212"\w* \w en|strong="H3212"\w* \w la|strong="H3605"\w* dureza \w de|strong="H5971"\w* \w su|strong="H1992"\w* \w corazón|strong="H3820"\w* y \w que|strong="H3808"\w* \w va|strong="H3068"\w* tras dioses ajenos \w para|strong="H1961"\w* servirles y \w para|strong="H1961"\w* postrarse ante \w ellos|strong="H1992"\w*, \w vendrá|strong="H1961"\w* \w a|strong="H3068"\w* ser \w como|strong="H1961"\w* \w este|strong="H2088"\w* ceñidor, \w que|strong="H3808"\w* \w para|strong="H1961"\w* \w ninguna|strong="H3605"\w* \w cosa|strong="H1697"\w* \w es|strong="H1961"\w* bueno.  
\v 11 \w Porque|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* ceñidor \w se|strong="H1961"\w* pega \w a|strong="H3068"\w* \w la|strong="H3588"\w* cintura del hombre, \w así|strong="H3651"\w* hice \w que|strong="H3588"\w* \w se|strong="H1961"\w* pegase \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* — \w dice|strong="H5002"\w* Yahvé —, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* fuesen \w por|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* renombre, \w por|strong="H3588"\w* \w alabanza|strong="H8416"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w gloria|strong="H8597"\w*; \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w escucharon|strong="H8085"\w*’.   
\p
\v 12 “Les dirás, \w pues|strong="H3588"\w*, \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*: ‘\w Así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: «\w Toda|strong="H3605"\w* tinaja \w se|strong="H3045"\w* \w llenará|strong="H4390"\w* \w de|strong="H3588"\w* \w vino|strong="H3196"\w*»’. \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* \w te|strong="H3588"\w* dirán: ‘¿Acaso \w no|strong="H3808"\w* \w sabemos|strong="H3045"\w* \w de|strong="H3588"\w* sobra \w que|strong="H3588"\w* \w toda|strong="H3605"\w* tinaja \w se|strong="H3045"\w* \w llenará|strong="H4390"\w* \w de|strong="H3588"\w* \w vino|strong="H3196"\w*?’  
\v 13 Entonces \w les|strong="H5921"\w* dirás: ‘\w Así|strong="H3541"\w* dice Yahvé: «He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* yo \w lleno|strong="H4390"\w* \w de|strong="H5921"\w* embriaguez \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* \w esta|strong="H2063"\w* tierra, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* estirpe \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* sientan \w sobre|strong="H5921"\w* su \w trono|strong="H3678"\w*, \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w profetas|strong="H5030"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén.  
\v 14 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* estrellaré \w el|strong="H1121"\w* uno contra \w el|strong="H1121"\w* otro, \w los|strong="H1121"\w* padres con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w juntamente|strong="H3162"\w* — \w dice|strong="H5002"\w* Yahvé —; \w no|strong="H3808"\w* \w perdonaré|strong="H2550"\w*, \w ni|strong="H3808"\w* tendré piedad \w ni|strong="H3808"\w* \w misericordia|strong="H2550"\w*, para dejar \w de|strong="H1121"\w* \w destruirlos|strong="H7843"\w*»’”.   
\q1
\v 15 \w Escuchad|strong="H8085"\w* \w y|strong="H3588"\w* prestad atención; \w no|strong="H3588"\w* seáis altivos,  
\q2 \w porque|strong="H3588"\w* Yahvé ha \w hablado|strong="H1696"\w*.   
\q1
\v 16 \w Dad|strong="H5414"\w* \w gloria|strong="H3519"\w* \w a|strong="H3068"\w* Yahvé vuestro \w Dios|strong="H3068"\w*,  
\q2 \w antes|strong="H2962"\w* \w que|strong="H5921"\w* \w haga|strong="H5414"\w* venir \w las|strong="H5921"\w* tinieblas,  
\q2 \w y|strong="H5921"\w* \w antes|strong="H2962"\w* \w que|strong="H5921"\w* vuestros \w pies|strong="H7272"\w* \w tropiecen|strong="H5062"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w* \w de|strong="H5921"\w* \w oscuridad|strong="H6205"\w*;  
\q1 \w y|strong="H5921"\w* esperéis \w la|strong="H5921"\w* \w luz|strong="H6757"\w*,  
\q2 \w y|strong="H5921"\w* \w él|strong="H5921"\w* \w la|strong="H5921"\w* vuelva \w en|strong="H5921"\w* sombra \w de|strong="H5921"\w* \w muerte|strong="H6757"\w*  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* densas tinieblas.   
\q1
\v 17 \w Mas|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w* escuchareis esto,  
\q2 \w en|strong="H3588"\w* secreto \w llorará|strong="H1058"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* vuestra \w soberbia|strong="H1466"\w*;  
\q1 \w y|strong="H3588"\w* \w llorando|strong="H1058"\w* \w amargamente|strong="H1830"\w*,  
\q2 \w se|strong="H3808"\w* desharán mis \w ojos|strong="H5869"\w* \w en|strong="H3588"\w* \w lágrimas|strong="H1832"\w*,  
\q2 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* rebaño \w de|strong="H3588"\w* Yahvé \w fue|strong="H3808"\w* \w hecho|strong="H5315"\w* \w cautivo|strong="H7617"\w*.   
\q1
\v 18 Decid \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w reina|strong="H4428"\w* madre:  
\q2 «\w Humillaos|strong="H8213"\w*, \w sentaos|strong="H3427"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* suelo;  
\q1 \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w corona|strong="H5850"\w* \w de|strong="H3588"\w* vuestra \w gloria|strong="H8597"\w*  
\q2 ha caído \w de|strong="H3588"\w* vuestras cabezas».   
\q1
\v 19 Las \w ciudades|strong="H5892"\w* del Neguev fueron cerradas,  
\q2 y no hubo \w quien|strong="H3605"\w* las abriese;  
\q1 \w toda|strong="H3605"\w* \w Judá|strong="H3063"\w* \w fue|strong="H3063"\w* \w trasportada|strong="H1540"\w*,  
\q2 llevada \w fue|strong="H3063"\w* \w toda|strong="H3605"\w* \w ella|strong="H3605"\w* en cautiverio.   
\q1
\v 20 \w Alzad|strong="H5375"\w* vuestros \w ojos|strong="H5869"\w*  
\q2 y \w ved|strong="H7200"\w* \w a|strong="H3068"\w* los que vienen del \w norte|strong="H6828"\w*.  
\q1 ¿Dónde está el \w rebaño|strong="H6629"\w* que \w te|strong="H5869"\w* fue \w dado|strong="H5414"\w*,  
\q2 tu \w hermoso|strong="H8597"\w* \w rebaño|strong="H6629"\w*?   
\q1
\v 21 ¿\w Qué|strong="H3588"\w* dirás \w cuando|strong="H3588"\w* \w él|strong="H5921"\w* \w ponga|strong="H6485"\w* \w como|strong="H4100"\w* \w jefes|strong="H7218"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*  
\q2 \w a|strong="H3068"\w* aquellos \w a|strong="H3068"\w* quienes tú \w enseñaste|strong="H3925"\w* \w a|strong="H3068"\w* ser tus amigos?  
\q1 ¿\w No|strong="H3808"\w* \w te|strong="H5921"\w* darán \w dolores|strong="H2256"\w* \w como|strong="H4100"\w* \w de|strong="H5921"\w* mujer \w de|strong="H5921"\w* parto?   
\q1
\v 22 \w Si|strong="H3588"\w* dijeres \w en|strong="H3588"\w* tu \w corazón|strong="H3824"\w*:  
\q2 «¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w me|strong="H3588"\w* ha sucedido esto?»,  
\q1 sabe \w que|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w multitud|strong="H7230"\w* \w de|strong="H3588"\w* tu \w maldad|strong="H5771"\w* fueron descubiertas tus faldas,  
\q2 \w y|strong="H3588"\w* tus talones fueron expuestos \w a|strong="H3068"\w* \w la|strong="H3588"\w* violencia.   
\q1
\v 23 ¿\w Podrá|strong="H3201"\w* \w el|strong="H1571"\w* \w etíope|strong="H3569"\w* mudar su \w piel|strong="H5785"\w*,  
\q2 \w o|strong="H3068"\w* \w el|strong="H1571"\w* leopardo sus manchas?  
\q1 \w Así|strong="H1571"\w* \w también|strong="H1571"\w*, ¿\w podréis|strong="H3201"\w* vosotros hacer \w el|strong="H1571"\w* \w bien|strong="H3190"\w*,  
\q2 estando habituados \w a|strong="H3068"\w* hacer \w el|strong="H1571"\w* \w mal|strong="H7489"\w*?   
\b  
\q1
\v 24 «Por tanto, yo los \w esparciré|strong="H6327"\w*  
\q2 como tamo que \w pasa|strong="H5674"\w*  
\q2 al \w viento|strong="H7307"\w* del \w desierto|strong="H4057"\w*.   
\q1
\v 25 \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* tu \w suerte|strong="H1486"\w*,  
\q2 la \w porción|strong="H4490"\w* \w que|strong="H2088"\w* yo he medido para ti — \w dice|strong="H5002"\w* Yahvé —,  
\q1 porque te \w olvidaste|strong="H7911"\w* \w de|strong="H7911"\w* mí  
\q2 y confiaste en la \w mentira|strong="H8267"\w*.   
\q1
\v 26 Yo, \w pues|strong="H7200"\w*, descubriré \w también|strong="H1571"\w* tus faldas \w delante|strong="H6440"\w* \w de|strong="H5921"\w* tu \w rostro|strong="H6440"\w*,  
\q2 \w y|strong="H1571"\w* \w se|strong="H5921"\w* \w verá|strong="H7200"\w* tu ignominia,   
\q1
\v 27 tus adulterios, tus relinchos, \w la|strong="H5921"\w* \w maldad|strong="H2154"\w* \w de|strong="H5921"\w* tu \w fornicación|strong="H2184"\w*  
\q2 \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w collados|strong="H1389"\w* \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w campos|strong="H7704"\w*.  
\q1 ¡Ay \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, Jerusalén!  
\q2 ¿\w No|strong="H3808"\w* serás \w limpia|strong="H2891"\w*?  
\q2 ¿\w Hasta|strong="H5921"\w* \w cuándo|strong="H4970"\w* \w todavía|strong="H5750"\w*?»   
\c 14
\p
\v 1 \w Esta|strong="H1961"\w* \w es|strong="H1961"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w que|strong="H5921"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w con|strong="H5921"\w* \w motivo|strong="H1697"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* sequía:   
\q1
\v 2 «\w Judá|strong="H3063"\w* está de luto,  
\q2 y sus \w puertas|strong="H8179"\w* languidecen;  
\q1 se sientan en el suelo vestidos de negro,  
\q2 y el clamor de Jerusalén \w sube|strong="H5927"\w* al cielo.   
\q1
\v 3 Sus nobles \w enviaron|strong="H7971"\w* \w a|strong="H3068"\w* sus mozos \w por|strong="H5921"\w* \w agua|strong="H4325"\w*;  
\q2 vinieron \w a|strong="H3068"\w* \w las|strong="H5921"\w* cisternas  
\q2 \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w hallaron|strong="H4672"\w* \w agua|strong="H4325"\w*.  
\q1 \w Volvieron|strong="H7725"\w* \w con|strong="H5921"\w* sus vasijas \w vacías|strong="H7387"\w*;  
\q2 quedaron \w avergonzados|strong="H3637"\w* \w y|strong="H5921"\w* confusos,  
\q2 \w y|strong="H5921"\w* \w cubrieron|strong="H2645"\w* sus \w cabezas|strong="H7218"\w*.   
\q1
\v 4 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* suelo \w se|strong="H1961"\w* \w ha|strong="H3808"\w* agrietado,  
\q2 \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w llovido|strong="H1653"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra;  
\q1 \w los|strong="H1961"\w* labradores \w están|strong="H1961"\w* confusos  
\q2 \w y|strong="H3588"\w* cubren sus \w cabezas|strong="H7218"\w*.   
\q1
\v 5 \w Aun|strong="H1571"\w* \w la|strong="H1571"\w* cierva \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w* \w parió|strong="H3205"\w* \w y|strong="H1571"\w* abandonó \w su|strong="H3588"\w* cría,  
\q2 \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w había|strong="H1961"\w* \w hierba|strong="H1877"\w*.   
\q1
\v 6 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* asnos monteses \w se|strong="H5921"\w* \w pusieron|strong="H5975"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* alturas yermas;  
\q2 jadeaban \w como|strong="H3588"\w* chacales,  
\q1 sus \w ojos|strong="H5869"\w* \w se|strong="H5921"\w* nublaron  
\q2 \w porque|strong="H3588"\w* \w no|strong="H3588"\w* \w había|strong="H5975"\w* vegetación.   
\q1
\v 7 \w Aunque|strong="H3588"\w* nuestras \w iniquidades|strong="H5771"\w* testifiquen contra nosotros,  
\q2 actúa \w tú|strong="H6213"\w*, Yahvé, \w por|strong="H3588"\w* amor \w de|strong="H3588"\w* \w tu|strong="H6213"\w* \w nombre|strong="H8034"\w*;  
\q1 \w porque|strong="H3588"\w* nuestras \w rebeliones|strong="H4878"\w* \w son|strong="H3588"\w* muchas,  
\q2 contra ti hemos \w pecado|strong="H5771"\w*.   
\q1
\v 8 \w Oh|strong="H4100"\w* \w esperanza|strong="H4723"\w* \w de|strong="H6256"\w* \w Israel|strong="H3478"\w*,  
\q2 \w salvador|strong="H3467"\w* suyo en \w el|strong="H3885"\w* \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* la \w aflicción|strong="H6869"\w*,  
\q1 ¿\w por|strong="H4100"\w* \w qué|strong="H4100"\w* has \w de|strong="H6256"\w* ser \w como|strong="H4100"\w* un forastero en la tierra,  
\q2 y \w como|strong="H4100"\w* un caminante \w que|strong="H4100"\w* \w se|strong="H1961"\w* retira \w para|strong="H1961"\w* pasar la noche?   
\q1
\v 9 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* has \w de|strong="H5921"\w* ser \w como|strong="H4100"\w* un \w hombre|strong="H1368"\w* \w atónito|strong="H1724"\w*,  
\q2 \w como|strong="H4100"\w* un \w valiente|strong="H1368"\w* \w que|strong="H4100"\w* \w no|strong="H3808"\w* \w puede|strong="H3201"\w* \w salvar|strong="H3467"\w*?  
\q1 \w Sin|strong="H3808"\w* embargo, tú, Yahvé, estás \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w nosotros|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* \w por|strong="H5921"\w* tu \w nombre|strong="H8034"\w* \w somos|strong="H1961"\w* \w llamados|strong="H7121"\w*;  
\q2 \w no|strong="H3808"\w* \w nos|strong="H5921"\w* desampares».   
\p
\v 10 \w Así|strong="H3541"\w* dice Yahvé \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*:  
\q1 «\w De|strong="H5971"\w* \w tal|strong="H3651"\w* manera les gustó vagar,  
\q2 \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w detuvieron|strong="H2820"\w* sus \w pies|strong="H7272"\w*;  
\q1 \w por|strong="H2088"\w* \w tanto|strong="H3651"\w*, Yahvé \w no|strong="H3808"\w* los acepta;  
\q2 \w se|strong="H3808"\w* acordará \w ahora|strong="H6258"\w* \w de|strong="H5971"\w* su \w iniquidad|strong="H5771"\w*  
\q2 \w y|strong="H3541"\w* castigará sus \w pecados|strong="H2403"\w*».   
\p
\v 11 Me dijo entonces Yahvé: «No \w ruegues|strong="H6419"\w* \w por|strong="H1157"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w para|strong="H5971"\w* \w bien|strong="H2896"\w*.  
\v 12 \w Cuando|strong="H3588"\w* ayunen, \w yo|strong="H3588"\w* \w no|strong="H3588"\w* \w oiré|strong="H8085"\w* \w su|strong="H3588"\w* \w clamor|strong="H7440"\w*; \w y|strong="H3588"\w* \w cuando|strong="H3588"\w* ofrezcan \w holocausto|strong="H5930"\w* \w y|strong="H3588"\w* \w ofrenda|strong="H4503"\w*, \w no|strong="H3588"\w* \w los|strong="H3588"\w* aceptaré, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w los|strong="H3588"\w* consumiré \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w*, \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w hambre|strong="H7458"\w* \w y|strong="H3588"\w* \w con|strong="H3588"\w* \w la|strong="H3588"\w* peste».   
\p
\v 13 \w Y|strong="H3068"\w* \w yo|strong="H3588"\w* dije: “¡Ah, Señor Yahvé! He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w los|strong="H1961"\w* \w profetas|strong="H5030"\w* les dicen: ‘\w No|strong="H3808"\w* \w veréis|strong="H7200"\w* \w espada|strong="H2719"\w*, \w ni|strong="H3808"\w* \w tendréis|strong="H1961"\w* \w hambre|strong="H7458"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* os \w daré|strong="H5414"\w* una \w paz|strong="H7965"\w* segura’”.   
\p
\v 14 Entonces Yahvé me \w dijo|strong="H1696"\w*: “\w Falsamente|strong="H8267"\w* \w profetizan|strong="H5012"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* en mi \w nombre|strong="H8034"\w*; \w yo|strong="H6680"\w* \w no|strong="H3808"\w* \w los|strong="H1992"\w* \w envié|strong="H7971"\w*, \w ni|strong="H3808"\w* \w les|strong="H1992"\w* \w mandé|strong="H6680"\w*, \w ni|strong="H3808"\w* \w les|strong="H1992"\w* \w hablé|strong="H1696"\w*; \w visión|strong="H2377"\w* \w mentirosa|strong="H8267"\w*, \w adivinación|strong="H7081"\w*, \w vanidad|strong="H8267"\w* y \w el|strong="H5030"\w* \w engaño|strong="H8267"\w* de \w su|strong="H1992"\w* propio \w corazón|strong="H3820"\w* os \w profetizan|strong="H5012"\w*.  
\v 15 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé \w sobre|strong="H5921"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* \w que|strong="H3808"\w* \w profetizan|strong="H5012"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w*, \w a|strong="H3068"\w* \w los|strong="H1992"\w* cuales yo \w no|strong="H3808"\w* \w envié|strong="H7971"\w*, \w y|strong="H5921"\w* \w que|strong="H3808"\w* dicen: ‘\w Ni|strong="H3808"\w* \w espada|strong="H2719"\w* \w ni|strong="H3808"\w* \w hambre|strong="H7458"\w* \w habrá|strong="H1961"\w* \w en|strong="H5921"\w* \w esta|strong="H2063"\w* tierra’: \w Con|strong="H5921"\w* \w espada|strong="H2719"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w hambre|strong="H7458"\w* \w serán|strong="H1961"\w* \w consumidos|strong="H8552"\w* esos \w profetas|strong="H5030"\w*.  
\v 16 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* quien \w profetizan|strong="H5012"\w* \w será|strong="H1961"\w* \w echado|strong="H7993"\w* \w en|strong="H5921"\w* \w las|strong="H1992"\w* \w calles|strong="H2351"\w* \w de|strong="H5921"\w* Jerusalén \w por|strong="H5921"\w* \w causa|strong="H6440"\w* \w del|strong="H5921"\w* \w hambre|strong="H7458"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*, \w y|strong="H5921"\w* \w no|strong="H1961"\w* \w habrá|strong="H1961"\w* quien \w los|strong="H1992"\w* \w entierre|strong="H6912"\w*, ni \w a|strong="H3068"\w* \w ellos|strong="H1992"\w*, ni \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w mujeres|strong="H1323"\w*, ni \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w*, ni \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w hijas|strong="H1323"\w*; \w pues|strong="H1961"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H1992"\w* \w derramaré|strong="H8210"\w* \w su|strong="H1992"\w* propia \w maldad|strong="H7451"\w*.   
\p
\v 17 “Les dirás, \w pues|strong="H3588"\w*, \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*:  
\q1 “‘Desháganse mis \w ojos|strong="H5869"\w* \w en|strong="H3588"\w* \w lágrimas|strong="H1832"\w* \w noche|strong="H3915"\w* \w y|strong="H3588"\w* \w día|strong="H3119"\w*,  
\q2 \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w cesen|strong="H1820"\w*;  
\q1 \w porque|strong="H3588"\w* \w de|strong="H3588"\w* \w gran|strong="H1419"\w* \w quebrantamiento|strong="H7667"\w* fue \w quebrantada|strong="H7665"\w* \w la|strong="H3588"\w* \w virgen|strong="H1330"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*,  
\q2 \w de|strong="H3588"\w* una herida \w muy|strong="H3966"\w* dolorosa.   
\q1
\v 18 \w Si|strong="H3588"\w* \w salgo|strong="H3318"\w* al \w campo|strong="H7704"\w*,  
\q2 ¡he \w aquí|strong="H2009"\w* \w los|strong="H3588"\w* \w muertos|strong="H2491"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*!  
\q1 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* entro \w en|strong="H3588"\w* \w la|strong="H1571"\w* \w ciudad|strong="H5892"\w*,  
\q2 ¡he \w aquí|strong="H2009"\w* \w los|strong="H3588"\w* \w enfermos|strong="H8463"\w* \w de|strong="H3588"\w* \w hambre|strong="H7458"\w*!  
\q1 \w Porque|strong="H3588"\w* tanto \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w* andan errantes \w por|strong="H3588"\w* \w la|strong="H1571"\w* tierra  
\q2 \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w saben|strong="H3045"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* hacen’”.   
\b  
\q1
\v 19 ¿Has \w desechado|strong="H3988"\w* del todo \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*?  
\q2 ¿Ha aborrecido tu \w alma|strong="H5315"\w* \w a|strong="H3068"\w* \w Sión|strong="H6726"\w*?  
\q1 ¿\w Por|strong="H4069"\w* \w qué|strong="H6256"\w* nos hiciste herir sin \w que|strong="H6256"\w* haya para nosotros \w medicina|strong="H4832"\w*?  
\q2 \w Esperamos|strong="H6960"\w* \w paz|strong="H7965"\w*, y no \w hubo|strong="H2009"\w* \w bien|strong="H2896"\w*;  
\q2 \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* \w salud|strong="H4832"\w*, y he \w aquí|strong="H2009"\w* \w turbación|strong="H1205"\w*.   
\q1
\v 20 \w Reconocemos|strong="H3045"\w*, Yahvé, nuestra \w impiedad|strong="H7562"\w*,  
\q2 \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H3588"\w* nuestros padres;  
\q2 \w porque|strong="H3588"\w* contra ti hemos \w pecado|strong="H5771"\w*.   
\q1
\v 21 No nos \w deseches|strong="H5006"\w*, \w por|strong="H4616"\w* amor de tu \w nombre|strong="H8034"\w*;  
\q2 no deshonres el \w trono|strong="H3678"\w* de tu \w gloria|strong="H3519"\w*;  
\q2 \w acuérdate|strong="H2142"\w*, no \w invalides|strong="H6565"\w* tu \w pacto|strong="H1285"\w* con nosotros.   
\q1
\v 22 ¿\w Hay|strong="H3426"\w* \w entre|strong="H3808"\w* las \w vanidades|strong="H1892"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w* \w quien|strong="H3605"\w* \w haga|strong="H6213"\w* llover?  
\q2 ¿\w O|strong="H3068"\w* \w darán|strong="H5414"\w* \w los|strong="H3605"\w* \w cielos|strong="H8064"\w* \w lluvias|strong="H7241"\w* \w de|strong="H3588"\w* \w por|strong="H3588"\w* \w sí|strong="H3588"\w*?  
\q2 ¿\w No|strong="H3808"\w* \w eres|strong="H1931"\w* \w tú|strong="H6213"\w*, Yahvé, nuestro \w Dios|strong="H3068"\w*?  
\q1 \w En|strong="H3588"\w* ti, \w pues|strong="H3588"\w*, esperaremos;  
\q2 \w pues|strong="H3588"\w* \w tú|strong="H6213"\w* \w hiciste|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H6213"\w* cosas.   
\c 15
\p
\v 1 Entonces Yahvé \w me|strong="H5921"\w* dijo: “Aunque \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* \w Samuel|strong="H8050"\w* \w se|strong="H5921"\w* pusiesen \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w mi|strong="H5921"\w* \w voluntad|strong="H5315"\w* \w no|strong="H5921"\w* estaría \w con|strong="H5921"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*. \w Échalos|strong="H7971"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w presencia|strong="H6440"\w*, \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w salgan|strong="H3318"\w*.  
\v 2 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w te|strong="H3588"\w* preguntan: ‘¿\w A|strong="H3068"\w* dónde \w saldremos|strong="H3318"\w*?’, les dirás: ‘\w Así|strong="H3541"\w* dice Yahvé:  
\q1 \w El|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w muerte|strong="H4194"\w*, \w a|strong="H3068"\w* \w muerte|strong="H4194"\w*;  
\q1 \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w a|strong="H3068"\w* \w espada|strong="H2719"\w*;  
\q1 \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w hambre|strong="H7458"\w*, \w a|strong="H3068"\w* \w hambre|strong="H7458"\w*;  
\q1 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w cautiverio|strong="H7628"\w*, \w a|strong="H3068"\w* \w cautiverio|strong="H7628"\w*’.   
\p
\v 3 Pues \w enviaré|strong="H6485"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* cuatro clases \w de|strong="H5921"\w* castigo”, \w dice|strong="H5002"\w* Yahvé: «\w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w para|strong="H5921"\w* matar, \w los|strong="H5921"\w* \w perros|strong="H3611"\w* \w para|strong="H5921"\w* despedazar, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* bestias \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w para|strong="H5921"\w* devorar \w y|strong="H5921"\w* \w destruir|strong="H7843"\w*.  
\v 4 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w entregaré|strong="H5414"\w* \w para|strong="H5921"\w* ser objeto \w de|strong="H5921"\w* espanto \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w reinos|strong="H4467"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w por|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w* \w en|strong="H5921"\w* Jerusalén.   
\q1
\v 5 \w Porque|strong="H3588"\w* ¿\w quién|strong="H4310"\w* tendrá compasión \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, Jerusalén?  
\q2 ¿\w Quién|strong="H4310"\w* \w te|strong="H5921"\w* llorará?  
\q2 ¿\w O|strong="H3068"\w* \w quién|strong="H4310"\w* \w se|strong="H5921"\w* detendrá \w a|strong="H3068"\w* preguntar \w por|strong="H5921"\w* tu \w paz|strong="H7965"\w*?   
\q1
\v 6 Tú \w me|strong="H5921"\w* abandonaste», \w dice|strong="H5002"\w* Yahvé.  
\q2 «\w Te|strong="H5921"\w* volviste atrás.  
\q1 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, yo \w extenderé|strong="H5186"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*  
\q2 \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w destruiré|strong="H7843"\w*.  
\q2 Estoy \w cansado|strong="H3811"\w* \w de|strong="H5921"\w* arrepentirme.   
\q1
\v 7 Los aventé con el bieldo \w a|strong="H3068"\w* las \w puertas|strong="H8179"\w* \w de|strong="H5971"\w* la tierra.  
\q2 Los dejé \w sin|strong="H3808"\w* hijos.  
\q1 He deshecho \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w*.  
\q2 \w No|strong="H3808"\w* \w se|strong="H3808"\w* convirtieron \w de|strong="H5971"\w* sus \w caminos|strong="H1870"\w*.   
\q1
\v 8 \w Sus|strong="H1992"\w* viudas \w se|strong="H5921"\w* multiplicaron \w más|strong="H5921"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* arena \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w mares|strong="H3220"\w*.  
\q2 Traje \w contra|strong="H5921"\w* \w la|strong="H5921"\w* madre \w de|strong="H5921"\w* \w los|strong="H1992"\w* jóvenes un \w destruidor|strong="H7703"\w* \w al|strong="H5921"\w* mediodía.  
\q2 Hice \w que|strong="H5921"\w* \w de|strong="H5921"\w* repente \w cayesen|strong="H5307"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* angustia \w y|strong="H5921"\w* terrores.   
\q1
\v 9 La \w que|strong="H7651"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w siete|strong="H7651"\w* languidece.  
\q2 Exhaló su aliento.  
\q1 Su \w sol|strong="H8121"\w* se \w puso|strong="H5414"\w* siendo \w aún|strong="H5750"\w* \w de|strong="H6440"\w* \w día|strong="H3119"\w*.  
\q2 Quedó avergonzada y confundida.  
\q2 \w Y|strong="H3068"\w* el \w resto|strong="H7611"\w* \w de|strong="H6440"\w* ellos lo \w entregaré|strong="H5414"\w* \w a|strong="H3068"\w* la \w espada|strong="H2719"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* sus enemigos», \w dice|strong="H5002"\w* Yahvé.   
\b  
\q1
\v 10 ¡Ay \w de|strong="H3588"\w* mí, madre mía, \w que|strong="H3588"\w* \w me|strong="H3588"\w* diste \w a|strong="H3068"\w* luz \w como|strong="H3588"\w* hombre \w de|strong="H3588"\w* \w contienda|strong="H7379"\w*  
\q2 \w y|strong="H3588"\w* hombre \w de|strong="H3588"\w* \w pleito|strong="H7379"\w* \w para|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra!  
\q1 \w Nunca|strong="H3808"\w* he prestado, \w ni|strong="H3808"\w* \w nadie|strong="H3808"\w* \w me|strong="H3588"\w* \w ha|strong="H3808"\w* prestado;  
\q2 \w mas|strong="H3588"\w* \w todos|strong="H3605"\w* \w me|strong="H3588"\w* maldicen.   
\p
\v 11 Yahvé dijo:  
\q1 «\w De|strong="H7451"\w* \w cierto|strong="H3808"\w* tu servicio \w será|strong="H3808"\w* para \w bien|strong="H2896"\w*.  
\q2 \w De|strong="H7451"\w* \w cierto|strong="H3808"\w* haré \w que|strong="H3808"\w* el enemigo te suplique en el \w tiempo|strong="H6256"\w* del \w mal|strong="H7451"\w*  
\q2 y en el \w tiempo|strong="H6256"\w* \w de|strong="H7451"\w* la \w aflicción|strong="H6869"\w*.   
\q1
\v 12 ¿Se rompe el \w hierro|strong="H1270"\w*,  
\q2 el \w hierro|strong="H1270"\w* del \w norte|strong="H6828"\w* y el bronce?   
\q1
\v 13 Tus bienes y tus tesoros \w daré|strong="H5414"\w* \w a|strong="H3068"\w* \w la|strong="H1366"\w* rapiña \w sin|strong="H3808"\w* \w ningún|strong="H3605"\w* \w precio|strong="H4242"\w*,  
\q2 y esto \w por|strong="H5414"\w* \w todos|strong="H3605"\w* tus \w pecados|strong="H2403"\w*,  
\q2 en \w todo|strong="H3605"\w* tu territorio.   
\q1
\v 14 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* haré \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* tus enemigos \w a|strong="H3068"\w* una tierra \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w conoces|strong="H3045"\w*;  
\q2 \w porque|strong="H3588"\w* \w el|strong="H5921"\w* fuego \w de|strong="H5921"\w* \w mi|strong="H5921"\w* ira \w se|strong="H3045"\w* \w ha|strong="H3808"\w* \w encendido|strong="H3344"\w*,  
\q2 \w y|strong="H3588"\w* \w arderá|strong="H3344"\w* \w sobre|strong="H5921"\w* vosotros».   
\b  
\q1
\v 15 Tú \w lo|strong="H5921"\w* \w sabes|strong="H3045"\w*, Yahvé.  
\q2 \w Acuérdate|strong="H2142"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w visítame|strong="H6485"\w*  
\q2 \w y|strong="H5921"\w* véngame \w de|strong="H5921"\w* \w mis|strong="H5375"\w* \w perseguidores|strong="H7291"\w*.  
\q1 \w Por|strong="H5921"\w* tu larga paciencia, \w no|strong="H5921"\w* \w me|strong="H5921"\w* arrebates.  
\q2 \w Sabe|strong="H3045"\w* \w que|strong="H5921"\w* \w por|strong="H5921"\w* amor \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w sufro|strong="H5375"\w* \w afrenta|strong="H2781"\w*.   
\q1
\v 16 \w Se|strong="H1961"\w* \w hallaron|strong="H4672"\w* tus \w palabras|strong="H1697"\w*,  
\q2 \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w las|strong="H5921"\w* comí.  
\q1 Tus \w palabras|strong="H1697"\w* \w fueron|strong="H1961"\w* \w para|strong="H5921"\w* \w mí|strong="H5921"\w* \w el|strong="H5921"\w* \w gozo|strong="H8057"\w* \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w alegría|strong="H8057"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3824"\w*,  
\q2 \w porque|strong="H3588"\w* \w por|strong="H5921"\w* tu \w nombre|strong="H8034"\w* \w soy|strong="H1961"\w* \w llamado|strong="H8034"\w*, Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*.   
\q1
\v 17 \w No|strong="H3808"\w* \w me|strong="H3588"\w* senté \w en|strong="H3588"\w* \w la|strong="H3588"\w* reunión \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w se|strong="H3808"\w* burlan, \w ni|strong="H3808"\w* \w me|strong="H3588"\w* regocijé.  
\q2 \w A|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* tu \w mano|strong="H3027"\w* \w me|strong="H3588"\w* senté solo,  
\q2 \w porque|strong="H3588"\w* \w me|strong="H3588"\w* llenaste \w de|strong="H3588"\w* indignación.   
\q1
\v 18 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w mi|strong="H1961"\w* dolor \w es|strong="H1961"\w* \w perpetuo|strong="H5331"\w*,  
\q2 y \w mi|strong="H1961"\w* herida incurable,  
\q2 \w que|strong="H4100"\w* \w no|strong="H3808"\w* admite medicina?  
\q1 ¿\w Serás|strong="H1961"\w* \w para|strong="H1961"\w* \w mí|strong="H1961"\w* \w como|strong="H4100"\w* arroyo engañoso,  
\q2 \w como|strong="H4100"\w* \w aguas|strong="H4325"\w* \w que|strong="H4100"\w* \w no|strong="H3808"\w* \w son|strong="H1961"\w* estables?   
\p
\v 19 \w Por|strong="H6440"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé:  
\q1 «\w Si|strong="H3808"\w* te convirtieres, yo te restauraré,  
\q2 \w y|strong="H3541"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H1961"\w* \w estarás|strong="H1961"\w*;  
\q1 \w y|strong="H3541"\w* \w si|strong="H3808"\w* entresacares \w lo|strong="H3808"\w* \w precioso|strong="H3368"\w* \w de|strong="H6440"\w* \w lo|strong="H3808"\w* vil,  
\q2 \w serás|strong="H1961"\w* \w como|strong="H1961"\w* \w mi|strong="H1961"\w* \w boca|strong="H6310"\w*.  
\q1 \w Conviértanse|strong="H7725"\w* \w ellos|strong="H1992"\w* \w a|strong="H3068"\w* ti,  
\q2 \w mas|strong="H3808"\w* tú \w no|strong="H3808"\w* te \w conviertas|strong="H7725"\w* \w a|strong="H3068"\w* \w ellos|strong="H1992"\w*.   
\q1
\v 20 \w Y|strong="H3068"\w* \w te|strong="H3588"\w* \w pondré|strong="H5414"\w* frente \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w como|strong="H3588"\w* \w muro|strong="H2346"\w* \w de|strong="H3588"\w* bronce fortificado.  
\q2 Pelearán contra ti,  
\q2 \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w prevalecerán|strong="H3201"\w* contra ti;  
\q1 \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* estoy \w con|strong="H3588"\w* vosotros \w para|strong="H3588"\w* salvaros  
\q2 \w y|strong="H3588"\w* \w para|strong="H3588"\w* \w libraros|strong="H5337"\w*», \w dice|strong="H5002"\w* Yahvé.   
\q1
\v 21 «\w Y|strong="H3068"\w* te \w libraré|strong="H5337"\w* \w de|strong="H7451"\w* la \w mano|strong="H3027"\w* \w de|strong="H7451"\w* los \w malos|strong="H7451"\w*,  
\q2 y te redimiré \w de|strong="H7451"\w* la \w mano|strong="H3027"\w* \w de|strong="H7451"\w* los fuertes».   
\c 16
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 «\w No|strong="H3808"\w* \w tomarás|strong="H3947"\w* \w para|strong="H1961"\w* ti mujer, \w ni|strong="H3808"\w* \w tendrás|strong="H1961"\w* \w hijos|strong="H1121"\w* \w ni|strong="H3808"\w* \w hijas|strong="H1323"\w* en \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*».  
\v 3 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w hijas|strong="H1323"\w* \w que|strong="H3588"\w* nazcan \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* madres \w que|strong="H3588"\w* \w los|strong="H1121"\w* den \w a|strong="H3068"\w* luz, \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* padres \w que|strong="H3588"\w* \w los|strong="H1121"\w* \w engendren|strong="H3205"\w* \w en|strong="H5921"\w* \w esta|strong="H2063"\w* tierra:  
\v 4 «\w De|strong="H5921"\w* muertes dolorosas \w morirán|strong="H4191"\w*; \w no|strong="H3808"\w* \w serán|strong="H1961"\w* lamentados \w ni|strong="H3808"\w* \w sepultados|strong="H6912"\w*; \w serán|strong="H1961"\w* \w como|strong="H1961"\w* estiércol \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra. \w Con|strong="H5921"\w* \w espada|strong="H2719"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w hambre|strong="H7458"\w* \w serán|strong="H1961"\w* consumidos, \w y|strong="H5921"\w* sus cuerpos \w muertos|strong="H4191"\w* \w serán|strong="H1961"\w* \w comida|strong="H3978"\w* \w para|strong="H5921"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w* \w y|strong="H5921"\w* \w para|strong="H5921"\w* \w las|strong="H5921"\w* bestias \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra».   
\p
\v 5 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* \w dice|strong="H5002"\w* Yahvé: “\w No|strong="H3588"\w* entres \w en|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* luto, ni \w vayas|strong="H3212"\w* \w a|strong="H3068"\w* lamentar, ni \w los|strong="H3588"\w* consueles; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* he quitado mi \w paz|strong="H7965"\w* \w de|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* — \w dice|strong="H5002"\w* Yahvé —, mi \w misericordia|strong="H2617"\w* \w y|strong="H3588"\w* mi piedad.  
\v 6 \w Morirán|strong="H4191"\w* \w en|strong="H6912"\w* \w esta|strong="H2063"\w* tierra \w grandes|strong="H1419"\w* y \w pequeños|strong="H6996"\w*; \w no|strong="H3808"\w* \w serán|strong="H1992"\w* \w sepultados|strong="H6912"\w*, \w ni|strong="H3808"\w* \w los|strong="H1992"\w* lamentarán, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* harán incisiones, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* raparán \w los|strong="H1992"\w* cabellos por \w ellos|strong="H1992"\w*.  
\v 7 \w No|strong="H3808"\w* partirán pan \w por|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* luto \w para|strong="H5921"\w* consolarlos \w por|strong="H5921"\w* sus \w muertos|strong="H4191"\w*; \w ni|strong="H3808"\w* \w les|strong="H5921"\w* darán \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* copa \w de|strong="H5921"\w* consolación \w por|strong="H5921"\w* su padre \w o|strong="H3068"\w* \w por|strong="H5921"\w* su madre.   
\p
\v 8 «Asimismo, \w no|strong="H3808"\w* entres en \w casa|strong="H1004"\w* de \w banquete|strong="H4960"\w* para sentarte con ellos \w a|strong="H3068"\w* comer y \w a|strong="H3068"\w* \w beber|strong="H8354"\w*».  
\v 9 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé \w de|strong="H4480"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H3588"\w* \w Dios|strong="H3068"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*: “He \w aquí|strong="H2088"\w* \w que|strong="H3588"\w* \w yo|strong="H4480"\w* haré cesar \w en|strong="H4480"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, ante vuestros \w ojos|strong="H5869"\w* \w y|strong="H3588"\w* \w en|strong="H4480"\w* vuestros \w días|strong="H3117"\w*, \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H4480"\w* \w gozo|strong="H8057"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H4480"\w* \w alegría|strong="H8057"\w*, \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w del|strong="H4480"\w* \w esposo|strong="H2860"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H4480"\w* \w la|strong="H3588"\w* \w esposa|strong="H3618"\w*.  
\v 10 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* anuncies \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w todas|strong="H3605"\w* \w estas|strong="H2088"\w* \w palabras|strong="H1697"\w*, \w y|strong="H3588"\w* \w te|strong="H5921"\w* pregunten: ‘¿\w Por|strong="H5921"\w* \w qué|strong="H3588"\w* ha pronunciado Yahvé \w contra|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w todo|strong="H3605"\w* \w este|strong="H2088"\w* \w mal|strong="H7451"\w* tan \w grande|strong="H1419"\w*?’, \w o|strong="H3068"\w* ‘¿\w Cuál|strong="H4100"\w* \w es|strong="H1961"\w* nuestra \w iniquidad|strong="H5771"\w*?’, \w o|strong="H3068"\w* ‘¿\w Cuál|strong="H4100"\w* \w es|strong="H1961"\w* nuestro \w pecado|strong="H2403"\w* \w que|strong="H3588"\w* hemos cometido \w contra|strong="H5921"\w* Yahvé nuestro \w Dios|strong="H3068"\w*?’,  
\v 11 entonces \w les|strong="H5921"\w* dirás: ‘\w Porque|strong="H5921"\w* \w vuestros|strong="H5647"\w* padres \w me|strong="H5921"\w* abandonaron — \w dice|strong="H5002"\w* Yahvé —, \w y|strong="H5921"\w* \w caminaron|strong="H3212"\w* \w en|strong="H5921"\w* pos \w de|strong="H5921"\w* dioses ajenos, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w sirvieron|strong="H5647"\w*, \w y|strong="H5921"\w* ante \w ellos|strong="H5921"\w* \w se|strong="H5921"\w* postraron, \w y|strong="H5921"\w* \w me|strong="H5921"\w* abandonaron \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w guardaron|strong="H8104"\w* \w mi|strong="H5921"\w* \w ley|strong="H8451"\w*.  
