\p
\v 9 \w A|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H6440"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w* \w mi|strong="H1961"\w* \w corazón|strong="H3820"\w* \w está|strong="H1961"\w* \w quebrantado|strong="H7665"\w* \w dentro|strong="H7130"\w* \w de|strong="H6440"\w* \w mí|strong="H1961"\w*, \w todos|strong="H3605"\w* mis \w huesos|strong="H6106"\w* \w tiemblan|strong="H7363"\w*; \w estoy|strong="H1961"\w* \w como|strong="H1961"\w* un ebrio, y \w como|strong="H1961"\w* \w hombre|strong="H1397"\w* \w a|strong="H3068"\w* \w quien|strong="H3605"\w* dominó \w el|strong="H3605"\w* \w vino|strong="H3196"\w*, \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé y \w delante|strong="H6440"\w* \w de|strong="H6440"\w* sus \w santas|strong="H6944"\w* \w palabras|strong="H1697"\w*.   
