\v 33 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*:  
\q1 «\w La|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* Babilonia \w es|strong="H3588"\w* \w como|strong="H3588"\w* una \w era|strong="H6256"\w* \w al|strong="H6256"\w* \w tiempo|strong="H6256"\w* \w de|strong="H3588"\w* trillarla;  
\q2 \w de|strong="H3588"\w* \w aquí|strong="H3541"\w* \w a|strong="H3068"\w* \w poco|strong="H4592"\w* le vendrá \w el|strong="H3588"\w* \w tiempo|strong="H6256"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* siega».   
\b  
\q1
\v 34 «Me \w devoró|strong="H1104"\w*, me desmenuzó \w Nabucodonosor|strong="H5019"\w* \w rey|strong="H4428"\w* de Babilonia;  
\q2 me dejó como \w vaso|strong="H3627"\w* \w vacío|strong="H7385"\w*;  
\q2 me tragó como un monstruo, \w llenó|strong="H4390"\w* su vientre de mis delicados manjares y me expulsó.   
\q1
\v 35 ¡\w Sobre|strong="H5921"\w* Babilonia recaiga \w la|strong="H5921"\w* \w violencia|strong="H2555"\w* hecha \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w carne|strong="H7607"\w*!», dirá \w la|strong="H5921"\w* \w moradora|strong="H3427"\w* \w de|strong="H5921"\w* \w Sión|strong="H6726"\w*;  
\q2 \w y|strong="H5921"\w*: «¡\w Mi|strong="H5921"\w* \w sangre|strong="H1818"\w* recaiga \w sobre|strong="H5921"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* Caldea!», dirá Jerusalén.   
