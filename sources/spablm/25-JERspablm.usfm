\p
\v 16 Entró, \w pues|strong="H3588"\w*, \w Jeremías|strong="H3414"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* mazmorra \w y|strong="H3588"\w* \w en|strong="H3588"\w* las bóvedas; \w y|strong="H3588"\w* habiendo estado \w allí|strong="H8033"\w* \w Jeremías|strong="H3414"\w* \w por|strong="H3588"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*,  
\v 17 el \w rey|strong="H4428"\w* Sedequías \w envió|strong="H7971"\w* y \w lo|strong="H1697"\w* sacó. \w Y|strong="H3068"\w* le \w preguntó|strong="H7592"\w* el \w rey|strong="H4428"\w* secretamente en su \w casa|strong="H1004"\w*, y dijo: «¿\w Hay|strong="H3426"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé?». \w Y|strong="H3068"\w* \w Jeremías|strong="H3414"\w* dijo: «La \w hay|strong="H3426"\w*». \w Y|strong="H3068"\w* añadió: «En \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H1697"\w* Babilonia serás \w entregado|strong="H5414"\w*».   
\p
\v 18 Dijo \w también|strong="H2088"\w* \w Jeremías|strong="H3414"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* Sedequías: “¿\w En|strong="H3588"\w* \w qué|strong="H3588"\w* \w pequé|strong="H2398"\w* contra ti, \w o|strong="H3068"\w* contra tus \w siervos|strong="H5650"\w*, \w o|strong="H3068"\w* contra \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* pusierais \w en|strong="H3588"\w* \w la|strong="H3588"\w* cárcel?  
\v 19 ¿\w Y|strong="H3068"\w* \w dónde|strong="H5921"\w* están vuestros \w profetas|strong="H5030"\w* \w que|strong="H3808"\w* \w os|strong="H5921"\w* \w profetizaban|strong="H5012"\w* diciendo: ‘\w No|strong="H3808"\w* vendrá \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w contra|strong="H5921"\w* vosotros, \w ni|strong="H3808"\w* \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* tierra’?  
\v 20 \w Ahora|strong="H6258"\w* \w pues|strong="H4994"\w*, \w oye|strong="H8085"\w*, os \w ruego|strong="H8467"\w*, \w mi|strong="H4994"\w* señor \w el|strong="H5307"\w* \w rey|strong="H4428"\w*; sea aceptada \w mi|strong="H4994"\w* \w súplica|strong="H8467"\w* en vuestra \w presencia|strong="H6440"\w*, y \w no|strong="H3808"\w* me hagáis \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w* del escribano Jonatán, \w para|strong="H6258"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w muera|strong="H4191"\w* \w allí|strong="H8033"\w*”.   
\p
\v 21 \w Entonces|strong="H3117"\w* \w mandó|strong="H6680"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* Sedequías \w que|strong="H4480"\w* custodiaran \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w en|strong="H4480"\w* \w el|strong="H3605"\w* \w patio|strong="H2691"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* guardia, \w y|strong="H5704"\w* \w que|strong="H4480"\w* le diesen \w cada|strong="H3605"\w* \w día|strong="H3117"\w* una \w torta|strong="H3603"\w* \w de|strong="H4480"\w* \w pan|strong="H3899"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* calle \w de|strong="H4480"\w* \w los|strong="H3427"\w* Panaderos, \w hasta|strong="H5704"\w* \w que|strong="H4480"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pan|strong="H3899"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w se|strong="H4480"\w* acabase. \w Y|strong="H3068"\w* \w se|strong="H4480"\w* \w quedó|strong="H3427"\w* \w Jeremías|strong="H3414"\w* \w en|strong="H4480"\w* \w el|strong="H3605"\w* \w patio|strong="H2691"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* guardia.   
\c 38
\p
\v 1 \w Oyeron|strong="H8085"\w* Sefatías \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Matán, \w Gedalías|strong="H1436"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Pasjur, Jucal \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Selemías, y Pasjur \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Malquías, las \w palabras|strong="H1697"\w* \w que|strong="H5971"\w* \w Jeremías|strong="H3414"\w* \w hablaba|strong="H1696"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Así|strong="H3541"\w* dice Yahvé: ‘\w El|strong="H3427"\w* \w que|strong="H1961"\w* \w se|strong="H1961"\w* \w quedare|strong="H3427"\w* \w en|strong="H3318"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w morirá|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, de \w hambre|strong="H7458"\w* \w o|strong="H3068"\w* de peste; \w mas|strong="H4191"\w* \w el|strong="H3427"\w* \w que|strong="H1961"\w* \w se|strong="H1961"\w* pasare \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w caldeos|strong="H3778"\w* \w vivirá|strong="H2421"\w*, \w pues|strong="H1961"\w* su \w vida|strong="H5315"\w* le \w será|strong="H1961"\w* por botín, \w y|strong="H3541"\w* \w vivirá|strong="H2421"\w*’.  
\v 3 \w Así|strong="H3541"\w* dice Yahvé: ‘\w De|strong="H5414"\w* cierto \w será|strong="H5414"\w* \w entregada|strong="H5414"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* en \w mano|strong="H3027"\w* del \w ejército|strong="H2428"\w* del \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Babilonia, \w y|strong="H3541"\w* él \w la|strong="H2063"\w* \w tomará|strong="H3920"\w*’”.   
\p
\v 4 \w Y|strong="H3068"\w* \w dijeron|strong="H1697"\w* \w los|strong="H5921"\w* \w príncipes|strong="H8269"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*: «\w Muera|strong="H4191"\w* \w ahora|strong="H4994"\w* \w este|strong="H2088"\w* hombre; \w porque|strong="H3588"\w* \w así|strong="H3651"\w* debilita \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* \w guerra|strong="H4421"\w* \w que|strong="H3588"\w* \w han|strong="H4191"\w* quedado \w en|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H3588"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w*, \w hablándoles|strong="H1696"\w* \w tales|strong="H3651"\w* \w palabras|strong="H1697"\w*; \w porque|strong="H3588"\w* \w este|strong="H2088"\w* hombre \w no|strong="H3588"\w* \w busca|strong="H1875"\w* \w la|strong="H1931"\w* \w paz|strong="H7965"\w* \w de|strong="H5921"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w sino|strong="H3588"\w* \w su|strong="H1931"\w* \w mal|strong="H7451"\w*».   
\p
\v 5 \w Y|strong="H3068"\w* dijo \w el|strong="H1931"\w* \w rey|strong="H4428"\w* Sedequías: «He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w él|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H3588"\w* \w vuestras|strong="H1697"\w* \w manos|strong="H3027"\w*; \w pues|strong="H3588"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w nada|strong="H1697"\w* \w puede|strong="H3201"\w* hacer contra vosotros».   
\p
\v 6 \w Entonces|strong="H3588"\w* \w tomaron|strong="H3947"\w* ellos \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w y|strong="H3588"\w* lo hicieron echar \w en|strong="H3588"\w* \w la|strong="H3588"\w* cisterna \w de|strong="H3588"\w* Malquías \w hijo|strong="H1121"\w* del rey, \w la|strong="H3588"\w* \w cual|strong="H3588"\w* estaba \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w patio|strong="H2691"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* guardia; \w y|strong="H3588"\w* bajaron \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w con|strong="H3588"\w* cuerdas. \w Y|strong="H3068"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* cisterna \w no|strong="H3588"\w* \w había|strong="H3588"\w* \w agua|strong="H4325"\w*, \w sino|strong="H3588"\w* lodo, \w y|strong="H3588"\w* se hundió \w Jeremías|strong="H3414"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* lodo.   
\p
\v 7 \w Y|strong="H3068"\w* \w oyendo|strong="H8085"\w* \w Ebed-melec|strong="H5663"\w*, \w etíope|strong="H3569"\w*, \w eunuco|strong="H5631"\w* \w que|strong="H3588"\w* \w estaba|strong="H3427"\w* \w en|strong="H3588"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w*, \w que|strong="H3588"\w* habían \w puesto|strong="H5414"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w en|strong="H3588"\w* \w la|strong="H1931"\w* cisterna (\w estando|strong="H3427"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w sentado|strong="H3427"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w puerta|strong="H8179"\w* \w de|strong="H3588"\w* \w Benjamín|strong="H1144"\w*),  
\v 8 \w Ebed-melec|strong="H5663"\w* \w salió|strong="H3318"\w* de la \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w* y \w habló|strong="H1696"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, \w diciendo|strong="H1696"\w*:  
\v 9 «Mi señor \w el|strong="H3588"\w* \w rey|strong="H4428"\w*, \w mal|strong="H7489"\w* \w han|strong="H4191"\w* \w hecho|strong="H6213"\w* \w estos|strong="H3605"\w* hombres \w en|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w han|strong="H4191"\w* \w hecho|strong="H6213"\w* \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*, \w al|strong="H4428"\w* \w cual|strong="H3588"\w* \w hicieron|strong="H6213"\w* echar \w en|strong="H3588"\w* \w la|strong="H3588"\w* cisterna; \w porque|strong="H3588"\w* allí \w morirá|strong="H4191"\w* \w de|strong="H3588"\w* \w hambre|strong="H7458"\w*, \w pues|strong="H3588"\w* \w no|strong="H6213"\w* \w hay|strong="H5750"\w* \w más|strong="H5750"\w* \w pan|strong="H3899"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*».   
\p
\v 10 Entonces \w mandó|strong="H6680"\w* \w el|strong="H5030"\w* \w rey|strong="H4428"\w* \w al|strong="H4480"\w* mismo \w Ebed-melec|strong="H5663"\w*, \w etíope|strong="H3569"\w*, diciendo: «\w Toma|strong="H3947"\w* \w en|strong="H4480"\w* tu \w poder|strong="H3027"\w* \w treinta|strong="H7970"\w* hombres \w de|strong="H4480"\w* \w aquí|strong="H2088"\w*, y \w saca|strong="H5927"\w* \w al|strong="H4480"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H4480"\w* la cisterna, \w antes|strong="H2962"\w* \w que|strong="H4480"\w* \w muera|strong="H4191"\w*».   
\p
\v 11 \w Tomó|strong="H3947"\w* \w Ebed-melec|strong="H5663"\w* \w a|strong="H3068"\w* los hombres consigo, y entró \w en|strong="H8478"\w* la \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* la tesorería, y \w tomó|strong="H3947"\w* \w de|strong="H8478"\w* \w allí|strong="H8033"\w* \w trapos|strong="H5499"\w* \w viejos|strong="H1094"\w* y ropas raídas, y los \w bajó|strong="H8478"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* con cuerdas \w en|strong="H8478"\w* la cisterna.  
\v 12 \w Y|strong="H3068"\w* dijo \w el|strong="H6213"\w* \w etíope|strong="H3569"\w* \w Ebed-melec|strong="H5663"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: «\w Pon|strong="H7760"\w* \w ahora|strong="H4994"\w* esos \w trapos|strong="H5499"\w* \w viejos|strong="H1094"\w* y ropas raídas \w bajo|strong="H8478"\w* tus axilas, \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* las cuerdas».  
\p \w Y|strong="H3068"\w* \w lo|strong="H6213"\w* \w hizo|strong="H6213"\w* \w así|strong="H3651"\w* \w Jeremías|strong="H3414"\w*.  
\v 13 \w De|strong="H4480"\w* este modo \w sacaron|strong="H4900"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w con|strong="H4480"\w* cuerdas, y lo \w subieron|strong="H5927"\w* \w de|strong="H4480"\w* la cisterna; y \w quedó|strong="H3427"\w* \w Jeremías|strong="H3414"\w* \w en|strong="H4480"\w* \w el|strong="H3427"\w* \w patio|strong="H2691"\w* \w de|strong="H4480"\w* la guardia.   
\p
\v 14 Después \w envió|strong="H7971"\w* \w el|strong="H5030"\w* \w rey|strong="H4428"\w* Sedequías, \w e|strong="H3068"\w* hizo traer \w al|strong="H4480"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w a|strong="H3068"\w* la \w tercera|strong="H7992"\w* \w entrada|strong="H3996"\w* \w que|strong="H4480"\w* \w estaba|strong="H1004"\w* \w en|strong="H4480"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* Yahvé. \w Y|strong="H3068"\w* dijo \w el|strong="H5030"\w* \w rey|strong="H4428"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: «\w Te|strong="H4480"\w* haré una \w pregunta|strong="H7592"\w*; no \w me|strong="H4480"\w* \w encubras|strong="H3582"\w* \w nada|strong="H1697"\w*».   
\p
\v 15 \w Y|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w dijo|strong="H5046"\w* \w a|strong="H3068"\w* Sedequías: «\w Si|strong="H3588"\w* \w te|strong="H3588"\w* \w lo|strong="H3808"\w* declarare, ¿\w no|strong="H3808"\w* \w es|strong="H3588"\w* \w cierto|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* matarás? \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w te|strong="H3588"\w* diere \w consejo|strong="H3289"\w*, \w no|strong="H3808"\w* \w me|strong="H3588"\w* escucharás».   
\p
\v 16 \w Y|strong="H3068"\w* \w juró|strong="H7650"\w* \w el|strong="H6213"\w* \w rey|strong="H4428"\w* Sedequías en secreto \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, diciendo: «\w Vive|strong="H2416"\w* Yahvé \w que|strong="H3027"\w* nos \w hizo|strong="H6213"\w* \w esta|strong="H2063"\w* \w alma|strong="H5315"\w*, \w que|strong="H3027"\w* \w no|strong="H6213"\w* \w te|strong="H5315"\w* \w mataré|strong="H4191"\w*, ni \w te|strong="H5315"\w* \w entregaré|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* \w estos|strong="H2063"\w* hombres \w que|strong="H3027"\w* \w buscan|strong="H1245"\w* \w tu|strong="H6213"\w* \w vida|strong="H5315"\w*».   
\p
\v 17 Entonces dijo \w Jeremías|strong="H3414"\w* \w a|strong="H3068"\w* Sedequías: “\w Así|strong="H3541"\w* dice Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H8269"\w* los \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H8269"\w* \w Israel|strong="H3478"\w*: ‘\w Si|strong="H3808"\w* \w te|strong="H5315"\w* entregares enseguida \w a|strong="H3068"\w* los \w príncipes|strong="H8269"\w* del \w rey|strong="H4428"\w* \w de|strong="H8269"\w* Babilonia, tu \w alma|strong="H5315"\w* \w vivirá|strong="H2421"\w*, \w y|strong="H3541"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w no|strong="H3808"\w* \w será|strong="H3808"\w* puesta \w a|strong="H3068"\w* fuego, \w y|strong="H3541"\w* \w vivirás|strong="H2421"\w* tú \w y|strong="H3541"\w* tu \w casa|strong="H1004"\w*.  
\v 18 Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* te \w entregares|strong="H5414"\w* \w a|strong="H3068"\w* los \w príncipes|strong="H8269"\w* del \w rey|strong="H4428"\w* \w de|strong="H8269"\w* Babilonia, entonces \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w será|strong="H3808"\w* \w entregada|strong="H5414"\w* \w en|strong="H3318"\w* \w mano|strong="H3027"\w* \w de|strong="H8269"\w* los \w caldeos|strong="H3778"\w*, y \w la|strong="H2063"\w* \w pondrán|strong="H5414"\w* \w a|strong="H3068"\w* fuego, y tú \w no|strong="H3808"\w* \w escaparás|strong="H4422"\w* \w de|strong="H8269"\w* su \w mano|strong="H3027"\w*’”.   
\p
\v 19 \w Y|strong="H3068"\w* \w el|strong="H5307"\w* \w rey|strong="H4428"\w* Sedequías dijo \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: «Tengo miedo \w de|strong="H5414"\w* los \w judíos|strong="H3064"\w* \w que|strong="H6435"\w* \w se|strong="H6435"\w* han pasado \w a|strong="H3068"\w* los \w caldeos|strong="H3778"\w*, \w de|strong="H5414"\w* \w que|strong="H6435"\w* me entreguen en sus \w manos|strong="H3027"\w* y \w se|strong="H6435"\w* burlen \w de|strong="H5414"\w* mí».   
\p
\v 20 \w Y|strong="H3068"\w* \w dijo|strong="H1696"\w* \w Jeremías|strong="H3414"\w*: “\w No|strong="H3808"\w* \w te|strong="H5315"\w* entregarán. \w Oye|strong="H8085"\w* \w ahora|strong="H4994"\w*, \w te|strong="H5315"\w* \w ruego|strong="H4994"\w*, la \w voz|strong="H6963"\w* \w de|strong="H5414"\w* Yahvé en \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w yo|strong="H5315"\w* \w te|strong="H5315"\w* \w hablo|strong="H1696"\w*, y \w te|strong="H5315"\w* irá \w bien|strong="H3190"\w* y \w vivirá|strong="H2421"\w* tu \w alma|strong="H5315"\w*.  
\v 21 Pero si no quieres entregarte, \w esta|strong="H2088"\w* \w es|strong="H2088"\w* la \w palabra|strong="H1697"\w* \w que|strong="H1697"\w* me ha mostrado Yahvé:  
\v 22 ‘He \w aquí|strong="H2009"\w* \w que|strong="H3605"\w* \w todas|strong="H3605"\w* las mujeres \w que|strong="H3605"\w* han quedado \w en|strong="H3318"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w* \w de|strong="H8269"\w* \w Judá|strong="H3063"\w* serán sacadas \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w príncipes|strong="H8269"\w* del \w rey|strong="H4428"\w* \w de|strong="H8269"\w* Babilonia; y \w ellas|strong="H2007"\w* mismas dirán:  
\q1 «Tus amigos íntimos te han engañado,  
\q2 y han prevalecido contra ti;  
\q1 se hundieron tus \w pies|strong="H7272"\w* \w en|strong="H3318"\w* \w el|strong="H3605"\w* lodo,  
\q2 y \w ellos|strong="H3605"\w* se volvieron atrás».   
\p
\v 23 Llevarán, \w pues|strong="H3588"\w*, \w todas|strong="H3605"\w* tus mujeres \w y|strong="H3588"\w* tus \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w caldeos|strong="H3778"\w*, \w y|strong="H3588"\w* tú \w no|strong="H3808"\w* \w escaparás|strong="H4422"\w* \w de|strong="H3588"\w* sus \w manos|strong="H3027"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w por|strong="H3588"\w* \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia serás apresado; \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* le pondrán fuego’”.   
\p
\v 24 Entonces dijo Sedequías \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*: “\w Nadie|strong="H3808"\w* \w sepa|strong="H3045"\w* estas \w palabras|strong="H1697"\w*, y \w no|strong="H3808"\w* \w morirás|strong="H4191"\w*.  
\v 25 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w los|strong="H3588"\w* \w príncipes|strong="H8269"\w* \w oyeren|strong="H8085"\w* \w que|strong="H3588"\w* \w yo|strong="H4480"\w* he \w hablado|strong="H1696"\w* contigo, \w y|strong="H3588"\w* vinieren \w a|strong="H3068"\w* \w ti|strong="H4480"\w* \w y|strong="H3588"\w* \w te|strong="H4480"\w* dijeren: ‘\w Decláranos|strong="H5046"\w* \w ahora|strong="H4994"\w* \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \w hablaste|strong="H1696"\w* \w con|strong="H4480"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w*, \w no|strong="H3808"\w* \w nos|strong="H4480"\w* \w lo|strong="H4100"\w* \w encubras|strong="H3582"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H4480"\w* \w mataremos|strong="H4191"\w*; dinos también \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w te|strong="H4480"\w* \w ha|strong="H3808"\w* \w dicho|strong="H1696"\w*’,  
\v 26 les dirás: ‘Presenté \w mi|strong="H1115"\w* \w ruego|strong="H8467"\w* \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w*, para \w que|strong="H1115"\w* \w no|strong="H1115"\w* me hiciese \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H6440"\w* Jonatán para \w morir|strong="H4191"\w* \w allí|strong="H8033"\w*’”.   
\p
\v 27 \w Y|strong="H3068"\w* \w vinieron|strong="H5046"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w príncipes|strong="H8269"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, \w y|strong="H3588"\w* le \w preguntaron|strong="H7592"\w*; \w y|strong="H3588"\w* \w él|strong="H3588"\w* \w les|strong="H1992"\w* respondió conforme \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w aquellas|strong="H1992"\w* \w palabras|strong="H1697"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* le \w había|strong="H3588"\w* \w mandado|strong="H6680"\w*. \w Con|strong="H4480"\w* \w esto|strong="H1697"\w* \w se|strong="H4480"\w* retiraron \w de|strong="H4480"\w* \w él|strong="H3588"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w asunto|strong="H1697"\w* \w no|strong="H3808"\w* \w se|strong="H4480"\w* \w había|strong="H3588"\w* divulgado.   
\p
\v 28 \w Y|strong="H3068"\w* \w quedó|strong="H1961"\w* \w Jeremías|strong="H3414"\w* \w en|strong="H5704"\w* \w el|strong="H3427"\w* \w patio|strong="H2691"\w* \w de|strong="H5704"\w* la guardia \w hasta|strong="H5704"\w* \w el|strong="H3427"\w* \w día|strong="H3117"\w* \w que|strong="H5704"\w* \w fue|strong="H1961"\w* \w tomada|strong="H3920"\w* Jerusalén.   
\c 39
\p
\v 1 \w En|strong="H5921"\w* \w el|strong="H5921"\w* \w noveno|strong="H8671"\w* \w año|strong="H8141"\w* \w de|strong="H5921"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w décimo|strong="H6224"\w* \w mes|strong="H2320"\w*, vino \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w con|strong="H5921"\w* \w todo|strong="H3605"\w* su \w ejército|strong="H2428"\w* \w contra|strong="H5921"\w* Jerusalén, \w y|strong="H5921"\w* \w la|strong="H5921"\w* sitiaron.  
\v 2 \w Y|strong="H3068"\w* en el \w undécimo|strong="H6249"\w* \w año|strong="H8141"\w* de Sedequías, en el \w mes|strong="H2320"\w* \w cuarto|strong="H7243"\w*, \w a|strong="H3068"\w* los \w nueve|strong="H8672"\w* días del \w mes|strong="H2320"\w*, se abrió brecha en el muro de la \w ciudad|strong="H5892"\w*.  
\v 3 \w Y|strong="H3068"\w* entraron \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w príncipes|strong="H8269"\w* del \w rey|strong="H4428"\w* \w de|strong="H8269"\w* Babilonia y acamparon \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* del \w Medio|strong="H8432"\w*: \w Nergal-sarezer|strong="H5371"\w*, \w Samgar-nebo|strong="H5562"\w*, Sarsequim \w el|strong="H3605"\w* \w Rabsaris|strong="H7249"\w*, \w Nergal-sarezer|strong="H5371"\w* \w el|strong="H3605"\w* \w Rabmag|strong="H7248"\w*, y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* demás \w príncipes|strong="H8269"\w* del \w rey|strong="H4428"\w* \w de|strong="H8269"\w* Babilonia.  
\v 4 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H4480"\w* \w cuando|strong="H1961"\w* \w los|strong="H3605"\w* \w vieron|strong="H7200"\w* Sedequías, \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H4480"\w* \w guerra|strong="H4421"\w*, \w huyeron|strong="H1272"\w* y \w salieron|strong="H3318"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w de|strong="H4480"\w* \w noche|strong="H3915"\w* \w por|strong="H4480"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w del|strong="H4480"\w* jardín \w del|strong="H4480"\w* \w rey|strong="H4428"\w*, \w por|strong="H4480"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w entre|strong="H4480"\w* \w los|strong="H3605"\w* dos \w muros|strong="H2346"\w*; y \w salió|strong="H3318"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w hacia|strong="H1870"\w* \w el|strong="H3605"\w* Arabá.   
\p
\v 5 Pero el \w ejército|strong="H2428"\w* de \w los|strong="H7291"\w* \w caldeos|strong="H3778"\w* \w los|strong="H7291"\w* \w siguió|strong="H7291"\w*, y \w alcanzaron|strong="H5381"\w* \w a|strong="H3068"\w* Sedequías en \w los|strong="H7291"\w* \w llanos|strong="H6160"\w* de \w Jericó|strong="H3405"\w*; y lo \w tomaron|strong="H3947"\w* y lo \w llevaron|strong="H3947"\w* \w a|strong="H3068"\w* Ribla, en tierra de Hamat, ante \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* de Babilonia, quien \w pronunció|strong="H1696"\w* \w sentencia|strong="H4941"\w* contra él.  
\v 6 \w Y|strong="H3068"\w* \w degolló|strong="H7819"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Sedequías en Ribla, ante sus propios \w ojos|strong="H5869"\w*; asimismo \w degolló|strong="H7819"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* nobles \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 7 Además, sacó los \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* Sedequías y lo aprisionó con grilletes \w de|strong="H5869"\w* bronce para llevarlo \w a|strong="H3068"\w* Babilonia.   
\p
\v 8 \w Y|strong="H3068"\w* los \w caldeos|strong="H3778"\w* incendiaron con fuego la \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w* y las \w casas|strong="H1004"\w* del \w pueblo|strong="H5971"\w*, y derribaron los \w muros|strong="H2346"\w* \w de|strong="H5971"\w* Jerusalén.  
\v 9 \w Y|strong="H3068"\w* \w al|strong="H5921"\w* \w resto|strong="H3499"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* había quedado \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* habían pasado \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w con|strong="H5921"\w* todo \w el|strong="H5921"\w* \w resto|strong="H3499"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* había quedado, \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* guardia, \w los|strong="H5921"\w* transportó \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* Babilonia.  
\v 10 Pero \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* guardia, \w dejó|strong="H7604"\w* \w en|strong="H4480"\w* \w la|strong="H1931"\w* tierra \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w pobres|strong="H1800"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w que|strong="H4480"\w* no tenían \w nada|strong="H3972"\w*, y \w les|strong="H3972"\w* \w dio|strong="H5414"\w* \w viñas|strong="H3754"\w* y campos \w en|strong="H4480"\w* \w aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*.   
\p
\v 11 \w Y|strong="H3068"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, había dado órdenes \w sobre|strong="H5921"\w* \w Jeremías|strong="H3414"\w* \w por|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* guardia, diciendo:  
\v 12 «\w Tómalo|strong="H3947"\w* \w y|strong="H3588"\w* cuida \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H3588"\w* \w no|strong="H6213"\w* \w le|strong="H5921"\w* \w hagas|strong="H6213"\w* ningún \w mal|strong="H7451"\w*; \w antes|strong="H3588"\w* \w bien|strong="H3588"\w*, \w haz|strong="H6213"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w como|strong="H3588"\w* \w él|strong="H5921"\w* \w te|strong="H5869"\w* \w dijere|strong="H1696"\w*».   
\p
\v 13 \w Enviaron|strong="H7971"\w*, \w pues|strong="H7971"\w*, \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* de \w la|strong="H3605"\w* guardia, Nabusazbán \w el|strong="H3605"\w* \w Rabsaris|strong="H7249"\w*, \w Nergal-sarezer|strong="H5371"\w* \w el|strong="H3605"\w* \w Rabmag|strong="H7248"\w* y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* oficiales del \w rey|strong="H4428"\w* de Babilonia;  
\v 14 \w enviaron|strong="H7971"\w* entonces y \w tomaron|strong="H3947"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* del \w patio|strong="H2691"\w* \w de|strong="H1121"\w* la guardia, y lo entregaron \w a|strong="H3068"\w* \w Gedalías|strong="H1436"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán, \w para|strong="H5414"\w* \w que|strong="H5971"\w* lo \w llevara|strong="H3947"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w*; y así vivió \w entre|strong="H8432"\w* \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 15 \w Y|strong="H3068"\w* \w había|strong="H1961"\w* venido \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, \w estando|strong="H1961"\w* él aún recluido en el \w patio|strong="H2691"\w* \w de|strong="H1697"\w* la guardia, diciendo:  
\v 16 “\w Ve|strong="H1980"\w* \w y|strong="H3541"\w* \w habla|strong="H1697"\w* \w a|strong="H3068"\w* \w Ebed-melec|strong="H5663"\w*, \w etíope|strong="H3569"\w*, diciendo: ‘\w Así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé \w de|strong="H6440"\w* \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*: He \w aquí|strong="H3541"\w* \w que|strong="H1931"\w* yo traigo mis \w palabras|strong="H1697"\w* \w sobre|strong="H1961"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w para|strong="H1961"\w* \w mal|strong="H7451"\w* \w y|strong="H3541"\w* \w no|strong="H3808"\w* \w para|strong="H1961"\w* \w bien|strong="H2896"\w*; \w y|strong="H3541"\w* \w se|strong="H1961"\w* cumplirán en tu \w presencia|strong="H6440"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*.  
\v 17 Pero en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* yo te \w libraré|strong="H5337"\w* — \w dice|strong="H5002"\w* Yahvé — y \w no|strong="H3808"\w* serás \w entregado|strong="H5414"\w* en \w manos|strong="H3027"\w* \w de|strong="H6440"\w* aquellos hombres \w a|strong="H3068"\w* quienes \w temes|strong="H3016"\w*.  
\v 18 \w Porque|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \w te|strong="H3588"\w* libraré, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w caerás|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* tu \w vida|strong="H5315"\w* \w te|strong="H3588"\w* \w será|strong="H1961"\w* \w por|strong="H3588"\w* botín, \w porque|strong="H3588"\w* tuviste confianza \w en|strong="H3588"\w* \w mí|strong="H1961"\w* — \w dice|strong="H5002"\w* Yahvé —’”.   
\c 40
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H4480"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H4480"\w* parte \w de|strong="H4480"\w* Yahvé, \w después|strong="H1961"\w* \w que|strong="H4480"\w* \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* guardia, \w lo|strong="H1931"\w* \w dejó|strong="H7971"\w* \w ir|strong="H7971"\w* \w desde|strong="H4480"\w* \w Ramá|strong="H7414"\w*, \w cuando|strong="H1961"\w* \w lo|strong="H1931"\w* \w tomó|strong="H3947"\w* atado \w con|strong="H4480"\w* cadenas \w entre|strong="H8432"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w cautivos|strong="H1540"\w* \w de|strong="H4480"\w* Jerusalén y \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* \w que|strong="H4480"\w* iban transportados \w a|strong="H3068"\w* Babilonia.  
\v 2 \w Tomó|strong="H3947"\w*, \w pues|strong="H2088"\w*, el \w capitán|strong="H7227"\w* \w de|strong="H7451"\w* \w la|strong="H2063"\w* guardia \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* y le \w dijo|strong="H1696"\w*: «Yahvé tu \w Dios|strong="H3068"\w* \w pronunció|strong="H1696"\w* \w este|strong="H2088"\w* \w mal|strong="H7451"\w* sobre \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*;  
\v 3 \w y|strong="H3588"\w* \w lo|strong="H1697"\w* \w ha|strong="H3808"\w* traído Yahvé, \w y|strong="H3588"\w* \w ha|strong="H3808"\w* \w hecho|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w había|strong="H1961"\w* \w dicho|strong="H1697"\w*; \w porque|strong="H3588"\w* habéis \w pecado|strong="H2398"\w* \w contra|strong="H1961"\w* Yahvé \w y|strong="H3588"\w* \w no|strong="H3808"\w* habéis escuchado \w su|strong="H3588"\w* \w voz|strong="H6963"\w*, \w por|strong="H3588"\w* eso os \w ha|strong="H3808"\w* sobrevenido \w esto|strong="H2088"\w*.  
\v 4 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* \w te|strong="H5869"\w* he soltado \w hoy|strong="H3117"\w* \w de|strong="H4480"\w* \w las|strong="H5921"\w* cadenas \w que|strong="H4480"\w* tenías \w en|strong="H5921"\w* tus \w manos|strong="H3027"\w*. \w Si|strong="H6440"\w* \w te|strong="H5869"\w* parece \w bien|strong="H2896"\w* \w venir|strong="H3212"\w* conmigo \w a|strong="H3068"\w* Babilonia, \w ven|strong="H3212"\w*, \w y|strong="H5921"\w* \w yo|strong="H4480"\w* velaré \w por|strong="H5921"\w* \w ti|strong="H5921"\w*; pero \w si|strong="H6440"\w* \w te|strong="H5869"\w* parece \w mal|strong="H7489"\w* \w venir|strong="H3212"\w* conmigo \w a|strong="H3068"\w* Babilonia, \w déjalo|strong="H2308"\w*. \w Mira|strong="H7200"\w*, \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w está|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w ti|strong="H5921"\w*; \w ve|strong="H3212"\w* \w a|strong="H3068"\w* \w donde|strong="H8033"\w* \w mejor|strong="H2896"\w* \w y|strong="H5921"\w* \w más|strong="H4480"\w* cómodo \w te|strong="H5869"\w* \w parezca|strong="H7200"\w*».  
