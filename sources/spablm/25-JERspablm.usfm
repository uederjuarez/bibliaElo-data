\q1
\v 37 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* Babilonia un \w montón|strong="H1530"\w* de ruinas,  
\q2 \w morada|strong="H3427"\w* de chacales,  
\q2 objeto de \w espanto|strong="H8047"\w* y de burla, sin \w morador|strong="H3427"\w* alguno.   
\q1
\v 38 \w Todos|strong="H3162"\w* ellos rugirán \w como|strong="H7580"\w* leones,  
\q2 gruñirán \w como|strong="H7580"\w* \w cachorros|strong="H1484"\w* de león.   
\q1
