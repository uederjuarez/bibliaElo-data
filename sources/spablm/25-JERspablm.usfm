\p
\v 19 \w Así|strong="H3541"\w* \w me|strong="H3541"\w* \w ha|strong="H3541"\w* dicho Yahvé: “\w Ve|strong="H1980"\w* \w y|strong="H3541"\w* \w ponte|strong="H5975"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w pueblo|strong="H5971"\w*, \w por|strong="H4428"\w* \w la|strong="H3605"\w* cual entran \w y|strong="H3541"\w* \w salen|strong="H3318"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3541"\w* \w en|strong="H3318"\w* \w todas|strong="H3605"\w* las \w puertas|strong="H8179"\w* \w de|strong="H1121"\w* Jerusalén.  
\v 20 \w Y|strong="H3068"\w* \w diles|strong="H1697"\w*: ‘\w Oíd|strong="H8085"\w* \w la|strong="H3605"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, \w vosotros|strong="H8085"\w* \w reyes|strong="H4428"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w*, y \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H1697"\w* Jerusalén \w que|strong="H1697"\w* entráis \w por|strong="H1697"\w* estas \w puertas|strong="H8179"\w*.  
\v 21 \w Así|strong="H3541"\w* dice Yahvé: \w Guardaos|strong="H8104"\w* por vuestra \w vida|strong="H5315"\w*, \w y|strong="H3541"\w* no llevéis \w carga|strong="H4853"\w* en \w día|strong="H3117"\w* de reposo, ni \w la|strong="H8104"\w* metáis por las \w puertas|strong="H8179"\w* de Jerusalén.  
\v 22 \w Ni|strong="H3808"\w* \w saquéis|strong="H3318"\w* \w carga|strong="H4853"\w* de vuestras \w casas|strong="H1004"\w* \w en|strong="H3318"\w* \w día|strong="H3117"\w* de reposo, \w ni|strong="H3808"\w* \w hagáis|strong="H6213"\w* trabajo \w alguno|strong="H3605"\w*, \w sino|strong="H3808"\w* \w santificad|strong="H6942"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* de reposo, como \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* vuestros padres.  
\v 23 Pero ellos \w no|strong="H3808"\w* \w escucharon|strong="H8085"\w*, \w ni|strong="H3808"\w* \w inclinaron|strong="H5186"\w* su \w oído|strong="H8085"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* endurecieron su \w cerviz|strong="H6203"\w*, para \w no|strong="H3808"\w* \w oír|strong="H8085"\w*, \w ni|strong="H3808"\w* \w recibir|strong="H3947"\w* \w corrección|strong="H4148"\w*.  
\v 24 \w No|strong="H6213"\w* obstante, \w si|strong="H1961"\w* \w vosotros|strong="H8085"\w* me escuchareis con diligencia — \w dice|strong="H5002"\w* Yahvé —, \w no|strong="H6213"\w* metiendo \w carga|strong="H4853"\w* por las \w puertas|strong="H8179"\w* de \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* en \w día|strong="H3117"\w* de reposo, sino \w que|strong="H1115"\w* santificareis \w el|strong="H3605"\w* \w día|strong="H3117"\w* de reposo y \w no|strong="H6213"\w* \w haréis|strong="H6213"\w* en \w él|strong="H3605"\w* trabajo \w alguno|strong="H3605"\w*,  
\v 25 entrarán \w por|strong="H5921"\w* \w las|strong="H1992"\w* \w puertas|strong="H8179"\w* \w de|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, \w en|strong="H5921"\w* \w carros|strong="H7393"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w caballos|strong="H5483"\w*, \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w y|strong="H5921"\w* \w los|strong="H1992"\w* \w príncipes|strong="H8269"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* sientan \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*, \w ellos|strong="H1992"\w* \w y|strong="H5921"\w* \w sus|strong="H1992"\w* \w príncipes|strong="H8269"\w*, \w los|strong="H1992"\w* varones \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w los|strong="H1992"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén; \w y|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* será \w habitada|strong="H3427"\w* \w para|strong="H5921"\w* \w siempre|strong="H5769"\w*.  
\v 26 \w Y|strong="H3068"\w* vendrán \w de|strong="H4480"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w de|strong="H4480"\w* los \w alrededores|strong="H5439"\w* \w de|strong="H4480"\w* Jerusalén, \w de|strong="H4480"\w* tierra \w de|strong="H4480"\w* \w Benjamín|strong="H1144"\w*, \w de|strong="H4480"\w* la Sefela, \w de|strong="H4480"\w* los \w montes|strong="H2022"\w* y \w del|strong="H4480"\w* Neguev, trayendo \w holocausto|strong="H5930"\w* y \w sacrificio|strong="H2077"\w*, y \w ofrenda|strong="H4503"\w* y perfume, y trayendo \w sacrificios|strong="H2077"\w* \w de|strong="H4480"\w* \w alabanza|strong="H8426"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* Yahvé.  
\v 27 Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* me escuchareis para santificar el \w día|strong="H3117"\w* de reposo, y para \w no|strong="H3808"\w* \w traer|strong="H5375"\w* \w carga|strong="H4853"\w* \w ni|strong="H3808"\w* meterla por las \w puertas|strong="H8179"\w* de Jerusalén en \w día|strong="H3117"\w* de reposo, yo haré encender fuego en sus \w puertas|strong="H8179"\w*, el cual consumirá los palacios de Jerusalén, y \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w apagará|strong="H3518"\w*’”.   
\c 18
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H1697"\w* parte \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 «\w Levántate|strong="H6965"\w* y \w baja|strong="H1004"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w* del alfarero, y \w allí|strong="H8033"\w* te haré \w oír|strong="H8085"\w* mis \w palabras|strong="H1697"\w*».   
\p
\v 3 \w Y|strong="H3068"\w* bajé \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* alfarero, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w estaba|strong="H2009"\w* trabajando \w en|strong="H5921"\w* \w el|strong="H5921"\w* torno.  
\v 4 \w Y|strong="H3068"\w* \w la|strong="H1931"\w* \w vasija|strong="H3627"\w* \w de|strong="H5869"\w* \w barro|strong="H2563"\w* \w que|strong="H1931"\w* \w él|strong="H1931"\w* \w hacía|strong="H6213"\w* \w se|strong="H1931"\w* echó \w a|strong="H3068"\w* perder en \w su|strong="H1931"\w* \w mano|strong="H3027"\w*; y \w volvió|strong="H7725"\w* y \w hizo|strong="H6213"\w* \w otra|strong="H6213"\w* \w vasija|strong="H3627"\w*, según \w le|strong="H1931"\w* \w pareció|strong="H5869"\w* \w mejor|strong="H3474"\w* hacerla.   
\p
\v 5 Entonces \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 6 “¿\w No|strong="H3808"\w* \w podré|strong="H3201"\w* \w yo|strong="H2009"\w* \w hacer|strong="H6213"\w* de vosotros \w como|strong="H3651"\w* \w este|strong="H2088"\w* alfarero, oh \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*? — \w dice|strong="H5002"\w* Yahvé —. He \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w como|strong="H3651"\w* \w el|strong="H6213"\w* \w barro|strong="H2563"\w* en la \w mano|strong="H3027"\w* del alfarero, \w así|strong="H3651"\w* sois vosotros en \w mi|strong="H2009"\w* \w mano|strong="H3027"\w*, oh \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*.  
\v 7 \w En|strong="H5921"\w* \w el|strong="H5921"\w* instante \w que|strong="H5921"\w* yo \w hablare|strong="H1696"\w* \w contra|strong="H5921"\w* una \w nación|strong="H1471"\w* \w o|strong="H3068"\w* \w contra|strong="H5921"\w* un \w reino|strong="H4467"\w*, \w para|strong="H5921"\w* arrancar, \w y|strong="H5921"\w* derribar \w y|strong="H5921"\w* destruir,  
\v 8 \w si|strong="H1931"\w* \w esa|strong="H1931"\w* \w nación|strong="H1471"\w* \w se|strong="H1931"\w* convirtiere \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w maldad|strong="H7451"\w* \w contra|strong="H5921"\w* \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w hablé|strong="H1696"\w*, \w yo|strong="H6213"\w* \w me|strong="H5921"\w* arrepentiré \w del|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H1931"\w* \w había|strong="H6213"\w* pensado \w hacerles|strong="H6213"\w*.  
\v 9 \w Y|strong="H3068"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* instante \w que|strong="H5921"\w* yo \w hablare|strong="H1696"\w* \w de|strong="H5921"\w* una \w nación|strong="H1471"\w* \w o|strong="H3068"\w* \w de|strong="H5921"\w* un \w reino|strong="H4467"\w*, \w para|strong="H5921"\w* \w edificar|strong="H1129"\w* \w y|strong="H5921"\w* \w para|strong="H5921"\w* plantar,  
\v 10 \w si|strong="H5921"\w* \w hiciere|strong="H6213"\w* \w lo|strong="H5921"\w* \w malo|strong="H7451"\w* ante mis \w ojos|strong="H5869"\w*, \w no|strong="H6213"\w* \w obedeciendo|strong="H8085"\w* \w mi|strong="H5921"\w* \w voz|strong="H6963"\w*, \w me|strong="H5921"\w* arrepentiré \w del|strong="H5921"\w* \w bien|strong="H2896"\w* \w que|strong="H5921"\w* \w había|strong="H6213"\w* determinado \w hacerles|strong="H6213"\w*.   
\p
\v 11 “\w Ahora|strong="H6258"\w*, \w pues|strong="H4994"\w*, habla \w a|strong="H3068"\w* \w los|strong="H3427"\w* varones \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén, diciendo: ‘\w Así|strong="H3541"\w* dice Yahvé: He \w aquí|strong="H2009"\w* \w que|strong="H6258"\w* \w yo|strong="H2009"\w* \w dispongo|strong="H3335"\w* \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* vosotros, \w y|strong="H5921"\w* trazo \w contra|strong="H5921"\w* vosotros un plan. \w Volveos|strong="H7725"\w* \w ahora|strong="H6258"\w* cada uno \w de|strong="H5921"\w* su \w mal|strong="H7451"\w* \w camino|strong="H1870"\w*, \w y|strong="H5921"\w* enmendad vuestros \w caminos|strong="H1870"\w* \w y|strong="H5921"\w* vuestras \w obras|strong="H4611"\w*’.  
\v 12 \w Y|strong="H3068"\w* dijeron: ‘\w Es|strong="H3588"\w* \w en|strong="H3588"\w* vano; \w porque|strong="H3588"\w* tras nuestros propios planes \w iremos|strong="H3212"\w*, \w y|strong="H3588"\w* cada uno \w de|strong="H3588"\w* nosotros seguirá \w la|strong="H3588"\w* dureza \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w malvado|strong="H7451"\w* \w corazón|strong="H3820"\w*’”.   
\p
\v 13 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé:  
\q1 «\w Preguntad|strong="H7592"\w* \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*,  
\q2 ¿\w quién|strong="H4310"\w* \w ha|strong="H3541"\w* \w oído|strong="H8085"\w* cosa \w semejante|strong="H3651"\w*?  
\q2 \w Gran|strong="H3966"\w* \w fealdad|strong="H8186"\w* \w ha|strong="H3541"\w* \w hecho|strong="H6213"\w* la \w virgen|strong="H1330"\w* de \w Israel|strong="H3478"\w*.   
\q1
\v 14 ¿\w Faltará|strong="H5800"\w* la nieve del \w Líbano|strong="H3844"\w* \w de|strong="H4325"\w* la piedra del \w campo|strong="H7704"\w*?  
\q2 ¿\w Faltarán|strong="H5428"\w* las \w aguas|strong="H4325"\w* \w frías|strong="H7119"\w* \w que|strong="H4325"\w* corren \w de|strong="H4325"\w* lejos?   
\q1
\v 15 \w Porque|strong="H3588"\w* mi \w pueblo|strong="H5971"\w* \w me|strong="H3588"\w* \w ha|strong="H3808"\w* olvidado,  
\q2 \w incensando|strong="H6999"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w vanidad|strong="H7723"\w*;  
\q1 \w y|strong="H3588"\w* les han hecho tropezar \w en|strong="H3588"\w* sus \w caminos|strong="H1870"\w*,  
\q2 \w en|strong="H3588"\w* las sendas \w antiguas|strong="H5769"\w*,  
\q2 \w para|strong="H3588"\w* \w que|strong="H3588"\w* caminen \w por|strong="H3588"\w* senderos, \w por|strong="H3588"\w* \w camino|strong="H1870"\w* \w no|strong="H3808"\w* hollado,   
\q1
\v 16 \w para|strong="H5921"\w* poner su tierra \w en|strong="H5921"\w* desolación,  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* escarnio \w perpetuo|strong="H5769"\w*.  
\q1 \w Todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w que|strong="H5921"\w* \w pase|strong="H5674"\w* \w por|strong="H5921"\w* \w ella|strong="H5921"\w* \w se|strong="H5921"\w* asombrará  
\q2 \w y|strong="H5921"\w* meneará su \w cabeza|strong="H7218"\w*.   
\q1
\v 17 Como \w viento|strong="H7307"\w* \w solano|strong="H6921"\w* los \w esparciré|strong="H6327"\w* \w delante|strong="H6440"\w* del enemigo;  
\q2 les \w mostraré|strong="H7200"\w* la espalda y \w no|strong="H3808"\w* el \w rostro|strong="H6440"\w*  
\q2 en el \w día|strong="H3117"\w* \w de|strong="H6440"\w* su perdición».   
\p
\v 18 \w Y|strong="H3068"\w* \w dijeron|strong="H1697"\w*: «\w Venid|strong="H3212"\w* \w e|strong="H3068"\w* ideemos planes \w contra|strong="H5921"\w* \w Jeremías|strong="H3414"\w*; \w porque|strong="H3588"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w no|strong="H3808"\w* faltará \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w*, \w ni|strong="H3808"\w* \w el|strong="H5921"\w* \w consejo|strong="H6098"\w* \w al|strong="H5921"\w* \w sabio|strong="H2450"\w*, \w ni|strong="H3808"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w al|strong="H5921"\w* \w profeta|strong="H5030"\w*. \w Venid|strong="H3212"\w* \w e|strong="H3068"\w* hiriámosle \w de|strong="H5921"\w* \w lengua|strong="H3956"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* prestemos atención \w a|strong="H3068"\w* \w ninguna|strong="H3605"\w* \w de|strong="H5921"\w* sus \w palabras|strong="H1697"\w*».   
\q1
\v 19 Oh Yahvé, \w atiende|strong="H7181"\w* \w a|strong="H3068"\w* mí,  
\q2 y \w oye|strong="H8085"\w* la \w voz|strong="H6963"\w* de los que contienden conmigo.   
\q1
\v 20 ¿\w Se|strong="H5921"\w* \w da|strong="H7725"\w* \w mal|strong="H7451"\w* \w por|strong="H5921"\w* \w bien|strong="H2896"\w*?  
\q2 \w Porque|strong="H3588"\w* han cavado \w hoyo|strong="H7745"\w* \w para|strong="H5921"\w* \w mi|strong="H5921"\w* \w vida|strong="H5315"\w*.  
\q1 \w Acuérdate|strong="H2142"\w* \w que|strong="H3588"\w* \w me|strong="H5921"\w* \w puse|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w para|strong="H5921"\w* \w hablar|strong="H1696"\w* \w bien|strong="H2896"\w* \w por|strong="H5921"\w* \w ellos|strong="H1992"\w*,  
\q2 \w para|strong="H5921"\w* apartar \w de|strong="H5921"\w* \w ellos|strong="H1992"\w* tu \w ira|strong="H2534"\w*.   
\q1
\v 21 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w entrega|strong="H5414"\w* sus \w hijos|strong="H1121"\w* \w al|strong="H5921"\w* \w hambre|strong="H7458"\w*,  
\q2 \w y|strong="H5921"\w* abandónalos \w al|strong="H5921"\w* \w poder|strong="H3027"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*;  
\q1 \w y|strong="H5921"\w* queden sus mujeres sin \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* viudas;  
\q2 \w y|strong="H5921"\w* sus maridos \w sean|strong="H1961"\w* \w heridos|strong="H5221"\w* \w de|strong="H5921"\w* \w muerte|strong="H4194"\w*,  
\q2 \w y|strong="H5921"\w* sus jóvenes \w heridos|strong="H5221"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w*.   
\q1
\v 22 \w Óigase|strong="H8085"\w* \w clamor|strong="H2201"\w* \w de|strong="H5921"\w* sus \w casas|strong="H1004"\w*  
\q2 \w cuando|strong="H3588"\w* traigas \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w ejército|strong="H1416"\w* \w de|strong="H5921"\w* repente;  
\q1 \w porque|strong="H3588"\w* \w cavaron|strong="H3738"\w* \w hoyo|strong="H7882"\w* \w para|strong="H5921"\w* prenderme,  
\q2 \w y|strong="H3588"\w* \w a|strong="H3068"\w* mis \w pies|strong="H7272"\w* han escondido \w lazos|strong="H6341"\w*.   
\q1
\v 23 Pero \w tú|strong="H6213"\w*, Yahvé, \w conoces|strong="H3045"\w* \w todo|strong="H3605"\w* su \w consejo|strong="H6098"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w para|strong="H5921"\w* matarme;  
\q2 \w no|strong="H6213"\w* \w perdones|strong="H3722"\w* su \w iniquidad|strong="H5771"\w*,  
\q2 ni \w borres|strong="H4229"\w* su \w pecado|strong="H2403"\w* \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w tu|strong="H6213"\w* \w rostro|strong="H6440"\w*;  
\q1 \w y|strong="H5921"\w* tropiecen \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*;  
\q2 \w haz|strong="H6213"\w* así \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5921"\w* \w tu|strong="H6213"\w* enojo”.   
\c 19
\p
\v 1 \w Así|strong="H3541"\w* dijo Yahvé: “\w Ve|strong="H1980"\w* \w y|strong="H3541"\w* \w compra|strong="H7069"\w* una botija \w de|strong="H5971"\w* barro \w de|strong="H5971"\w* alfarero, \w y|strong="H3541"\w* toma \w contigo|strong="H5971"\w* \w a|strong="H3068"\w* algunos \w de|strong="H5971"\w* los \w ancianos|strong="H2205"\w* del \w pueblo|strong="H5971"\w* \w y|strong="H3541"\w* \w de|strong="H5971"\w* los \w ancianos|strong="H2205"\w* \w de|strong="H5971"\w* los \w sacerdotes|strong="H3548"\w*;  
\v 2 y \w sal|strong="H3318"\w* al \w valle|strong="H1516"\w* del \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hinom, \w que|strong="H1697"\w* \w está|strong="H8033"\w* \w a|strong="H3068"\w* la entrada \w de|strong="H1121"\w* la \w puerta|strong="H6607"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* Tiestos, y proclama \w allí|strong="H8033"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* yo te \w diré|strong="H1696"\w*.  
\v 3 Dirás: ‘\w Oíd|strong="H8085"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé, \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén. \w Así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: He \w aquí|strong="H2088"\w* \w que|strong="H5921"\w* yo traigo \w sobre|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* un \w mal|strong="H7451"\w* \w tal|strong="H2088"\w* \w que|strong="H5921"\w* \w a|strong="H3068"\w* \w quien|strong="H3605"\w* \w lo|strong="H1697"\w* \w oyere|strong="H8085"\w* \w le|strong="H5921"\w* retiñirán \w los|strong="H3427"\w* \w oídos|strong="H8085"\w*.  
\v 4 \w Porque|strong="H3282"\w* me abandonasteis \w y|strong="H5355"\w* profanasteis \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, quemando \w en|strong="H5355"\w* \w él|strong="H1992"\w* incienso \w a|strong="H3068"\w* dioses ajenos \w que|strong="H3808"\w* \w no|strong="H3808"\w* habíais \w conocido|strong="H3045"\w* \w ni|strong="H3808"\w* vosotros, \w ni|strong="H3808"\w* vuestros padres, \w ni|strong="H3808"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H1818"\w* \w Judá|strong="H3063"\w*; \w y|strong="H5355"\w* llenasteis \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w de|strong="H1818"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* inocentes.  
\v 5 \w Edificaron|strong="H1129"\w* lugares \w altos|strong="H1116"\w* \w a|strong="H3068"\w* \w Baal|strong="H1168"\w* \w para|strong="H5921"\w* quemar \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w con|strong="H5921"\w* fuego \w en|strong="H5921"\w* \w holocaustos|strong="H5930"\w* \w al|strong="H5921"\w* mismo \w Baal|strong="H1168"\w*; \w cosa|strong="H1696"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w les|strong="H5921"\w* \w mandé|strong="H6680"\w*, \w ni|strong="H3808"\w* \w hablé|strong="H1696"\w*, \w ni|strong="H3808"\w* \w me|strong="H5921"\w* pasó \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pensamiento|strong="H3820"\w*.  
\v 6 \w Por|strong="H3588"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H2009"\w* vienen \w días|strong="H3117"\w* — \w dice|strong="H5002"\w* Yahvé — \w que|strong="H3588"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w llamará|strong="H7121"\w* \w más|strong="H5750"\w* Tofet, \w ni|strong="H3808"\w* \w valle|strong="H1516"\w* del \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Hinom, \w sino|strong="H3588"\w* \w Valle|strong="H1516"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* Matanza.   
\p
\v 7 \w Y|strong="H3068"\w* anularé \w el|strong="H5307"\w* \w consejo|strong="H6098"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w* y \w de|strong="H6440"\w* Jerusalén en \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, y los \w haré|strong="H5414"\w* \w caer|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* sus enemigos y \w a|strong="H3068"\w* \w mano|strong="H3027"\w* \w de|strong="H6440"\w* los \w que|strong="H2088"\w* \w buscan|strong="H1245"\w* su \w vida|strong="H5315"\w*; y \w daré|strong="H5414"\w* sus cuerpos muertos \w por|strong="H6440"\w* \w comida|strong="H3978"\w* \w a|strong="H3068"\w* las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w* y \w a|strong="H3068"\w* las bestias \w de|strong="H6440"\w* la tierra.  
\v 8 \w Pondré|strong="H7760"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w por|strong="H5921"\w* \w espanto|strong="H8047"\w* \w y|strong="H5921"\w* burla; \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w que|strong="H5921"\w* \w pasare|strong="H5674"\w* \w por|strong="H5921"\w* \w ella|strong="H5921"\w* \w se|strong="H5921"\w* asombrará \w y|strong="H5921"\w* \w silbará|strong="H8319"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w todas|strong="H3605"\w* sus \w plagas|strong="H4347"\w*.  
\v 9 \w Y|strong="H3068"\w* les haré \w comer|strong="H5315"\w* la \w carne|strong="H1320"\w* \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* y la \w carne|strong="H1320"\w* \w de|strong="H1121"\w* sus \w hijas|strong="H1323"\w*, y cada uno comerá la \w carne|strong="H1320"\w* \w de|strong="H1121"\w* su \w amigo|strong="H7453"\w* en \w el|strong="H1121"\w* asedio y en \w el|strong="H1121"\w* apuro con \w que|strong="H1121"\w* \w los|strong="H1121"\w* estrecharán sus enemigos y \w los|strong="H1121"\w* \w que|strong="H1121"\w* \w buscan|strong="H1245"\w* su \w vida|strong="H5315"\w*’.   
\p
\v 10 “Entonces romperás la botija ante los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* los varones que \w van|strong="H1980"\w* contigo,  
\v 11 \w y|strong="H3541"\w* les dirás: ‘\w Así|strong="H3541"\w* dice Yahvé \w de|strong="H5750"\w* los \w Ejércitos|strong="H6635"\w*: \w De|strong="H5750"\w* \w esta|strong="H2063"\w* manera romperé \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w y|strong="H3541"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, \w como|strong="H5750"\w* quien rompe una \w vasija|strong="H3627"\w* \w de|strong="H5750"\w* alfarero \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w puede|strong="H3201"\w* restaurar \w más|strong="H5750"\w*; \w y|strong="H3541"\w* \w en|strong="H6912"\w* Tofet \w se|strong="H3808"\w* \w enterrarán|strong="H6912"\w*, \w porque|strong="H3808"\w* \w no|strong="H3808"\w* habrá \w otro|strong="H2088"\w* \w lugar|strong="H4725"\w* \w para|strong="H5971"\w* enterrar.  
\v 12 \w Así|strong="H3651"\w* \w haré|strong="H6213"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* — \w dice|strong="H5002"\w* Yahvé — y \w a|strong="H3068"\w* sus \w moradores|strong="H3427"\w*, \w poniendo|strong="H5414"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w como|strong="H3651"\w* Tofet.  
\v 13 \w Las|strong="H5921"\w* \w casas|strong="H1004"\w* \w de|strong="H5921"\w* Jerusalén \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w casas|strong="H1004"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w serán|strong="H1961"\w* \w inmundas|strong="H2931"\w* \w como|strong="H1961"\w* \w el|strong="H5921"\w* \w lugar|strong="H4725"\w* \w de|strong="H5921"\w* Tofet, \w por|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w casas|strong="H1004"\w* \w sobre|strong="H5921"\w* \w cuyos|strong="H5921"\w* \w tejados|strong="H1406"\w* ofrecieron incienso \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w ejército|strong="H6635"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w* \w y|strong="H5921"\w* \w derramaron|strong="H5258"\w* \w libaciones|strong="H5262"\w* \w a|strong="H3068"\w* dioses ajenos’”.   
\p
\v 14 \w Y|strong="H3068"\w* volvió \w Jeremías|strong="H3414"\w* \w de|strong="H5971"\w* Tofet, \w a|strong="H3068"\w* \w donde|strong="H8033"\w* le \w había|strong="H5975"\w* \w enviado|strong="H7971"\w* Yahvé \w a|strong="H3068"\w* profetizar, y \w se|strong="H5971"\w* \w puso|strong="H5975"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w en|strong="H5975"\w* \w el|strong="H3605"\w* \w atrio|strong="H2691"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Yahvé y dijo \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*:  
\v 15 “\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: ‘He \w aquí|strong="H3541"\w*, \w yo|strong="H3588"\w* traigo \w sobre|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* sus aldeas \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H3588"\w* he \w hablado|strong="H1696"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*; \w porque|strong="H3588"\w* han endurecido \w su|strong="H3588"\w* \w cerviz|strong="H6203"\w* \w para|strong="H5921"\w* \w no|strong="H3588"\w* \w oír|strong="H8085"\w* mis \w palabras|strong="H1697"\w*’”.   
\c 20
\p
\v 1 Pasjur \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Imer, \w sacerdote|strong="H3548"\w* \w que|strong="H1931"\w* presidía \w como|strong="H1931"\w* \w jefe|strong="H6496"\w* en \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Yahvé, \w oyó|strong="H8085"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w que|strong="H1931"\w* profetizaba estas \w palabras|strong="H1697"\w*.  
\v 2 \w Y|strong="H3068"\w* \w hirió|strong="H5221"\w* Pasjur \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w puso|strong="H5414"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w cepo|strong="H4115"\w* \w que|strong="H5921"\w* \w estaba|strong="H1004"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* superior \w de|strong="H5921"\w* \w Benjamín|strong="H1144"\w*, \w la|strong="H5921"\w* cual caía \w hacia|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé.  
\v 3 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w al|strong="H4480"\w* día \w siguiente|strong="H4283"\w* Pasjur \w sacó|strong="H3318"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w del|strong="H4480"\w* \w cepo|strong="H4115"\w*. Le dijo \w entonces|strong="H3588"\w* \w Jeremías|strong="H3414"\w*: “Yahvé \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w llamado|strong="H8034"\w* tu \w nombre|strong="H8034"\w* Pasjur, \w sino|strong="H3588"\w* Magor-misabib\f + \fr 20:3 \ft «Magor-misabib» significa «terror por todas partes».\f*.  
\v 4 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé: ‘He \w aquí|strong="H3541"\w*, \w yo|strong="H3588"\w* \w te|strong="H5869"\w* \w pondré|strong="H5414"\w* \w por|strong="H3588"\w* terror \w a|strong="H3068"\w* ti \w mismo|strong="H3605"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* vuestros amigos, \w los|strong="H3605"\w* cuales \w caerán|strong="H5307"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* \w de|strong="H3588"\w* sus enemigos, \w y|strong="H3588"\w* vuestros \w ojos|strong="H5869"\w* \w lo|strong="H3605"\w* \w verán|strong="H7200"\w*. \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* \w entregaré|strong="H5414"\w* \w en|strong="H3588"\w* \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia, \w y|strong="H3588"\w* \w los|strong="H3605"\w* transportará \w a|strong="H3068"\w* Babilonia \w y|strong="H3588"\w* \w los|strong="H3605"\w* matará \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.  
\v 5 \w Entregaré|strong="H5414"\w* asimismo \w toda|strong="H3605"\w* \w la|strong="H2063"\w* riqueza \w de|strong="H5414"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, \w todo|strong="H3605"\w* su \w trabajo|strong="H3018"\w* y \w todas|strong="H3605"\w* sus cosas preciosas; y \w daré|strong="H5414"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* tesoros \w de|strong="H5414"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w* en \w manos|strong="H3027"\w* \w de|strong="H5414"\w* sus enemigos, \w que|strong="H3605"\w* \w los|strong="H3605"\w* saquearán, \w los|strong="H3605"\w* \w tomarán|strong="H3947"\w* y \w los|strong="H3605"\w* llevarán \w a|strong="H3068"\w* Babilonia.  
\v 6 \w Y|strong="H3068"\w* tú, Pasjur, y \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w moradores|strong="H3427"\w* de tu \w casa|strong="H1004"\w* \w iréis|strong="H3212"\w* \w en|strong="H6912"\w* \w cautiverio|strong="H7628"\w*; llegarás \w a|strong="H3068"\w* Babilonia, y \w allí|strong="H8033"\w* \w morirás|strong="H4191"\w*, y \w allí|strong="H8033"\w* serás \w sepultado|strong="H6912"\w* tú, y \w todos|strong="H3605"\w* vuestros amigos \w a|strong="H3068"\w* quienes habéis \w profetizado|strong="H5012"\w* \w mentira|strong="H8267"\w*’”.   
\b  
\q1
\v 7 Me sedujiste, oh Yahvé, y \w fui|strong="H1961"\w* seducido;  
\q2 más fuerte \w fuiste|strong="H1961"\w* \w que|strong="H3117"\w* yo, y me venciste.  
\q1 \w Cada|strong="H3605"\w* \w día|strong="H3117"\w* he \w sido|strong="H1961"\w* \w escarnecido|strong="H7814"\w*,  
\q2 \w cada|strong="H3605"\w* cual \w se|strong="H1961"\w* burla de \w mí|strong="H1961"\w*.   
\q1
\v 8 \w Porque|strong="H3588"\w* cuantas veces \w hablo|strong="H1696"\w*, doy voces;  
\q2 \w grito|strong="H2199"\w*: «¡\w Violencia|strong="H2555"\w* \w y|strong="H3588"\w* \w destrucción|strong="H7701"\w*!»;  
\q1 \w porque|strong="H3588"\w* \w la|strong="H3605"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé \w me|strong="H3588"\w* ha \w sido|strong="H1961"\w* \w por|strong="H3588"\w* \w afrenta|strong="H2781"\w*  
\q2 \w y|strong="H3588"\w* \w por|strong="H3588"\w* escarnio \w cada|strong="H3605"\w* \w día|strong="H3117"\w*.   
\q1
\v 9 \w Y|strong="H3068"\w* \w dije|strong="H1696"\w*: «\w No|strong="H3808"\w* me acordaré \w más|strong="H5750"\w* \w de|strong="H5750"\w* él,  
\q2 \w ni|strong="H3808"\w* \w hablaré|strong="H1696"\w* \w más|strong="H5750"\w* \w en|strong="H5750"\w* su \w nombre|strong="H8034"\w*»;  
\q1 \w no|strong="H3808"\w* obstante, \w había|strong="H1961"\w* \w en|strong="H5750"\w* \w mi|strong="H1961"\w* \w corazón|strong="H3820"\w* \w como|strong="H1961"\w* un fuego \w ardiente|strong="H1197"\w* encubierto \w en|strong="H5750"\w* mis \w huesos|strong="H6106"\w*;  
\q2 traté \w de|strong="H5750"\w* sufrirlo,  
\q2 \w y|strong="H1197"\w* \w no|strong="H3808"\w* \w pude|strong="H3201"\w*.   
\q1
\v 10 \w Porque|strong="H3588"\w* \w oí|strong="H8085"\w* \w la|strong="H8104"\w* murmuración \w de|strong="H4480"\w* \w muchos|strong="H7227"\w*:  
\q2 «¡Terror \w por|strong="H3588"\w* \w todas|strong="H3605"\w* \w partes|strong="H5439"\w*!  
\q2 ¡Denunciadle! ¡Denunciémosle!».  
\q1 \w Todos|strong="H3605"\w* mis \w amigos|strong="H7227"\w* íntimos acechaban mi caída:  
\q2 «\w Quizá|strong="H3588"\w* \w se|strong="H4480"\w* \w engañe|strong="H6601"\w*,  
\q2 \w y|strong="H3588"\w* prevaleceremos \w contra|strong="H4480"\w* \w él|strong="H3588"\w*,  
\q2 \w y|strong="H3588"\w* \w tomaremos|strong="H3947"\w* \w de|strong="H4480"\w* \w él|strong="H3588"\w* nuestra \w venganza|strong="H5360"\w*».   
\q1
\v 11 \w Mas|strong="H3588"\w* Yahvé \w está|strong="H3651"\w* conmigo \w como|strong="H3588"\w* un guerrero terrible;  
\q2 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w me|strong="H5921"\w* \w persiguen|strong="H7291"\w* \w tropezarán|strong="H3782"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w prevalecerán|strong="H3201"\w*;  
\q1 serán avergonzados \w en|strong="H5921"\w* \w gran|strong="H3966"\w* \w manera|strong="H3966"\w* \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w prosperarán|strong="H7919"\w*;  
\q2 tendrán \w perpetua|strong="H5769"\w* \w confusión|strong="H3639"\w* \w que|strong="H3588"\w* \w jamás|strong="H5769"\w* \w será|strong="H3808"\w* \w olvidada|strong="H7911"\w*.   
\q1
\v 12 Oh Yahvé \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w Ejércitos|strong="H6635"\w*, \w que|strong="H3588"\w* escudriñas \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w justos|strong="H6662"\w*,  
\q2 \w que|strong="H3588"\w* \w ves|strong="H7200"\w* \w los|strong="H1992"\w* \w riñones|strong="H3629"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w corazón|strong="H3820"\w*,  
\q1 \w vea|strong="H7200"\w* \w yo|strong="H3588"\w* tu \w venganza|strong="H5360"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*;  
\q2 \w porque|strong="H3588"\w* \w a|strong="H3068"\w* ti he expuesto mi \w causa|strong="H7379"\w*.   
\q1
\v 13 ¡\w Cantad|strong="H7891"\w* \w a|strong="H3068"\w* Yahvé,  
\q2 \w load|strong="H1984"\w* \w a|strong="H3068"\w* Yahvé!;  
\q2 \w porque|strong="H3588"\w* ha \w librado|strong="H5337"\w* \w el|strong="H3588"\w* \w alma|strong="H5315"\w* del pobre \w de|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* malvados.   
\q1
\v 14 ¡Maldito el \w día|strong="H3117"\w* en \w que|strong="H3117"\w* \w nací|strong="H3205"\w*!  
\q2 El \w día|strong="H3117"\w* en \w que|strong="H3117"\w* \w mi|strong="H1961"\w* madre me dio \w a|strong="H3068"\w* luz \w no|strong="H1961"\w* \w sea|strong="H1961"\w* \w bendito|strong="H1288"\w*.   
\q1
\v 15 ¡Maldito \w el|strong="H1121"\w* \w hombre|strong="H1121"\w* \w que|strong="H1121"\w* dio nuevas \w a|strong="H3068"\w* mi padre, diciendo:  
\q2 «\w Hijo|strong="H1121"\w* \w varón|strong="H2145"\w* te ha \w nacido|strong="H3205"\w*», haciéndole \w alegrarse|strong="H8055"\w* mucho!   
\q1
\v 16 \w Y|strong="H3068"\w* \w sea|strong="H1961"\w* \w el|strong="H1931"\w* tal hombre \w como|strong="H1961"\w* las \w ciudades|strong="H5892"\w* \w que|strong="H1931"\w* \w asoló|strong="H2015"\w* Yahvé,  
\q2 y \w no|strong="H3808"\w* \w se|strong="H1961"\w* arrepintió;  
\q1 \w que|strong="H1931"\w* \w oiga|strong="H8085"\w* \w gritos|strong="H8643"\w* por \w la|strong="H1931"\w* \w mañana|strong="H1242"\w*  
\q2 y alaridos \w al|strong="H6256"\w* mediodía,   
\q1
\v 17 \w porque|strong="H3808"\w* \w no|strong="H3808"\w* me \w mató|strong="H4191"\w* en el vientre;  
\q2 así \w mi|strong="H1961"\w* madre hubiera \w sido|strong="H1961"\w* \w mi|strong="H1961"\w* \w sepulcro|strong="H6913"\w*,  
\q2 y su vientre \w siempre|strong="H5769"\w* encinta.   
\q1
\v 18 ¿Para \w qué|strong="H4100"\w* \w salí|strong="H3318"\w* del vientre para \w ver|strong="H7200"\w* \w trabajo|strong="H5999"\w* y \w dolor|strong="H3015"\w*,  
\q2 y \w que|strong="H4100"\w* mis \w días|strong="H3117"\w* \w se|strong="H4100"\w* consumiesen \w en|strong="H3318"\w* afrenta?   
\c 21
\p
\v 1 \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H1121"\w* parte \w de|strong="H1121"\w* Yahvé, \w cuando|strong="H1961"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* Sedequías \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w él|strong="H1121"\w* \w a|strong="H3068"\w* Pasjur \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Malquías y \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* \w Sofonías|strong="H6846"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Maasías|strong="H4641"\w*, diciendo:  
\v 2 «Consulta \w ahora|strong="H4994"\w* \w por|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w a|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* \w Nabucodonosor|strong="H5019"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w hace|strong="H6213"\w* \w guerra|strong="H3898"\w* \w contra|strong="H5921"\w* \w nosotros|strong="H3605"\w*; \w quizá|strong="H3588"\w* Yahvé \w haga|strong="H6213"\w* \w con|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* sus \w maravillas|strong="H6381"\w*, \w y|strong="H3588"\w* \w aquel|strong="H3605"\w* \w se|strong="H5921"\w* retire \w de|strong="H5921"\w* \w nosotros|strong="H3605"\w*».   
\p
\v 3 \w Y|strong="H3068"\w* \w Jeremías|strong="H3414"\w* les dijo: “Diréis \w así|strong="H3541"\w* \w a|strong="H3068"\w* Sedequías:  
\v 4 ‘\w Así|strong="H3541"\w* dice Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: «He \w aquí|strong="H3541"\w*, yo vuelvo atrás \w las|strong="H5921"\w* \w armas|strong="H3627"\w* \w de|strong="H5921"\w* \w guerra|strong="H4421"\w* \w que|strong="H5921"\w* están \w en|strong="H5921"\w* vuestras \w manos|strong="H3027"\w*, \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w que|strong="H5921"\w* \w peleáis|strong="H3898"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w* \w que|strong="H5921"\w* \w os|strong="H5921"\w* tienen sitiados \w fuera|strong="H2351"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* muralla, \w y|strong="H5921"\w* yo \w las|strong="H5921"\w* juntaré \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*.  
\v 5 Yo mismo pelearé contra vosotros con \w mano|strong="H3027"\w* \w extendida|strong="H5186"\w* y con \w brazo|strong="H2220"\w* \w fuerte|strong="H2389"\w*, con \w furor|strong="H2534"\w*, con \w ira|strong="H2534"\w* y con \w gran|strong="H1419"\w* indignación.  
\v 6 \w Y|strong="H3068"\w* \w heriré|strong="H5221"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, y \w los|strong="H3427"\w* hombres y las bestias \w morirán|strong="H4191"\w* de \w gran|strong="H1419"\w* \w pestilencia|strong="H1698"\w*.  
\v 7 \w Después|strong="H5921"\w* — \w dice|strong="H5002"\w* Yahvé — \w entregaré|strong="H5414"\w* \w a|strong="H3068"\w* Sedequías \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w a|strong="H3068"\w* sus \w criados|strong="H5650"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H4480"\w* queden \w en|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w pestilencia|strong="H1698"\w*, \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w y|strong="H5921"\w* \w del|strong="H4480"\w* \w hambre|strong="H7458"\w*, \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H4480"\w* \w Nabucodonosor|strong="H5019"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* Babilonia, \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H4480"\w* sus enemigos \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w que|strong="H4480"\w* \w buscan|strong="H1245"\w* su \w vida|strong="H5315"\w*; \w y|strong="H5921"\w* \w él|strong="H5921"\w* \w los|strong="H5921"\w* \w herirá|strong="H5221"\w* \w a|strong="H3068"\w* \w filo|strong="H3027"\w* \w de|strong="H4480"\w* \w espada|strong="H2719"\w*. \w No|strong="H3808"\w* \w los|strong="H5921"\w* \w perdonará|strong="H2550"\w*, \w ni|strong="H3808"\w* \w se|strong="H5921"\w* apiadará \w de|strong="H4480"\w* \w ellos|strong="H3027"\w*, \w ni|strong="H3808"\w* tendrá compasión»’.   
\p
\v 8 “\w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* dirás: ‘\w Así|strong="H3541"\w* dice Yahvé: «He \w aquí|strong="H2088"\w* \w pongo|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros el \w camino|strong="H1870"\w* \w de|strong="H6440"\w* la \w vida|strong="H2416"\w* \w y|strong="H3541"\w* el \w camino|strong="H1870"\w* \w de|strong="H6440"\w* la \w muerte|strong="H4194"\w*.  
\v 9 \w El|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* \w quedare|strong="H3427"\w* \w en|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w morirá|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w de|strong="H5921"\w* \w hambre|strong="H7458"\w* \w o|strong="H3068"\w* \w de|strong="H5921"\w* \w pestilencia|strong="H1698"\w*; \w mas|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w saliere|strong="H3318"\w* \w y|strong="H5921"\w* \w se|strong="H1961"\w* pasare \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w caldeos|strong="H3778"\w* \w que|strong="H5921"\w* \w os|strong="H5921"\w* \w tienen|strong="H1961"\w* sitiados, \w vivirá|strong="H2421"\w*, \w y|strong="H5921"\w* su \w vida|strong="H5315"\w* \w le|strong="H5921"\w* \w será|strong="H1961"\w* \w por|strong="H5921"\w* botín.  
\v 10 \w Porque|strong="H3588"\w* mi \w rostro|strong="H6440"\w* he \w puesto|strong="H5414"\w* \w contra|strong="H6440"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w para|strong="H3588"\w* \w mal|strong="H7451"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w para|strong="H3588"\w* \w bien|strong="H2896"\w* — \w dice|strong="H5002"\w* Yahvé —; \w en|strong="H3588"\w* \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia \w será|strong="H3808"\w* \w entregada|strong="H5414"\w*, \w y|strong="H3588"\w* \w él|strong="H3588"\w* \w la|strong="H2063"\w* \w quemará|strong="H8313"\w* \w a|strong="H3068"\w* fuego»’.   
\p
\v 11 “\w Y|strong="H3068"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w* diréis: ‘\w Oíd|strong="H8085"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé:  
\v 12 \w Casa|strong="H1004"\w* \w de|strong="H6440"\w* \w David|strong="H1732"\w*, \w así|strong="H3541"\w* dice Yahvé:  
\q1 «Practicad \w la|strong="H1197"\w* \w justicia|strong="H4941"\w* \w por|strong="H6440"\w* \w la|strong="H1197"\w* \w mañana|strong="H1242"\w*,  
\q2 \w y|strong="H3541"\w* librad al \w oprimido|strong="H6231"\w* \w de|strong="H6440"\w* \w mano|strong="H3027"\w* del opresor,  
\q1 para \w que|strong="H6435"\w* mi \w ira|strong="H2534"\w* \w no|strong="H6435"\w* \w salga|strong="H3318"\w* como fuego  
\q2 \w y|strong="H3541"\w* \w se|strong="H6435"\w* encienda \w de|strong="H6440"\w* modo \w que|strong="H6435"\w* \w no|strong="H6435"\w* haya quien \w la|strong="H1197"\w* apague,  
\q2 \w por|strong="H6440"\w* \w la|strong="H1197"\w* \w maldad|strong="H7455"\w* \w de|strong="H6440"\w* vuestras \w obras|strong="H4611"\w*.   
\q1
\v 13 He \w aquí|strong="H2005"\w*, yo estoy \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w moradora|strong="H3427"\w* \w del|strong="H5921"\w* \w valle|strong="H6010"\w*,  
\q2 \w roca|strong="H6697"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* llanura», \w dice|strong="H5002"\w* Yahvé;  
\q1 “vosotros \w que|strong="H4310"\w* decís: ‘¿\w Quién|strong="H4310"\w* bajará \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*?’,  
\q2 \w o|strong="H3068"\w*: ‘¿\w Quién|strong="H4310"\w* entrará \w en|strong="H5921"\w* nuestras moradas?’.   
\q1
\v 14 Yo \w os|strong="H5921"\w* castigaré \w conforme|strong="H5921"\w* \w al|strong="H5921"\w* \w fruto|strong="H6529"\w* \w de|strong="H5921"\w* vuestras \w obras|strong="H4611"\w* — \w dice|strong="H5002"\w* Yahvé —;  
\q2 \w y|strong="H5921"\w* haré encender fuego \w en|strong="H5921"\w* su \w bosque|strong="H3293"\w*,  
\q2 \w el|strong="H5921"\w* cual consumirá \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w en|strong="H5921"\w* sus \w alrededores|strong="H5439"\w*”’”.   
\c 22
\p
\v 1 \w Así|strong="H3541"\w* \w dijo|strong="H1696"\w* Yahvé: “\w Baja|strong="H1004"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3541"\w* \w di|strong="H1696"\w* \w allí|strong="H8033"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*:  
\v 2 ‘\w Escucha|strong="H8085"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé, oh \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w que|strong="H5921"\w* estás \w sentado|strong="H3427"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*; tú, \w y|strong="H5921"\w* tus \w siervos|strong="H5650"\w*, \w y|strong="H5921"\w* tu \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* entráis \w por|strong="H5921"\w* estas \w puertas|strong="H8179"\w*.  
\v 3 \w Así|strong="H3541"\w* dice Yahvé: «\w Haced|strong="H6213"\w* \w derecho|strong="H4941"\w* \w y|strong="H3541"\w* \w justicia|strong="H6666"\w*, \w y|strong="H3541"\w* librad al despojado \w de|strong="H1818"\w* \w mano|strong="H3027"\w* del opresor, \w y|strong="H3541"\w* \w no|strong="H6213"\w* \w hagáis|strong="H6213"\w* engaño \w ni|strong="H5355"\w* violencia al \w extranjero|strong="H1616"\w*, \w ni|strong="H5355"\w* al \w huérfano|strong="H3490"\w* \w ni|strong="H5355"\w* \w a|strong="H3068"\w* la viuda, \w ni|strong="H5355"\w* \w derraméis|strong="H8210"\w* \w sangre|strong="H1818"\w* \w inocente|strong="H5355"\w* \w en|strong="H5355"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.  
\v 4 \w Porque|strong="H3588"\w* \w si|strong="H3588"\w* \w de|strong="H5921"\w* veras \w hiciereis|strong="H6213"\w* \w esto|strong="H2088"\w*, \w los|strong="H3427"\w* \w reyes|strong="H4428"\w* \w que|strong="H3588"\w* \w se|strong="H1931"\w* sientan \w en|strong="H5921"\w* lugar \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* \w trono|strong="H3678"\w* entrarán \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H8179"\w* \w de|strong="H5921"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w*, \w montados|strong="H7393"\w* \w en|strong="H5921"\w* \w carros|strong="H7393"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w caballos|strong="H5483"\w*, \w ellos|strong="H1931"\w*, \w sus|strong="H1931"\w* \w siervos|strong="H5650"\w* \w y|strong="H3588"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*.  
\v 5 \w Mas|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w* escuchareis \w estas|strong="H2088"\w* \w palabras|strong="H1697"\w*, \w por|strong="H3588"\w* \w mí|strong="H1961"\w* mismo he \w jurado|strong="H7650"\w* — \w dice|strong="H5002"\w* Yahvé — \w que|strong="H3588"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w* \w vendrá|strong="H1961"\w* \w a|strong="H3068"\w* ser una desolación»’”.   
\p
\v 6 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*:  
\q1 “\w Galaad|strong="H1568"\w* eres tú \w para|strong="H5921"\w* \w mí|strong="H5921"\w*,  
\q2 \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w del|strong="H5921"\w* \w Líbano|strong="H3844"\w*;  
\q1 \w sin|strong="H3808"\w* embargo, \w te|strong="H5921"\w* convertiré \w en|strong="H5921"\w* un \w desierto|strong="H4057"\w*,  
\q2 \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w deshabitadas|strong="H3427"\w*.   
\q1
\v 7 \w Y|strong="H3068"\w* prepararé \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* destruidores,  
\q2 cada uno \w con|strong="H5921"\w* sus \w armas|strong="H3627"\w*;  
\q1 \w y|strong="H5921"\w* cortarán tus cedros \w escogidos|strong="H4005"\w*  
\q2 \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w echarán|strong="H5307"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* fuego.   
\p
\v 8 “\w Y|strong="H3068"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w* \w pasarán|strong="H5674"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H5921"\w* dirá cada uno \w a|strong="H3068"\w* su \w compañero|strong="H7453"\w*: ‘¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w hizo|strong="H6213"\w* \w así|strong="H3602"\w* Yahvé \w con|strong="H5921"\w* \w esta|strong="H2063"\w* \w gran|strong="H1419"\w* \w ciudad|strong="H5892"\w*?’.  
\v 9 \w Y|strong="H3068"\w* responderán: ‘\w Porque|strong="H5921"\w* abandonaron \w el|strong="H5921"\w* \w pacto|strong="H1285"\w* \w de|strong="H5921"\w* Yahvé su \w Dios|strong="H3068"\w*, \w y|strong="H5921"\w* \w adoraron|strong="H7812"\w* dioses ajenos \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w sirvieron|strong="H5647"\w*’”.   
\q1
\v 10 \w No|strong="H3808"\w* \w lloréis|strong="H1058"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w muerto|strong="H4191"\w*,  
