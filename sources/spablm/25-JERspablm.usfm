\q2 ‘¿\w Quién|strong="H4310"\w* vendrá contra mí?’.   
\q1
\v 5 He \w aquí|strong="H2005"\w* \w que|strong="H5921"\w* yo traigo \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w terror|strong="H6343"\w*”, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor, Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*,  
