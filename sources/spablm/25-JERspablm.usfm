\v 29 \w Sus|strong="H1992"\w* tiendas \w y|strong="H5921"\w* \w sus|strong="H1992"\w* \w ganados|strong="H6629"\w* \w tomarán|strong="H3947"\w*;  
\q2 \w sus|strong="H1992"\w* cortinajes \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w sus|strong="H1992"\w* utensilios,  
\q2 \w y|strong="H5921"\w* \w sus|strong="H1992"\w* \w camellos|strong="H1581"\w* \w tomarán|strong="H3947"\w* \w para|strong="H5921"\w* \w sí|strong="H5921"\w*;  
\q1 \w y|strong="H5921"\w* clamarán \w contra|strong="H5921"\w* \w ellos|strong="H1992"\w*: ‘¡Terror \w por|strong="H5921"\w* \w todas|strong="H3605"\w* \w partes|strong="H5439"\w*!’.   
\q1
\v 30 ¡\w Huid|strong="H5127"\w*, marchaos \w muy|strong="H3966"\w* lejos!  
\q2 \w Habitad|strong="H3427"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* profundidades, \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* Hazor”, \w dice|strong="H5002"\w* Yahvé;  
\q1 «\w porque|strong="H3588"\w* \w Nabucodonosor|strong="H5019"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia ha tomado \w consejo|strong="H6098"\w* \w contra|strong="H5921"\w* vosotros,  
\q2 \w y|strong="H3588"\w* ha formado \w contra|strong="H5921"\w* vosotros un plan.   
\q1
\v 31 \w Levantaos|strong="H6965"\w*, \w subid|strong="H5927"\w* contra una \w nación|strong="H1471"\w* \w pacífica|strong="H7961"\w*  
\q2 \w que|strong="H3808"\w* vive confiada», \w dice|strong="H5002"\w* Yahvé;  
\q1 «\w que|strong="H3808"\w* \w no|strong="H3808"\w* tiene \w puertas|strong="H1817"\w* \w ni|strong="H3808"\w* \w cerrojos|strong="H1280"\w*,  
\q2 \w que|strong="H3808"\w* \w habita|strong="H3427"\w* solitaria.   
