\q2 \w ni|strong="H3808"\w* la \w habitará|strong="H3427"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*.   
\b  
\q1
\v 19 He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w como|strong="H3588"\w* león \w subirá|strong="H5927"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* espesura \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* pradera sólida;  
