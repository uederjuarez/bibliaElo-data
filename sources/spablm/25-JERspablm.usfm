\v 19 \w por|strong="H6440"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*: \w No|strong="H3808"\w* \w faltará|strong="H3772"\w* \w de|strong="H6440"\w* \w Jonadab|strong="H3122"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Recab, varón \w que|strong="H3808"\w* \w esté|strong="H5975"\w* \w en|strong="H5975"\w* mi \w presencia|strong="H6440"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w*’”.   
\c 36
\p
\v 1 En \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w* \w año|strong="H8141"\w* \w de|strong="H1121"\w* \w Joacim|strong="H3079"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w vino|strong="H1961"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*, diciendo:  
\v 2 «\w Toma|strong="H3947"\w* un \w rollo|strong="H4039"\w* \w de|strong="H5921"\w* \w libro|strong="H5612"\w* \w y|strong="H5921"\w* \w escribe|strong="H3789"\w* \w en|strong="H5921"\w* \w él|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* he \w hablado|strong="H1696"\w* \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w contra|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, \w desde|strong="H5704"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w en|strong="H5921"\w* \w que|strong="H5921"\w* comencé \w a|strong="H3068"\w* \w hablarte|strong="H1696"\w*, \w desde|strong="H5704"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w Josías|strong="H2977"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.  
\v 3 Quizá \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H7451"\w* \w Judá|strong="H3063"\w* \w oiga|strong="H8085"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w mal|strong="H7451"\w* \w que|strong="H4616"\w* \w yo|strong="H6213"\w* \w pienso|strong="H2803"\w* \w hacerles|strong="H6213"\w*, \w para|strong="H4616"\w* \w que|strong="H4616"\w* se arrepienta \w cada|strong="H3605"\w* uno \w de|strong="H7451"\w* su \w mal|strong="H7451"\w* \w camino|strong="H1870"\w*, y \w yo|strong="H6213"\w* \w perdone|strong="H5545"\w* su \w iniquidad|strong="H5771"\w* y su \w pecado|strong="H2403"\w*».   
\p
\v 4 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w Jeremías|strong="H3414"\w* \w a|strong="H3068"\w* Baruc, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nerías; \w y|strong="H5921"\w* \w escribió|strong="H3789"\w* Baruc \w de|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \w Jeremías|strong="H3414"\w*, \w en|strong="H5921"\w* un \w rollo|strong="H4039"\w* \w de|strong="H5921"\w* \w libro|strong="H5612"\w*, \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w que|strong="H5921"\w* Yahvé \w le|strong="H5921"\w* había \w hablado|strong="H1696"\w*.  
\v 5 Después \w mandó|strong="H6680"\w* \w Jeremías|strong="H3414"\w* \w a|strong="H3068"\w* Baruc, diciendo: «\w Yo|strong="H6680"\w* estoy recluido y \w no|strong="H3808"\w* \w puedo|strong="H3201"\w* entrar en la \w casa|strong="H1004"\w* de Yahvé.  
\v 6 Entra tú, \w pues|strong="H1571"\w*, \w y|strong="H1571"\w* \w lee|strong="H7121"\w* del \w rollo|strong="H4039"\w* \w que|strong="H1571"\w* \w escribiste|strong="H3789"\w* \w de|strong="H5971"\w* mi \w boca|strong="H6310"\w*, las \w palabras|strong="H1697"\w* \w de|strong="H5971"\w* Yahvé, \w a|strong="H3068"\w* oídos del \w pueblo|strong="H5971"\w*, en \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Yahvé, \w el|strong="H3605"\w* \w día|strong="H3117"\w* del \w ayuno|strong="H6685"\w*; \w y|strong="H1571"\w* \w también|strong="H1571"\w* las \w leerás|strong="H7121"\w* \w a|strong="H3068"\w* oídos \w de|strong="H5971"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w de|strong="H5971"\w* \w Judá|strong="H3063"\w* \w que|strong="H1571"\w* vienen \w de|strong="H5971"\w* sus \w ciudades|strong="H5892"\w*.  
\v 7 \w Quizá|strong="H3588"\w* eleven \w su|strong="H3588"\w* \w oración|strong="H8467"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Yahvé, \w y|strong="H3588"\w* \w se|strong="H5971"\w* \w vuelva|strong="H7725"\w* cada uno \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w mal|strong="H7451"\w* \w camino|strong="H1870"\w*; \w porque|strong="H3588"\w* \w grande|strong="H1419"\w* \w es|strong="H2088"\w* \w el|strong="H3588"\w* \w furor|strong="H2534"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w ira|strong="H2534"\w* \w que|strong="H3588"\w* ha expresado Yahvé \w contra|strong="H6440"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*».   
