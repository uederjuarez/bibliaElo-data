\v 34 \w El|strong="H5973"\w* día \w siguiente|strong="H4283"\w*, dijo \w la|strong="H1571"\w* mayor \w a|strong="H3068"\w* \w la|strong="H1571"\w* \w menor|strong="H6810"\w*: «He \w aquí|strong="H2005"\w*, yo dormí \w la|strong="H1571"\w* \w noche|strong="H3915"\w* pasada \w con|strong="H5973"\w* \w mi|strong="H1961"\w* padre; \w démosle|strong="H8248"\w* \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w vino|strong="H3196"\w* \w también|strong="H1571"\w* \w esta|strong="H1961"\w* \w noche|strong="H3915"\w*, \w y|strong="H1571"\w* entra \w y|strong="H1571"\w* \w duerme|strong="H7901"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*, \w para|strong="H1961"\w* \w que|strong="H1571"\w* conservemos \w de|strong="H5973"\w* nuestro padre \w descendencia|strong="H2233"\w*».  
