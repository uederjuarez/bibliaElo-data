\v 4 Así \w halló|strong="H4672"\w* \w José|strong="H3130"\w* \w gracia|strong="H2580"\w* \w en|strong="H5921"\w* sus \w ojos|strong="H5869"\w*, \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w servía|strong="H8334"\w*; \w y|strong="H5921"\w* \w él|strong="H5921"\w* \w le|strong="H5921"\w* \w hizo|strong="H5414"\w* \w mayordomo|strong="H5921"\w* \w de|strong="H5921"\w* su \w casa|strong="H1004"\w*, \w y|strong="H5921"\w* \w entregó|strong="H5414"\w* \w en|strong="H5921"\w* su \w poder|strong="H3027"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w tenía|strong="H3426"\w*.  
\v 5 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H5921"\w* \w desde|strong="H5921"\w* \w cuando|strong="H1961"\w* \w le|strong="H5921"\w* dio \w el|strong="H5921"\w* encargo \w de|strong="H5921"\w* su \w casa|strong="H1004"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w tenía|strong="H1961"\w*, Yahvé \w bendijo|strong="H1288"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w egipcio|strong="H4713"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w José|strong="H3130"\w*; \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w bendición|strong="H1293"\w* \w de|strong="H5921"\w* Yahvé \w estaba|strong="H1961"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w tenía|strong="H1961"\w*, así \w en|strong="H5921"\w* \w casa|strong="H1004"\w* \w como|strong="H1961"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campo|strong="H7704"\w*.  
\v 6 \w Y|strong="H3068"\w* \w dejó|strong="H5800"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* \w tenía|strong="H1961"\w* \w en|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w José|strong="H3130"\w*, \w y|strong="H3588"\w* \w con|strong="H3588"\w* \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* preocupaba \w de|strong="H3588"\w* \w cosa|strong="H3605"\w* \w alguna|strong="H3605"\w* \w sino|strong="H3588"\w* del \w pan|strong="H3899"\w* \w que|strong="H3588"\w* comía.  
\p \w Y|strong="H3068"\w* \w era|strong="H1961"\w* \w José|strong="H3130"\w* \w de|strong="H3588"\w* \w hermoso|strong="H3303"\w* \w semblante|strong="H8389"\w* \w y|strong="H3588"\w* bella \w presencia|strong="H4758"\w*.  
\v 7 \w Aconteció|strong="H1961"\w* \w después|strong="H1961"\w* \w de|strong="H5973"\w* \w esto|strong="H1697"\w*, \w que|strong="H1697"\w* la mujer \w de|strong="H5973"\w* su amo \w puso|strong="H5375"\w* sus \w ojos|strong="H5869"\w* \w en|strong="H5973"\w* \w José|strong="H3130"\w*, y dijo: «\w Duerme|strong="H7901"\w* \w conmigo|strong="H5973"\w*».   
\p
\v 8 \w Y|strong="H3068"\w* \w él|strong="H3605"\w* rehusó, y dijo \w a|strong="H3068"\w* \w la|strong="H3605"\w* mujer \w de|strong="H5414"\w* su amo: «He \w aquí|strong="H2005"\w* \w que|strong="H4100"\w* mi señor \w no|strong="H3808"\w* \w se|strong="H3045"\w* preocupa conmigo \w de|strong="H5414"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w hay|strong="H3426"\w* en \w casa|strong="H1004"\w*, y \w ha|strong="H3808"\w* \w puesto|strong="H5414"\w* en mi \w mano|strong="H3027"\w* \w todo|strong="H3605"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w tiene|strong="H3426"\w*.  
\v 9 \w No|strong="H3808"\w* hay \w otro|strong="H2088"\w* \w mayor|strong="H1419"\w* \w que|strong="H3588"\w* \w yo|strong="H4480"\w* \w en|strong="H4480"\w* \w esta|strong="H2063"\w* \w casa|strong="H1004"\w*, \w y|strong="H3588"\w* \w ninguna|strong="H3808"\w* \w cosa|strong="H3972"\w* \w me|strong="H4480"\w* \w ha|strong="H3808"\w* reservado \w sino|strong="H3588"\w* \w a|strong="H3068"\w* \w ti|strong="H4480"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w tú|strong="H6213"\w* eres \w su|strong="H3588"\w* mujer; ¿\w cómo|strong="H3588"\w*, \w pues|strong="H3588"\w*, \w haría|strong="H6213"\w* \w yo|strong="H4480"\w* \w este|strong="H2088"\w* \w grande|strong="H1419"\w* \w mal|strong="H7451"\w*, \w y|strong="H3588"\w* pecaría \w contra|strong="H4480"\w* Dios?»   
\p
\v 10 \w Hablando|strong="H1696"\w* ella \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w cada|strong="H3117"\w* \w día|strong="H3117"\w*, y \w no|strong="H3808"\w* \w escuchándola|strong="H8085"\w* \w él|strong="H5973"\w* \w para|strong="H1961"\w* acostarse al lado \w de|strong="H5973"\w* ella, \w para|strong="H1961"\w* estar \w con|strong="H5973"\w* ella,  
\v 11 \w aconteció|strong="H1961"\w* un \w día|strong="H3117"\w*, \w que|strong="H3117"\w* entró José en la \w casa|strong="H1004"\w* \w para|strong="H1961"\w* \w hacer|strong="H6213"\w* su \w oficio|strong="H4399"\w*, y \w no|strong="H6213"\w* \w había|strong="H1961"\w* nadie de \w los|strong="H1961"\w* de \w casa|strong="H1004"\w* \w allí|strong="H8033"\w* \w dentro|strong="H8033"\w*.  
\v 12 \w Y|strong="H3068"\w* ella lo asió \w por|strong="H3027"\w* su ropa, diciendo: «\w Duerme|strong="H7901"\w* \w conmigo|strong="H5973"\w*».  
\p Entonces \w él|strong="H5973"\w* \w dejó|strong="H5800"\w* su ropa \w en|strong="H5973"\w* las \w manos|strong="H3027"\w* \w de|strong="H5973"\w* ella, y \w huyó|strong="H5127"\w* y \w salió|strong="H3318"\w* \w fuera|strong="H2351"\w*.  
\v 13 \w Cuando|strong="H3588"\w* \w vio|strong="H7200"\w* ella \w que|strong="H3588"\w* le \w había|strong="H1961"\w* dejado \w su|strong="H3588"\w* ropa \w en|strong="H3588"\w* sus \w manos|strong="H3027"\w*, \w y|strong="H3588"\w* \w había|strong="H1961"\w* huido \w fuera|strong="H2351"\w*,  
\v 14 \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w de|strong="H5973"\w* \w casa|strong="H1004"\w*, y \w les|strong="H5973"\w* habló diciendo: «\w Mirad|strong="H7200"\w*, nos ha traído un \w hebreo|strong="H5680"\w* \w para|strong="H5973"\w* que hiciese burla \w de|strong="H5973"\w* \w nosotros|strong="H5973"\w*. Vino \w él|strong="H5973"\w* \w a|strong="H3068"\w* mí \w para|strong="H5973"\w* dormir \w conmigo|strong="H5973"\w*, y yo di \w grandes|strong="H1419"\w* \w voces|strong="H6963"\w*.  
\v 15 \w Y|strong="H3068"\w* viendo \w que|strong="H3588"\w* \w yo|strong="H3588"\w* alzaba \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w y|strong="H3588"\w* gritaba, \w dejó|strong="H5800"\w* \w su|strong="H3588"\w* ropa junto \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, \w y|strong="H3588"\w* \w huyó|strong="H5127"\w* \w y|strong="H3588"\w* \w salió|strong="H3318"\w* \w fuera|strong="H2351"\w*».  
\v 16 \w Y|strong="H3068"\w* ella \w puso|strong="H3240"\w* junto \w a|strong="H3068"\w* sí la ropa \w de|strong="H5704"\w* él, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* vino su señor \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*.  
\v 17 Entonces le \w habló|strong="H1696"\w* ella las mismas \w palabras|strong="H1697"\w*, \w diciendo|strong="H1696"\w*: «El \w siervo|strong="H5650"\w* \w hebreo|strong="H5680"\w* \w que|strong="H1697"\w* nos trajiste, vino \w a|strong="H3068"\w* mí para deshonrarme.  
\v 18 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* yo alcé \w mi|strong="H1961"\w* \w voz|strong="H6963"\w* y grité, él \w dejó|strong="H5800"\w* su ropa junto \w a|strong="H3068"\w* \w mí|strong="H1961"\w* y \w huyó|strong="H5127"\w* \w fuera|strong="H2351"\w*».   
\p
\v 19 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1697"\w* \w cuando|strong="H1961"\w* \w oyó|strong="H8085"\w* \w el|strong="H6213"\w* amo \w de|strong="H1697"\w* José las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* su mujer le \w hablaba|strong="H1696"\w*, \w diciendo|strong="H1696"\w*: «\w Así|strong="H1696"\w* me ha tratado \w tu|strong="H6213"\w* \w siervo|strong="H5650"\w*», \w se|strong="H1961"\w* encendió su furor.  
\v 20 \w Y|strong="H3068"\w* \w tomó|strong="H3947"\w* su amo \w a|strong="H3068"\w* \w José|strong="H3130"\w*, y lo \w puso|strong="H5414"\w* en la cárcel, \w donde|strong="H8033"\w* \w estaban|strong="H1961"\w* \w los|strong="H1961"\w* presos del \w rey|strong="H4428"\w*, y \w estuvo|strong="H1961"\w* \w allí|strong="H8033"\w* en la cárcel.  
\v 21 Pero Yahvé \w estaba|strong="H1961"\w* con \w José|strong="H3130"\w* y \w le|strong="H5869"\w* \w extendió|strong="H5186"\w* su \w misericordia|strong="H2617"\w*, y \w le|strong="H5869"\w* \w dio|strong="H5414"\w* \w gracia|strong="H2580"\w* en \w los|strong="H1961"\w* \w ojos|strong="H5869"\w* del alcaide \w de|strong="H8269"\w* la cárcel.  
\v 22 \w Y|strong="H3068"\w* \w el|strong="H1931"\w* alcaide \w de|strong="H8269"\w* \w la|strong="H1931"\w* cárcel \w entregó|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H8269"\w* \w José|strong="H3130"\w* \w el|strong="H1931"\w* \w cuidado|strong="H3027"\w* \w de|strong="H8269"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* presos \w que|strong="H1931"\w* \w había|strong="H1961"\w* en \w aquella|strong="H1931"\w* prisión; \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w se|strong="H1961"\w* \w hacía|strong="H6213"\w* \w allí|strong="H8033"\w*, \w él|strong="H1931"\w* \w lo|strong="H1931"\w* \w hacía|strong="H6213"\w*.  
\v 23 \w No|strong="H6213"\w* necesitaba atender \w el|strong="H1931"\w* alcaide \w de|strong="H8269"\w* \w la|strong="H1931"\w* cárcel \w cosa|strong="H3605"\w* \w alguna|strong="H3605"\w* \w de|strong="H8269"\w* las \w que|strong="H1931"\w* estaban al \w cuidado|strong="H3027"\w* \w de|strong="H8269"\w* José, porque Yahvé \w estaba|strong="H1004"\w* con \w él|strong="H1931"\w*, y \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w él|strong="H1931"\w* \w hacía|strong="H6213"\w*, Yahvé \w lo|strong="H1931"\w* prosperaba.   
\c 40
\p
\v 1 \w Aconteció|strong="H1961"\w* \w después|strong="H1961"\w* \w de|strong="H1697"\w* estas \w cosas|strong="H1697"\w*, \w que|strong="H1697"\w* el copero del \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Egipto|strong="H4714"\w* y el panadero \w delinquieron|strong="H2398"\w* \w contra|strong="H1961"\w* su señor, el \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Egipto|strong="H4714"\w*.  
\v 2 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* enojó \w Faraón|strong="H6547"\w* \w contra|strong="H5921"\w* sus \w dos|strong="H8147"\w* oficiales, \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* coperos \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* panaderos,  
\v 3 y los \w puso|strong="H5414"\w* en prisión en la \w casa|strong="H1004"\w* del \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* la guardia, en la \w cárcel|strong="H4929"\w* \w donde|strong="H8033"\w* \w José|strong="H3130"\w* \w estaba|strong="H1004"\w* preso.  
\v 4 \w Y|strong="H3068"\w* el \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* la guardia \w los|strong="H1961"\w* confió \w a|strong="H3068"\w* \w José|strong="H3130"\w*, y él les \w servía|strong="H8334"\w*; y \w estuvieron|strong="H1961"\w* muchos \w días|strong="H3117"\w* en la prisión.  
\v 5 \w Y|strong="H3068"\w* \w ambos|strong="H8147"\w*, el copero y el panadero del \w rey|strong="H4428"\w* de \w Egipto|strong="H4714"\w*, que estaban apresados en la cárcel, tuvieron un \w sueño|strong="H2472"\w*, cada uno su propio \w sueño|strong="H2472"\w* en una misma \w noche|strong="H3915"\w*, cada uno con su propio significado.  
\v 6 Vino \w a|strong="H3068"\w* ellos \w José|strong="H3130"\w* por la \w mañana|strong="H1242"\w*, y los \w miró|strong="H7200"\w*, y he \w aquí|strong="H2005"\w* que estaban tristes.  
\v 7 \w Y|strong="H3068"\w* él \w preguntó|strong="H7592"\w* \w a|strong="H3068"\w* aquellos oficiales \w de|strong="H6440"\w* \w Faraón|strong="H6547"\w*, \w que|strong="H3117"\w* estaban con él en la prisión \w de|strong="H6440"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* su señor, diciendo: «¿\w Por|strong="H4069"\w* \w qué|strong="H3117"\w* están \w hoy|strong="H3117"\w* tristes vuestros semblantes?»   
\p
\v 8 Ellos le dijeron: «Hemos tenido un \w sueño|strong="H2472"\w*, y \w no|strong="H3808"\w* hay quien \w lo|strong="H3808"\w* interprete».  
\p Entonces les dijo \w José|strong="H3130"\w*: «¿\w No|strong="H3808"\w* \w son|strong="H3808"\w* de Dios las interpretaciones? \w Contádmelo|strong="H5608"\w* \w ahora|strong="H4994"\w*».   
\p
\v 9 Entonces el \w jefe|strong="H8269"\w* \w de|strong="H6440"\w* los coperos \w contó|strong="H5608"\w* su \w sueño|strong="H2472"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*, y le dijo: «\w Yo|strong="H2009"\w* soñaba que veía una \w vid|strong="H1612"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H2009"\w*,  
\v 10 y en \w la|strong="H1931"\w* \w vid|strong="H1612"\w* \w tres|strong="H7969"\w* \w sarmientos|strong="H8299"\w*; y \w ella|strong="H1931"\w* \w como|strong="H1931"\w* \w que|strong="H1931"\w* brotaba, y arrojaba \w su|strong="H1931"\w* \w flor|strong="H5322"\w*, viniendo \w a|strong="H3068"\w* madurar \w sus|strong="H1931"\w* racimos de \w uvas|strong="H6025"\w*.  
\v 11 \w Y|strong="H3068"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* copa \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w* estaba \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*, \w y|strong="H5921"\w* \w tomaba|strong="H3947"\w* yo \w las|strong="H5921"\w* \w uvas|strong="H6025"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* exprimía \w en|strong="H5921"\w* \w la|strong="H5921"\w* copa \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H5921"\w* \w daba|strong="H5414"\w* yo \w la|strong="H5921"\w* copa \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*».   
\p
\v 12 \w Y|strong="H3068"\w* le dijo \w José|strong="H3130"\w*: «\w Ésta|strong="H2088"\w* \w es|strong="H2088"\w* \w su|strong="H1992"\w* interpretación: \w los|strong="H1992"\w* \w tres|strong="H7969"\w* \w sarmientos|strong="H8299"\w* son \w tres|strong="H7969"\w* \w días|strong="H3117"\w*.  
\v 13 \w Al|strong="H5921"\w* cabo \w de|strong="H5921"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* levantará \w Faraón|strong="H6547"\w* tu \w cabeza|strong="H7218"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w restituirá|strong="H7725"\w* \w a|strong="H3068"\w* tu \w puesto|strong="H5414"\w*, \w y|strong="H5921"\w* \w darás|strong="H5414"\w* \w la|strong="H5921"\w* copa \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w en|strong="H5921"\w* su \w mano|strong="H3027"\w*, \w como|strong="H1961"\w* solías hacerlo \w cuando|strong="H3117"\w* \w eras|strong="H1961"\w* su copero.  
\v 14 \w Acuérdate|strong="H2142"\w*, \w pues|strong="H3588"\w*, \w de|strong="H4480"\w* \w mí|strong="H4994"\w* \w cuando|strong="H3588"\w* tengas \w ese|strong="H2088"\w* \w bien|strong="H3190"\w*, \w y|strong="H3588"\w* \w te|strong="H4480"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* uses \w conmigo|strong="H6213"\w* \w de|strong="H4480"\w* \w misericordia|strong="H2617"\w*, \w y|strong="H3588"\w* \w hagas|strong="H6213"\w* mención \w de|strong="H4480"\w* \w mí|strong="H4994"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H3588"\w* \w me|strong="H4480"\w* saques \w de|strong="H4480"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w*.  
\v 15 \w Porque|strong="H3588"\w* \w fui|strong="H3808"\w* \w hurtado|strong="H1589"\w* \w de|strong="H3588"\w* \w la|strong="H1571"\w* tierra \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w hebreos|strong="H5680"\w*; \w y|strong="H1571"\w* \w tampoco|strong="H3808"\w* he \w hecho|strong="H6213"\w* \w aquí|strong="H6311"\w* \w nada|strong="H3808"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* pusiesen \w en|strong="H3588"\w* \w la|strong="H1571"\w* cárcel».   
\p
\v 16 \w Viendo|strong="H7200"\w* \w el|strong="H5921"\w* \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* panaderos \w que|strong="H3588"\w* \w había|strong="H3588"\w* interpretado \w para|strong="H5921"\w* \w bien|strong="H2896"\w*, dijo \w a|strong="H3068"\w* \w José|strong="H3130"\w*: «También \w yo|strong="H3588"\w* soñaba \w que|strong="H3588"\w* \w veía|strong="H7200"\w* \w tres|strong="H7969"\w* \w canastillos|strong="H5536"\w* \w blancos|strong="H2751"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*.  
\v 17 \w En|strong="H5921"\w* \w el|strong="H5921"\w* \w canastillo|strong="H5536"\w* \w más|strong="H4480"\w* \w alto|strong="H5945"\w* había \w toda|strong="H3605"\w* clase \w de|strong="H4480"\w* manjares \w de|strong="H4480"\w* pastelería \w para|strong="H5921"\w* \w Faraón|strong="H6547"\w*; \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w los|strong="H5921"\w* comían \w del|strong="H4480"\w* \w canastillo|strong="H5536"\w* \w de|strong="H4480"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*».   
\p
\v 18 \w Entonces|strong="H3117"\w* \w respondió|strong="H6030"\w* \w José|strong="H3130"\w*, y dijo: «\w Ésta|strong="H2088"\w* \w es|strong="H2088"\w* \w su|strong="H1992"\w* interpretación: \w los|strong="H1992"\w* \w tres|strong="H7969"\w* \w canastillos|strong="H5536"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* son.  
\v 19 \w Al|strong="H5921"\w* \w cabo|strong="H6086"\w* \w de|strong="H5921"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w quitará|strong="H5375"\w* \w Faraón|strong="H6547"\w* tu \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* hará colgar \w en|strong="H5921"\w* \w la|strong="H5921"\w* horca, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* comerán tu \w carne|strong="H1320"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*».  
\v 20 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H3117"\w* al tercer \w día|strong="H3117"\w*, \w que|strong="H3117"\w* \w era|strong="H1961"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* del cumpleaños \w de|strong="H8269"\w* \w Faraón|strong="H6547"\w*, \w hizo|strong="H6213"\w* \w banquete|strong="H4960"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus sirvientes; y \w alzó|strong="H5375"\w* \w la|strong="H3605"\w* \w cabeza|strong="H7218"\w* del \w jefe|strong="H7218"\w* \w de|strong="H8269"\w* \w los|strong="H3605"\w* coperos, y \w la|strong="H3605"\w* \w cabeza|strong="H7218"\w* del \w jefe|strong="H7218"\w* \w de|strong="H8269"\w* \w los|strong="H3605"\w* panaderos, \w entre|strong="H8432"\w* sus servidores.  
\v 21 \w E|strong="H3068"\w* \w hizo|strong="H5414"\w* \w volver|strong="H7725"\w* \w a|strong="H3068"\w* su oficio \w al|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* coperos, \w y|strong="H5921"\w* \w dio|strong="H5414"\w* \w él|strong="H5921"\w* \w la|strong="H5921"\w* copa \w en|strong="H5921"\w* \w mano|strong="H3709"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*.  
\v 22 Mas hizo ahorcar al \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* los panaderos, como lo había interpretado \w José|strong="H3130"\w*.  
\v 23 \w Y|strong="H3068"\w* el \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* los coperos \w no|strong="H3808"\w* \w se|strong="H3808"\w* acordó \w de|strong="H8269"\w* \w José|strong="H3130"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* le \w olvidó|strong="H7911"\w*.   
\c 41
\p
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H5921"\w* \w pasados|strong="H1961"\w* \w dos|strong="H3117"\w* \w años|strong="H8141"\w* completos, \w soñó|strong="H2492"\w* \w Faraón|strong="H6547"\w* \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w río|strong="H2975"\w*;  
\v 2 y \w que|strong="H4480"\w* \w del|strong="H4480"\w* \w río|strong="H2975"\w* \w subían|strong="H5927"\w* \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w*, \w hermosas|strong="H3303"\w* \w a|strong="H3068"\w* la \w vista|strong="H4758"\w*, y muy gordas, y pacían \w en|strong="H4480"\w* \w el|strong="H2975"\w* prado.  
\v 3 \w Y|strong="H3068"\w* \w que|strong="H4480"\w* tras \w ellas|strong="H5921"\w* \w subían|strong="H5927"\w* \w del|strong="H4480"\w* \w río|strong="H2975"\w* otras \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w* \w de|strong="H4480"\w* feo \w aspecto|strong="H4758"\w* \w y|strong="H5921"\w* enjutas \w de|strong="H4480"\w* \w carne|strong="H1320"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* pararon \w cerca|strong="H5921"\w* \w de|strong="H4480"\w* \w las|strong="H5921"\w* \w vacas|strong="H6510"\w* hermosas \w a|strong="H3068"\w* \w la|strong="H5921"\w* orilla \w del|strong="H4480"\w* \w río|strong="H2975"\w*;  
\v 4 y \w que|strong="H7651"\w* las \w vacas|strong="H6510"\w* \w de|strong="H7451"\w* feo \w aspecto|strong="H4758"\w* y enjutas \w de|strong="H7451"\w* \w carne|strong="H1320"\w* devoraban \w a|strong="H3068"\w* las \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w* \w hermosas|strong="H3303"\w* y muy gordas. \w Y|strong="H3068"\w* \w despertó|strong="H3364"\w* \w Faraón|strong="H6547"\w*.  
\v 5 Se durmió de nuevo, y \w soñó|strong="H2492"\w* la \w segunda|strong="H8145"\w* vez: \w Que|strong="H7651"\w* \w siete|strong="H7651"\w* \w espigas|strong="H7641"\w* \w llenas|strong="H1277"\w* y \w hermosas|strong="H2896"\w* crecían de un solo tallo,  
\v 6 y \w que|strong="H7651"\w* después de \w ellas|strong="H2009"\w* \w salían|strong="H6779"\w* otras \w siete|strong="H7651"\w* \w espigas|strong="H7641"\w* \w menudas|strong="H1851"\w* y abatidas del viento \w solano|strong="H6921"\w*;  
\v 7 y las \w siete|strong="H7651"\w* \w espigas|strong="H7641"\w* \w menudas|strong="H1851"\w* \w devoraban|strong="H1104"\w* \w a|strong="H3068"\w* las \w siete|strong="H7651"\w* \w espigas|strong="H7641"\w* \w gruesas|strong="H1277"\w* y \w llenas|strong="H4392"\w*. \w Y|strong="H3068"\w* \w despertó|strong="H3364"\w* \w Faraón|strong="H6547"\w*, y \w he|strong="H4392"\w* \w aquí|strong="H2009"\w* \w que|strong="H7651"\w* era \w sueño|strong="H2472"\w*.  
\v 8 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* por \w la|strong="H3605"\w* \w mañana|strong="H1242"\w* \w estaba|strong="H1961"\w* agitado su \w espíritu|strong="H7307"\w*, y \w envió|strong="H7971"\w* \w e|strong="H3068"\w* hizo \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w magos|strong="H2748"\w* de \w Egipto|strong="H4714"\w*, y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w sabios|strong="H2450"\w*; y les \w contó|strong="H5608"\w* \w Faraón|strong="H6547"\w* sus \w sueños|strong="H2472"\w*, mas \w no|strong="H1961"\w* \w había|strong="H1961"\w* \w quien|strong="H3605"\w* \w los|strong="H3605"\w* pudiese interpretar \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*.   
\p
\v 9 \w Entonces|strong="H3117"\w* el \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* los coperos \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*, \w diciendo|strong="H1696"\w*: «Me acuerdo \w hoy|strong="H3117"\w* \w de|strong="H8269"\w* mis \w faltas|strong="H2399"\w*.  
\v 10 \w Cuando|strong="H5650"\w* \w Faraón|strong="H6547"\w* \w se|strong="H5921"\w* enojó \w contra|strong="H5921"\w* sus \w siervos|strong="H5650"\w*, \w nos|strong="H5921"\w* echó \w a|strong="H3068"\w* \w la|strong="H5921"\w* prisión \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w capitán|strong="H8269"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* guardia, \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* panaderos.  
\v 11 \w Y|strong="H3068"\w* \w él|strong="H1931"\w* y yo tuvimos un \w sueño|strong="H2472"\w* en una \w misma|strong="H1931"\w* \w noche|strong="H3915"\w*, y cada \w sueño|strong="H2472"\w* \w tenía|strong="H1931"\w* \w su|strong="H1931"\w* propio significado.  
\v 12 Estaba \w allí|strong="H8033"\w* con nosotros un joven \w hebreo|strong="H5680"\w*, \w siervo|strong="H5650"\w* del \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* la guardia; y se lo contamos, y él nos interpretó nuestros \w sueños|strong="H2472"\w*, y \w declaró|strong="H6622"\w* \w a|strong="H3068"\w* \w cada|strong="H8033"\w* uno conforme \w a|strong="H3068"\w* su \w sueño|strong="H2472"\w*.  
\v 13 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H5921"\w* \w como|strong="H1961"\w* \w él|strong="H5921"\w* \w nos|strong="H5921"\w* \w lo|strong="H5921"\w* interpretó, \w así|strong="H3651"\w* \w fue|strong="H1961"\w*: yo \w fui|strong="H1961"\w* restablecido \w en|strong="H5921"\w* \w mi|strong="H5921"\w* puesto, \w y|strong="H5921"\w* \w el|strong="H5921"\w* otro \w fue|strong="H1961"\w* \w colgado|strong="H8518"\w*».   
\p
\v 14 Entonces \w Faraón|strong="H6547"\w* \w envió|strong="H7971"\w* y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*. \w Y|strong="H3068"\w* lo sacaron apresuradamente \w de|strong="H4480"\w* la cárcel, y \w se|strong="H4480"\w* cortó el pelo, y mudó sus \w vestidos|strong="H8071"\w*, y vino \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*.  
\v 15 \w Y|strong="H3068"\w* dijo \w Faraón|strong="H6547"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*: «Yo he tenido un \w sueño|strong="H2472"\w*, \w y|strong="H5921"\w* \w no|strong="H5921"\w* hay quien \w lo|strong="H5921"\w* interprete; \w mas|strong="H5921"\w* he \w oído|strong="H8085"\w* \w decir|strong="H8085"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w que|strong="H5921"\w* \w oyes|strong="H8085"\w* \w sueños|strong="H2472"\w* \w para|strong="H5921"\w* interpretarlos».   
\p
\v 16 \w Respondió|strong="H6030"\w* \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*, diciendo: «No está en \w mí|strong="H6030"\w*; Dios será el \w que|strong="H1107"\w* dé respuesta propicia \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*».   
\p
\v 17 Entonces \w Faraón|strong="H6547"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*: «\w En|strong="H5921"\w* \w mi|strong="H5921"\w* \w sueño|strong="H2472"\w* \w me|strong="H5921"\w* parecía \w que|strong="H5921"\w* \w estaba|strong="H5975"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* orilla \w del|strong="H5921"\w* \w río|strong="H2975"\w*;  
\v 18 y \w que|strong="H4480"\w* \w del|strong="H4480"\w* \w río|strong="H2975"\w* \w subían|strong="H5927"\w* \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w* \w de|strong="H4480"\w* \w gruesas|strong="H1277"\w* \w carnes|strong="H1320"\w* y \w hermosa|strong="H3303"\w* \w apariencia|strong="H8389"\w*, \w que|strong="H4480"\w* pacían \w en|strong="H4480"\w* \w el|strong="H2975"\w* prado.  
\v 19 \w Y|strong="H3068"\w* \w que|strong="H3808"\w* otras \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w* \w subían|strong="H5927"\w* después \w de|strong="H7451"\w* \w ellas|strong="H2007"\w*, \w flacas|strong="H7534"\w* y \w de|strong="H7451"\w* \w muy|strong="H3966"\w* feo aspecto; \w tan|strong="H3966"\w* extenuadas, \w que|strong="H3808"\w* \w no|strong="H3808"\w* he \w visto|strong="H7200"\w* otras \w semejantes|strong="H2007"\w* en fealdad en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H7451"\w* \w Egipto|strong="H4714"\w*.  
\v 20 \w Y|strong="H3068"\w* las \w vacas|strong="H6510"\w* \w flacas|strong="H7534"\w* y feas devoraban \w a|strong="H3068"\w* las \w siete|strong="H7651"\w* \w primeras|strong="H7223"\w* \w vacas|strong="H6510"\w* gordas;  
\v 21 \w y|strong="H3588"\w* éstas entraban \w en|strong="H3588"\w* sus entrañas, \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* \w conocía|strong="H3045"\w* \w que|strong="H3588"\w* hubiesen entrado, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w apariencia|strong="H4758"\w* \w de|strong="H3588"\w* las flacas era \w aún|strong="H3808"\w* \w mala|strong="H7451"\w*, \w como|strong="H3588"\w* \w al|strong="H7130"\w* principio. \w Y|strong="H3068"\w* \w yo|strong="H3588"\w* desperté.  
\v 22 \w Vi|strong="H7200"\w* también soñando, \w que|strong="H7651"\w* \w siete|strong="H7651"\w* \w espigas|strong="H7641"\w* crecían en un mismo tallo, \w llenas|strong="H4392"\w* y \w hermosas|strong="H2896"\w*.  
\v 23 \w Y|strong="H3068"\w* \w que|strong="H7651"\w* otras \w siete|strong="H7651"\w* \w espigas|strong="H7641"\w* \w menudas|strong="H1851"\w*, \w marchitas|strong="H6798"\w*, abatidas del viento \w solano|strong="H6921"\w*, \w crecían|strong="H6779"\w* después de \w ellas|strong="H2009"\w*;  
\v 24 y las \w espigas|strong="H7641"\w* \w menudas|strong="H1851"\w* \w devoraban|strong="H1104"\w* \w a|strong="H3068"\w* las \w siete|strong="H7651"\w* \w espigas|strong="H7641"\w* \w hermosas|strong="H2896"\w*; y lo he dicho \w a|strong="H3068"\w* los \w magos|strong="H2748"\w*, mas no hay quien me lo \w declare|strong="H5046"\w*».   
\p
\v 25 Entonces respondió \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*: «\w El|strong="H1931"\w* \w sueño|strong="H2472"\w* de \w Faraón|strong="H6547"\w* \w es|strong="H1931"\w* uno \w mismo|strong="H1931"\w*; Dios ha mostrado \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w va|strong="H3068"\w* \w a|strong="H3068"\w* \w hacer|strong="H6213"\w*.  
\v 26 Las \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w* \w hermosas|strong="H2896"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* son; y las \w espigas|strong="H7641"\w* \w hermosas|strong="H2896"\w* son \w siete|strong="H7651"\w* \w años|strong="H8141"\w*: \w el|strong="H1931"\w* \w sueño|strong="H2472"\w* \w es|strong="H1931"\w* uno \w mismo|strong="H1931"\w*.  
\v 27 También las \w siete|strong="H7651"\w* \w vacas|strong="H6510"\w* \w flacas|strong="H7534"\w* y feas \w que|strong="H1961"\w* \w subían|strong="H5927"\w* tras \w ellas|strong="H2007"\w*, \w son|strong="H1961"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w*; y las \w siete|strong="H7651"\w* \w espigas|strong="H7641"\w* \w menudas|strong="H7386"\w* y marchitas del viento \w solano|strong="H6921"\w*, \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w serán|strong="H1961"\w* \w de|strong="H7451"\w* \w hambre|strong="H7458"\w*.  
\v 28 \w Esto|strong="H1697"\w* \w es|strong="H1931"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w respondo|strong="H1696"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*. \w Lo|strong="H1931"\w* \w que|strong="H1931"\w* Dios \w va|strong="H3068"\w* \w a|strong="H3068"\w* \w hacer|strong="H6213"\w*, \w lo|strong="H1931"\w* ha mostrado \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*.  
\v 29 He \w aquí|strong="H2009"\w* vienen \w siete|strong="H7651"\w* \w años|strong="H8141"\w* de \w gran|strong="H1419"\w* abundancia en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra de \w Egipto|strong="H4714"\w*.  
\v 30 \w Y|strong="H3068"\w* tras \w ellos|strong="H3605"\w* seguirán \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w de|strong="H7911"\w* \w hambre|strong="H7458"\w*; y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* abundancia será \w olvidada|strong="H7911"\w* en \w la|strong="H3605"\w* tierra \w de|strong="H7911"\w* \w Egipto|strong="H4714"\w*, y \w el|strong="H3605"\w* \w hambre|strong="H7458"\w* \w consumirá|strong="H3615"\w* \w la|strong="H3605"\w* tierra.  
\v 31 \w Y|strong="H3068"\w* \w aquella|strong="H1931"\w* abundancia \w no|strong="H3808"\w* \w se|strong="H3045"\w* echará \w de|strong="H3588"\w* ver, \w a|strong="H3068"\w* \w causa|strong="H6440"\w* del \w hambre|strong="H7458"\w* siguiente, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w será|strong="H1931"\w* \w gravísima|strong="H3966"\w*.  
\v 32 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w suceder|strong="H8138"\w* \w el|strong="H5921"\w* \w sueño|strong="H2472"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*, significa \w que|strong="H3588"\w* \w la|strong="H5921"\w* \w cosa|strong="H1697"\w* \w es|strong="H3588"\w* \w firme|strong="H3559"\w* \w de|strong="H5921"\w* parte \w de|strong="H5921"\w* Dios, \w y|strong="H3588"\w* \w que|strong="H3588"\w* Dios \w se|strong="H5921"\w* apresura \w a|strong="H3068"\w* hacerla.   
\p
\v 33 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w provéase|strong="H7200"\w* \w ahora|strong="H6258"\w* \w Faraón|strong="H6547"\w* \w de|strong="H5921"\w* un varón prudente \w y|strong="H5921"\w* \w sabio|strong="H2450"\w*, \w y|strong="H5921"\w* póngalo \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.  
\v 34 \w Haga|strong="H6213"\w* \w esto|strong="H6213"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H5921"\w* \w ponga|strong="H6485"\w* \w gobernadores|strong="H6496"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* país, \w y|strong="H5921"\w* quinte \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* abundancia.  
\v 35 \w Y|strong="H3068"\w* junten \w toda|strong="H3605"\w* \w la|strong="H8104"\w* provisión \w de|strong="H8478"\w* \w estos|strong="H3605"\w* \w buenos|strong="H2896"\w* \w años|strong="H8141"\w* \w que|strong="H3605"\w* vienen, y recojan \w el|strong="H3605"\w* \w trigo|strong="H1250"\w* \w bajo|strong="H8478"\w* \w la|strong="H8104"\w* \w mano|strong="H3027"\w* \w de|strong="H8478"\w* \w Faraón|strong="H6547"\w* para mantenimiento \w de|strong="H8478"\w* las \w ciudades|strong="H5892"\w*; y guárdenlo.  
\v 36 \w Y|strong="H3068"\w* \w esté|strong="H1961"\w* aquella provisión en depósito \w para|strong="H1961"\w* el país, \w para|strong="H1961"\w* \w los|strong="H1961"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* de \w hambre|strong="H7458"\w* \w que|strong="H3808"\w* \w habrá|strong="H1961"\w* en la tierra de \w Egipto|strong="H4714"\w*; y el país \w no|strong="H3808"\w* \w perecerá|strong="H3772"\w* de \w hambre|strong="H7458"\w*».   
\p
\v 37 \w El|strong="H3605"\w* \w asunto|strong="H1697"\w* \w pareció|strong="H5869"\w* \w bien|strong="H3190"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* y \w a|strong="H3068"\w* sus \w siervos|strong="H5650"\w*.  
\v 38 \w Y|strong="H3068"\w* dijo \w Faraón|strong="H6547"\w* \w a|strong="H3068"\w* sus \w siervos|strong="H5650"\w*: «¿Acaso \w hallaremos|strong="H4672"\w* \w a|strong="H3068"\w* \w otro|strong="H2088"\w* hombre como \w éste|strong="H2088"\w*, en quien \w esté|strong="H2088"\w* el \w espíritu|strong="H7307"\w* de Dios?»  
\v 39 \w Y|strong="H3068"\w* dijo \w Faraón|strong="H6547"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*: «Pues \w que|strong="H3045"\w* Dios te ha hecho \w saber|strong="H3045"\w* \w todo|strong="H3605"\w* \w esto|strong="H2063"\w*, no hay \w entendido|strong="H3045"\w* ni \w sabio|strong="H2450"\w* \w como|strong="H3644"\w* tú.  
\v 40 Tú \w estarás|strong="H1961"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w*, \w y|strong="H5921"\w* \w por|strong="H5921"\w* tu \w palabra|strong="H6310"\w* \w se|strong="H1961"\w* gobernará \w todo|strong="H3605"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*; \w solamente|strong="H7535"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w seré|strong="H1961"\w* \w yo|strong="H4480"\w* mayor \w que|strong="H4480"\w* tú».  
\v 41 Dijo \w además|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*: «He aquí yo \w te|strong="H5921"\w* he \w puesto|strong="H5414"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*».  
\v 42 \w Entonces|strong="H5493"\w* \w Faraón|strong="H6547"\w* \w quitó|strong="H5493"\w* su anillo \w de|strong="H5921"\w* su \w mano|strong="H3027"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w puso|strong="H7760"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w hizo|strong="H5414"\w* vestir \w de|strong="H5921"\w* ropas \w de|strong="H5921"\w* lino finísimo, \w y|strong="H5921"\w* \w puso|strong="H7760"\w* un collar \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w en|strong="H5921"\w* su \w cuello|strong="H6677"\w*;  
\v 43 \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w hizo|strong="H5414"\w* subir \w en|strong="H5921"\w* su \w segundo|strong="H4932"\w* \w carro|strong="H4818"\w*, \w y|strong="H5921"\w* pregonaron \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*: «¡Doblad \w la|strong="H5921"\w* rodilla!» \w Y|strong="H3068"\w* \w lo|strong="H5921"\w* \w puso|strong="H5414"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.  
