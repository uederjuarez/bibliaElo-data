\q2 \w y|strong="H3588"\w* \w al|strong="H4480"\w* \w polvo|strong="H6083"\w* \w volverás|strong="H7725"\w*”.   
\p
\v 20 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* Adán \w el|strong="H1931"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* mujer, \w Eva|strong="H2332"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w ella|strong="H1931"\w* \w era|strong="H1961"\w* madre \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w vivientes|strong="H2416"\w*.  
\v 21 \w Y|strong="H3068"\w* Yahvé \w Dios|strong="H3068"\w* \w hizo|strong="H6213"\w* al hombre y \w a|strong="H3068"\w* su mujer \w túnicas|strong="H3801"\w* \w de|strong="H3847"\w* pieles, y los \w vistió|strong="H3847"\w*.   
\p
\v 22 \w Y|strong="H3068"\w* dijo Yahvé \w Dios|strong="H3068"\w*: «He \w aquí|strong="H2005"\w* \w el|strong="H1571"\w* hombre \w es|strong="H1961"\w* \w como|strong="H1571"\w* uno \w de|strong="H4480"\w* nosotros, \w sabiendo|strong="H3045"\w* \w el|strong="H1571"\w* \w bien|strong="H2896"\w* \w y|strong="H1571"\w* \w el|strong="H1571"\w* \w mal|strong="H7451"\w*; \w ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w que|strong="H4480"\w* \w no|strong="H6435"\w* \w alargue|strong="H7971"\w* su \w mano|strong="H3027"\w*, \w y|strong="H1571"\w* \w tome|strong="H3947"\w* \w también|strong="H1571"\w* \w del|strong="H4480"\w* \w árbol|strong="H6086"\w* \w de|strong="H4480"\w* \w la|strong="H1571"\w* \w vida|strong="H2416"\w*, \w y|strong="H1571"\w* coma, \w y|strong="H1571"\w* \w viva|strong="H2416"\w* \w para|strong="H4480"\w* \w siempre|strong="H5769"\w*».  
\v 23 \w Y|strong="H3068"\w* lo sacó Yahvé \w Dios|strong="H3068"\w* del \w huerto|strong="H1588"\w* de Edén, para que labrase la tierra de que fue \w tomado|strong="H3947"\w*.  
\v 24 \w Echó|strong="H1644"\w*, pues, fuera al hombre, y puso al \w oriente|strong="H6924"\w* del \w huerto|strong="H1588"\w* de Edén \w querubines|strong="H3742"\w*\f + \fr 3:24 \ft Los querubines son poderosas criaturas angélicas, mensajeros de Dios con alas. Véase Ezequiel 10.\f* y una \w espada|strong="H2719"\w* \w encendida|strong="H3858"\w* que se revolvía \w a|strong="H3068"\w* todas partes, para \w guardar|strong="H8104"\w* el \w camino|strong="H1870"\w* del \w árbol|strong="H6086"\w* de \w la|strong="H8104"\w* \w vida|strong="H2416"\w*.   
\c 4
\p
\v 1 \w Conoció|strong="H3045"\w*\f + \fr 4:1 \ft o, yacer con, o, tener relaciones con\f* Adán \w a|strong="H3068"\w* su mujer \w Eva|strong="H2332"\w*, la cual \w concibió|strong="H2029"\w*\f + \fr 4:1 \ft o, se quedó embarazada\f* y dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Caín|strong="H7014"\w*, y dijo: «He alcanzado varón de parte de Yahvé».  
\v 2 \w Después|strong="H1961"\w* dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* su hermano \w Abel|strong="H1893"\w*. \w Y|strong="H3068"\w* \w Abel|strong="H1893"\w* \w fue|strong="H1961"\w* \w pastor|strong="H7462"\w* de \w ovejas|strong="H6629"\w*, y \w Caín|strong="H7014"\w* \w fue|strong="H1961"\w* \w labrador|strong="H5647"\w* de la tierra.  
\v 3 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w andando|strong="H7093"\w* el \w tiempo|strong="H3117"\w*, \w que|strong="H3117"\w* \w Caín|strong="H7014"\w* trajo del \w fruto|strong="H6529"\w* de la tierra una \w ofrenda|strong="H4503"\w* \w a|strong="H3068"\w* Yahvé.  
\v 4 \w Y|strong="H3068"\w* \w Abel|strong="H1893"\w* trajo \w también|strong="H1571"\w* de \w los|strong="H1931"\w* primogénitos de \w sus|strong="H1931"\w* \w ovejas|strong="H6629"\w*, de \w lo|strong="H1931"\w* \w más|strong="H1571"\w* gordo de \w ellas|strong="H1931"\w*. \w Y|strong="H3068"\w* \w miró|strong="H8159"\w* Yahvé \w con|strong="H1571"\w* agrado \w a|strong="H3068"\w* \w Abel|strong="H1893"\w* \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w ofrenda|strong="H4503"\w*;  
\v 5 pero \w no|strong="H3808"\w* \w miró|strong="H8159"\w* con agrado \w a|strong="H3068"\w* \w Caín|strong="H7014"\w* y \w a|strong="H3068"\w* la \w ofrenda|strong="H4503"\w* suya. \w Y|strong="H3068"\w* \w se|strong="H3808"\w* ensañó \w Caín|strong="H7014"\w* en \w gran|strong="H3966"\w* \w manera|strong="H3966"\w*, y decayó su semblante.  
\v 6 Entonces Yahvé dijo \w a|strong="H3068"\w* \w Caín|strong="H7014"\w*: «¿\w Por|strong="H6440"\w* \w qué|strong="H4100"\w* te has ensañado, y \w por|strong="H6440"\w* \w qué|strong="H4100"\w* ha decaído tu semblante?  
\v 7 \w Si|strong="H3808"\w* \w bien|strong="H3190"\w* hicieres, ¿\w no|strong="H3808"\w* serás enaltecido? y \w si|strong="H3808"\w* \w no|strong="H3808"\w* hicieres \w bien|strong="H3190"\w*, el \w pecado|strong="H2403"\w* está \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w*; con todo esto, \w a|strong="H3068"\w* ti \w será|strong="H3808"\w* su deseo, y tú te enseñorearás de él».  
\v 8 \w Y|strong="H3068"\w* dijo \w Caín|strong="H7014"\w* \w a|strong="H3068"\w* su hermano \w Abel|strong="H1893"\w*: «Salgamos al \w campo|strong="H7704"\w*». \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w estando|strong="H1961"\w* ellos en el \w campo|strong="H7704"\w*, \w Caín|strong="H7014"\w* \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* \w contra|strong="H1961"\w* su hermano \w Abel|strong="H1893"\w*, y lo \w mató|strong="H2026"\w*.   
\p
\v 9 \w Y|strong="H3068"\w* Yahvé dijo \w a|strong="H3068"\w* \w Caín|strong="H7014"\w*: «¿Dónde está \w Abel|strong="H1893"\w* tu hermano?»  
\p \w Y|strong="H3068"\w* él respondió: «\w No|strong="H3808"\w* \w sé|strong="H3045"\w*. ¿Soy yo acaso \w guarda|strong="H8104"\w* de mi hermano?»   
\p
\v 10 \w Y|strong="H3068"\w* \w él|strong="H6213"\w* le dijo: «¿\w Qué|strong="H4100"\w* has \w hecho|strong="H6213"\w*? La \w voz|strong="H6963"\w* \w de|strong="H4480"\w* la \w sangre|strong="H1818"\w* \w de|strong="H4480"\w* \w tu|strong="H6213"\w* hermano \w clama|strong="H6817"\w* \w a|strong="H3068"\w* mí \w desde|strong="H4480"\w* la tierra.  
\v 11 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, maldito seas tú \w de|strong="H4480"\w* la tierra, \w que|strong="H4480"\w* \w abrió|strong="H6475"\w* su \w boca|strong="H6310"\w* \w para|strong="H4480"\w* \w recibir|strong="H3947"\w* \w de|strong="H4480"\w* tu \w mano|strong="H3027"\w* la \w sangre|strong="H1818"\w* \w de|strong="H4480"\w* tu hermano.  
\v 12 \w Cuando|strong="H3588"\w* labres \w la|strong="H3588"\w* tierra, \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w volverá|strong="H3254"\w* \w a|strong="H3068"\w* \w dar|strong="H5414"\w* \w su|strong="H3588"\w* \w fuerza|strong="H3581"\w*; \w errante|strong="H5128"\w* \w y|strong="H3588"\w* extranjero \w serás|strong="H1961"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra».   
\p
\v 13 \w Y|strong="H3068"\w* dijo \w Caín|strong="H7014"\w* \w a|strong="H3068"\w* Yahvé: «\w Grande|strong="H1419"\w* es \w mi|strong="H5375"\w* castigo para ser soportado.  
\v 14 He \w aquí|strong="H2005"\w* \w me|strong="H5921"\w* echas \w hoy|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w de|strong="H5921"\w* tu \w presencia|strong="H6440"\w* \w me|strong="H5921"\w* \w esconderé|strong="H5641"\w*, \w y|strong="H5921"\w* \w seré|strong="H1961"\w* \w errante|strong="H5128"\w* \w y|strong="H5921"\w* extranjero \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra; \w y|strong="H5921"\w* \w sucederá|strong="H1961"\w* \w que|strong="H5921"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* \w hallare|strong="H4672"\w*, \w me|strong="H5921"\w* \w matará|strong="H2026"\w*».   
\p
\v 15 \w Y|strong="H3068"\w* le respondió Yahvé: «\w Ciertamente|strong="H5221"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H1115"\w* \w matare|strong="H2026"\w* \w a|strong="H3068"\w* \w Caín|strong="H7014"\w*, \w siete|strong="H7659"\w* veces será castigado». \w Entonces|strong="H3651"\w* Yahvé \w puso|strong="H7760"\w* señal \w en|strong="H5221"\w* \w Caín|strong="H7014"\w*, para \w que|strong="H1115"\w* \w no|strong="H1115"\w* \w lo|strong="H3605"\w* matase \w cualquiera|strong="H3605"\w* \w que|strong="H1115"\w* le \w hallara|strong="H4672"\w*.   
\p
\v 16 \w Salió|strong="H3318"\w*, pues, \w Caín|strong="H7014"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, y \w habitó|strong="H3427"\w* \w en|strong="H3318"\w* tierra \w de|strong="H6440"\w* Nod, al oriente \w de|strong="H6440"\w* Edén.  
\v 17 \w Y|strong="H3068"\w* \w conoció|strong="H3045"\w* \w Caín|strong="H7014"\w* \w a|strong="H3068"\w* su mujer, la cual \w concibió|strong="H2029"\w* y dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Enoc; y \w edificó|strong="H1129"\w* una \w ciudad|strong="H5892"\w*, y \w llamó|strong="H7121"\w* \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w* del \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su \w hijo|strong="H1121"\w*, Enoc.  
\v 18 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* Enoc \w nació|strong="H3205"\w* \w Irad|strong="H5897"\w*, \w e|strong="H3068"\w* \w Irad|strong="H5897"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Mehujael, y Mehujael \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Matusael, y Matusael \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Lamec.  
