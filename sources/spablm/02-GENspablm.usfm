\v 23 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Lea|strong="H3812"\w*: \w Rubén|strong="H7205"\w* \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w*, y \w Simeón|strong="H8095"\w*, \w Leví|strong="H3878"\w*, \w Judá|strong="H3063"\w*, Isacar y \w Zabulón|strong="H2074"\w*.  
\v 24 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Raquel: \w José|strong="H3130"\w* y \w Benjamín|strong="H1144"\w*.  
\v 25 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bilha|strong="H1090"\w*, \w sierva|strong="H8198"\w* \w de|strong="H1121"\w* Raquel: \w Dan|strong="H1835"\w* y Neftalí.  
\v 26 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zilpa|strong="H2153"\w*, \w sierva|strong="H8198"\w* \w de|strong="H1121"\w* \w Lea|strong="H3812"\w*: \w Gad|strong="H1410"\w* y Aser. Éstos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w*, \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* en Padán Aram.  
\v 27 \w Y|strong="H3068"\w* vino \w Jacob|strong="H3290"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w su|strong="H1931"\w* padre \w a|strong="H3068"\w* \w Mamre|strong="H4471"\w*, \w a|strong="H3068"\w* \w la|strong="H1931"\w* ciudad de Quiriat Arba (\w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Hebrón|strong="H2275"\w*), \w donde|strong="H8033"\w* habitaron Abraham \w e|strong="H3068"\w* \w Isaac|strong="H3327"\w*.   
\p
\v 28 \w Y|strong="H3068"\w* \w fueron|strong="H1961"\w* \w los|strong="H1961"\w* \w días|strong="H3117"\w* de \w Isaac|strong="H3327"\w* \w ciento|strong="H3967"\w* \w ochenta|strong="H8084"\w* \w años|strong="H8141"\w*.  
\v 29 \w Y|strong="H3068"\w* exhaló \w Isaac|strong="H3327"\w* \w el|strong="H1121"\w* espíritu, y \w murió|strong="H4191"\w*, y fue reunido \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*, \w anciano|strong="H2205"\w* y \w lleno|strong="H7649"\w* \w de|strong="H1121"\w* \w días|strong="H3117"\w*; y lo \w sepultaron|strong="H6912"\w* \w Esaú|strong="H6215"\w* y \w Jacob|strong="H3290"\w* sus \w hijos|strong="H1121"\w*.   
\c 36
\p
\v 1 Éstas son las generaciones de \w Esaú|strong="H6215"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* Edom.  
\v 2 \w Esaú|strong="H6215"\w* \w tomó|strong="H3947"\w* sus \w mujeres|strong="H1323"\w* de las \w hijas|strong="H1323"\w* de \w Canaán|strong="H3667"\w*: \w a|strong="H3068"\w* \w Ada|strong="H5711"\w*, \w hija|strong="H1323"\w* de Elón heteo, \w a|strong="H3068"\w* Aholibama, \w hija|strong="H1323"\w* de \w Aná|strong="H6034"\w*, nieta de \w Zibeón|strong="H6649"\w* \w heveo|strong="H2340"\w*;  
\v 3 y \w a|strong="H3068"\w* Basemat, \w hija|strong="H1323"\w* de \w Ismael|strong="H3458"\w*, hermana de Nebaiot.  
\v 4 \w Y|strong="H3068"\w* \w Ada|strong="H5711"\w* dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Elifaz para \w Esaú|strong="H6215"\w*; y Basemat dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Reuel|strong="H7467"\w*.  
\v 5 \w Y|strong="H3068"\w* Aholibama dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Jeús, \w a|strong="H3068"\w* \w Jalam|strong="H3281"\w* y \w a|strong="H3068"\w* \w Coré|strong="H7141"\w*. Éstos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* en la tierra \w de|strong="H1121"\w* \w Canaán|strong="H3667"\w*.  
\v 6 \w Y|strong="H3068"\w* \w Esaú|strong="H6215"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* sus \w mujeres|strong="H1323"\w*, \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* y \w a|strong="H3068"\w* sus \w hijas|strong="H1323"\w*, y \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w personas|strong="H5315"\w* \w de|strong="H6440"\w* su \w casa|strong="H1004"\w*, y sus \w ganados|strong="H4735"\w*, y \w todas|strong="H3605"\w* sus \w bestias|strong="H4735"\w*, y \w todo|strong="H3605"\w* cuanto había adquirido \w en|strong="H3212"\w* \w la|strong="H3605"\w* tierra \w de|strong="H6440"\w* \w Canaán|strong="H3667"\w*, y se \w fue|strong="H3212"\w* \w a|strong="H3068"\w* otra tierra, separándose \w de|strong="H6440"\w* \w Jacob|strong="H3290"\w* su hermano.  
\v 7 \w Porque|strong="H3588"\w* \w los|strong="H3427"\w* bienes \w de|strong="H3588"\w* ellos \w eran|strong="H1961"\w* \w muchos|strong="H7227"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w podían|strong="H3201"\w* \w habitar|strong="H3427"\w* \w juntos|strong="H3162"\w*, \w ni|strong="H3808"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w su|strong="H3588"\w* peregrinación \w los|strong="H3427"\w* \w podía|strong="H3201"\w* \w sostener|strong="H5375"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* sus \w ganados|strong="H4735"\w*.  
\v 8 \w Y|strong="H3068"\w* \w Esaú|strong="H6215"\w* \w habitó|strong="H3427"\w* en \w el|strong="H1931"\w* \w monte|strong="H2022"\w* de \w Seir|strong="H8165"\w*; \w Esaú|strong="H6215"\w* \w es|strong="H1931"\w* Edom.   
\p
\v 9 Éstos son los linajes de \w Esaú|strong="H6215"\w*, padre de Edom, en el \w monte|strong="H2022"\w* de \w Seir|strong="H8165"\w*.  
\v 10 Éstos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: Elifaz, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ada|strong="H5711"\w* mujer \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*; \w Reuel|strong="H7467"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Basemat mujer \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.  
\v 11 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elifaz \w fueron|strong="H1961"\w* \w Temán|strong="H8487"\w*, Omar, Zefo, \w Gatam|strong="H1609"\w* y Cenaz.  
\v 12 \w Y|strong="H3068"\w* \w Timna|strong="H8555"\w* \w fue|strong="H1961"\w* \w concubina|strong="H6370"\w* \w de|strong="H1121"\w* Elifaz \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, y ella le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Amalec|strong="H6002"\w*; éstos \w son|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ada|strong="H5711"\w*, mujer \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.  
\v 13 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w* \w fueron|strong="H1961"\w* Nahat, \w Zera|strong="H2226"\w*, Sama y Miza; éstos \w son|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Basemat, mujer \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.  
\v 14 \w Y|strong="H3068"\w* éstos \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aholibama, mujer \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w Aná|strong="H6034"\w*, nieta \w de|strong="H1121"\w* \w Zibeón|strong="H6649"\w*: ella dio \w a|strong="H3068"\w* luz \w para|strong="H1961"\w* \w Esaú|strong="H6215"\w* \w a|strong="H3068"\w* Jeús, \w a|strong="H3068"\w* \w Jalam|strong="H3281"\w* y \w a|strong="H3068"\w* \w Coré|strong="H7141"\w*.   
\p
\v 15 Éstos son \w los|strong="H1121"\w* caudillos \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elifaz, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: \w el|strong="H1121"\w* caudillo \w Temán|strong="H8487"\w*, \w el|strong="H1121"\w* caudillo Omar, \w el|strong="H1121"\w* caudillo Zefo, \w el|strong="H1121"\w* caudillo Cenaz,  
\v 16 \w el|strong="H1121"\w* caudillo \w Coré|strong="H7141"\w*, \w el|strong="H1121"\w* caudillo \w Gatam|strong="H1609"\w* y \w el|strong="H1121"\w* caudillo \w Amalec|strong="H6002"\w*; éstos son \w los|strong="H1121"\w* caudillos \w que|strong="H1121"\w* salieron \w de|strong="H1121"\w* Elifaz en la tierra \w de|strong="H1121"\w* Edom, \w los|strong="H1121"\w* cuales fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ada|strong="H5711"\w*.  
\v 17 \w Y|strong="H3068"\w* éstos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: \w el|strong="H1121"\w* caudillo Nahat, \w el|strong="H1121"\w* caudillo \w Zera|strong="H2226"\w*, \w el|strong="H1121"\w* caudillo Sama y \w el|strong="H1121"\w* caudillo Miza; éstos son \w los|strong="H1121"\w* caudillos \w que|strong="H1121"\w* salieron \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w* en la tierra \w de|strong="H1121"\w* Edom; éstos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Basemat, mujer \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.  
\v 18 \w Y|strong="H3068"\w* éstos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aholibama, mujer \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: \w el|strong="H1121"\w* caudillo \w Jeús|strong="H3266"\w*, \w el|strong="H1121"\w* caudillo \w Jalam|strong="H3281"\w* y \w el|strong="H1121"\w* caudillo \w Coré|strong="H7141"\w*; éstos fueron \w los|strong="H1121"\w* caudillos \w que|strong="H1121"\w* salieron \w de|strong="H1121"\w* Aholibama, mujer \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w Aná|strong="H6034"\w*.  
\v 19 \w Éstos|strong="H1931"\w*, \w pues|strong="H1931"\w*, son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, y \w sus|strong="H1931"\w* caudillos; \w él|strong="H1931"\w* \w es|strong="H1931"\w* Edom.   
\p
\v 20 Éstos son \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Seir|strong="H8165"\w* \w horeo|strong="H2752"\w*, \w moradores|strong="H3427"\w* \w de|strong="H1121"\w* aquella tierra: \w Lotán|strong="H3877"\w*, \w Sobal|strong="H7732"\w*, \w Zibeón|strong="H6649"\w*, \w Aná|strong="H6034"\w*,  
\v 21 \w Disón|strong="H1789"\w*, Ezer y Disán; éstos son \w los|strong="H1121"\w* caudillos \w de|strong="H1121"\w* \w los|strong="H1121"\w* horeos, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Seir|strong="H8165"\w*, en la tierra \w de|strong="H1121"\w* Edom.  
\v 22 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Lotán|strong="H3877"\w* \w fueron|strong="H1961"\w* \w Hori|strong="H2753"\w* y Hemán; y \w Timna|strong="H8555"\w* \w fue|strong="H1961"\w* hermana \w de|strong="H1121"\w* \w Lotán|strong="H3877"\w*.  
\v 23 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sobal|strong="H7732"\w* fueron Alván, Manahat, \w Ebal|strong="H5858"\w*, Sefo y Onam.  
\v 24 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zibeón|strong="H6649"\w* fueron Aja y \w Aná|strong="H6034"\w*. \w Éste|strong="H1931"\w* \w es|strong="H1931"\w* \w aquel|strong="H1931"\w* \w Aná|strong="H6034"\w* \w que|strong="H1931"\w* \w halló|strong="H4672"\w* manantiales \w de|strong="H1121"\w* aguas termales en \w el|strong="H1931"\w* \w desierto|strong="H4057"\w*, cuando \w apacentaba|strong="H7462"\w* \w los|strong="H1121"\w* \w asnos|strong="H2543"\w* \w de|strong="H1121"\w* \w Zibeón|strong="H6649"\w* \w su|strong="H1931"\w* padre.  
\v 25 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Aná|strong="H6034"\w* fueron \w Disón|strong="H1787"\w* y Aholibama, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w Aná|strong="H6034"\w*.  
\v 26 Éstos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Disón|strong="H1789"\w*: \w Hemdán|strong="H2533"\w*, Esbán, Itrán y Querán.  
\v 27 Éstos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ezer: \w Bilhán|strong="H1092"\w*, \w Zaaván|strong="H2190"\w* y Acán.  
\v 28 Éstos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Disán: \w Uz|strong="H5780"\w* y Arán.  
\v 29 Éstos son los caudillos de los horeos: el caudillo \w Lotán|strong="H3877"\w*, el caudillo \w Sobal|strong="H7732"\w*, el caudillo \w Zibeón|strong="H6649"\w*, el caudillo \w Aná|strong="H6034"\w*,  
\v 30 el caudillo \w Disón|strong="H1789"\w*, el caudillo Ezer, el caudillo Disán; éstos son los caudillos de los horeos, por sus mandos en la tierra de \w Seir|strong="H8165"\w*.   
\p
\v 31 Éstos son \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w que|strong="H1121"\w* \w reinaron|strong="H4428"\w* en la tierra \w de|strong="H6440"\w* Edom, \w antes|strong="H6440"\w* \w que|strong="H1121"\w* \w reinara|strong="H4427"\w* \w rey|strong="H4428"\w* alguno sobre \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.  
\v 32 \w Bela|strong="H1106"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Beor \w reinó|strong="H4427"\w* en Edom; y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w* fue Dinaba.  
\v 33 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Bela|strong="H1106"\w*, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Jobab|strong="H3103"\w* \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* \w Zera|strong="H2226"\w*, \w de|strong="H8478"\w* \w Bosra|strong="H1224"\w*.  
\v 34 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Jobab|strong="H3103"\w*, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Husam|strong="H2367"\w*, \w de|strong="H8478"\w* la tierra \w de|strong="H8478"\w* los temanitas.  
\v 35 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Husam|strong="H2367"\w*, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* Hadad \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Bedad, \w el|strong="H1121"\w* \w que|strong="H1121"\w* derrotó \w a|strong="H3068"\w* \w Madián|strong="H4080"\w* \w en|strong="H8478"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w* \w de|strong="H8478"\w* \w Moab|strong="H4124"\w*; y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su \w ciudad|strong="H5892"\w* fue Avit.  
\v 36 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* Hadad, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Samla|strong="H8072"\w*, \w de|strong="H8478"\w* Masreca.  
\v 37 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Samla|strong="H8072"\w*, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Saúl|strong="H7586"\w*, \w de|strong="H8478"\w* Rehobot, que está junto \w al|strong="H8478"\w* \w río|strong="H5104"\w*.  
\v 38 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Saúl|strong="H7586"\w*, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* Baal Hanán \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Acbor.  
\v 39 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* Baal Hanán \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Acbor, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* Hadar; y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su \w ciudad|strong="H5892"\w* fue Pau; y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su mujer, Mehetabel \w hija|strong="H1323"\w* \w de|strong="H8478"\w* Matred, nieta \w de|strong="H8478"\w* Mezaab.   
\p
\v 40 Éstos, pues, son los \w nombres|strong="H8034"\w* de los caudillos de \w Esaú|strong="H6215"\w*, por sus \w linajes|strong="H4940"\w*, por sus \w lugares|strong="H4725"\w* y sus \w nombres|strong="H8034"\w*: el caudillo \w Timna|strong="H8555"\w*, el caudillo Alva, el caudillo Jetet,  
\v 41 el caudillo Aholibama, el caudillo Ela, el caudillo Pinón,  
\v 42 el caudillo Cenaz, el caudillo \w Temán|strong="H8487"\w*, el caudillo Mibzar,  
\v 43 \w el|strong="H1931"\w* caudillo \w Magdiel|strong="H4025"\w* y \w el|strong="H1931"\w* caudillo Iram. \w Éstos|strong="H1931"\w* son \w los|strong="H1931"\w* caudillos de Edom, según \w sus|strong="H1931"\w* moradas en \w la|strong="H1931"\w* tierra de \w su|strong="H1931"\w* posesión. \w Éste|strong="H1931"\w* \w es|strong="H1931"\w* \w Esaú|strong="H6215"\w*, padre de \w los|strong="H1931"\w* edomitas.   
\c 37
\p
\v 1 \w Habitó|strong="H3427"\w* \w Jacob|strong="H3290"\w* en la tierra donde había peregrinado su padre, en la tierra de \w Canaán|strong="H3667"\w*.  
\v 2 \w Ésta|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* historia \w de|strong="H1121"\w* \w la|strong="H1931"\w* familia \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w*: \w José|strong="H3130"\w*, \w siendo|strong="H1931"\w* \w de|strong="H1121"\w* \w edad|strong="H8141"\w* \w de|strong="H1121"\w* \w diecisiete|strong="H7651"\w* \w años|strong="H8141"\w*, \w apacentaba|strong="H7462"\w* las \w ovejas|strong="H6629"\w* con \w sus|strong="H1931"\w* hermanos; y \w el|strong="H1931"\w* joven \w estaba|strong="H1961"\w* con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bilha|strong="H1090"\w* y con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zilpa|strong="H2153"\w*, mujeres \w de|strong="H1121"\w* \w su|strong="H1931"\w* padre; \w e|strong="H3068"\w* informaba \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre \w la|strong="H1931"\w* \w mala|strong="H7451"\w* \w fama|strong="H1681"\w* \w de|strong="H1121"\w* \w ellos|strong="H1931"\w*.  
\v 3 \w Y|strong="H3068"\w* amaba \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*, \w porque|strong="H3588"\w* \w lo|strong="H1931"\w* \w había|strong="H3588"\w* tenido \w en|strong="H3588"\w* \w su|strong="H1931"\w* vejez; \w y|strong="H3588"\w* \w le|strong="H1931"\w* \w hizo|strong="H6213"\w* una túnica \w de|strong="H3588"\w* diversos colores.  
\v 4 \w Y|strong="H3068"\w* \w viendo|strong="H7200"\w* sus hermanos \w que|strong="H3588"\w* \w su|strong="H3588"\w* padre \w lo|strong="H3808"\w* amaba \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos, le \w aborrecían|strong="H8130"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* le \w podían|strong="H3201"\w* \w hablar|strong="H1696"\w* \w pacíficamente|strong="H7965"\w*.   
\p
\v 5 \w Y|strong="H3068"\w* \w soñó|strong="H2492"\w* \w José|strong="H3130"\w* un \w sueño|strong="H2472"\w*, y lo \w contó|strong="H5046"\w* \w a|strong="H3068"\w* sus hermanos; y ellos llegaron \w a|strong="H3068"\w* aborrecerle \w más|strong="H5750"\w* \w todavía|strong="H5750"\w*.  
\v 6 \w Y|strong="H3068"\w* él les dijo: «\w Oíd|strong="H8085"\w* \w ahora|strong="H4994"\w* \w este|strong="H2088"\w* sueño \w que|strong="H4994"\w* he soñado:  
\v 7 he \w aquí|strong="H2009"\w* \w que|strong="H1571"\w* atábamos gavillas \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w campo|strong="H7704"\w*, \w y|strong="H1571"\w* \w mi|strong="H2009"\w* gavilla se levantaba \w y|strong="H1571"\w* \w estaba|strong="H5324"\w* derecha, \w y|strong="H1571"\w* vuestras gavillas \w estaban|strong="H5324"\w* \w alrededor|strong="H5437"\w* \w y|strong="H1571"\w* se inclinaban ante \w la|strong="H1571"\w* mía».   
\p
\v 8 \w Le|strong="H5921"\w* respondieron sus hermanos: «¿\w Reinarás|strong="H4427"\w* tú \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w o|strong="H3068"\w* \w te|strong="H5921"\w* enseñorearás \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*?» \w Y|strong="H3068"\w* \w le|strong="H5921"\w* \w aborrecieron|strong="H8130"\w* \w aún|strong="H5750"\w* \w más|strong="H5750"\w* \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* sus \w sueños|strong="H2472"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* sus \w palabras|strong="H1697"\w*.  
\v 9 \w Soñó|strong="H2492"\w* \w aun|strong="H5750"\w* \w otro|strong="H5750"\w* \w sueño|strong="H2472"\w*, y lo \w contó|strong="H5608"\w* \w a|strong="H3068"\w* sus hermanos, diciendo: «He \w aquí|strong="H2009"\w* que he soñado \w otro|strong="H5750"\w* \w sueño|strong="H2472"\w*, y he \w aquí|strong="H2009"\w* que el \w sol|strong="H8121"\w* y la \w luna|strong="H3394"\w* y once \w estrellas|strong="H3556"\w* se inclinaban \w a|strong="H3068"\w* \w mí|strong="H2009"\w*».  
\v 10 \w Y|strong="H3068"\w* \w lo|strong="H4100"\w* \w contó|strong="H5608"\w* \w a|strong="H3068"\w* su padre y \w a|strong="H3068"\w* sus hermanos; y su padre le reprendió, y le dijo: «¿\w Qué|strong="H4100"\w* \w sueño|strong="H2472"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* \w que|strong="H4100"\w* \w soñaste|strong="H2492"\w*? ¿Acaso vendremos yo y tu madre y tus hermanos \w a|strong="H3068"\w* postrarnos en tierra ante ti?»  
\v 11 \w Y|strong="H3068"\w* sus hermanos le \w tenían|strong="H8104"\w* \w envidia|strong="H7065"\w*, mas su padre meditaba en \w esto|strong="H1697"\w*.   
\p
\v 12 \w Y|strong="H3068"\w* \w fueron|strong="H3212"\w* sus hermanos \w a|strong="H3068"\w* apacentar las \w ovejas|strong="H6629"\w* de su padre \w en|strong="H3212"\w* Siquem.  
\v 13 \w Y|strong="H3068"\w* dijo \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*: «Tus hermanos \w apacientan|strong="H7462"\w* las ovejas \w en|strong="H3212"\w* Siquem; \w ven|strong="H3212"\w*, y te \w enviaré|strong="H7971"\w* \w a|strong="H3068"\w* ellos». \w Y|strong="H3068"\w* él respondió: «\w Aquí|strong="H2009"\w* estoy».   
\p
\v 14 \w E|strong="H3068"\w* \w Israel|strong="H4994"\w* le dijo: «\w Ve|strong="H3212"\w* \w ahora|strong="H4994"\w*, \w mira|strong="H7200"\w* cómo están tus hermanos y cómo están las \w ovejas|strong="H6629"\w*, y tráeme la \w respuesta|strong="H1697"\w*». \w Y|strong="H3068"\w* \w lo|strong="H1697"\w* \w envió|strong="H7971"\w* del \w valle|strong="H6010"\w* \w de|strong="H1697"\w* \w Hebrón|strong="H2275"\w*, y \w llegó|strong="H3212"\w* \w a|strong="H3068"\w* Siquem.  
\v 15 \w Y|strong="H3068"\w* le \w halló|strong="H4672"\w* un hombre, andando él errante \w por|strong="H4100"\w* el \w campo|strong="H7704"\w*, y le \w preguntó|strong="H7592"\w* aquel hombre, diciendo: «¿\w Qué|strong="H4100"\w* \w buscas|strong="H1245"\w*?»   
\p
\v 16 José respondió: «\w Busco|strong="H1245"\w* \w a|strong="H3068"\w* mis hermanos; te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me muestres dónde están apacentando».   
\p
\v 17 \w Aquel|strong="H2088"\w* hombre respondió: “\w Ya|strong="H3068"\w* se han \w ido|strong="H3212"\w* \w de|strong="H3588"\w* \w aquí|strong="H2088"\w*; \w y|strong="H3588"\w* \w yo|strong="H3588"\w* les \w oí|strong="H8085"\w* \w decir|strong="H8085"\w*: ‘\w Vamos|strong="H3212"\w* \w a|strong="H3068"\w* Dotán’”. \w Entonces|strong="H3588"\w* \w José|strong="H3130"\w* \w fue|strong="H3212"\w* tras sus hermanos, \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w halló|strong="H4672"\w* \w en|strong="H3588"\w* Dotán.  
\v 18 Cuando ellos \w lo|strong="H7350"\w* \w vieron|strong="H7200"\w* de \w lejos|strong="H7350"\w*, \w antes|strong="H2962"\w* que llegara \w cerca|strong="H7126"\w* de ellos, conspiraron contra él para \w matarle|strong="H4191"\w*.  
\v 19 \w Y|strong="H3068"\w* dijeron el uno al otro: “He \w aquí|strong="H2009"\w* viene el soñador.  
\v 20 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w venid|strong="H3212"\w*, y matémosle y echémosle \w en|strong="H3212"\w* una cisterna, y diremos: ‘Alguna \w mala|strong="H7451"\w* \w bestia|strong="H2416"\w* \w lo|strong="H4100"\w* devoró’; y \w veremos|strong="H7200"\w* \w qué|strong="H4100"\w* \w será|strong="H1961"\w* \w de|strong="H7451"\w* sus \w sueños|strong="H2472"\w*”.   
\p
\v 21 Cuando \w Rubén|strong="H7205"\w* \w oyó|strong="H8085"\w* esto, \w lo|strong="H3808"\w* \w libró|strong="H5337"\w* de sus \w manos|strong="H3027"\w*, y dijo: «\w No|strong="H3808"\w* \w lo|strong="H3808"\w* matemos».  
\v 22 \w Y|strong="H3068"\w* les dijo \w Rubén|strong="H7205"\w*: «\w No|strong="H3808"\w* \w derraméis|strong="H8210"\w* \w sangre|strong="H1818"\w*; \w echadlo|strong="H7993"\w* en \w esta|strong="H2088"\w* cisterna \w que|strong="H3808"\w* \w está|strong="H2088"\w* en el \w desierto|strong="H4057"\w*, y \w no|strong="H3808"\w* \w pongáis|strong="H7971"\w* \w mano|strong="H3027"\w* en él»; \w por|strong="H4616"\w* librarlo \w así|strong="H2088"\w* \w de|strong="H1818"\w* sus \w manos|strong="H3027"\w*, \w para|strong="H4616"\w* hacerlo \w volver|strong="H7725"\w* \w a|strong="H3068"\w* su padre.  
\v 23 \w Sucedió|strong="H1961"\w*, \w pues|strong="H1961"\w*, \w que|strong="H5921"\w* \w cuando|strong="H1961"\w* llegó \w José|strong="H3130"\w* \w a|strong="H3068"\w* sus hermanos, \w ellos|strong="H5921"\w* quitaron \w a|strong="H3068"\w* \w José|strong="H3130"\w* su túnica, \w la|strong="H5921"\w* túnica \w de|strong="H5921"\w* colores \w que|strong="H5921"\w* \w tenía|strong="H1961"\w* \w sobre|strong="H5921"\w* \w sí|strong="H1961"\w*;  
\v 24 y le \w tomaron|strong="H3947"\w* y le echaron en la cisterna; pero la cisterna estaba \w vacía|strong="H7386"\w*, no había en ella \w agua|strong="H4325"\w*.   
\p
\v 25 \w Y|strong="H3068"\w* se \w sentaron|strong="H3427"\w* \w a|strong="H3068"\w* comer \w pan|strong="H3899"\w*; y \w alzando|strong="H5375"\w* \w los|strong="H3427"\w* \w ojos|strong="H5869"\w* \w miraron|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* una compañía \w de|strong="H5869"\w* ismaelitas que venía \w de|strong="H5869"\w* \w Galaad|strong="H1568"\w*, y sus \w camellos|strong="H1581"\w* \w traían|strong="H5375"\w* \w aromas|strong="H5219"\w*, \w bálsamo|strong="H6875"\w* y mirra, \w e|strong="H3068"\w* \w iban|strong="H1980"\w* \w a|strong="H3068"\w* \w llevarlo|strong="H5375"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.  
\v 26 \w Entonces|strong="H3588"\w* \w Judá|strong="H3063"\w* dijo \w a|strong="H3068"\w* sus hermanos: «¿\w Qué|strong="H3588"\w* \w provecho|strong="H1215"\w* hay \w en|strong="H3588"\w* \w que|strong="H3588"\w* \w matemos|strong="H2026"\w* \w a|strong="H3068"\w* nuestro hermano \w y|strong="H3588"\w* encubramos \w su|strong="H3588"\w* \w sangre|strong="H1818"\w*?  
\v 27 \w Venid|strong="H3212"\w*, \w y|strong="H3588"\w* vendámosle \w a|strong="H3068"\w* \w los|strong="H1931"\w* ismaelitas, \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w sea|strong="H1961"\w* nuestra \w mano|strong="H3027"\w* \w sobre|strong="H1961"\w* \w él|strong="H1931"\w*; \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w es|strong="H1931"\w* nuestro hermano, nuestra propia \w carne|strong="H1320"\w*». \w Y|strong="H3068"\w* \w sus|strong="H1931"\w* hermanos vinieron \w a|strong="H3068"\w* acuerdo.  
\v 28 \w Y|strong="H3068"\w* cuando \w pasaban|strong="H5674"\w* los \w mercaderes|strong="H5503"\w* madianitas, \w sacaron|strong="H4900"\w* \w ellos|strong="H4480"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w de|strong="H4480"\w* la cisterna, y le trajeron \w arriba|strong="H4480"\w*, y le \w vendieron|strong="H4376"\w* \w a|strong="H3068"\w* los ismaelitas \w por|strong="H4480"\w* \w veinte|strong="H6242"\w* piezas \w de|strong="H4480"\w* \w plata|strong="H3701"\w*. \w Y|strong="H3068"\w* llevaron \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 29 Después \w Rubén|strong="H7205"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* la cisterna, y no halló \w a|strong="H3068"\w* \w José|strong="H3130"\w* dentro, y \w rasgó|strong="H7167"\w* sus vestidos.  
\v 30 \w Y|strong="H3068"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* sus hermanos, y dijo: «El joven no parece; y yo, ¿adónde iré yo?»  
\v 31 Entonces \w tomaron|strong="H3947"\w* ellos la túnica \w de|strong="H1818"\w* \w José|strong="H3130"\w*, y degollaron un cabrito \w de|strong="H1818"\w* las \w cabras|strong="H5795"\w*, y tiñeron la túnica con la \w sangre|strong="H1818"\w*;  
\v 32 y \w enviaron|strong="H7971"\w* \w la|strong="H1931"\w* túnica \w de|strong="H1121"\w* colores y \w la|strong="H1931"\w* trajeron \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre, y dijeron: «\w Esto|strong="H2063"\w* hemos \w hallado|strong="H4672"\w*; \w reconoce|strong="H5234"\w* \w ahora|strong="H4994"\w* \w si|strong="H3808"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* túnica \w de|strong="H1121"\w* tu \w hijo|strong="H1121"\w*, \w o|strong="H3068"\w* \w no|strong="H3808"\w*».   
\p
\v 33 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* la reconoció, y dijo: «La túnica \w de|strong="H1121"\w* mi \w hijo|strong="H1121"\w* es; alguna \w mala|strong="H7451"\w* \w bestia|strong="H2416"\w* lo devoró; \w José|strong="H3130"\w* ha sido despedazado».  
\v 34 \w Entonces|strong="H3117"\w* \w Jacob|strong="H3290"\w* \w rasgó|strong="H7167"\w* sus \w vestidos|strong="H8071"\w*, \w y|strong="H5921"\w* \w puso|strong="H7760"\w* cilicio \w sobre|strong="H5921"\w* sus \w lomos|strong="H4975"\w*, \w y|strong="H5921"\w* guardó luto \w por|strong="H5921"\w* su \w hijo|strong="H1121"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*.  
\v 35 \w Y|strong="H3068"\w* se \w levantaron|strong="H6965"\w* \w todos|strong="H3605"\w* sus \w hijos|strong="H1121"\w* \w y|strong="H3588"\w* \w todas|strong="H3605"\w* sus \w hijas|strong="H1323"\w* \w para|strong="H3588"\w* consolarlo; \w mas|strong="H3588"\w* \w él|strong="H3588"\w* \w no|strong="H3985"\w* quiso recibir \w consuelo|strong="H5162"\w*, \w y|strong="H3588"\w* dijo: «\w Descenderé|strong="H3381"\w* enlutado \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w* hasta \w el|strong="H3588"\w* Seol».\f + \fr 37:35 \ft El Seol es el lugar de los muertos.\f* \w Y|strong="H3068"\w* \w lo|strong="H3605"\w* \w lloró|strong="H1058"\w* \w su|strong="H3588"\w* padre.  
\v 36 \w Y|strong="H3068"\w* los madianitas lo \w vendieron|strong="H4376"\w* en \w Egipto|strong="H4714"\w* \w a|strong="H3068"\w* Potifar, oficial \w de|strong="H8269"\w* \w Faraón|strong="H6547"\w*, \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* la guardia.   
\c 38
\p
\v 1 \w Aconteció|strong="H1961"\w* \w en|strong="H5704"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w*, \w que|strong="H1931"\w* \w Judá|strong="H3063"\w* \w se|strong="H1961"\w* apartó \w de|strong="H5704"\w* \w sus|strong="H1931"\w* hermanos, \w y|strong="H5704"\w* \w se|strong="H1961"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* un varón adulamita \w que|strong="H1931"\w* \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* \w Hira|strong="H2437"\w*.  
\v 2 \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* \w allí|strong="H8033"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* de un varón \w cananeo|strong="H3669"\w*, el cual se \w llamaba|strong="H8034"\w* \w Súa|strong="H7770"\w*; y la \w tomó|strong="H3947"\w*, y se llegó \w a|strong="H3068"\w* \w ella|strong="H8033"\w*.  
\v 3 \w Y|strong="H3068"\w* ella \w concibió|strong="H2029"\w*, y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*; y \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Er|strong="H6147"\w*.  
\v 4 \w Concibió|strong="H2029"\w* \w otra|strong="H5750"\w* vez, y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, y \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* Onán.  
\v 5 \w Y|strong="H3068"\w* \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* concebir, y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, y \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Selá|strong="H7956"\w*. \w Y|strong="H3068"\w* \w estaba|strong="H1961"\w* \w en|strong="H5750"\w* Quezib \w cuando|strong="H1961"\w* lo dio \w a|strong="H3068"\w* luz.  
\v 6 \w Y|strong="H3068"\w* \w Judá|strong="H3063"\w* \w tomó|strong="H3947"\w* mujer para su \w primogénito|strong="H1060"\w* \w Er|strong="H6147"\w*, la cual se \w llamaba|strong="H8034"\w* Tamar.  
\v 7 \w Y|strong="H3068"\w* \w Er|strong="H6147"\w*, el \w primogénito|strong="H1060"\w* \w de|strong="H5869"\w* \w Judá|strong="H3063"\w*, \w fue|strong="H1961"\w* \w malo|strong="H7451"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Yahvé, y \w le|strong="H5869"\w* \w quitó|strong="H4191"\w* Yahvé la vida.  
\v 8 Entonces \w Judá|strong="H3063"\w* dijo \w a|strong="H3068"\w* Onán: «Llégate \w a|strong="H3068"\w* la mujer de tu hermano, y cumple con ella el deber de cuñado, y levanta \w descendencia|strong="H2233"\w* \w a|strong="H3068"\w* tu hermano».  
\v 9 \w Y|strong="H3068"\w* \w sabiendo|strong="H3045"\w* Onán \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w descendencia|strong="H2233"\w* \w no|strong="H3808"\w* \w había|strong="H1961"\w* \w de|strong="H3588"\w* ser suya, \w sucedía|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w se|strong="H3045"\w* llegaba \w a|strong="H3068"\w* \w la|strong="H3588"\w* mujer \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermano, \w vertía|strong="H7843"\w* \w su|strong="H3588"\w* semen \w en|strong="H3588"\w* tierra, \w por|strong="H3588"\w* \w no|strong="H3808"\w* \w dar|strong="H5414"\w* \w descendencia|strong="H2233"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* hermano.  
\v 10 \w Y|strong="H3068"\w* desagradó en los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Yahvé \w lo|strong="H6213"\w* \w que|strong="H1571"\w* \w hacía|strong="H6213"\w*, \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w él|strong="H6213"\w* \w también|strong="H1571"\w* \w le|strong="H5869"\w* \w quitó|strong="H4191"\w* \w la|strong="H1571"\w* vida.  
