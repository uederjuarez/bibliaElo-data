\mt2 Libro primero de Moisés,  
\mt3 comúnmente llamado  
\mt1 Génesis  
\c 1
\p
\v 1 En el \w principio|strong="H7225"\w*, Dios\f + \fr 1:1 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f* creó los \w cielos|strong="H8064"\w* y la tierra.  
\v 2 \w La|strong="H5921"\w* tierra \w estaba|strong="H1961"\w* sin forma \w y|strong="H5921"\w* vacía. \w Las|strong="H5921"\w* \w tinieblas|strong="H2822"\w* cubrían \w la|strong="H5921"\w* superficie \w del|strong="H5921"\w* \w abismo|strong="H8415"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Dios \w se|strong="H1961"\w* cernía \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*.   
\p
\v 3 Dios dijo: «Hágase la luz», y la luz \w se|strong="H1961"\w* hizo.  
\v 4 Dios \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* luz era \w buena|strong="H2896"\w* \w y|strong="H3588"\w* separó Dios \w la|strong="H3588"\w* luz \w de|strong="H3588"\w* las \w tinieblas|strong="H2822"\w*.  
\v 5 Dios \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* la luz «\w día|strong="H3117"\w*», y \w a|strong="H3068"\w* las \w tinieblas|strong="H2822"\w* las \w llamó|strong="H7121"\w* «\w noche|strong="H3915"\w*». \w Y|strong="H3068"\w* \w hubo|strong="H1961"\w* \w tarde|strong="H6153"\w* y \w hubo|strong="H1961"\w* \w mañana|strong="H1242"\w*: el primer \w día|strong="H3117"\w*.   
\p
\v 6 Dios dijo: «\w Haya|strong="H1961"\w* un firmamento \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H4325"\w* las \w aguas|strong="H4325"\w*, y \w que|strong="H4325"\w* separe las \w aguas|strong="H4325"\w* \w de|strong="H4325"\w* las \w aguas|strong="H4325"\w*».  
\v 7 Dios \w hizo|strong="H6213"\w* \w el|strong="H5921"\w* firmamento \w y|strong="H5921"\w* separó \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w que|strong="H5921"\w* \w estaban|strong="H1961"\w* \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* firmamento \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w que|strong="H5921"\w* \w estaban|strong="H1961"\w* \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w del|strong="H5921"\w* firmamento; \w y|strong="H5921"\w* \w así|strong="H3651"\w* \w fue|strong="H1961"\w*.  
\v 8 Dios \w llamó|strong="H7121"\w* al firmamento «\w cielo|strong="H8064"\w*». \w Y|strong="H3068"\w* \w hubo|strong="H1961"\w* \w tarde|strong="H6153"\w* y \w hubo|strong="H1961"\w* \w mañana|strong="H1242"\w*: el \w segundo|strong="H8145"\w* \w día|strong="H3117"\w*.   
\p
\v 9 Dios dijo: «\w Que|strong="H4325"\w* las \w aguas|strong="H4325"\w* \w que|strong="H4325"\w* \w están|strong="H1961"\w* \w bajo|strong="H8478"\w* el \w cielo|strong="H8064"\w* \w se|strong="H1961"\w* reúnan \w en|strong="H8478"\w* un solo \w lugar|strong="H4725"\w*, y \w que|strong="H4325"\w* \w aparezca|strong="H7200"\w* lo seco»; y \w así|strong="H3651"\w* \w fue|strong="H1961"\w*.  
\v 10 Dios \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* lo seco «\w tierra|strong="H3004"\w*», \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* reunión \w de|strong="H3588"\w* las \w aguas|strong="H4325"\w* \w la|strong="H3588"\w* \w llamó|strong="H7121"\w* «\w mares|strong="H3220"\w*». \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* Dios \w que|strong="H3588"\w* era \w bueno|strong="H2896"\w*.  
\v 11 Dijo Dios: «\w Produzca|strong="H1877"\w* \w la|strong="H5921"\w* tierra \w hierba|strong="H6212"\w* verde, plantas \w que|strong="H5921"\w* den semilla \w y|strong="H5921"\w* \w árboles|strong="H6086"\w* frutales \w que|strong="H5921"\w* den \w fruto|strong="H6529"\w* \w según|strong="H5921"\w* su \w especie|strong="H4327"\w*, cuya semilla \w esté|strong="H1961"\w* \w en|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra»; \w y|strong="H5921"\w* \w así|strong="H3651"\w* \w fue|strong="H1961"\w*.  
\v 12 \w La|strong="H3588"\w* tierra produjo \w hierba|strong="H6212"\w* verde, plantas \w que|strong="H3588"\w* dan semilla según \w su|strong="H3588"\w* \w especie|strong="H4327"\w*, \w y|strong="H3588"\w* \w árboles|strong="H6086"\w* \w que|strong="H3588"\w* dan \w fruto|strong="H6529"\w*, cuya semilla está \w en|strong="H3588"\w* ellos, según \w su|strong="H3588"\w* \w especie|strong="H4327"\w*; \w y|strong="H3588"\w* \w vio|strong="H7200"\w* Dios \w que|strong="H3588"\w* era \w bueno|strong="H2896"\w*.  
\v 13 \w Y|strong="H3068"\w* \w hubo|strong="H1961"\w* \w tarde|strong="H6153"\w* y \w hubo|strong="H1961"\w* \w mañana|strong="H1242"\w*: el tercer \w día|strong="H3117"\w*.   
\p
\v 14 Dios dijo: «\w Haya|strong="H1961"\w* \w lumbreras|strong="H3974"\w* en el firmamento del \w cielo|strong="H8064"\w* \w para|strong="H1961"\w* separar el \w día|strong="H3117"\w* de la \w noche|strong="H3915"\w*; y sirvan de señales \w para|strong="H1961"\w* las estaciones, \w para|strong="H1961"\w* \w los|strong="H1961"\w* \w días|strong="H3117"\w* y \w los|strong="H1961"\w* \w años|strong="H8141"\w*;  
\v 15 \w y|strong="H5921"\w* \w sean|strong="H1961"\w* \w por|strong="H5921"\w* \w lumbreras|strong="H3974"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* firmamento \w del|strong="H5921"\w* \w cielo|strong="H8064"\w* \w para|strong="H5921"\w* alumbrar \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra»; \w y|strong="H5921"\w* \w así|strong="H3651"\w* \w fue|strong="H1961"\w*.  
\v 16 Dios \w hizo|strong="H6213"\w* las \w dos|strong="H8147"\w* \w grandes|strong="H1419"\w* \w lumbreras|strong="H3974"\w*: la lumbrera \w mayor|strong="H1419"\w* para \w que|strong="H3117"\w* dominase en \w el|strong="H6213"\w* \w día|strong="H3117"\w*, y la lumbrera \w menor|strong="H6996"\w* para \w que|strong="H3117"\w* dominase en la \w noche|strong="H3915"\w*. \w Hizo|strong="H6213"\w* también las \w estrellas|strong="H3556"\w*.  
\v 17 Dios \w las|strong="H5921"\w* \w puso|strong="H5414"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* firmamento \w del|strong="H5921"\w* \w cielo|strong="H8064"\w* \w para|strong="H5921"\w* alumbrar \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra,  
\v 18 \w y|strong="H3588"\w* \w para|strong="H3588"\w* dominar \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w noche|strong="H3915"\w*, \w y|strong="H3588"\w* \w para|strong="H3588"\w* separar \w la|strong="H3588"\w* luz \w de|strong="H3588"\w* las \w tinieblas|strong="H2822"\w*. \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* Dios \w que|strong="H3588"\w* era \w bueno|strong="H2896"\w*.  
\v 19 \w Y|strong="H3068"\w* \w hubo|strong="H1961"\w* \w tarde|strong="H6153"\w* y \w hubo|strong="H1961"\w* \w mañana|strong="H1242"\w*: el \w cuarto|strong="H7243"\w* \w día|strong="H3117"\w*.   
\p
\v 20 Dios dijo: «\w Produzcan|strong="H8318"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w seres|strong="H5315"\w* \w vivientes|strong="H2416"\w* \w en|strong="H5921"\w* abundancia, \w y|strong="H5921"\w* vuelen \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w en|strong="H5921"\w* \w el|strong="H5921"\w* ancho firmamento \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*».  
\v 21 Dios creó \w los|strong="H3605"\w* \w grandes|strong="H1419"\w* monstruos marinos \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w ser|strong="H5315"\w* \w viviente|strong="H2416"\w* \w que|strong="H3588"\w* se mueve, \w que|strong="H3588"\w* las \w aguas|strong="H4325"\w* \w produjeron|strong="H8317"\w* según \w su|strong="H3588"\w* \w especie|strong="H4327"\w*, \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w ave|strong="H5775"\w* \w alada|strong="H3671"\w* según \w su|strong="H3588"\w* \w especie|strong="H4327"\w*. \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* Dios \w que|strong="H3588"\w* era \w bueno|strong="H2896"\w*.  
\v 22 Dios los \w bendijo|strong="H1288"\w*, diciendo: «Sed fecundos y multiplicaos, y llenad las \w aguas|strong="H4325"\w* \w de|strong="H4325"\w* los \w mares|strong="H3220"\w*, y multiplíquense las \w aves|strong="H5775"\w* en la tierra».  
\v 23 \w Y|strong="H3068"\w* \w hubo|strong="H1961"\w* \w tarde|strong="H6153"\w* y \w hubo|strong="H1961"\w* \w mañana|strong="H1242"\w*: el \w quinto|strong="H2549"\w* \w día|strong="H3117"\w*.   
\p
\v 24 Dios dijo: «\w Produzca|strong="H3318"\w* la tierra \w seres|strong="H5315"\w* \w vivientes|strong="H2416"\w* según su \w especie|strong="H4327"\w*: ganado, \w reptiles|strong="H7431"\w* y \w animales|strong="H2416"\w* de la tierra según su \w especie|strong="H4327"\w*»; y \w así|strong="H3651"\w* \w fue|strong="H1961"\w*.  
\v 25 Dios \w hizo|strong="H6213"\w* \w los|strong="H3605"\w* \w animales|strong="H2416"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra según \w su|strong="H3588"\w* \w especie|strong="H4327"\w*, \w el|strong="H3588"\w* ganado según \w su|strong="H3588"\w* \w especie|strong="H4327"\w* \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* se arrastra sobre \w la|strong="H3588"\w* tierra según \w su|strong="H3588"\w* \w especie|strong="H4327"\w*. \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* Dios \w que|strong="H3588"\w* era \w bueno|strong="H2896"\w*.   
\p
\v 26 Dios dijo: «\w Hagamos|strong="H6213"\w* \w al|strong="H5921"\w* hombre \w a|strong="H3068"\w* nuestra \w imagen|strong="H6754"\w*, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* nuestra \w semejanza|strong="H1823"\w*; \w y|strong="H5921"\w* tenga dominio \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w peces|strong="H1710"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w*, \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* ganado, \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w reptil|strong="H7431"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* arrastra \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra».  
\v 27 Dios creó al hombre \w a|strong="H3068"\w* su \w imagen|strong="H6754"\w*, \w a|strong="H3068"\w* \w imagen|strong="H6754"\w* de Dios lo creó; \w varón|strong="H2145"\w* y mujer los creó.  
\v 28 Dios \w los|strong="H5921"\w* \w bendijo|strong="H1288"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* dijo: «Sed fecundos \w y|strong="H5921"\w* multiplicaos; llenad \w la|strong="H5921"\w* tierra \w y|strong="H5921"\w* sometedla; dominad \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w peces|strong="H1710"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w*, \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* ser \w viviente|strong="H2416"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* mueve \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra».  
\v 29 Dios dijo: “\w Mirad|strong="H2009"\w*,\f + \fr 1:29 \ft «He aquí», de «הִנֵּה», significa mirar, fijarse, observar, ver o contemplar. Se utiliza a menudo como interjección.\f* \w os|strong="H5921"\w* he \w dado|strong="H5414"\w* \w toda|strong="H3605"\w* planta \w que|strong="H5921"\w* \w da|strong="H5414"\w* semilla, \w que|strong="H5921"\w* \w está|strong="H1961"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w hay|strong="H1961"\w* \w fruto|strong="H6529"\w* \w que|strong="H5921"\w* \w da|strong="H5414"\w* semilla. \w Os|strong="H5921"\w* \w servirán|strong="H1961"\w* \w de|strong="H5921"\w* alimento.  
\v 30 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w bestia|strong="H2416"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w ave|strong="H5775"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* arrastra \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w en|strong="H5921"\w* \w que|strong="H5921"\w* \w hay|strong="H1961"\w* \w vida|strong="H5315"\w*, \w toda|strong="H3605"\w* \w hierba|strong="H6212"\w* \w verde|strong="H3418"\w* \w les|strong="H5921"\w* \w servirá|strong="H1961"\w* \w de|strong="H5921"\w* alimento”; \w y|strong="H5921"\w* \w así|strong="H3651"\w* \w fue|strong="H1961"\w*.   
\p
\v 31 Dios \w vio|strong="H7200"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3117"\w* \w había|strong="H1961"\w* \w hecho|strong="H6213"\w*, y he \w aquí|strong="H2009"\w* \w que|strong="H3117"\w* \w era|strong="H1961"\w* \w muy|strong="H3966"\w* \w bueno|strong="H2896"\w*. \w Y|strong="H3068"\w* \w hubo|strong="H1961"\w* \w tarde|strong="H6153"\w* y \w hubo|strong="H1961"\w* \w mañana|strong="H1242"\w*: \w el|strong="H3605"\w* \w sexto|strong="H8345"\w* \w día|strong="H3117"\w*.   
\c 2
\p
\v 1 Así fueron terminados \w los|strong="H3605"\w* \w cielos|strong="H8064"\w* y \w la|strong="H3605"\w* tierra y \w todo|strong="H3605"\w* su ornato.  
\v 2 \w Y|strong="H3068"\w* \w acabó|strong="H3615"\w* Dios en \w el|strong="H3605"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* \w que|strong="H3117"\w* \w hizo|strong="H6213"\w*; y descansó \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w séptimo|strong="H7637"\w* de \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* \w que|strong="H3117"\w* \w había|strong="H6213"\w* realizado.  
\v 3 \w Y|strong="H3068"\w* \w bendijo|strong="H1288"\w* Dios \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w séptimo|strong="H7637"\w* \w y|strong="H3588"\w* \w lo|strong="H6213"\w* \w santificó|strong="H6942"\w*, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w él|strong="H3588"\w* descansó \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* \w que|strong="H3588"\w* \w había|strong="H6942"\w* creado \w y|strong="H3588"\w* \w hecho|strong="H6213"\w*.   
\p
\v 4 Éstos son los orígenes de los \w cielos|strong="H8064"\w* y de la tierra \w cuando|strong="H3117"\w* fueron creados, \w el|strong="H6213"\w* \w día|strong="H3117"\w* en \w que|strong="H3117"\w* Yahvé \w Dios|strong="H3068"\w* \w hizo|strong="H6213"\w* la tierra y los \w cielos|strong="H8064"\w*.  
\v 5 \w Y|strong="H3068"\w* \w toda|strong="H3605"\w* \w planta|strong="H7880"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w antes|strong="H3588"\w* \w que|strong="H3588"\w* \w fuese|strong="H1961"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w hierba|strong="H6212"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w antes|strong="H3588"\w* \w que|strong="H3588"\w* germinase; \w porque|strong="H3588"\w* Yahvé \w Dios|strong="H3068"\w* \w aún|strong="H2962"\w* \w no|strong="H3808"\w* \w había|strong="H1961"\w* \w hecho|strong="H1961"\w* llover \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w ni|strong="H3808"\w* \w había|strong="H1961"\w* hombre \w para|strong="H5921"\w* \w que|strong="H3588"\w* labrase \w el|strong="H5921"\w* suelo,  
\v 6 sino \w que|strong="H4480"\w* \w subía|strong="H5927"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* tierra un vapor \w que|strong="H4480"\w* regaba \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w faz|strong="H6440"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* tierra.  
\v 7 \w Formó|strong="H3335"\w*, \w pues|strong="H1961"\w*, Yahvé \w Dios|strong="H3068"\w* \w al|strong="H4480"\w* hombre \w del|strong="H4480"\w* \w polvo|strong="H6083"\w* \w de|strong="H4480"\w* la \w tierra|strong="H6083"\w*, y \w sopló|strong="H5397"\w* \w en|strong="H4480"\w* su nariz aliento \w de|strong="H4480"\w* \w vida|strong="H5315"\w*, y \w fue|strong="H1961"\w* el hombre un \w ser|strong="H5315"\w* \w viviente|strong="H2416"\w*.  
