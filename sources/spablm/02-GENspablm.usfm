\v 8 \w Entonces|strong="H3588"\w* Abram dijo \w a|strong="H3068"\w* \w Lot|strong="H3876"\w*: «\w No|strong="H3588"\w* \w haya|strong="H1961"\w* \w ahora|strong="H4994"\w* \w altercado|strong="H4808"\w* \w entre|strong="H3588"\w* nosotros dos, \w entre|strong="H3588"\w* mis pastores \w y|strong="H3588"\w* \w los|strong="H1961"\w* tuyos, \w porque|strong="H3588"\w* \w somos|strong="H1961"\w* hermanos.  
\v 9 ¿\w No|strong="H3808"\w* \w está|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*? \w Yo|strong="H4994"\w* \w os|strong="H5921"\w* \w ruego|strong="H4994"\w* \w que|strong="H3808"\w* \w os|strong="H5921"\w* apartéis \w de|strong="H5921"\w* \w mí|strong="H5921"\w*. \w Si|strong="H3808"\w* fueres \w a|strong="H3068"\w* \w la|strong="H5921"\w* mano \w izquierda|strong="H8040"\w*, \w yo|strong="H4994"\w* iré \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w*; \w y|strong="H5921"\w* \w si|strong="H3808"\w* tú \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w*, \w yo|strong="H4994"\w* iré \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w*».   
\p
\v 10 \w Y|strong="H3068"\w* \w alzó|strong="H5375"\w* \w Lot|strong="H3876"\w* sus \w ojos|strong="H5869"\w*, \w y|strong="H3588"\w* \w vio|strong="H7200"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* llanura del \w Jordán|strong="H3383"\w*, \w que|strong="H3588"\w* \w toda|strong="H3605"\w* \w ella|strong="H3605"\w* era \w de|strong="H3588"\w* riego, \w antes|strong="H6440"\w* \w que|strong="H3588"\w* \w destruyese|strong="H7843"\w* Yahvé \w a|strong="H3068"\w* \w Sodoma|strong="H5467"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w Gomorra|strong="H6017"\w*, \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w huerto|strong="H1588"\w* \w de|strong="H3588"\w* Yahvé, \w como|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* dirección \w de|strong="H3588"\w* \w Zoar|strong="H6820"\w*.  
\v 11 Entonces \w Lot|strong="H3876"\w* escogió \w para|strong="H5921"\w* \w sí|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* llanura \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w*; \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w fue|strong="H5265"\w* \w Lot|strong="H3876"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w oriente|strong="H6924"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* apartaron \w el|strong="H5921"\w* uno \w del|strong="H5921"\w* otro.  
\v 12 Abram acampó \w en|strong="H5704"\w* la tierra \w de|strong="H5704"\w* \w Canaán|strong="H3667"\w*, \w en|strong="H5704"\w* tanto \w que|strong="H5704"\w* \w Lot|strong="H3876"\w* \w habitó|strong="H3427"\w* \w en|strong="H5704"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5704"\w* la llanura, \w y|strong="H5704"\w* fue poniendo sus tiendas \w hasta|strong="H5704"\w* \w Sodoma|strong="H5467"\w*.  
\v 13 Mas los hombres \w de|strong="H7451"\w* \w Sodoma|strong="H5467"\w* eran \w malos|strong="H7451"\w* y \w pecadores|strong="H2400"\w* contra Yahvé en \w gran|strong="H3966"\w* \w manera|strong="H3966"\w*.   
