\c 20
\p
\v 1 Abraham \w partió|strong="H5265"\w* de \w allí|strong="H8033"\w* \w hacia|strong="H5045"\w* la tierra del Négueb, y \w habitó|strong="H3427"\w* \w entre|strong="H8033"\w* \w Cades|strong="H6946"\w* y \w Shur|strong="H7793"\w*; y \w moró|strong="H3427"\w* como forastero en \w Gerar|strong="H1642"\w*.  
\v 2 \w Y|strong="H3068"\w* dijo Abraham de \w Sara|strong="H8283"\w* \w su|strong="H1931"\w* mujer: «\w Es|strong="H1931"\w* mi hermana». \w Y|strong="H3068"\w* Abimelec, \w rey|strong="H4428"\w* de \w Gerar|strong="H1642"\w*, \w envió|strong="H7971"\w* y \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Sara|strong="H8283"\w*.  
\v 3 Pero Dios vino \w a|strong="H3068"\w* Abimelec \w en|strong="H5921"\w* \w sueños|strong="H2472"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w*, \w y|strong="H5921"\w* \w le|strong="H1931"\w* dijo: «He \w aquí|strong="H2009"\w*, \w muerto|strong="H4191"\w* \w eres|strong="H1931"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H1931"\w* mujer \w que|strong="H1931"\w* \w has|strong="H4191"\w* \w tomado|strong="H3947"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* mujer \w casada|strong="H1167"\w*».   
\p
\v 4 \w Mas|strong="H1571"\w* Abimelec \w no|strong="H3808"\w* \w se|strong="H3808"\w* había llegado \w a|strong="H3068"\w* ella, \w y|strong="H1571"\w* dijo: “Señor, ¿\w matarás|strong="H2026"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* \w nación|strong="H1471"\w* \w justa|strong="H6662"\w*?  
\v 5 ¿\w No|strong="H3808"\w* me dijo \w él|strong="H1931"\w*: ‘\w Es|strong="H1931"\w* mi hermana’? \w Y|strong="H3068"\w* \w ella|strong="H1931"\w* \w también|strong="H1571"\w* dijo: ‘\w Es|strong="H1931"\w* mi hermano’. \w Con|strong="H1571"\w* sencillez de mi \w corazón|strong="H3824"\w* \w y|strong="H1571"\w* \w con|strong="H1571"\w* limpieza de mis \w manos|strong="H3709"\w* he \w hecho|strong="H6213"\w* \w esto|strong="H2063"\w*”.   
\p
\v 6 \w Y|strong="H3068"\w* \w le|strong="H5921"\w* dijo Dios \w en|strong="H5921"\w* \w sueños|strong="H2472"\w*: «\w Yo|strong="H3588"\w* \w también|strong="H1571"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w con|strong="H5921"\w* \w integridad|strong="H8537"\w* \w de|strong="H5921"\w* \w tu|strong="H6213"\w* \w corazón|strong="H3824"\w* \w has|strong="H5414"\w* \w hecho|strong="H6213"\w* \w esto|strong="H2063"\w*; \w y|strong="H1571"\w* \w yo|strong="H3588"\w* \w también|strong="H1571"\w* \w te|strong="H5921"\w* detuve \w de|strong="H5921"\w* \w pecar|strong="H2398"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H1571"\w* \w así|strong="H3651"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* permití \w que|strong="H3588"\w* \w la|strong="H5921"\w* tocases.  
\v 7 \w Ahora|strong="H6258"\w*, \w pues|strong="H3588"\w*, devuelve \w la|strong="H1931"\w* mujer \w a|strong="H3068"\w* \w su|strong="H1931"\w* marido; \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w profeta|strong="H5030"\w*, \w y|strong="H3588"\w* \w orará|strong="H6419"\w* \w por|strong="H3588"\w* ti, \w y|strong="H3588"\w* \w vivirás|strong="H2421"\w*. \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w no|strong="H3588"\w* \w la|strong="H1931"\w* devolvieres, \w sabe|strong="H3045"\w* \w que|strong="H3588"\w* \w de|strong="H3588"\w* \w cierto|strong="H3588"\w* \w morirás|strong="H4191"\w* tú, \w y|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* tuyos».   
\p
\v 8 Entonces Abimelec se levantó \w de|strong="H1697"\w* \w mañana|strong="H1242"\w*, y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w siervos|strong="H5650"\w*, y \w dijo|strong="H1696"\w* \w todas|strong="H3605"\w* estas \w palabras|strong="H1697"\w* en \w los|strong="H3605"\w* oídos \w de|strong="H1697"\w* \w ellos|strong="H3605"\w*; y \w temieron|strong="H3372"\w* \w los|strong="H3605"\w* varones en \w gran|strong="H3966"\w* \w manera|strong="H1697"\w*.  
\v 9 \w Después|strong="H5921"\w* \w llamó|strong="H7121"\w* Abimelec \w a|strong="H3068"\w* Abraham, \w y|strong="H3588"\w* \w le|strong="H5921"\w* dijo: «¿\w Qué|strong="H3588"\w* \w nos|strong="H5921"\w* has \w hecho|strong="H6213"\w*? ¿\w En|strong="H5921"\w* \w qué|strong="H3588"\w* \w pequé|strong="H2398"\w* \w yo|strong="H3588"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w que|strong="H3588"\w* has atraído \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w reino|strong="H4467"\w* un \w pecado|strong="H2401"\w* tan \w grande|strong="H1419"\w*? \w Lo|strong="H4100"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* debiste \w hacer|strong="H6213"\w* has \w hecho|strong="H6213"\w* \w conmigo|strong="H6213"\w*».  
\v 10 Dijo \w también|strong="H2088"\w* Abimelec \w a|strong="H3068"\w* Abraham: «¿\w Qué|strong="H3588"\w* \w veías|strong="H7200"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w hicieses|strong="H6213"\w* \w esto|strong="H2088"\w*?»   
\p
\v 11 \w Y|strong="H3068"\w* Abraham respondió: “\w Porque|strong="H3588"\w* dije \w para|strong="H5921"\w* \w mí|strong="H5921"\w*: \w Ciertamente|strong="H3588"\w* \w no|strong="H3588"\w* hay \w temor|strong="H3374"\w* \w de|strong="H5921"\w* Dios \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, \w y|strong="H3588"\w* \w me|strong="H5921"\w* \w matarán|strong="H2026"\w* \w por|strong="H5921"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* mujer.  
\v 12 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* verdad \w también|strong="H1571"\w* \w es|strong="H1931"\w* \w mi|strong="H1961"\w* hermana, \w hija|strong="H1323"\w* de \w mi|strong="H1961"\w* padre, \w mas|strong="H1571"\w* \w no|strong="H3808"\w* \w hija|strong="H1323"\w* de \w mi|strong="H1961"\w* madre, \w y|strong="H1571"\w* \w la|strong="H1931"\w* tomé por mujer.  
\v 13 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1931"\w* \w cuando|strong="H1961"\w* Dios me \w hizo|strong="H6213"\w* \w errar|strong="H8582"\w* de \w la|strong="H1931"\w* \w casa|strong="H1004"\w* de \w mi|strong="H1961"\w* padre, \w yo|strong="H6213"\w* \w le|strong="H1931"\w* dije \w a|strong="H3068"\w* \w ella|strong="H1931"\w*: ‘\w Esta|strong="H2088"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* merced \w que|strong="H1931"\w* \w tú|strong="H6213"\w* \w harás|strong="H6213"\w* \w conmigo|strong="H6213"\w*: \w que|strong="H1931"\w* en \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w lugares|strong="H4725"\w* adonde lleguemos, digas de \w mí|strong="H1961"\w*: «\w Mi|strong="H1961"\w* hermano \w es|strong="H1931"\w*»’”.   
\p
\v 14 \w Entonces|strong="H7725"\w* Abimelec \w tomó|strong="H3947"\w* \w ovejas|strong="H6629"\w* \w y|strong="H1241"\w* \w vacas|strong="H1241"\w*, \w y|strong="H1241"\w* \w siervos|strong="H5650"\w* \w y|strong="H1241"\w* \w siervas|strong="H8198"\w*, \w y|strong="H1241"\w* se los \w dio|strong="H5414"\w* \w a|strong="H3068"\w* Abraham, \w y|strong="H1241"\w* le devolvió \w a|strong="H3068"\w* \w Sara|strong="H8283"\w* su mujer.  
\v 15 \w Y|strong="H3068"\w* dijo Abimelec: «He \w aquí|strong="H2009"\w* \w mi|strong="H2009"\w* tierra \w está|strong="H3427"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti; \w habita|strong="H3427"\w* donde \w bien|strong="H2896"\w* \w te|strong="H5869"\w* parezca».  
\v 16 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w Sara|strong="H8283"\w* dijo: «He \w aquí|strong="H2009"\w* he \w dado|strong="H5414"\w* mil \w monedas|strong="H3701"\w* \w de|strong="H5414"\w* \w plata|strong="H3701"\w* \w a|strong="H3068"\w* tu hermano; \w mira|strong="H2009"\w* \w que|strong="H1931"\w* \w él|strong="H1931"\w* \w te|strong="H5869"\w* \w es|strong="H1931"\w* \w por|strong="H5414"\w* velo \w de|strong="H5414"\w* \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w para|strong="H5414"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H1931"\w* \w están|strong="H2009"\w* contigo, y \w para|strong="H5414"\w* con \w todos|strong="H3605"\w*; \w así|strong="H1931"\w* quedas justificada».   
\p
\v 17 Entonces Abraham \w oró|strong="H6419"\w* \w a|strong="H3068"\w* Dios; y Dios \w sanó|strong="H7495"\w* \w a|strong="H3068"\w* Abimelec y \w a|strong="H3068"\w* su mujer, y \w a|strong="H3068"\w* sus siervas, y dieron \w a|strong="H3068"\w* luz.  
\v 18 \w Porque|strong="H3588"\w* Yahvé \w había|strong="H3588"\w* \w cerrado|strong="H6113"\w* \w del|strong="H5921"\w* \w todo|strong="H3605"\w* \w toda|strong="H3605"\w* \w matriz|strong="H7358"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Abimelec, \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w Sara|strong="H8283"\w* mujer \w de|strong="H5921"\w* Abraham.   
\c 21
\p
\v 1 Yahvé \w visitó|strong="H6485"\w* \w a|strong="H3068"\w* \w Sara|strong="H8283"\w* como \w había|strong="H6213"\w* \w dicho|strong="H1696"\w*, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* Yahvé con \w Sara|strong="H8283"\w* como \w había|strong="H6213"\w* \w hablado|strong="H1696"\w*.  
\v 2 \w Y|strong="H3068"\w* \w concibió|strong="H2029"\w* \w Sara|strong="H8283"\w*, y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* Abraham en su vejez, en \w el|strong="H1121"\w* \w tiempo|strong="H4150"\w* \w señalado|strong="H4150"\w* \w que|strong="H1121"\w* Dios le había \w dicho|strong="H1696"\w*.  
\v 3 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* Abraham \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su \w hijo|strong="H1121"\w* \w que|strong="H1121"\w* le \w nació|strong="H3205"\w*, \w que|strong="H1121"\w* le dio \w a|strong="H3068"\w* luz \w Sara|strong="H8283"\w*, \w Isaac|strong="H3327"\w*. \f + \fr 21:3 \ft Isaac significa «Él se ríe».\f*  
\v 4 \w Y|strong="H3068"\w* circuncidó Abraham \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w* \w de|strong="H1121"\w* \w ocho|strong="H8083"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w edad|strong="H3117"\w*, como Dios le había \w mandado|strong="H6680"\w*.  
\v 5 \w Y|strong="H3068"\w* \w era|strong="H8141"\w* Abraham \w de|strong="H1121"\w* \w cien|strong="H3967"\w* \w años|strong="H8141"\w* cuando le \w nació|strong="H3205"\w* \w Isaac|strong="H3327"\w* su \w hijo|strong="H1121"\w*.  
\v 6 Entonces dijo \w Sara|strong="H8283"\w*: «Dios me ha \w hecho|strong="H6213"\w* reír; \w cualquiera|strong="H3605"\w* \w que|strong="H3605"\w* \w lo|strong="H6213"\w* \w oyere|strong="H8085"\w*, se reirá \w conmigo|strong="H6213"\w*».  
