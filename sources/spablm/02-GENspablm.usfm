\p
\v 12 \w Y|strong="H3068"\w* dijeron \w los|strong="H1121"\w* varones \w a|strong="H3068"\w* \w Lot|strong="H3876"\w*: «¿\w Tienes|strong="H4480"\w* \w aquí|strong="H6311"\w* \w alguno|strong="H3605"\w* \w más|strong="H5750"\w*? \w Yernos|strong="H2860"\w*, y tus \w hijos|strong="H1121"\w* y tus \w hijas|strong="H1323"\w*, y \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H4480"\w* \w tienes|strong="H4480"\w* \w en|strong="H4480"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w*, sácalo \w de|strong="H4480"\w* este \w lugar|strong="H4725"\w*;  
\v 13 \w porque|strong="H3588"\w* \w vamos|strong="H7843"\w* \w a|strong="H3068"\w* \w destruir|strong="H7843"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w el|strong="H3588"\w* \w clamor|strong="H6818"\w* \w contra|strong="H6440"\w* ellos ha subido \w de|strong="H3588"\w* punto \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Yahvé; \w por|strong="H3588"\w* tanto, Yahvé nos ha \w enviado|strong="H7971"\w* \w para|strong="H3588"\w* \w destruirlo|strong="H7843"\w*».   
\p
\v 14 \w Entonces|strong="H3588"\w* \w salió|strong="H3318"\w* \w Lot|strong="H3876"\w* \w y|strong="H3588"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* sus \w yernos|strong="H2860"\w*, \w los|strong="H1961"\w* \w que|strong="H3588"\w* \w habían|strong="H1961"\w* \w de|strong="H4480"\w* \w tomar|strong="H3947"\w* sus \w hijas|strong="H1323"\w*, \w y|strong="H3588"\w* les \w dijo|strong="H1696"\w*: «\w Levantaos|strong="H6965"\w*, \w salid|strong="H3318"\w* \w de|strong="H4480"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*; \w porque|strong="H3588"\w* Yahvé \w va|strong="H3068"\w* \w a|strong="H3068"\w* \w destruir|strong="H7843"\w* \w esta|strong="H2088"\w* \w ciudad|strong="H5892"\w*». \w Mas|strong="H3588"\w* \w pareció|strong="H5869"\w* \w a|strong="H3068"\w* sus \w yernos|strong="H2860"\w* \w como|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* burlaba.  
\v 15 \w Y|strong="H3068"\w* al \w rayar|strong="H5927"\w* el alba, los \w ángeles|strong="H4397"\w* daban prisa \w a|strong="H3068"\w* \w Lot|strong="H3876"\w*, diciendo: «\w Levántate|strong="H6965"\w*, \w toma|strong="H3947"\w* tu mujer, y tus \w dos|strong="H8147"\w* \w hijas|strong="H1323"\w* \w que|strong="H6435"\w* \w se|strong="H6435"\w* \w hallan|strong="H4672"\w* aquí, para \w que|strong="H6435"\w* \w no|strong="H6435"\w* \w perezcas|strong="H5595"\w* en el castigo de la \w ciudad|strong="H5892"\w*».  
\v 16 \w Y|strong="H3068"\w* deteniéndose \w él|strong="H5921"\w*, \w los|strong="H5921"\w* varones \w asieron|strong="H2388"\w* \w de|strong="H5921"\w* su \w mano|strong="H3027"\w*, \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* su mujer \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* sus \w dos|strong="H8147"\w* \w hijas|strong="H1323"\w*, \w según|strong="H5921"\w* \w la|strong="H5921"\w* misericordia \w de|strong="H5921"\w* Yahvé \w para|strong="H5921"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w*; \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w sacaron|strong="H3318"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w pusieron|strong="H3240"\w* \w fuera|strong="H2351"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.  
\v 17 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* \w los|strong="H5921"\w* hubieron llevado \w fuera|strong="H2351"\w*, dijeron: «\w Escapa|strong="H4422"\w* \w por|strong="H5921"\w* tu \w vida|strong="H5315"\w*; \w no|strong="H6435"\w* \w mires|strong="H5027"\w* tras \w ti|strong="H5921"\w*, \w ni|strong="H6435"\w* \w pares|strong="H5975"\w* \w en|strong="H5921"\w* \w toda|strong="H3605"\w* \w esta|strong="H1961"\w* llanura; \w escapa|strong="H4422"\w* \w al|strong="H5921"\w* \w monte|strong="H2022"\w*, \w no|strong="H6435"\w* \w sea|strong="H1961"\w* \w que|strong="H5921"\w* \w perezcas|strong="H5595"\w*».   
\p
\v 18 Pero \w Lot|strong="H3876"\w* les dijo: «No, os \w ruego|strong="H4994"\w*, señor mío.  
\v 19 He \w aquí|strong="H2009"\w* \w ahora|strong="H4994"\w* \w ha|strong="H3808"\w* \w hallado|strong="H4672"\w* \w tu|strong="H6213"\w* \w siervo|strong="H5650"\w* \w gracia|strong="H2580"\w* en tus \w ojos|strong="H5869"\w*, y \w has|strong="H4191"\w* \w engrandecido|strong="H1431"\w* \w tu|strong="H6213"\w* \w misericordia|strong="H2617"\w* \w que|strong="H3808"\w* \w has|strong="H4191"\w* \w hecho|strong="H6213"\w* \w conmigo|strong="H6213"\w* dándome la \w vida|strong="H5315"\w*; \w mas|strong="H4191"\w* \w yo|strong="H5315"\w* \w no|strong="H3808"\w* \w podré|strong="H3201"\w* \w escapar|strong="H4422"\w* al \w monte|strong="H2022"\w*, \w no|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3808"\w* me alcance \w el|strong="H6213"\w* \w mal|strong="H7451"\w*, y \w muera|strong="H4191"\w*.  
\v 20 He \w aquí|strong="H2009"\w* \w ahora|strong="H4994"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w está|strong="H2063"\w* \w cerca|strong="H7138"\w* para huir \w allá|strong="H8033"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w pequeña|strong="H4705"\w*; dejadme \w escapar|strong="H4422"\w* \w ahora|strong="H4994"\w* \w allá|strong="H8033"\w* (¿\w no|strong="H3808"\w* \w es|strong="H1931"\w* \w ella|strong="H1931"\w* \w pequeña|strong="H4705"\w*?), y salvaré \w mi|strong="H2009"\w* \w vida|strong="H5315"\w*».   
\p
\v 21 \w Y|strong="H3068"\w* le respondió: «He \w aquí|strong="H2088"\w* he recibido \w también|strong="H1571"\w* tu súplica sobre \w esto|strong="H2088"\w*, \w y|strong="H1571"\w* \w no|strong="H1115"\w* \w destruiré|strong="H2015"\w* \w la|strong="H1571"\w* \w ciudad|strong="H5892"\w* \w de|strong="H6440"\w* \w que|strong="H1571"\w* has \w hablado|strong="H1696"\w*.  
\v 22 Date prisa, \w escápate|strong="H4422"\w* \w allá|strong="H8033"\w*; \w porque|strong="H3588"\w* \w nada|strong="H3808"\w* \w podré|strong="H3201"\w* \w hacer|strong="H6213"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* hayas llegado \w allí|strong="H8033"\w*». \w Por|strong="H5921"\w* \w esto|strong="H3651"\w* \w fue|strong="H3808"\w* \w llamado|strong="H8034"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w Zoar|strong="H6820"\w*.   
\p
\v 23 \w El|strong="H5921"\w* \w sol|strong="H8121"\w* \w salía|strong="H3318"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, cuando \w Lot|strong="H3876"\w* llegó \w a|strong="H3068"\w* \w Zoar|strong="H6820"\w*.  
\v 24 Entonces Yahvé hizo llover \w sobre|strong="H5921"\w* \w Sodoma|strong="H5467"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w Gomorra|strong="H6017"\w* \w azufre|strong="H1614"\w* \w y|strong="H5921"\w* fuego \w de|strong="H4480"\w* parte \w de|strong="H4480"\w* Yahvé \w desde|strong="H4480"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*;  
