\v 5 \w Y|strong="H3068"\w* \w fueron|strong="H1961"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w que|strong="H3117"\w* \w vivió|strong="H3117"\w* Adán \w novecientos|strong="H8672"\w* \w treinta|strong="H7970"\w* \w años|strong="H8141"\w*; y \w murió|strong="H4191"\w*.   
\p
