\v 14 \w Y|strong="H3068"\w* Yahvé dijo \w a|strong="H3068"\w* Abram, después \w que|strong="H4480"\w* \w Lot|strong="H3876"\w* \w se|strong="H4480"\w* \w apartó|strong="H6504"\w* \w de|strong="H4480"\w* \w él|strong="H5973"\w*: «\w Alzad|strong="H5375"\w* \w ahora|strong="H4994"\w* vuestros \w ojos|strong="H5869"\w* y \w mirad|strong="H7200"\w* \w desde|strong="H4480"\w* \w el|strong="H5973"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* estáis \w hacia|strong="H4480"\w* \w el|strong="H5973"\w* \w norte|strong="H6828"\w* y \w el|strong="H5973"\w* sur, y \w al|strong="H4480"\w* \w oriente|strong="H6924"\w* y \w al|strong="H4480"\w* occidente.  
\v 15 \w Porque|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w que|strong="H3588"\w* \w veis|strong="H7200"\w*, \w os|strong="H5704"\w* \w la|strong="H3605"\w* \w daré|strong="H5414"\w* \w a|strong="H3068"\w* vos \w y|strong="H3588"\w* \w a|strong="H3068"\w* vuestra \w descendencia|strong="H2233"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.  
\v 16 \w Y|strong="H3068"\w* \w haré|strong="H7760"\w* vuestra \w descendencia|strong="H2233"\w* \w como|strong="H1571"\w* \w el|strong="H1571"\w* \w polvo|strong="H6083"\w* de \w la|strong="H1571"\w* \w tierra|strong="H6083"\w*; \w que|strong="H1571"\w* \w si|strong="H1571"\w* alguno \w puede|strong="H3201"\w* contar \w el|strong="H1571"\w* \w polvo|strong="H6083"\w* de \w la|strong="H1571"\w* \w tierra|strong="H6083"\w*, \w también|strong="H1571"\w* vuestra \w descendencia|strong="H2233"\w* será contada.  
\v 17 \w Levantaos|strong="H6965"\w*, \w recorred|strong="H1980"\w* \w la|strong="H3588"\w* tierra \w por|strong="H3588"\w* \w su|strong="H3588"\w* longitud \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w anchura|strong="H7341"\w*; \w porque|strong="H3588"\w* \w a|strong="H3068"\w* vos os \w la|strong="H3588"\w* he \w de|strong="H3588"\w* \w dar|strong="H5414"\w*».   
\p
\v 18 Abram, pues, removiendo su tienda, vino y \w moró|strong="H3427"\w* en \w el|strong="H3427"\w* encinar de \w Mamre|strong="H4471"\w*, que \w está|strong="H3427"\w* en \w Hebrón|strong="H2275"\w*, y \w edificó|strong="H1129"\w* \w allí|strong="H8033"\w* \w altar|strong="H4196"\w* \w a|strong="H3068"\w* Yahvé.   
\c 14
\p
\v 1 \w Aconteció|strong="H1961"\w* en \w los|strong="H1961"\w* \w días|strong="H3117"\w* de Amrafel \w rey|strong="H4428"\w* de Sinar, Arioc \w rey|strong="H4428"\w* de Elasar, Quedorlaomer \w rey|strong="H4428"\w* de \w Elam|strong="H5867"\w*, y Tidal \w rey|strong="H4428"\w* de Goim,  
\v 2 \w que|strong="H1931"\w* \w éstos|strong="H1931"\w* \w hicieron|strong="H6213"\w* \w guerra|strong="H4421"\w* contra \w Bera|strong="H1298"\w* \w rey|strong="H4428"\w* de \w Sodoma|strong="H5467"\w*, contra Birsa \w rey|strong="H4428"\w* de \w Gomorra|strong="H6017"\w*, contra Sinab \w rey|strong="H4428"\w* de Adma, contra Semeber \w rey|strong="H4428"\w* de Zeboim, y contra \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de \w Bela|strong="H1106"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w Zoar|strong="H6820"\w*.  
\v 3 \w Todos|strong="H3605"\w* \w éstos|strong="H1931"\w* \w se|strong="H1931"\w* juntaron en \w el|strong="H1931"\w* \w valle|strong="H6010"\w* de Sidim, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w Mar|strong="H3220"\w* \w Salado|strong="H4417"\w*.  
\v 4 \w Doce|strong="H8147"\w* \w años|strong="H8141"\w* habían servido \w a|strong="H3068"\w* Quedorlaomer, y en el decimotercero se rebelaron.  
\v 5 \w Y|strong="H3068"\w* \w en|strong="H5221"\w* el \w año|strong="H8141"\w* \w decimocuarto|strong="H6240"\w* vino Quedorlaomer, y los \w reyes|strong="H4428"\w* que estaban con él, y derrotaron \w a|strong="H3068"\w* los refaítas \w en|strong="H5221"\w* Astarot Karnaim, \w a|strong="H3068"\w* los zuzitas \w en|strong="H5221"\w* Ham, \w a|strong="H3068"\w* los emitas \w en|strong="H5221"\w* Save-quiriataim,  
\v 6 \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* horeos \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w de|strong="H5921"\w* \w Seir|strong="H8165"\w*, \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* llanura \w de|strong="H5921"\w* Parán, \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w desierto|strong="H4057"\w*.  
\v 7 \w Y|strong="H3068"\w* \w volvieron|strong="H7725"\w* \w y|strong="H1571"\w* vinieron \w a|strong="H3068"\w* En-mispat, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Cades|strong="H6946"\w*, \w y|strong="H1571"\w* devastaron \w todo|strong="H3605"\w* \w el|strong="H1931"\w* país de \w los|strong="H3427"\w* amalecitas, \w y|strong="H1571"\w* \w también|strong="H1571"\w* al amorreo \w que|strong="H1931"\w* \w habitaba|strong="H3427"\w* \w en|strong="H5221"\w* Hazezón-tamar.  
\v 8 \w Y|strong="H3068"\w* \w salieron|strong="H3318"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de \w Sodoma|strong="H5467"\w*, \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de \w Gomorra|strong="H6017"\w*, \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de Adma, \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de Zeboim y \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de \w Bela|strong="H1106"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Zoar|strong="H6820"\w*, y \w ordenaron|strong="H6186"\w* \w batalla|strong="H4421"\w* contra \w ellos|strong="H1931"\w* \w en|strong="H3318"\w* \w el|strong="H1931"\w* \w valle|strong="H6010"\w* de Sidim;  
\v 9 esto es, contra Quedorlaomer \w rey|strong="H4428"\w* \w de|strong="H2568"\w* \w Elam|strong="H5867"\w*, Tidal \w rey|strong="H4428"\w* \w de|strong="H2568"\w* Goim, Amrafel \w rey|strong="H4428"\w* \w de|strong="H2568"\w* Sinar y Arioc \w rey|strong="H4428"\w* \w de|strong="H2568"\w* Elasar; cuatro \w reyes|strong="H4428"\w* contra \w cinco|strong="H2568"\w*.  
\v 10 \w Y|strong="H3068"\w* \w el|strong="H5307"\w* \w valle|strong="H6010"\w* de Sidim estaba lleno de pozos de asfalto; y cuando \w huyeron|strong="H5127"\w* \w el|strong="H5307"\w* \w rey|strong="H4428"\w* de \w Sodoma|strong="H5467"\w* y \w el|strong="H5307"\w* de \w Gomorra|strong="H6017"\w*, \w cayeron|strong="H5307"\w* \w allí|strong="H8033"\w*; y los demás \w huyeron|strong="H5127"\w* \w al|strong="H4428"\w* \w monte|strong="H2022"\w*.  
\v 11 \w Y|strong="H3068"\w* \w tomaron|strong="H3947"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w riqueza|strong="H7399"\w* de \w Sodoma|strong="H5467"\w* y de \w Gomorra|strong="H6017"\w*, y \w todas|strong="H3605"\w* sus provisiones, y se \w fueron|strong="H3212"\w*.  
\v 12 \w Tomaron|strong="H3947"\w* también \w a|strong="H3068"\w* \w Lot|strong="H3876"\w*, \w hijo|strong="H1121"\w* del hermano \w de|strong="H1121"\w* Abram, \w que|strong="H1931"\w* \w moraba|strong="H3427"\w* \w en|strong="H3212"\w* \w Sodoma|strong="H5467"\w*, y \w sus|strong="H1931"\w* bienes, y \w se|strong="H1931"\w* \w fueron|strong="H3212"\w*.   
\p
\v 13 \w Y|strong="H3068"\w* vino uno de \w los|strong="H1992"\w* \w que|strong="H1931"\w* escaparon, y \w lo|strong="H1931"\w* \w anunció|strong="H5046"\w* \w a|strong="H3068"\w* Abram \w el|strong="H1931"\w* \w hebreo|strong="H5680"\w*, \w que|strong="H1931"\w* habitaba en \w el|strong="H1931"\w* encinar de \w Mamre|strong="H4471"\w* \w el|strong="H1931"\w* amorreo, hermano de Escol y hermano de \w Aner|strong="H6063"\w*, \w los|strong="H1992"\w* cuales eran aliados de Abram.  
\v 14 \w Oyó|strong="H8085"\w* Abram \w que|strong="H3588"\w* \w su|strong="H3588"\w* pariente \w estaba|strong="H1004"\w* \w cautivo|strong="H7617"\w*, \w y|strong="H3588"\w* armó \w a|strong="H3068"\w* sus criados, \w los|strong="H7291"\w* \w nacidos|strong="H3211"\w* \w en|strong="H5704"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*, \w trescientos|strong="H7969"\w* \w dieciocho|strong="H8083"\w*, \w y|strong="H3588"\w* \w los|strong="H7291"\w* \w siguió|strong="H7291"\w* \w hasta|strong="H5704"\w* \w Dan|strong="H1835"\w*.  
\v 15 \w Y|strong="H3068"\w* cayó \w sobre|strong="H5921"\w* \w ellos|strong="H1931"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w*, \w él|strong="H1931"\w* \w y|strong="H5921"\w* \w sus|strong="H1931"\w* \w siervos|strong="H5650"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* atacó, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w siguió|strong="H7291"\w* \w hasta|strong="H5704"\w* Hoba \w al|strong="H5921"\w* norte \w de|strong="H5921"\w* \w Damasco|strong="H1834"\w*.  
\v 16 \w Y|strong="H3068"\w* recobró \w todos|strong="H3605"\w* \w los|strong="H3605"\w* bienes, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* \w Lot|strong="H3876"\w* su pariente \w y|strong="H1571"\w* sus bienes, \w y|strong="H1571"\w* \w a|strong="H3068"\w* las mujeres \w y|strong="H1571"\w* \w demás|strong="H1571"\w* \w gente|strong="H5971"\w*.   
\p
\v 17 Cuando \w volvía|strong="H7725"\w* de \w la|strong="H1931"\w* derrota de Quedorlaomer y de \w los|strong="H1931"\w* \w reyes|strong="H4428"\w* \w que|strong="H1931"\w* con \w él|strong="H1931"\w* estaban, \w salió|strong="H3318"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de \w Sodoma|strong="H5467"\w* \w a|strong="H3068"\w* recibirlo \w al|strong="H4428"\w* \w valle|strong="H6010"\w* de Save, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w Valle|strong="H6010"\w* del \w Rey|strong="H4428"\w*.  
\v 18 Entonces Melquisedec, \w rey|strong="H4428"\w* de Salem y \w sacerdote|strong="H3548"\w* del Dios \w Altísimo|strong="H5945"\w*, \w sacó|strong="H3318"\w* \w pan|strong="H3899"\w* y \w vino|strong="H3196"\w*;  
\v 19 y le \w bendijo|strong="H1288"\w*, diciendo: «\w Bendito|strong="H1288"\w* sea Abram del Dios \w Altísimo|strong="H5945"\w*, \w poseedor|strong="H7069"\w* de los \w cielos|strong="H8064"\w* y de la tierra;  
\v 20 y \w bendito|strong="H1288"\w* sea \w el|strong="H3605"\w* Dios \w Altísimo|strong="H5945"\w*, \w que|strong="H3605"\w* \w entregó|strong="H5414"\w* tus \w enemigos|strong="H6862"\w* en tu \w mano|strong="H3027"\w*». \w Y|strong="H3068"\w* le \w dio|strong="H5414"\w* Abram \w los|strong="H3605"\w* diezmos \w de|strong="H5414"\w* \w todo|strong="H3605"\w*.   
\p
\v 21 Entonces el \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Sodoma|strong="H5467"\w* dijo \w a|strong="H3068"\w* Abram: «\w Dame|strong="H5414"\w* las \w personas|strong="H5315"\w*, y \w toma|strong="H3947"\w* \w para|strong="H5414"\w* ti los bienes».  
\v 22 \w Y|strong="H3068"\w* respondió Abram \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de \w Sodoma|strong="H5467"\w*: “He alzado mi \w mano|strong="H3027"\w* \w a|strong="H3068"\w* Yahvé \w Dios|strong="H3068"\w* \w Altísimo|strong="H5945"\w*, \w poseedor|strong="H7069"\w* de los \w cielos|strong="H8064"\w* y de la tierra,  
\v 23 \w que|strong="H3808"\w* \w desde|strong="H5704"\w* un hilo \w hasta|strong="H5704"\w* una correa \w de|strong="H5704"\w* calzado, \w nada|strong="H3808"\w* \w tomaré|strong="H3947"\w* \w de|strong="H5704"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* es tuyo, \w para|strong="H5704"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* digas: ‘Yo \w enriquecí|strong="H6238"\w* \w a|strong="H3068"\w* Abram’;  
\v 24 \w excepto|strong="H7535"\w* \w solamente|strong="H7535"\w* \w lo|strong="H1992"\w* \w que|strong="H1992"\w* comieron \w los|strong="H1992"\w* jóvenes, y la \w parte|strong="H2506"\w* de \w los|strong="H1992"\w* varones \w que|strong="H1992"\w* \w fueron|strong="H1980"\w* conmigo, \w Aner|strong="H6063"\w*, Escol y \w Mamre|strong="H4471"\w*, \w los|strong="H1992"\w* cuales \w tomarán|strong="H3947"\w* \w su|strong="H1992"\w* \w parte|strong="H2506"\w*”.   
\c 15
\p
\v 1 \w Después|strong="H1961"\w* \w de|strong="H1697"\w* estas \w cosas|strong="H1697"\w*, \w vino|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* Abram en \w visión|strong="H4236"\w*, diciendo: «\w No|strong="H1961"\w* \w temas|strong="H3372"\w*, Abram; yo \w soy|strong="H1961"\w* tu \w escudo|strong="H4043"\w*, y tu galardón \w será|strong="H1961"\w* \w sobremanera|strong="H3966"\w* \w grande|strong="H7235"\w*».   
\p
\v 2 \w Y|strong="H3068"\w* respondió Abram: “Señor\f + \fr 15:2 \ft La palabra traducida «Señor» es «Adonai».\f* Yahvé, ¿\w qué|strong="H4100"\w* me \w darás|strong="H5414"\w*, \w siendo|strong="H1931"\w* \w así|strong="H1931"\w* \w que|strong="H4100"\w* \w ando|strong="H1980"\w* \w sin|strong="H6185"\w* \w hijo|strong="H1121"\w*, y \w el|strong="H1931"\w* \w mayordomo|strong="H1004"\w* \w de|strong="H1121"\w* mi \w casa|strong="H1004"\w* \w es|strong="H1931"\w* \w ese|strong="H1931"\w* damasceno Eliezer?”  
\v 3 Dijo también Abram: «He \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* me \w has|strong="H5414"\w* \w dado|strong="H5414"\w* \w prole|strong="H2233"\w*, y he \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w será|strong="H5414"\w* \w mi|strong="H2009"\w* \w heredero|strong="H3423"\w* un esclavo nacido en \w mi|strong="H2009"\w* \w casa|strong="H1004"\w*».   
\p
\v 4 \w Luego|strong="H3318"\w* vino \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé, diciendo: «\w No|strong="H3808"\w* \w te|strong="H3588"\w* \w heredará|strong="H3423"\w* \w éste|strong="H2088"\w*, \w sino|strong="H3588"\w* un hijo tuyo, \w que|strong="H3588"\w* \w saldrá|strong="H3318"\w* \w de|strong="H3588"\w* tus \w entrañas|strong="H4578"\w*, \w será|strong="H1931"\w* \w el|strong="H1931"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* herede».  
\v 5 \w Y|strong="H3068"\w* lo \w sacó|strong="H3318"\w* \w fuera|strong="H2351"\w*, \w y|strong="H3541"\w* le dijo: «\w Mira|strong="H5027"\w* \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w cielos|strong="H8064"\w*, \w y|strong="H3541"\w* \w cuenta|strong="H5608"\w* las \w estrellas|strong="H3556"\w*, \w si|strong="H4994"\w* las \w puedes|strong="H3201"\w* \w contar|strong="H5608"\w*». \w Y|strong="H3068"\w* le dijo: «\w Así|strong="H3541"\w* \w será|strong="H1961"\w* tu \w descendencia|strong="H2233"\w*».  
\v 6 \w Y|strong="H3068"\w* creyó \w a|strong="H3068"\w* Yahvé, y le fue contado por \w justicia|strong="H6666"\w*.  
\v 7 \w Y|strong="H3068"\w* le dijo: «Yo soy Yahvé, que te \w saqué|strong="H3318"\w* \w de|strong="H5414"\w* Ur \w de|strong="H5414"\w* los \w caldeos|strong="H3778"\w*, \w para|strong="H5414"\w* darte \w a|strong="H3068"\w* heredar \w esta|strong="H2063"\w* tierra».   
\p
\v 8 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: «Señor Yahvé, ¿\w en|strong="H3588"\w* \w qué|strong="H3588"\w* \w conoceré|strong="H3045"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* he \w de|strong="H3588"\w* heredar?»   
\p
\v 9 \w Y|strong="H3068"\w* le dijo: «Tráeme una \w becerra|strong="H5697"\w* de tres años, y una \w cabra|strong="H5795"\w* de tres años, y un carnero de tres años, una tórtola también, y un palomino».  
\v 10 \w Y|strong="H3068"\w* \w él|strong="H3605"\w* le trajo \w todo|strong="H3605"\w* esto, y \w los|strong="H3605"\w* \w partió|strong="H1335"\w* \w por|strong="H5414"\w* \w el|strong="H3605"\w* \w medio|strong="H8432"\w*, y \w puso|strong="H5414"\w* \w cada|strong="H3605"\w* \w mitad|strong="H8432"\w* una enfrente \w de|strong="H5414"\w* \w la|strong="H3605"\w* otra; \w mas|strong="H7453"\w* \w no|strong="H3808"\w* \w partió|strong="H1335"\w* las aves.  
\v 11 \w Y|strong="H3068"\w* \w descendían|strong="H3381"\w* \w aves|strong="H5861"\w* \w de|strong="H5921"\w* rapiña \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w cuerpos|strong="H6297"\w* \w muertos|strong="H6297"\w*, \w y|strong="H5921"\w* Abram \w las|strong="H5921"\w* ahuyentaba.   
\p
\v 12 \w Mas|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* caída \w del|strong="H5921"\w* \w sol|strong="H8121"\w* \w sobrecogió|strong="H5307"\w* \w el|strong="H5921"\w* sueño \w a|strong="H3068"\w* Abram, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* temor \w de|strong="H5921"\w* una \w grande|strong="H1419"\w* oscuridad \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 13 \w Entonces|strong="H3588"\w* Yahvé dijo \w a|strong="H3068"\w* Abram: «\w Ten|strong="H3045"\w* \w por|strong="H3588"\w* \w cierto|strong="H3588"\w* \w que|strong="H3588"\w* tu \w descendencia|strong="H2233"\w* morará \w en|strong="H3588"\w* tierra \w ajena|strong="H3808"\w*, \w y|strong="H3588"\w* \w será|strong="H1961"\w* esclava allí, \w y|strong="H3588"\w* \w será|strong="H1961"\w* oprimida cuatrocientos \w años|strong="H8141"\w*.  
\v 14 \w Mas|strong="H1571"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* \w nación|strong="H1471"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* cual \w servirán|strong="H5647"\w*, \w juzgaré|strong="H1777"\w* yo; \w y|strong="H1571"\w* después de \w esto|strong="H3651"\w* \w saldrán|strong="H3318"\w* \w con|strong="H1571"\w* \w gran|strong="H1419"\w* \w riqueza|strong="H7399"\w*.  
\v 15 \w Y|strong="H3068"\w* tú irás \w a|strong="H3068"\w* tus padres \w en|strong="H6912"\w* \w paz|strong="H7965"\w*, y serás \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* \w buena|strong="H2896"\w* \w vejez|strong="H7872"\w*.  
\v 16 \w Y|strong="H3068"\w* \w en|strong="H5704"\w* \w la|strong="H3588"\w* cuarta \w generación|strong="H1755"\w* \w volverán|strong="H7725"\w* \w acá|strong="H2008"\w*; \w porque|strong="H3588"\w* \w aún|strong="H5704"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* llegado \w a|strong="H3068"\w* \w su|strong="H3588"\w* colmo \w la|strong="H3588"\w* \w maldad|strong="H5771"\w* del amorreo \w hasta|strong="H5704"\w* \w aquí|strong="H2008"\w*».  
\v 17 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1961"\w* puesto \w el|strong="H5674"\w* \w sol|strong="H8121"\w*, y ya oscurecido, \w se|strong="H1961"\w* dejó ver un \w horno|strong="H8574"\w* \w humeando|strong="H6227"\w*, y una antorcha de fuego \w que|strong="H1961"\w* \w pasó|strong="H5674"\w* por entre \w los|strong="H1961"\w* animales divididos.  
\v 18 \w En|strong="H5704"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w hizo|strong="H3772"\w* Yahvé un \w pacto|strong="H1285"\w* \w con|strong="H5704"\w* Abram, diciendo: «\w A|strong="H3068"\w* tu \w descendencia|strong="H2233"\w* \w daré|strong="H5414"\w* \w esta|strong="H2063"\w* tierra, \w desde|strong="H5704"\w* \w el|strong="H1931"\w* \w río|strong="H5104"\w* \w de|strong="H5704"\w* \w Egipto|strong="H4714"\w* \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w río|strong="H5104"\w* \w grande|strong="H1419"\w*, \w el|strong="H1931"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*;  
\v 19 la tierra de los ceneos, los cenezeos, los cadmoneos,  
\v 20 los heteos, los ferezeos, los refaítas,  
\v 21 los amorreos, los \w cananeos|strong="H3669"\w*, los \w gergeseos|strong="H1622"\w* y los \w jebuseos|strong="H2983"\w*».   
\c 16
\p
\v 1 \w Sarai|strong="H8297"\w*, mujer de Abram, \w no|strong="H3808"\w* le daba hijos; y ella tenía una \w sierva|strong="H8198"\w* \w egipcia|strong="H4713"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* \w llamaba|strong="H8034"\w* \w Agar|strong="H1904"\w*.  
\v 2 Dijo entonces \w Sarai|strong="H8297"\w* \w a|strong="H3068"\w* Abram: «\w Mira|strong="H2009"\w*, Yahvé \w me|strong="H4480"\w* ha impedido el tener hijos; \w te|strong="H4480"\w* \w ruego|strong="H4994"\w* \w que|strong="H4480"\w* \w te|strong="H4480"\w* llegues \w a|strong="H3068"\w* \w mi|strong="H2009"\w* \w sierva|strong="H8198"\w*, quizá tendré descendencia \w de|strong="H4480"\w* \w ella|strong="H4480"\w*». \w Y|strong="H3068"\w* \w atendió|strong="H8085"\w* Abram \w al|strong="H4480"\w* \w ruego|strong="H4994"\w* \w de|strong="H4480"\w* \w Sarai|strong="H8297"\w*.  
\v 3 \w Y|strong="H3068"\w* \w Sarai|strong="H8297"\w*, mujer \w de|strong="H5414"\w* Abram, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Agar|strong="H1904"\w* su \w sierva|strong="H8198"\w* \w egipcia|strong="H4713"\w*, al cabo \w de|strong="H5414"\w* \w diez|strong="H6235"\w* \w años|strong="H8141"\w* que había habitado Abram en la tierra \w de|strong="H5414"\w* \w Canaán|strong="H3667"\w*, y la \w dio|strong="H5414"\w* \w por|strong="H5414"\w* mujer \w a|strong="H3068"\w* Abram su marido.  
\v 4 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* se llegó \w a|strong="H3068"\w* \w Agar|strong="H1904"\w*, \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w concibió|strong="H2029"\w*; \w y|strong="H3588"\w* \w cuando|strong="H3588"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* concebido, \w miraba|strong="H7200"\w* \w con|strong="H3588"\w* desprecio \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w señora|strong="H1404"\w*.  
\v 5 \w Entonces|strong="H3588"\w* \w Sarai|strong="H8297"\w* dijo \w a|strong="H3068"\w* Abram: «Este \w agravio|strong="H2555"\w* \w es|strong="H3588"\w* culpa tuya. \w Entregué|strong="H5414"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w sierva|strong="H8198"\w* \w en|strong="H5921"\w* \w tu|strong="H8199"\w* \w seno|strong="H2436"\w*, \w y|strong="H3588"\w* \w cuando|strong="H3588"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* concebido, \w me|strong="H5921"\w* \w miraba|strong="H7200"\w* \w con|strong="H5921"\w* desprecio; \w juzgue|strong="H8199"\w* Yahvé \w entre|strong="H5921"\w* \w tú|strong="H8199"\w* \w y|strong="H3588"\w* \w yo|strong="H3588"\w*».   
\p
\v 6 \w Y|strong="H3068"\w* respondió Abram \w a|strong="H3068"\w* \w Sarai|strong="H8297"\w*: «He \w aquí|strong="H2009"\w*, \w tu|strong="H6213"\w* doncella está en \w tu|strong="H6213"\w* \w mano|strong="H3027"\w*; \w haz|strong="H6213"\w* con ella \w lo|strong="H6213"\w* \w que|strong="H3027"\w* \w bien|strong="H2896"\w* \w te|strong="H5869"\w* parezca». \w Y|strong="H3068"\w* como \w Sarai|strong="H8297"\w* la afligiese, ella \w huyó|strong="H1272"\w* \w de|strong="H6440"\w* su \w presencia|strong="H6440"\w*.   
\p
\v 7 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w halló|strong="H4672"\w* \w el|strong="H5921"\w* \w ángel|strong="H4397"\w* \w de|strong="H5921"\w* Yahvé \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w una|strong="H4672"\w* \w fuente|strong="H5869"\w* \w de|strong="H5921"\w* \w agua|strong="H4325"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w fuente|strong="H5869"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w de|strong="H5921"\w* \w Shur|strong="H7793"\w*.  
\v 8 \w Y|strong="H3068"\w* le dijo: «\w Agar|strong="H1904"\w*, \w sierva|strong="H8198"\w* \w de|strong="H6440"\w* \w Sarai|strong="H8297"\w*, ¿\w de|strong="H6440"\w* dónde \w vienes|strong="H3212"\w* tú, y \w a|strong="H3068"\w* dónde \w vas|strong="H3212"\w*?»  
\p \w Y|strong="H3068"\w* ella respondió: «\w Huyo|strong="H1272"\w* \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* mi \w señora|strong="H1404"\w* \w Sarai|strong="H8297"\w*».   
\p
\v 9 \w Y|strong="H3068"\w* le dijo el \w ángel|strong="H4397"\w* \w de|strong="H8478"\w* Yahvé: «\w Vuélvete|strong="H7725"\w* \w a|strong="H3068"\w* tu \w señora|strong="H1404"\w*, y ponte sumisa \w bajo|strong="H8478"\w* sus \w manos|strong="H3027"\w*».  
\v 10 Le dijo también el \w ángel|strong="H4397"\w* de Yahvé: «\w Multiplicaré|strong="H7235"\w* en \w gran|strong="H7235"\w* \w manera|strong="H7235"\w* tu \w descendencia|strong="H2233"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w podrá|strong="H3808"\w* ser contada \w a|strong="H3068"\w* causa de la \w multitud|strong="H7230"\w*».  
\v 11 \w Además|strong="H3588"\w* le dijo \w el|strong="H3588"\w* \w ángel|strong="H4397"\w* \w de|strong="H3588"\w* Yahvé: «He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* has concebido, \w y|strong="H3588"\w* darás \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, \w y|strong="H3588"\w* \w llamarás|strong="H7121"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Ismael|strong="H3458"\w*, \w porque|strong="H3588"\w* Yahvé ha \w oído|strong="H8085"\w* tu \w aflicción|strong="H6040"\w*.  
\v 12 \w Y|strong="H3068"\w* \w él|strong="H1931"\w* \w será|strong="H1961"\w* un hombre \w fiero|strong="H6501"\w* \w como|strong="H1961"\w* un asno \w montés|strong="H6501"\w*; \w su|strong="H1931"\w* \w mano|strong="H3027"\w* \w será|strong="H1961"\w* \w contra|strong="H5921"\w* \w todos|strong="H3605"\w*, \w y|strong="H5921"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w contra|strong="H5921"\w* \w él|strong="H1931"\w*, \w y|strong="H5921"\w* \w habitará|strong="H7931"\w* frente \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* hermanos».   
\p
\v 13 \w Entonces|strong="H3588"\w* \w llamó|strong="H7121"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* Yahvé \w que|strong="H3588"\w* \w con|strong="H3588"\w* ella \w hablaba|strong="H1696"\w*: «Tú eres \w Dios|strong="H3068"\w* \w que|strong="H3588"\w* \w ve|strong="H7200"\w*»; \w porque|strong="H3588"\w* \w dijo|strong="H1696"\w*: «¿\w No|strong="H3588"\w* he \w visto|strong="H7200"\w* \w también|strong="H1571"\w* \w aquí|strong="H1988"\w* al \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w ve|strong="H7200"\w*?»  
\v 14 \w Por|strong="H5921"\w* \w lo|strong="H5921"\w* cual \w llamó|strong="H7121"\w* \w al|strong="H5921"\w* pozo Beer Lahai Roi.\f + \fr 16:14 \ft Beer Lahai Roi significa «pozo del que vive y me ve».\f* He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w está|strong="H3651"\w* \w entre|strong="H5921"\w* \w Cades|strong="H6946"\w* \w y|strong="H5921"\w* \w Bered|strong="H1260"\w*.   
\p
\v 15 \w Y|strong="H3068"\w* \w Agar|strong="H1904"\w* dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* Abram, y \w llamó|strong="H7121"\w* Abram \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* del \w hijo|strong="H1121"\w* \w que|strong="H1121"\w* le dio \w Agar|strong="H1904"\w*, \w Ismael|strong="H3458"\w*.  
\v 16 \w Era|strong="H8141"\w* Abram \w de|strong="H1121"\w* \w edad|strong="H8141"\w* \w de|strong="H1121"\w* \w ochenta|strong="H8084"\w* y \w seis|strong="H8337"\w* \w años|strong="H8141"\w*, cuando \w Agar|strong="H1904"\w* dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Ismael|strong="H3458"\w*.   
\c 17
\p
\v 1 \w Cuando|strong="H1961"\w* Abram \w tenía|strong="H1961"\w* \w noventa|strong="H8673"\w* y \w nueve|strong="H8672"\w* \w años|strong="H8141"\w*, \w se|strong="H1961"\w* le \w apareció|strong="H7200"\w* Yahvé y le dijo: «Yo \w soy|strong="H1961"\w* \w el|strong="H1121"\w* \w Dios|strong="H3068"\w* \w Todopoderoso|strong="H7706"\w*; \w anda|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H1961"\w* y \w sé|strong="H1961"\w* \w perfecto|strong="H8549"\w*.  
\v 2 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* mi \w pacto|strong="H1285"\w* entre mí y ti, y te \w multiplicaré|strong="H7235"\w* en \w gran|strong="H3966"\w* \w manera|strong="H7235"\w*».   
\p
\v 3 Entonces Abram \w se|strong="H5921"\w* postró \w sobre|strong="H5921"\w* su \w rostro|strong="H6440"\w*, \w y|strong="H5921"\w* Dios \w habló|strong="H1696"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w*, \w diciendo|strong="H1696"\w*:  
\v 4 «En cuanto \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H1961"\w* \w mi|strong="H1961"\w* \w pacto|strong="H1285"\w* \w es|strong="H1961"\w* contigo, y \w serás|strong="H1961"\w* padre de \w muchedumbre|strong="H1995"\w* de \w gentes|strong="H1471"\w*.  
\v 5 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* \w llamará|strong="H7121"\w* \w más|strong="H5750"\w* tu \w nombre|strong="H8034"\w* Abram, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w será|strong="H1961"\w* tu \w nombre|strong="H8034"\w* Abraham, \w porque|strong="H3588"\w* \w te|strong="H3588"\w* he \w puesto|strong="H5414"\w* \w por|strong="H3588"\w* padre \w de|strong="H3588"\w* \w muchedumbre|strong="H1995"\w* \w de|strong="H3588"\w* \w gentes|strong="H1471"\w*.  
\v 6 \w Y|strong="H3068"\w* \w te|strong="H4480"\w* \w haré|strong="H5414"\w* fructificar \w en|strong="H4480"\w* \w gran|strong="H3966"\w* \w manera|strong="H3966"\w*, y \w haré|strong="H5414"\w* \w naciones|strong="H1471"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, y \w reyes|strong="H4428"\w* \w saldrán|strong="H3318"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w*.  
\v 7 \w Y|strong="H3068"\w* \w estableceré|strong="H6965"\w* \w mi|strong="H1961"\w* \w pacto|strong="H1285"\w* entre \w mí|strong="H1961"\w* y ti, y tu \w descendencia|strong="H2233"\w* \w después|strong="H1961"\w* de ti en sus \w generaciones|strong="H1755"\w*, \w por|strong="H5769"\w* \w pacto|strong="H1285"\w* \w perpetuo|strong="H5769"\w*, \w para|strong="H1961"\w* ser tu Dios, y el de tu \w descendencia|strong="H2233"\w* \w después|strong="H1961"\w* de ti.  
\v 8 \w Y|strong="H3068"\w* te \w daré|strong="H5414"\w* \w a|strong="H3068"\w* ti, y \w a|strong="H3068"\w* tu \w descendencia|strong="H2233"\w* \w después|strong="H1961"\w* \w de|strong="H5414"\w* ti, \w la|strong="H3605"\w* tierra en \w que|strong="H1961"\w* moras, \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5414"\w* \w Canaán|strong="H3667"\w* en heredad \w perpetua|strong="H5769"\w*; y \w seré|strong="H1961"\w* \w el|strong="H3605"\w* Dios \w de|strong="H5414"\w* \w ellos|strong="H3605"\w*».   
\p
\v 9 Dijo de nuevo Dios \w a|strong="H3068"\w* Abraham: «En cuanto \w a|strong="H3068"\w* ti, \w guardarás|strong="H8104"\w* mi \w pacto|strong="H1285"\w*, tú y tu \w descendencia|strong="H2233"\w* después de ti por sus \w generaciones|strong="H1755"\w*.  
\v 10 \w Éste|strong="H2063"\w* \w es|strong="H2063"\w* mi \w pacto|strong="H1285"\w*, \w que|strong="H3605"\w* \w guardaréis|strong="H8104"\w* entre mí y vosotros y tu \w descendencia|strong="H2233"\w* después de ti: Será \w circuncidado|strong="H4135"\w* \w todo|strong="H3605"\w* \w varón|strong="H2145"\w* de entre vosotros.  
\v 11 \w Circuncidaréis|strong="H5243"\w*, \w pues|strong="H1961"\w*, la \w carne|strong="H1320"\w* de vuestro \w prepucio|strong="H6190"\w*, y \w será|strong="H1961"\w* por señal del \w pacto|strong="H1285"\w* entre \w mí|strong="H1961"\w* y vosotros.  
\v 12 \w Y|strong="H3068"\w* \w de|strong="H1121"\w* \w edad|strong="H3117"\w* \w de|strong="H1121"\w* \w ocho|strong="H8083"\w* \w días|strong="H3117"\w* \w será|strong="H1931"\w* \w circuncidado|strong="H4135"\w* \w todo|strong="H3605"\w* \w varón|strong="H2145"\w* \w entre|strong="H3808"\w* vosotros por vuestras \w generaciones|strong="H1755"\w*; \w el|strong="H1931"\w* \w nacido|strong="H3211"\w* en \w casa|strong="H1004"\w*, y \w el|strong="H1931"\w* \w comprado|strong="H4736"\w* por \w dinero|strong="H3701"\w* \w a|strong="H3068"\w* \w cualquier|strong="H3605"\w* \w extranjero|strong="H5236"\w*, \w que|strong="H1931"\w* \w no|strong="H3808"\w* fuere \w de|strong="H1121"\w* tu \w linaje|strong="H2233"\w*.  
\v 13 \w Debe|strong="H4135"\w* ser \w circuncidado|strong="H4135"\w* el \w nacido|strong="H3211"\w* en tu \w casa|strong="H1004"\w*, y el \w comprado|strong="H4736"\w* \w por|strong="H5769"\w* tu \w dinero|strong="H3701"\w*; y \w estará|strong="H1961"\w* \w mi|strong="H1961"\w* \w pacto|strong="H1285"\w* en \w vuestra|strong="H1961"\w* \w carne|strong="H1320"\w* \w por|strong="H5769"\w* \w pacto|strong="H1285"\w* \w perpetuo|strong="H5769"\w*.  
\v 14 \w Y|strong="H3068"\w* \w el|strong="H1931"\w* \w varón|strong="H2145"\w* \w incircunciso|strong="H6189"\w*, \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w no|strong="H3808"\w* hubiere \w circuncidado|strong="H4135"\w* \w la|strong="H1931"\w* \w carne|strong="H1320"\w* \w de|strong="H5971"\w* \w su|strong="H1931"\w* \w prepucio|strong="H6190"\w*, \w aquella|strong="H1931"\w* \w persona|strong="H5315"\w* \w será|strong="H1931"\w* cortada \w de|strong="H5971"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*; \w ha|strong="H3808"\w* violado \w mi|strong="H5315"\w* \w pacto|strong="H1285"\w*».   
\p
\v 15 Dijo también Dios \w a|strong="H3068"\w* Abraham: «\w A|strong="H3068"\w* \w Sarai|strong="H8297"\w* tu mujer \w no|strong="H3808"\w* \w la|strong="H3588"\w* \w llamarás|strong="H7121"\w* \w Sarai|strong="H8297"\w*, \w mas|strong="H3588"\w* \w Sara|strong="H8283"\w* \w será|strong="H3808"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w*.  
\v 16 \w Y|strong="H3068"\w* \w la|strong="H1571"\w* \w bendeciré|strong="H1288"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w te|strong="H4480"\w* \w daré|strong="H5414"\w* \w de|strong="H4480"\w* \w ella|strong="H4480"\w* \w hijo|strong="H1121"\w*; \w sí|strong="H1571"\w*, \w la|strong="H1571"\w* \w bendeciré|strong="H1288"\w*, \w y|strong="H1571"\w* \w vendrá|strong="H1961"\w* \w a|strong="H3068"\w* ser madre \w de|strong="H4480"\w* \w naciones|strong="H1471"\w*; \w reyes|strong="H4428"\w* \w de|strong="H4480"\w* \w pueblos|strong="H5971"\w* vendrán \w de|strong="H4480"\w* \w ella|strong="H4480"\w*».   
\p
\v 17 Entonces Abraham \w se|strong="H5921"\w* postró \w sobre|strong="H5921"\w* su \w rostro|strong="H6440"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* rió, \w y|strong="H5921"\w* dijo \w en|strong="H5921"\w* su \w corazón|strong="H3820"\w*: «¿\w A|strong="H3068"\w* \w hombre|strong="H1121"\w* \w de|strong="H5921"\w* \w cien|strong="H3967"\w* \w años|strong="H8141"\w* ha \w de|strong="H5921"\w* nacer \w hijo|strong="H1121"\w*? ¿\w Y|strong="H3068"\w* \w Sara|strong="H8283"\w*, ya \w de|strong="H5921"\w* \w noventa|strong="H8673"\w* \w años|strong="H8141"\w*, ha \w de|strong="H5921"\w* concebir?»  
\v 18 \w Y|strong="H3068"\w* dijo Abraham \w a|strong="H3068"\w* Dios: «¡\w Ojalá|strong="H3863"\w* \w Ismael|strong="H3458"\w* \w viva|strong="H2421"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti!»   
\p
\v 19 Respondió Dios: “Ciertamente \w Sara|strong="H8283"\w* tu mujer te \w dará|strong="H3205"\w* \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, y \w llamarás|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Isaac|strong="H3327"\w*.\f + \fr 17:19 \ft Isaac significa «se ríe».\f* \w Y|strong="H3068"\w* \w confirmaré|strong="H6965"\w* mi \w pacto|strong="H1285"\w* con \w él|strong="H1121"\w* como \w pacto|strong="H1285"\w* \w perpetuo|strong="H5769"\w* para sus descendientes después \w de|strong="H1121"\w* \w él|strong="H1121"\w*.  
\v 20 \w Y|strong="H3068"\w* en cuanto \w a|strong="H3068"\w* \w Ismael|strong="H3458"\w*, también te he \w oído|strong="H8085"\w*; he \w aquí|strong="H2009"\w* que le \w bendeciré|strong="H1288"\w*, y le \w haré|strong="H5414"\w* fructificar y multiplicar en \w gran|strong="H1419"\w* \w manera|strong="H7235"\w*; \w doce|strong="H8147"\w* \w príncipes|strong="H5387"\w* \w engendrará|strong="H3205"\w*, y \w haré|strong="H5414"\w* \w de|strong="H5414"\w* él una \w gran|strong="H1419"\w* \w nación|strong="H1471"\w*.  
\v 21 Mas yo \w estableceré|strong="H6965"\w* mi \w pacto|strong="H1285"\w* con \w Isaac|strong="H3327"\w*, el \w que|strong="H2088"\w* \w Sara|strong="H8283"\w* te \w dará|strong="H3205"\w* \w a|strong="H3068"\w* luz \w por|strong="H2088"\w* \w este|strong="H2088"\w* \w tiempo|strong="H4150"\w* el \w año|strong="H8141"\w* \w que|strong="H2088"\w* viene”.   
\p
\v 22 \w Y|strong="H3068"\w* \w acabó|strong="H3615"\w* \w de|strong="H5921"\w* \w hablar|strong="H1696"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w subió|strong="H5927"\w* Dios \w de|strong="H5921"\w* estar \w con|strong="H5921"\w* Abraham.  
\v 23 \w Entonces|strong="H3117"\w* \w tomó|strong="H3947"\w* Abraham \w a|strong="H3068"\w* \w Ismael|strong="H3458"\w* su \w hijo|strong="H1121"\w*, y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* siervos \w nacidos|strong="H3211"\w* en su \w casa|strong="H1004"\w*, y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* comprados \w por|strong="H2088"\w* su \w dinero|strong="H3701"\w*, \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w varón|strong="H2145"\w* entre \w los|strong="H1121"\w* domésticos \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Abraham, y circuncidó \w la|strong="H3605"\w* \w carne|strong="H1320"\w* del \w prepucio|strong="H6190"\w* \w de|strong="H1121"\w* \w ellos|strong="H3605"\w* en \w aquel|strong="H2088"\w* \w mismo|strong="H6106"\w* \w día|strong="H3117"\w*, como Dios le había \w dicho|strong="H1696"\w*.  
\v 24 \w Era|strong="H8141"\w* Abraham \w de|strong="H1121"\w* \w edad|strong="H8141"\w* \w de|strong="H1121"\w* \w noventa|strong="H8673"\w* y \w nueve|strong="H8672"\w* \w años|strong="H8141"\w* cuando circuncidó la \w carne|strong="H1320"\w* \w de|strong="H1121"\w* su \w prepucio|strong="H6190"\w*.  
\v 25 \w E|strong="H3068"\w* \w Ismael|strong="H3458"\w* su \w hijo|strong="H1121"\w* \w era|strong="H8141"\w* \w de|strong="H1121"\w* \w trece|strong="H7969"\w* \w años|strong="H8141"\w* cuando fue circuncidada la \w carne|strong="H1320"\w* \w de|strong="H1121"\w* su \w prepucio|strong="H6190"\w*.  
\v 26 En \w el|strong="H1121"\w* \w mismo|strong="H6106"\w* \w día|strong="H3117"\w* fueron circuncidados Abraham \w e|strong="H3068"\w* \w Ismael|strong="H3458"\w* su \w hijo|strong="H1121"\w*.  
\v 27 \w Y|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* varones \w de|strong="H1121"\w* su \w casa|strong="H1004"\w*, \w el|strong="H3605"\w* siervo \w nacido|strong="H3211"\w* en \w casa|strong="H1004"\w*, y \w el|strong="H3605"\w* \w comprado|strong="H4736"\w* del \w extranjero|strong="H5236"\w* por \w dinero|strong="H3701"\w*, fueron circuncidados con \w él|strong="H3605"\w*.   
\c 18
\p
\v 1 Yahvé \w se|strong="H1931"\w* \w le|strong="H1931"\w* \w apareció|strong="H7200"\w* en \w el|strong="H1931"\w* encinar de \w Mamre|strong="H4471"\w*, \w estando|strong="H3427"\w* \w él|strong="H1931"\w* \w sentado|strong="H3427"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w puerta|strong="H6607"\w* de \w su|strong="H1931"\w* tienda en \w el|strong="H1931"\w* calor del \w día|strong="H3117"\w*.  
\v 2 \w Y|strong="H3068"\w* \w alzó|strong="H5375"\w* sus \w ojos|strong="H5869"\w* \w y|strong="H5921"\w* \w miró|strong="H7200"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w tres|strong="H7969"\w* varones \w que|strong="H5921"\w* \w estaban|strong="H5324"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*. \w Al|strong="H5921"\w* verlos, salió \w corriendo|strong="H7323"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tienda \w a|strong="H3068"\w* recibirlos, \w se|strong="H5921"\w* postró \w en|strong="H5921"\w* tierra,  
\v 3 \w y|strong="H5921"\w* dijo: «Señor \w mío|strong="H5921"\w*, \w si|strong="H4994"\w* he \w hallado|strong="H4672"\w* \w gracia|strong="H2580"\w* \w en|strong="H5921"\w* tus \w ojos|strong="H5869"\w*, \w te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w no|strong="H5921"\w* \w pases|strong="H5674"\w* \w de|strong="H5921"\w* largo \w junto|strong="H5921"\w* \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w*.  
\v 4 \w Que|strong="H4994"\w* se \w traiga|strong="H3947"\w* \w ahora|strong="H4994"\w* un \w poco|strong="H4592"\w* \w de|strong="H8478"\w* \w agua|strong="H4325"\w*, \w lavad|strong="H7364"\w* vuestros \w pies|strong="H7272"\w* y recostaos \w bajo|strong="H8478"\w* el \w árbol|strong="H6086"\w*.  
\v 5 \w Yo|strong="H3588"\w* traeré un bocado \w de|strong="H5921"\w* \w pan|strong="H3899"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* sustentéis vuestro \w corazón|strong="H3820"\w*; \w después|strong="H5921"\w* podréis seguir vuestro camino, ya \w que|strong="H3588"\w* habéis \w pasado|strong="H5674"\w* \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* vuestro \w siervo|strong="H5650"\w*».  
\p \w Ellos|strong="H5921"\w* \w dijeron|strong="H1696"\w*: «\w Haz|strong="H6213"\w* \w así|strong="H3651"\w* \w como|strong="H3588"\w* has \w dicho|strong="H1696"\w*».   
\p
\v 6 Entonces Abraham fue de prisa \w a|strong="H3068"\w* la tienda, \w a|strong="H3068"\w* donde estaba \w Sara|strong="H8283"\w*, y le dijo: «Toma \w pronto|strong="H4116"\w* \w tres|strong="H7969"\w* \w medidas|strong="H5429"\w*\f + \fr 18:6 \ft La medida hebrea original es el seah, equivalente a unos 7 litros.\f* de flor de \w harina|strong="H7058"\w*, amásala y cuece \w panes|strong="H5692"\w*».  
\v 7 \w Y|strong="H3068"\w* \w corrió|strong="H7323"\w* Abraham \w a|strong="H3068"\w* las \w vacas|strong="H1241"\w*, \w tomó|strong="H3947"\w* un becerro \w tierno|strong="H7390"\w* \w y|strong="H1241"\w* \w bueno|strong="H2896"\w*, \w y|strong="H1241"\w* \w lo|strong="H6213"\w* \w dio|strong="H5414"\w* al \w criado|strong="H5288"\w*, \w quien|strong="H6213"\w* se apresuró \w a|strong="H3068"\w* prepararlo.  
\v 8 \w Tomó|strong="H3947"\w* también cuajada, \w leche|strong="H2461"\w* \w y|strong="H5921"\w* \w el|strong="H1931"\w* becerro \w que|strong="H1931"\w* \w había|strong="H5975"\w* preparado, \w y|strong="H5921"\w* \w lo|strong="H1931"\w* \w puso|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ellos|strong="H1931"\w*. \w Él|strong="H1931"\w* \w se|strong="H1931"\w* \w quedó|strong="H5975"\w* \w de|strong="H5921"\w* \w pie|strong="H8478"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H1931"\w* \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* \w árbol|strong="H6086"\w*, \w y|strong="H5921"\w* comieron.   
\p
\v 9 \w Y|strong="H3068"\w* le dijeron: «¿Dónde está \w Sara|strong="H8283"\w* tu mujer?»  
\p \w Y|strong="H3068"\w* él respondió: «Allí en la tienda».   
\p
\v 10 \w Entonces|strong="H6256"\w* dijo: «\w Ciertamente|strong="H2009"\w* \w volveré|strong="H7725"\w* \w a|strong="H3068"\w* ti por \w este|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w el|strong="H1931"\w* año próximo, y he \w aquí|strong="H2009"\w*, \w Sara|strong="H8283"\w* tu mujer tendrá un \w hijo|strong="H1121"\w*».  
\p \w Y|strong="H3068"\w* \w Sara|strong="H8283"\w* \w escuchaba|strong="H8085"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w puerta|strong="H6607"\w* \w de|strong="H1121"\w* \w la|strong="H1931"\w* tienda, \w que|strong="H1931"\w* \w estaba|strong="H2009"\w* detrás \w de|strong="H1121"\w* \w él|strong="H1931"\w*.  
\v 11 Abraham y \w Sara|strong="H8283"\w* \w eran|strong="H1961"\w* \w ancianos|strong="H2205"\w*, de \w edad|strong="H3117"\w* avanzada; y \w a|strong="H3068"\w* \w Sara|strong="H8283"\w* le \w había|strong="H1961"\w* cesado ya la costumbre de las mujeres.  
\v 12 \w Se|strong="H1961"\w* rió, \w pues|strong="H1961"\w*, \w Sara|strong="H8283"\w* \w entre|strong="H7130"\w* \w sí|strong="H1961"\w*, diciendo: «¿\w Después|strong="H1961"\w* \w que|strong="H1961"\w* he \w envejecido|strong="H2204"\w* \w tendré|strong="H1961"\w* \w deleite|strong="H5730"\w*, siendo también \w mi|strong="H1961"\w* señor ya \w viejo|strong="H2204"\w*?»   
\p
\v 13 Entonces Yahvé dijo \w a|strong="H3068"\w* Abraham: “¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* \w se|strong="H4100"\w* ha reído \w Sara|strong="H8283"\w* diciendo: ‘¿Será cierto \w que|strong="H4100"\w* he de dar \w a|strong="H3068"\w* luz siendo \w ya|strong="H2088"\w* vieja?’  
\v 14 ¿Hay para Yahvé alguna \w cosa|strong="H1697"\w* \w difícil|strong="H6381"\w*? \w Al|strong="H6256"\w* \w tiempo|strong="H6256"\w* \w señalado|strong="H4150"\w* \w volveré|strong="H7725"\w* \w a|strong="H3068"\w* ti, \w por|strong="H1697"\w* este \w tiempo|strong="H6256"\w* \w el|strong="H1121"\w* año próximo, y \w Sara|strong="H8283"\w* tendrá un \w hijo|strong="H1121"\w*”.   
\p
\v 15 \w Entonces|strong="H3588"\w* \w Sara|strong="H8283"\w* \w lo|strong="H3808"\w* \w negó|strong="H3584"\w*, diciendo: «\w No|strong="H3808"\w* \w me|strong="H3588"\w* he reído»; \w porque|strong="H3588"\w* \w tuvo|strong="H3372"\w* \w miedo|strong="H3372"\w*.  
\p \w Pero|strong="H3588"\w* \w él|strong="H3588"\w* dijo: «\w No|strong="H3808"\w* \w es|strong="H3588"\w* \w así|strong="H3588"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* has reído».   
\p
\v 16 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* varones \w se|strong="H5921"\w* \w levantaron|strong="H6965"\w* \w de|strong="H5921"\w* \w allí|strong="H8033"\w*, \w y|strong="H5921"\w* miraron \w hacia|strong="H5921"\w* \w Sodoma|strong="H5467"\w*; \w y|strong="H5921"\w* Abraham \w iba|strong="H1980"\w* \w con|strong="H5973"\w* \w ellos|strong="H5921"\w* acompañándolos.  
\v 17 \w Y|strong="H3068"\w* Yahvé dijo: «¿Ocultaré \w yo|strong="H6213"\w* \w a|strong="H3068"\w* Abraham \w lo|strong="H6213"\w* que voy \w a|strong="H3068"\w* \w hacer|strong="H6213"\w*,  
\v 18 \w habiendo|strong="H1961"\w* de ser Abraham una \w nación|strong="H1471"\w* \w grande|strong="H1419"\w* y \w fuerte|strong="H6099"\w*, y \w habiendo|strong="H1961"\w* de ser benditas en \w él|strong="H3605"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* de \w la|strong="H3605"\w* tierra?  
\v 19 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w lo|strong="H5921"\w* he elegido, \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w mandará|strong="H6680"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w sí|strong="H3588"\w*, \w que|strong="H3588"\w* \w guarden|strong="H8104"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w de|strong="H5921"\w* Yahvé, \w haciendo|strong="H6213"\w* \w justicia|strong="H6666"\w* \w y|strong="H3588"\w* \w juicio|strong="H4941"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w haga|strong="H6213"\w* venir Yahvé \w sobre|strong="H5921"\w* Abraham \w lo|strong="H5921"\w* \w que|strong="H3588"\w* ha \w hablado|strong="H1696"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*».  
\v 20 \w Entonces|strong="H3588"\w* Yahvé le dijo: «\w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w el|strong="H3588"\w* \w clamor|strong="H2201"\w* contra \w Sodoma|strong="H5467"\w* \w y|strong="H3588"\w* \w Gomorra|strong="H6017"\w* se aumenta \w más|strong="H3588"\w* \w y|strong="H3588"\w* \w más|strong="H3588"\w*, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w pecado|strong="H2403"\w* \w de|strong="H3588"\w* ellos se ha \w agravado|strong="H3513"\w* \w en|strong="H3588"\w* extremo,  
\v 21 \w descenderé|strong="H3381"\w* \w ahora|strong="H4994"\w*, y \w veré|strong="H7200"\w* \w si|strong="H3808"\w* han consumado su \w obra|strong="H6213"\w* según \w el|strong="H6213"\w* \w clamor|strong="H6818"\w* \w que|strong="H3808"\w* \w ha|strong="H3808"\w* llegado hasta \w mí|strong="H4994"\w*; y \w si|strong="H3808"\w* \w no|strong="H3808"\w*, \w lo|strong="H3808"\w* sabré».   
\p
\v 22 \w Y|strong="H3068"\w* se apartaron \w de|strong="H6440"\w* \w allí|strong="H8033"\w* los varones, y \w fueron|strong="H3212"\w* \w hacia|strong="H6440"\w* \w Sodoma|strong="H5467"\w*; pero Abraham \w estaba|strong="H5975"\w* \w aún|strong="H5750"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.  
\v 23 \w Y|strong="H3068"\w* se \w acercó|strong="H5066"\w* Abraham y dijo: «¿\w Destruirás|strong="H5595"\w* también al \w justo|strong="H6662"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w impío|strong="H7563"\w*?  
