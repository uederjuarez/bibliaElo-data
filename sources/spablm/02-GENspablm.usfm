\v 19 \w Con|strong="H4480"\w* \w el|strong="H3588"\w* sudor \w de|strong="H4480"\w* tu rostro comerás \w el|strong="H3588"\w* \w pan|strong="H3899"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w vuelvas|strong="H7725"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w tierra|strong="H6083"\w*,  
