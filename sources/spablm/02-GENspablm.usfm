\v 6 \w Tomó|strong="H3947"\w* Abraham \w la|strong="H5921"\w* \w leña|strong="H6086"\w* \w del|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w puso|strong="H7760"\w* \w sobre|strong="H5921"\w* \w Isaac|strong="H3327"\w* su \w hijo|strong="H1121"\w*; \w y|strong="H5921"\w* \w él|strong="H5921"\w* \w tomó|strong="H3947"\w* \w en|strong="H5921"\w* su \w mano|strong="H3027"\w* \w el|strong="H5921"\w* fuego \w y|strong="H5921"\w* \w el|strong="H5921"\w* cuchillo, \w y|strong="H5921"\w* \w fueron|strong="H3212"\w* \w ambos|strong="H8147"\w* \w juntos|strong="H3162"\w*.  
