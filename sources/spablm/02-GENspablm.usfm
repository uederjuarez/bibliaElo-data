\c 3
\p
\v 1 \w Pero|strong="H3588"\w* \w la|strong="H3588"\w* \w serpiente|strong="H5175"\w* \w era|strong="H1961"\w* \w astuta|strong="H6175"\w*, \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w animales|strong="H2416"\w* del \w campo|strong="H7704"\w* \w que|strong="H3588"\w* Yahvé \w Dios|strong="H3068"\w* \w había|strong="H1961"\w* \w hecho|strong="H6213"\w*; \w la|strong="H3588"\w* \w cual|strong="H3588"\w* dijo \w a|strong="H3068"\w* \w la|strong="H3588"\w* mujer: “¿Conque \w Dios|strong="H3068"\w* os \w ha|strong="H3808"\w* dicho: ‘\w No|strong="H3808"\w* comáis \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* del \w huerto|strong="H1588"\w*’?”   
