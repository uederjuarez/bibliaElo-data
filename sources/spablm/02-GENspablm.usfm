\p
\v 46 \w Era|strong="H8141"\w* \w José|strong="H3130"\w* \w de|strong="H6440"\w* \w edad|strong="H8141"\w* \w de|strong="H6440"\w* \w treinta|strong="H7970"\w* \w años|strong="H8141"\w* cuando fue presentado \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Faraón|strong="H6547"\w* \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Egipto|strong="H4714"\w*; y \w salió|strong="H3318"\w* \w José|strong="H3130"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Faraón|strong="H6547"\w*, y recorrió \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H6440"\w* \w Egipto|strong="H4714"\w*.  
\v 47 En aquellos \w siete|strong="H7651"\w* \w años|strong="H8141"\w* de abundancia la tierra produjo \w a|strong="H3068"\w* montones.  
\v 48 \w Y|strong="H3068"\w* \w él|strong="H3605"\w* reunió \w todo|strong="H3605"\w* \w el|strong="H3605"\w* alimento \w de|strong="H5414"\w* \w los|strong="H3605"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w de|strong="H5414"\w* abundancia \w que|strong="H1961"\w* \w hubo|strong="H1961"\w* \w en|strong="H8432"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5414"\w* \w Egipto|strong="H4714"\w*, y guardó alimento \w en|strong="H8432"\w* las \w ciudades|strong="H5892"\w*, \w poniendo|strong="H5414"\w* \w en|strong="H8432"\w* \w cada|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w el|strong="H3605"\w* alimento del \w campo|strong="H7704"\w* \w de|strong="H5414"\w* sus \w alrededores|strong="H5439"\w*.  
\v 49 Recogió \w José|strong="H3130"\w* \w trigo|strong="H1250"\w* \w como|strong="H3588"\w* arena del \w mar|strong="H3220"\w*, \w mucho|strong="H3966"\w* \w en|strong="H5704"\w* extremo, \w hasta|strong="H5704"\w* \w no|strong="H3588"\w* poderse \w contar|strong="H5608"\w*, \w porque|strong="H3588"\w* \w no|strong="H3588"\w* tenía \w número|strong="H4557"\w*.  
\v 50 \w Y|strong="H3068"\w* \w nacieron|strong="H3205"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w* \w antes|strong="H2962"\w* \w que|strong="H1121"\w* viniese \w el|strong="H1121"\w* primer \w año|strong="H8141"\w* del \w hambre|strong="H7458"\w*, \w los|strong="H1121"\w* cuales le dio \w a|strong="H3068"\w* luz Asenat, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Potifera \w sacerdote|strong="H3548"\w* \w de|strong="H1121"\w* On.  
\v 51 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w José|strong="H3130"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* del \w primogénito|strong="H1060"\w*, \w Manasés|strong="H4519"\w*;\f + \fr 41:51 \ft «Manasés» suena en hebreo como la palabra «olvidar».\f* \w porque|strong="H3588"\w* dijo: «Dios \w me|strong="H3588"\w* hizo olvidar \w todo|strong="H3605"\w* mi \w trabajo|strong="H5999"\w*, \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* mi padre».  
\v 52 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* del \w segundo|strong="H8145"\w*, Efraín;\f + \fr 41:52 \ft «Efraín» suena en hebreo como «doblemente fructífero».\f* \w porque|strong="H3588"\w* dijo: «Dios \w me|strong="H3588"\w* hizo fructificar \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* mi \w aflicción|strong="H6040"\w*».   
\p
\v 53 Así \w se|strong="H1961"\w* cumplieron \w los|strong="H1961"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* de abundancia \w que|strong="H1961"\w* \w hubo|strong="H1961"\w* en la tierra de \w Egipto|strong="H4714"\w*.  
