\v 35 \w Concibió|strong="H2029"\w* \w otra|strong="H5750"\w* \w vez|strong="H6471"\w*, \w y|strong="H5921"\w* dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, \w y|strong="H5921"\w* dijo: «\w Esta|strong="H5975"\w* \w vez|strong="H6471"\w* \w alabaré|strong="H3034"\w* \w a|strong="H3068"\w* Yahvé». \w Por|strong="H5921"\w* \w esto|strong="H3651"\w* \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Judá|strong="H3063"\w*; \w y|strong="H5921"\w* dejó \w de|strong="H5921"\w* dar \w a|strong="H3068"\w* luz.   
\c 30
\p
\v 1 \w Viendo|strong="H7200"\w* Raquel \w que|strong="H3588"\w* \w no|strong="H3808"\w* daba \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, tuvo \w envidia|strong="H7065"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermana, \w y|strong="H3588"\w* dijo \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: «\w Dame|strong="H3051"\w* \w hijos|strong="H1121"\w*, \w o|strong="H3068"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w*, \w me|strong="H3588"\w* \w muero|strong="H4191"\w*».   
\p
\v 2 \w Y|strong="H3068"\w* \w se|strong="H4480"\w* encendió la ira \w de|strong="H4480"\w* \w Jacob|strong="H3290"\w* \w contra|strong="H4480"\w* Raquel, y dijo: «¿Estoy \w yo|strong="H4480"\w* \w en|strong="H4480"\w* \w lugar|strong="H8478"\w* \w de|strong="H4480"\w* Dios, \w que|strong="H4480"\w* \w te|strong="H4480"\w* ha negado el \w fruto|strong="H6529"\w* \w de|strong="H4480"\w* tu vientre?»   
\p
\v 3 \w Y|strong="H3068"\w* \w ella|strong="H4480"\w* dijo: «He \w aquí|strong="H2009"\w* \w mi|strong="H5921"\w* sierva \w Bilha|strong="H1090"\w*; llégate \w a|strong="H3068"\w* \w ella|strong="H4480"\w*, \w y|strong="H1571"\w* \w dará|strong="H3205"\w* \w a|strong="H3068"\w* luz \w sobre|strong="H5921"\w* mis \w rodillas|strong="H1290"\w*, \w y|strong="H1571"\w* \w así|strong="H1571"\w* tendré \w yo|strong="H4480"\w* \w también|strong="H1571"\w* hijos \w de|strong="H4480"\w* \w ella|strong="H4480"\w*».  
\v 4 Así le \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Bilha|strong="H1090"\w* su \w sierva|strong="H8198"\w* \w por|strong="H5414"\w* mujer; y \w Jacob|strong="H3290"\w* se llegó \w a|strong="H3068"\w* ella.  
\v 5 \w Y|strong="H3068"\w* \w concibió|strong="H2029"\w* \w Bilha|strong="H1090"\w*, y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 6 \w Y|strong="H3068"\w* dijo Raquel: «\w Me|strong="H5921"\w* juzgó Dios, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w oyó|strong="H8085"\w* \w mi|strong="H5921"\w* \w voz|strong="H6963"\w*, \w y|strong="H1571"\w* \w me|strong="H5921"\w* \w dio|strong="H5414"\w* un \w hijo|strong="H1121"\w*». \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Dan|strong="H1835"\w*.  
\v 7 \w Concibió|strong="H2029"\w* \w otra|strong="H5750"\w* vez \w Bilha|strong="H1090"\w* la \w sierva|strong="H8198"\w* \w de|strong="H5750"\w* Raquel, y dio \w a|strong="H3068"\w* luz un \w segundo|strong="H8145"\w* \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 8 \w Y|strong="H3068"\w* dijo Raquel: «\w Con|strong="H5973"\w* luchas \w de|strong="H5973"\w* Dios he contendido \w con|strong="H5973"\w* mi hermana, \w y|strong="H1571"\w* he vencido». \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* Neftalí.   
\p
\v 9 \w Viendo|strong="H7200"\w* \w Lea|strong="H3812"\w* \w que|strong="H3588"\w* \w había|strong="H5975"\w* dejado \w de|strong="H3588"\w* \w dar|strong="H5414"\w* \w a|strong="H3068"\w* luz, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Zilpa|strong="H2153"\w* \w su|strong="H3588"\w* \w sierva|strong="H8198"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w por|strong="H3588"\w* mujer.  
\v 10 \w Y|strong="H3068"\w* \w Zilpa|strong="H2153"\w* \w sierva|strong="H8198"\w* \w de|strong="H1121"\w* \w Lea|strong="H3812"\w* dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 11 \w Y|strong="H3068"\w* dijo \w Lea|strong="H3812"\w*: «¡Vino la ventura!» \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Gad|strong="H1410"\w*.  
\v 12 \w Y|strong="H3068"\w* \w Zilpa|strong="H2153"\w* \w sierva|strong="H8198"\w* \w de|strong="H1121"\w* \w Lea|strong="H3812"\w* dio \w a|strong="H3068"\w* luz un \w segundo|strong="H8145"\w* \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 13 \w Y|strong="H3068"\w* dijo \w Lea|strong="H3812"\w*: «\w Para|strong="H3588"\w* dicha mía, \w porque|strong="H3588"\w* las \w mujeres|strong="H1323"\w* \w me|strong="H3588"\w* \w llamarán|strong="H7121"\w* dichosa». \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w* Aser.   
\p
\v 14 \w Fue|strong="H3212"\w* \w Rubén|strong="H7205"\w* \w en|strong="H3212"\w* \w tiempo|strong="H3117"\w* \w de|strong="H1121"\w* la siega \w de|strong="H1121"\w* \w los|strong="H1121"\w* trigos, y \w halló|strong="H4672"\w* \w mandrágoras|strong="H1736"\w* \w en|strong="H3212"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w*, y las trajo \w a|strong="H3068"\w* \w Lea|strong="H3812"\w* su madre; y dijo Raquel \w a|strong="H3068"\w* \w Lea|strong="H3812"\w*: «Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me \w des|strong="H5414"\w* \w de|strong="H1121"\w* las \w mandrágoras|strong="H1736"\w* \w de|strong="H1121"\w* tu \w hijo|strong="H1121"\w*».   
\p
\v 15 \w Y|strong="H3068"\w* ella respondió: «¿Es \w poco|strong="H4592"\w* \w que|strong="H1571"\w* hayas \w tomado|strong="H3947"\w* \w a|strong="H3068"\w* mi marido, \w para|strong="H5973"\w* \w que|strong="H1571"\w* \w también|strong="H1571"\w* \w te|strong="H5973"\w* quieras llevar las \w mandrágoras|strong="H1736"\w* \w de|strong="H8478"\w* mi \w hijo|strong="H1121"\w*?»  
\p \w Y|strong="H3068"\w* dijo Raquel: «\w Pues|strong="H3651"\w* \w dormirá|strong="H7901"\w* \w contigo|strong="H5973"\w* \w esta|strong="H3651"\w* \w noche|strong="H3915"\w* \w por|strong="H8478"\w* las \w mandrágoras|strong="H1736"\w* \w de|strong="H8478"\w* tu \w hijo|strong="H1121"\w*».   
\p
\v 16 \w Cuando|strong="H3588"\w* \w Jacob|strong="H3290"\w* volvía \w del|strong="H4480"\w* \w campo|strong="H7704"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w tarde|strong="H6153"\w*, \w salió|strong="H3318"\w* \w Lea|strong="H3812"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* encuentro, \w y|strong="H3588"\w* \w le|strong="H1931"\w* dijo: «\w A|strong="H3068"\w* mí has \w de|strong="H4480"\w* llegarte, \w porque|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* verdad \w te|strong="H4480"\w* he alquilado \w por|strong="H3588"\w* las \w mandrágoras|strong="H1736"\w* \w de|strong="H4480"\w* mi \w hijo|strong="H1121"\w*».  
\p \w Y|strong="H3068"\w* \w durmió|strong="H7901"\w* \w con|strong="H5973"\w* \w ella|strong="H1931"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*.  
\v 17 \w Y|strong="H3068"\w* \w escuchó|strong="H8085"\w* Dios \w a|strong="H3068"\w* \w Lea|strong="H3812"\w*; y \w concibió|strong="H2029"\w*, y dio \w a|strong="H3068"\w* luz \w el|strong="H1121"\w* \w quinto|strong="H2549"\w* \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 18 \w Y|strong="H3068"\w* dijo \w Lea|strong="H3812"\w*: «Dios me ha \w dado|strong="H5414"\w* mi recompensa, \w por|strong="H5414"\w* cuanto \w di|strong="H5414"\w* mi \w sierva|strong="H8198"\w* \w a|strong="H3068"\w* mi marido». \w Por|strong="H5414"\w* eso \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* Isacar.  
\v 19 \w Concibió|strong="H2029"\w* \w Lea|strong="H3812"\w* \w otra|strong="H5750"\w* vez, y dio \w a|strong="H3068"\w* luz \w el|strong="H1121"\w* \w sexto|strong="H8345"\w* \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 20 \w Y|strong="H3068"\w* dijo \w Lea|strong="H3812"\w*: «Dios \w me|strong="H3588"\w* ha dado \w una|strong="H6471"\w* \w buena|strong="H2896"\w* \w dote|strong="H2064"\w*; \w ahora|strong="H6471"\w* \w morará|strong="H2082"\w* conmigo mi marido, \w porque|strong="H3588"\w* le he dado \w a|strong="H3068"\w* luz \w seis|strong="H8337"\w* \w hijos|strong="H1121"\w*». \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Zabulón|strong="H2074"\w*.  
\v 21 Después dio \w a|strong="H3068"\w* luz una \w hija|strong="H1323"\w*, y \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Dina|strong="H1783"\w*.   
\p
\v 22 \w Y|strong="H3068"\w* se acordó Dios de Raquel, y la \w oyó|strong="H8085"\w* Dios, y le concedió hijos.  
\v 23 \w Y|strong="H3068"\w* \w concibió|strong="H2029"\w*, y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, y dijo: «Dios ha quitado mi \w afrenta|strong="H2781"\w*».  
\v 24 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w José|strong="H3130"\w*,\f + \fr 30:24 \ft José significa «puede añadir».\f* diciendo: «\w Añádame|strong="H3254"\w* Yahvé otro \w hijo|strong="H1121"\w*».   
\p
\v 25 \w Aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* Raquel \w hubo|strong="H1961"\w* dado \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w José|strong="H3130"\w*, \w Jacob|strong="H3290"\w* dijo \w a|strong="H3068"\w* \w Labán|strong="H3837"\w*: «Despídeme, \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w vaya|strong="H3212"\w* \w a|strong="H3068"\w* \w mi|strong="H1961"\w* \w lugar|strong="H4725"\w*, y \w a|strong="H3068"\w* \w mi|strong="H1961"\w* tierra.  
\v 26 \w Dame|strong="H5414"\w* \w mis|strong="H5414"\w* mujeres \w y|strong="H3588"\w* \w mis|strong="H5414"\w* \w hijos|strong="H3206"\w*, \w por|strong="H3588"\w* las cuales he servido contigo, \w y|strong="H3588"\w* déjame \w ir|strong="H3212"\w*; \w pues|strong="H3588"\w* tú \w sabes|strong="H3045"\w* \w los|strong="H3588"\w* servicios \w que|strong="H3588"\w* \w te|strong="H3588"\w* he prestado».   
\p
\v 27 \w Y|strong="H3068"\w* \w Labán|strong="H3837"\w* \w le|strong="H5869"\w* respondió: «\w Halle|strong="H4672"\w* \w yo|strong="H4994"\w* \w ahora|strong="H4994"\w* \w gracia|strong="H2580"\w* en tus \w ojos|strong="H5869"\w*, y quédate; he \w experimentado|strong="H5172"\w* \w que|strong="H4994"\w* Yahvé me ha bendecido por tu causa».  
\v 28 \w Y|strong="H3068"\w* añadió: «\w Señálame|strong="H5344"\w* tu \w salario|strong="H7939"\w*, \w y|strong="H5921"\w* \w yo|strong="H5344"\w* \w lo|strong="H5921"\w* \w daré|strong="H5414"\w*».   
\p
\v 29 \w Y|strong="H3068"\w* él le respondió: «Tú \w sabes|strong="H3045"\w* \w cómo|strong="H1961"\w* te he servido, y \w cómo|strong="H1961"\w* ha \w estado|strong="H1961"\w* tu \w ganado|strong="H4735"\w* conmigo.  
\v 30 \w Porque|strong="H3588"\w* \w poco|strong="H4592"\w* \w tenías|strong="H1961"\w* \w antes|strong="H6440"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \w venida|strong="H1961"\w*, \w y|strong="H1571"\w* ha crecido \w en|strong="H3588"\w* gran número, \w y|strong="H1571"\w* Yahvé \w te|strong="H3588"\w* ha bendecido \w con|strong="H3588"\w* \w mi|strong="H1961"\w* llegada; \w y|strong="H1571"\w* \w ahora|strong="H6258"\w*, ¿\w cuándo|strong="H3588"\w* proveeré \w yo|strong="H3588"\w* \w también|strong="H1571"\w* \w para|strong="H3588"\w* \w mi|strong="H1961"\w* propia \w casa|strong="H1004"\w*?»   
\p
\v 31 \w Y|strong="H3068"\w* \w él|strong="H6213"\w* dijo: «¿\w Qué|strong="H4100"\w* te \w daré|strong="H5414"\w*?»  
\p \w Y|strong="H3068"\w* \w respondió|strong="H7725"\w* \w Jacob|strong="H3290"\w*: «\w No|strong="H3808"\w* me \w des|strong="H5414"\w* \w nada|strong="H3808"\w*; \w si|strong="H3808"\w* \w haces|strong="H6213"\w* \w por|strong="H1697"\w* mí \w esto|strong="H2088"\w*, \w volveré|strong="H7725"\w* \w a|strong="H3068"\w* apacentar tus \w ovejas|strong="H6629"\w*.  
\v 32 Yo \w pasaré|strong="H5674"\w* \w hoy|strong="H3117"\w* por \w todo|strong="H3605"\w* tu \w rebaño|strong="H6629"\w*, apartando de \w él|strong="H3605"\w* \w toda|strong="H3605"\w* \w oveja|strong="H7716"\w* manchada y salpicada de color, y \w toda|strong="H3605"\w* \w oveja|strong="H7716"\w* de color oscuro, y las \w manchadas|strong="H5348"\w* y salpicadas de color \w entre|strong="H8033"\w* las \w cabras|strong="H5795"\w*; y esto \w será|strong="H1961"\w* \w mi|strong="H1961"\w* \w salario|strong="H7939"\w*.  
\v 33 \w Así|strong="H3588"\w* \w responderá|strong="H6030"\w* \w por|strong="H5921"\w* \w mí|strong="H5921"\w* \w mi|strong="H5921"\w* honradez \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w mañana|strong="H4279"\w*, \w cuando|strong="H3588"\w* vengas \w a|strong="H3068"\w* reconocer \w mi|strong="H5921"\w* \w salario|strong="H7939"\w*; \w toda|strong="H3605"\w* \w la|strong="H1931"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* fuere pintada ni manchada \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w cabras|strong="H5795"\w*, \w y|strong="H3588"\w* \w de|strong="H5921"\w* color oscuro \w entre|strong="H5921"\w* \w las|strong="H5921"\w* ovejas, \w se|strong="H1931"\w* \w me|strong="H5921"\w* ha \w de|strong="H5921"\w* tener \w por|strong="H5921"\w* \w hurto|strong="H1589"\w*».   
\p
\v 34 Dijo entonces \w Labán|strong="H3837"\w*: «\w Mira|strong="H2005"\w*, \w sea|strong="H1961"\w* \w como|strong="H1961"\w* tú \w dices|strong="H1697"\w*».   
\p
\v 35 \w Y|strong="H3068"\w* Labán apartó \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w los|strong="H1121"\w* machos cabríos manchados y \w rayados|strong="H2921"\w*, y \w todas|strong="H3605"\w* las \w cabras|strong="H5795"\w* \w manchadas|strong="H5348"\w* y salpicadas \w de|strong="H1121"\w* color, y \w toda|strong="H3605"\w* \w aquella|strong="H1931"\w* \w que|strong="H1931"\w* \w tenía|strong="H1931"\w* \w en|strong="H5493"\w* \w sí|strong="H1931"\w* algo \w de|strong="H1121"\w* \w blanco|strong="H3836"\w*, y \w todas|strong="H3605"\w* las \w de|strong="H1121"\w* color oscuro entre las ovejas, y las \w puso|strong="H5414"\w* \w en|strong="H5493"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*.  
\v 36 \w Y|strong="H3068"\w* \w puso|strong="H7760"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* de \w camino|strong="H1870"\w* entre sí y \w Jacob|strong="H3290"\w*; y \w Jacob|strong="H3290"\w* \w apacentaba|strong="H7462"\w* las otras \w ovejas|strong="H6629"\w* de \w Labán|strong="H3837"\w*.   
\p
\v 37 \w Tomó|strong="H3947"\w* luego \w Jacob|strong="H3290"\w* \w varas|strong="H4731"\w* \w verdes|strong="H3892"\w* \w de|strong="H5921"\w* álamo, \w de|strong="H5921"\w* avellano \w y|strong="H5921"\w* \w de|strong="H5921"\w* castaño, \w y|strong="H5921"\w* descortezó \w en|strong="H5921"\w* \w ellas|strong="H5921"\w* mondaduras \w blancas|strong="H3836"\w*, \w descubriendo|strong="H4286"\w* así \w lo|strong="H5921"\w* \w blanco|strong="H3836"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w varas|strong="H4731"\w*.  
\v 38 \w Y|strong="H3068"\w* puso las \w varas|strong="H4731"\w* \w que|strong="H4325"\w* había mondado \w delante|strong="H5227"\w* \w de|strong="H4325"\w* los rebaños, en los abrevaderos donde venían \w a|strong="H3068"\w* \w beber|strong="H8354"\w* las \w ovejas|strong="H6629"\w*, las cuales procreaban cuando venían \w a|strong="H3068"\w* \w beber|strong="H8354"\w*.  
\v 39 Así concebían las \w ovejas|strong="H6629"\w* delante de las \w varas|strong="H4731"\w*; y \w parían|strong="H3205"\w* \w borregos|strong="H6629"\w* \w listados|strong="H6124"\w*, \w pintados|strong="H5348"\w* y salpicados de diversos colores.  
\v 40 \w Y|strong="H3068"\w* apartaba \w Jacob|strong="H3290"\w* \w los|strong="H5921"\w* \w corderos|strong="H6629"\w*, \w y|strong="H5921"\w* \w ponía|strong="H7896"\w* \w con|strong="H5921"\w* su \w rebaño|strong="H6629"\w* \w los|strong="H5921"\w* \w listados|strong="H6124"\w* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* era oscuro \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w rebaño|strong="H6629"\w* \w de|strong="H5921"\w* \w Labán|strong="H3837"\w*. \w Y|strong="H3068"\w* \w ponía|strong="H7896"\w* su \w rebaño|strong="H6629"\w* aparte, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w ponía|strong="H7896"\w* \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w* \w de|strong="H5921"\w* \w Labán|strong="H3837"\w*.  
\v 41 \w Y|strong="H3068"\w* \w sucedía|strong="H1961"\w* \w que|strong="H1961"\w* cuantas veces \w se|strong="H1961"\w* hallaban en celo las \w ovejas|strong="H6629"\w* más fuertes, \w Jacob|strong="H3290"\w* \w ponía|strong="H7760"\w* las \w varas|strong="H4731"\w* \w delante|strong="H5869"\w* \w de|strong="H5869"\w* las \w ovejas|strong="H6629"\w* en \w los|strong="H3605"\w* abrevaderos, \w para|strong="H1961"\w* \w que|strong="H1961"\w* concibiesen \w a|strong="H3068"\w* \w la|strong="H3605"\w* vista \w de|strong="H5869"\w* las \w varas|strong="H4731"\w*.  
\v 42 Pero \w cuando|strong="H1961"\w* venían las \w ovejas|strong="H6629"\w* \w más|strong="H3808"\w* débiles, \w no|strong="H3808"\w* las \w ponía|strong="H7760"\w*; así \w eran|strong="H1961"\w* las \w más|strong="H3808"\w* débiles \w para|strong="H1961"\w* \w Labán|strong="H3837"\w*, y las \w más|strong="H3808"\w* fuertes \w para|strong="H1961"\w* \w Jacob|strong="H3290"\w*.  
\v 43 \w Y|strong="H3068"\w* \w se|strong="H1961"\w* enriqueció el varón muchísimo, y \w tuvo|strong="H1961"\w* \w muchas|strong="H7227"\w* \w ovejas|strong="H6629"\w*, y \w siervas|strong="H8198"\w* y \w siervos|strong="H5650"\w*, y \w camellos|strong="H1581"\w* y \w asnos|strong="H2543"\w*.   
\c 31
\p
\v 1 \w Y|strong="H3068"\w* \w oía|strong="H8085"\w* \w Jacob|strong="H3290"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Labán|strong="H3837"\w*, \w que|strong="H1697"\w* decían: «\w Jacob|strong="H3290"\w* ha \w tomado|strong="H3947"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w era|strong="H1121"\w* \w de|strong="H1121"\w* nuestro padre, \w y|strong="H3519"\w* \w de|strong="H1121"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w era|strong="H1121"\w* \w de|strong="H1121"\w* nuestro padre ha adquirido \w toda|strong="H3605"\w* \w esta|strong="H2088"\w* riqueza».  
\v 2 \w Miró|strong="H7200"\w* también \w Jacob|strong="H3290"\w* \w el|strong="H5973"\w* semblante \w de|strong="H6440"\w* \w Labán|strong="H3837"\w*, y \w vio|strong="H7200"\w* que \w no|strong="H6440"\w* era \w para|strong="H5973"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w como|strong="H5973"\w* \w antes|strong="H6440"\w*.  
\v 3 También Yahvé dijo \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: «\w Vuélvete|strong="H7725"\w* \w a|strong="H3068"\w* la tierra \w de|strong="H5973"\w* tus padres, y \w a|strong="H3068"\w* tu \w parentela|strong="H4138"\w*, y yo estaré \w contigo|strong="H5973"\w*».   
\p
\v 4 \w Y|strong="H3068"\w* \w envió|strong="H7971"\w* \w Jacob|strong="H3290"\w*, y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* Raquel y \w a|strong="H3068"\w* \w Lea|strong="H3812"\w* al \w campo|strong="H7704"\w* donde estaba su \w rebaño|strong="H6629"\w*,  
\v 5 \w y|strong="H3588"\w* les dijo: “\w Veo|strong="H7200"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* semblante \w de|strong="H3588"\w* vuestro padre \w no|strong="H3588"\w* \w es|strong="H1961"\w* \w para|strong="H3588"\w* \w conmigo|strong="H5978"\w* \w como|strong="H3588"\w* \w antes|strong="H6440"\w*; \w mas|strong="H3588"\w* \w el|strong="H3588"\w* Dios \w de|strong="H3588"\w* \w mi|strong="H1961"\w* padre ha \w estado|strong="H1961"\w* \w conmigo|strong="H5978"\w*.  
\v 6 \w Y|strong="H3068"\w* vosotras \w sabéis|strong="H3045"\w* \w que|strong="H3588"\w* \w con|strong="H3588"\w* \w todas|strong="H3605"\w* mis \w fuerzas|strong="H3581"\w* he servido \w a|strong="H3068"\w* vuestro padre;  
\v 7 y vuestro padre me \w ha|strong="H3808"\w* engañado, y me \w ha|strong="H3808"\w* cambiado el \w salario|strong="H4909"\w* \w diez|strong="H6235"\w* \w veces|strong="H4489"\w*; pero Dios \w no|strong="H3808"\w* le \w ha|strong="H3808"\w* permitido \w que|strong="H3808"\w* me hiciese \w mal|strong="H7489"\w*.  
\v 8 \w Si|strong="H1961"\w* \w él|strong="H3605"\w* decía \w así|strong="H3541"\w*: ‘\w Los|strong="H3605"\w* \w pintados|strong="H5348"\w* \w serán|strong="H1961"\w* tu \w salario|strong="H7939"\w*’, entonces \w todas|strong="H3605"\w* las \w ovejas|strong="H6629"\w* \w parían|strong="H3205"\w* pintadas; \w y|strong="H3541"\w* \w si|strong="H1961"\w* decía \w así|strong="H3541"\w*: ‘\w Los|strong="H3605"\w* \w listados|strong="H6124"\w* \w serán|strong="H1961"\w* tu \w salario|strong="H7939"\w*’, entonces \w todas|strong="H3605"\w* las \w ovejas|strong="H6629"\w* \w parían|strong="H3205"\w* listadas.  
\v 9 Así quitó Dios el \w ganado|strong="H4735"\w* \w de|strong="H5414"\w* vuestro padre, y me lo \w dio|strong="H5414"\w* \w a|strong="H3068"\w* mí.  
\v 10 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H5921"\w* \w al|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w que|strong="H5921"\w* \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w* \w se|strong="H1961"\w* apareaban, \w alcé|strong="H5375"\w* \w yo|strong="H2009"\w* \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w* \w y|strong="H5921"\w* \w vi|strong="H7200"\w* \w en|strong="H5921"\w* \w sueños|strong="H2472"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* machos \w que|strong="H5921"\w* cubrían \w a|strong="H3068"\w* \w las|strong="H5921"\w* hembras \w eran|strong="H1961"\w* \w listados|strong="H6124"\w*, \w pintados|strong="H5348"\w* \w y|strong="H5921"\w* abigarrados.  
\v 11 \w Y|strong="H3068"\w* me dijo el \w ángel|strong="H4397"\w* de Dios en \w sueños|strong="H2472"\w*: ‘\w Jacob|strong="H3290"\w*’. \w Y|strong="H3068"\w* \w yo|strong="H2009"\w* dije: ‘\w Aquí|strong="H2009"\w* estoy’.  
\v 12 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* dijo: ‘\w Alza|strong="H5375"\w* \w ahora|strong="H4994"\w* tus \w ojos|strong="H5869"\w*, \w y|strong="H3588"\w* \w verás|strong="H7200"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* machos \w que|strong="H3588"\w* cubren \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w* \w son|strong="H3588"\w* \w listados|strong="H6124"\w*, \w pintados|strong="H5348"\w* \w y|strong="H3588"\w* abigarrados; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* he \w visto|strong="H7200"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w Labán|strong="H3837"\w* \w te|strong="H5869"\w* \w hace|strong="H6213"\w*.  
\v 13 \w Yo|strong="H4480"\w* soy \w el|strong="H1008"\w* Dios \w de|strong="H4480"\w* Betel, \w donde|strong="H8033"\w* tú ungiste \w la|strong="H2063"\w* piedra, y \w donde|strong="H8033"\w* \w me|strong="H4480"\w* hiciste un \w voto|strong="H5087"\w*. \w Levántate|strong="H6965"\w* \w ahora|strong="H6258"\w* y \w sal|strong="H3318"\w* \w de|strong="H4480"\w* \w esta|strong="H2063"\w* tierra, y \w vuélvete|strong="H7725"\w* \w a|strong="H3068"\w* \w la|strong="H2063"\w* tierra \w de|strong="H4480"\w* tu \w nacimiento|strong="H4138"\w*’”.   
\p
\v 14 \w Respondieron|strong="H6030"\w* Raquel y \w Lea|strong="H3812"\w*, y le dijeron: «¿Tenemos acaso \w parte|strong="H2506"\w* \w o|strong="H3068"\w* \w heredad|strong="H5159"\w* \w en|strong="H5750"\w* la \w casa|strong="H1004"\w* \w de|strong="H5750"\w* nuestro padre?  
\v 15 ¿\w No|strong="H3808"\w* nos \w tiene|strong="H2803"\w* \w ya|strong="H1571"\w* \w por|strong="H3588"\w* \w extranjeras|strong="H5237"\w*, \w pues|strong="H3588"\w* \w que|strong="H3588"\w* nos \w vendió|strong="H4376"\w*, \w y|strong="H1571"\w* \w aun|strong="H1571"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* comido del todo nuestro \w precio|strong="H3701"\w*?  
\v 16 \w Porque|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* riqueza \w que|strong="H3588"\w* Dios ha quitado \w a|strong="H3068"\w* nuestro padre, \w es|strong="H1931"\w* nuestra \w y|strong="H3588"\w* \w de|strong="H3588"\w* nuestros \w hijos|strong="H1121"\w*; \w ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \w haz|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* Dios \w te|strong="H3588"\w* ha dicho».   
\p
\v 17 Entonces \w se|strong="H5921"\w* \w levantó|strong="H5375"\w* \w Jacob|strong="H3290"\w*, \w y|strong="H5921"\w* subió \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* sus mujeres \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w camellos|strong="H1581"\w*,  
\v 18 y puso en camino \w todo|strong="H3605"\w* su \w ganado|strong="H4735"\w*, y \w todo|strong="H3605"\w* cuanto había adquirido, \w el|strong="H3605"\w* \w ganado|strong="H4735"\w* de su ganancia \w que|strong="H3605"\w* había obtenido en Padán Aram, para ir \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* su padre en \w la|strong="H3605"\w* tierra de \w Canaán|strong="H3667"\w*.  
\v 19 \w Y|strong="H3068"\w* \w Labán|strong="H3837"\w* había ido \w a|strong="H3068"\w* trasquilar sus \w ovejas|strong="H6629"\w*; y Raquel \w hurtó|strong="H1589"\w* los terafines\f + \fr 31:19 \ft Los terafines eran ídolos domésticos que podían estar asociados a los derechos de herencia de los bienes del hogar.\f* de su padre.   
\p
\v 20 \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* engañó \w a|strong="H3068"\w* \w Labán|strong="H3837"\w* arameo, \w no|strong="H1097"\w* haciéndole \w saber|strong="H5046"\w* \w que|strong="H3588"\w* \w se|strong="H1931"\w* iba.  
\v 21 \w Huyó|strong="H1272"\w*, \w pues|strong="H1931"\w*, con \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w tenía|strong="H1931"\w*; y \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* y \w pasó|strong="H5674"\w* \w el|strong="H1931"\w* \w río|strong="H5104"\w*, y \w se|strong="H1931"\w* dirigió al \w monte|strong="H2022"\w* \w de|strong="H6440"\w* \w Galaad|strong="H1568"\w*.   
\p
\v 22 \w Y|strong="H3068"\w* al tercer \w día|strong="H3117"\w* fue dicho \w a|strong="H3068"\w* \w Labán|strong="H3837"\w* \w que|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w había|strong="H3588"\w* huido.  
\v 23 \w Entonces|strong="H3117"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* sus parientes \w consigo|strong="H5973"\w*, y fue \w tras|strong="H5973"\w* \w él|strong="H5973"\w* \w camino|strong="H1870"\w* \w de|strong="H5973"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w*, y \w le|strong="H5973"\w* alcanzó \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w monte|strong="H2022"\w* \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w*.  
\v 24 \w Y|strong="H3068"\w* vino Dios \w a|strong="H3068"\w* \w Labán|strong="H3837"\w* arameo \w en|strong="H5973"\w* \w sueños|strong="H2472"\w* aquella \w noche|strong="H3915"\w*, \w y|strong="H5704"\w* \w le|strong="H5973"\w* \w dijo|strong="H1696"\w*: «\w Guárdate|strong="H8104"\w* \w que|strong="H5704"\w* \w no|strong="H6435"\w* \w hables|strong="H1696"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w descomedidamente|strong="H2896"\w*».   
\p
\v 25 \w Alcanzó|strong="H5381"\w*, pues, \w Labán|strong="H3837"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*; y éste había fijado su tienda en el \w monte|strong="H2022"\w*; y \w Labán|strong="H3837"\w* acampó con sus parientes en el \w monte|strong="H2022"\w* de \w Galaad|strong="H1568"\w*.  
\v 26 \w Y|strong="H3068"\w* dijo \w Labán|strong="H3837"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: “¿\w Qué|strong="H4100"\w* has \w hecho|strong="H6213"\w*, \w que|strong="H4100"\w* me engañaste, y has traído \w a|strong="H3068"\w* mis \w hijas|strong="H1323"\w* \w como|strong="H4100"\w* cautivas de guerra?  
\v 27 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* te escondiste para huir, y me engañaste, y \w no|strong="H3808"\w* me \w lo|strong="H4100"\w* hiciste \w saber|strong="H5046"\w* para \w que|strong="H4100"\w* yo te despidiera con \w alegría|strong="H8057"\w* y con cantares, con tamboril y \w arpa|strong="H3658"\w*?  
\v 28 \w Pues|strong="H6258"\w* \w ni|strong="H3808"\w* \w aun|strong="H6258"\w* me \w dejaste|strong="H5203"\w* \w besar|strong="H5401"\w* \w a|strong="H3068"\w* mis \w hijos|strong="H1121"\w* y \w a|strong="H3068"\w* mis \w hijas|strong="H1323"\w*. \w Ahora|strong="H6258"\w*, \w locamente|strong="H5528"\w* has \w hecho|strong="H6213"\w*.  
\v 29 \w Poder|strong="H3027"\w* \w hay|strong="H3426"\w* \w en|strong="H5973"\w* mi \w mano|strong="H3027"\w* \w para|strong="H5704"\w* \w haceros|strong="H6213"\w* \w mal|strong="H7451"\w*; \w mas|strong="H5704"\w* \w el|strong="H5973"\w* Dios \w de|strong="H5973"\w* \w tu|strong="H6213"\w* padre \w me|strong="H5973"\w* \w habló|strong="H1696"\w* anoche \w diciendo|strong="H1696"\w*: ‘\w Guárdate|strong="H8104"\w* \w que|strong="H5704"\w* \w no|strong="H6213"\w* \w hables|strong="H1696"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w descomedidamente|strong="H2896"\w*’.  
\v 30 \w Y|strong="H3068"\w* \w ya|strong="H6258"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* \w ibas|strong="H1980"\w*, \w porque|strong="H3588"\w* tenías deseo \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* tu padre, ¿\w por|strong="H3588"\w* \w qué|strong="H3588"\w* \w me|strong="H3588"\w* hurtaste mis dioses?”   
\p
\v 31 \w Respondió|strong="H6030"\w* \w Jacob|strong="H3290"\w* \w y|strong="H3588"\w* dijo \w a|strong="H3068"\w* \w Labán|strong="H3837"\w*: «\w Porque|strong="H3588"\w* tuve \w miedo|strong="H3372"\w*; \w pues|strong="H3588"\w* pensé \w que|strong="H3588"\w* \w quizá|strong="H6435"\w* \w me|strong="H3588"\w* \w quitarías|strong="H1497"\w* \w por|strong="H3588"\w* fuerza \w a|strong="H3068"\w* tus \w hijas|strong="H1323"\w*.  
\v 32 Aquel \w en|strong="H5973"\w* cuyo poder \w hallares|strong="H4672"\w* tus dioses, \w no|strong="H3808"\w* \w viva|strong="H2421"\w*; \w delante|strong="H5048"\w* \w de|strong="H3588"\w* nuestros hermanos \w reconoce|strong="H5234"\w* \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* tenga tuyo, \w y|strong="H3588"\w* llévatelo». \w Jacob|strong="H3290"\w* \w no|strong="H3808"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* Raquel \w los|strong="H5973"\w* \w había|strong="H4672"\w* \w hurtado|strong="H1589"\w*.   
\p
\v 33 Entró \w Labán|strong="H3837"\w* \w en|strong="H3318"\w* la tienda de \w Jacob|strong="H3290"\w*, \w en|strong="H3318"\w* la tienda de \w Lea|strong="H3812"\w*, y \w en|strong="H3318"\w* la tienda de las \w dos|strong="H8147"\w* \w siervas|strong="H8147"\w*, y \w no|strong="H3808"\w* los \w halló|strong="H4672"\w*; y \w salió|strong="H3318"\w* de la tienda de \w Lea|strong="H3812"\w*, y entró \w en|strong="H3318"\w* la tienda de Raquel.  
\v 34 Pero \w tomó|strong="H3947"\w* Raquel \w los|strong="H3427"\w* terafines \w y|strong="H5921"\w* \w los|strong="H3427"\w* \w puso|strong="H7760"\w* \w en|strong="H5921"\w* \w una|strong="H4672"\w* albarda \w de|strong="H5921"\w* un \w camello|strong="H1581"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* sentó \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*; \w y|strong="H5921"\w* buscó \w Labán|strong="H3837"\w* \w en|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tienda, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w los|strong="H3427"\w* \w halló|strong="H4672"\w*.  
\v 35 \w Y|strong="H3068"\w* ella dijo \w a|strong="H3068"\w* \w su|strong="H3588"\w* padre: «\w No|strong="H3808"\w* \w se|strong="H3808"\w* enoje mi señor, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* \w puedo|strong="H3201"\w* \w levantar|strong="H6965"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti; \w pues|strong="H3588"\w* estoy \w con|strong="H3588"\w* \w la|strong="H3588"\w* costumbre \w de|strong="H3588"\w* las mujeres». \w Y|strong="H3068"\w* \w él|strong="H3588"\w* buscó, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w halló|strong="H4672"\w* \w los|strong="H3588"\w* terafines.   
\p
\v 36 \w Entonces|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w se|strong="H4100"\w* enojó, \w y|strong="H3588"\w* riñó \w con|strong="H3588"\w* \w Labán|strong="H3837"\w*; \w y|strong="H3588"\w* \w respondió|strong="H6030"\w* \w Jacob|strong="H3290"\w* \w y|strong="H3588"\w* dijo \w a|strong="H3068"\w* \w Labán|strong="H3837"\w*: «¿\w Qué|strong="H3588"\w* transgresión \w es|strong="H3588"\w* \w la|strong="H3588"\w* mía? ¿\w Cuál|strong="H4100"\w* \w es|strong="H3588"\w* \w mi|strong="H6030"\w* \w pecado|strong="H2403"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w con|strong="H3588"\w* tanto ardor hayas venido \w en|strong="H3588"\w* \w mi|strong="H6030"\w* persecución?  
\v 37 \w Pues|strong="H3588"\w* \w que|strong="H3588"\w* has buscado \w en|strong="H3588"\w* \w todas|strong="H3605"\w* mis \w cosas|strong="H8147"\w*, ¿\w qué|strong="H3588"\w* has \w hallado|strong="H4672"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w enseres|strong="H3627"\w* \w de|strong="H3588"\w* tu \w casa|strong="H1004"\w*? \w Ponlo|strong="H7760"\w* \w aquí|strong="H3541"\w* \w delante|strong="H5048"\w* \w de|strong="H3588"\w* mis hermanos \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w tuyos|strong="H1004"\w*, \w y|strong="H3588"\w* juzguen \w entre|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w dos|strong="H8147"\w*.   
\p
\v 38 \w Estos|strong="H2088"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* he estado \w contigo|strong="H5973"\w*; tus \w ovejas|strong="H6629"\w* y tus \w cabras|strong="H5795"\w* \w no|strong="H3808"\w* han abortado, \w ni|strong="H3808"\w* yo comí carnero \w de|strong="H5973"\w* tus \w ovejas|strong="H6629"\w*.  
\v 39 \w Nunca|strong="H3808"\w* te traje \w lo|strong="H3808"\w* arrebatado \w por|strong="H3027"\w* las fieras: yo pagaba el daño; \w lo|strong="H3808"\w* \w hurtado|strong="H1589"\w* así de \w día|strong="H3117"\w* como de \w noche|strong="H3915"\w*, \w a|strong="H3068"\w* \w mí|strong="H1245"\w* me \w lo|strong="H3808"\w* cobrabas.  
\v 40 \w De|strong="H5869"\w* \w día|strong="H3117"\w* me consumía el calor, y \w de|strong="H5869"\w* \w noche|strong="H3915"\w* la helada, y el \w sueño|strong="H8142"\w* huía \w de|strong="H5869"\w* mis \w ojos|strong="H5869"\w*.  
\v 41 \w Así|strong="H2088"\w* he estado \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* en tu \w casa|strong="H1004"\w*; catorce \w años|strong="H8141"\w* te serví \w por|strong="H2088"\w* tus \w dos|strong="H8147"\w* \w hijas|strong="H1323"\w*, y \w seis|strong="H8337"\w* \w años|strong="H8141"\w* \w por|strong="H2088"\w* tu \w ganado|strong="H6629"\w*, y has cambiado mi \w salario|strong="H4909"\w* \w diez|strong="H6235"\w* \w veces|strong="H4489"\w*.  
\v 42 \w Si|strong="H3588"\w* \w el|strong="H3588"\w* Dios \w de|strong="H3588"\w* \w mi|strong="H1961"\w* padre, Dios \w de|strong="H3588"\w* Abraham \w y|strong="H3588"\w* \w temor|strong="H6343"\w* \w de|strong="H3588"\w* \w Isaac|strong="H3327"\w*, \w no|strong="H3884"\w* estuviera conmigo, \w de|strong="H3588"\w* \w cierto|strong="H3588"\w* \w me|strong="H3588"\w* enviarías \w ahora|strong="H6258"\w* \w con|strong="H3588"\w* las \w manos|strong="H3709"\w* \w vacías|strong="H7387"\w*; \w vio|strong="H7200"\w* Dios \w mi|strong="H1961"\w* \w aflicción|strong="H6040"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w trabajo|strong="H3018"\w* \w de|strong="H3588"\w* mis \w manos|strong="H3709"\w*, \w y|strong="H3588"\w* \w te|strong="H3588"\w* reprendió anoche».   
\p
\v 43 \w Respondió|strong="H6030"\w* \w Labán|strong="H3837"\w* y dijo \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: «Las \w hijas|strong="H1323"\w* son \w hijas|strong="H1323"\w* mías, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w*, \w hijos|strong="H1121"\w* míos son, y las \w ovejas|strong="H6629"\w* son mis \w ovejas|strong="H6629"\w*, y \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H4100"\w* \w tú|strong="H6213"\w* \w ves|strong="H7200"\w* \w es|strong="H1931"\w* mío. ¿\w Y|strong="H3068"\w* \w qué|strong="H4100"\w* puedo \w yo|strong="H6213"\w* \w hacer|strong="H6213"\w* \w hoy|strong="H3117"\w* \w a|strong="H3068"\w* \w estas|strong="H6213"\w* mis \w hijas|strong="H1323"\w*, \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* \w que|strong="H4100"\w* \w ellas|strong="H1931"\w* han dado \w a|strong="H3068"\w* luz?  
\v 44 \w Ven|strong="H3212"\w* \w pues|strong="H6258"\w* \w ahora|strong="H6258"\w*, y hagamos \w pacto|strong="H1285"\w* tú y yo, y \w sea|strong="H1961"\w* por \w testimonio|strong="H5707"\w* entre nosotros dos».   
\p
\v 45 Entonces \w Jacob|strong="H3290"\w* \w tomó|strong="H3947"\w* una piedra, y la levantó por señal.  
\v 46 \w Y|strong="H3068"\w* dijo \w Jacob|strong="H3290"\w* \w a|strong="H3068"\w* sus hermanos: «Recoged piedras». \w Y|strong="H3068"\w* \w tomaron|strong="H3947"\w* piedras \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* un \w majano|strong="H1530"\w*, \w y|strong="H5921"\w* comieron \w allí|strong="H8033"\w* \w sobre|strong="H5921"\w* \w aquel|strong="H6213"\w* \w majano|strong="H1530"\w*.  
\v 47 \w Y|strong="H3068"\w* lo \w llamó|strong="H7121"\w* \w Labán|strong="H3837"\w* Jegar Sahaduta,\f + \fr 31:47 \ft «Jegar Sahaduta» significa «Majano de Testimonio» en arameo.\f* y \w Jacob|strong="H3290"\w* lo \w llamó|strong="H7121"\w* \w Galaad|strong="H1567"\w*.\f + \fr 31:47 \ft «Galaad» significa «Majano de Testimonio» en hebreo.\f*  
\v 48 \w Porque|strong="H5921"\w* \w Labán|strong="H3837"\w* dijo: «\w Este|strong="H2088"\w* \w majano|strong="H1530"\w* \w es|strong="H2088"\w* \w testigo|strong="H5707"\w* \w hoy|strong="H3117"\w* \w entre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w dos|strong="H3117"\w*»; \w por|strong="H5921"\w* \w eso|strong="H3651"\w* fue \w llamado|strong="H8034"\w* su \w nombre|strong="H8034"\w* \w Galaad|strong="H1530"\w*;  
\v 49 \w y|strong="H3588"\w* \w Mizpa|strong="H4709"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* dijo: «Vigile Yahvé \w entre|strong="H3588"\w* tú \w y|strong="H3588"\w* \w yo|strong="H3588"\w*, \w cuando|strong="H3588"\w* nos apartemos \w el|strong="H3588"\w* uno del \w otro|strong="H7453"\w*.  
\v 50 \w Si|strong="H5921"\w* \w afligieres|strong="H6031"\w* \w a|strong="H3068"\w* mis \w hijas|strong="H1323"\w*, \w o|strong="H3068"\w* \w si|strong="H5921"\w* \w tomares|strong="H3947"\w* otras \w mujeres|strong="H1323"\w* \w además|strong="H5921"\w* \w de|strong="H5921"\w* mis \w hijas|strong="H1323"\w*, nadie \w está|strong="H5921"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*; \w mira|strong="H7200"\w*, Dios es \w testigo|strong="H5707"\w* \w entre|strong="H5921"\w* \w nosotros|strong="H5973"\w* dos».  
\v 51 Dijo más \w Labán|strong="H3837"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: «He \w aquí|strong="H2088"\w* \w este|strong="H2088"\w* \w majano|strong="H1530"\w*, y he \w aquí|strong="H2088"\w* \w esta|strong="H2088"\w* señal, \w que|strong="H2088"\w* he erigido entre tú y \w yo|strong="H2009"\w*.  
\v 52 \w Testigo|strong="H5707"\w* sea \w este|strong="H2088"\w* \w majano|strong="H1530"\w*, y \w testigo|strong="H5707"\w* sea \w esta|strong="H2063"\w* señal, \w que|strong="H3808"\w* \w ni|strong="H3808"\w* yo \w pasaré|strong="H5674"\w* \w de|strong="H7451"\w* \w este|strong="H2088"\w* \w majano|strong="H1530"\w* contra ti, \w ni|strong="H3808"\w* tú \w pasarás|strong="H5674"\w* \w de|strong="H7451"\w* \w este|strong="H2088"\w* \w majano|strong="H1530"\w* \w ni|strong="H3808"\w* \w de|strong="H7451"\w* \w esta|strong="H2063"\w* señal contra mí, para \w mal|strong="H7451"\w*.  
\v 53 El Dios de Abraham y el Dios de Nacor \w juzgue|strong="H8199"\w* entre nosotros, el Dios de sus padres». \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w juró|strong="H7650"\w* por el \w temor|strong="H6343"\w* de \w Isaac|strong="H3327"\w* su padre.  
\v 54 Entonces \w Jacob|strong="H3290"\w* \w inmoló|strong="H2077"\w* \w víctimas|strong="H2076"\w* en \w el|strong="H3885"\w* \w monte|strong="H2022"\w*, y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* sus hermanos \w a|strong="H3068"\w* comer \w pan|strong="H3899"\w*; y comieron \w pan|strong="H3899"\w*, y durmieron aquella noche en \w el|strong="H3885"\w* \w monte|strong="H2022"\w*.  
\v 55 \w Y|strong="H3068"\w* se levantó Labán de mañana, y besó sus hijos y sus hijas, y los bendijo; y regresó y se volvió \w a|strong="H3068"\w* su lugar.   
\c 32
\p
\v 1 Jacob \w siguió|strong="H3212"\w* su camino, y \w le|strong="H1242"\w* salieron al encuentro ángeles \w de|strong="H1121"\w* Dios.  
\v 2 \w Y|strong="H3068"\w* dijo \w Jacob|strong="H3290"\w* cuando los vio: «Campamento de Dios es este». \w Y|strong="H3068"\w* llamó el nombre de aquel lugar Mahanaim.\f + \fr 32:2 \ft «Mahanaim» significa «dos campamentos».\f*   
\p
\v 3 \w Y|strong="H3068"\w* envió \w Jacob|strong="H3290"\w* mensajeros \w delante|strong="H1931"\w* de \w sí|strong="H1931"\w* \w a|strong="H3068"\w* Esaú \w su|strong="H1931"\w* hermano, \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra de Seir, \w campo|strong="H4264"\w* de Edom.  
\v 4 \w Y|strong="H3068"\w* les \w mandó|strong="H7971"\w* diciendo: “Así diréis \w a|strong="H3068"\w* mi señor \w Esaú|strong="H6215"\w*: ‘Así dice tu siervo \w Jacob|strong="H3290"\w*: Con Labán he morado como forastero, y me he detenido hasta ahora;  
\v 5 \w y|strong="H5704"\w* tengo vacas, asnos, ovejas, \w y|strong="H5704"\w* \w siervos|strong="H5650"\w* \w y|strong="H5704"\w* siervas; \w y|strong="H5704"\w* \w envío|strong="H6680"\w* \w a|strong="H3068"\w* decirlo \w a|strong="H3068"\w* mi señor, \w para|strong="H5704"\w* hallar gracia \w en|strong="H5973"\w* tus ojos’”.  
\v 6 \w Y|strong="H3068"\w* \w los|strong="H1961"\w* mensajeros volvieron \w a|strong="H3068"\w* Jacob, diciendo: «\w Fuimos|strong="H1961"\w* \w a|strong="H3068"\w* tu hermano Esaú, \w y|strong="H7794"\w* él también viene \w a|strong="H3068"\w* recibirte, \w y|strong="H7794"\w* cuatrocientos hombres con él».  
\v 7 \w Entonces|strong="H7725"\w* \w Jacob|strong="H3290"\w* tuvo mucho miedo, \w y|strong="H1571"\w* se angustió; \w y|strong="H1571"\w* dividió \w el|strong="H5973"\w* \w pueblo|strong="H5973"\w* \w que|strong="H1571"\w* tenía \w consigo|strong="H5973"\w*, \w y|strong="H1571"\w* las ovejas \w y|strong="H1571"\w* las vacas \w y|strong="H1571"\w* \w los|strong="H5973"\w* camellos, \w en|strong="H5973"\w* dos campamentos.  
\v 8 \w Y|strong="H3068"\w* dijo: «Si viene Esaú contra un \w campamento|strong="H4264"\w* \w y|strong="H1241"\w* lo ataca, \w el|strong="H4264"\w* otro \w campamento|strong="H4264"\w* escapará».  
\v 9 \w Y|strong="H3068"\w* dijo Jacob: “Dios de \w mi|strong="H1961"\w* padre Abraham, y Dios de \w mi|strong="H1961"\w* padre Isaac, Yahvé, \w que|strong="H1961"\w* me dijiste: ‘Vuélvete \w a|strong="H3068"\w* tu tierra y \w a|strong="H3068"\w* tu parentela, y yo te haré bien’;  
\v 10 menor soy que todas las misericordias y que toda la verdad que has usado \w para|strong="H5973"\w* \w con|strong="H5973"\w* tu siervo; pues \w con|strong="H5973"\w* mi bordón pasé este Jordán, y ahora estoy sobre dos campamentos.  
\v 11 Líbrame \w ahora|strong="H6258"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* mano \w de|strong="H3588"\w* \w mi|strong="H1961"\w* hermano, \w de|strong="H3588"\w* \w la|strong="H3588"\w* mano \w de|strong="H3588"\w* Esaú, \w porque|strong="H3588"\w* le temo; \w no|strong="H6213"\w* \w venga|strong="H1961"\w* acaso \w y|strong="H3588"\w* \w me|strong="H3588"\w* hiera \w la|strong="H3588"\w* madre \w con|strong="H3588"\w* \w los|strong="H3605"\w* hijos.  
\v 12 \w Y|strong="H3068"\w* tú has dicho: ‘\w Yo|strong="H3588"\w* \w te|strong="H5921"\w* haré \w bien|strong="H3588"\w*, \w y|strong="H3588"\w* haré tu descendencia \w como|strong="H3588"\w* \w la|strong="H5921"\w* arena \w del|strong="H5921"\w* mar, \w que|strong="H3588"\w* \w no|strong="H6435"\w* \w se|strong="H5921"\w* puede contar \w por|strong="H5921"\w* \w la|strong="H5921"\w* multitud’”.   
\p
\v 13 \w Y|strong="H3068"\w* durmió allí aquella noche, y tomó \w de|strong="H5973"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w le|strong="H5973"\w* vino \w a|strong="H3068"\w* la mano un presente \w para|strong="H5973"\w* su hermano Esaú:  
\v 14 doscientas cabras y veinte machos cabríos, doscientas ovejas y veinte carneros,  
\v 15 treinta camellas paridas con sus crías, cuarenta vacas y diez novillos, \w veinte|strong="H6242"\w* asnas y diez borriquillos.  
\v 16 \w Y|strong="H3068"\w* lo entregó en mano \w de|strong="H1121"\w* sus siervos, \w cada|strong="H6235"\w* manada \w de|strong="H1121"\w* por sí; y dijo \w a|strong="H3068"\w* sus siervos: «Pasad delante \w de|strong="H1121"\w* mí, y poned espacio entre manada y manada».  
\v 17 \w Y|strong="H3068"\w* mandó al primero, diciendo: “\w Si|strong="H6440"\w* Esaú mi hermano te encontrare, y te preguntare, diciendo: ‘¿\w De|strong="H6440"\w* quién eres? ¿y adónde vas? ¿y \w para|strong="H5414"\w* quién \w es|strong="H3027"\w* esto \w que|strong="H3027"\w* llevas \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti?’  
\v 18 \w entonces|strong="H3588"\w* diréis: ‘\w Es|strong="H3588"\w* un presente \w de|strong="H3588"\w* tu siervo Jacob, \w que|strong="H3588"\w* \w envía|strong="H6680"\w* \w a|strong="H3068"\w* mi señor \w Esaú|strong="H6215"\w*; \w y|strong="H3588"\w* he aquí también \w él|strong="H3588"\w* viene tras nosotros’”.  
\v 19 \w Mandó|strong="H7971"\w* \w también|strong="H1571"\w* al segundo, \w y|strong="H1571"\w* al tercero, \w y|strong="H1571"\w* \w a|strong="H3068"\w* todos \w los|strong="H1931"\w* \w que|strong="H1931"\w* iban tras aquellas manadas, diciendo: “\w Conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w esto|strong="H1931"\w* hablaréis \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w*, \w cuando|strong="H1571"\w* \w le|strong="H1931"\w* hallareis.  
\v 20 \w Y|strong="H3068"\w* diréis \w también|strong="H1571"\w*: ‘He \w aquí|strong="H2088"\w* tu siervo Jacob \w viene|strong="H1980"\w* tras \w nosotros|strong="H3605"\w*’”. Porque \w dijo|strong="H1696"\w*: «Le apaciguaré \w con|strong="H1571"\w* \w el|strong="H3605"\w* presente \w que|strong="H1571"\w* \w va|strong="H3068"\w* delante \w de|strong="H1697"\w* mí, \w y|strong="H1571"\w* \w después|strong="H8145"\w* veré su rostro; quizá le seré acepto».   
\p
\v 21 Pasó, \w pues|strong="H3588"\w*, \w el|strong="H3588"\w* \w presente|strong="H4503"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*; \w y|strong="H1571"\w* \w él|strong="H3588"\w* durmió aquella noche \w en|strong="H3588"\w* \w el|strong="H3588"\w* campamento.   
\p
\v 22 \w Y|strong="H3068"\w* \w se|strong="H1931"\w* levantó \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*, \w y|strong="H5921"\w* tomó \w sus|strong="H1931"\w* \w dos|strong="H6440"\w* mujeres, \w y|strong="H5921"\w* \w sus|strong="H1931"\w* \w dos|strong="H6440"\w* siervas, \w y|strong="H5921"\w* \w sus|strong="H1931"\w* once hijos, \w y|strong="H5921"\w* \w pasó|strong="H5674"\w* \w el|strong="H1931"\w* vado \w de|strong="H5921"\w* Jaboc.  
\v 23 \w Los|strong="H1931"\w* \w tomó|strong="H3947"\w*, \w pues|strong="H1931"\w*, \w e|strong="H3068"\w* hizo \w pasar|strong="H5674"\w* \w el|strong="H1931"\w* arroyo \w a|strong="H3068"\w* \w ellos|strong="H1931"\w* y \w a|strong="H3068"\w* todo \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w tenía|strong="H1931"\w*.  
\v 24 Así se quedó Jacob solo; y luchó con \w él|strong="H5674"\w* un varón hasta que rayaba \w el|strong="H5674"\w* alba.  
\v 25 \w Y|strong="H3068"\w* \w cuando|strong="H5704"\w* \w el|strong="H5973"\w* varón vio \w que|strong="H5704"\w* no podía \w con|strong="H5973"\w* \w él|strong="H5973"\w*, tocó \w en|strong="H5973"\w* \w el|strong="H5973"\w* sitio \w del|strong="H5973"\w* encaje \w de|strong="H5973"\w* su muslo, \w y|strong="H5704"\w* se descoyuntó \w el|strong="H5973"\w* muslo \w de|strong="H5973"\w* \w Jacob|strong="H3290"\w* \w mientras|strong="H5704"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* luchaba.  
\v 26 \w Y|strong="H3068"\w* dijo: «Déjame, \w porque|strong="H3588"\w* raya \w el|strong="H5973"\w* alba».  
\p \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w le|strong="H5973"\w* respondió: «\w No|strong="H3808"\w* \w te|strong="H3588"\w* dejaré, \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* bendices».   
\p
\v 27 \w Y|strong="H3068"\w* \w el|strong="H3588"\w* varón le dijo: «¿\w Cuál|strong="H3588"\w* \w es|strong="H3588"\w* tu nombre?»  
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: «Jacob».   
\p
\v 28 \w Y|strong="H3068"\w* el varón le dijo: «\w No|strong="H4100"\w* \w se|strong="H4100"\w* dirá más tu \w nombre|strong="H8034"\w* \w Jacob|strong="H3290"\w*, sino Israel; \w porque|strong="H4100"\w* has luchado con Dios y con los hombres, y has vencido».   
\p
\v 29 \w Entonces|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w le|strong="H5973"\w* preguntó, \w y|strong="H3588"\w* dijo: «Declárame ahora tu \w nombre|strong="H8034"\w*».  
\p \w Y|strong="H3068"\w* \w el|strong="H5973"\w* varón respondió: «¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w me|strong="H3588"\w* preguntas \w por|strong="H3588"\w* mi \w nombre|strong="H8034"\w*?» \w Y|strong="H3068"\w* \w lo|strong="H3808"\w* bendijo allí.   
\p
\v 30 \w Y|strong="H3068"\w* \w llamó|strong="H8034"\w* \w Jacob|strong="H3290"\w* el \w nombre|strong="H8034"\w* de \w aquel|strong="H2088"\w* lugar, Peniel;\f + \fr 32:30 \ft Peniel significa «rostro de Dios».\f* \w porque|strong="H4100"\w* \w dijo|strong="H5046"\w*: «Vi \w a|strong="H3068"\w* Dios cara \w a|strong="H3068"\w* cara, y fue librada \w mi|strong="H4994"\w* alma».  
\v 31 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w había|strong="H3588"\w* pasado \w Peniel|strong="H6439"\w*, le salió \w el|strong="H3588"\w* sol; \w y|strong="H3588"\w* cojeaba \w de|strong="H3588"\w* \w su|strong="H3588"\w* cadera.  
\v 32 \w Por|strong="H5921"\w* \w esto|strong="H1931"\w* \w no|strong="H5921"\w* comen \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* Israel, \w hasta|strong="H5921"\w* hoy día, \w del|strong="H5921"\w* nervio \w que|strong="H1931"\w* \w se|strong="H1931"\w* encogió, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* encaje \w del|strong="H5921"\w* \w muslo|strong="H3409"\w*; \w porque|strong="H5921"\w* tocó \w a|strong="H3068"\w* Jacob \w este|strong="H1931"\w* sitio \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w muslo|strong="H3409"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* nervio \w que|strong="H1931"\w* \w se|strong="H1931"\w* encogió.   
\c 33
\p
\v 1 \w Alzó|strong="H5375"\w* \w Jacob|strong="H3290"\w* sus \w ojos|strong="H5869"\w* \w y|strong="H5921"\w* \w miró|strong="H7200"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* venía \w Esaú|strong="H6215"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* cuatrocientos \w hombres|strong="H8147"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w*; entonces repartió \w él|strong="H5921"\w* \w los|strong="H5921"\w* \w niños|strong="H3206"\w* \w entre|strong="H5921"\w* \w Lea|strong="H3812"\w* \w y|strong="H5921"\w* Raquel \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w siervas|strong="H8198"\w*.  
