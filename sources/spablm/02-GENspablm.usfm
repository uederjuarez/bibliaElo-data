\p
\v 3 \w Y|strong="H3068"\w* Abraham se \w levantó|strong="H6965"\w* muy \w de|strong="H1121"\w* \w mañana|strong="H1242"\w*, ensilló su \w asno|strong="H2543"\w*, y \w tomó|strong="H3947"\w* consigo \w a|strong="H3068"\w* \w dos|strong="H8147"\w* \w de|strong="H1121"\w* sus \w mozos|strong="H5288"\w* y \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* su \w hijo|strong="H1121"\w*; y \w cortó|strong="H1234"\w* \w leña|strong="H6086"\w* para \w el|strong="H1121"\w* \w holocausto|strong="H5930"\w*, y se \w levantó|strong="H6965"\w* y \w fue|strong="H3212"\w* \w al|strong="H5930"\w* \w lugar|strong="H4725"\w* \w que|strong="H1121"\w* Dios \w le|strong="H1242"\w* había dicho.  
\v 4 Al tercer \w día|strong="H3117"\w* \w alzó|strong="H5375"\w* Abraham sus \w ojos|strong="H5869"\w* y \w vio|strong="H7200"\w* el \w lugar|strong="H4725"\w* \w de|strong="H5869"\w* \w lejos|strong="H7350"\w*.  
