\v 16 \w Así|strong="H1931"\w* \w volvió|strong="H7725"\w* \w Esaú|strong="H6215"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w por|strong="H1870"\w* \w su|strong="H1931"\w* \w camino|strong="H1870"\w* \w a|strong="H3068"\w* \w Seir|strong="H8165"\w*.  
