\p
\v 1 Entonces \w José|strong="H3130"\w* \w se|strong="H5921"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w rostro|strong="H6440"\w* \w de|strong="H5921"\w* su padre, \w y|strong="H5921"\w* \w lloró|strong="H1058"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w besó|strong="H5401"\w*.  
