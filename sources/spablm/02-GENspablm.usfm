\v 13 pues \w lo|strong="H5921"\w* \w llevaron|strong="H5375"\w* sus \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cueva|strong="H4631"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w de|strong="H5921"\w* Macpela, \w la|strong="H5921"\w* \w que|strong="H5921"\w* había \w comprado|strong="H7069"\w* Abraham \w con|strong="H5921"\w* \w el|strong="H5921"\w* mismo \w campo|strong="H7704"\w*, \w para|strong="H5921"\w* \w heredad|strong="H7704"\w* \w de|strong="H5921"\w* \w sepultura|strong="H6913"\w*, \w de|strong="H5921"\w* Efrón \w el|strong="H5921"\w* heteo, \w al|strong="H5921"\w* oriente \w de|strong="H5921"\w* \w Mamre|strong="H4471"\w*.  
\v 14 \w Y|strong="H3068"\w* \w volvió|strong="H7725"\w* \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, \w él|strong="H1931"\w* y \w sus|strong="H1931"\w* hermanos, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H1931"\w* \w subieron|strong="H5927"\w* con \w él|strong="H1931"\w* \w a|strong="H3068"\w* sepultar \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre, después \w que|strong="H1931"\w* \w lo|strong="H1931"\w* \w hubo|strong="H5927"\w* \w sepultado|strong="H6912"\w*.   
\p
\v 15 \w Viendo|strong="H7200"\w* \w los|strong="H3605"\w* hermanos \w de|strong="H3588"\w* \w José|strong="H3130"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* padre era \w muerto|strong="H4191"\w*, dijeron: «\w Quizá|strong="H3863"\w* nos \w aborrecerá|strong="H7852"\w* \w José|strong="H3130"\w*, \w y|strong="H3588"\w* nos \w dará|strong="H7725"\w* \w el|strong="H3588"\w* \w pago|strong="H1580"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w* \w que|strong="H3588"\w* le hicimos».  
\v 16 \w Y|strong="H3068"\w* enviaron \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w José|strong="H3130"\w*: “Tu padre \w mandó|strong="H6680"\w* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* su \w muerte|strong="H4194"\w*, diciendo:  
\v 17 ‘\w Así|strong="H3541"\w* diréis \w a|strong="H3068"\w* \w José|strong="H3130"\w*: «\w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w perdones|strong="H5375"\w* \w ahora|strong="H6258"\w* \w la|strong="H3588"\w* \w maldad|strong="H7451"\w* \w de|strong="H3588"\w* tus hermanos \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w pecado|strong="H2403"\w*, \w porque|strong="H3588"\w* \w mal|strong="H7451"\w* \w te|strong="H3588"\w* trataron»’. \w Por|strong="H3588"\w* tanto, \w ahora|strong="H6258"\w* \w te|strong="H3588"\w* rogamos \w que|strong="H3588"\w* \w perdones|strong="H5375"\w* \w la|strong="H3588"\w* \w maldad|strong="H7451"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w siervos|strong="H5650"\w* del Dios \w de|strong="H3588"\w* tu padre”. \w Y|strong="H3068"\w* \w José|strong="H3130"\w* \w lloró|strong="H1058"\w* \w mientras|strong="H3588"\w* \w hablaban|strong="H1696"\w* \w con|strong="H3588"\w* \w él|strong="H3588"\w*.  
\v 18 Vinieron \w también|strong="H1571"\w* sus hermanos \w y|strong="H1571"\w* se postraron \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H5307"\w*, \w y|strong="H1571"\w* dijeron: «Henos \w aquí|strong="H2009"\w* \w por|strong="H6440"\w* \w siervos|strong="H5650"\w* tuyos».  
\v 19 \w Y|strong="H3068"\w* les respondió \w José|strong="H3130"\w*: «\w No|strong="H3588"\w* \w temáis|strong="H3372"\w*; ¿acaso estoy \w yo|strong="H3588"\w* \w en|strong="H3588"\w* \w lugar|strong="H8478"\w* \w de|strong="H3588"\w* Dios?  
\v 20 Vosotros \w pensasteis|strong="H2803"\w* \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*, \w mas|strong="H5921"\w* Dios \w lo|strong="H2088"\w* encaminó \w a|strong="H3068"\w* \w bien|strong="H2896"\w*, \w para|strong="H4616"\w* \w hacer|strong="H6213"\w* \w lo|strong="H2088"\w* \w que|strong="H5921"\w* vemos \w hoy|strong="H3117"\w*, \w para|strong="H4616"\w* mantener \w en|strong="H5921"\w* \w vida|strong="H2421"\w* \w a|strong="H3068"\w* \w mucho|strong="H7227"\w* \w pueblo|strong="H5971"\w*.  
\v 21 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w no|strong="H5921"\w* \w temáis|strong="H3372"\w*; yo \w os|strong="H5921"\w* sustentaré \w a|strong="H3068"\w* vosotros \w y|strong="H5921"\w* \w a|strong="H3068"\w* vuestros hijos». \w Y|strong="H3068"\w* \w los|strong="H5921"\w* consoló, \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w habló|strong="H1696"\w* \w al|strong="H5921"\w* \w corazón|strong="H3820"\w*.   
\p
\v 22 \w Y|strong="H3068"\w* \w habitó|strong="H3427"\w* \w José|strong="H3130"\w* en \w Egipto|strong="H4714"\w*, \w él|strong="H1931"\w* y \w la|strong="H1931"\w* \w casa|strong="H1004"\w* de \w su|strong="H1931"\w* padre; y \w vivió|strong="H2421"\w* \w José|strong="H3130"\w* \w ciento|strong="H3967"\w* \w diez|strong="H6235"\w* \w años|strong="H8141"\w*.  
\v 23 \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* \w José|strong="H3130"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Efraín \w hasta|strong="H5921"\w* \w la|strong="H5921"\w* tercera generación; \w también|strong="H1571"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Maquir \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w* fueron criados \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w rodillas|strong="H1290"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*.  
\v 24 \w Y|strong="H3068"\w* \w José|strong="H3130"\w* dijo \w a|strong="H3068"\w* sus hermanos: «\w Yo|strong="H4480"\w* voy \w a|strong="H3068"\w* \w morir|strong="H4191"\w*; \w mas|strong="H4480"\w* Dios \w ciertamente|strong="H4191"\w* \w os|strong="H4480"\w* \w visitará|strong="H6485"\w*, y \w os|strong="H4480"\w* hará \w subir|strong="H5927"\w* \w de|strong="H4480"\w* \w esta|strong="H2063"\w* tierra \w a|strong="H3068"\w* \w la|strong="H2063"\w* tierra \w que|strong="H4480"\w* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* Abraham, \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* y \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*».  
\v 25 \w E|strong="H3068"\w* \w hizo|strong="H5927"\w* jurar \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, diciendo: «Dios \w ciertamente|strong="H6485"\w* os \w visitará|strong="H6485"\w*, y haréis llevar \w de|strong="H1121"\w* \w aquí|strong="H2088"\w* mis \w huesos|strong="H6106"\w*».  
\v 26 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w José|strong="H3130"\w* \w a|strong="H3068"\w* la \w edad|strong="H8141"\w* \w de|strong="H1121"\w* \w ciento|strong="H3967"\w* \w diez|strong="H6235"\w* \w años|strong="H8141"\w*; y lo \w embalsamaron|strong="H2590"\w*, y fue puesto en un ataúd en \w Egipto|strong="H4714"\w*.   