\v 55 Cuando \w se|strong="H5971"\w* sintió \w el|strong="H3605"\w* \w hambre|strong="H7456"\w* \w en|strong="H3212"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*, \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w clamó|strong="H6817"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* por \w pan|strong="H3899"\w*. \w Y|strong="H3068"\w* dijo \w Faraón|strong="H6547"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w egipcios|strong="H4713"\w*: «\w Id|strong="H3212"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*, y \w haced|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H5971"\w* \w él|strong="H3605"\w* os dijere».  
\v 56 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w hambre|strong="H7458"\w* \w estaba|strong="H1961"\w* \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* extensión \w del|strong="H5921"\w* país. Entonces \w abrió|strong="H6605"\w* \w José|strong="H3130"\w* \w todo|strong="H3605"\w* granero \w donde|strong="H5921"\w* \w había|strong="H1961"\w*, \w y|strong="H5921"\w* vendía \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4713"\w*; \w porque|strong="H5921"\w* \w había|strong="H1961"\w* crecido \w el|strong="H5921"\w* \w hambre|strong="H7458"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.  
\v 57 \w Y|strong="H3068"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* países venían \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* \w para|strong="H3588"\w* comprar \w a|strong="H3068"\w* \w José|strong="H3130"\w*, \w porque|strong="H3588"\w* \w por|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra \w había|strong="H3588"\w* crecido \w el|strong="H3588"\w* \w hambre|strong="H7458"\w*.   
\c 42
\p
\v 1 \w Viendo|strong="H7200"\w* \w Jacob|strong="H3290"\w* \w que|strong="H3588"\w* \w había|strong="H3426"\w* provisiones \w en|strong="H3588"\w* \w Egipto|strong="H4714"\w*, dijo \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*: «¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* os estáis mirando unos \w a|strong="H3068"\w* otros?»  
\v 2 \w Y|strong="H3068"\w* dijo: «He \w aquí|strong="H2009"\w*, he \w oído|strong="H8085"\w* \w que|strong="H3588"\w* \w hay|strong="H3426"\w* trigo \w en|strong="H3588"\w* \w Egipto|strong="H4714"\w*; \w descended|strong="H3381"\w* \w allá|strong="H8033"\w*, \w y|strong="H3588"\w* \w comprad|strong="H7666"\w* \w de|strong="H3588"\w* \w allí|strong="H8033"\w* \w para|strong="H3588"\w* nosotros, \w para|strong="H3588"\w* \w que|strong="H3588"\w* podamos \w vivir|strong="H2421"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w muramos|strong="H4191"\w*».  
\v 3 \w Y|strong="H3068"\w* \w descendieron|strong="H3381"\w* los \w diez|strong="H6235"\w* hermanos de \w José|strong="H3130"\w* \w a|strong="H3068"\w* comprar \w trigo|strong="H1250"\w* en \w Egipto|strong="H4714"\w*.  
\v 4 \w Mas|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w no|strong="H3808"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w*, hermano \w de|strong="H3588"\w* \w José|strong="H3130"\w*, \w con|strong="H3588"\w* sus hermanos; \w porque|strong="H3588"\w* dijo: «\w No|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* le acontezca algún desastre».  
\v 5 Vinieron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* comprar \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* venían; \w porque|strong="H3588"\w* \w había|strong="H1961"\w* \w hambre|strong="H7458"\w* \w en|strong="H8432"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w*.  
\v 6 \w Y|strong="H3068"\w* \w José|strong="H3130"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* señor \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra, \w quien|strong="H3605"\w* \w le|strong="H1931"\w* vendía \w el|strong="H1931"\w* trigo \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra; \w y|strong="H5921"\w* llegaron \w los|strong="H5921"\w* hermanos \w de|strong="H5921"\w* \w José|strong="H3130"\w*, \w y|strong="H5921"\w* \w se|strong="H1931"\w* inclinaron \w a|strong="H3068"\w* \w él|strong="H1931"\w* rostro \w a|strong="H3068"\w* tierra.  
\v 7 \w Y|strong="H3068"\w* \w José|strong="H3130"\w*, cuando \w vio|strong="H7200"\w* \w a|strong="H3068"\w* sus hermanos, los \w conoció|strong="H5234"\w*; mas hizo como que no los conocía, y les \w habló|strong="H1696"\w* \w ásperamente|strong="H7186"\w*, y les \w dijo|strong="H1696"\w*: «¿De dónde venís?»  
\p Ellos \w respondieron|strong="H1696"\w*: «De la tierra de \w Canaán|strong="H3667"\w*, para comprar alimentos».   
\p
\v 8 \w José|strong="H3130"\w*, pues, \w conoció|strong="H5234"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanos; pero \w ellos|strong="H1992"\w* \w no|strong="H3808"\w* le \w conocieron|strong="H5234"\w*.  
\v 9 Entonces se acordó \w José|strong="H3130"\w* de los \w sueños|strong="H2472"\w* que había tenido acerca de ellos, y les dijo: «¡\w Espías|strong="H7270"\w* sois! Por \w ver|strong="H7200"\w* lo descubierto del país habéis venido».   
\p
\v 10 Ellos le respondieron: «\w No|strong="H3808"\w*, señor mío, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* tus \w siervos|strong="H5650"\w* han venido \w a|strong="H3068"\w* comprar alimentos.  
\v 11 \w Todos|strong="H3605"\w* \w nosotros|strong="H3605"\w* \w somos|strong="H1961"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* un varón; \w somos|strong="H1961"\w* \w hombres|strong="H1121"\w* honrados; tus \w siervos|strong="H5650"\w* \w nunca|strong="H3808"\w* \w fueron|strong="H1961"\w* \w espías|strong="H7270"\w*».   
\p
\v 12 \w Pero|strong="H3588"\w* \w él|strong="H3588"\w* les dijo: «\w No|strong="H3808"\w*; \w para|strong="H3588"\w* \w ver|strong="H7200"\w* \w lo|strong="H3808"\w* descubierto del país habéis venido».   
\p
\v 13 \w Y|strong="H3068"\w* ellos respondieron: «Tus \w siervos|strong="H5650"\w* somos \w doce|strong="H8147"\w* hermanos, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* un varón en la tierra \w de|strong="H1121"\w* \w Canaán|strong="H3667"\w*; y he \w aquí|strong="H2009"\w* \w el|strong="H1121"\w* \w menor|strong="H6996"\w* está \w hoy|strong="H3117"\w* con nuestro padre, y otro ya no parece».   
\p
\v 14 \w Y|strong="H3068"\w* \w José|strong="H3130"\w* les \w dijo|strong="H1696"\w*: «\w Eso|strong="H1931"\w* \w es|strong="H1931"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* os he \w dicho|strong="H1696"\w*: \w espías|strong="H7270"\w* sois.  
\v 15 \w En|strong="H3588"\w* \w esto|strong="H2063"\w* seréis probados: ¡\w Vive|strong="H2416"\w* \w Faraón|strong="H6547"\w*, \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w saldréis|strong="H3318"\w* \w de|strong="H3588"\w* \w aquí|strong="H2008"\w*, \w sino|strong="H3588"\w* \w cuando|strong="H3588"\w* vuestro hermano \w menor|strong="H6996"\w* viniere \w acá|strong="H2008"\w*!  
\v 16 \w Enviad|strong="H7971"\w* \w a|strong="H3068"\w* uno \w de|strong="H4480"\w* vosotros \w y|strong="H3588"\w* \w traiga|strong="H3947"\w* \w a|strong="H3068"\w* vuestro hermano, \w y|strong="H3588"\w* vosotros quedad presos, \w y|strong="H3588"\w* \w vuestras|strong="H1697"\w* \w palabras|strong="H1697"\w* serán probadas, \w si|strong="H3588"\w* hay verdad \w en|strong="H4480"\w* vosotros; \w y|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w*, ¡\w vive|strong="H2416"\w* \w Faraón|strong="H6547"\w*, \w que|strong="H3588"\w* sois \w espías|strong="H7270"\w*!»  
\v 17 \w Y|strong="H3068"\w* los puso juntos en la \w cárcel|strong="H4929"\w* por \w tres|strong="H7969"\w* \w días|strong="H3117"\w*.   
\p
\v 18 \w Y|strong="H3068"\w* al tercer \w día|strong="H3117"\w* les dijo \w José|strong="H3130"\w*: «\w Haced|strong="H6213"\w* \w esto|strong="H2063"\w* y \w vivid|strong="H2421"\w*, porque \w yo|strong="H6213"\w* \w temo|strong="H3372"\w* \w a|strong="H3068"\w* Dios.  
\v 19 Si sois hombres honrados, quede atado uno de vuestros hermanos \w en|strong="H3212"\w* la \w casa|strong="H1004"\w* de vuestra prisión; y vosotros \w id|strong="H3212"\w*, \w llevad|strong="H3212"\w* el trigo para el hambre de vuestras \w casas|strong="H1004"\w*.  
\v 20 Pero habéis \w de|strong="H1697"\w* traerme \w a|strong="H3068"\w* vuestro hermano \w menor|strong="H6996"\w*, y serán verificadas \w vuestras|strong="H1697"\w* \w palabras|strong="H1697"\w*, y \w no|strong="H3808"\w* \w moriréis|strong="H4191"\w*».  
\p \w Y|strong="H3068"\w* ellos \w lo|strong="H1697"\w* \w hicieron|strong="H6213"\w* \w así|strong="H3651"\w*.  
\v 21 \w Y|strong="H3068"\w* decían \w el|strong="H5921"\w* uno \w al|strong="H5921"\w* otro: «Verdaderamente hemos pecado \w contra|strong="H5921"\w* nuestro hermano, \w pues|strong="H3651"\w* \w vimos|strong="H7200"\w* \w la|strong="H5921"\w* \w angustia|strong="H6869"\w* \w de|strong="H5921"\w* su \w alma|strong="H5315"\w* cuando \w nos|strong="H5921"\w* \w rogaba|strong="H2603"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w le|strong="H5921"\w* escuchamos; \w por|strong="H5921"\w* \w eso|strong="H3651"\w* \w ha|strong="H3808"\w* venido \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w esta|strong="H2063"\w* \w angustia|strong="H6869"\w*».  
\v 22 \w Entonces|strong="H1571"\w* \w Rubén|strong="H7205"\w* les \w respondió|strong="H6030"\w*, diciendo: “¿\w No|strong="H3808"\w* os \w hablé|strong="H6030"\w* \w yo|strong="H2009"\w* \w y|strong="H1571"\w* dije: ‘\w No|strong="H3808"\w* \w pequéis|strong="H2398"\w* contra \w el|strong="H1571"\w* joven’, \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w escuchasteis|strong="H8085"\w*? He \w aquí|strong="H2009"\w* \w también|strong="H1571"\w* \w se|strong="H3808"\w* nos demanda su \w sangre|strong="H1818"\w*”.  
\v 23 \w Y|strong="H3068"\w* \w ellos|strong="H1992"\w* \w no|strong="H3808"\w* \w sabían|strong="H3045"\w* \w que|strong="H3588"\w* \w los|strong="H1992"\w* \w entendía|strong="H3045"\w* \w José|strong="H3130"\w*, \w porque|strong="H3588"\w* \w había|strong="H3588"\w* intérprete \w entre|strong="H3808"\w* \w ellos|strong="H1992"\w*.  
\v 24 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* \w apartó|strong="H5437"\w* José \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w lloró|strong="H1058"\w*; \w después|strong="H5921"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w habló|strong="H1696"\w*, \w y|strong="H5921"\w* \w tomó|strong="H3947"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* \w Simeón|strong="H8095"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* aprisionó \w a|strong="H3068"\w* vista \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 25 Después \w mandó|strong="H6680"\w* \w José|strong="H3130"\w* que llenaran sus \w sacos|strong="H8242"\w* \w de|strong="H5414"\w* \w trigo|strong="H1250"\w*, y devolviesen \w el|strong="H6213"\w* \w dinero|strong="H3701"\w* \w de|strong="H5414"\w* cada uno \w de|strong="H5414"\w* ellos, \w poniéndolo|strong="H5414"\w* en su \w saco|strong="H8242"\w*, y \w les|strong="H6680"\w* diesen provisiones \w para|strong="H5414"\w* \w el|strong="H6213"\w* \w camino|strong="H1870"\w*; y \w así|strong="H3651"\w* \w se|strong="H3651"\w* \w hizo|strong="H6213"\w* con ellos.   
\p
\v 26 \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* pusieron su trigo \w sobre|strong="H5921"\w* sus \w asnos|strong="H2543"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w fueron|strong="H3212"\w* \w de|strong="H5921"\w* \w allí|strong="H8033"\w*.  
\v 27 Pero abriendo uno \w de|strong="H5414"\w* \w ellos|strong="H1931"\w* \w su|strong="H1931"\w* \w saco|strong="H8242"\w* \w para|strong="H5414"\w* \w dar|strong="H5414"\w* \w forraje|strong="H4554"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w asno|strong="H2543"\w* en \w el|strong="H1931"\w* \w mesón|strong="H4411"\w*, \w vio|strong="H7200"\w* \w su|strong="H1931"\w* \w dinero|strong="H3701"\w* \w que|strong="H1931"\w* \w estaba|strong="H2009"\w* en \w la|strong="H1931"\w* \w boca|strong="H6310"\w* \w de|strong="H5414"\w* \w su|strong="H1931"\w* costal.  
\v 28 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* sus hermanos: «¡\w Mi|strong="H2009"\w* \w dinero|strong="H3701"\w* \w se|strong="H4100"\w* me ha devuelto, \w y|strong="H1571"\w* he \w aquí|strong="H2009"\w* \w está|strong="H2063"\w* \w en|strong="H3318"\w* \w mi|strong="H2009"\w* \w saco|strong="H3318"\w*!» \w Entonces|strong="H7725"\w* \w se|strong="H4100"\w* les sobresaltó \w el|strong="H6213"\w* \w corazón|strong="H3820"\w*, \w y|strong="H1571"\w* espantados dijeron \w el|strong="H6213"\w* uno al otro: «¿\w Qué|strong="H4100"\w* \w es|strong="H2063"\w* \w esto|strong="H2063"\w* \w que|strong="H4100"\w* \w nos|strong="H4100"\w* ha \w hecho|strong="H6213"\w* Dios?»  
\v 29 \w Y|strong="H3068"\w* \w vinieron|strong="H5046"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* su padre en \w la|strong="H3605"\w* tierra de \w Canaán|strong="H3667"\w*, y le \w contaron|strong="H5046"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* les había acontecido, diciendo:  
\v 30 “Aquel varón, el señor \w de|strong="H5414"\w* la tierra, nos \w habló|strong="H1696"\w* \w ásperamente|strong="H7186"\w*, y nos \w trató|strong="H5414"\w* como \w a|strong="H3068"\w* \w espías|strong="H7270"\w* \w de|strong="H5414"\w* la tierra.  
\v 31 \w Y|strong="H3068"\w* nosotros le dijimos: ‘\w Somos|strong="H1961"\w* hombres honrados, \w nunca|strong="H3808"\w* \w fuimos|strong="H1961"\w* \w espías|strong="H7270"\w*.  
\v 32 Somos \w doce|strong="H8147"\w* hermanos, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* nuestro padre; uno ya no parece, y \w el|strong="H1121"\w* \w menor|strong="H6996"\w* está \w hoy|strong="H3117"\w* con nuestro padre en la tierra \w de|strong="H1121"\w* \w Canaán|strong="H3667"\w*’.  
\v 33 \w Entonces|strong="H3588"\w* aquel varón, \w el|strong="H3588"\w* señor \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra, nos dijo: ‘\w En|strong="H3588"\w* \w esto|strong="H2063"\w* \w conoceré|strong="H3045"\w* \w que|strong="H3588"\w* sois hombres honrados: dejad conmigo uno \w de|strong="H3588"\w* vuestros hermanos, \w y|strong="H3588"\w* \w tomad|strong="H3947"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* hambre \w de|strong="H3588"\w* vuestras \w casas|strong="H1004"\w*, \w y|strong="H3588"\w* \w andad|strong="H3212"\w*,  
\v 34 \w y|strong="H3588"\w* traedme \w a|strong="H3068"\w* vuestro hermano \w el|strong="H3588"\w* \w menor|strong="H6996"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w sepa|strong="H3045"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* sois \w espías|strong="H7270"\w*, \w sino|strong="H3588"\w* hombres honrados; \w así|strong="H3651"\w* os \w entregaré|strong="H5414"\w* \w a|strong="H3068"\w* vuestro hermano, \w y|strong="H3588"\w* negociaréis \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra’”.   
\p
\v 35 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* al vaciar \w ellos|strong="H1992"\w* \w sus|strong="H1992"\w* \w sacos|strong="H8242"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H1961"\w* en \w el|strong="H1992"\w* \w saco|strong="H8242"\w* \w de|strong="H3372"\w* cada uno \w estaba|strong="H1961"\w* \w el|strong="H1992"\w* atado \w de|strong="H3372"\w* \w su|strong="H1992"\w* \w dinero|strong="H3701"\w*; y \w viéndolo|strong="H7200"\w* \w ellos|strong="H1992"\w* y \w su|strong="H1992"\w* padre, \w tuvieron|strong="H1961"\w* \w temor|strong="H3372"\w*.  
\v 36 Entonces su padre \w Jacob|strong="H3290"\w* \w les|strong="H5921"\w* dijo: «\w Me|strong="H5921"\w* habéis \w privado|strong="H7921"\w* \w de|strong="H5921"\w* mis hijos; \w José|strong="H3130"\w* ya \w no|strong="H1961"\w* parece, ni \w Simeón|strong="H8095"\w* tampoco, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w* \w le|strong="H5921"\w* queréis llevar; \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w son|strong="H1961"\w* \w todas|strong="H3605"\w* estas cosas».   
\p
\v 37 \w Y|strong="H3068"\w* \w Rubén|strong="H7205"\w* habló \w a|strong="H3068"\w* su padre, diciendo: «Harás \w morir|strong="H4191"\w* \w a|strong="H3068"\w* \w mis|strong="H5414"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*, \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* \w lo|strong="H3808"\w* devuelvo; \w entrégalo|strong="H5414"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*, \w que|strong="H3808"\w* yo \w lo|strong="H3808"\w* devolveré \w a|strong="H3068"\w* \w ti|strong="H5921"\w*».   
\p
\v 38 \w Y|strong="H3068"\w* \w él|strong="H1931"\w* dijo: «\w No|strong="H3808"\w* \w descenderá|strong="H3381"\w* \w mi|strong="H3015"\w* \w hijo|strong="H1121"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*, \w pues|strong="H3588"\w* \w su|strong="H1931"\w* hermano \w ha|strong="H3808"\w* \w muerto|strong="H4191"\w*, \w y|strong="H3588"\w* \w él|strong="H1931"\w* \w solo|strong="H1931"\w* \w ha|strong="H3808"\w* quedado; \w y|strong="H3588"\w* \w si|strong="H3588"\w* \w le|strong="H1931"\w* \w aconteciere|strong="H1931"\w* algún desastre \w en|strong="H5973"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w por|strong="H3588"\w* \w donde|strong="H1931"\w* \w vais|strong="H3212"\w*, haréis descender mis canas \w con|strong="H5973"\w* \w dolor|strong="H3015"\w* al Seol».\f + \fr 42:38 \ft El Seol es el lugar de los muertos.\f*   
\c 43
\p
\v 1 El \w hambre|strong="H7458"\w* era muy \w grave|strong="H3515"\w* en la tierra.  
\v 2 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w se|strong="H1961"\w* \w acabaron|strong="H3615"\w* el trigo \w que|strong="H1961"\w* \w habían|strong="H1961"\w* traído de \w Egipto|strong="H4714"\w*, su padre les dijo: «\w Volved|strong="H7725"\w* \w a|strong="H3068"\w* comprarnos un \w poco|strong="H4592"\w* de alimento».   
\p
\v 3 Respondió \w Judá|strong="H3063"\w*, diciendo: “Aquel varón nos \w protestó|strong="H5749"\w* solemnemente, diciendo: ‘\w No|strong="H3808"\w* \w veréis|strong="H7200"\w* \w mi|strong="H1115"\w* \w rostro|strong="H6440"\w*, \w si|strong="H3808"\w* vuestro hermano \w no|strong="H3808"\w* viene con vosotros’.  
\v 4 \w Si|strong="H3426"\w* \w envías|strong="H7971"\w* \w a|strong="H3068"\w* nuestro hermano con nosotros, \w descenderemos|strong="H3381"\w* y te compraremos alimento;  
\v 5 \w pero|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w envías|strong="H7971"\w*, \w no|strong="H3808"\w* \w descenderemos|strong="H3381"\w*; \w porque|strong="H3588"\w* aquel varón nos dijo: ‘\w No|strong="H3808"\w* \w veréis|strong="H7200"\w* \w mi|strong="H1115"\w* \w rostro|strong="H6440"\w*, \w si|strong="H3588"\w* vuestro hermano \w no|strong="H3808"\w* viene \w con|strong="H3588"\w* vosotros’”.   
\p
\v 6 \w Y|strong="H3068"\w* \w dijo|strong="H5046"\w* \w Israel|strong="H3478"\w*: «¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* me hicisteis tanto \w mal|strong="H7489"\w*, \w declarando|strong="H5046"\w* al varón \w que|strong="H4100"\w* teníais \w otro|strong="H5750"\w* hermano?»   
\p
\v 7 \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* respondieron: “Aquel varón \w nos|strong="H5921"\w* \w preguntó|strong="H7592"\w* \w expresamente|strong="H7592"\w* \w por|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w y|strong="H3588"\w* \w por|strong="H5921"\w* nuestra \w parentela|strong="H4138"\w*, diciendo: ‘¿\w Vive|strong="H2416"\w* \w aún|strong="H5750"\w* vuestro padre? ¿\w Tenéis|strong="H3426"\w* \w otro|strong="H5750"\w* hermano?’ \w Y|strong="H3068"\w* \w le|strong="H5921"\w* declaramos \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* estas \w palabras|strong="H1697"\w*. ¿Acaso \w podíamos|strong="H3045"\w* \w saber|strong="H5046"\w* \w que|strong="H3588"\w* \w él|strong="H5921"\w* \w nos|strong="H5921"\w* diría: ‘Haced venir \w a|strong="H3068"\w* vuestro hermano’?”   
\p
\v 8 \w Entonces|strong="H1571"\w* \w Judá|strong="H3063"\w* dijo \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* su padre: «\w Envía|strong="H7971"\w* al joven conmigo, \w y|strong="H1571"\w* nos levantaremos \w y|strong="H1571"\w* nos \w iremos|strong="H3212"\w*, \w a|strong="H3068"\w* fin de \w que|strong="H3808"\w* vivamos \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w muramos|strong="H4191"\w*, \w ni|strong="H3808"\w* nosotros, \w ni|strong="H3808"\w* tú, \w ni|strong="H3808"\w* nuestros \w niños|strong="H2945"\w*.  
\v 9 Yo te respondo \w por|strong="H6440"\w* \w él|strong="H3605"\w*; \w de|strong="H6440"\w* \w mi|strong="H1245"\w* \w mano|strong="H3027"\w* \w lo|strong="H3808"\w* demandarás. \w Si|strong="H3808"\w* \w no|strong="H3808"\w* te \w lo|strong="H3808"\w* vuelvo \w a|strong="H3068"\w* traer y \w lo|strong="H3808"\w* pongo \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, \w seré|strong="H3808"\w* culpable \w para|strong="H6148"\w* \w contigo|strong="H6440"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w*.  
\v 10 \w Que|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3884"\w* nos hubiéramos detenido, \w ciertamente|strong="H3588"\w* hubiéramos \w ya|strong="H2088"\w* \w vuelto|strong="H7725"\w* \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*».   
\p
\v 11 \w Entonces|strong="H3651"\w* \w Israel|strong="H3478"\w* su padre les respondió: «\w Pues|strong="H3651"\w* que \w así|strong="H3651"\w* \w es|strong="H2063"\w*, \w hacedlo|strong="H6213"\w*; \w tomad|strong="H3947"\w* de \w lo|strong="H6213"\w* mejor de \w la|strong="H2063"\w* tierra en vuestros sacos, y llevad \w a|strong="H3068"\w* \w aquel|strong="H6213"\w* varón un \w presente|strong="H4503"\w*, un \w poco|strong="H4592"\w* de \w bálsamo|strong="H6875"\w*, un \w poco|strong="H4592"\w* de \w miel|strong="H1706"\w*, \w aromas|strong="H5219"\w* y mirra, nueces y \w almendras|strong="H8247"\w*.  
\v 12 \w Y|strong="H3068"\w* \w tomad|strong="H3947"\w* en vuestras \w manos|strong="H3027"\w* doble cantidad de \w dinero|strong="H3701"\w*, y llevad en vuestra \w mano|strong="H3027"\w* \w el|strong="H1931"\w* \w dinero|strong="H3701"\w* devuelto en las \w bocas|strong="H6310"\w* de vuestros costales; quizá \w fue|strong="H1931"\w* equivocación.  
\v 13 \w Tomad|strong="H3947"\w* también \w a|strong="H3068"\w* vuestro hermano, y \w levantaos|strong="H6965"\w*, y \w volved|strong="H7725"\w* \w a|strong="H3068"\w* aquel varón.  
\v 14 \w Y|strong="H3068"\w* el Dios \w Omnipotente|strong="H7706"\w* os \w dé|strong="H6440"\w* misericordia \w delante|strong="H6440"\w* \w de|strong="H6440"\w* aquel varón, y os suelte al otro hermano vuestro, y \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w*. \w Y|strong="H3068"\w* \w si|strong="H6440"\w* he \w de|strong="H6440"\w* ser \w privado|strong="H7921"\w* \w de|strong="H6440"\w* \w mis|strong="H5414"\w* hijos, \w séalo|strong="H7921"\w*».   
\p
\v 15 \w Tomaron|strong="H3947"\w*, \w pues|strong="H3381"\w*, aquellos varones el \w presente|strong="H4503"\w*, y \w tomaron|strong="H3947"\w* \w en|strong="H5975"\w* su \w mano|strong="H3027"\w* doble \w dinero|strong="H3701"\w*, y \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w*; y se \w levantaron|strong="H6965"\w*, y \w descendieron|strong="H3381"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, y se presentaron \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w José|strong="H3130"\w*.  
\v 16 \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H3588"\w* dijo \w al|strong="H5921"\w* \w mayordomo|strong="H5921"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*: «Lleva \w a|strong="H3068"\w* estos \w varones|strong="H3588"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w*, \w y|strong="H3588"\w* mata alguna res \w y|strong="H3588"\w* prepárala, \w porque|strong="H3588"\w* estos \w varones|strong="H3588"\w* comerán conmigo \w al|strong="H5921"\w* mediodía».   
\p
\v 17 \w E|strong="H3068"\w* \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* hombre como \w José|strong="H3130"\w* dijo, y llevó \w el|strong="H6213"\w* hombre \w a|strong="H3068"\w* los varones \w a|strong="H3068"\w* \w casa|strong="H1004"\w* de \w José|strong="H3130"\w*.  
\v 18 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* \w varones|strong="H3588"\w* tuvieron \w temor|strong="H3372"\w*, \w al|strong="H5921"\w* ser llevados \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*, \w y|strong="H3588"\w* decían: «\w Por|strong="H5921"\w* \w el|strong="H5921"\w* \w dinero|strong="H3701"\w* \w que|strong="H3588"\w* \w nos|strong="H5921"\w* fue devuelto \w en|strong="H5921"\w* nuestros costales \w la|strong="H5921"\w* primera vez \w nos|strong="H5921"\w* han traído aquí, \w para|strong="H5921"\w* tender un lazo \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w y|strong="H3588"\w* dar \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w y|strong="H3588"\w* tomarnos \w por|strong="H5921"\w* \w siervos|strong="H5650"\w* \w a|strong="H3068"\w* \w nosotros|strong="H5921"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* nuestros \w asnos|strong="H2543"\w*».  
\v 19 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* acercaron \w al|strong="H5921"\w* \w mayordomo|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*, \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w hablaron|strong="H1696"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*,  
\v 20 y le dijeron: «Ay, señor mío, nosotros \w en|strong="H8462"\w* verdad \w descendimos|strong="H3381"\w* al principio \w a|strong="H3068"\w* comprar alimentos.  
\v 21 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* llegamos al \w mesón|strong="H4411"\w* \w y|strong="H3588"\w* abrimos nuestros costales, he \w aquí|strong="H2009"\w* \w el|strong="H3588"\w* \w dinero|strong="H3701"\w* \w de|strong="H3588"\w* cada uno \w estaba|strong="H1961"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* costal, nuestro \w dinero|strong="H3701"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* justo \w peso|strong="H4948"\w*; \w y|strong="H3588"\w* lo hemos \w vuelto|strong="H7725"\w* \w a|strong="H3068"\w* traer \w en|strong="H3588"\w* nuestras \w manos|strong="H3027"\w*.  
\v 22 También hemos traído en nuestras \w manos|strong="H3027"\w* otro \w dinero|strong="H3701"\w* para comprar alimentos; nosotros \w no|strong="H3808"\w* \w sabemos|strong="H3045"\w* \w quién|strong="H4310"\w* \w puso|strong="H7760"\w* nuestro \w dinero|strong="H3701"\w* en nuestros costales».   
\p
\v 23 \w Y|strong="H3068"\w* él respondió: «La \w paz|strong="H7965"\w* sea con vosotros, no \w temáis|strong="H3372"\w*; vuestro Dios y el Dios \w de|strong="H3372"\w* vuestro padre os \w dio|strong="H5414"\w* el tesoro \w en|strong="H3318"\w* vuestros costales; yo recibí vuestro \w dinero|strong="H3701"\w*». \w Y|strong="H3068"\w* \w sacó|strong="H3318"\w* \w a|strong="H3068"\w* \w Simeón|strong="H8095"\w* \w a|strong="H3068"\w* ellos.  
\v 24 \w Y|strong="H3068"\w* metió aquel varón \w a|strong="H3068"\w* los hombres en \w casa|strong="H1004"\w* \w de|strong="H5414"\w* \w José|strong="H3130"\w*, y les \w dio|strong="H5414"\w* \w agua|strong="H4325"\w*, y lavaron sus \w pies|strong="H7272"\w*; y \w dio|strong="H5414"\w* \w forraje|strong="H4554"\w* \w a|strong="H3068"\w* sus \w asnos|strong="H2543"\w*.  
\v 25 \w Y|strong="H3068"\w* ellos prepararon \w el|strong="H3588"\w* \w presente|strong="H4503"\w* \w entretanto|strong="H5704"\w* \w que|strong="H3588"\w* venía \w José|strong="H3130"\w* \w al|strong="H5704"\w* mediodía, \w porque|strong="H3588"\w* habían \w oído|strong="H8085"\w* \w que|strong="H3588"\w* \w allí|strong="H8033"\w* habrían \w de|strong="H3588"\w* comer \w pan|strong="H3899"\w*.   
\p
\v 26 \w Y|strong="H3068"\w* vino \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w*, y \w ellos|strong="H3027"\w* le trajeron el \w presente|strong="H4503"\w* \w que|strong="H3027"\w* tenían en su \w mano|strong="H3027"\w* dentro de la \w casa|strong="H1004"\w*, y se inclinaron ante él hasta la tierra.  
\v 27 Entonces les \w preguntó|strong="H7592"\w* él \w cómo|strong="H5750"\w* estaban, y dijo: «¿Está \w bien|strong="H7965"\w* vuestro padre, el \w anciano|strong="H2205"\w* \w de|strong="H5750"\w* quien me hablasteis? ¿\w Vive|strong="H2416"\w* \w aún|strong="H5750"\w*?»   
\p
\v 28 \w Y|strong="H3068"\w* ellos respondieron: «\w Bien|strong="H7965"\w* está tu \w siervo|strong="H5650"\w* nuestro padre; \w aún|strong="H5750"\w* \w vive|strong="H2416"\w*». \w Y|strong="H3068"\w* se inclinaron, \w e|strong="H3068"\w* hicieron reverencia.  
\v 29 \w Y|strong="H3068"\w* \w alzando|strong="H5375"\w* José sus \w ojos|strong="H5869"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w* su hermano, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* su madre, y dijo: «¿\w Es|strong="H2088"\w* \w éste|strong="H2088"\w* vuestro hermano \w menor|strong="H6996"\w*, \w de|strong="H1121"\w* quien me hablasteis?» \w Y|strong="H3068"\w* dijo: «Dios tenga \w misericordia|strong="H2603"\w* \w de|strong="H1121"\w* ti, \w hijo|strong="H1121"\w* mío».  
\v 30 \w Entonces|strong="H3588"\w* \w José|strong="H3130"\w* se apresuró, \w porque|strong="H3588"\w* se conmovieron sus entrañas \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermano, \w y|strong="H3588"\w* \w buscó|strong="H1245"\w* \w dónde|strong="H8033"\w* llorar; \w y|strong="H3588"\w* entró \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w cámara|strong="H2315"\w*, \w y|strong="H3588"\w* \w lloró|strong="H1058"\w* \w allí|strong="H8033"\w*.  
\v 31 \w Y|strong="H3068"\w* \w lavó|strong="H7364"\w* su \w rostro|strong="H6440"\w* y \w salió|strong="H3318"\w*, y se contuvo, y dijo: «Servid el \w pan|strong="H3899"\w*».   
\p
\v 32 \w Y|strong="H3068"\w* \w le|strong="H1931"\w* sirvieron \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w aparte|strong="H1931"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w ellos|strong="H1931"\w* \w aparte|strong="H1931"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w egipcios|strong="H4713"\w* \w que|strong="H3588"\w* comían \w con|strong="H3588"\w* \w él|strong="H1931"\w* \w aparte|strong="H1931"\w*; \w porque|strong="H3588"\w* \w los|strong="H1931"\w* \w egipcios|strong="H4713"\w* \w no|strong="H3808"\w* \w pueden|strong="H3201"\w* comer \w pan|strong="H3899"\w* \w con|strong="H3588"\w* \w los|strong="H1931"\w* \w hebreos|strong="H5680"\w*, \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w abominación|strong="H8441"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w egipcios|strong="H4713"\w*.  
\v 33 \w Y|strong="H3068"\w* se \w sentaron|strong="H3427"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H3427"\w*, \w el|strong="H3427"\w* mayor conforme \w a|strong="H3068"\w* su primogenitura, y \w el|strong="H3427"\w* \w menor|strong="H6810"\w* conforme \w a|strong="H3068"\w* su \w menor|strong="H6810"\w* edad; y \w estaban|strong="H3427"\w* aquellos varones maravillados \w los|strong="H3427"\w* unos con \w los|strong="H3427"\w* otros.  
\v 34 \w Y|strong="H3068"\w* \w él|strong="H5973"\w* \w tomó|strong="H5375"\w* porciones \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w sí|strong="H6440"\w* \w para|strong="H5973"\w* \w ellos|strong="H3027"\w*; \w mas|strong="H7235"\w* \w la|strong="H3605"\w* porción \w de|strong="H6440"\w* \w Benjamín|strong="H1144"\w* era \w cinco|strong="H2568"\w* \w veces|strong="H3027"\w* mayor \w que|strong="H3605"\w* \w la|strong="H3605"\w* \w de|strong="H6440"\w* \w cualquiera|strong="H3605"\w* \w de|strong="H6440"\w* \w ellos|strong="H3027"\w*. \w Y|strong="H3068"\w* \w bebieron|strong="H8354"\w*, y se alegraron \w con|strong="H5973"\w* \w él|strong="H5973"\w*.   
\c 44
\p
\v 1 \w Y|strong="H3068"\w* \w mandó|strong="H6680"\w* José \w al|strong="H5921"\w* \w mayordomo|strong="H5921"\w* \w de|strong="H5921"\w* su \w casa|strong="H1004"\w*, diciendo: «\w Llena|strong="H4390"\w* \w de|strong="H5921"\w* alimento \w los|strong="H5921"\w* costales \w de|strong="H5921"\w* estos varones, \w cuanto|strong="H5921"\w* puedan llevar, \w y|strong="H5921"\w* \w pon|strong="H7760"\w* \w el|strong="H5921"\w* \w dinero|strong="H3701"\w* \w de|strong="H5921"\w* cada uno \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* su costal.  
\v 2 \w Y|strong="H3068"\w* \w pondrás|strong="H7760"\w* mi copa, la copa \w de|strong="H1697"\w* \w plata|strong="H3701"\w*, en la \w boca|strong="H6310"\w* del costal del \w menor|strong="H6996"\w*, con \w el|strong="H6213"\w* \w dinero|strong="H3701"\w* \w de|strong="H1697"\w* su trigo». \w Y|strong="H3068"\w* \w el|strong="H6213"\w* mayordomo \w hizo|strong="H6213"\w* \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w José|strong="H3130"\w* le \w había|strong="H6213"\w* \w dicho|strong="H6310"\w*.  
\v 3 Venida la \w mañana|strong="H1242"\w*, \w los|strong="H1992"\w* hombres fueron despedidos, \w ellos|strong="H1992"\w* con \w sus|strong="H1992"\w* \w asnos|strong="H2543"\w*.  
\v 4 Habiendo \w ellos|strong="H1992"\w* \w salido|strong="H3318"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H4100"\w* \w aún|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* habían alejado, dijo \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w mayordomo|strong="H5921"\w*: “\w Levántate|strong="H6965"\w* \w y|strong="H5921"\w* sigue \w a|strong="H3068"\w* esos hombres; \w y|strong="H5921"\w* \w cuando|strong="H4100"\w* \w los|strong="H1992"\w* alcances, diles: ‘¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* habéis pagado \w mal|strong="H7451"\w* \w por|strong="H5921"\w* \w bien|strong="H2896"\w*?  
\v 5 ¿\w No|strong="H3808"\w* \w es|strong="H1931"\w* \w ésta|strong="H2088"\w* \w la|strong="H1931"\w* copa en \w que|strong="H1931"\w* \w bebe|strong="H8354"\w* mi señor, y \w por|strong="H2088"\w* \w la|strong="H1931"\w* \w que|strong="H1931"\w* \w suele|strong="H6213"\w* \w adivinar|strong="H5172"\w*? \w Habéis|strong="H8354"\w* \w hecho|strong="H6213"\w* \w mal|strong="H7489"\w* en \w hacer|strong="H6213"\w* \w esto|strong="H2088"\w*’”.  
\v 6 \w Y|strong="H3068"\w* él los \w alcanzó|strong="H5381"\w*, y les \w dijo|strong="H1696"\w* estas \w palabras|strong="H1697"\w*.   
\p
\v 7 \w Y|strong="H3068"\w* ellos le \w respondieron|strong="H1696"\w*: «¿\w Por|strong="H1697"\w* \w qué|strong="H4100"\w* \w dice|strong="H1696"\w* mi señor tales \w cosas|strong="H1697"\w*? ¡\w Nunca|strong="H2486"\w* \w tal|strong="H2088"\w* \w hagan|strong="H6213"\w* tus \w siervos|strong="H5650"\w*!  
\v 8 He \w aquí|strong="H2005"\w*, el \w dinero|strong="H3701"\w* \w que|strong="H6310"\w* \w hallamos|strong="H4672"\w* en la \w boca|strong="H6310"\w* de nuestros costales te lo \w volvimos|strong="H7725"\w* \w a|strong="H3068"\w* traer desde la tierra de \w Canaán|strong="H3667"\w*; ¿cómo, pues, habíamos de hurtar de \w casa|strong="H1004"\w* de tu señor \w plata|strong="H3701"\w* ni \w oro|strong="H2091"\w*?  
\v 9 Aquel de tus \w siervos|strong="H5650"\w* en quien \w fuere|strong="H1961"\w* hallada \w la|strong="H1571"\w* copa, \w que|strong="H1571"\w* \w muera|strong="H4191"\w*, \w y|strong="H1571"\w* \w aun|strong="H1571"\w* nosotros \w seremos|strong="H1961"\w* \w siervos|strong="H5650"\w* de \w mi|strong="H1961"\w* señor».   
\p
\v 10 \w Y|strong="H3068"\w* \w él|strong="H1931"\w* dijo: «\w Sea|strong="H1961"\w* \w ahora|strong="H6258"\w* \w también|strong="H1571"\w* \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w vuestras|strong="H1697"\w* \w palabras|strong="H1697"\w*: \w aquel|strong="H1931"\w* \w en|strong="H5355"\w* \w quien|strong="H1931"\w* \w se|strong="H1961"\w* \w hallare|strong="H4672"\w* \w será|strong="H1961"\w* \w mi|strong="H1961"\w* \w siervo|strong="H5650"\w*, \w y|strong="H1571"\w* vosotros \w seréis|strong="H1961"\w* sin culpa».   
\p
\v 11 Entonces ellos se dieron prisa, y bajó cada uno su costal \w a|strong="H3068"\w* tierra, y \w abrió|strong="H6605"\w* cada uno su costal.  
\v 12 \w Y|strong="H3068"\w* buscó, comenzando desde el \w mayor|strong="H1419"\w* y \w acabando|strong="H3615"\w* en el \w menor|strong="H6996"\w*; y la copa fue hallada en el costal de \w Benjamín|strong="H1144"\w*.  
\v 13 \w Entonces|strong="H7725"\w* \w ellos|strong="H5921"\w* \w rasgaron|strong="H7167"\w* sus \w vestidos|strong="H8071"\w*, \w y|strong="H5921"\w* cargó cada uno su \w asno|strong="H2543"\w* \w y|strong="H5921"\w* \w volvieron|strong="H7725"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.   
\p
\v 14 \w Vino|strong="H5307"\w* \w Judá|strong="H3063"\w* con \w sus|strong="H1931"\w* hermanos \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w José|strong="H3130"\w*, \w que|strong="H1931"\w* \w aún|strong="H5750"\w* \w estaba|strong="H1004"\w* \w allí|strong="H8033"\w*, y \w se|strong="H1931"\w* postraron \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H1931"\w* \w en|strong="H5750"\w* tierra.  
\v 15 \w Y|strong="H3068"\w* les dijo \w José|strong="H3130"\w*: «¿\w Qué|strong="H3588"\w* acción \w es|strong="H2088"\w* \w esta|strong="H2088"\w* \w que|strong="H3588"\w* habéis \w hecho|strong="H6213"\w*? ¿\w No|strong="H3808"\w* \w sabéis|strong="H3045"\w* \w que|strong="H3588"\w* un hombre \w como|strong="H4100"\w* \w yo|strong="H3588"\w* \w sabe|strong="H3045"\w* \w adivinar|strong="H5172"\w*?»   
\p
\v 16 \w Entonces|strong="H1571"\w* \w dijo|strong="H1696"\w* \w Judá|strong="H3063"\w*: «¿\w Qué|strong="H4100"\w* diremos \w a|strong="H3068"\w* mi señor? ¿\w Qué|strong="H4100"\w* \w hablaremos|strong="H1696"\w*, \w o|strong="H3068"\w* \w con|strong="H1571"\w* \w qué|strong="H4100"\w* \w nos|strong="H4100"\w* justificaremos? Dios ha \w hallado|strong="H4672"\w* \w la|strong="H1571"\w* \w maldad|strong="H5771"\w* de tus \w siervos|strong="H5650"\w*; he \w aquí|strong="H2005"\w*, nosotros somos \w siervos|strong="H5650"\w* de mi señor, nosotros, \w y|strong="H1571"\w* \w también|strong="H1571"\w* aquel en cuyo \w poder|strong="H3027"\w* \w fue|strong="H3063"\w* hallada \w la|strong="H1571"\w* copa».   
\p
\v 17 Pero José respondió: «\w Nunca|strong="H2486"\w* \w yo|strong="H6213"\w* \w tal|strong="H2063"\w* \w haga|strong="H6213"\w*. \w El|strong="H1931"\w* varón en \w cuyo|strong="H1931"\w* \w poder|strong="H3027"\w* \w fue|strong="H1961"\w* hallada \w la|strong="H1931"\w* copa, \w él|strong="H1931"\w* \w será|strong="H1961"\w* \w mi|strong="H1961"\w* \w siervo|strong="H5650"\w*; en cuanto \w a|strong="H3068"\w* vosotros, idos en \w paz|strong="H7965"\w* \w a|strong="H3068"\w* vuestro padre».   
\p
\v 18 \w Entonces|strong="H3588"\w* \w Judá|strong="H3063"\w* se \w acercó|strong="H5066"\w* \w a|strong="H3068"\w* \w él|strong="H3588"\w*, \w y|strong="H3588"\w* \w dijo|strong="H1696"\w*: “Ay, señor mío, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* permitas \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w* decir una \w palabra|strong="H1697"\w* \w en|strong="H3588"\w* \w los|strong="H3588"\w* oídos \w de|strong="H3588"\w* \w mi|strong="H4994"\w* señor, \w y|strong="H3588"\w* \w no|strong="H3588"\w* se encienda tu ira contra tu \w siervo|strong="H5650"\w*, \w pues|strong="H3588"\w* tú eres \w como|strong="H3588"\w* \w Faraón|strong="H6547"\w*.  
\v 19 Mi señor \w preguntó|strong="H7592"\w* \w a|strong="H3068"\w* sus \w siervos|strong="H5650"\w*, diciendo: ‘¿\w Tenéis|strong="H3426"\w* padre \w o|strong="H3068"\w* hermano?’  
\v 20 \w Y|strong="H3068"\w* \w nosotros|strong="H1931"\w* respondimos \w a|strong="H3068"\w* mi señor: ‘\w Tenemos|strong="H3426"\w* un padre \w anciano|strong="H2205"\w*, y un hermano joven \w que|strong="H1931"\w* \w le|strong="H1931"\w* nació en \w su|strong="H1931"\w* vejez; y un hermano \w suyo|strong="H1931"\w* \w murió|strong="H4191"\w*, y \w él|strong="H1931"\w* \w solo|strong="H1931"\w* ha quedado de \w su|strong="H1931"\w* madre; y \w su|strong="H1931"\w* padre \w lo|strong="H1931"\w* ama’.  
\v 21 \w Y|strong="H3068"\w* tú dijiste \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w*: ‘\w Traédmelo|strong="H3381"\w*, \w y|strong="H5921"\w* \w pondré|strong="H7760"\w* mis \w ojos|strong="H5869"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*’.  
\v 22 \w Y|strong="H3068"\w* nosotros dijimos \w a|strong="H3068"\w* mi señor: ‘El joven \w no|strong="H3808"\w* \w puede|strong="H3201"\w* \w dejar|strong="H5800"\w* \w a|strong="H3068"\w* su padre, \w porque|strong="H3808"\w* \w si|strong="H3808"\w* \w lo|strong="H3808"\w* \w dejare|strong="H5800"\w*, su padre \w morirá|strong="H4191"\w*’.  
\v 23 \w Y|strong="H3068"\w* dijiste \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w*: ‘\w Si|strong="H3808"\w* vuestro hermano \w menor|strong="H6996"\w* \w no|strong="H3808"\w* \w desciende|strong="H3381"\w* con vosotros, \w no|strong="H3808"\w* \w veréis|strong="H7200"\w* \w más|strong="H3254"\w* mi \w rostro|strong="H6440"\w*’.  
\v 24 \w Aconteció|strong="H1961"\w*, \w pues|strong="H3588"\w*, \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* subimos \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w* \w mi|strong="H1961"\w* padre, le contamos las \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* señor.  
\v 25 \w Y|strong="H3068"\w* dijo nuestro padre: ‘\w Volved|strong="H7725"\w* \w a|strong="H3068"\w* comprarnos un \w poco|strong="H4592"\w* de alimento’.  
\v 26 \w Y|strong="H3068"\w* nosotros respondimos: ‘\w No|strong="H3808"\w* \w podemos|strong="H3201"\w* \w ir|strong="H3381"\w*. \w Si|strong="H3588"\w* nuestro hermano \w menor|strong="H6996"\w* \w va|strong="H3068"\w* \w con|strong="H3588"\w* nosotros, \w descenderemos|strong="H3381"\w*; \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w podremos|strong="H3201"\w* \w ver|strong="H7200"\w* \w el|strong="H3588"\w* \w rostro|strong="H6440"\w* del varón, \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w está|strong="H3426"\w* \w con|strong="H3588"\w* nosotros nuestro hermano \w menor|strong="H6996"\w*’.  
\v 27 \w Entonces|strong="H3588"\w* tu \w siervo|strong="H5650"\w* mi padre nos dijo: ‘Vosotros \w sabéis|strong="H3045"\w* \w que|strong="H3588"\w* mi mujer \w me|strong="H3588"\w* dio \w a|strong="H3068"\w* luz \w dos|strong="H8147"\w* hijos.  
\v 28 El uno \w salió|strong="H3318"\w* \w de|strong="H5704"\w* mi presencia, \w y|strong="H5704"\w* pensé: «\w De|strong="H5704"\w* \w cierto|strong="H3808"\w* \w ha|strong="H3808"\w* sido despedazado»; \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* \w ahora|strong="H2008"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* he \w visto|strong="H7200"\w*.  
\v 29 \w Y|strong="H3068"\w* \w si|strong="H1571"\w* tomáis \w también|strong="H1571"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w de|strong="H6440"\w* mi \w presencia|strong="H6440"\w*, \w y|strong="H1571"\w* \w le|strong="H5973"\w* acontece algún desastre, haréis descender mis canas \w con|strong="H5973"\w* dolor al Seol’.\f + \fr 44:29 \ft El Seol es el lugar de los muertos.\f*  
\v 30 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w cuando|strong="H5650"\w* \w yo|strong="H5315"\w* llegue \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w* \w mi|strong="H5315"\w* padre, \w si|strong="H5315"\w* el joven no \w va|strong="H3068"\w* con nosotros, como su \w vida|strong="H5315"\w* está ligada \w a|strong="H3068"\w* la \w vida|strong="H5315"\w* de él,  
\v 31 \w sucederá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w no|strong="H3588"\w* \w vea|strong="H7200"\w* al joven, \w morirá|strong="H4191"\w*; \w y|strong="H3588"\w* tus \w siervos|strong="H5650"\w* harán descender las canas \w de|strong="H3588"\w* tu \w siervo|strong="H5650"\w* nuestro padre \w con|strong="H3588"\w* \w dolor|strong="H3015"\w* al Seol.\f + \fr 44:31 \ft El Seol es el lugar de los muertos.\f*  
\v 32 \w Como|strong="H3588"\w* tu \w siervo|strong="H5650"\w* salió fiador \w del|strong="H5973"\w* joven \w con|strong="H5973"\w* mi padre, diciendo: ‘\w Si|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w lo|strong="H3808"\w* devuelvo, \w entonces|strong="H3117"\w* cargaré \w con|strong="H5973"\w* \w la|strong="H3605"\w* culpa ante mi padre \w para|strong="H3588"\w* \w siempre|strong="H3605"\w*’;  
\v 33 \w te|strong="H5973"\w* \w ruego|strong="H4994"\w*, \w por|strong="H8478"\w* tanto, \w que|strong="H6258"\w* \w quede|strong="H3427"\w* \w ahora|strong="H6258"\w* tu \w siervo|strong="H5650"\w* \w en|strong="H5973"\w* \w lugar|strong="H8478"\w* \w del|strong="H5973"\w* joven \w por|strong="H8478"\w* \w siervo|strong="H5650"\w* \w de|strong="H8478"\w* \w mi|strong="H4994"\w* señor, y \w que|strong="H6258"\w* \w el|strong="H5973"\w* joven \w vaya|strong="H5927"\w* \w con|strong="H5973"\w* sus hermanos.  
\v 34 \w Porque|strong="H3588"\w* ¿\w cómo|strong="H3588"\w* \w iré|strong="H5927"\w* \w yo|strong="H3588"\w* \w a|strong="H3068"\w* mi padre sin \w el|strong="H3588"\w* joven? \w No|strong="H6435"\w* podré, \w por|strong="H3588"\w* \w no|strong="H6435"\w* \w ver|strong="H7200"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w* \w que|strong="H3588"\w* \w sobrevendrá|strong="H4672"\w* \w a|strong="H3068"\w* mi padre”.   
\c 45
\p
\v 1 Entonces \w José|strong="H3130"\w* \w no|strong="H3808"\w* \w pudo|strong="H3201"\w* contenerse \w más|strong="H5921"\w* \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3808"\w* \w estaban|strong="H5975"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w clamó|strong="H7121"\w*: «¡Haced \w salir|strong="H3318"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* presencia!» \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w quedó|strong="H5975"\w* \w nadie|strong="H3808"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w*, cuando \w José|strong="H3130"\w* \w se|strong="H3045"\w* dio \w a|strong="H3068"\w* conocer \w a|strong="H3068"\w* sus hermanos.  
\v 2 \w Y|strong="H3068"\w* alzó su \w voz|strong="H6963"\w* \w llorando|strong="H1065"\w*; y lo \w oyeron|strong="H8085"\w* los \w egipcios|strong="H4713"\w*, y lo \w oyó|strong="H8085"\w* también la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* \w Faraón|strong="H6547"\w*.  
\v 3 \w Y|strong="H3068"\w* dijo \w José|strong="H3130"\w* \w a|strong="H3068"\w* sus hermanos: «¡\w Yo|strong="H3588"\w* soy \w José|strong="H3130"\w*! ¿\w Vive|strong="H2416"\w* \w aún|strong="H5750"\w* \w mi|strong="H6030"\w* padre?» \w Y|strong="H3068"\w* sus hermanos \w no|strong="H3808"\w* le \w pudieron|strong="H3201"\w* \w responder|strong="H6030"\w*, \w porque|strong="H3588"\w* estaban turbados \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*.   
\p
\v 4 Entonces dijo \w José|strong="H3130"\w* \w a|strong="H3068"\w* sus hermanos: «\w Acercaos|strong="H5066"\w* \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* \w mí|strong="H4994"\w*, os \w ruego|strong="H4994"\w*».  
\p \w Y|strong="H3068"\w* ellos se acercaron. \w Y|strong="H3068"\w* \w él|strong="H5066"\w* dijo: “\w Yo|strong="H4994"\w* soy \w José|strong="H3130"\w* vuestro hermano, \w el|strong="H5066"\w* \w que|strong="H4994"\w* \w vendisteis|strong="H4376"\w* para \w Egipto|strong="H4714"\w*.  
\v 5 \w Ahora|strong="H6258"\w*, \w pues|strong="H3588"\w*, \w no|strong="H3588"\w* \w os|strong="H5869"\w* entristezcáis, \w ni|strong="H6258"\w* \w os|strong="H5869"\w* pese \w de|strong="H3588"\w* haberme vendido \w acá|strong="H2008"\w*; \w porque|strong="H3588"\w* \w para|strong="H3588"\w* preservación \w de|strong="H3588"\w* \w vida|strong="H4241"\w* \w me|strong="H3588"\w* \w envió|strong="H7971"\w* Dios \w delante|strong="H6440"\w* \w de|strong="H3588"\w* vosotros.  
\v 6 \w Pues|strong="H3588"\w* \w ya|strong="H2088"\w* ha habido \w dos|strong="H8141"\w* \w años|strong="H8141"\w* \w de|strong="H3588"\w* \w hambre|strong="H7458"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w y|strong="H3588"\w* \w aún|strong="H5750"\w* quedan \w cinco|strong="H2568"\w* \w años|strong="H8141"\w* \w en|strong="H3588"\w* \w los|strong="H3588"\w* cuales ni habrá \w arada|strong="H2758"\w* ni siega.  
\v 7 \w Y|strong="H3068"\w* Dios me \w envió|strong="H7971"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros, para preservaros posteridad sobre la tierra, y para daros \w vida|strong="H2421"\w* \w por|strong="H6440"\w* medio \w de|strong="H6440"\w* \w gran|strong="H1419"\w* liberación.  
\v 8 \w Así|strong="H3588"\w*, \w pues|strong="H3588"\w*, \w no|strong="H3808"\w* \w me|strong="H3588"\w* enviasteis \w acá|strong="H2008"\w* vosotros, \w sino|strong="H3588"\w* Dios, \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w ha|strong="H3808"\w* \w puesto|strong="H3588"\w* \w por|strong="H3588"\w* padre \w de|strong="H3588"\w* \w Faraón|strong="H6547"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* señor \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*, \w y|strong="H3588"\w* \w por|strong="H3588"\w* gobernador \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.  
\v 9 Daos prisa, \w id|strong="H5927"\w* \w a|strong="H3068"\w* mi padre \w y|strong="H3541"\w* decidle: ‘\w Así|strong="H3541"\w* dice tu \w hijo|strong="H1121"\w* \w José|strong="H3130"\w*: «Dios \w me|strong="H3541"\w* \w ha|strong="H3541"\w* \w puesto|strong="H5927"\w* por señor \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w Egipto|strong="H4714"\w*; \w ven|strong="H3381"\w* \w a|strong="H3068"\w* mí, no te detengas.  
\v 10 \w Habitarás|strong="H3427"\w* en \w la|strong="H3605"\w* tierra \w de|strong="H1121"\w* Gosén, \w y|strong="H1241"\w* \w estarás|strong="H1961"\w* \w cerca|strong="H7138"\w* \w de|strong="H1121"\w* \w mí|strong="H1961"\w*, tú \w y|strong="H1241"\w* tus \w hijos|strong="H1121"\w*, \w y|strong="H1241"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* tus \w hijos|strong="H1121"\w*, tus \w ganados|strong="H6629"\w* \w y|strong="H1241"\w* tus \w vacas|strong="H1241"\w*, \w y|strong="H1241"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1121"\w* tienes.  
\v 11 \w Y|strong="H3068"\w* \w allí|strong="H8033"\w* \w te|strong="H3588"\w* \w alimentaré|strong="H3605"\w*, \w pues|strong="H3588"\w* \w aún|strong="H5750"\w* quedan \w cinco|strong="H2568"\w* \w años|strong="H8141"\w* \w de|strong="H3588"\w* \w hambre|strong="H7458"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H6435"\w* \w perezcas|strong="H3423"\w* \w de|strong="H3588"\w* pobreza tú \w y|strong="H3588"\w* tu \w casa|strong="H1004"\w*, \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3588"\w* \w tienes|strong="H5750"\w*»’.  
\v 12 He \w aquí|strong="H2009"\w*, vuestros \w ojos|strong="H5869"\w* \w ven|strong="H7200"\w*, \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* \w mi|strong="H2009"\w* hermano \w Benjamín|strong="H1144"\w*, \w que|strong="H3588"\w* \w mi|strong="H2009"\w* propia \w boca|strong="H6310"\w* \w os|strong="H5869"\w* \w habla|strong="H1696"\w*.  
\v 13 Haréis, \w pues|strong="H3381"\w*, \w saber|strong="H5046"\w* \w a|strong="H3068"\w* mi padre \w toda|strong="H3605"\w* mi \w gloria|strong="H3519"\w* en \w Egipto|strong="H4714"\w*, \w y|strong="H3519"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* habéis \w visto|strong="H7200"\w*; \w y|strong="H3519"\w* daos prisa, \w y|strong="H3519"\w* traed \w a|strong="H3068"\w* mi padre \w acá|strong="H2008"\w*”.  
\v 14 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w cuello|strong="H6677"\w* \w de|strong="H5921"\w* \w Benjamín|strong="H1144"\w* su hermano, \w y|strong="H5921"\w* \w lloró|strong="H1058"\w*; \w y|strong="H5921"\w* también \w Benjamín|strong="H1144"\w* \w lloró|strong="H1058"\w* \w sobre|strong="H5921"\w* su \w cuello|strong="H6677"\w*.  
\v 15 \w Y|strong="H3068"\w* \w besó|strong="H5401"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos, \w y|strong="H5921"\w* \w lloró|strong="H1058"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*; \w y|strong="H5921"\w* \w después|strong="H5921"\w* sus hermanos \w hablaron|strong="H1696"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w*.   
\p
\v 16 \w Y|strong="H3068"\w* se \w oyó|strong="H8085"\w* la noticia en la \w casa|strong="H1004"\w* \w de|strong="H5869"\w* \w Faraón|strong="H6547"\w*, diciendo: «Los hermanos \w de|strong="H5869"\w* \w José|strong="H3130"\w* han venido». \w Y|strong="H3068"\w* \w agradó|strong="H3190"\w* en los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w Faraón|strong="H6547"\w* y \w de|strong="H5869"\w* sus \w siervos|strong="H5650"\w*.  
\v 17 \w Y|strong="H3068"\w* dijo \w Faraón|strong="H6547"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*: “Di \w a|strong="H3068"\w* tus hermanos: ‘\w Haced|strong="H6213"\w* \w esto|strong="H2063"\w*: \w cargad|strong="H2943"\w* vuestras \w bestias|strong="H1165"\w*, \w e|strong="H3068"\w* \w id|strong="H3212"\w*, volved \w a|strong="H3068"\w* \w la|strong="H2063"\w* tierra de \w Canaán|strong="H3667"\w*;  
\v 18 y \w tomad|strong="H3947"\w* \w a|strong="H3068"\w* vuestro padre y \w a|strong="H3068"\w* vuestras \w familias|strong="H1004"\w*, y venid \w a|strong="H3068"\w* mí; y yo os \w daré|strong="H5414"\w* lo bueno \w de|strong="H5414"\w* la tierra \w de|strong="H5414"\w* \w Egipto|strong="H4714"\w*, y comeréis \w de|strong="H5414"\w* la abundancia \w de|strong="H5414"\w* la tierra’.  
\v 19 \w Y|strong="H3068"\w* \w tú|strong="H6213"\w* \w manda|strong="H6680"\w*: ‘\w Haced|strong="H6213"\w* \w esto|strong="H2063"\w*: \w tomaos|strong="H3947"\w* \w carros|strong="H5699"\w* de \w la|strong="H2063"\w* tierra de \w Egipto|strong="H4714"\w* para vuestros \w niños|strong="H2945"\w* y vuestras mujeres, y \w traed|strong="H3947"\w* \w a|strong="H3068"\w* vuestro padre, y venid.  
\v 20 \w Y|strong="H3068"\w* \w no|strong="H3588"\w* \w os|strong="H5921"\w* preocupéis \w por|strong="H5921"\w* vuestros \w enseres|strong="H3627"\w*, \w porque|strong="H3588"\w* \w la|strong="H1931"\w* riqueza \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w será|strong="H1931"\w* vuestra’”.   
\p
\v 21 \w Y|strong="H3068"\w* \w lo|strong="H5921"\w* \w hicieron|strong="H6213"\w* \w así|strong="H3651"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*; \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w dio|strong="H5414"\w* \w José|strong="H3130"\w* \w carros|strong="H5699"\w* \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* orden \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w dio|strong="H5414"\w* provisiones \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*.  
\v 22 \w A|strong="H3068"\w* \w cada|strong="H3605"\w* uno \w de|strong="H2568"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w dio|strong="H5414"\w* \w mudas|strong="H2487"\w* \w de|strong="H2568"\w* \w vestidos|strong="H8071"\w*, y \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w* \w dio|strong="H5414"\w* \w trescientas|strong="H7969"\w* piezas \w de|strong="H2568"\w* \w plata|strong="H3701"\w*, y \w cinco|strong="H2568"\w* \w mudas|strong="H2487"\w* \w de|strong="H2568"\w* \w vestidos|strong="H8071"\w*.  
\v 23 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* su padre \w envió|strong="H7971"\w* \w esto|strong="H2063"\w*: \w diez|strong="H6235"\w* \w asnos|strong="H2543"\w* \w cargados|strong="H5375"\w* de lo mejor de \w Egipto|strong="H4714"\w*, y \w diez|strong="H6235"\w* asnas \w cargadas|strong="H5375"\w* de \w trigo|strong="H1250"\w*, y \w pan|strong="H3899"\w* y \w comida|strong="H3899"\w*, para su padre en el \w camino|strong="H1870"\w*.  
\v 24 \w Y|strong="H3068"\w* \w despidió|strong="H7971"\w* \w a|strong="H3068"\w* sus hermanos, y ellos se \w fueron|strong="H3212"\w*. \w Y|strong="H3068"\w* él les dijo: «\w No|strong="H1870"\w* \w riñáis|strong="H7264"\w* \w por|strong="H1870"\w* el \w camino|strong="H1870"\w*».   
\p
\v 25 \w Subieron|strong="H5927"\w*, pues, de \w Egipto|strong="H4714"\w*, y llegaron \w a|strong="H3068"\w* la tierra de \w Canaán|strong="H3667"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* su padre.  
\v 26 \w Y|strong="H3068"\w* \w le|strong="H1931"\w* dieron las nuevas, diciendo: «¡\w José|strong="H3130"\w* \w vive|strong="H2416"\w* \w aún|strong="H5750"\w*, \w y|strong="H3588"\w* \w es|strong="H1931"\w* señor \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*!» \w Y|strong="H3068"\w* \w su|strong="H1931"\w* \w corazón|strong="H3820"\w* \w se|strong="H1931"\w* paralizó, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* les creía.  
\v 27 \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* le \w contaron|strong="H1697"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w José|strong="H3130"\w*, \w que|strong="H1697"\w* \w él|strong="H3605"\w* les había \w hablado|strong="H1696"\w*; y \w viendo|strong="H7200"\w* \w Jacob|strong="H3290"\w* \w los|strong="H3605"\w* \w carros|strong="H5699"\w* \w que|strong="H1697"\w* \w José|strong="H3130"\w* \w enviaba|strong="H7971"\w* para \w llevarlo|strong="H5375"\w*, \w el|strong="H3605"\w* \w espíritu|strong="H7307"\w* \w de|strong="H1697"\w* su padre \w revivió|strong="H2421"\w*.  
\v 28 Entonces dijo \w Israel|strong="H3478"\w*: «¡\w Basta|strong="H7227"\w*! \w José|strong="H3130"\w* mi \w hijo|strong="H1121"\w* \w vive|strong="H2416"\w* \w todavía|strong="H5750"\w*; \w iré|strong="H3212"\w*, y le \w veré|strong="H7200"\w* \w antes|strong="H2962"\w* \w que|strong="H1121"\w* yo \w muera|strong="H4191"\w*».   
\c 46
\p
\v 1 \w Partió|strong="H5265"\w* \w Israel|strong="H3478"\w* con \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tenía, y vino \w a|strong="H3068"\w* Beerseba, y \w ofreció|strong="H2076"\w* \w sacrificios|strong="H2077"\w* al Dios de su padre \w Isaac|strong="H3327"\w*.  
\v 2 \w Y|strong="H3068"\w* habló Dios \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* en \w visiones|strong="H4759"\w* de \w noche|strong="H3915"\w*, y dijo: «¡\w Jacob|strong="H3290"\w*, \w Jacob|strong="H3290"\w*!»  
\p \w Y|strong="H3068"\w* él respondió: «\w Aquí|strong="H2009"\w* estoy».   
\p
\v 3 \w Y|strong="H3068"\w* dijo: «\w Yo|strong="H3588"\w* soy Dios, \w el|strong="H3588"\w* Dios \w de|strong="H3588"\w* tu padre; \w no|strong="H3588"\w* \w temas|strong="H3372"\w* \w de|strong="H3588"\w* descender \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, \w porque|strong="H3588"\w* \w allí|strong="H8033"\w* \w yo|strong="H3588"\w* \w haré|strong="H7760"\w* \w de|strong="H3588"\w* ti una \w gran|strong="H1419"\w* \w nación|strong="H1471"\w*.  
\v 4 Yo \w descenderé|strong="H3381"\w* \w contigo|strong="H5973"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H1571"\w* yo \w también|strong="H1571"\w* \w te|strong="H5869"\w* haré volver; \w y|strong="H1571"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w* cerrará tus \w ojos|strong="H5869"\w*».   
\p
\v 5 \w Y|strong="H3068"\w* se \w levantó|strong="H5375"\w* \w Jacob|strong="H3290"\w* \w de|strong="H1121"\w* Beerseba; y \w llevaron|strong="H5375"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* su padre \w Jacob|strong="H3290"\w*, \w a|strong="H3068"\w* sus \w niños|strong="H2945"\w* y \w a|strong="H3068"\w* sus mujeres, en \w los|strong="H1121"\w* \w carros|strong="H5699"\w* \w que|strong="H1121"\w* \w Faraón|strong="H6547"\w* había \w enviado|strong="H7971"\w* para \w llevarlo|strong="H5375"\w*.  
\v 6 \w Y|strong="H3068"\w* \w tomaron|strong="H3947"\w* sus \w ganados|strong="H4735"\w* y sus bienes \w que|strong="H3605"\w* habían adquirido en \w la|strong="H3605"\w* tierra de \w Canaán|strong="H3667"\w*, y vinieron \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, \w Jacob|strong="H3290"\w* y \w toda|strong="H3605"\w* su \w descendencia|strong="H2233"\w* con \w él|strong="H3605"\w*;  
\v 7 sus \w hijos|strong="H1121"\w*, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* consigo; sus \w hijas|strong="H1323"\w*, y las \w hijas|strong="H1323"\w* \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w*, y \w a|strong="H3068"\w* \w toda|strong="H3605"\w* su \w descendencia|strong="H2233"\w* trajo consigo \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 8 \w Y|strong="H3068"\w* éstos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* entraron en \w Egipto|strong="H4714"\w*, \w Jacob|strong="H3290"\w* y sus \w hijos|strong="H1121"\w*: \w Rubén|strong="H7205"\w*, \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w*.  
\v 9 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*: Hanoc, Falú, \w Hezrón|strong="H2696"\w* y \w Carmi|strong="H3756"\w*.  
