\v 6 \w Y|strong="H3068"\w* \w Faraón|strong="H6547"\w* dijo: «\w Ve|strong="H5927"\w*, y \w sepulta|strong="H6912"\w* \w a|strong="H3068"\w* tu padre, como él te \w hizo|strong="H5927"\w* jurar».   
\p
\v 7 Entonces \w José|strong="H3130"\w* \w subió|strong="H5927"\w* para sepultar \w a|strong="H3068"\w* su padre; y \w subieron|strong="H5927"\w* con \w él|strong="H3605"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w siervos|strong="H5650"\w* de \w Faraón|strong="H6547"\w*, \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de su \w casa|strong="H1004"\w*, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de \w la|strong="H3605"\w* tierra de \w Egipto|strong="H4714"\w*,  
\v 8 \w y|strong="H1241"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de \w José|strong="H3130"\w*, \w y|strong="H1241"\w* sus hermanos, \w y|strong="H1241"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de su padre; \w solamente|strong="H7535"\w* \w dejaron|strong="H5800"\w* en \w la|strong="H3605"\w* tierra de Gosén sus \w niños|strong="H2945"\w*, \w y|strong="H1241"\w* sus \w ovejas|strong="H6629"\w* \w y|strong="H1241"\w* sus \w vacas|strong="H1241"\w*.  
\v 9 \w Subieron|strong="H5927"\w* \w también|strong="H1571"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w carros|strong="H7393"\w* \w y|strong="H1571"\w* gente \w de|strong="H5973"\w* \w a|strong="H3068"\w* caballo, \w y|strong="H1571"\w* \w se|strong="H1961"\w* \w hizo|strong="H5927"\w* un escuadrón \w muy|strong="H3966"\w* \w grande|strong="H3515"\w*.  
\v 10 \w Y|strong="H3068"\w* llegaron \w a|strong="H3068"\w* la era \w de|strong="H5704"\w* Atad, \w que|strong="H5704"\w* \w está|strong="H8033"\w* \w al|strong="H5704"\w* otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, \w y|strong="H5704"\w* endechaban \w allí|strong="H8033"\w* \w con|strong="H5704"\w* \w grande|strong="H1419"\w* \w y|strong="H5704"\w* \w muy|strong="H3966"\w* triste lamentación; \w y|strong="H5704"\w* José \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* su padre duelo \w por|strong="H5704"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.  
\v 11 \w Y|strong="H3068"\w* \w viendo|strong="H7200"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w*, \w el|strong="H5921"\w* llanto \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w era|strong="H2088"\w* \w de|strong="H5921"\w* Atad, dijeron: «Llanto \w grande|strong="H3515"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w egipcios|strong="H4713"\w*»; \w por|strong="H5921"\w* \w eso|strong="H3651"\w* fue \w llamado|strong="H8034"\w* su \w nombre|strong="H8034"\w* Abel-mizraim, \w que|strong="H5921"\w* \w está|strong="H2088"\w* \w al|strong="H5921"\w* \w otro|strong="H2088"\w* \w lado|strong="H5676"\w* \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w*.  
