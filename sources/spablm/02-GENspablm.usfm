\v 8 \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* respondieron: «\w No|strong="H3808"\w* \w podemos|strong="H3201"\w*, \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* junten \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w rebaños|strong="H5739"\w*, \w y|strong="H5921"\w* remuevan \w la|strong="H5921"\w* piedra \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w del|strong="H5921"\w* pozo, \w para|strong="H5704"\w* \w que|strong="H3808"\w* \w abrevemos|strong="H8248"\w* \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w*».   
