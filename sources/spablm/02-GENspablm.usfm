\v 9 \w Y|strong="H3068"\w* cuando llegaron \w al|strong="H5921"\w* \w lugar|strong="H4725"\w* \w que|strong="H5921"\w* Dios \w le|strong="H5921"\w* había dicho, \w edificó|strong="H1129"\w* \w allí|strong="H8033"\w* Abraham un \w altar|strong="H4196"\w*, compuso \w la|strong="H5921"\w* \w leña|strong="H6086"\w*, ató \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* su \w hijo|strong="H1121"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w puso|strong="H7760"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w*.  
\v 10 \w Y|strong="H3068"\w* \w extendió|strong="H7971"\w* Abraham su \w mano|strong="H3027"\w* y \w tomó|strong="H3947"\w* \w el|strong="H1121"\w* cuchillo para degollar \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w*.   
