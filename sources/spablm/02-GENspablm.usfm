\v 13 \w Y|strong="H3068"\w* \w respondieron|strong="H6030"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w a|strong="H3068"\w* Siquem y \w a|strong="H3068"\w* \w Hamor|strong="H2544"\w* su padre con \w palabras|strong="H1696"\w* \w engañosas|strong="H4820"\w*, por cuanto había \w amancillado|strong="H2930"\w* \w a|strong="H3068"\w* \w Dina|strong="H1783"\w* su hermana;  
\v 14 \w y|strong="H3588"\w* les \w dijeron|strong="H1697"\w*: “\w No|strong="H3808"\w* \w podemos|strong="H3201"\w* \w hacer|strong="H6213"\w* \w esto|strong="H2088"\w* \w de|strong="H3588"\w* \w dar|strong="H5414"\w* nuestra hermana \w a|strong="H3068"\w* hombre \w incircunciso|strong="H6190"\w*, \w porque|strong="H3588"\w* \w entre|strong="H3808"\w* \w nosotros|strong="H1931"\w* \w es|strong="H1931"\w* abominación.  
\v 15 Mas con \w esta|strong="H2063"\w* condición os complaceremos: \w si|strong="H1961"\w* habéis de ser \w como|strong="H3644"\w* \w nosotros|strong="H3605"\w*, \w que|strong="H1961"\w* \w se|strong="H1961"\w* circuncide entre vosotros \w todo|strong="H3605"\w* \w varón|strong="H2145"\w*.  
\v 16 Entonces os \w daremos|strong="H5414"\w* nuestras \w hijas|strong="H1323"\w*, y \w tomaremos|strong="H3947"\w* nosotros las vuestras; y habitaremos con vosotros, y \w seremos|strong="H1961"\w* un solo \w pueblo|strong="H5971"\w*.  
\v 17 \w Mas|strong="H3808"\w* \w si|strong="H3808"\w* \w no|strong="H3808"\w* nos prestareis \w oído|strong="H8085"\w* para circuncidaros, \w tomaremos|strong="H3947"\w* \w a|strong="H3068"\w* nuestra \w hija|strong="H1323"\w*,\f + \fr 34:17 \ft El hebreo tiene, literalmente, «hija».\f* y nos \w iremos|strong="H1980"\w*”.   
\p
\v 18 \w Y|strong="H3068"\w* parecieron \w bien|strong="H3190"\w* sus \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* \w Hamor|strong="H2544"\w* y \w a|strong="H3068"\w* Siquem \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hamor|strong="H2544"\w*.  
