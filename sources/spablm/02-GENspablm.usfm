\v 34 Entonces \w Jacob|strong="H3290"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w* \w pan|strong="H3899"\w* y \w del|strong="H8354"\w* guisado \w de|strong="H5414"\w* las \w lentejas|strong="H5742"\w*; y él comió y \w bebió|strong="H8354"\w*, y se \w levantó|strong="H6965"\w* y se \w fue|strong="H3212"\w*. Así menospreció \w Esaú|strong="H6215"\w* la primogenitura.   
\c 26
\p
\v 1 \w Hubo|strong="H1961"\w* \w hambre|strong="H7458"\w* \w en|strong="H3212"\w* la tierra, además de la \w primera|strong="H7223"\w* \w hambre|strong="H7458"\w* \w que|strong="H3117"\w* \w hubo|strong="H1961"\w* \w en|strong="H3212"\w* \w los|strong="H1961"\w* \w días|strong="H3117"\w* de Abraham. \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* Abimelec, \w rey|strong="H4428"\w* de \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*, \w a|strong="H3068"\w* \w Gerar|strong="H1642"\w*.  
\v 2 \w Y|strong="H3068"\w* se le \w apareció|strong="H7200"\w* Yahvé y le dijo: «No \w desciendas|strong="H3381"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*; \w habita|strong="H7931"\w* en la tierra que yo te diré.  
\v 3 \w Habita|strong="H1481"\w* \w como|strong="H3588"\w* forastero \w en|strong="H5973"\w* \w esta|strong="H2063"\w* tierra, \w y|strong="H3588"\w* estaré \w contigo|strong="H5973"\w*, \w y|strong="H3588"\w* \w te|strong="H3588"\w* \w bendeciré|strong="H1288"\w*; \w porque|strong="H3588"\w* \w a|strong="H3068"\w* \w ti|strong="H5973"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* tu \w descendencia|strong="H2233"\w* \w daré|strong="H5414"\w* \w todas|strong="H3605"\w* \w estas|strong="H2063"\w* tierras, \w y|strong="H3588"\w* \w confirmaré|strong="H6965"\w* \w el|strong="H5973"\w* \w juramento|strong="H7621"\w* \w que|strong="H3588"\w* \w hice|strong="H7650"\w* \w a|strong="H3068"\w* Abraham tu padre.  
\v 4 \w Multiplicaré|strong="H7235"\w* tu \w descendencia|strong="H2233"\w* como las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w*, y \w daré|strong="H5414"\w* \w a|strong="H3068"\w* tu \w descendencia|strong="H2233"\w* \w todas|strong="H3605"\w* estas tierras; y \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w de|strong="H5414"\w* \w la|strong="H3605"\w* tierra serán benditas en tu \w simiente|strong="H2233"\w*,  
\v 5 \w por|strong="H6118"\w* cuanto \w oyó|strong="H8085"\w* Abraham mi \w voz|strong="H6963"\w*, y \w guardó|strong="H8104"\w* mi precepto, mis \w mandamientos|strong="H4687"\w*, mis \w estatutos|strong="H2708"\w* y mis \w leyes|strong="H8451"\w*».   
\p
\v 6 \w Habitó|strong="H3427"\w*, pues, \w Isaac|strong="H3327"\w* en \w Gerar|strong="H1642"\w*.  
\v 7 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* \w le|strong="H1931"\w* \w preguntaron|strong="H7592"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* mujer; \w y|strong="H3588"\w* \w él|strong="H1931"\w* respondió: «\w Es|strong="H1931"\w* \w mi|strong="H5921"\w* hermana», \w porque|strong="H3588"\w* \w tuvo|strong="H3372"\w* \w miedo|strong="H3372"\w* \w de|strong="H5921"\w* decir: «\w Es|strong="H1931"\w* \w mi|strong="H5921"\w* mujer»; pensando \w que|strong="H3588"\w* tal vez \w los|strong="H5921"\w* hombres \w del|strong="H5921"\w* \w lugar|strong="H4725"\w* \w lo|strong="H1931"\w* matarían \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* \w Rebeca|strong="H7259"\w*, \w pues|strong="H3588"\w* \w ella|strong="H1931"\w* \w era|strong="H1931"\w* \w de|strong="H5921"\w* \w hermoso|strong="H2896"\w* \w aspecto|strong="H4758"\w*.  
\v 8 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w después|strong="H1961"\w* \w de|strong="H3588"\w* estar \w él|strong="H3588"\w* \w allí|strong="H8033"\w* muchos \w días|strong="H3117"\w*, Abimelec, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*, \w miró|strong="H7200"\w* \w por|strong="H3588"\w* una ventana, \w y|strong="H3588"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w que|strong="H3588"\w* acariciaba \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* \w su|strong="H3588"\w* mujer.  
\v 9 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* Abimelec \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*, \w y|strong="H3588"\w* dijo: “He \w aquí|strong="H2009"\w* \w ella|strong="H1931"\w* \w es|strong="H1931"\w* \w de|strong="H5921"\w* \w cierto|strong="H3588"\w* tu mujer. ¿\w Cómo|strong="H3588"\w*, \w pues|strong="H3588"\w*, dijiste: ‘\w Es|strong="H1931"\w* \w mi|strong="H5921"\w* hermana’?” \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w le|strong="H1931"\w* respondió: “\w Porque|strong="H3588"\w* dije: ‘\w Quizá|strong="H6435"\w* \w moriré|strong="H4191"\w* \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* \w ella|strong="H1931"\w*’”.   
\p
\v 10 \w Y|strong="H3068"\w* Abimelec dijo: «¿\w Qué|strong="H4100"\w* \w es|strong="H2063"\w* \w esto|strong="H2063"\w* \w que|strong="H4100"\w* \w nos|strong="H5921"\w* has \w hecho|strong="H6213"\w*? \w Por|strong="H5921"\w* \w poco|strong="H4592"\w* hubiera dormido alguno \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w con|strong="H5921"\w* \w tu|strong="H6213"\w* mujer, \w y|strong="H5921"\w* hubieras traído \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w el|strong="H5921"\w* pecado».   
\p
\v 11 Entonces Abimelec \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, diciendo: «\w El|strong="H3605"\w* \w que|strong="H5971"\w* \w tocare|strong="H5060"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* hombre \w o|strong="H3068"\w* \w a|strong="H3068"\w* su mujer, \w de|strong="H5971"\w* \w cierto|strong="H4191"\w* \w morirá|strong="H4191"\w*».   
\p
\v 12 \w Y|strong="H3068"\w* sembró \w Isaac|strong="H3327"\w* en \w aquella|strong="H1931"\w* tierra, y cosechó \w aquel|strong="H1931"\w* \w año|strong="H8141"\w* \w ciento|strong="H3967"\w* por uno; y \w le|strong="H1931"\w* \w bendijo|strong="H1288"\w* Yahvé.  
\v 13 \w El|strong="H3588"\w* varón se enriqueció, \w y|strong="H3588"\w* \w fue|strong="H3212"\w* prosperando \w y|strong="H3588"\w* engrandeciéndose \w hasta|strong="H5704"\w* hacerse \w muy|strong="H3966"\w* \w poderoso|strong="H1431"\w*.  
\v 14 \w Y|strong="H3068"\w* \w tuvo|strong="H1961"\w* \w hato|strong="H4735"\w* de \w ovejas|strong="H6629"\w*, \w y|strong="H1241"\w* \w hato|strong="H4735"\w* de \w vacas|strong="H1241"\w*, \w y|strong="H1241"\w* \w mucha|strong="H7227"\w* servidumbre; \w y|strong="H1241"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w* le \w tuvieron|strong="H1961"\w* \w envidia|strong="H7065"\w*.  
\v 15 \w Y|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* pozos \w que|strong="H3117"\w* habían cavado \w los|strong="H3605"\w* \w criados|strong="H5650"\w* de Abraham su padre en sus \w días|strong="H3117"\w*, \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w los|strong="H3605"\w* \w cegaron|strong="H5640"\w* y \w los|strong="H3605"\w* \w llenaron|strong="H4390"\w* de \w tierra|strong="H6083"\w*.  
\v 16 \w Entonces|strong="H3588"\w* dijo Abimelec \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*: «\w Apártate|strong="H3212"\w* \w de|strong="H4480"\w* \w nosotros|strong="H5973"\w*, \w porque|strong="H3588"\w* \w mucho|strong="H3966"\w* \w más|strong="H3588"\w* poderoso \w que|strong="H3588"\w* \w nosotros|strong="H5973"\w* \w te|strong="H4480"\w* has hecho».   
\p
\v 17 \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* se \w fue|strong="H3212"\w* de \w allí|strong="H8033"\w*, y acampó \w en|strong="H3212"\w* \w el|strong="H3427"\w* valle de \w Gerar|strong="H1642"\w*, y \w habitó|strong="H3427"\w* \w allí|strong="H8033"\w*.   
\p
\v 18 \w Y|strong="H3068"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* abrir \w Isaac|strong="H3327"\w* los pozos \w de|strong="H4325"\w* \w agua|strong="H4325"\w* \w que|strong="H3117"\w* habían abierto en los \w días|strong="H3117"\w* \w de|strong="H4325"\w* Abraham su padre, los cuales habían cegado los \w filisteos|strong="H6430"\w* después \w de|strong="H4325"\w* la \w muerte|strong="H4194"\w* \w de|strong="H4325"\w* Abraham; y los \w llamó|strong="H7121"\w* por los \w nombres|strong="H8034"\w* \w que|strong="H3117"\w* su padre los había \w llamado|strong="H8034"\w*.  
\v 19 \w Y|strong="H3068"\w* los \w siervos|strong="H5650"\w* \w de|strong="H4325"\w* \w Isaac|strong="H3327"\w* \w cavaron|strong="H2658"\w* en el valle, y \w hallaron|strong="H4672"\w* \w allí|strong="H8033"\w* un pozo \w de|strong="H4325"\w* \w aguas|strong="H4325"\w* \w vivas|strong="H2416"\w*.\f + \fr 26:19 \ft O, agua fresca.\f*  
\v 20 \w Y|strong="H3068"\w* \w los|strong="H5973"\w* pastores \w de|strong="H3588"\w* \w Gerar|strong="H1642"\w* \w riñeron|strong="H7378"\w* \w con|strong="H5973"\w* \w los|strong="H5973"\w* pastores \w de|strong="H3588"\w* \w Isaac|strong="H3327"\w*, diciendo: «\w El|strong="H5973"\w* \w agua|strong="H4325"\w* \w es|strong="H3588"\w* nuestra». \w Por|strong="H3588"\w* eso \w llamó|strong="H7121"\w* \w el|strong="H5973"\w* \w nombre|strong="H8034"\w* \w del|strong="H5973"\w* pozo \w Esek|strong="H6230"\w*,\f + \fr 26:20 \ft «Esek» significa «contención».\f* \w porque|strong="H3588"\w* habían altercado \w con|strong="H5973"\w* \w él|strong="H5973"\w*.  
\v 21 \w Y|strong="H3068"\w* abrieron otro pozo, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w riñeron|strong="H7378"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*; \w y|strong="H1571"\w* \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* Sitna.\f + \fr 26:21 \ft «Sitna» significa «hostilidad».\f*  
\v 22 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \w allí|strong="H8033"\w*, \w y|strong="H3588"\w* abrió otro pozo, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w riñeron|strong="H7378"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*; \w y|strong="H3588"\w* \w llamó|strong="H7121"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w* Rehobot,\f + \fr 26:22 \ft «Rehobot» significa «lugares amplios».\f* \w y|strong="H3588"\w* dijo: «\w Porque|strong="H3588"\w* \w ahora|strong="H6258"\w* Yahvé \w nos|strong="H5921"\w* \w ha|strong="H3808"\w* prosperado, \w y|strong="H3588"\w* fructificaremos \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra».   
\p
\v 23 \w Y|strong="H3068"\w* de \w allí|strong="H8033"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* Beerseba.  
\v 24 \w Y|strong="H3068"\w* \w se|strong="H1931"\w* \w le|strong="H1931"\w* \w apareció|strong="H7200"\w* Yahvé \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*, \w y|strong="H3588"\w* \w le|strong="H1931"\w* dijo: «\w Yo|strong="H3588"\w* \w soy|strong="H1931"\w* \w el|strong="H1931"\w* \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* Abraham tu padre; \w no|strong="H3588"\w* \w temas|strong="H3372"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* estoy contigo, \w y|strong="H3588"\w* \w te|strong="H3588"\w* \w bendeciré|strong="H1288"\w*, \w y|strong="H3588"\w* \w multiplicaré|strong="H7235"\w* tu \w descendencia|strong="H2233"\w* \w por|strong="H3588"\w* amor \w de|strong="H3588"\w* Abraham mi \w siervo|strong="H5650"\w*».   
\p
\v 25 \w Y|strong="H3068"\w* \w edificó|strong="H1129"\w* \w allí|strong="H8033"\w* un \w altar|strong="H4196"\w*, \w e|strong="H3068"\w* invocó el \w nombre|strong="H8034"\w* de Yahvé, y plantó \w allí|strong="H8033"\w* su tienda; y abrieron \w allí|strong="H8033"\w* los \w siervos|strong="H5650"\w* de \w Isaac|strong="H3327"\w* un pozo.   
\p
\v 26 \w Y|strong="H3068"\w* Abimelec \w vino|strong="H1980"\w* \w a|strong="H3068"\w* él desde \w Gerar|strong="H1642"\w*, y Ahuzat, \w amigo|strong="H4828"\w* suyo, y Ficol, \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* su \w ejército|strong="H6635"\w*.  
\v 27 \w Y|strong="H3068"\w* les dijo \w Isaac|strong="H3327"\w*: «¿\w Por|strong="H4069"\w* qué venís \w a|strong="H3068"\w* mí, \w pues|strong="H7971"\w* que me habéis aborrecido, y me echasteis de entre vosotros?»   
\p
\v 28 \w Y|strong="H3068"\w* ellos respondieron: “Hemos \w visto|strong="H7200"\w* \w que|strong="H3588"\w* Yahvé \w está|strong="H1961"\w* \w contigo|strong="H5973"\w*; \w y|strong="H3588"\w* dijimos: ‘\w Haya|strong="H1961"\w* \w ahora|strong="H4994"\w* juramento \w entre|strong="H5973"\w* \w nosotros|strong="H5973"\w*, \w entre|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w y|strong="H3588"\w* tú, \w y|strong="H3588"\w* hagamos \w pacto|strong="H1285"\w* \w contigo|strong="H5973"\w*,  
\v 29 \w que|strong="H3808"\w* \w no|strong="H3808"\w* nos \w harás|strong="H6213"\w* \w mal|strong="H7451"\w*, \w como|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w no|strong="H3808"\w* \w te|strong="H5973"\w* hemos tocado, y \w como|strong="H5973"\w* \w solamente|strong="H7535"\w* \w te|strong="H5973"\w* hemos \w hecho|strong="H6213"\w* \w bien|strong="H2896"\w*, y \w te|strong="H5973"\w* \w enviamos|strong="H7971"\w* \w en|strong="H5973"\w* \w paz|strong="H7965"\w*; \w tú|strong="H6213"\w* eres \w ahora|strong="H6258"\w* \w bendito|strong="H1288"\w* \w de|strong="H5973"\w* Yahvé’”.   
\p
\v 30 Entonces \w él|strong="H6213"\w* les \w hizo|strong="H6213"\w* \w banquete|strong="H4960"\w*, y comieron y \w bebieron|strong="H8354"\w*.  
\v 31 \w Y|strong="H3068"\w* se levantaron de madrugada, y \w juraron|strong="H7650"\w* el uno al otro. \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* los \w despidió|strong="H7971"\w*, y ellos se \w partieron|strong="H3212"\w* de él \w en|strong="H3212"\w* \w paz|strong="H7965"\w*.  
\v 32 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1931"\w* \w vinieron|strong="H5046"\w* \w los|strong="H5921"\w* \w criados|strong="H5650"\w* \w de|strong="H5921"\w* \w Isaac|strong="H3327"\w*, \w y|strong="H5921"\w* \w le|strong="H1931"\w* dieron nuevas \w acerca|strong="H5921"\w* \w del|strong="H5921"\w* pozo \w que|strong="H1931"\w* \w habían|strong="H1961"\w* cavado, \w y|strong="H5921"\w* \w le|strong="H1931"\w* dijeron: «Hemos \w hallado|strong="H4672"\w* \w agua|strong="H4325"\w*».  
\v 33 \w Y|strong="H3068"\w* \w lo|strong="H2088"\w* \w llamó|strong="H7121"\w* \w Seba|strong="H7656"\w*;\f + \fr 26:33 \ft Seba significa «juramento» o «siete».\f* \w por|strong="H5921"\w* cuya causa \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* \w aquella|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w es|strong="H2088"\w* Beerseba\f + \fr 26:33 \ft Beerseba significa «pozo del juramento» o «pozo de los siete».\f* \w hasta|strong="H5704"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w*.   
\p
\v 34 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* \w Esaú|strong="H6215"\w* \w era|strong="H1961"\w* \w de|strong="H1121"\w* cuarenta \w años|strong="H8141"\w*, \w tomó|strong="H3947"\w* por mujer \w a|strong="H3068"\w* Judit \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Beeri heteo, y \w a|strong="H3068"\w* Basemat \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Elón heteo;  
\v 35 y \w fueron|strong="H1961"\w* amargura de \w espíritu|strong="H7307"\w* \w para|strong="H1961"\w* \w Isaac|strong="H3327"\w* y \w para|strong="H1961"\w* \w Rebeca|strong="H7259"\w*.   
\c 27
\p
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w Isaac|strong="H3327"\w* \w envejeció|strong="H2204"\w*, \w y|strong="H3588"\w* sus \w ojos|strong="H5869"\w* \w se|strong="H1961"\w* oscurecieron quedando sin vista, \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* \w mayor|strong="H1419"\w*, \w y|strong="H3588"\w* \w le|strong="H5869"\w* dijo: «\w Hijo|strong="H1121"\w* mío».  
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: «\w Aquí|strong="H2009"\w* \w estoy|strong="H1961"\w*».   
\p
\v 2 \w Y|strong="H3068"\w* él dijo: «He \w aquí|strong="H2009"\w* \w ya|strong="H4994"\w* soy \w viejo|strong="H2204"\w*, y \w no|strong="H3808"\w* \w sé|strong="H3045"\w* el \w día|strong="H3117"\w* de \w mi|strong="H4994"\w* \w muerte|strong="H4194"\w*.  
\v 3 \w Toma|strong="H5375"\w*, \w pues|strong="H4994"\w*, \w ahora|strong="H6258"\w* tus \w armas|strong="H3627"\w*, tu aljaba y tu \w arco|strong="H7198"\w*, y \w sal|strong="H3318"\w* al \w campo|strong="H7704"\w* y tráeme \w caza|strong="H6679"\w*.  
\v 4 \w Y|strong="H3068"\w* \w hazme|strong="H6213"\w* un guisado como \w a|strong="H3068"\w* \w mí|strong="H5315"\w* me gusta, y tráemelo para que coma, y \w te|strong="H5315"\w* \w bendiga|strong="H1288"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w antes|strong="H2962"\w* que \w yo|strong="H5315"\w* \w muera|strong="H4191"\w*».   
\p
\v 5 \w Y|strong="H3068"\w* \w Rebeca|strong="H7259"\w* estaba \w escuchando|strong="H8085"\w* cuando \w hablaba|strong="H1696"\w* \w Isaac|strong="H3327"\w* \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w* su \w hijo|strong="H1121"\w*. \w Y|strong="H3068"\w* se \w fue|strong="H3212"\w* \w Esaú|strong="H6215"\w* al \w campo|strong="H7704"\w* para cazar la \w caza|strong="H6718"\w* y traerla.  
\v 6 Entonces \w Rebeca|strong="H7259"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Jacob|strong="H3290"\w*, \w diciendo|strong="H1696"\w*: “He \w aquí|strong="H2009"\w* \w yo|strong="H2009"\w* he \w oído|strong="H8085"\w* \w a|strong="H3068"\w* tu padre \w que|strong="H1121"\w* \w hablaba|strong="H1696"\w* con \w Esaú|strong="H6215"\w* tu hermano, \w diciendo|strong="H1696"\w*:  
\v 7 ‘Tráeme \w caza|strong="H6718"\w* y \w hazme|strong="H6213"\w* un guisado, para que coma y te \w bendiga|strong="H1288"\w* en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w antes|strong="H6440"\w* \w de|strong="H6440"\w* mi \w muerte|strong="H4194"\w*’.  
\v 8 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w hijo|strong="H1121"\w* mío, \w obedece|strong="H8085"\w* \w a|strong="H3068"\w* mi \w voz|strong="H6963"\w* en lo \w que|strong="H6258"\w* te \w mando|strong="H6680"\w*.  
\v 9 \w Ve|strong="H3212"\w* \w ahora|strong="H4994"\w* al \w ganado|strong="H6629"\w*, y tráeme de \w allí|strong="H8033"\w* \w dos|strong="H8147"\w* \w buenos|strong="H2896"\w* \w cabritos|strong="H1423"\w* de las \w cabras|strong="H5795"\w*, y \w haré|strong="H6213"\w* de ellos un guisado para \w tu|strong="H6213"\w* padre, como \w a|strong="H3068"\w* \w él|strong="H6213"\w* le gusta.  
\v 10 \w Y|strong="H3068"\w* tú se lo llevarás \w a|strong="H3068"\w* tu padre, y comerá, para que él te \w bendiga|strong="H1288"\w* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* su \w muerte|strong="H4194"\w*”.   
\p
\v 11 \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* dijo \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* su madre: «He \w aquí|strong="H2005"\w*, \w Esaú|strong="H6215"\w* mi hermano es hombre \w velloso|strong="H8163"\w*, y yo \w lampiño|strong="H2509"\w*.  
\v 12 Quizá \w me|strong="H5921"\w* palpará \w mi|strong="H5921"\w* padre, \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w tendrá|strong="H1961"\w* \w por|strong="H5921"\w* burlador, \w y|strong="H5921"\w* traeré \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* \w maldición|strong="H7045"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w bendición|strong="H1293"\w*».   
\p
\v 13 \w Y|strong="H3068"\w* su madre \w le|strong="H5921"\w* respondió: «\w Hijo|strong="H1121"\w* \w mío|strong="H5921"\w*, sea \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* tu \w maldición|strong="H7045"\w*; solamente \w obedece|strong="H8085"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w voz|strong="H6963"\w*, \w y|strong="H5921"\w* \w ve|strong="H3212"\w* \w y|strong="H5921"\w* tráemelos».   
\p
\v 14 \w Él|strong="H6213"\w* \w fue|strong="H3212"\w*, y los \w tomó|strong="H3947"\w*, y los trajo \w a|strong="H3068"\w* su madre; y su madre \w hizo|strong="H6213"\w* un guisado, como \w a|strong="H3068"\w* su padre le gustaba.  
\v 15 \w Y|strong="H3068"\w* \w tomó|strong="H3947"\w* \w Rebeca|strong="H7259"\w* \w los|strong="H1121"\w* \w vestidos|strong="H3847"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w* su \w hijo|strong="H1121"\w* \w mayor|strong="H1419"\w*, \w los|strong="H1121"\w* preciosos, \w que|strong="H1121"\w* ella tenía en \w casa|strong="H1004"\w*, y \w vistió|strong="H3847"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* su \w hijo|strong="H1121"\w* \w menor|strong="H6996"\w*.  
\v 16 \w Y|strong="H3068"\w* \w le|strong="H5921"\w* cubrió \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w parte|strong="H2513"\w* sin vello \w de|strong="H5921"\w* su \w cuello|strong="H6677"\w* \w con|strong="H5921"\w* \w las|strong="H5921"\w* pieles \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w cabritos|strong="H1423"\w*.  
\v 17 \w Y|strong="H3068"\w* \w entregó|strong="H5414"\w* \w el|strong="H1121"\w* guisado y \w el|strong="H1121"\w* \w pan|strong="H3899"\w* \w que|strong="H1121"\w* \w había|strong="H6213"\w* preparado, en \w manos|strong="H3027"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w* su \w hijo|strong="H1121"\w*.   
\p
\v 18 Entonces \w él|strong="H4310"\w* fue \w a|strong="H3068"\w* su padre y dijo: «Padre mío».  
\p \w E|strong="H3068"\w* Isaac respondió: «\w Aquí|strong="H2009"\w* estoy. ¿\w Quién|strong="H4310"\w* eres, \w hijo|strong="H1121"\w* mío?»   
\p
\v 19 \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* su padre: «\w Yo|strong="H5315"\w* soy \w Esaú|strong="H6215"\w* \w tu|strong="H6213"\w* \w primogénito|strong="H1060"\w*; he \w hecho|strong="H6213"\w* como me \w dijiste|strong="H1696"\w*. \w Levántate|strong="H6965"\w* \w ahora|strong="H4994"\w*, y \w siéntate|strong="H3427"\w*, y come de \w mi|strong="H4994"\w* \w caza|strong="H6718"\w*, para \w que|strong="H4994"\w* me \w bendiga|strong="H1288"\w* \w tu|strong="H6213"\w* \w alma|strong="H5315"\w*».   
\p
\v 20 \w Entonces|strong="H3588"\w* \w Isaac|strong="H3327"\w* dijo \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*: «¿\w Cómo|strong="H4100"\w* \w es|strong="H2088"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w hallaste|strong="H4672"\w* tan \w pronto|strong="H4116"\w*, \w hijo|strong="H1121"\w* mío?»  
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: «\w Porque|strong="H3588"\w* Yahvé tu \w Dios|strong="H3068"\w* hizo \w que|strong="H3588"\w* \w la|strong="H3588"\w* encontrase \w delante|strong="H6440"\w* \w de|strong="H3588"\w* mí».   
\p
\v 21 \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* dijo \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: «\w Acércate|strong="H5066"\w* \w ahora|strong="H4994"\w*, y te palparé, \w hijo|strong="H1121"\w* mío, \w por|strong="H2088"\w* \w si|strong="H3808"\w* eres \w mi|strong="H4994"\w* \w hijo|strong="H1121"\w* \w Esaú|strong="H6215"\w* \w o|strong="H3068"\w* \w no|strong="H3808"\w*».   
\p
\v 22 \w Y|strong="H3068"\w* se \w acercó|strong="H5066"\w* \w Jacob|strong="H3290"\w* \w a|strong="H3068"\w* su padre \w Isaac|strong="H3327"\w*, quien le palpó, y dijo: «La \w voz|strong="H6963"\w* \w es|strong="H3027"\w* la \w voz|strong="H6963"\w* de \w Jacob|strong="H3290"\w*, pero las \w manos|strong="H3027"\w*, las \w manos|strong="H3027"\w* de \w Esaú|strong="H6215"\w*».  
\v 23 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* le \w conoció|strong="H5234"\w*, \w porque|strong="H3588"\w* sus \w manos|strong="H3027"\w* \w eran|strong="H1961"\w* \w vellosas|strong="H8163"\w* \w como|strong="H3588"\w* las \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w Esaú|strong="H6215"\w*; \w y|strong="H3588"\w* le \w bendijo|strong="H1288"\w*.  
\v 24 \w Y|strong="H3068"\w* le dijo: «¿Eres tú mi \w hijo|strong="H1121"\w* \w Esaú|strong="H6215"\w*?»  
\p \w Y|strong="H3068"\w* Jacob respondió: «Yo soy».   
\p
\v 25 Dijo también: «\w Acércamela|strong="H5066"\w*, y comeré \w de|strong="H1121"\w* la \w caza|strong="H6718"\w* \w de|strong="H1121"\w* \w mi|strong="H5315"\w* \w hijo|strong="H1121"\w*, \w para|strong="H4616"\w* \w que|strong="H1121"\w* \w te|strong="H5315"\w* \w bendiga|strong="H1288"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*».  
\p \w Y|strong="H3068"\w* \w él|strong="H1121"\w* se la \w acercó|strong="H5066"\w*, \w e|strong="H3068"\w* Isaac comió; le trajo también \w vino|strong="H3196"\w*, y \w bebió|strong="H8354"\w*.  
\v 26 \w Y|strong="H3068"\w* le dijo \w Isaac|strong="H3327"\w* su padre: «\w Acércate|strong="H5066"\w* \w ahora|strong="H4994"\w*, y bésame, \w hijo|strong="H1121"\w* mío».  
\v 27 \w Y|strong="H3068"\w* Jacob se \w acercó|strong="H5066"\w*, y le \w besó|strong="H5401"\w*; y olió Isaac \w el|strong="H1121"\w* \w olor|strong="H7381"\w* \w de|strong="H1121"\w* sus vestidos, y le \w bendijo|strong="H1288"\w*, diciendo:  
\q1 «\w Mira|strong="H7200"\w*, \w el|strong="H1121"\w* \w olor|strong="H7381"\w* \w de|strong="H1121"\w* mi \w hijo|strong="H1121"\w*  
\q2 es como \w el|strong="H1121"\w* \w olor|strong="H7381"\w* del \w campo|strong="H7704"\w* \w que|strong="H1121"\w* Yahvé ha bendecido.   
\q1
\v 28 Dios, pues, te \w dé|strong="H5414"\w* del \w rocío|strong="H2919"\w* del \w cielo|strong="H8064"\w*,  
\q2 y \w de|strong="H5414"\w* la grosura \w de|strong="H5414"\w* la tierra,  
\q2 y \w abundancia|strong="H7230"\w* \w de|strong="H5414"\w* \w trigo|strong="H1715"\w* y \w de|strong="H5414"\w* \w mosto|strong="H8492"\w*.   
\q1
\v 29 \w Sírvante|strong="H5647"\w* \w pueblos|strong="H5971"\w*,  
\q2 y naciones \w se|strong="H5971"\w* inclinen \w a|strong="H3068"\w* ti.  
\q1 \w Sé|strong="H5971"\w* señor \w de|strong="H1121"\w* tus hermanos,  
\q2 y \w se|strong="H5971"\w* inclinen ante ti \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* tu madre.  
\q1 Malditos \w los|strong="H1121"\w* \w que|strong="H5971"\w* te maldijeren,  
\q2 y \w benditos|strong="H1288"\w* \w los|strong="H1121"\w* \w que|strong="H5971"\w* te bendijeren».   
\p
\v 30 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w*, \w luego|strong="H3318"\w* \w que|strong="H1961"\w* \w Isaac|strong="H3327"\w* \w acabó|strong="H3615"\w* \w de|strong="H6440"\w* bendecir \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, y apenas \w había|strong="H1961"\w* \w salido|strong="H3318"\w* \w Jacob|strong="H3290"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Isaac|strong="H3327"\w* su padre, \w que|strong="H1961"\w* \w Esaú|strong="H6215"\w* su hermano volvió \w de|strong="H6440"\w* su \w caza|strong="H6718"\w*.  
\v 31 \w E|strong="H3068"\w* \w hizo|strong="H6213"\w* \w él|strong="H1931"\w* \w también|strong="H1571"\w* un guisado, \w y|strong="H1571"\w* \w lo|strong="H1931"\w* trajo \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre, \w y|strong="H1571"\w* \w le|strong="H1931"\w* dijo: «\w Levántese|strong="H6965"\w* \w mi|strong="H5315"\w* padre, \w y|strong="H1571"\w* coma \w de|strong="H1121"\w* \w la|strong="H1931"\w* \w caza|strong="H6718"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* \w hijo|strong="H1121"\w*, para \w que|strong="H1931"\w* me \w bendiga|strong="H1288"\w* \w tu|strong="H6213"\w* \w alma|strong="H5315"\w*».   
\p
\v 32 Entonces \w Isaac|strong="H3327"\w* su padre \w le|strong="H4310"\w* dijo: «¿\w Quién|strong="H4310"\w* eres tú?»  
\p \w Y|strong="H3068"\w* \w él|strong="H4310"\w* \w le|strong="H4310"\w* dijo: «Yo soy tu \w hijo|strong="H1121"\w*, tu \w primogénito|strong="H1060"\w*, \w Esaú|strong="H6215"\w*».   
\p
\v 33 \w Y|strong="H3068"\w* \w se|strong="H1961"\w* estremeció \w Isaac|strong="H3327"\w* \w grandemente|strong="H3966"\w*, \w y|strong="H1571"\w* dijo: «¿\w Quién|strong="H4310"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w que|strong="H4310"\w* \w vino|strong="H1961"\w* aquí, \w que|strong="H4310"\w* trajo \w caza|strong="H6718"\w*, \w y|strong="H1571"\w* \w me|strong="H4310"\w* dio, \w y|strong="H1571"\w* comí \w de|strong="H5704"\w* \w todo|strong="H3605"\w* \w antes|strong="H2962"\w* \w que|strong="H4310"\w* tú vinieses? Yo \w le|strong="H1931"\w* \w bendije|strong="H1288"\w*, \w y|strong="H1571"\w* \w será|strong="H1961"\w* \w bendito|strong="H1288"\w*».   
\p
\v 34 \w Cuando|strong="H5704"\w* \w Esaú|strong="H6215"\w* \w oyó|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H5704"\w* su padre, \w clamó|strong="H6817"\w* \w con|strong="H1571"\w* una \w muy|strong="H3966"\w* \w grande|strong="H1419"\w* \w y|strong="H1571"\w* \w muy|strong="H3966"\w* \w amarga|strong="H4751"\w* \w exclamación|strong="H6818"\w*, \w y|strong="H1571"\w* le dijo: «\w Bendíceme|strong="H1288"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* mí, padre mío».   
\p
\v 35 \w Y|strong="H3068"\w* él dijo: «Vino tu hermano con \w engaño|strong="H4820"\w*, y \w tomó|strong="H3947"\w* tu \w bendición|strong="H1293"\w*».   
\p
\v 36 \w Y|strong="H3068"\w* Esaú respondió: «\w Bien|strong="H3588"\w* \w llamaron|strong="H7121"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Jacob|strong="H3290"\w*, \w pues|strong="H3588"\w* \w ya|strong="H2088"\w* \w me|strong="H3588"\w* \w ha|strong="H3808"\w* suplantado \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*: \w se|strong="H3808"\w* apoderó \w de|strong="H3588"\w* \w mi|strong="H2009"\w* primogenitura, \w y|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w ahora|strong="H6258"\w* \w ha|strong="H3808"\w* \w tomado|strong="H3947"\w* \w mi|strong="H2009"\w* \w bendición|strong="H1293"\w*». \w Y|strong="H3068"\w* añadió: «¿\w No|strong="H3808"\w* has guardado \w bendición|strong="H1293"\w* \w para|strong="H3588"\w* \w mí|strong="H2009"\w*?»   
\p
\v 37 \w Isaac|strong="H3327"\w* \w respondió|strong="H6030"\w* y dijo \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w*: «He \w aquí|strong="H2005"\w* \w yo|strong="H6213"\w* le he \w puesto|strong="H5414"\w* \w por|strong="H4100"\w* señor tuyo, y le he \w dado|strong="H5414"\w* \w por|strong="H4100"\w* \w siervos|strong="H5650"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos; \w de|strong="H1121"\w* \w trigo|strong="H1715"\w* y \w de|strong="H1121"\w* \w vino|strong="H8492"\w* le he provisto. ¿\w Qué|strong="H4100"\w*, \w pues|strong="H4100"\w*, te \w haré|strong="H6213"\w* \w a|strong="H3068"\w* ti ahora, \w hijo|strong="H1121"\w* mío?»   
\p
\v 38 \w Y|strong="H3068"\w* \w Esaú|strong="H6215"\w* respondió \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre: «¿No tienes \w más|strong="H1571"\w* \w que|strong="H1931"\w* una sola \w bendición|strong="H1293"\w*, padre mío? \w Bendíceme|strong="H1288"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* \w mí|strong="H5375"\w*, padre mío». \w Y|strong="H3068"\w* \w alzó|strong="H5375"\w* \w Esaú|strong="H6215"\w* \w su|strong="H1931"\w* \w voz|strong="H6963"\w*, \w y|strong="H1571"\w* \w lloró|strong="H1058"\w*.   
\p
\v 39 Entonces \w Isaac|strong="H3327"\w* su padre \w habló|strong="H6030"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijo:  
\q1 «He \w aquí|strong="H2009"\w*, \w será|strong="H1961"\w* tu habitación \w en|strong="H5921"\w* \w la|strong="H5921"\w* grosura \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra,  
\q1 \w y|strong="H5921"\w* \w del|strong="H5921"\w* \w rocío|strong="H2919"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w* \w de|strong="H5921"\w* arriba.   
\q1
\v 40 \w Por|strong="H5921"\w* tu \w espada|strong="H2719"\w* \w vivirás|strong="H2421"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* tu hermano \w servirás|strong="H5647"\w*.  
\q1 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w cuando|strong="H1961"\w* \w te|strong="H5921"\w* fortalezcas,  
\q1 \w que|strong="H5921"\w* descargarás su \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* tu cerviz».   
\p
\v 41 \w Y|strong="H3068"\w* aborreció \w Esaú|strong="H6215"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w bendición|strong="H1293"\w* \w con|strong="H5921"\w* \w que|strong="H5921"\w* su padre \w le|strong="H5921"\w* había bendecido, \w y|strong="H5921"\w* dijo \w en|strong="H5921"\w* su \w corazón|strong="H3820"\w*: «\w Llegarán|strong="H7126"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w del|strong="H5921"\w* luto \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre, \w y|strong="H5921"\w* yo \w mataré|strong="H2026"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* hermano \w Jacob|strong="H3290"\w*».   
\p
\v 42 \w Y|strong="H3068"\w* fueron dichas \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w* su \w hijo|strong="H1121"\w* \w mayor|strong="H1419"\w*; y ella \w envió|strong="H7971"\w* y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* su \w hijo|strong="H1121"\w* \w menor|strong="H6996"\w*, y le \w dijo|strong="H5046"\w*: «He \w aquí|strong="H2009"\w*, \w Esaú|strong="H6215"\w* tu hermano se \w consuela|strong="H5162"\w* \w acerca|strong="H1697"\w* \w de|strong="H1121"\w* ti con la idea \w de|strong="H1121"\w* matarte.  
\v 43 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w hijo|strong="H1121"\w* mío, \w obedece|strong="H8085"\w* \w a|strong="H3068"\w* mi \w voz|strong="H6963"\w*. \w Levántate|strong="H6965"\w* y huye \w a|strong="H3068"\w* casa \w de|strong="H1121"\w* \w Labán|strong="H3837"\w* mi hermano, en \w Harán|strong="H2771"\w*.  
\v 44 \w Y|strong="H3068"\w* \w mora|strong="H3427"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* algunos \w días|strong="H3117"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w el|strong="H5973"\w* \w enojo|strong="H2534"\w* \w de|strong="H5973"\w* tu hermano se mitigue;  
\v 45 \w hasta|strong="H5704"\w* \w que|strong="H4100"\w* \w se|strong="H4480"\w* aplaque \w la|strong="H1571"\w* ira \w de|strong="H4480"\w* \w tu|strong="H6213"\w* hermano \w contra|strong="H4480"\w* \w ti|strong="H4480"\w*, \w y|strong="H1571"\w* olvide \w lo|strong="H4100"\w* \w que|strong="H4100"\w* le has \w hecho|strong="H6213"\w*. \w Entonces|strong="H3117"\w* \w enviaré|strong="H7971"\w* \w y|strong="H1571"\w* \w te|strong="H4480"\w* traeré \w de|strong="H4480"\w* \w allá|strong="H8033"\w*. ¿\w Por|strong="H4480"\w* \w qué|strong="H4100"\w* seré privada \w de|strong="H4480"\w* vosotros \w dos|strong="H8147"\w* \w en|strong="H4480"\w* un solo \w día|strong="H3117"\w*?»   
\p
\v 46 \w Y|strong="H3068"\w* dijo \w Rebeca|strong="H7259"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*: «Fastidio tengo \w de|strong="H6440"\w* mi \w vida|strong="H2416"\w*, \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* las \w hijas|strong="H1323"\w* \w de|strong="H6440"\w* Het. \w Si|strong="H6440"\w* \w Jacob|strong="H3290"\w* \w toma|strong="H3947"\w* mujer \w de|strong="H6440"\w* las \w hijas|strong="H1323"\w* \w de|strong="H6440"\w* Het, \w como|strong="H4100"\w* éstas, \w de|strong="H6440"\w* las \w hijas|strong="H1323"\w* \w de|strong="H6440"\w* esta tierra, ¿para \w qué|strong="H4100"\w* quiero la \w vida|strong="H2416"\w*?»   
\c 28
\p
\v 1 Entonces \w Isaac|strong="H3327"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, y \w lo|strong="H3808"\w* \w bendijo|strong="H1288"\w*, y le \w mandó|strong="H6680"\w* diciendo: «\w No|strong="H3808"\w* \w tomes|strong="H3947"\w* mujer de las \w hijas|strong="H1323"\w* de \w Canaán|strong="H3667"\w*.  
\v 2 \w Levántate|strong="H6965"\w*, \w ve|strong="H3212"\w* \w a|strong="H3068"\w* Padán Aram, \w a|strong="H3068"\w* \w casa|strong="H1004"\w* de Betuel, padre de tu madre, y \w toma|strong="H3947"\w* \w allí|strong="H8033"\w* mujer de las \w hijas|strong="H1323"\w* de \w Labán|strong="H3837"\w*, hermano de tu madre.  
\v 3 \w Y|strong="H3068"\w* el Dios \w Omnipotente|strong="H7706"\w* te \w bendiga|strong="H1288"\w*, y te haga fructificar y te multiplique, hasta llegar \w a|strong="H3068"\w* ser \w multitud|strong="H6951"\w* \w de|strong="H5971"\w* \w pueblos|strong="H5971"\w*;  
\v 4 y te \w dé|strong="H5414"\w* la \w bendición|strong="H1293"\w* \w de|strong="H5414"\w* Abraham, \w a|strong="H3068"\w* ti y \w a|strong="H3068"\w* tu \w descendencia|strong="H2233"\w* contigo, \w para|strong="H5414"\w* que heredes la tierra en que moras, que Dios \w dio|strong="H5414"\w* \w a|strong="H3068"\w* Abraham».   
\p
\v 5 Así \w envió|strong="H7971"\w* \w Isaac|strong="H3327"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, \w el|strong="H1121"\w* cual \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Padán Aram, \w a|strong="H3068"\w* \w Labán|strong="H3837"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Betuel arameo, hermano \w de|strong="H1121"\w* \w Rebeca|strong="H7259"\w* madre \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w* y \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.   
\p
\v 6 \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* \w Esaú|strong="H6215"\w* \w cómo|strong="H3588"\w* \w Isaac|strong="H3327"\w* \w había|strong="H3588"\w* bendecido \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, \w y|strong="H3588"\w* \w le|strong="H5921"\w* \w había|strong="H3588"\w* \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* Padán Aram \w para|strong="H5921"\w* \w tomar|strong="H3947"\w* \w para|strong="H5921"\w* \w sí|strong="H3588"\w* mujer \w de|strong="H5921"\w* \w allí|strong="H8033"\w*; \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w le|strong="H5921"\w* \w bendijo|strong="H1288"\w*, \w le|strong="H5921"\w* \w había|strong="H3588"\w* \w mandado|strong="H6680"\w* diciendo: «\w No|strong="H3808"\w* \w tomarás|strong="H3947"\w* mujer \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w hijas|strong="H1323"\w* \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w*»;  
\v 7 y que \w Jacob|strong="H3290"\w* había obedecido \w a|strong="H3068"\w* su padre y \w a|strong="H3068"\w* su madre, y se había \w ido|strong="H3212"\w* \w a|strong="H3068"\w* Padán Aram.  
\v 8 \w Vio|strong="H7200"\w* asimismo \w Esaú|strong="H6215"\w* \w que|strong="H3588"\w* las \w hijas|strong="H1323"\w* \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w* \w parecían|strong="H5869"\w* \w mal|strong="H7451"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w su|strong="H3588"\w* padre;  
\v 9 \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w fue|strong="H3212"\w* \w Esaú|strong="H6215"\w* \w a|strong="H3068"\w* \w Ismael|strong="H3458"\w*, \w y|strong="H5921"\w* \w tomó|strong="H3947"\w* \w para|strong="H5921"\w* \w sí|strong="H5921"\w* \w por|strong="H5921"\w* mujer \w a|strong="H3068"\w* Mahalat, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Ismael|strong="H3458"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Abraham, hermana \w de|strong="H5921"\w* Nebaiot, \w además|strong="H5921"\w* \w de|strong="H5921"\w* sus otras \w mujeres|strong="H1323"\w*.   
\p
\v 10 \w Salió|strong="H3318"\w*, pues, \w Jacob|strong="H3290"\w* de Beerseba, y \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Harán|strong="H2771"\w*.  
\v 11 \w Y|strong="H3068"\w* llegó \w a|strong="H3068"\w* un \w cierto|strong="H3588"\w* \w lugar|strong="H4725"\w*, \w y|strong="H3588"\w* \w durmió|strong="H7901"\w* \w allí|strong="H8033"\w*, \w porque|strong="H3588"\w* ya \w el|strong="H1931"\w* \w sol|strong="H8121"\w* \w se|strong="H1931"\w* \w había|strong="H3588"\w* \w puesto|strong="H3588"\w*; \w y|strong="H3588"\w* \w tomó|strong="H3947"\w* \w de|strong="H3588"\w* las piedras \w de|strong="H3588"\w* \w aquel|strong="H1931"\w* paraje \w y|strong="H3588"\w* \w puso|strong="H7760"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w cabecera|strong="H4763"\w*, \w y|strong="H3588"\w* \w se|strong="H1931"\w* acostó \w en|strong="H3588"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w*.  
\v 12 \w Y|strong="H3068"\w* \w soñó|strong="H2492"\w*: y he \w aquí|strong="H2009"\w* una escalera que \w estaba|strong="H5324"\w* apoyada en tierra, y su extremo \w tocaba|strong="H5060"\w* en el \w cielo|strong="H8064"\w*; y he \w aquí|strong="H2009"\w* \w ángeles|strong="H4397"\w* de Dios que \w subían|strong="H5927"\w* y \w descendían|strong="H3381"\w* por ella.  
\v 13 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w*, Yahvé \w estaba|strong="H5324"\w* \w en|strong="H5921"\w* \w lo|strong="H5921"\w* alto \w de|strong="H5921"\w* \w ella|strong="H5921"\w*, \w el|strong="H5921"\w* cual dijo: «\w Yo|strong="H2009"\w* soy Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* Abraham tu padre, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Isaac|strong="H3327"\w*; \w la|strong="H5921"\w* tierra \w en|strong="H5921"\w* \w que|strong="H5921"\w* estás \w acostado|strong="H7901"\w* \w te|strong="H5921"\w* \w la|strong="H5921"\w* \w daré|strong="H5414"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* tu \w descendencia|strong="H2233"\w*.  
\v 14 \w Será|strong="H1961"\w* tu \w descendencia|strong="H2233"\w* \w como|strong="H1961"\w* \w el|strong="H3605"\w* \w polvo|strong="H6083"\w* de \w la|strong="H3605"\w* \w tierra|strong="H6083"\w*, y \w te|strong="H3220"\w* extenderás al occidente, al \w oriente|strong="H6924"\w*, al \w norte|strong="H6828"\w* y al sur; y \w todas|strong="H3605"\w* las \w familias|strong="H4940"\w* de \w la|strong="H3605"\w* \w tierra|strong="H6083"\w* \w serán|strong="H1961"\w* benditas en ti y en tu \w simiente|strong="H2233"\w*.  
\v 15 He \w aquí|strong="H2009"\w*, \w yo|strong="H3588"\w* estoy \w contigo|strong="H5973"\w*, \w y|strong="H3588"\w* \w te|strong="H3588"\w* \w guardaré|strong="H8104"\w* \w por|strong="H3588"\w* dondequiera \w que|strong="H3588"\w* \w fueres|strong="H3212"\w*, \w y|strong="H3588"\w* \w volveré|strong="H7725"\w* \w a|strong="H3068"\w* traerte \w a|strong="H3068"\w* \w esta|strong="H2063"\w* tierra; \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w dejaré|strong="H5800"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* haya \w hecho|strong="H6213"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* he \w dicho|strong="H1696"\w*».   
\p
\v 16 \w Y|strong="H3068"\w* \w despertó|strong="H3364"\w* \w Jacob|strong="H3290"\w* de su \w sueño|strong="H8142"\w*, y dijo: «\w Ciertamente|strong="H3426"\w* Yahvé \w está|strong="H2088"\w* en \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, y yo \w no|strong="H3808"\w* \w lo|strong="H2088"\w* \w sabía|strong="H3045"\w*».  
\v 17 \w Y|strong="H3068"\w* \w tuvo|strong="H3372"\w* \w miedo|strong="H3372"\w*, \w y|strong="H3588"\w* dijo: «¡\w Cuán|strong="H4100"\w* \w terrible|strong="H3372"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*! \w No|strong="H3588"\w* \w es|strong="H2088"\w* otra \w cosa|strong="H2088"\w* \w que|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Dios, \w y|strong="H3588"\w* \w puerta|strong="H8179"\w* del \w cielo|strong="H8064"\w*».   
\p
\v 18 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* levantó \w Jacob|strong="H3290"\w* \w de|strong="H5921"\w* \w mañana|strong="H1242"\w*, \w y|strong="H5921"\w* \w tomó|strong="H3947"\w* \w la|strong="H5921"\w* piedra \w que|strong="H5921"\w* había puesto \w de|strong="H5921"\w* \w cabecera|strong="H4763"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* alzó \w por|strong="H5921"\w* señal, \w y|strong="H5921"\w* \w derramó|strong="H3332"\w* \w aceite|strong="H8081"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*.  
\v 19 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w el|strong="H1931"\w* \w nombre|strong="H8034"\w* de \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* Betel, aunque \w Luz|strong="H3870"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* \w nombre|strong="H8034"\w* de \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w primero|strong="H7223"\w*.  
