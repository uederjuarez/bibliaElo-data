\p \w Y|strong="H3068"\w* él respondió: «\w Aquí|strong="H2009"\w* estoy».   
\p
\v 12 \w Y|strong="H3068"\w* dijo: «\w No|strong="H3808"\w* \w extiendas|strong="H7971"\w* \w tu|strong="H6213"\w* \w mano|strong="H3027"\w* \w sobre|strong="H4480"\w* \w el|strong="H3588"\w* \w muchacho|strong="H5288"\w*, \w ni|strong="H3808"\w* le \w hagas|strong="H6213"\w* \w nada|strong="H3808"\w*; \w porque|strong="H3588"\w* \w ya|strong="H6258"\w* \w conozco|strong="H3045"\w* \w que|strong="H3588"\w* \w temes|strong="H3373"\w* \w a|strong="H3068"\w* Dios, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H4480"\w* \w rehusaste|strong="H2820"\w* \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w hijo|strong="H1121"\w*, \w tu|strong="H6213"\w* \w único|strong="H3173"\w* \w hijo|strong="H1121"\w*».   
\p
\v 13 Entonces \w alzó|strong="H5375"\w* Abraham sus \w ojos|strong="H5869"\w* y \w miró|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* \w a|strong="H3068"\w* sus espaldas un carnero trabado \w en|strong="H8478"\w* un zarzal \w por|strong="H8478"\w* sus \w cuernos|strong="H7161"\w*; y \w fue|strong="H3212"\w* Abraham y \w tomó|strong="H3947"\w* \w el|strong="H1121"\w* carnero, y lo \w ofreció|strong="H5927"\w* \w en|strong="H8478"\w* \w holocausto|strong="H5930"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* su \w hijo|strong="H1121"\w*.  
\v 14 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* Abraham \w el|strong="H1931"\w* \w nombre|strong="H8034"\w* de \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* «Yahvé \w proveerá|strong="H7200"\w*».\f + \fr 22:14 \ft o, Yahvé-Jireh, que significa «Yahvé provee».\f* Por tanto \w se|strong="H1931"\w* dice \w hoy|strong="H3117"\w*: «En \w el|strong="H1931"\w* \w monte|strong="H2022"\w* de Yahvé \w será|strong="H1931"\w* provisto».   
\p
\v 15 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* el \w ángel|strong="H4397"\w* \w de|strong="H4480"\w* Yahvé \w a|strong="H3068"\w* Abraham \w por|strong="H4480"\w* \w segunda|strong="H8145"\w* vez \w desde|strong="H4480"\w* el \w cielo|strong="H8064"\w*,  
\v 16 \w y|strong="H3588"\w* \w dijo|strong="H5002"\w*: «\w Por|strong="H3588"\w* mí mismo he \w jurado|strong="H7650"\w*, \w dice|strong="H5002"\w* Yahvé, \w que|strong="H3588"\w* \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* has \w hecho|strong="H6213"\w* \w esto|strong="H2088"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* has rehusado \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w hijo|strong="H1121"\w*, \w tu|strong="H6213"\w* \w único|strong="H3173"\w* \w hijo|strong="H1121"\w*,  
\v 17 \w de|strong="H5921"\w* \w cierto|strong="H3588"\w* \w te|strong="H5921"\w* \w bendeciré|strong="H1288"\w*, \w y|strong="H3588"\w* \w multiplicaré|strong="H7235"\w* tu \w descendencia|strong="H2233"\w* \w como|strong="H3588"\w* \w las|strong="H5921"\w* \w estrellas|strong="H3556"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w* \w y|strong="H3588"\w* \w como|strong="H3588"\w* \w la|strong="H5921"\w* arena \w que|strong="H3588"\w* \w está|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* orilla \w del|strong="H5921"\w* \w mar|strong="H3220"\w*; \w y|strong="H3588"\w* tu \w descendencia|strong="H2233"\w* \w poseerá|strong="H3423"\w* \w las|strong="H5921"\w* \w puertas|strong="H8179"\w* \w de|strong="H5921"\w* sus enemigos.  
\v 18 En tu \w simiente|strong="H2233"\w* serán benditas \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* de \w la|strong="H3605"\w* tierra, \w por|strong="H6118"\w* cuanto has obedecido \w a|strong="H3068"\w* mi \w voz|strong="H6963"\w*».   
\p
\v 19 \w Y|strong="H3068"\w* \w volvió|strong="H7725"\w* Abraham \w a|strong="H3068"\w* sus \w mozos|strong="H5288"\w*, y se \w levantaron|strong="H6965"\w* y se \w fueron|strong="H3212"\w* \w juntos|strong="H3162"\w* \w a|strong="H3068"\w* Beerseba; y \w habitó|strong="H3427"\w* Abraham \w en|strong="H3212"\w* Beerseba.   
\p
\v 20 \w Aconteció|strong="H1961"\w* \w después|strong="H1961"\w* \w de|strong="H1121"\w* estas \w cosas|strong="H1697"\w*, \w que|strong="H1931"\w* \w fue|strong="H1961"\w* dada \w la|strong="H1931"\w* nueva \w a|strong="H3068"\w* Abraham, diciendo: «He \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w también|strong="H1571"\w* \w Milca|strong="H4435"\w* ha dado \w a|strong="H3068"\w* luz \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* Nacor tu hermano:  
\v 21 \w Uz|strong="H5780"\w* su \w primogénito|strong="H1060"\w*, Buz su hermano, Kemuel padre de Aram,  
\v 22 Quesed, Hazo, Pildas, Jidlaf y Betuel».  
\v 23 \w Y|strong="H3068"\w* Betuel \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w*. \w A|strong="H3068"\w* estos \w ocho|strong="H8083"\w* dio \w a|strong="H3068"\w* luz \w Milca|strong="H4435"\w* para Nacor, hermano de Abraham.  
\v 24 \w Y|strong="H3068"\w* \w su|strong="H1931"\w* \w concubina|strong="H6370"\w*, \w que|strong="H1931"\w* \w se|strong="H1931"\w* \w llamaba|strong="H8034"\w* \w Reúma|strong="H7208"\w*, dio \w a|strong="H3068"\w* luz \w también|strong="H1571"\w* \w a|strong="H3068"\w* Teba, \w a|strong="H3068"\w* Gaham, \w a|strong="H3068"\w* Tahas \w y|strong="H1571"\w* \w a|strong="H3068"\w* Maaca.   
\c 23
\p
\v 1 \w Fue|strong="H1961"\w* la \w vida|strong="H2416"\w* de \w Sara|strong="H8283"\w* \w ciento|strong="H3967"\w* \w veintisiete|strong="H6242"\w* \w años|strong="H8141"\w*; estos \w fueron|strong="H1961"\w* \w los|strong="H1961"\w* \w años|strong="H8141"\w* de la \w vida|strong="H2416"\w* de \w Sara|strong="H8283"\w*.  
\v 2 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Sara|strong="H8283"\w* en Quiriat Arba, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Hebrón|strong="H2275"\w*, en \w la|strong="H1931"\w* tierra de \w Canaán|strong="H3667"\w*; y vino Abraham \w a|strong="H3068"\w* hacer duelo por \w Sara|strong="H8283"\w* y \w a|strong="H3068"\w* llorarla.  
\v 3 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* Abraham \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* su \w muerta|strong="H4191"\w*, \w y|strong="H5921"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Het, \w diciendo|strong="H1696"\w*:  
\v 4 «Forastero y advenedizo soy \w entre|strong="H5973"\w* \w vosotros|strong="H5973"\w*; \w dadme|strong="H5414"\w* heredad \w de|strong="H6440"\w* \w sepultura|strong="H6913"\w* \w entre|strong="H5973"\w* \w vosotros|strong="H5973"\w*, y sepultaré \w a|strong="H3068"\w* mi \w muerta|strong="H4191"\w* \w de|strong="H6440"\w* mi \w presencia|strong="H6440"\w*».   
\p
\v 5 \w Y|strong="H3068"\w* \w respondieron|strong="H6030"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het \w a|strong="H3068"\w* Abraham, diciéndole:  
\v 6 «\w Óyenos|strong="H8085"\w*, señor nuestro; eres un \w príncipe|strong="H5387"\w* \w de|strong="H4480"\w* Dios \w entre|strong="H8432"\w* nosotros; \w en|strong="H4480"\w* el mejor \w de|strong="H4480"\w* nuestros \w sepulcros|strong="H6913"\w* \w sepulta|strong="H6912"\w* \w a|strong="H3068"\w* tu \w muerta|strong="H4191"\w*. \w Ninguno|strong="H3808"\w* \w de|strong="H4480"\w* nosotros \w te|strong="H4480"\w* negará su \w sepulcro|strong="H6913"\w*, \w ni|strong="H3808"\w* \w te|strong="H4480"\w* \w impedirá|strong="H3607"\w* \w que|strong="H4480"\w* \w entierres|strong="H6912"\w* \w a|strong="H3068"\w* tu \w muerta|strong="H4191"\w*».   
\p
\v 7 \w Y|strong="H3068"\w* Abraham \w se|strong="H5971"\w* \w levantó|strong="H6965"\w*, y \w se|strong="H5971"\w* inclinó ante \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w* \w de|strong="H1121"\w* aquella tierra, ante \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het.  
\v 8 \w Y|strong="H3068"\w* \w habló|strong="H1696"\w* con ellos, \w diciendo|strong="H1696"\w*: «\w Si|strong="H6440"\w* \w tenéis|strong="H3426"\w* \w por|strong="H6440"\w* bien \w que|strong="H1121"\w* \w yo|strong="H5315"\w* sepulte \w a|strong="H3068"\w* \w mi|strong="H5315"\w* \w muerta|strong="H4191"\w* \w de|strong="H6440"\w* \w mi|strong="H5315"\w* \w presencia|strong="H6440"\w*, \w escuchadme|strong="H8085"\w*, \w e|strong="H3068"\w* interceded \w por|strong="H6440"\w* \w mí|strong="H5315"\w* con Efrón, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Zohar,  
\v 9 \w para|strong="H5414"\w* que me venda la \w cueva|strong="H4631"\w* \w de|strong="H5414"\w* Macpela que tiene, que está al \w extremo|strong="H7097"\w* \w de|strong="H5414"\w* su \w heredad|strong="H7704"\w*. Que \w por|strong="H5414"\w* su \w justo|strong="H4392"\w* \w precio|strong="H3701"\w* me la \w dé|strong="H5414"\w* \w entre|strong="H8432"\w* vosotros como posesión \w para|strong="H5414"\w* lugar \w de|strong="H5414"\w* \w sepultura|strong="H6913"\w*».   
\p
\v 10 Efrón \w estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het. \w Y|strong="H3068"\w* \w respondió|strong="H6030"\w* Efrón \w el|strong="H3605"\w* heteo \w a|strong="H3068"\w* Abraham, \w en|strong="H8432"\w* presencia \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het, \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H1121"\w* entraban por \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w*, diciendo:  
\v 11 «\w No|strong="H3808"\w*, señor \w mío|strong="H5971"\w*, \w escúchame|strong="H8085"\w*: \w te|strong="H5869"\w* \w doy|strong="H5414"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w*, y \w te|strong="H5869"\w* \w doy|strong="H5414"\w* también la \w cueva|strong="H4631"\w* \w que|strong="H3808"\w* está \w en|strong="H6912"\w* \w él|strong="H1121"\w*. \w En|strong="H6912"\w* presencia \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* mi \w pueblo|strong="H5971"\w* \w te|strong="H5869"\w* \w lo|strong="H3808"\w* \w doy|strong="H5414"\w*; \w sepulta|strong="H6912"\w* \w a|strong="H3068"\w* tu \w muerta|strong="H4191"\w*».   
\p
\v 12 \w Y|strong="H3068"\w* Abraham \w se|strong="H5971"\w* inclinó \w delante|strong="H6440"\w* del \w pueblo|strong="H5971"\w* \w de|strong="H6440"\w* aquella tierra.  
\v 13 \w Y|strong="H3068"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* Efrón \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* la tierra, \w diciendo|strong="H1696"\w*: «\w Te|strong="H4480"\w* ruego \w que|strong="H4480"\w* \w me|strong="H4480"\w* escuches. \w Daré|strong="H5414"\w* el \w precio|strong="H3701"\w* \w del|strong="H4480"\w* \w campo|strong="H7704"\w*; \w tómalo|strong="H3947"\w* \w de|strong="H4480"\w* mí, y sepultaré \w allí|strong="H8033"\w* \w a|strong="H3068"\w* mi \w muerta|strong="H4191"\w*».   
\p
\v 14 \w Respondió|strong="H6030"\w* Efrón \w a|strong="H3068"\w* Abraham, diciéndole:  
\v 15 «Señor mío, \w escúchame|strong="H8085"\w*: un pedazo de tierra \w que|strong="H4100"\w* vale cuatrocientos \w siclos|strong="H8255"\w* de \w plata|strong="H3701"\w*\f + \fr 23:15 \ft Un siclo equivale a unos 10 gramos, por lo que 400 siclos serían unos 4 kg u 8,8 libras.\f* entre tú y yo, ¿\w qué|strong="H4100"\w* \w es|strong="H1931"\w*? \w Sepulta|strong="H6912"\w*, \w pues|strong="H1931"\w*, \w a|strong="H3068"\w* tu \w muerta|strong="H4191"\w*».   
\p
\v 16 Entonces Abraham \w escuchó|strong="H8085"\w* \w a|strong="H3068"\w* Efrón, y pesó Abraham \w a|strong="H3068"\w* Efrón la \w plata|strong="H3701"\w* \w que|strong="H1121"\w* había nombrado \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het: cuatrocientos \w siclos|strong="H8255"\w* \w de|strong="H1121"\w* \w plata|strong="H3701"\w*, \w de|strong="H1121"\w* buena ley entre \w los|strong="H1121"\w* \w mercaderes|strong="H5503"\w* corrientes.   
\p
\v 17 Así \w que|strong="H3605"\w* \w el|strong="H3605"\w* \w campo|strong="H7704"\w* \w de|strong="H6440"\w* Efrón \w que|strong="H3605"\w* estaba en Macpela, \w el|strong="H3605"\w* cual estaba \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Mamre|strong="H4471"\w*, \w el|strong="H3605"\w* \w campo|strong="H7704"\w* y \w la|strong="H3605"\w* \w cueva|strong="H4631"\w* \w que|strong="H3605"\w* había en \w él|strong="H3605"\w*, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* \w que|strong="H3605"\w* había en \w el|strong="H3605"\w* \w campo|strong="H7704"\w*, \w que|strong="H3605"\w* estaban en \w todos|strong="H3605"\w* sus límites, fueron escriturados  
\v 18 \w a|strong="H3068"\w* Abraham como posesión en presencia \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het, ante \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* entraban por \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w*.  
\v 19 \w Después|strong="H5921"\w* \w de|strong="H5921"\w* \w esto|strong="H3651"\w*, Abraham \w sepultó|strong="H6912"\w* \w a|strong="H3068"\w* \w Sara|strong="H8283"\w* \w su|strong="H1931"\w* mujer \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w cueva|strong="H4631"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w de|strong="H5921"\w* Macpela, frente \w a|strong="H3068"\w* \w Mamre|strong="H4471"\w* (\w es|strong="H1931"\w* decir, \w Hebrón|strong="H2275"\w*), \w en|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w*.  
\v 20 \w Y|strong="H3068"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w* y la \w cueva|strong="H4631"\w* \w que|strong="H1121"\w* en \w él|strong="H1121"\w* había, pasaron \w a|strong="H3068"\w* ser \w de|strong="H1121"\w* Abraham como posesión para \w sepultura|strong="H6913"\w*, cedidos por \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het.   
\c 24
\p
\v 1 Era Abraham ya \w viejo|strong="H2204"\w*, y bien avanzado en \w años|strong="H3117"\w*; y Yahvé había bendecido \w a|strong="H3068"\w* Abraham en \w todo|strong="H3605"\w*.  
\v 2 \w Y|strong="H3068"\w* dijo Abraham \w a|strong="H3068"\w* un \w criado|strong="H5650"\w* suyo, \w el|strong="H3605"\w* más \w viejo|strong="H2205"\w* \w de|strong="H8478"\w* su \w casa|strong="H1004"\w*, \w que|strong="H4994"\w* era \w el|strong="H3605"\w* \w que|strong="H4994"\w* gobernaba \w en|strong="H8478"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H4994"\w* tenía: «\w Pon|strong="H7760"\w* \w ahora|strong="H4994"\w* tu \w mano|strong="H3027"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w mi|strong="H4994"\w* \w muslo|strong="H3409"\w*,  
\v 3 y te haré jurar por Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w cielos|strong="H8064"\w* y \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* la tierra, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w tomarás|strong="H3947"\w* para mi \w hijo|strong="H1121"\w* mujer \w de|strong="H1121"\w* las \w hijas|strong="H1323"\w* \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w*, \w entre|strong="H7130"\w* \w los|strong="H3427"\w* cuales yo \w habito|strong="H3427"\w*;  
\v 4 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w irás|strong="H3212"\w* \w a|strong="H3068"\w* mi tierra \w y|strong="H3588"\w* \w a|strong="H3068"\w* mi \w parentela|strong="H4138"\w*, \w y|strong="H3588"\w* \w tomarás|strong="H3947"\w* mujer \w para|strong="H3588"\w* mi \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w*».   
\p
\v 5 \w El|strong="H1121"\w* \w criado|strong="H5650"\w* le \w respondió|strong="H7725"\w*: «Quizá \w la|strong="H2063"\w* mujer \w no|strong="H3808"\w* \w querrá|strong="H3212"\w* \w venir|strong="H3212"\w* conmigo \w a|strong="H3068"\w* \w esta|strong="H2063"\w* tierra. ¿\w Volveré|strong="H7725"\w*, pues, tu \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w la|strong="H2063"\w* tierra \w de|strong="H1121"\w* \w donde|strong="H8033"\w* \w saliste|strong="H3318"\w*?»   
\p
\v 6 \w Y|strong="H3068"\w* Abraham le dijo: “\w Guárdate|strong="H8104"\w* \w de|strong="H1121"\w* \w que|strong="H6435"\w* \w no|strong="H6435"\w* \w vuelvas|strong="H7725"\w* \w a|strong="H3068"\w* llevar \w allá|strong="H8033"\w* \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w*.  
\v 7 Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w cielos|strong="H8064"\w*, \w que|strong="H1931"\w* me \w tomó|strong="H3947"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H6440"\w* mi padre y \w de|strong="H6440"\w* \w la|strong="H1931"\w* tierra \w de|strong="H6440"\w* mi \w parentela|strong="H4138"\w*, y me \w habló|strong="H1696"\w* y me \w juró|strong="H7650"\w*, \w diciendo|strong="H1696"\w*: ‘\w A|strong="H3068"\w* tu \w descendencia|strong="H2233"\w* \w daré|strong="H5414"\w* \w esta|strong="H2063"\w* tierra’; \w él|strong="H1931"\w* \w enviará|strong="H7971"\w* \w su|strong="H1931"\w* \w ángel|strong="H4397"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, y tú traerás \w de|strong="H6440"\w* \w allá|strong="H8033"\w* mujer \w para|strong="H5414"\w* mi \w hijo|strong="H1121"\w*.  
\v 8 \w Y|strong="H3068"\w* \w si|strong="H3808"\w* \w la|strong="H2063"\w* mujer \w no|strong="H3808"\w* quisiere \w venir|strong="H3212"\w* \w contigo|strong="H8033"\w*, quedarás \w libre|strong="H5352"\w* \w de|strong="H1121"\w* \w este|strong="H2063"\w* mi \w juramento|strong="H7621"\w*; \w solamente|strong="H7535"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* lleves \w allá|strong="H8033"\w* \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w*”.   
\p
\v 9 Entonces \w el|strong="H5921"\w* \w criado|strong="H5650"\w* \w puso|strong="H7760"\w* su \w mano|strong="H3027"\w* \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* \w muslo|strong="H3409"\w* \w de|strong="H5921"\w* Abraham su señor, \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w juró|strong="H7650"\w* \w sobre|strong="H5921"\w* \w este|strong="H2088"\w* \w negocio|strong="H1697"\w*.  
\v 10 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w criado|strong="H5650"\w* \w tomó|strong="H3947"\w* \w diez|strong="H6235"\w* \w camellos|strong="H1581"\w* de \w los|strong="H3605"\w* \w camellos|strong="H1581"\w* de su señor, y se \w fue|strong="H3212"\w*, \w tomando|strong="H3947"\w* \w toda|strong="H3605"\w* clase de regalos escogidos de su señor; y puesto \w en|strong="H3212"\w* camino, \w llegó|strong="H3212"\w* \w a|strong="H3068"\w* Mesopotamia, \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* de Nacor.  
\v 11 \w E|strong="H3068"\w* hizo arrodillar los \w camellos|strong="H1581"\w* \w fuera|strong="H2351"\w* \w de|strong="H4325"\w* la \w ciudad|strong="H5892"\w*, junto \w a|strong="H3068"\w* un pozo \w de|strong="H4325"\w* \w agua|strong="H4325"\w*, \w a|strong="H3068"\w* la \w hora|strong="H6256"\w* \w de|strong="H4325"\w* la \w tarde|strong="H6153"\w*, la \w hora|strong="H6256"\w* \w en|strong="H3318"\w* \w que|strong="H4325"\w* \w salen|strong="H3318"\w* las doncellas \w por|strong="H7579"\w* \w agua|strong="H4325"\w*.  
\v 12 \w Y|strong="H3068"\w* dijo: “Oh Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w mi|strong="H4994"\w* \w señor|strong="H3068"\w* Abraham, \w dame|strong="H6440"\w*, \w te|strong="H5973"\w* \w ruego|strong="H4994"\w*, \w el|strong="H5973"\w* tener \w hoy|strong="H3117"\w* buen encuentro, y \w haz|strong="H6213"\w* \w misericordia|strong="H2617"\w* \w con|strong="H5973"\w* \w mi|strong="H4994"\w* \w señor|strong="H3068"\w* Abraham.  
\v 13 He \w aquí|strong="H2009"\w* \w yo|strong="H2009"\w* \w estoy|strong="H5324"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w fuente|strong="H5869"\w* \w de|strong="H5921"\w* \w agua|strong="H4325"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w hijas|strong="H1323"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* varones \w de|strong="H5921"\w* \w esta|strong="H5324"\w* \w ciudad|strong="H5892"\w* \w salen|strong="H3318"\w* \w por|strong="H5921"\w* \w agua|strong="H4325"\w*.  
\v 14 \w Sea|strong="H1961"\w*, \w pues|strong="H3588"\w*, \w que|strong="H3588"\w* \w la|strong="H1571"\w* doncella \w a|strong="H3068"\w* \w quien|strong="H6213"\w* \w yo|strong="H3588"\w* dijere: ‘\w Baja|strong="H5186"\w* \w tu|strong="H6213"\w* \w cántaro|strong="H3537"\w*, \w te|strong="H3588"\w* rogo, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* beba’, \w y|strong="H1571"\w* ella respondiere: ‘\w Bebe|strong="H8354"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* daré \w de|strong="H3588"\w* \w beber|strong="H8354"\w* \w a|strong="H3068"\w* tus \w camellos|strong="H1581"\w*’; \w que|strong="H3588"\w* \w sea|strong="H1961"\w* \w ésta|strong="H1961"\w* \w la|strong="H1571"\w* \w que|strong="H3588"\w* \w tú|strong="H6213"\w* has destinado \w para|strong="H3588"\w* \w tu|strong="H6213"\w* \w siervo|strong="H5650"\w* \w Isaac|strong="H3327"\w*; \w y|strong="H1571"\w* \w en|strong="H5973"\w* \w esto|strong="H6213"\w* \w conoceré|strong="H3045"\w* \w que|strong="H3588"\w* habrás \w hecho|strong="H6213"\w* \w misericordia|strong="H2617"\w* \w con|strong="H5973"\w* \w mi|strong="H1961"\w* señor”.   
\p
\v 15 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1931"\w* \w antes|strong="H2962"\w* \w que|strong="H1931"\w* \w él|strong="H1931"\w* \w acabase|strong="H3615"\w* \w de|strong="H5921"\w* \w hablar|strong="H1696"\w*, he \w aquí|strong="H2009"\w* \w Rebeca|strong="H7259"\w*, \w que|strong="H1931"\w* \w había|strong="H1961"\w* \w nacido|strong="H3205"\w* \w a|strong="H3068"\w* Betuel, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Milca|strong="H4435"\w* mujer \w de|strong="H5921"\w* Nacor hermano \w de|strong="H5921"\w* Abraham, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w salía|strong="H3318"\w* \w con|strong="H5921"\w* \w su|strong="H1931"\w* \w cántaro|strong="H3537"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* \w hombro|strong="H7926"\w*.  
\v 16 \w Y|strong="H3068"\w* la doncella era \w de|strong="H5869"\w* \w aspecto|strong="H4758"\w* \w muy|strong="H3966"\w* \w hermoso|strong="H2896"\w*, \w virgen|strong="H1330"\w*, \w a|strong="H3068"\w* la \w que|strong="H3808"\w* varón \w no|strong="H3808"\w* había \w conocido|strong="H3045"\w*; la cual \w descendió|strong="H3381"\w* \w a|strong="H3068"\w* la \w fuente|strong="H5869"\w*, y \w llenó|strong="H4390"\w* su \w cántaro|strong="H3537"\w*, y \w se|strong="H3045"\w* volvía.  
\v 17 Entonces el \w criado|strong="H5650"\w* \w corrió|strong="H7323"\w* \w hacia|strong="H7125"\w* ella, y dijo: «Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me des \w a|strong="H3068"\w* beber un \w poco|strong="H4592"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w* \w de|strong="H4325"\w* tu \w cántaro|strong="H3537"\w*».   
\p
\v 18 \w Ella|strong="H5921"\w* respondió: «\w Bebe|strong="H8354"\w*, señor \w mío|strong="H5921"\w*». \w Y|strong="H3068"\w* \w se|strong="H5921"\w* dio prisa \w a|strong="H3068"\w* bajar su \w cántaro|strong="H3537"\w* \w sobre|strong="H5921"\w* su \w mano|strong="H3027"\w*, \w y|strong="H5921"\w* \w le|strong="H5921"\w* dio \w a|strong="H3068"\w* \w beber|strong="H8354"\w*.  
\v 19 \w Y|strong="H3068"\w* \w cuando|strong="H5704"\w* \w acabó|strong="H3615"\w* \w de|strong="H5704"\w* darle \w a|strong="H3068"\w* \w beber|strong="H8354"\w*, dijo: «\w También|strong="H1571"\w* \w para|strong="H5704"\w* tus \w camellos|strong="H1581"\w* \w sacaré|strong="H7579"\w* agua, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w acaben|strong="H3615"\w* \w de|strong="H5704"\w* \w beber|strong="H8354"\w*».  
\v 20 \w Y|strong="H3068"\w* se dio prisa, y vació su \w cántaro|strong="H3537"\w* \w en|strong="H5750"\w* \w la|strong="H3605"\w* pila, y \w corrió|strong="H7323"\w* \w otra|strong="H5750"\w* vez al pozo para sacar agua, y sacó para \w todos|strong="H3605"\w* sus \w camellos|strong="H1581"\w*.   
\p
\v 21 \w Y|strong="H3068"\w* el hombre estaba maravillado de ella, \w callando|strong="H2790"\w*, para \w saber|strong="H3045"\w* \w si|strong="H3808"\w* Yahvé había \w prosperado|strong="H6743"\w* su \w viaje|strong="H1870"\w*, \w o|strong="H3068"\w* \w no|strong="H3808"\w*.  
\v 22 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* \w los|strong="H5921"\w* \w camellos|strong="H1581"\w* \w acabaron|strong="H3615"\w* \w de|strong="H5921"\w* \w beber|strong="H8354"\w*, \w le|strong="H5921"\w* dio \w el|strong="H5921"\w* hombre un pendiente \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w que|strong="H5921"\w* pesaba \w medio|strong="H3027"\w* siclo,\f + \fr 24:22 \ft Un siclo equivale a unos 10 gramos o a unas 0,35 onzas.\f* \w y|strong="H5921"\w* \w dos|strong="H8147"\w* \w brazaletes|strong="H6781"\w* \w que|strong="H5921"\w* pesaban \w diez|strong="H6235"\w* \w siclos|strong="H4948"\w*,  
\v 23 y \w dijo|strong="H5046"\w*: «¿De \w quién|strong="H4310"\w* eres \w hija|strong="H1323"\w*? Te \w ruego|strong="H4994"\w* \w que|strong="H4310"\w* \w me|strong="H4310"\w* digas: ¿\w hay|strong="H3426"\w* en \w casa|strong="H1004"\w* de \w tu|strong="H3426"\w* padre \w lugar|strong="H4725"\w* \w donde|strong="H4725"\w* posemos?»   
\p
\v 24 \w Y|strong="H3068"\w* ella respondió: «Soy \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Betuel \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Milca|strong="H4435"\w*, \w el|strong="H1121"\w* cual dio \w a|strong="H3068"\w* luz ella \w a|strong="H3068"\w* Nacor».  
\v 25 \w Y|strong="H3068"\w* añadió: «\w También|strong="H1571"\w* hay \w en|strong="H5973"\w* nuestra casa \w paja|strong="H8401"\w* \w y|strong="H1571"\w* \w mucho|strong="H7227"\w* \w forraje|strong="H4554"\w*, \w y|strong="H1571"\w* \w lugar|strong="H4725"\w* \w para|strong="H5973"\w* posar».   
\p
\v 26 El hombre entonces se \w inclinó|strong="H6915"\w*, y \w adoró|strong="H7812"\w* \w a|strong="H3068"\w* Yahvé,  
\v 27 y dijo: «\w Bendito|strong="H1288"\w* sea Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5973"\w* mi amo Abraham, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w apartó|strong="H5800"\w* \w de|strong="H5973"\w* mi amo su \w misericordia|strong="H2617"\w* y su verdad, \w guiándome|strong="H5148"\w* Yahvé \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w camino|strong="H1870"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w los|strong="H5973"\w* hermanos \w de|strong="H5973"\w* mi amo».   
\p
\v 28 \w Y|strong="H3068"\w* la doncella \w corrió|strong="H7323"\w*, y \w e|strong="H3068"\w* hizo \w saber|strong="H5046"\w* en \w casa|strong="H1004"\w* \w de|strong="H1697"\w* su madre estas \w cosas|strong="H1697"\w*.  
\v 29 \w Y|strong="H3068"\w* \w Rebeca|strong="H7259"\w* tenía un hermano que se \w llamaba|strong="H8034"\w* \w Labán|strong="H3837"\w*, el cual \w corrió|strong="H7323"\w* \w afuera|strong="H2351"\w* hacia el hombre, \w a|strong="H3068"\w* la \w fuente|strong="H5869"\w*.  
\v 30 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H5921"\w* \w como|strong="H1961"\w* \w vio|strong="H7200"\w* \w el|strong="H5921"\w* pendiente \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w brazaletes|strong="H6781"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* su hermana, \w que|strong="H5921"\w* decía: «\w Así|strong="H3541"\w* \w me|strong="H5921"\w* \w habló|strong="H1696"\w* aquel hombre», \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*; \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w camellos|strong="H1581"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w fuente|strong="H5869"\w*.  
\v 31 \w Y|strong="H3068"\w* le dijo: «Entra, \w bendito|strong="H1288"\w* de Yahvé; ¿\w por|strong="H4100"\w* \w qué|strong="H4100"\w* \w estás|strong="H5975"\w* \w fuera|strong="H2351"\w*? Yo he limpiado la \w casa|strong="H1004"\w*, y el \w lugar|strong="H4725"\w* para los \w camellos|strong="H1581"\w*».   
\p
\v 32 Entonces el hombre vino \w a|strong="H3068"\w* \w casa|strong="H1004"\w*, y Labán \w desató|strong="H6605"\w* los \w camellos|strong="H1581"\w*; y les \w dio|strong="H5414"\w* \w paja|strong="H8401"\w* y \w forraje|strong="H4554"\w*, y \w agua|strong="H4325"\w* \w para|strong="H5414"\w* lavar los \w pies|strong="H7272"\w* \w de|strong="H5414"\w* él, y los \w pies|strong="H7272"\w* \w de|strong="H5414"\w* los hombres \w que|strong="H4325"\w* con él venían.  
\v 33 \w Y|strong="H3068"\w* le pusieron \w delante|strong="H6440"\w* \w qué|strong="H3808"\w* comer; \w mas|strong="H5704"\w* él \w dijo|strong="H1696"\w*: «\w No|strong="H3808"\w* comeré \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* haya \w dicho|strong="H1697"\w* mi mensaje».  
\p \w Y|strong="H3068"\w* él le \w dijo|strong="H1696"\w*: «\w Habla|strong="H1696"\w*».   
\p
\v 34 Entonces dijo: “Yo soy \w criado|strong="H5650"\w* de Abraham.  
\v 35 \w Y|strong="H3068"\w* Yahvé ha bendecido \w mucho|strong="H3966"\w* \w a|strong="H3068"\w* \w mi|strong="H1431"\w* amo, \w y|strong="H1241"\w* él se ha \w engrandecido|strong="H1431"\w*; \w y|strong="H1241"\w* le ha \w dado|strong="H5414"\w* \w ovejas|strong="H6629"\w* \w y|strong="H1241"\w* \w vacas|strong="H1241"\w*, \w plata|strong="H3701"\w* \w y|strong="H1241"\w* \w oro|strong="H2091"\w*, \w siervos|strong="H5650"\w* \w y|strong="H1241"\w* \w siervas|strong="H8198"\w*, \w camellos|strong="H1581"\w* \w y|strong="H1241"\w* \w asnos|strong="H2543"\w*.  
\v 36 \w Y|strong="H3068"\w* \w Sara|strong="H8283"\w*, mujer \w de|strong="H1121"\w* mi amo, \w dio|strong="H5414"\w* \w a|strong="H3068"\w* luz en su vejez un \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* mi señor, \w quien|strong="H3605"\w* le ha \w dado|strong="H5414"\w* \w a|strong="H3068"\w* \w él|strong="H3605"\w* \w todo|strong="H3605"\w* cuanto tiene.  
\v 37 \w Y|strong="H3068"\w* mi amo me hizo jurar, diciendo: ‘\w No|strong="H3808"\w* \w tomarás|strong="H3947"\w* para mi \w hijo|strong="H1121"\w* mujer \w de|strong="H1121"\w* las \w hijas|strong="H1323"\w* \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w*, en cuya tierra \w habito|strong="H3427"\w*;  
\v 38 \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w irás|strong="H3212"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* mi padre y \w a|strong="H3068"\w* mi parentela, y \w tomarás|strong="H3947"\w* mujer para mi \w hijo|strong="H1121"\w*’.  
\v 39 \w Y|strong="H3068"\w* yo dije \w a|strong="H3068"\w* mi amo: ‘Quizá la mujer \w no|strong="H3808"\w* \w querrá|strong="H3212"\w* seguirme’.  
\v 40 Entonces \w él|strong="H1121"\w* me respondió: ‘Yahvé, en cuya \w presencia|strong="H6440"\w* he \w andado|strong="H1980"\w*, \w enviará|strong="H7971"\w* su \w ángel|strong="H4397"\w* \w contigo|strong="H6440"\w*, y \w prosperará|strong="H6743"\w* tu \w camino|strong="H1870"\w*; y \w tomarás|strong="H3947"\w* para mi \w hijo|strong="H1121"\w* mujer \w de|strong="H6440"\w* mi \w familia|strong="H1004"\w* y \w de|strong="H6440"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* mi padre.  
\v 41 \w Entonces|strong="H3588"\w* \w serás|strong="H1961"\w* \w libre|strong="H5355"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* juramento, \w cuando|strong="H3588"\w* hayas llegado \w a|strong="H3068"\w* \w mi|strong="H1961"\w* \w familia|strong="H4940"\w*; \w y|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w la|strong="H3588"\w* dieren, \w serás|strong="H1961"\w* \w libre|strong="H5355"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* juramento’.  
\v 42 Llegué, \w pues|strong="H4994"\w*, \w hoy|strong="H3117"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w fuente|strong="H5869"\w*, \w y|strong="H5921"\w* dije: ‘Oh Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w señor|strong="H3068"\w* Abraham, \w si|strong="H4994"\w* \w tú|strong="H3426"\w* \w prosperas|strong="H6743"\w* \w ahora|strong="H4994"\w* \w mi|strong="H5921"\w* \w camino|strong="H1870"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* cual \w ando|strong="H1980"\w*,  
\v 43 he \w aquí|strong="H2009"\w* \w yo|strong="H2009"\w* \w estoy|strong="H1961"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w fuente|strong="H5869"\w* \w de|strong="H5921"\w* \w agua|strong="H4325"\w*; \w sea|strong="H1961"\w*, \w pues|strong="H4994"\w*, \w que|strong="H4994"\w* \w la|strong="H5921"\w* doncella \w que|strong="H4994"\w* \w saliere|strong="H3318"\w* \w por|strong="H5921"\w* \w agua|strong="H4325"\w*, \w a|strong="H3068"\w* \w la|strong="H5921"\w* cual dijere: «Dame \w de|strong="H5921"\w* \w beber|strong="H8248"\w*, \w te|strong="H5869"\w* \w ruego|strong="H4994"\w*, un \w poco|strong="H4592"\w* \w de|strong="H5921"\w* \w agua|strong="H4325"\w* \w de|strong="H5921"\w* tu \w cántaro|strong="H3537"\w*»,  
\v 44 \w y|strong="H1571"\w* \w ella|strong="H1931"\w* me respondiere: «\w Bebe|strong="H8354"\w* tú, \w y|strong="H1571"\w* \w también|strong="H1571"\w* para tus \w camellos|strong="H1581"\w* \w sacaré|strong="H7579"\w* agua»; sea \w ésta|strong="H1931"\w* \w la|strong="H1931"\w* mujer \w que|strong="H1931"\w* \w destinó|strong="H3198"\w* Yahvé para \w el|strong="H1931"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* mi \w señor|strong="H3068"\w*’.  
\v 45 \w Y|strong="H3068"\w* \w antes|strong="H2962"\w* \w que|strong="H4994"\w* \w acabase|strong="H3615"\w* \w de|strong="H5921"\w* \w hablar|strong="H1696"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w*, he \w aquí|strong="H2009"\w* \w Rebeca|strong="H7259"\w*, \w que|strong="H4994"\w* \w salía|strong="H3318"\w* \w con|strong="H5921"\w* su \w cántaro|strong="H3537"\w* \w sobre|strong="H5921"\w* su \w hombro|strong="H7926"\w*; \w y|strong="H5921"\w* \w descendió|strong="H3381"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w fuente|strong="H5869"\w*, \w y|strong="H5921"\w* \w sacó|strong="H3318"\w* agua; \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w dije|strong="H1696"\w*: ‘\w Te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w me|strong="H5921"\w* des \w de|strong="H5921"\w* \w beber|strong="H8248"\w*’.  
\v 46 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* dio prisa, \w y|strong="H1571"\w* bajó su \w cántaro|strong="H3537"\w* \w de|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w sí|strong="H1571"\w*, \w y|strong="H1571"\w* dijo: ‘\w Bebe|strong="H8354"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* tus \w camellos|strong="H1581"\w* daré \w de|strong="H5921"\w* \w beber|strong="H8354"\w*’. \w Y|strong="H3068"\w* \w bebí|strong="H8354"\w*, \w y|strong="H1571"\w* dio \w también|strong="H1571"\w* \w de|strong="H5921"\w* \w beber|strong="H8354"\w* \w a|strong="H3068"\w* mis \w camellos|strong="H1581"\w*.  
\v 47 Entonces \w le|strong="H5921"\w* \w pregunté|strong="H7592"\w*, \w y|strong="H5921"\w* dije: ‘¿\w De|strong="H5921"\w* \w quién|strong="H4310"\w* eres \w hija|strong="H1323"\w*?’ \w Y|strong="H3068"\w* \w ella|strong="H5921"\w* respondió: ‘\w Hija|strong="H1323"\w* \w de|strong="H5921"\w* Betuel \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nacor, \w que|strong="H4310"\w* \w le|strong="H5921"\w* \w dio|strong="H7760"\w* \w a|strong="H3068"\w* luz \w Milca|strong="H4435"\w*’. Entonces \w le|strong="H5921"\w* \w puse|strong="H7760"\w* un \w zarcillo|strong="H5141"\w* \w en|strong="H5921"\w* su nariz, \w y|strong="H5921"\w* \w brazaletes|strong="H6781"\w* \w en|strong="H5921"\w* sus brazos;  
\v 48 y me incliné y adoré \w a|strong="H3068"\w* Yahvé, y \w bendije|strong="H1288"\w* \w a|strong="H3068"\w* Yahvé \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* mi \w señor|strong="H3068"\w* Abraham, \w que|strong="H1121"\w* me había guiado \w por|strong="H1870"\w* \w camino|strong="H1870"\w* \w de|strong="H1121"\w* verdad para \w tomar|strong="H3947"\w* la \w hija|strong="H1323"\w* del hermano \w de|strong="H1121"\w* mi \w señor|strong="H3068"\w* para su \w hijo|strong="H1121"\w*.  
\v 49 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w si|strong="H3808"\w* \w vosotros|strong="H3426"\w* \w hacéis|strong="H6213"\w* \w misericordia|strong="H2617"\w* \w y|strong="H5921"\w* verdad \w con|strong="H5921"\w* \w mi|strong="H5921"\w* señor, \w declarádmelo|strong="H5046"\w*; \w y|strong="H5921"\w* \w si|strong="H3808"\w* \w no|strong="H3808"\w*, \w declarádmelo|strong="H5046"\w* también, \w para|strong="H5921"\w* \w que|strong="H3808"\w* vaya \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w diestra|strong="H3225"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w siniestra|strong="H8040"\w*”.   
\p
\v 50 Entonces \w Labán|strong="H3837"\w* y Betuel \w respondieron|strong="H6030"\w* y \w dijeron|strong="H1697"\w*: «\w De|strong="H1697"\w* Yahvé \w ha|strong="H3808"\w* \w salido|strong="H3318"\w* \w esto|strong="H1697"\w*; \w no|strong="H3808"\w* \w podemos|strong="H3201"\w* \w hablarte|strong="H1696"\w* \w malo|strong="H7451"\w* \w ni|strong="H3808"\w* \w bueno|strong="H2896"\w*.  
\v 51 He \w aquí|strong="H2009"\w* \w Rebeca|strong="H7259"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti; \w tómala|strong="H3947"\w* y \w vete|strong="H3212"\w*, y \w sea|strong="H1961"\w* mujer del \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* tu \w señor|strong="H3068"\w*, \w como|strong="H1961"\w* lo ha \w dicho|strong="H1696"\w* Yahvé».   
\p
\v 52 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* el \w criado|strong="H5650"\w* \w de|strong="H1697"\w* Abraham \w oyó|strong="H8085"\w* sus \w palabras|strong="H1697"\w*, \w se|strong="H1961"\w* postró en tierra ante Yahvé.  
\v 53 \w Y|strong="H3068"\w* \w sacó|strong="H3318"\w* el \w criado|strong="H5650"\w* \w alhajas|strong="H3627"\w* \w de|strong="H5414"\w* \w plata|strong="H3701"\w* y \w alhajas|strong="H3627"\w* \w de|strong="H5414"\w* \w oro|strong="H2091"\w*, y vestidos, y \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w*; \w también|strong="H3318"\w* \w dio|strong="H5414"\w* cosas preciosas \w a|strong="H3068"\w* su hermano y \w a|strong="H3068"\w* su madre.  
\v 54 \w Y|strong="H3068"\w* comieron y \w bebieron|strong="H8354"\w* \w él|strong="H1931"\w* y \w los|strong="H5973"\w* varones \w que|strong="H1931"\w* venían \w con|strong="H5973"\w* \w él|strong="H1931"\w*, y durmieron; y \w levantándose|strong="H6965"\w* \w de|strong="H5973"\w* \w mañana|strong="H1242"\w*, dijo: «\w Enviadme|strong="H7971"\w* \w a|strong="H3068"\w* mi señor».   
\p
\v 55 \w Entonces|strong="H3117"\w* respondieron su hermano y su madre: «\w Espere|strong="H3427"\w* la doncella con nosotros \w a|strong="H3068"\w* lo menos diez \w días|strong="H3117"\w*, y \w después|strong="H3427"\w* se \w irá|strong="H3212"\w*».   
\p
\v 56 \w Y|strong="H3068"\w* él les dijo: «\w No|strong="H1870"\w* me detengáis, ya que Yahvé ha \w prosperado|strong="H6743"\w* mi \w camino|strong="H1870"\w*; \w despachadme|strong="H7971"\w* para que me \w vaya|strong="H3212"\w* \w a|strong="H3068"\w* mi \w señor|strong="H3068"\w*».   
\p
\v 57 Ellos respondieron entonces: «\w Llamemos|strong="H7121"\w* \w a|strong="H3068"\w* la doncella y preguntémosle».  
\v 58 \w Y|strong="H3068"\w* \w llamaron|strong="H7121"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w*, y \w le|strong="H5973"\w* dijeron: «¿\w Irás|strong="H3212"\w* tú \w con|strong="H5973"\w* \w este|strong="H2088"\w* varón?»  
\p \w Y|strong="H3068"\w* ella respondió: «Sí, \w iré|strong="H3212"\w*».   
\p
\v 59 Entonces dejaron \w ir|strong="H7971"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* su hermana, y \w a|strong="H3068"\w* su nodriza, y al \w criado|strong="H5650"\w* de Abraham y \w a|strong="H3068"\w* sus hombres.  
\v 60 \w Y|strong="H3068"\w* \w bendijeron|strong="H1288"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w*, y le dijeron: «Hermana nuestra, \w sé|strong="H1961"\w* madre de millares de millares, y \w posean|strong="H3423"\w* tus descendientes la \w puerta|strong="H8179"\w* de sus \w enemigos|strong="H8130"\w*».   
\p
\v 61 Entonces \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w Rebeca|strong="H7259"\w* \w y|strong="H5921"\w* sus \w doncellas|strong="H5291"\w*, \w y|strong="H5921"\w* montaron \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w camellos|strong="H1581"\w*, \w y|strong="H5921"\w* siguieron \w al|strong="H5921"\w* hombre; \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w criado|strong="H5650"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w fue|strong="H3212"\w*.  
\v 62 \w Y|strong="H3068"\w* venía \w Isaac|strong="H3327"\w* del pozo del Viviente-que-me-ve; porque \w él|strong="H1931"\w* \w habitaba|strong="H3427"\w* en \w el|strong="H1931"\w* Négueb.  
\v 63 \w Y|strong="H3068"\w* había \w salido|strong="H3318"\w* \w Isaac|strong="H3327"\w* \w a|strong="H3068"\w* meditar al \w campo|strong="H7704"\w*, \w a|strong="H3068"\w* la hora \w de|strong="H5869"\w* la \w tarde|strong="H6153"\w*; y \w alzando|strong="H5375"\w* sus \w ojos|strong="H5869"\w* \w miró|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* los \w camellos|strong="H1581"\w* que venían.  
\v 64 \w Rebeca|strong="H7259"\w* también \w alzó|strong="H5375"\w* sus \w ojos|strong="H5869"\w*, \w y|strong="H5921"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*, \w y|strong="H5921"\w* descendió \w del|strong="H5921"\w* \w camello|strong="H1581"\w*;  
\v 65 porque había preguntado al \w criado|strong="H5650"\w*: «¿\w Quién|strong="H4310"\w* \w es|strong="H1931"\w* \w este|strong="H1931"\w* varón \w que|strong="H4310"\w* \w viene|strong="H1980"\w* por \w el|strong="H1931"\w* \w campo|strong="H7704"\w* \w hacia|strong="H7125"\w* \w nosotros|strong="H1931"\w*?»  
\p \w Y|strong="H3068"\w* \w el|strong="H1931"\w* \w criado|strong="H5650"\w* había respondido: «\w Este|strong="H1931"\w* \w es|strong="H1931"\w* mi señor».  
\p \w Ella|strong="H1931"\w* entonces \w tomó|strong="H3947"\w* \w el|strong="H1931"\w* velo, y \w se|strong="H1931"\w* \w cubrió|strong="H3680"\w*.  
\v 66 Entonces \w el|strong="H3605"\w* \w criado|strong="H5650"\w* \w contó|strong="H5608"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w*.  
\v 67 \w Y|strong="H3068"\w* la trajo \w Isaac|strong="H3327"\w* \w a|strong="H3068"\w* la tienda de su madre \w Sara|strong="H8283"\w*, y \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w* por mujer, y la amó; y \w se|strong="H1961"\w* consoló \w Isaac|strong="H3327"\w* \w después|strong="H1961"\w* de la muerte de su madre.   
\c 25
\p
\v 1 Abraham \w tomó|strong="H3947"\w* otra mujer, que se \w llamaba|strong="H8034"\w* Cetura.  
\v 2 Ella le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Zimrán, \w a|strong="H3068"\w* \w Jocsán|strong="H3370"\w*, \w a|strong="H3068"\w* \w Medán|strong="H4091"\w*, \w a|strong="H3068"\w* \w Madián|strong="H4080"\w*, \w a|strong="H3068"\w* \w Isbac|strong="H3435"\w* y \w a|strong="H3068"\w* Súa.  
\v 3 \w Jocsán|strong="H3370"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Seba|strong="H7614"\w* y \w a|strong="H3068"\w* \w Dedán|strong="H1719"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Dedán|strong="H1719"\w* \w fueron|strong="H1961"\w* Asurim, Letusim y Leumim.  
\v 4 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Madián|strong="H4080"\w* fueron Efá, Efer, Hanoc, Abida y Eldá. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cetura.  
\v 5 Abraham \w dio|strong="H5414"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tenía \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*,  
\v 6 pero \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* sus \w concubinas|strong="H6370"\w* \w les|strong="H5921"\w* \w dio|strong="H5414"\w* Abraham regalos; \w y|strong="H5921"\w* \w mientras|strong="H5750"\w* \w él|strong="H5921"\w* \w aún|strong="H5750"\w* vivía, \w los|strong="H1121"\w* \w envió|strong="H7971"\w* lejos \w de|strong="H5921"\w* su \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w*, \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* este, \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w oriental|strong="H6924"\w*.  
\v 7 Estos son los \w días|strong="H3117"\w* \w de|strong="H2568"\w* los \w años|strong="H8141"\w* \w de|strong="H2568"\w* la \w vida|strong="H2416"\w* \w de|strong="H2568"\w* Abraham: \w ciento|strong="H3967"\w* \w setenta|strong="H7657"\w* y \w cinco|strong="H2568"\w* \w años|strong="H8141"\w*.  
\v 8 \w Y|strong="H3068"\w* exhaló el espíritu, y \w murió|strong="H4191"\w* Abraham en \w buena|strong="H2896"\w* \w vejez|strong="H7872"\w*, \w anciano|strong="H2205"\w* y \w lleno|strong="H7649"\w* \w de|strong="H5971"\w* años, y fue reunido con su \w pueblo|strong="H5971"\w*.  
\v 9 \w Isaac|strong="H3327"\w* \w e|strong="H3068"\w* \w Ismael|strong="H3458"\w*, sus \w hijos|strong="H1121"\w*, \w lo|strong="H5921"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cueva|strong="H4631"\w* \w de|strong="H5921"\w* Macpela, \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w heredad|strong="H7704"\w* \w de|strong="H5921"\w* Efrón, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Zohar heteo, \w que|strong="H5921"\w* \w está|strong="H5921"\w* frente \w a|strong="H3068"\w* \w Mamre|strong="H4471"\w*,  
\v 10 la \w heredad|strong="H7704"\w* \w que|strong="H1121"\w* Abraham \w compró|strong="H7069"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het. \w Allí|strong="H8033"\w* fue \w sepultado|strong="H6912"\w* Abraham, junto con \w Sara|strong="H8283"\w*, su mujer.  
\v 11 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w*, \w después|strong="H3427"\w* \w de|strong="H5973"\w* la \w muerte|strong="H4194"\w* \w de|strong="H5973"\w* Abraham, \w que|strong="H1121"\w* Dios \w bendijo|strong="H1288"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*, su \w hijo|strong="H1121"\w*. \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w habitó|strong="H3427"\w* \w junto|strong="H5973"\w* \w a|strong="H3068"\w* Beer Lahai Roi.   
\p
\v 12 Éstas son las generaciones \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abraham, \w el|strong="H1121"\w* \w que|strong="H1121"\w* \w Agar|strong="H1904"\w* la \w egipcia|strong="H4713"\w*, \w sierva|strong="H8198"\w* \w de|strong="H1121"\w* \w Sara|strong="H8283"\w*, le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Abraham.  
\v 13 \w Y|strong="H3068"\w* estos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w*, por sus \w nombres|strong="H8034"\w*, según \w el|strong="H1121"\w* orden \w de|strong="H1121"\w* su nacimiento: \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w*, Nebaiot; luego \w Cedar|strong="H6938"\w*, Adbeel, \w Mibsam|strong="H4017"\w*,  
\v 14 \w Misma|strong="H4927"\w*, \w Duma|strong="H1746"\w*, Massa,  
\v 15 \w Hadad|strong="H2301"\w*, Tema, \w Jetur|strong="H3195"\w*, Nafis y Cedema.  
\v 16 \w Estos|strong="H1992"\w* son \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w*, y \w estos|strong="H1992"\w* son \w sus|strong="H1992"\w* \w nombres|strong="H8034"\w*, por \w sus|strong="H1992"\w* \w villas|strong="H2691"\w* y por \w sus|strong="H1992"\w* \w campamentos|strong="H2918"\w*: \w doce|strong="H8147"\w* \w príncipes|strong="H5387"\w*, según \w sus|strong="H1992"\w* naciones.  
\v 17 \w Y|strong="H3068"\w* estos son los \w años|strong="H8141"\w* \w de|strong="H5971"\w* la \w vida|strong="H2416"\w* \w de|strong="H5971"\w* \w Ismael|strong="H3458"\w*: \w ciento|strong="H3967"\w* \w treinta|strong="H7970"\w* y \w siete|strong="H7651"\w* \w años|strong="H8141"\w*. Exhaló el espíritu y \w murió|strong="H4191"\w*, y fue reunido con su \w pueblo|strong="H5971"\w*.  
\v 18 \w Y|strong="H3068"\w* habitaron \w desde|strong="H5704"\w* \w Havila|strong="H2341"\w* \w hasta|strong="H5704"\w* \w Shur|strong="H7793"\w*, \w que|strong="H5921"\w* \w está|strong="H7931"\w* frente \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, \w en|strong="H5921"\w* dirección \w a|strong="H3068"\w* Asiria. \w Y|strong="H3068"\w* \w se|strong="H5921"\w* estableció frente \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos.   
\p
\v 19 Éstas son las generaciones \w de|strong="H1121"\w* \w Isaac|strong="H3327"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abraham. Abraham \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*.  
\v 20 \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w tenía|strong="H1961"\w* cuarenta \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* \w tomó|strong="H3947"\w* por mujer \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Betuel \w el|strong="H1121"\w* arameo \w de|strong="H1121"\w* Padán Aram, hermana \w de|strong="H1121"\w* \w Labán|strong="H3837"\w* \w el|strong="H1121"\w* arameo.  
\v 21 \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* rogó \w a|strong="H3068"\w* Yahvé \w por|strong="H3588"\w* \w su|strong="H1931"\w* mujer, \w porque|strong="H3588"\w* \w era|strong="H1931"\w* estéril. \w Y|strong="H3068"\w* Yahvé aceptó \w su|strong="H1931"\w* ruego, \w y|strong="H3588"\w* \w Rebeca|strong="H7259"\w*, \w su|strong="H1931"\w* mujer, \w concibió|strong="H2029"\w*.  
\v 22 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* luchaban \w dentro|strong="H7130"\w* \w de|strong="H1121"\w* ella; y ella dijo: «Si \w esto|strong="H2088"\w* \w es|strong="H2088"\w* \w así|strong="H3651"\w*, ¿para \w qué|strong="H4100"\w* vivo yo?» \w Y|strong="H3068"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* consultar \w a|strong="H3068"\w* Yahvé.  
\v 23 \w Y|strong="H3068"\w* Yahvé le respondió:  
\q1 «\w Dos|strong="H8147"\w* \w naciones|strong="H1471"\w* hay en tu vientre,  
\q2 y \w dos|strong="H8147"\w* \w pueblos|strong="H3816"\w* serán divididos desde tus \w entrañas|strong="H4578"\w*.  
\q1 Un \w pueblo|strong="H7227"\w* será \w más|strong="H7227"\w* fuerte que el otro,  
\q2 y el \w mayor|strong="H7227"\w* \w servirá|strong="H5647"\w* al \w menor|strong="H6810"\w*».   
\p
\v 24 \w Cuando|strong="H3117"\w* se cumplieron sus \w días|strong="H3117"\w* para dar \w a|strong="H3068"\w* luz, he \w aquí|strong="H2009"\w* \w que|strong="H3117"\w* había gemelos en su vientre.  
\v 25 \w Y|strong="H3068"\w* \w salió|strong="H3318"\w* \w el|strong="H3605"\w* \w primero|strong="H7223"\w* rubio, y \w todo|strong="H3605"\w* velludo como una pelliza; y \w llamaron|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Esaú|strong="H6215"\w*.  
\v 26 Después \w salió|strong="H3318"\w* su hermano, con su \w mano|strong="H3027"\w* trabada al talón \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*. \w Y|strong="H3068"\w* \w llamaron|strong="H7121"\w* su \w nombre|strong="H8034"\w* \w Jacob|strong="H3290"\w*. \w Isaac|strong="H3327"\w* tenía \w sesenta|strong="H8346"\w* \w años|strong="H8141"\w* cuando ella \w los|strong="H1121"\w* dio \w a|strong="H3068"\w* luz.   
\p
\v 27 \w Y|strong="H3068"\w* crecieron \w los|strong="H3427"\w* \w niños|strong="H5288"\w*. \w Esaú|strong="H6215"\w* \w fue|strong="H1961"\w* \w diestro|strong="H3045"\w* en la \w caza|strong="H6718"\w*, hombre del \w campo|strong="H7704"\w*; pero \w Jacob|strong="H3290"\w* \w era|strong="H1961"\w* varón \w quieto|strong="H8535"\w*, \w que|strong="H3045"\w* \w habitaba|strong="H3427"\w* en tiendas.  
\v 28 \w E|strong="H3068"\w* \w Isaac|strong="H3327"\w* amaba \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w*, \w porque|strong="H3588"\w* \w comía|strong="H6310"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w caza|strong="H6718"\w*; \w mas|strong="H3588"\w* \w Rebeca|strong="H7259"\w* amaba \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 29 \w Y|strong="H3068"\w* guisó \w Jacob|strong="H3290"\w* un \w potaje|strong="H5138"\w*; y volviendo \w Esaú|strong="H6215"\w* \w del|strong="H4480"\w* \w campo|strong="H7704"\w*, \w cansado|strong="H5889"\w*,  
\v 30 dijo \w Esaú|strong="H6215"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: «\w Te|strong="H5921"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w me|strong="H4480"\w* des \w a|strong="H3068"\w* comer \w de|strong="H4480"\w* \w ese|strong="H2088"\w* guiso rojo, \w pues|strong="H3588"\w* estoy muy \w cansado|strong="H5889"\w*». \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w* fue \w llamado|strong="H8034"\w* Edom.\f + \fr 25:30 \ft «Edom» significa «rojo».\f*   
\p
\v 31 \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* respondió: «\w Véndeme|strong="H4376"\w* en este \w día|strong="H3117"\w* tu primogenitura».   
\p
\v 32 Entonces dijo \w Esaú|strong="H6215"\w*: «He \w aquí|strong="H2088"\w* \w yo|strong="H2009"\w* me \w voy|strong="H1980"\w* \w a|strong="H3068"\w* \w morir|strong="H4191"\w*; ¿para \w qué|strong="H4100"\w*, \w pues|strong="H2088"\w*, me servirá la primogenitura?»   
