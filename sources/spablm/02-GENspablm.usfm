\v 26 \w Todas|strong="H3605"\w* las \w personas|strong="H5315"\w* \w que|strong="H1121"\w* vinieron con \w Jacob|strong="H3290"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, \w procedentes|strong="H3318"\w* \w de|strong="H1121"\w* sus lomos, sin las mujeres \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w*, \w todas|strong="H3605"\w* las \w personas|strong="H5315"\w* fueron \w sesenta|strong="H8346"\w* y \w seis|strong="H8337"\w*.  
\v 27 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*, \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* en \w Egipto|strong="H4714"\w*, \w dos|strong="H8147"\w* \w personas|strong="H5315"\w*. \w Todas|strong="H3605"\w* las \w almas|strong="H5315"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w*, \w que|strong="H1121"\w* entraron en \w Egipto|strong="H4714"\w*, fueron \w setenta|strong="H7657"\w*.   
\p
\v 28 \w Y|strong="H3068"\w* \w envió|strong="H7971"\w* Jacob \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w sí|strong="H6440"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*, para que le viniese \w a|strong="H3068"\w* ver en Gosén; y llegaron \w a|strong="H3068"\w* la tierra \w de|strong="H6440"\w* Gosén.  
\v 29 \w Y|strong="H3068"\w* \w José|strong="H3130"\w* unció su \w carro|strong="H4818"\w* \w y|strong="H5921"\w* \w vino|strong="H5307"\w* \w a|strong="H3068"\w* recibir \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* su padre \w en|strong="H5921"\w* Gosén; \w y|strong="H5921"\w* \w se|strong="H5921"\w* manifestó \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* su \w cuello|strong="H6677"\w*, \w y|strong="H5921"\w* \w lloró|strong="H1058"\w* \w sobre|strong="H5921"\w* su \w cuello|strong="H6677"\w* largamente.  
\v 30 \w Entonces|strong="H3588"\w* \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* \w José|strong="H3130"\w*: «\w Muera|strong="H4191"\w* \w yo|strong="H3588"\w* \w ahora|strong="H6471"\w*, ya \w que|strong="H3588"\w* he \w visto|strong="H7200"\w* tu \w rostro|strong="H6440"\w*, \w y|strong="H3588"\w* sé \w que|strong="H3588"\w* \w aún|strong="H5750"\w* \w vives|strong="H2416"\w*».   
\p
\v 31 \w Y|strong="H3068"\w* \w José|strong="H3130"\w* \w dijo|strong="H5046"\w* \w a|strong="H3068"\w* sus hermanos, y \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de su padre: “\w Subiré|strong="H5927"\w* y lo haré \w saber|strong="H5046"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*, y le diré: ‘Mis hermanos y la \w casa|strong="H1004"\w* de mi padre, que estaban en la tierra de \w Canaán|strong="H3667"\w*, han venido \w a|strong="H3068"\w* mí.  
\v 32 \w Y|strong="H3068"\w* \w los|strong="H3605"\w* hombres \w son|strong="H1961"\w* \w pastores|strong="H7462"\w* \w de|strong="H3588"\w* \w ovejas|strong="H6629"\w*, \w porque|strong="H3588"\w* \w son|strong="H1961"\w* \w ganaderos|strong="H4735"\w*; \w y|strong="H3588"\w* han traído sus \w ovejas|strong="H6629"\w* \w y|strong="H3588"\w* sus \w vacas|strong="H1241"\w*, \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3588"\w* \w tenían|strong="H1961"\w*’.  
\v 33 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w Faraón|strong="H6547"\w* os \w llame|strong="H7121"\w* \w y|strong="H3588"\w* os pregunte: ‘¿\w Cuál|strong="H4100"\w* \w es|strong="H1961"\w* vuestro oficio?’  
\v 34 \w entonces|strong="H3588"\w* diréis: ‘Tus \w siervos|strong="H5650"\w* han \w sido|strong="H1961"\w* \w ganaderos|strong="H4735"\w* \w desde|strong="H5704"\w* nuestra \w juventud|strong="H5271"\w* \w hasta|strong="H5704"\w* \w ahora|strong="H6258"\w*, \w nosotros|strong="H3605"\w* \w y|strong="H1571"\w* nuestros padres’; \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* moréis \w en|strong="H5704"\w* \w la|strong="H1571"\w* tierra \w de|strong="H3588"\w* Gosén, \w porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w pastor|strong="H7462"\w* \w de|strong="H3588"\w* \w ovejas|strong="H6629"\w* \w es|strong="H1961"\w* \w abominación|strong="H8441"\w* \w para|strong="H5704"\w* \w los|strong="H3427"\w* \w egipcios|strong="H4713"\w*”.   
\c 47
\p
\v 1 Vino \w José|strong="H3130"\w* \w y|strong="H1241"\w* \w lo|strong="H3605"\w* hizo \w saber|strong="H5046"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H1241"\w* \w dijo|strong="H5046"\w*: «Mi padre \w y|strong="H1241"\w* mis hermanos, \w y|strong="H1241"\w* sus \w ovejas|strong="H6629"\w* \w y|strong="H1241"\w* sus \w vacas|strong="H1241"\w*, con \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tienen, han venido de \w la|strong="H3605"\w* tierra de \w Canaán|strong="H3667"\w*, \w y|strong="H1241"\w* he \w aquí|strong="H2005"\w* están en \w la|strong="H3605"\w* tierra de Gosén».  
\v 2 \w Y|strong="H3068"\w* \w de|strong="H6440"\w* entre sus hermanos \w tomó|strong="H3947"\w* \w cinco|strong="H2568"\w* varones, y los presentó \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Faraón|strong="H6547"\w*.  
\v 3 \w Y|strong="H3068"\w* \w Faraón|strong="H6547"\w* dijo \w a|strong="H3068"\w* sus hermanos: «¿\w Cuál|strong="H4100"\w* es vuestro oficio?»  
\p \w Y|strong="H3068"\w* \w ellos|strong="H1571"\w* respondieron \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*: «\w Pastores|strong="H7462"\w* de \w ovejas|strong="H6629"\w* son tus \w siervos|strong="H5650"\w*, \w así|strong="H1571"\w* nosotros \w como|strong="H4100"\w* nuestros padres».  
\v 4 Dijeron \w además|strong="H3588"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*: «\w Para|strong="H3588"\w* \w morar|strong="H3427"\w* \w en|strong="H3588"\w* \w esta|strong="H3427"\w* tierra hemos venido; \w porque|strong="H3588"\w* \w no|strong="H3588"\w* hay \w pasto|strong="H4829"\w* \w para|strong="H3588"\w* las \w ovejas|strong="H6629"\w* \w de|strong="H3588"\w* tus \w siervos|strong="H5650"\w*, \w pues|strong="H3588"\w* \w el|strong="H3588"\w* \w hambre|strong="H7458"\w* \w es|strong="H3588"\w* \w grave|strong="H3515"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w*; \w por|strong="H3588"\w* tanto, \w te|strong="H3588"\w* rogamos \w ahora|strong="H6258"\w* \w que|strong="H3588"\w* permitas \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w* \w habitar|strong="H3427"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* Gosén».   
\p
\v 5 Entonces \w Faraón|strong="H6547"\w* habló \w a|strong="H3068"\w* \w José|strong="H3130"\w*, diciendo: «Tu padre y tus hermanos han venido \w a|strong="H3068"\w* ti.  
