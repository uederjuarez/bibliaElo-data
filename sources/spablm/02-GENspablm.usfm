\v 12 \w Y|strong="H3068"\w* \w esperó|strong="H3176"\w* \w aún|strong="H5750"\w* \w otros|strong="H5750"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w*, y \w envió|strong="H7971"\w* la \w paloma|strong="H3123"\w*, la cual \w no|strong="H3808"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* él \w más|strong="H5750"\w*.   
\p
\v 13 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* \w seiscientos|strong="H8337"\w* uno \w de|strong="H5921"\w* \w Noé|strong="H5146"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w mes|strong="H2320"\w* \w primero|strong="H7223"\w*, \w al|strong="H5921"\w* \w primero|strong="H7223"\w* \w del|strong="H5921"\w* \w mes|strong="H2320"\w*, \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w se|strong="H1961"\w* secaron \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra; \w y|strong="H5921"\w* \w quitó|strong="H5493"\w* \w Noé|strong="H5146"\w* \w la|strong="H5921"\w* cubierta \w del|strong="H5921"\w* \w arca|strong="H8392"\w* \w y|strong="H5921"\w* \w miró|strong="H7200"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w estaba|strong="H1961"\w* seca.  
\v 14 \w Y|strong="H3068"\w* en el \w mes|strong="H2320"\w* \w segundo|strong="H8145"\w*, \w a|strong="H3068"\w* los \w veintisiete|strong="H6242"\w* \w días|strong="H3117"\w* del \w mes|strong="H2320"\w*, se \w secó|strong="H3001"\w* la tierra.   
\p
\v 15 Entonces \w habló|strong="H1696"\w* Dios \w a|strong="H3068"\w* \w Noé|strong="H5146"\w*, \w diciendo|strong="H1696"\w*:  
\v 16 «\w Salid|strong="H3318"\w* \w del|strong="H4480"\w* \w arca|strong="H8392"\w* tú, y vuestra mujer, y vuestros \w hijos|strong="H1121"\w*, y las mujeres \w de|strong="H4480"\w* vuestros \w hijos|strong="H1121"\w* \w con|strong="H4480"\w* vosotros.  
\v 17 \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w animales|strong="H2416"\w* \w que|strong="H5921"\w* están \w con|strong="H5921"\w* vosotros \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w*, \w de|strong="H5921"\w* \w aves|strong="H5775"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w bestias|strong="H2416"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w reptil|strong="H7431"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* arrastra \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, sacadlos \w con|strong="H5921"\w* vosotros; \w y|strong="H5921"\w* vayan \w por|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* fructifiquen \w y|strong="H5921"\w* multiplíquense \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra».   
\p
\v 18 Entonces \w salió|strong="H3318"\w* \w Noé|strong="H5146"\w*, y sus \w hijos|strong="H1121"\w*, su mujer, y las mujeres \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* con \w él|strong="H1121"\w*.  
\v 19 \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w animales|strong="H2416"\w*, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w reptil|strong="H7431"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w ave|strong="H5775"\w*, \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H4480"\w* \w se|strong="H5921"\w* mueve \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w según|strong="H5921"\w* sus especies, \w salieron|strong="H3318"\w* \w del|strong="H4480"\w* \w arca|strong="H8392"\w*.   
\p
\v 20 \w Y|strong="H3068"\w* \w edificó|strong="H1129"\w* \w Noé|strong="H5146"\w* un \w altar|strong="H4196"\w* \w a|strong="H3068"\w* Yahvé, y \w tomó|strong="H3947"\w* de \w todo|strong="H3605"\w* animal \w limpio|strong="H2889"\w* y de \w toda|strong="H3605"\w* \w ave|strong="H5775"\w* \w limpia|strong="H2889"\w*, y \w ofreció|strong="H5927"\w* \w holocausto|strong="H5930"\w* en \w el|strong="H3605"\w* \w altar|strong="H4196"\w*.  
\v 21 \w Y|strong="H3068"\w* percibió Yahvé \w olor|strong="H7381"\w* \w grato|strong="H5207"\w*; \w y|strong="H3588"\w* dijo Yahvé \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w*: «\w No|strong="H3808"\w* \w volveré|strong="H3254"\w* \w más|strong="H5750"\w* \w a|strong="H3068"\w* maldecir \w la|strong="H3588"\w* tierra \w por|strong="H3588"\w* causa del hombre; \w porque|strong="H3588"\w* \w el|strong="H3588"\w* intento del \w corazón|strong="H3820"\w* del hombre \w es|strong="H3588"\w* \w malo|strong="H7451"\w* desde \w su|strong="H3588"\w* \w juventud|strong="H5271"\w*; \w ni|strong="H3808"\w* \w volveré|strong="H3254"\w* \w más|strong="H5750"\w* \w a|strong="H3068"\w* destruir \w todo|strong="H3605"\w* ser \w viviente|strong="H2416"\w*, \w como|strong="H3588"\w* he \w hecho|strong="H6213"\w*.  
\v 22 \w Mientras|strong="H3605"\w* \w la|strong="H3605"\w* tierra permanezca, \w no|strong="H3808"\w* \w cesarán|strong="H7673"\w* \w la|strong="H3605"\w* sementera y \w la|strong="H3605"\w* siega, \w el|strong="H3605"\w* frío y \w el|strong="H3605"\w* calor, \w el|strong="H3605"\w* \w verano|strong="H7019"\w* y \w el|strong="H3605"\w* invierno, y \w el|strong="H3605"\w* \w día|strong="H3117"\w* y \w la|strong="H3605"\w* \w noche|strong="H3915"\w*».   
\c 9
\p
\v 1 \w Bendijo|strong="H1288"\w* Dios \w a|strong="H3068"\w* \w Noé|strong="H5146"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*, y les dijo: «\w Fructificad|strong="H6509"\w* y multiplicaos, y llenad la tierra.  
\v 2 Vuestro \w temor|strong="H4172"\w* \w y|strong="H5921"\w* vuestro pavor \w estarán|strong="H1961"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w animal|strong="H2416"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w ave|strong="H5775"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*, \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* mueva \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* peces \w del|strong="H5921"\w* \w mar|strong="H3220"\w*; \w en|strong="H5921"\w* vuestras \w manos|strong="H3027"\w* \w son|strong="H1961"\w* entregados.  
\v 3 \w Todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w se|strong="H1961"\w* mueve y \w vive|strong="H2416"\w* os \w será|strong="H1961"\w* \w para|strong="H5414"\w* mantenimiento: \w así|strong="H1931"\w* \w como|strong="H1961"\w* las legumbres y hierbas verdes, os \w lo|strong="H1931"\w* he \w dado|strong="H5414"\w* \w todo|strong="H3605"\w*.  
\v 4 Pero \w carne|strong="H1320"\w* con su \w vida|strong="H5315"\w*, \w que|strong="H3808"\w* es su \w sangre|strong="H1818"\w*, \w no|strong="H3808"\w* comeréis.  
\v 5 Porque \w ciertamente|strong="H1875"\w* \w demandaré|strong="H1875"\w* \w la|strong="H3605"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* vuestras \w vidas|strong="H5315"\w*; \w de|strong="H1818"\w* \w mano|strong="H3027"\w* \w de|strong="H1818"\w* \w toda|strong="H3605"\w* \w bestia|strong="H2416"\w* \w la|strong="H3605"\w* \w demandaré|strong="H1875"\w*, y \w de|strong="H1818"\w* \w mano|strong="H3027"\w* del hombre; \w de|strong="H1818"\w* \w mano|strong="H3027"\w* del varón su hermano \w demandaré|strong="H1875"\w* \w la|strong="H3605"\w* \w vida|strong="H5315"\w* del hombre.  
\v 6 \w El|strong="H3588"\w* \w que|strong="H3588"\w* \w derramare|strong="H8210"\w* \w sangre|strong="H1818"\w* \w de|strong="H3588"\w* hombre, \w por|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w su|strong="H3588"\w* \w sangre|strong="H1818"\w* \w será|strong="H6213"\w* derramada; \w porque|strong="H3588"\w* \w a|strong="H3068"\w* \w imagen|strong="H6754"\w* \w de|strong="H3588"\w* Dios \w es|strong="H3588"\w* \w hecho|strong="H6213"\w* \w el|strong="H3588"\w* hombre.  
\v 7 \w Mas|strong="H7235"\w* vosotros \w fructificad|strong="H6509"\w* y multiplicaos; procread abundantemente en la tierra, y multiplicaos en ella».   
\p
\v 8 \w Y|strong="H3068"\w* habló Dios \w a|strong="H3068"\w* \w Noé|strong="H5146"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* con \w él|strong="H1121"\w*, diciendo:  
\v 9 «He \w aquí|strong="H2005"\w* que yo establezco mi \w pacto|strong="H1285"\w* con vosotros, y con vuestra \w simiente|strong="H2233"\w* después de vosotros;  
\v 10 y con \w todo|strong="H3605"\w* \w ser|strong="H5315"\w* \w viviente|strong="H2416"\w* \w que|strong="H3605"\w* está con vosotros, de \w aves|strong="H5775"\w*, de \w animales|strong="H2416"\w* y de \w toda|strong="H3605"\w* \w bestia|strong="H2416"\w* de \w la|strong="H3605"\w* tierra \w que|strong="H3605"\w* está con vosotros, desde \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* \w salieron|strong="H3318"\w* del \w arca|strong="H8392"\w* hasta \w todo|strong="H3605"\w* \w animal|strong="H2416"\w* de \w la|strong="H3605"\w* tierra.  
\v 11 \w Estableceré|strong="H6965"\w* \w mi|strong="H1961"\w* \w pacto|strong="H1285"\w* con vosotros, y \w no|strong="H3808"\w* exterminaré ya \w más|strong="H5750"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* con \w aguas|strong="H4325"\w* \w de|strong="H5750"\w* \w diluvio|strong="H3999"\w*, \w ni|strong="H3808"\w* \w habrá|strong="H1961"\w* \w más|strong="H5750"\w* \w diluvio|strong="H3999"\w* \w para|strong="H1961"\w* \w destruir|strong="H7843"\w* \w la|strong="H3605"\w* tierra».  
\v 12 \w Y|strong="H3068"\w* dijo Dios: «\w Ésta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* señal del \w pacto|strong="H1285"\w* \w que|strong="H3605"\w* \w yo|strong="H5315"\w* \w establezco|strong="H5414"\w* entre \w mí|strong="H5315"\w* y vosotros y \w todo|strong="H3605"\w* \w ser|strong="H5315"\w* \w viviente|strong="H2416"\w* \w que|strong="H3605"\w* \w está|strong="H2063"\w* con vosotros, \w por|strong="H5769"\w* \w siglos|strong="H5769"\w* \w perpetuos|strong="H5769"\w*:  
\v 13 \w Mi|strong="H1961"\w* \w arco|strong="H7198"\w* he \w puesto|strong="H5414"\w* en las \w nubes|strong="H6051"\w*, el cual \w será|strong="H1961"\w* \w por|strong="H5414"\w* señal del \w pacto|strong="H1285"\w* entre \w mí|strong="H1961"\w* y la tierra.  
\v 14 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H5921"\w* \w cuando|strong="H1961"\w* haga venir \w nubes|strong="H6051"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w se|strong="H1961"\w* dejará \w ver|strong="H7200"\w* entonces \w mi|strong="H5921"\w* \w arco|strong="H7198"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w nubes|strong="H6051"\w*.  
\v 15 \w Y|strong="H3068"\w* me acordaré del \w pacto|strong="H1285"\w* mío, \w que|strong="H3808"\w* \w hay|strong="H1961"\w* \w entre|strong="H3808"\w* \w mí|strong="H1961"\w* y vosotros y \w todo|strong="H3605"\w* \w ser|strong="H5315"\w* \w viviente|strong="H2416"\w* \w de|strong="H5750"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w*; y \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* \w más|strong="H5750"\w* \w aguas|strong="H4325"\w* \w de|strong="H5750"\w* \w diluvio|strong="H3999"\w* \w para|strong="H1961"\w* \w destruir|strong="H7843"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w*.  
\v 16 \w Estará|strong="H1961"\w* \w el|strong="H5921"\w* \w arco|strong="H7198"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w nubes|strong="H6051"\w*, \w y|strong="H5921"\w* verlo he \w para|strong="H5921"\w* acordarme \w del|strong="H5921"\w* \w pacto|strong="H1285"\w* \w perpetuo|strong="H5769"\w* \w entre|strong="H5921"\w* Dios \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w ser|strong="H5315"\w* \w viviente|strong="H2416"\w*, \w con|strong="H5921"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* \w que|strong="H5921"\w* \w hay|strong="H1961"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra».  
\v 17 Dijo, pues, Dios \w a|strong="H3068"\w* \w Noé|strong="H5146"\w*: «\w Ésta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H5921"\w* señal \w del|strong="H5921"\w* \w pacto|strong="H1285"\w* \w que|strong="H5921"\w* he establecido \w entre|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* \w que|strong="H5921"\w* \w está|strong="H2063"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra».   
\p
\v 18 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Noé|strong="H5146"\w* \w que|strong="H4480"\w* \w salieron|strong="H3318"\w* \w del|strong="H4480"\w* \w arca|strong="H8392"\w* \w fueron|strong="H1961"\w* \w Sem|strong="H8035"\w*, Cam y Jafet; y Cam \w es|strong="H1931"\w* \w el|strong="H1931"\w* padre \w de|strong="H4480"\w* \w Canaán|strong="H3667"\w*.  
\v 19 \w Éstos|strong="H3605"\w* \w tres|strong="H7969"\w* son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Noé|strong="H5146"\w*, y \w de|strong="H1121"\w* \w ellos|strong="H3605"\w* se pobló \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra.   
\p
\v 20 Después \w comenzó|strong="H2490"\w* \w Noé|strong="H5146"\w* \w a|strong="H3068"\w* labrar la tierra, y \w plantó|strong="H5193"\w* una \w viña|strong="H3754"\w*;  
\v 21 y \w bebió|strong="H8354"\w* \w del|strong="H4480"\w* \w vino|strong="H3196"\w*, y \w se|strong="H4480"\w* embriagó, y estaba descubierto \w en|strong="H4480"\w* \w medio|strong="H8432"\w* \w de|strong="H4480"\w* su tienda.  
\v 22 \w Y|strong="H3068"\w* Cam, padre de \w Canaán|strong="H3667"\w*, \w vio|strong="H7200"\w* la \w desnudez|strong="H6172"\w* de su padre, y lo \w dijo|strong="H5046"\w* \w a|strong="H3068"\w* sus \w dos|strong="H8147"\w* hermanos que estaban \w fuera|strong="H2351"\w*.  
\v 23 Entonces \w Sem|strong="H8035"\w* \w y|strong="H5921"\w* Jafet \w tomaron|strong="H3947"\w* \w la|strong="H5921"\w* \w ropa|strong="H8071"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w pusieron|strong="H7760"\w* \w sobre|strong="H5921"\w* sus propios \w hombros|strong="H7926"\w*, \w y|strong="H5921"\w* \w andando|strong="H3212"\w* \w hacia|strong="H5921"\w* atrás, \w cubrieron|strong="H3680"\w* \w la|strong="H5921"\w* \w desnudez|strong="H6172"\w* \w de|strong="H5921"\w* su padre, teniendo vueltos sus \w rostros|strong="H6440"\w*, \w y|strong="H5921"\w* así \w no|strong="H3808"\w* \w vieron|strong="H7200"\w* \w la|strong="H5921"\w* \w desnudez|strong="H6172"\w* \w de|strong="H5921"\w* su padre.  
\v 24 \w Y|strong="H3068"\w* \w despertó|strong="H3364"\w* \w Noé|strong="H5146"\w* \w de|strong="H1121"\w* su \w vino|strong="H3196"\w*, y \w supo|strong="H3045"\w* \w lo|strong="H6213"\w* \w que|strong="H3045"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* con \w él|strong="H1121"\w* su \w hijo|strong="H1121"\w* más joven,  
\v 25 y dijo:  
\q1 «Maldito \w sea|strong="H1961"\w* \w Canaán|strong="H3667"\w*;  
\q2 \w siervo|strong="H5650"\w* de \w siervos|strong="H5650"\w* \w será|strong="H1961"\w* \w a|strong="H3068"\w* sus hermanos».   
\p
\v 26 Dijo más:  
\q1 «\w Bendito|strong="H1288"\w* \w sea|strong="H1961"\w* Yahvé el \w Dios|strong="H3068"\w* de \w Sem|strong="H8035"\w*,  
\q2 y \w sea|strong="H1961"\w* \w Canaán|strong="H3667"\w* su \w siervo|strong="H5650"\w*.   
\q1
\v 27 \w Engrandezca|strong="H6601"\w* Dios \w a|strong="H3068"\w* Jafet,  
\q2 y habite en las tiendas de \w Sem|strong="H8035"\w*,  
\q2 y \w sea|strong="H1961"\w* \w Canaán|strong="H3667"\w* su \w siervo|strong="H5650"\w*».   
\p
\v 28 \w Y|strong="H3068"\w* \w vivió|strong="H2421"\w* \w Noé|strong="H5146"\w* después del \w diluvio|strong="H3999"\w* \w trescientos|strong="H7969"\w* \w cincuenta|strong="H2572"\w* \w años|strong="H8141"\w*.  
\v 29 \w Y|strong="H3068"\w* \w fueron|strong="H1961"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* de \w Noé|strong="H5146"\w* \w novecientos|strong="H8672"\w* \w cincuenta|strong="H2572"\w* \w años|strong="H8141"\w*; y \w murió|strong="H4191"\w*.   
\c 10
\p
\v 1 Éstas son las generaciones \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Noé|strong="H5146"\w*: \w Sem|strong="H8035"\w*, Cam y Jafet, \w a|strong="H3068"\w* \w los|strong="H1121"\w* cuales \w nacieron|strong="H3205"\w* \w hijos|strong="H1121"\w* después del \w diluvio|strong="H3999"\w*.   
\p
\v 2 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jafet: \w Gomer|strong="H1586"\w*, \w Magog|strong="H4031"\w*, Madai, \w Javán|strong="H3120"\w*, \w Tubal|strong="H8422"\w*, \w Mesec|strong="H4902"\w* y Tiras.  
\v 3 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gomer|strong="H1586"\w*: Askenaz, Rifat y Togarma.  
\v 4 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Javán|strong="H3120"\w*: Elisa, \w Tarsis|strong="H8659"\w*, Quitim y Dodanim.  
\v 5 De éstos se poblaron las costas de las \w naciones|strong="H1471"\w* en sus tierras, cada cual según su \w lengua|strong="H3956"\w*, conforme \w a|strong="H3068"\w* sus \w familias|strong="H4940"\w* en sus \w naciones|strong="H1471"\w*.   
\p
\v 6 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cam: Cus, Mizraim, Fut y \w Canaán|strong="H3667"\w*.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cus: \w Seba|strong="H7614"\w*, \w Havila|strong="H2341"\w*, Sabta, Raama y Sabteca. \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Raama: Sabá y \w Dedán|strong="H1719"\w*.  
\v 8 \w Y|strong="H3068"\w* Cus \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Nimrod, \w quien|strong="H1931"\w* llegó \w a|strong="H3068"\w* ser \w el|strong="H1931"\w* primer \w poderoso|strong="H1368"\w* en \w la|strong="H1931"\w* tierra.  
\v 9 \w Éste|strong="H1931"\w* \w fue|strong="H1961"\w* \w vigoroso|strong="H1368"\w* \w cazador|strong="H6718"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé; \w por|strong="H5921"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w se|strong="H1961"\w* dice: «\w Así|strong="H3651"\w* \w como|strong="H1961"\w* Nimrod, \w vigoroso|strong="H1368"\w* \w cazador|strong="H6718"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé».  
\v 10 \w Y|strong="H3068"\w* \w fue|strong="H1961"\w* el comienzo de su \w reino|strong="H4467"\w* Babel, Erec, Acad y Calne, en la tierra de Sinar.  
\v 11 \w De|strong="H4480"\w* \w esta|strong="H1931"\w* tierra \w salió|strong="H3318"\w* \w para|strong="H4480"\w* Asiria, y \w edificó|strong="H1129"\w* \w Nínive|strong="H5210"\w*, Rehobot, Cala,  
\v 12 y Resén entre \w Nínive|strong="H5210"\w* y Cala, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w grande|strong="H1419"\w*.  
\v 13 Mizraim \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Ludim, \w a|strong="H3068"\w* Anamim, \w a|strong="H3068"\w* Lehabim, \w a|strong="H3068"\w* Naftuhim,  
\v 14 \w a|strong="H3068"\w* Patrusim, \w a|strong="H3068"\w* Casluhim, de \w donde|strong="H8033"\w* \w salieron|strong="H3318"\w* los \w filisteos|strong="H6430"\w*, y \w a|strong="H3068"\w* Caftorim.   
\p
\v 15 \w Y|strong="H3068"\w* \w Canaán|strong="H3667"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sidón|strong="H6721"\w* su \w primogénito|strong="H1060"\w*, \w a|strong="H3068"\w* Het,  
\v 16 al \w jebuseo|strong="H2983"\w*, al amorreo, al gergeseo,  
\v 17 al \w heveo|strong="H2340"\w*, al araceo, al sineo,  
\v 18 al arvadeo, al zemareo y al hamateo; y después se dispersaron las \w familias|strong="H4940"\w* de los \w cananeos|strong="H3669"\w*.  
\v 19 \w Y|strong="H3068"\w* \w fue|strong="H1961"\w* el territorio \w de|strong="H5704"\w* \w los|strong="H1961"\w* \w cananeos|strong="H3669"\w* \w desde|strong="H5704"\w* \w Sidón|strong="H6721"\w*, \w en|strong="H5704"\w* dirección \w a|strong="H3068"\w* \w Gerar|strong="H1642"\w*, \w hasta|strong="H5704"\w* \w Gaza|strong="H5804"\w*; \w y|strong="H5704"\w* \w en|strong="H5704"\w* dirección \w de|strong="H5704"\w* \w Sodoma|strong="H5467"\w*, \w Gomorra|strong="H6017"\w*, Adma \w y|strong="H5704"\w* Zeboim, \w hasta|strong="H5704"\w* \w Lasa|strong="H3962"\w*.  
\v 20 Éstos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cam por sus \w familias|strong="H4940"\w*, por sus lenguas, en sus tierras, en sus \w naciones|strong="H1471"\w*.   
\p
\v 21 \w También|strong="H1571"\w* \w le|strong="H1931"\w* \w nacieron|strong="H3205"\w* \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* \w Sem|strong="H8035"\w*, padre \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Heber|strong="H5677"\w*, \w y|strong="H1571"\w* hermano \w mayor|strong="H1419"\w* \w de|strong="H1121"\w* Jafet.  
\v 22 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sem|strong="H8035"\w*: \w Elam|strong="H5867"\w*, Asur, Arfaxad, \w Lud|strong="H3865"\w* y Aram.  
\v 23 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aram: \w Uz|strong="H5780"\w*, \w Hul|strong="H2343"\w*, Geter y Mas.  
\v 24 Arfaxad \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sala|strong="H7974"\w*, y \w Sala|strong="H7974"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w*.  
\v 25 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w* \w nacieron|strong="H3205"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*: \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* del uno fue \w Peleg|strong="H6389"\w*, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* sus \w días|strong="H3117"\w* fue repartida \w la|strong="H3588"\w* tierra; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermano, \w Joctán|strong="H3355"\w*.  
\v 26 \w Y|strong="H3068"\w* \w Joctán|strong="H3355"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Almodad, Selef, Hazar-mavet, Jera,  
\v 27 Adoram, Uzal, \w Dicla|strong="H1853"\w*,  
\v 28 Obal, Abimael, Sabá,  
\v 29 Ofir, \w Havila|strong="H2341"\w* y \w Jobab|strong="H3103"\w*; \w todos|strong="H3605"\w* \w éstos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Joctán|strong="H3355"\w*.  
\v 30 \w Y|strong="H3068"\w* su habitación \w fue|strong="H1961"\w* desde Mesa en dirección de Sefar, \w monte|strong="H2022"\w* del \w oriente|strong="H6924"\w*.  
\v 31 Éstos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sem|strong="H8035"\w* por sus \w familias|strong="H4940"\w*, por sus lenguas, en sus tierras, en sus \w naciones|strong="H1471"\w*.   
\p
\v 32 Éstas son las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Noé|strong="H5146"\w* por sus descendencias, en sus \w naciones|strong="H1471"\w*; y \w de|strong="H1121"\w* éstos se esparcieron las \w naciones|strong="H1471"\w* en la tierra después del \w diluvio|strong="H3999"\w*.   
\c 11
\p
\v 1 \w Tenía|strong="H1961"\w* entonces \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra una sola \w lengua|strong="H8193"\w* y unas mismas \w palabras|strong="H1697"\w*.  
\v 2 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w partieron|strong="H5265"\w* de \w oriente|strong="H6924"\w*, \w hallaron|strong="H4672"\w* \w una|strong="H4672"\w* llanura en la tierra de Sinar, y \w se|strong="H1961"\w* establecieron \w allí|strong="H8033"\w*.  
\v 3 \w Y|strong="H3068"\w* \w se|strong="H1961"\w* dijeron unos \w a|strong="H3068"\w* otros: «Venid, \w hagamos|strong="H3835"\w* \w ladrillo|strong="H3835"\w* y cozámoslo con fuego». \w Y|strong="H3068"\w* les sirvió el \w ladrillo|strong="H3835"\w* en lugar de piedra, y el betún en lugar de mezcla.  
\v 4 \w Y|strong="H3068"\w* dijeron: «Venid, \w edifiquémonos|strong="H1129"\w* una \w ciudad|strong="H5892"\w* \w y|strong="H5921"\w* una \w torre|strong="H4026"\w*, cuya cúspide llegue \w al|strong="H5921"\w* \w cielo|strong="H8064"\w*; \w y|strong="H5921"\w* hagámonos un \w nombre|strong="H8034"\w*, \w por|strong="H5921"\w* \w si|strong="H6440"\w* fuéramos esparcidos \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra».   
\p
\v 5 \w Y|strong="H3068"\w* \w descendió|strong="H3381"\w* Yahvé para \w ver|strong="H7200"\w* la \w ciudad|strong="H5892"\w* y la \w torre|strong="H4026"\w* \w que|strong="H1121"\w* \w edificaban|strong="H1129"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*.  
\v 6 \w Y|strong="H3068"\w* dijo Yahvé: «He \w aquí|strong="H2088"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w es|strong="H2088"\w* uno, y \w todos|strong="H3605"\w* \w éstos|strong="H1992"\w* \w tienen|strong="H1992"\w* un solo \w lenguaje|strong="H8193"\w*; y han comenzado \w la|strong="H3605"\w* edificación, y \w ahora|strong="H6258"\w* \w nada|strong="H3808"\w* \w les|strong="H1992"\w* \w hará|strong="H6213"\w* desistir \w de|strong="H5971"\w* \w lo|strong="H2088"\w* \w que|strong="H3808"\w* han pensado \w hacer|strong="H6213"\w*.  
\v 7 Ahora, \w pues|strong="H3381"\w*, \w descendamos|strong="H3381"\w*, y confundamos \w allí|strong="H8033"\w* su \w lengua|strong="H8193"\w*, para \w que|strong="H3808"\w* \w ninguno|strong="H3808"\w* \w entienda|strong="H8085"\w* el \w habla|strong="H8193"\w* de su \w compañero|strong="H7453"\w*».  
\v 8 Así \w los|strong="H5921"\w* esparció Yahvé \w desde|strong="H6440"\w* \w allí|strong="H8033"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w dejaron|strong="H2308"\w* \w de|strong="H5921"\w* \w edificar|strong="H1129"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.  
\v 9 \w Por|strong="H5921"\w* \w esto|strong="H3651"\w* fue \w llamado|strong="H8034"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* \w ella|strong="H8033"\w* Babel, \w porque|strong="H3588"\w* \w allí|strong="H8033"\w* \w confundió|strong="H1101"\w* Yahvé \w el|strong="H5921"\w* \w lenguaje|strong="H8193"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H3588"\w* \w desde|strong="H6440"\w* \w allí|strong="H8033"\w* \w los|strong="H5921"\w* esparció \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.   
\p
\v 10 Éstas son las generaciones \w de|strong="H1121"\w* \w Sem|strong="H8035"\w*: \w Sem|strong="H8035"\w*, \w de|strong="H1121"\w* \w edad|strong="H8141"\w* \w de|strong="H1121"\w* \w cien|strong="H3967"\w* \w años|strong="H8141"\w*, \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Arfaxad, \w dos|strong="H8141"\w* \w años|strong="H8141"\w* después del \w diluvio|strong="H3999"\w*.  
\v 11 \w Y|strong="H3068"\w* \w vivió|strong="H2421"\w* \w Sem|strong="H8035"\w*, después \w que|strong="H1121"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Arfaxad, \w quinientos|strong="H2568"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.   
\p
\v 12 Arfaxad \w vivió|strong="H2421"\w* \w treinta|strong="H7970"\w* y \w cinco|strong="H2568"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sala|strong="H7974"\w*.  
\v 13 \w Y|strong="H3068"\w* \w vivió|strong="H2421"\w* Arfaxad, después \w que|strong="H1121"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sala|strong="H7974"\w*, cuatrocientos \w tres|strong="H7969"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.   
\p
\v 14 \w Sala|strong="H7974"\w* \w vivió|strong="H2421"\w* \w treinta|strong="H7970"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w*.  
\v 15 \w Y|strong="H3068"\w* \w vivió|strong="H2421"\w* \w Sala|strong="H7974"\w*, después \w que|strong="H1121"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w*, cuatrocientos \w tres|strong="H7969"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.   
\p
\v 16 \w Heber|strong="H5677"\w* \w vivió|strong="H2421"\w* \w treinta|strong="H7970"\w* y cuatro \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Peleg|strong="H6389"\w*.  
\v 17 \w Y|strong="H3068"\w* \w vivió|strong="H2421"\w* \w Heber|strong="H5677"\w*, después \w que|strong="H1121"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Peleg|strong="H6389"\w*, cuatrocientos \w treinta|strong="H7970"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.   
\p
\v 18 \w Peleg|strong="H6389"\w* \w vivió|strong="H2421"\w* \w treinta|strong="H7970"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Reu|strong="H7466"\w*.  
\v 19 \w Y|strong="H3068"\w* \w vivió|strong="H2421"\w* \w Peleg|strong="H6389"\w*, después \w que|strong="H1121"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Reu|strong="H7466"\w*, \w doscientos|strong="H3967"\w* \w nueve|strong="H8672"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.   
\p
\v 20 \w Reu|strong="H7466"\w* \w vivió|strong="H2421"\w* \w treinta|strong="H7970"\w* y \w dos|strong="H8147"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Serug|strong="H8286"\w*.  
\v 21 \w Y|strong="H3068"\w* \w vivió|strong="H2421"\w* \w Reu|strong="H7466"\w*, después \w que|strong="H1121"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Serug|strong="H8286"\w*, \w doscientos|strong="H3967"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.   
\p
\v 22 \w Serug|strong="H8286"\w* \w vivió|strong="H2421"\w* \w treinta|strong="H7970"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Nacor.  
\v 23 \w Y|strong="H3068"\w* \w vivió|strong="H2421"\w* \w Serug|strong="H8286"\w*, después \w que|strong="H1121"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Nacor, \w doscientos|strong="H3967"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.   
\p
\v 24 Nacor \w vivió|strong="H2421"\w* \w veintinueve|strong="H6242"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Taré.  
\v 25 \w Y|strong="H3068"\w* \w vivió|strong="H2421"\w* Nacor, después \w que|strong="H1121"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Taré, \w ciento|strong="H3967"\w* \w diecinueve|strong="H8672"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.   
\p
\v 26 Taré \w vivió|strong="H2421"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*, y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Abram, \w a|strong="H3068"\w* Nacor y \w a|strong="H3068"\w* \w Harán|strong="H2039"\w*.   
\p
\v 27 Éstas son las generaciones de Taré: Taré \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Abram, \w a|strong="H3068"\w* Nacor y \w a|strong="H3068"\w* \w Harán|strong="H2039"\w*; y \w Harán|strong="H2039"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Lot|strong="H3876"\w*.  
\v 28 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Harán|strong="H2039"\w* \w antes|strong="H6440"\w* \w que|strong="H5921"\w* su padre Taré \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* su \w nacimiento|strong="H4138"\w*, \w en|strong="H5921"\w* Ur \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w*.  
\v 29 \w Y|strong="H3068"\w* \w tomaron|strong="H3947"\w* Abram y Nacor para sí \w mujeres|strong="H1323"\w*; el \w nombre|strong="H8034"\w* de la mujer de Abram era \w Sarai|strong="H8297"\w*, y el \w nombre|strong="H8034"\w* de la mujer de Nacor, \w Milca|strong="H4435"\w*, \w hija|strong="H1323"\w* de \w Harán|strong="H2039"\w*, padre de \w Milca|strong="H4435"\w* y de Isca.  
\v 30 Mas \w Sarai|strong="H8297"\w* \w era|strong="H1961"\w* estéril, y \w no|strong="H1961"\w* \w tenía|strong="H1961"\w* hijo.  
\v 31 \w Y|strong="H3068"\w* \w tomó|strong="H3947"\w* Taré \w a|strong="H3068"\w* Abram su \w hijo|strong="H1121"\w*, \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w Lot|strong="H3876"\w* \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Harán|strong="H2771"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* su \w hijo|strong="H1121"\w*, \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w Sarai|strong="H8297"\w* su \w nuera|strong="H3618"\w*, mujer \w de|strong="H5704"\w* Abram su \w hijo|strong="H1121"\w*, \w y|strong="H5704"\w* \w salió|strong="H3318"\w* \w con|strong="H5704"\w* ellos \w de|strong="H5704"\w* Ur \w de|strong="H5704"\w* \w los|strong="H3427"\w* \w caldeos|strong="H3778"\w*, \w para|strong="H5704"\w* \w ir|strong="H3212"\w* \w a|strong="H3068"\w* la tierra \w de|strong="H5704"\w* \w Canaán|strong="H3667"\w*; \w y|strong="H5704"\w* vinieron \w hasta|strong="H5704"\w* \w Harán|strong="H2771"\w*, \w y|strong="H5704"\w* se quedaron \w allí|strong="H8033"\w*.  
\v 32 \w Y|strong="H3068"\w* \w fueron|strong="H1961"\w* \w los|strong="H1961"\w* \w días|strong="H3117"\w* \w de|strong="H2568"\w* Taré \w doscientos|strong="H3967"\w* \w cinco|strong="H2568"\w* \w años|strong="H8141"\w*; y \w murió|strong="H4191"\w* Taré en \w Harán|strong="H2771"\w*.   
\c 12
\p
\v 1 Pero Yahvé había dicho \w a|strong="H3068"\w* Abram: «\w Vete|strong="H3212"\w* de tu tierra y de tu \w parentela|strong="H4138"\w*, y de la \w casa|strong="H1004"\w* de tu padre, \w a|strong="H3068"\w* la tierra que te \w mostraré|strong="H7200"\w*.  
