\p
\v 6 \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* \w la|strong="H1931"\w* mujer \w que|strong="H3588"\w* \w el|strong="H1931"\w* \w árbol|strong="H6086"\w* \w era|strong="H1931"\w* \w bueno|strong="H2896"\w* \w para|strong="H3588"\w* comer, \w y|strong="H1571"\w* \w que|strong="H3588"\w* \w era|strong="H1931"\w* agradable \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w ojos|strong="H5869"\w*, \w y|strong="H1571"\w* \w árbol|strong="H6086"\w* \w codiciable|strong="H2530"\w* \w para|strong="H3588"\w* alcanzar \w la|strong="H1931"\w* sabiduría; \w y|strong="H1571"\w* \w tomó|strong="H3947"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w fruto|strong="H6529"\w* \w y|strong="H1571"\w* comió; \w y|strong="H1571"\w* \w dio|strong="H5414"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* marido, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* comió \w así|strong="H1571"\w* \w como|strong="H3588"\w* \w ella|strong="H1931"\w*.  
