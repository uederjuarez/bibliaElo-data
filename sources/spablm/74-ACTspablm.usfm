\p
\v 23 Propusieron a \w dos|strong="G1417"\w*: a \w José|strong="G2501"\w*, \w llamado|strong="G2564"\w* Barsabás, \w que|strong="G3588"\w* \w también|strong="G2532"\w* \w se|strong="G2532"\w* llamaba \w Justo|strong="G2459"\w*, \w y|strong="G2532"\w* a \w Matías|strong="G3159"\w*.  
\v 24 \w Oraron|strong="G4336"\w* \w y|strong="G2532"\w* \w dijeron|strong="G3004"\w*: «\w Tú|strong="G4771"\w*, \w Señor|strong="G2962"\w*, \w que|strong="G3588"\w* conoces \w el|strong="G3588"\w* corazón \w de|strong="G1537"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* hombres, muestra \w a|strong="G1537"\w* \w cuál|strong="G3739"\w* \w de|strong="G1537"\w* \w estos|strong="G3778"\w* \w dos|strong="G1417"\w* has elegido  
