\c 1
\p
\v 1 \w El|strong="G3588"\w* \w primer|strong="G4413"\w* libro \w que|strong="G3588"\w* escribí, \w Teófilo|strong="G2321"\w*, trataba \w de|strong="G4012"\w* \w todo|strong="G3956"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \w Jesús|strong="G2424"\w* empezó a \w hacer|strong="G4160"\w* \w y|strong="G2532"\w* a \w enseñar|strong="G1321"\w*,  
