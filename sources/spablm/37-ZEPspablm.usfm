\c 1
\p
\v 1 \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé \w que|strong="H1697"\w* llegó \w a|strong="H3068"\w* \w Sofonías|strong="H6846"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Cushi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amarías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ezequías, en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amón, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.   
\p
\v 2 «Arrasaré \w con|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* hay \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra», \w dice|strong="H5002"\w* Yahvé.  
\v 3 «Arrasaré \w al|strong="H5921"\w* hombre \w y|strong="H5921"\w* \w al|strong="H5921"\w* animal. Arrasaré \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w los|strong="H5921"\w* peces \w del|strong="H5921"\w* \w mar|strong="H3220"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* tropiezos \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* malvados. Eliminaré \w al|strong="H5921"\w* hombre \w de|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra», \w dice|strong="H5002"\w* Yahvé.  
\v 4 «\w Extenderé|strong="H5186"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H4480"\w* Jerusalén. Extirparé \w de|strong="H4480"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w el|strong="H5921"\w* resto \w de|strong="H4480"\w* \w Baal|strong="H1168"\w*, \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H4480"\w* \w los|strong="H3427"\w* ministros idólatras \w junto|strong="H5921"\w* \w con|strong="H5973"\w* \w los|strong="H3427"\w* \w sacerdotes|strong="H3548"\w*,  
\v 5 \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w adoran|strong="H7812"\w* \w al|strong="H5921"\w* \w ejército|strong="H6635"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* azoteas, \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w adoran|strong="H7812"\w* \w y|strong="H5921"\w* juran \w por|strong="H5921"\w* Yahvé \w y|strong="H5921"\w* también juran \w por|strong="H5921"\w* Malcam,  
\v 6 \w a|strong="H3068"\w* los \w que|strong="H3808"\w* \w se|strong="H3808"\w* han apartado de seguir \w a|strong="H3068"\w* Yahvé, y \w a|strong="H3068"\w* los \w que|strong="H3808"\w* \w no|strong="H3808"\w* han buscado \w a|strong="H3068"\w* Yahvé \w ni|strong="H3808"\w* han preguntado por él».   
\p
\v 7 ¡\w Callad|strong="H2013"\w* \w ante|strong="H6440"\w* \w la|strong="H3588"\w* \w presencia|strong="H6440"\w* del \w Señor|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* Yahvé está \w cerca|strong="H7138"\w*! \w Pues|strong="H3588"\w* Yahvé ha preparado un \w sacrificio|strong="H2077"\w* \w y|strong="H3588"\w* ha consagrado \w a|strong="H3068"\w* sus invitados.  
\v 8 «\w El|strong="H5921"\w* \w día|strong="H3117"\w* \w del|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w de|strong="H5921"\w* Yahvé castigaré \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w príncipes|strong="H8269"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* visten \w con|strong="H5921"\w* ropas \w extranjeras|strong="H5237"\w*.  
\v 9 \w Ese|strong="H1931"\w* \w día|strong="H3117"\w* castigaré \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H1931"\w* saltan \w el|strong="H1931"\w* \w umbral|strong="H4670"\w*, \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H1931"\w* llenan \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* señor \w con|strong="H5921"\w* \w violencia|strong="H2555"\w* \w y|strong="H5921"\w* \w engaño|strong="H4820"\w*».   
\p
\v 10 “\w En|strong="H4480"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* —\w dice|strong="H5002"\w* Yahvé—, \w habrá|strong="H1961"\w* gritos \w de|strong="H4480"\w* auxilio \w desde|strong="H4480"\w* \w la|strong="H1931"\w* \w Puerta|strong="H8179"\w* \w de|strong="H4480"\w* \w los|strong="H1931"\w* Peces, un lamento \w desde|strong="H4480"\w* \w el|strong="H1931"\w* \w segundo|strong="H4932"\w* distrito y un \w gran|strong="H1419"\w* \w estruendo|strong="H6963"\w* \w desde|strong="H4480"\w* las colinas.  
\v 11 ¡Gemid, \w moradores|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* Hondonada, \w porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* mercaderes ha sido aniquilado! \w Todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w estaban|strong="H3427"\w* cargados \w de|strong="H3588"\w* \w plata|strong="H3701"\w* han sido eliminados.  
\v 12 \w Sucederá|strong="H1961"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w que|strong="H1931"\w* registraré \w a|strong="H3068"\w* Jerusalén \w con|strong="H5921"\w* \w lámparas|strong="H5216"\w*, \w y|strong="H5921"\w* castigaré \w a|strong="H3068"\w* \w los|strong="H5921"\w* hombres \w que|strong="H1931"\w* reposan \w sobre|strong="H5921"\w* \w sus|strong="H1931"\w* heces, \w los|strong="H5921"\w* cuales dicen \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w corazón|strong="H3824"\w*: ‘Yahvé \w no|strong="H3808"\w* \w hará|strong="H1961"\w* \w ni|strong="H3808"\w* \w bien|strong="H3190"\w* \w ni|strong="H3808"\w* \w mal|strong="H7489"\w*’.  
\v 13 Sus \w riquezas|strong="H2428"\w* \w se|strong="H1961"\w* convertirán en botín y sus \w casas|strong="H1004"\w* en desolación. Construirán \w casas|strong="H1004"\w*, pero \w no|strong="H3808"\w* las \w habitarán|strong="H3427"\w*; \w plantarán|strong="H5193"\w* \w viñas|strong="H3754"\w*, pero \w no|strong="H3808"\w* \w beberán|strong="H8354"\w* su \w vino|strong="H3196"\w*”.   
\p
\v 14 El \w gran|strong="H1419"\w* \w día|strong="H3117"\w* de Yahvé \w está|strong="H8033"\w* \w cerca|strong="H7138"\w*. \w Está|strong="H8033"\w* \w cerca|strong="H7138"\w* y llega con prontitud. ¡\w Amarga|strong="H4751"\w* es la \w voz|strong="H6963"\w* del \w día|strong="H3117"\w* de Yahvé! \w Allí|strong="H8033"\w* \w hasta|strong="H3117"\w* el \w valiente|strong="H1368"\w* \w grita|strong="H6963"\w* con angustia.  
\v 15 \w Ese|strong="H1931"\w* \w día|strong="H3117"\w* \w es|strong="H1931"\w* un \w día|strong="H3117"\w* de ira, \w día|strong="H3117"\w* de \w angustia|strong="H6869"\w* y de \w tribulación|strong="H6869"\w*, \w día|strong="H3117"\w* de devastación y de ruina, \w día|strong="H3117"\w* de \w tinieblas|strong="H2822"\w* y de \w oscuridad|strong="H6205"\w*, \w día|strong="H3117"\w* de \w nublado|strong="H6051"\w* y de densos nubarrones,  
\v 16 \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w trompeta|strong="H7782"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w clamor|strong="H8643"\w* \w contra|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w las|strong="H5921"\w* altas almenas.  
\v 17 «Traeré tal \w angustia|strong="H6887"\w* sobre \w los|strong="H3588"\w* hombres \w que|strong="H3588"\w* andarán \w como|strong="H3588"\w* \w ciegos|strong="H5787"\w* \w por|strong="H3588"\w* haber \w pecado|strong="H2398"\w* contra Yahvé. \w Su|strong="H3588"\w* \w sangre|strong="H1818"\w* será derramada \w como|strong="H3588"\w* \w polvo|strong="H6083"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* carne \w como|strong="H3588"\w* estiércol.  
\v 18 \w Ni|strong="H3808"\w* \w su|strong="H3588"\w* \w plata|strong="H3701"\w* \w ni|strong="H3808"\w* \w su|strong="H3588"\w* \w oro|strong="H2091"\w* \w podrán|strong="H3201"\w* librarlos \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H1571"\w* ira \w de|strong="H3588"\w* Yahvé, \w pues|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H1571"\w* tierra \w será|strong="H3808"\w* devorada \w por|strong="H3588"\w* \w el|strong="H3588"\w* fuego \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w celo|strong="H7068"\w*; \w porque|strong="H3588"\w* \w él|strong="H3588"\w* exterminará \w por|strong="H3588"\w* completo \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H1571"\w* tierra».   
\c 2
\p
\v 1 Reuníos, \w sí|strong="H3808"\w*, reuníos, \w nación|strong="H1471"\w* \w sin|strong="H3808"\w* pudor,  
\v 2 \w antes|strong="H2962"\w* \w que|strong="H3808"\w* \w el|strong="H5921"\w* decreto surta efecto \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w pase|strong="H5674"\w* \w como|strong="H5921"\w* \w el|strong="H5921"\w* tamo; \w antes|strong="H2962"\w* \w que|strong="H3808"\w* venga \w sobre|strong="H5921"\w* vosotros \w el|strong="H5921"\w* ardor \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ira|strong="H2740"\w* \w de|strong="H5921"\w* Yahvé, \w antes|strong="H2962"\w* \w que|strong="H3808"\w* venga \w sobre|strong="H5921"\w* vosotros \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w del|strong="H5921"\w* \w furor|strong="H2740"\w* \w de|strong="H5921"\w* Yahvé.  
\v 3 \w Buscad|strong="H1245"\w* \w a|strong="H3068"\w* Yahvé, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* humildes de \w la|strong="H3605"\w* tierra, \w los|strong="H3605"\w* \w que|strong="H3117"\w* habéis puesto por \w obra|strong="H6466"\w* sus decretos. \w Buscad|strong="H1245"\w* \w la|strong="H3605"\w* \w justicia|strong="H6664"\w*, \w buscad|strong="H1245"\w* \w la|strong="H3605"\w* \w mansedumbre|strong="H6038"\w*; quizá hallaréis refugio en \w el|strong="H3605"\w* \w día|strong="H3117"\w* de \w la|strong="H3605"\w* ira de Yahvé.  
\v 4 \w Porque|strong="H3588"\w* \w Gaza|strong="H5804"\w* \w será|strong="H1961"\w* \w desamparada|strong="H5800"\w* \w y|strong="H3588"\w* Ascalón \w asolada|strong="H8077"\w*; \w saquearán|strong="H1644"\w* \w a|strong="H3068"\w* Asdod al mediodía \w y|strong="H3588"\w* \w Ecrón|strong="H6138"\w* \w será|strong="H1961"\w* \w desarraigada|strong="H6131"\w*.  
\v 5 ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* costa \w del|strong="H5921"\w* \w mar|strong="H3220"\w*, \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w nación|strong="H1471"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* quereteos! \w La|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w es|strong="H1697"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w Canaán|strong="H3667"\w*, tierra \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w*: «\w Te|strong="H5921"\w* destruiré \w hasta|strong="H5921"\w* \w que|strong="H5921"\w* \w no|strong="H5921"\w* \w quede|strong="H3427"\w* \w morador|strong="H3427"\w* alguno».  
\v 6 \w Y|strong="H3068"\w* la costa del \w mar|strong="H3220"\w* \w será|strong="H1961"\w* de pastizales, con chozas \w para|strong="H1961"\w* \w pastores|strong="H7462"\w* y corrales \w para|strong="H1961"\w* \w ovejas|strong="H6629"\w*.  
\v 7 \w La|strong="H5921"\w* costa \w será|strong="H1961"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w resto|strong="H7611"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*; allí apacentarán. \w En|strong="H5921"\w* \w las|strong="H5921"\w* \w casas|strong="H1004"\w* \w de|strong="H5921"\w* Ascalón \w se|strong="H1961"\w* tumbarán \w al|strong="H5921"\w* atardecer, \w porque|strong="H3588"\w* Yahvé, \w su|strong="H3588"\w* \w Dios|strong="H3068"\w*, \w los|strong="H5921"\w* \w visitará|strong="H6485"\w* \w y|strong="H3588"\w* restaurará \w su|strong="H3588"\w* \w suerte|strong="H2256"\w*.  
\v 8 «He \w oído|strong="H8085"\w* \w los|strong="H1121"\w* ultrajes \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w y|strong="H5921"\w* \w los|strong="H1121"\w* insultos \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, \w con|strong="H5921"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* han afrentado \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* han \w engrandecido|strong="H1431"\w* \w contra|strong="H5921"\w* su territorio.  
\v 9 \w Por|strong="H3588"\w* \w tanto|strong="H3651"\w*, \w vivo|strong="H2416"\w* \w yo|strong="H3588"\w* —\w dice|strong="H5002"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*—, \w que|strong="H3588"\w* \w Moab|strong="H4124"\w* \w será|strong="H1961"\w* \w como|strong="H3588"\w* \w Sodoma|strong="H5467"\w*, \w y|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Amón \w como|strong="H3588"\w* \w Gomorra|strong="H6017"\w*; \w campo|strong="H4476"\w* \w de|strong="H3588"\w* \w ortigas|strong="H2738"\w*, mina \w de|strong="H3588"\w* \w sal|strong="H4417"\w* \w y|strong="H3588"\w* desolación \w perpetua|strong="H5769"\w*. \w El|strong="H3588"\w* \w resto|strong="H3499"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* \w los|strong="H1121"\w* saqueará, \w y|strong="H3588"\w* \w los|strong="H1121"\w* supervivientes \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \w nación|strong="H1471"\w* \w los|strong="H1121"\w* \w poseerán|strong="H5157"\w*».  
\v 10 \w Esto|strong="H2063"\w* \w les|strong="H1992"\w* sucederá \w por|strong="H5921"\w* \w su|strong="H1992"\w* \w soberbia|strong="H1347"\w*, \w porque|strong="H3588"\w* han ultrajado \w y|strong="H3588"\w* \w se|strong="H5921"\w* han \w engrandecido|strong="H1431"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w Ejércitos|strong="H6635"\w*.  
\v 11 Temible \w se|strong="H5921"\w* mostrará Yahvé \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w porque|strong="H3588"\w* hará desfallecer \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* dioses \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra; \w y|strong="H3588"\w* \w lo|strong="H5921"\w* adorarán, \w cada|strong="H3605"\w* uno \w desde|strong="H5921"\w* \w su|strong="H3588"\w* \w lugar|strong="H4725"\w*, \w todas|strong="H3605"\w* \w las|strong="H5921"\w* costas \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.   
\p
\v 12 «\w También|strong="H1571"\w* vosotros, \w los|strong="H1992"\w* etíopes, seréis \w muertos|strong="H2491"\w* por mi \w espada|strong="H2719"\w*».   
\p
\v 13 \w Extenderá|strong="H5186"\w* su \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w norte|strong="H6828"\w*, destruirá \w a|strong="H3068"\w* Asiria \w y|strong="H5921"\w* convertirá \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w* \w en|strong="H5921"\w* un \w desierto|strong="H4057"\w*, \w en|strong="H5921"\w* una tierra árida.  
\v 14 \w En|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w ella|strong="H3605"\w* se echarán \w los|strong="H3605"\w* \w rebaños|strong="H5739"\w* \w y|strong="H1571"\w* \w todas|strong="H3605"\w* las \w bestias|strong="H2416"\w* del campo. \w El|strong="H3588"\w* pelícano \w y|strong="H1571"\w* \w el|strong="H3588"\w* erizo se alojarán \w en|strong="H8432"\w* sus capiteles; \w su|strong="H3588"\w* \w voz|strong="H6963"\w* resonará \w en|strong="H8432"\w* las \w ventanas|strong="H2474"\w*. Habrá desolación \w en|strong="H8432"\w* \w los|strong="H3605"\w* umbrales, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* maderamen \w de|strong="H3588"\w* cedro quedará al descubierto.  
\v 15 \w Esta|strong="H2063"\w* \w es|strong="H1961"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w alegre|strong="H5947"\w* \w que|strong="H5921"\w* \w vivía|strong="H3427"\w* segura, \w la|strong="H5921"\w* \w que|strong="H5921"\w* decía \w en|strong="H5921"\w* su \w corazón|strong="H3824"\w*: «Yo, \w y|strong="H5921"\w* \w nadie|strong="H3605"\w* \w más|strong="H5750"\w*». ¡\w Cómo|strong="H1961"\w* ha quedado hecha una desolación, un cubil \w de|strong="H5921"\w* fieras! \w Todo|strong="H3605"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w pase|strong="H5674"\w* \w por|strong="H5921"\w* \w ella|strong="H5921"\w* \w silbará|strong="H8319"\w* \w y|strong="H5921"\w* sacudirá su \w mano|strong="H3027"\w*.   
\c 3
\p
\v 1 ¡\w Ay|strong="H1945"\w* de la \w ciudad|strong="H5892"\w* rebelde, manchada y \w opresora|strong="H3238"\w*!  
\v 2 \w No|strong="H3808"\w* \w escuchó|strong="H8085"\w* la \w voz|strong="H6963"\w* \w ni|strong="H3808"\w* aceptó la \w corrección|strong="H4148"\w*. \w No|strong="H3808"\w* confió en Yahvé; \w no|strong="H3808"\w* \w se|strong="H3808"\w* acercó \w a|strong="H3068"\w* su \w Dios|strong="H3068"\w*.   
\p
\v 3 Sus \w príncipes|strong="H8269"\w* en \w medio|strong="H7130"\w* \w de|strong="H8269"\w* ella \w son|strong="H3808"\w* leones rugientes; sus \w jueces|strong="H8199"\w* \w son|strong="H3808"\w* \w lobos|strong="H2061"\w* nocturnos \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w dejan|strong="H1633"\w* \w ni|strong="H3808"\w* un hueso para la \w mañana|strong="H1242"\w*.  
\v 4 Sus \w profetas|strong="H5030"\w* son insolentes y traidores; sus \w sacerdotes|strong="H3548"\w* \w profanaron|strong="H2490"\w* \w el|strong="H5030"\w* \w santuario|strong="H6944"\w* y \w violentaron|strong="H2554"\w* la \w ley|strong="H8451"\w*.  
\v 5 Yahvé es \w justo|strong="H6662"\w* en \w medio|strong="H7130"\w* \w de|strong="H5414"\w* ella; \w no|strong="H3808"\w* cometerá \w iniquidad|strong="H5766"\w*. Cada \w mañana|strong="H1242"\w* saca \w a|strong="H3068"\w* la luz su \w juicio|strong="H4941"\w*, \w no|strong="H3808"\w* falta \w nunca|strong="H3808"\w*; pero \w el|strong="H6213"\w* perverso \w no|strong="H3808"\w* \w conoce|strong="H3045"\w* la vergüenza.   
\p
\v 6 “He exterminado \w naciones|strong="H1471"\w*; sus torreones \w están|strong="H3427"\w* desolados. He dejado \w desiertas|strong="H2717"\w* sus \w calles|strong="H2351"\w* \w hasta|strong="H1097"\w* \w no|strong="H1097"\w* quedar quien \w pase|strong="H5674"\w* por ellas; sus \w ciudades|strong="H5892"\w* \w están|strong="H3427"\w* \w asoladas|strong="H8074"\w* \w hasta|strong="H1097"\w* \w no|strong="H1097"\w* quedar nadie, \w hasta|strong="H1097"\w* \w no|strong="H1097"\w* quedar \w ni|strong="H1097"\w* un \w morador|strong="H3427"\w*.  
\v 7 Dije: ‘\w Ciertamente|strong="H6485"\w* \w me|strong="H5921"\w* \w temerás|strong="H3372"\w* \w y|strong="H5921"\w* aceptarás \w la|strong="H5921"\w* \w corrección|strong="H4148"\w*’, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* fuera destruida su morada \w según|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* yo había ordenado \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*. Pero \w ellos|strong="H5921"\w* \w se|strong="H5921"\w* apresuraron \w a|strong="H3068"\w* corromper \w todas|strong="H3605"\w* sus acciones.   
\p
\v 8 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w esperadme|strong="H2442"\w* —\w dice|strong="H5002"\w* Yahvé— \w hasta|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w en|strong="H5921"\w* \w que|strong="H3588"\w* \w me|strong="H5921"\w* levante \w para|strong="H5921"\w* \w el|strong="H5921"\w* botín; \w porque|strong="H3588"\w* \w mi|strong="H5921"\w* determinación \w es|strong="H3588"\w* reunir \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w y|strong="H3588"\w* \w juntar|strong="H6908"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w para|strong="H5921"\w* derramar \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w mi|strong="H5921"\w* indignación, \w todo|strong="H3605"\w* \w el|strong="H5921"\w* ardor \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w ira|strong="H2740"\w*; \w pues|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra será devorada \w por|strong="H5921"\w* \w el|strong="H5921"\w* fuego \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w celo|strong="H7068"\w*.   
\p
\v 9 \w Entonces|strong="H3588"\w* daré \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* \w labios|strong="H8193"\w* puros, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w invoquen|strong="H7121"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* Yahvé \w y|strong="H3588"\w* le sirvan \w de|strong="H3588"\w* común acuerdo.  
\v 10 Desde más allá de los ríos de \w Etiopía|strong="H3568"\w*, mis adoradores, los hijos de mis dispersos, traerán mi \w ofrenda|strong="H4503"\w*.  
\v 11 \w En|strong="H3588"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w no|strong="H3808"\w* serás avergonzada \w por|strong="H3588"\w* \w ninguna|strong="H3605"\w* \w de|strong="H3588"\w* las \w obras|strong="H5949"\w* \w con|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* rebelaste contra mí; \w porque|strong="H3588"\w* \w entonces|strong="H3117"\w* \w quitaré|strong="H5493"\w* \w de|strong="H3588"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* ti \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w se|strong="H1931"\w* regocijan \w en|strong="H3588"\w* tu \w soberbia|strong="H1346"\w*, \w y|strong="H3588"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w te|strong="H3588"\w* ensoberbecerás \w en|strong="H3588"\w* mi \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*.  
\v 12 \w Y|strong="H3068"\w* dejaré en \w medio|strong="H7130"\w* \w de|strong="H5971"\w* vosotros un \w pueblo|strong="H5971"\w* \w humilde|strong="H6041"\w* y \w pobre|strong="H1800"\w*, el cual confiará en el \w nombre|strong="H8034"\w* \w de|strong="H5971"\w* Yahvé.  
\v 13 \w El|strong="H3588"\w* \w resto|strong="H7611"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* cometerá injusticia \w ni|strong="H3808"\w* dirá \w mentira|strong="H3577"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* \w hallará|strong="H4672"\w* \w en|strong="H3588"\w* \w su|strong="H1992"\w* \w boca|strong="H6310"\w* \w lengua|strong="H3956"\w* \w engañosa|strong="H8649"\w*; \w porque|strong="H3588"\w* \w ellos|strong="H1992"\w* apacentarán \w y|strong="H3588"\w* descansarán, \w y|strong="H3588"\w* \w no|strong="H3808"\w* habrá \w quien|strong="H6213"\w* \w los|strong="H1992"\w* atemorice”.   
\p
\v 14 ¡\w Canta|strong="H7442"\w*, \w hija|strong="H1323"\w* de \w Sión|strong="H6726"\w*! ¡Da voces de júbilo, \w Israel|strong="H3478"\w*! ¡\w Alégrate|strong="H8055"\w* y regocíjate de \w todo|strong="H3605"\w* \w corazón|strong="H3820"\w*, \w hija|strong="H1323"\w* de Jerusalén!  
\v 15 Yahvé \w ha|strong="H3808"\w* retirado las sentencias \w contra|strong="H3478"\w* ti y \w ha|strong="H3808"\w* echado fuera \w a|strong="H3068"\w* tus enemigos. Yahvé, \w Rey|strong="H4428"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*, está \w en|strong="H5493"\w* \w medio|strong="H7130"\w* \w de|strong="H5750"\w* ti; ya \w no|strong="H3808"\w* \w temerás|strong="H3372"\w* \w mal|strong="H7451"\w* \w alguno|strong="H5750"\w*.  
\v 16 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* dirá \w a|strong="H3068"\w* Jerusalén: «¡No \w temas|strong="H3372"\w*, \w Sión|strong="H6726"\w*! ¡No \w se|strong="H1931"\w* debiliten tus \w manos|strong="H3027"\w*!».  
\v 17 Yahvé, tu \w Dios|strong="H3068"\w*, \w está|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*: ¡un \w poderoso|strong="H1368"\w* \w que|strong="H5921"\w* \w salvará|strong="H3467"\w*! \w Se|strong="H5921"\w* regocijará \w por|strong="H5921"\w* \w ti|strong="H5921"\w* \w con|strong="H5921"\w* \w alegría|strong="H8057"\w*, \w te|strong="H5921"\w* renovará \w en|strong="H5921"\w* su amor, \w se|strong="H5921"\w* regocijará \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w con|strong="H5921"\w* cánticos.  
\v 18 «Reuniré \w a|strong="H3068"\w* \w los|strong="H5921"\w* afligidos \w por|strong="H5921"\w* \w las|strong="H5921"\w* fiestas solemnes, \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H4480"\w* \w fueron|strong="H1961"\w* \w tuyos|strong="H4480"\w*, \w para|strong="H5921"\w* quienes \w el|strong="H5921"\w* \w oprobio|strong="H2781"\w* \w de|strong="H4480"\w* \w ella|strong="H4480"\w* \w era|strong="H1961"\w* una carga.  
\v 19 He \w aquí|strong="H2005"\w*, en \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w yo|strong="H6213"\w* apremiaré \w a|strong="H3068"\w* \w todos|strong="H3605"\w* tus \w opresores|strong="H6031"\w*; \w salvaré|strong="H3467"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* oveja coja y \w recogeré|strong="H6908"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* descarriada; y les daré renombre y \w fama|strong="H8034"\w* en \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra \w donde|strong="H8034"\w* fueron avergonzados.  
\v 20 \w En|strong="H3588"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w yo|strong="H3588"\w* \w os|strong="H5869"\w* traeré, \w en|strong="H3588"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w os|strong="H5869"\w* reuniré; \w pues|strong="H3588"\w* \w os|strong="H5869"\w* \w daré|strong="H5414"\w* renombre \w y|strong="H3588"\w* \w fama|strong="H8034"\w* \w entre|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* tierra, \w cuando|strong="H3588"\w* \w haga|strong="H5414"\w* \w volver|strong="H7725"\w* \w a|strong="H3068"\w* vuestros cautivos ante vuestros \w ojos|strong="H5869"\w*», dice Yahvé.   