\v 31 \w Después|strong="H1961"\w* \w de|strong="H1121"\w* \w él|strong="H1931"\w* \w fue|strong="H1961"\w* \w Samgar|strong="H8044"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Anat, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w seiscientos|strong="H8337"\w* \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w con|strong="H1571"\w* una aguijada \w de|strong="H1121"\w* \w bueyes|strong="H1241"\w*; \w y|strong="H1571"\w* \w él|strong="H1931"\w* \w también|strong="H1571"\w* libró \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.   
\c 4
\p
\v 1 Después \w de|strong="H1121"\w* la \w muerte|strong="H4191"\w* \w de|strong="H1121"\w* Aod, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* volvieron \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H1121"\w* Yahvé.  
\v 2 \w Y|strong="H3068"\w* Yahvé \w los|strong="H3427"\w* \w vendió|strong="H4376"\w* en \w mano|strong="H3027"\w* \w de|strong="H8269"\w* \w Jabín|strong="H2985"\w* \w rey|strong="H4428"\w* \w de|strong="H8269"\w* \w Canaán|strong="H3667"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w reinaba|strong="H4428"\w* en Hazor; y \w el|strong="H1931"\w* \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* \w su|strong="H1931"\w* \w ejército|strong="H6635"\w* \w se|strong="H1931"\w* llamaba \w Sísara|strong="H5516"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w habitaba|strong="H3427"\w* en Haroset-goim.  
\v 3 \w Entonces|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w clamaron|strong="H6817"\w* \w a|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* \w aquel|strong="H1931"\w* \w tenía|strong="H1931"\w* \w novecientos|strong="H8672"\w* \w carros|strong="H7393"\w* \w de|strong="H3588"\w* \w hierro|strong="H1270"\w*, \w y|strong="H3588"\w* \w había|strong="H3588"\w* oprimido \w con|strong="H3588"\w* crueldad \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w por|strong="H3588"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w*.  
\v 4 Gobernaba en \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* una mujer, \w Débora|strong="H1683"\w*, \w profetisa|strong="H5031"\w*, mujer \w de|strong="H6256"\w* Lapidot;  
\v 5 \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w se|strong="H1931"\w* sentaba \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w la|strong="H1931"\w* palmera \w de|strong="H8478"\w* \w Débora|strong="H1683"\w*, \w entre|strong="H8478"\w* \w Ramá|strong="H7414"\w* y Bet-el, \w en|strong="H8478"\w* \w el|strong="H1931"\w* \w monte|strong="H2022"\w* \w de|strong="H8478"\w* Efraín; y \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w* \w subían|strong="H5927"\w* \w a|strong="H3068"\w* \w ella|strong="H1931"\w* \w a|strong="H3068"\w* \w juicio|strong="H4941"\w*.  
\v 6 \w Y|strong="H3068"\w* ella \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* \w Barac|strong="H1301"\w* \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Abinoam, \w de|strong="H5973"\w* Cedes \w de|strong="H5973"\w* Neftalí, y \w le|strong="H5973"\w* dijo: “¿\w No|strong="H3808"\w* \w te|strong="H5973"\w* \w ha|strong="H3808"\w* \w mandado|strong="H6680"\w* Yahvé \w Dios|strong="H3068"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*, diciendo: «\w Ve|strong="H3212"\w*, junta \w a|strong="H3068"\w* tu gente \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w monte|strong="H2022"\w* \w Tabor|strong="H8396"\w*, y \w toma|strong="H3947"\w* \w contigo|strong="H5973"\w* \w diez|strong="H6235"\w* \w mil|strong="H6235"\w* \w hombres|strong="H1121"\w* \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Neftalí y \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Zabulón|strong="H2074"\w*;  
\v 7 y yo atraeré hacia ti al \w torrente|strong="H5158"\w* \w de|strong="H8269"\w* Cisón \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w*, \w capitán|strong="H8269"\w* del \w ejército|strong="H6635"\w* \w de|strong="H8269"\w* \w Jabín|strong="H2985"\w*, con sus \w carros|strong="H7393"\w* y su \w multitud|strong="H1995"\w*, y lo \w entregaré|strong="H5414"\w* en tu \w mano|strong="H3027"\w*»?”.   
\p
\v 8 \w Barac|strong="H1301"\w* \w le|strong="H5973"\w* respondió: «\w Si|strong="H3808"\w* tú \w fueres|strong="H3212"\w* \w conmigo|strong="H5973"\w*, yo \w iré|strong="H3212"\w*; pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w fueres|strong="H3212"\w* \w conmigo|strong="H5973"\w*, \w no|strong="H3808"\w* \w iré|strong="H3212"\w*».   
\p
\v 9 \w Ella|strong="H5921"\w* dijo: «\w Iré|strong="H3212"\w* \w contigo|strong="H5973"\w*; \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w será|strong="H1961"\w* tuya \w la|strong="H5921"\w* \w gloria|strong="H8597"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* jornada \w que|strong="H3588"\w* emprendes, \w porque|strong="H3588"\w* \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* mujer \w venderá|strong="H4376"\w* Yahvé \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w*». \w Y|strong="H3068"\w* \w levantándose|strong="H6965"\w* \w Débora|strong="H1683"\w*, \w fue|strong="H1961"\w* \w con|strong="H5973"\w* \w Barac|strong="H1301"\w* \w a|strong="H3068"\w* Cedes.   
\p
\v 10 \w Y|strong="H3068"\w* \w juntó|strong="H5973"\w* \w Barac|strong="H1301"\w* \w a|strong="H3068"\w* \w Zabulón|strong="H2074"\w* y \w a|strong="H3068"\w* Neftalí \w en|strong="H5973"\w* Cedes, y \w subió|strong="H5927"\w* \w con|strong="H5973"\w* \w diez|strong="H6235"\w* \w mil|strong="H6235"\w* hombres \w a|strong="H3068"\w* su mando; y \w Débora|strong="H1683"\w* \w subió|strong="H5927"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*.  
\v 11 \w Y|strong="H3068"\w* \w Heber|strong="H2268"\w* ceneo, \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* Hobab \w suegro|strong="H2859"\w* \w de|strong="H5704"\w* \w Moisés|strong="H4872"\w*, se había apartado \w de|strong="H5704"\w* \w los|strong="H1121"\w* ceneos, \w y|strong="H5704"\w* había plantado sus tiendas \w hasta|strong="H5704"\w* la encina \w de|strong="H5704"\w* Zaanaim, \w que|strong="H5704"\w* está junto \w a|strong="H3068"\w* Cedes.  
\v 12 Dieron \w aviso|strong="H5046"\w* \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w* \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w Barac|strong="H1301"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Abinoam \w había|strong="H3588"\w* \w subido|strong="H5927"\w* al \w monte|strong="H2022"\w* \w Tabor|strong="H8396"\w*.  
