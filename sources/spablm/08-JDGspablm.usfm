\p
\v 14 \w Entonces|strong="H3117"\w* \w Débora|strong="H1683"\w* dijo \w a|strong="H3068"\w* \w Barac|strong="H1301"\w*: «¡\w Levántate|strong="H6965"\w*!, \w porque|strong="H3588"\w* \w este|strong="H2088"\w* \w es|strong="H2088"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w en|strong="H3588"\w* \w que|strong="H3588"\w* Yahvé \w ha|strong="H3808"\w* \w entregado|strong="H5414"\w* \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w* \w en|strong="H3588"\w* tu \w mano|strong="H3027"\w*. ¿\w No|strong="H3808"\w* \w ha|strong="H3808"\w* \w salido|strong="H3318"\w* Yahvé \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti?». \w Y|strong="H3068"\w* \w Barac|strong="H1301"\w* \w descendió|strong="H3381"\w* del \w monte|strong="H2022"\w* \w Tabor|strong="H8396"\w*, \w y|strong="H3588"\w* \w diez|strong="H6235"\w* \w mil|strong="H6235"\w* hombres \w en|strong="H3588"\w* pos \w de|strong="H3588"\w* \w él|strong="H3588"\w*.  
\v 15 \w Y|strong="H3068"\w* Yahvé desbarató \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w*, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w carros|strong="H7393"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* su \w ejército|strong="H4264"\w*, \w a|strong="H3068"\w* filo \w de|strong="H5921"\w* \w espada|strong="H2719"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Barac|strong="H1301"\w*; \w y|strong="H5921"\w* \w Sísara|strong="H5516"\w* \w descendió|strong="H3381"\w* \w del|strong="H5921"\w* \w carro|strong="H4818"\w*, \w y|strong="H5921"\w* \w huyó|strong="H5127"\w* \w a|strong="H3068"\w* \w pie|strong="H7272"\w*.  
\v 16 \w Mas|strong="H5704"\w* \w Barac|strong="H1301"\w* \w siguió|strong="H7291"\w* \w los|strong="H3605"\w* \w carros|strong="H7393"\w* \w y|strong="H5704"\w* \w el|strong="H3605"\w* \w ejército|strong="H4264"\w* \w hasta|strong="H5704"\w* Haroset-goim, \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ejército|strong="H4264"\w* \w de|strong="H5704"\w* \w Sísara|strong="H5516"\w* \w cayó|strong="H5307"\w* \w a|strong="H3068"\w* filo \w de|strong="H5704"\w* \w espada|strong="H2719"\w*, \w hasta|strong="H5704"\w* \w no|strong="H3808"\w* \w quedar|strong="H7604"\w* \w ni|strong="H3808"\w* uno.   
\p
\v 17 \w Y|strong="H3068"\w* \w Sísara|strong="H5516"\w* \w huyó|strong="H5127"\w* \w a|strong="H3068"\w* \w pie|strong="H7272"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* tienda \w de|strong="H3588"\w* \w Jael|strong="H3278"\w* mujer \w de|strong="H3588"\w* \w Heber|strong="H2268"\w* ceneo; \w porque|strong="H3588"\w* \w había|strong="H3588"\w* \w paz|strong="H7965"\w* \w entre|strong="H3588"\w* \w Jabín|strong="H2985"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Hazor \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Heber|strong="H2268"\w* ceneo.  
\v 18 \w Y|strong="H3068"\w* \w saliendo|strong="H3318"\w* \w Jael|strong="H3278"\w* \w a|strong="H3068"\w* recibir \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w*, le dijo: «\w Ven|strong="H5493"\w*, señor mío, \w ven|strong="H5493"\w* \w a|strong="H3068"\w* mí, no tengas \w temor|strong="H3372"\w*». \w Y|strong="H3068"\w* él vino \w a|strong="H3068"\w* ella \w a|strong="H3068"\w* la tienda, y ella lo \w cubrió|strong="H3680"\w* con una manta.   
\p
\v 19 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* le dijo: «\w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w me|strong="H3588"\w* des \w de|strong="H3588"\w* \w beber|strong="H8248"\w* un \w poco|strong="H4592"\w* \w de|strong="H3588"\w* \w agua|strong="H4325"\w*, \w pues|strong="H3588"\w* tengo \w sed|strong="H6770"\w*». \w Y|strong="H3068"\w* ella \w abrió|strong="H6605"\w* un odre \w de|strong="H3588"\w* \w leche|strong="H2461"\w* \w y|strong="H3588"\w* le dio \w de|strong="H3588"\w* \w beber|strong="H8248"\w*, \w y|strong="H3588"\w* le volvió \w a|strong="H3068"\w* \w cubrir|strong="H3680"\w*.   
\p
\v 20 \w Y|strong="H3068"\w* él le dijo: “Estáte \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* de la tienda, y \w si|strong="H1961"\w* alguien \w viniere|strong="H1961"\w* y te \w preguntare|strong="H7592"\w*, diciendo: «¿\w Hay|strong="H3426"\w* alguien \w aquí|strong="H6311"\w*?», \w tú|strong="H3426"\w* responderás \w que|strong="H1961"\w* \w no|strong="H1961"\w*”.   
