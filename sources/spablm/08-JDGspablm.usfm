\v 5 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Jair|strong="H2971"\w*, y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* Camón.   
\p
\v 6 Pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* volvieron \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H1121"\w* Yahvé, y \w sirvieron|strong="H5647"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* baales y \w a|strong="H3068"\w* las imágenes \w de|strong="H1121"\w* Astarot, \w a|strong="H3068"\w* \w los|strong="H1121"\w* dioses \w de|strong="H1121"\w* Siria, \w a|strong="H3068"\w* \w los|strong="H1121"\w* dioses \w de|strong="H1121"\w* \w Sidón|strong="H6721"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* dioses \w de|strong="H1121"\w* \w Moab|strong="H4124"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* dioses \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón y \w a|strong="H3068"\w* \w los|strong="H1121"\w* dioses \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*; y \w dejaron|strong="H5800"\w* \w a|strong="H3068"\w* Yahvé, y \w no|strong="H3808"\w* \w le|strong="H3254"\w* \w sirvieron|strong="H5647"\w*.  
\v 7 \w Y|strong="H3068"\w* se encendió la ira \w de|strong="H1121"\w* Yahvé \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w*, y \w los|strong="H1121"\w* entregó en \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* y en \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón;  
