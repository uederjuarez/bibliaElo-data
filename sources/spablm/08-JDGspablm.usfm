\c 19
\p
\v 1 En \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w*, \w cuando|strong="H3117"\w* \w no|strong="H1961"\w* \w había|strong="H1961"\w* \w rey|strong="H4428"\w* en \w Israel|strong="H3478"\w*, \w hubo|strong="H1961"\w* un \w levita|strong="H3881"\w* \w que|strong="H3117"\w* moraba \w como|strong="H1961"\w* forastero en la parte más remota del \w monte|strong="H2022"\w* de Efraín, \w el|strong="H1992"\w* cual \w tomó|strong="H3947"\w* \w para|strong="H1961"\w* \w sí|strong="H1961"\w* una \w concubina|strong="H6370"\w* de Belén de \w Judá|strong="H3063"\w*.  
\v 2 \w Y|strong="H3068"\w* su \w concubina|strong="H6370"\w* \w le|strong="H5921"\w* \w fue|strong="H1961"\w* infiel, \w y|strong="H5921"\w* \w se|strong="H1961"\w* \w fue|strong="H1961"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su padre, \w a|strong="H3068"\w* Belén \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w estuvo|strong="H1961"\w* \w allí|strong="H8033"\w* \w por|strong="H5921"\w* espacio \w de|strong="H5921"\w* cuatro \w meses|strong="H2320"\w*.  
\v 3 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* su marido \w y|strong="H5921"\w* \w fue|strong="H3212"\w* \w tras|strong="H5973"\w* \w ella|strong="H5921"\w*, \w para|strong="H5921"\w* \w hablarle|strong="H1696"\w* \w al|strong="H5921"\w* \w corazón|strong="H3820"\w* \w y|strong="H5921"\w* \w volverla|strong="H7725"\w* \w consigo|strong="H5973"\w*, llevando \w consigo|strong="H5973"\w* \w a|strong="H3068"\w* su paje \w y|strong="H5921"\w* un \w par|strong="H6776"\w* \w de|strong="H5921"\w* \w asnos|strong="H2543"\w*; \w y|strong="H5921"\w* \w ella|strong="H5921"\w* \w le|strong="H5921"\w* introdujo \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su padre, \w y|strong="H5921"\w* cuando \w el|strong="H5921"\w* padre \w de|strong="H5921"\w* \w la|strong="H5921"\w* joven \w lo|strong="H5921"\w* \w vio|strong="H7200"\w*, \w se|strong="H5921"\w* alegró \w de|strong="H5921"\w* recibirle.  
\v 4 \w Y|strong="H3068"\w* lo \w retuvo|strong="H2388"\w* su \w suegro|strong="H2859"\w*, \w el|strong="H3427"\w* padre de la joven, y se \w quedó|strong="H3427"\w* con \w él|strong="H3427"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w*, comiendo y \w bebiendo|strong="H8354"\w*, y \w posaron|strong="H3885"\w* \w allí|strong="H8033"\w*.   
\p
\v 5 Al \w cuarto|strong="H7243"\w* \w día|strong="H3117"\w*, \w cuando|strong="H3117"\w* \w se|strong="H1961"\w* \w levantaron|strong="H6965"\w* de \w mañana|strong="H1242"\w*, \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* también el levita \w para|strong="H1961"\w* marcharse; y el padre de la joven dijo \w a|strong="H3068"\w* su \w yerno|strong="H2860"\w*: «\w Conforta|strong="H5582"\w* tu \w corazón|strong="H3820"\w* con un bocado de \w pan|strong="H3899"\w*, y \w después|strong="H1961"\w* os \w iréis|strong="H3212"\w*».  
\v 6 \w Y|strong="H3068"\w* se \w sentaron|strong="H3427"\w* \w ambos|strong="H8147"\w*, y comieron y \w bebieron|strong="H8354"\w* \w juntos|strong="H3162"\w*. \w Y|strong="H3068"\w* dijo \w el|strong="H3427"\w* padre de la joven al varón: «\w Yo|strong="H4994"\w* te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* quieras pasar aquí la noche, y se alegrará tu \w corazón|strong="H3820"\w*».  
\v 7 \w Y|strong="H3068"\w* se \w levantó|strong="H6965"\w* \w el|strong="H3885"\w* varón para irse, pero su \w suegro|strong="H2859"\w* le insistió, y \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* pasar \w allí|strong="H8033"\w* la noche.  
\v 8 \w Al|strong="H5704"\w* \w quinto|strong="H2549"\w* \w día|strong="H3117"\w* se levantó \w de|strong="H5704"\w* \w mañana|strong="H1242"\w* \w para|strong="H5704"\w* irse, \w y|strong="H5704"\w* \w le|strong="H1242"\w* dijo el padre \w de|strong="H5704"\w* la joven: «\w Conforta|strong="H5582"\w* tu \w corazón|strong="H3824"\w*, te \w ruego|strong="H4994"\w*, \w y|strong="H5704"\w* aguardad \w hasta|strong="H5704"\w* \w que|strong="H4994"\w* \w decline|strong="H5186"\w* el \w día|strong="H3117"\w*». \w Y|strong="H3068"\w* comieron \w ambos|strong="H8147"\w*.   
\p
\v 9 \w Luego|strong="H4994"\w* \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* \w el|strong="H1931"\w* varón para irse, \w él|strong="H1931"\w*, \w su|strong="H1931"\w* \w concubina|strong="H6370"\w* y \w su|strong="H1931"\w* paje. \w Entonces|strong="H3117"\w* \w su|strong="H1931"\w* \w suegro|strong="H2859"\w*, \w el|strong="H1931"\w* padre de \w la|strong="H1931"\w* joven, \w le|strong="H1931"\w* dijo: «He \w aquí|strong="H6311"\w*, \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w declina|strong="H7503"\w* para anochecer; os \w ruego|strong="H4994"\w* \w que|strong="H1931"\w* paséis \w aquí|strong="H6311"\w* \w la|strong="H1931"\w* noche. \w Mirad|strong="H2009"\w* \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* acaba; duerme \w aquí|strong="H6311"\w*, para \w que|strong="H1931"\w* \w se|strong="H1931"\w* alegre tu \w corazón|strong="H3824"\w*, y \w mañana|strong="H4279"\w* madrugaréis para vuestro \w camino|strong="H1870"\w* \w e|strong="H3068"\w* \w irás|strong="H3212"\w* \w a|strong="H3068"\w* tu casa».  
\v 10 \w Mas|strong="H5704"\w* \w el|strong="H1931"\w* varón \w no|strong="H3808"\w* quiso pasar \w la|strong="H1931"\w* noche, \w sino|strong="H3808"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* \w y|strong="H5704"\w* \w se|strong="H1931"\w* \w fue|strong="H3212"\w*, \w y|strong="H5704"\w* \w llegó|strong="H5704"\w* \w hasta|strong="H5704"\w* \w quedar|strong="H3885"\w* frente \w a|strong="H3068"\w* Jebús (\w que|strong="H1931"\w* \w es|strong="H1931"\w* Jerusalén), \w con|strong="H5973"\w* \w su|strong="H1931"\w* \w par|strong="H6776"\w* \w de|strong="H5973"\w* \w asnos|strong="H2543"\w* ensillados \w y|strong="H5704"\w* \w su|strong="H1931"\w* \w concubina|strong="H6370"\w*.   
\p
\v 11 \w Cuando|strong="H3117"\w* estaban \w cerca|strong="H5973"\w* \w de|strong="H5973"\w* \w Jebús|strong="H2983"\w*, \w el|strong="H5973"\w* \w día|strong="H3117"\w* había declinado \w mucho|strong="H3966"\w*; y dijo \w el|strong="H5973"\w* paje \w a|strong="H3068"\w* \w su|strong="H1992"\w* señor: «\w Ven|strong="H3212"\w*, \w te|strong="H5973"\w* \w ruego|strong="H4994"\w*, y nos apartaremos \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5973"\w* \w los|strong="H1992"\w* \w jebuseos|strong="H2983"\w* \w para|strong="H5973"\w* pasar \w en|strong="H5973"\w* ella \w la|strong="H2063"\w* noche».  
\v 12 \w Y|strong="H3068"\w* su señor le respondió: «\w No|strong="H3808"\w* nos apartaremos \w a|strong="H3068"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* \w extranjeros|strong="H1121"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* sea \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w pasaremos|strong="H5674"\w* \w hasta|strong="H5704"\w* \w Gabaa|strong="H1390"\w*».  
\v 13 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* su paje: «\w Ven|strong="H3212"\w*, lleguemos \w a|strong="H3068"\w* uno de esos \w lugares|strong="H4725"\w*, para pasar la noche \w en|strong="H3212"\w* \w Gabaa|strong="H1390"\w* \w o|strong="H3068"\w* \w en|strong="H3212"\w* \w Ramá|strong="H7414"\w*».  
\v 14 \w Pasaron|strong="H5674"\w*, pues, y siguieron su camino, y se les puso \w el|strong="H5674"\w* \w sol|strong="H8121"\w* junto \w a|strong="H3068"\w* \w Gabaa|strong="H1390"\w*, que es de \w Benjamín|strong="H1144"\w*.  
\v 15 \w Y|strong="H3068"\w* se apartaron \w allí|strong="H8033"\w* \w para|strong="H5493"\w* entrar \w a|strong="H3068"\w* posar \w en|strong="H5493"\w* \w Gabaa|strong="H1390"\w*; y entrando, se \w sentaron|strong="H3427"\w* \w en|strong="H5493"\w* la plaza de la \w ciudad|strong="H5892"\w*, \w porque|strong="H8033"\w* no hubo hombre que \w los|strong="H3427"\w* acogiese \w en|strong="H5493"\w* \w casa|strong="H1004"\w* \w para|strong="H5493"\w* pernoctar.   
\p
\v 16 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* un hombre \w anciano|strong="H2205"\w* \w que|strong="H4480"\w* venía \w de|strong="H4480"\w* \w su|strong="H1931"\w* trabajo \w del|strong="H4480"\w* \w campo|strong="H7704"\w* \w al|strong="H4480"\w* anochecer, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w era|strong="H1931"\w* \w del|strong="H4480"\w* \w monte|strong="H2022"\w* \w de|strong="H4480"\w* Efraín y moraba \w como|strong="H1931"\w* forastero \w en|strong="H4480"\w* \w Gabaa|strong="H1390"\w*; pero \w los|strong="H1931"\w* moradores \w de|strong="H4480"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* eran hijos \w de|strong="H4480"\w* Benjamín.  
\v 17 \w Y|strong="H3068"\w* \w alzando|strong="H5375"\w* el \w anciano|strong="H2205"\w* los \w ojos|strong="H5869"\w*, \w vio|strong="H7200"\w* \w a|strong="H3068"\w* aquel caminante \w en|strong="H3212"\w* la plaza \w de|strong="H5869"\w* la \w ciudad|strong="H5892"\w*, y \w le|strong="H5869"\w* preguntó: «¿\w A|strong="H3068"\w* dónde \w vas|strong="H3212"\w*, y \w de|strong="H5869"\w* dónde \w vienes|strong="H3212"\w*?».  
\v 18 \w Y|strong="H3068"\w* \w él|strong="H5674"\w* respondió: «\w Pasamos|strong="H5674"\w* \w de|strong="H5704"\w* Belén \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* la parte \w más|strong="H5704"\w* remota del \w monte|strong="H2022"\w* \w de|strong="H5704"\w* Efraín, \w de|strong="H5704"\w* \w donde|strong="H8033"\w* yo soy; \w y|strong="H5704"\w* \w fui|strong="H3212"\w* \w a|strong="H3068"\w* Belén \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5704"\w* ahora \w voy|strong="H1980"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Yahvé, \w y|strong="H5704"\w* no hay quien me reciba \w en|strong="H5704"\w* \w casa|strong="H1004"\w*.  
\v 19 \w Tenemos|strong="H3426"\w* \w paja|strong="H8401"\w* \w y|strong="H1571"\w* \w forraje|strong="H4554"\w* \w para|strong="H5973"\w* nuestros \w asnos|strong="H2543"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w pan|strong="H3899"\w* \w y|strong="H1571"\w* \w vino|strong="H3196"\w* \w para|strong="H5973"\w* mí \w y|strong="H1571"\w* \w para|strong="H5973"\w* \w tu|strong="H3426"\w* sierva, \w y|strong="H1571"\w* \w para|strong="H5973"\w* \w el|strong="H5973"\w* joven \w que|strong="H1571"\w* \w está|strong="H3426"\w* \w con|strong="H5973"\w* tus \w siervos|strong="H5650"\w*; no nos \w falta|strong="H4270"\w* \w nada|strong="H1697"\w*».   
