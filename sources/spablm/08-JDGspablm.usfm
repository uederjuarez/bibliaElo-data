\v 25 En \w estos|strong="H1992"\w* \w días|strong="H3117"\w* \w no|strong="H6213"\w* \w había|strong="H6213"\w* \w rey|strong="H4428"\w* en \w Israel|strong="H3478"\w*; \w cada|strong="H3117"\w* uno \w hacía|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H3117"\w* \w bien|strong="H5869"\w* \w le|strong="H5869"\w* \w parecía|strong="H5869"\w*.   