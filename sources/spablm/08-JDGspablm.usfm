\p
\v 1 \w Hubo|strong="H1961"\w* un hombre del \w monte|strong="H2022"\w* de Efraín, \w que|strong="H1961"\w* \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* Micaía.  
\v 2 \w El|strong="H1121"\w* cual dijo \w a|strong="H3068"\w* su madre: «\w Los|strong="H1121"\w* \w mil|strong="H3967"\w* \w cien|strong="H3967"\w* siclos \w de|strong="H1121"\w* \w plata|strong="H3701"\w* \w que|strong="H1571"\w* te fueron hurtados, acerca \w de|strong="H1121"\w* \w los|strong="H1121"\w* cuales proferiste una maldición, \w y|strong="H1571"\w* \w aun|strong="H1571"\w* lo dijiste \w a|strong="H3068"\w* mis oídos, he \w aquí|strong="H2009"\w* \w que|strong="H1571"\w* \w el|strong="H1121"\w* \w dinero|strong="H3701"\w* está en \w mi|strong="H2009"\w* poder; \w yo|strong="H2009"\w* lo \w tomé|strong="H3947"\w*». \w Entonces|strong="H1571"\w* \w la|strong="H1571"\w* madre dijo: «\w Bendito|strong="H1288"\w* seas \w de|strong="H1121"\w* Yahvé, \w hijo|strong="H1121"\w* mío».   
\p
\v 3 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* devolvió \w los|strong="H1121"\w* \w mil|strong="H3967"\w* \w cien|strong="H3967"\w* siclos \w de|strong="H1121"\w* \w plata|strong="H3701"\w* \w a|strong="H3068"\w* su madre; y su madre dijo: «\w Yo|strong="H6213"\w* he dedicado \w por|strong="H3027"\w* entero este \w dinero|strong="H3701"\w* \w a|strong="H3068"\w* Yahvé \w de|strong="H1121"\w* mi \w mano|strong="H3027"\w* \w para|strong="H6258"\w* mi \w hijo|strong="H1121"\w*, \w para|strong="H6258"\w* \w hacer|strong="H6213"\w* una \w imagen|strong="H6459"\w* \w de|strong="H1121"\w* talla y una \w de|strong="H1121"\w* \w fundición|strong="H4541"\w*; \w ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, te \w lo|strong="H6213"\w* devuelvo».   
\p
\v 4 Mas \w él|strong="H6213"\w* devolvió \w el|strong="H6213"\w* \w dinero|strong="H3701"\w* \w a|strong="H3068"\w* su madre, y \w tomó|strong="H3947"\w* su madre \w doscientos|strong="H3967"\w* siclos \w de|strong="H5414"\w* \w plata|strong="H3701"\w* y \w los|strong="H1961"\w* \w dio|strong="H5414"\w* al \w fundidor|strong="H6884"\w*, \w quien|strong="H6213"\w* \w hizo|strong="H6213"\w* \w de|strong="H5414"\w* ellos una \w imagen|strong="H6459"\w* \w de|strong="H5414"\w* talla y una \w de|strong="H5414"\w* \w fundición|strong="H4541"\w*, la cual \w fue|strong="H1961"\w* puesta en \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Micaía.   
\p
\v 5 \w Y|strong="H3068"\w* \w tuvo|strong="H1961"\w* \w este|strong="H1961"\w* \w hombre|strong="H1121"\w* Micaía un santuario \w de|strong="H1121"\w* Dios, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* un efod y terafines,\f + \fr 17:5 \ft Los terafines eran ídolos domésticos que, según la costumbre antigua, podían estar vinculados a los derechos de herencia y la protección del hogar.\f* y \w consagró|strong="H4390"\w* \w a|strong="H3068"\w* uno \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* \w para|strong="H1961"\w* \w que|strong="H1121"\w* \w fuera|strong="H1961"\w* su \w sacerdote|strong="H3548"\w*.  
\v 6 En \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w no|strong="H6213"\w* \w había|strong="H6213"\w* \w rey|strong="H4428"\w* en \w Israel|strong="H3478"\w*; \w cada|strong="H3117"\w* uno \w hacía|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H3117"\w* \w bien|strong="H5869"\w* \w le|strong="H5869"\w* \w parecía|strong="H5869"\w*.  
\v 7 \w Y|strong="H3068"\w* \w había|strong="H1961"\w* un joven de Belén de \w Judá|strong="H3063"\w*, de \w la|strong="H1931"\w* estirpe de \w Judá|strong="H3063"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w era|strong="H1961"\w* \w levita|strong="H3881"\w* y moraba \w allí|strong="H8033"\w* \w como|strong="H1961"\w* forastero.  
\v 8 Este hombre \w partió|strong="H3212"\w* \w de|strong="H5704"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* Belén \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w para|strong="H5704"\w* \w ir|strong="H3212"\w* \w a|strong="H3068"\w* morar donde \w hallara|strong="H4672"\w* lugar; \w y|strong="H5704"\w* llegando \w al|strong="H5704"\w* \w monte|strong="H2022"\w* \w de|strong="H5704"\w* Efraín, \w vino|strong="H3212"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Micaía \w para|strong="H5704"\w* seguir su \w camino|strong="H1870"\w*.  
\v 9 \w Y|strong="H3068"\w* Micaía le dijo: «¿De dónde vienes?». \w Y|strong="H3068"\w* el \w levita|strong="H3881"\w* respondió: «Soy de Belén de \w Judá|strong="H3063"\w*, y \w voy|strong="H1980"\w* \w a|strong="H3068"\w* vivir donde pueda \w hallar|strong="H4672"\w* lugar».   
\p
\v 10 \w Entonces|strong="H3117"\w* Micaía le dijo: «\w Quédate|strong="H3427"\w* \w en|strong="H3212"\w* \w mi|strong="H1961"\w* casa, y \w serás|strong="H1961"\w* \w para|strong="H5414"\w* \w mí|strong="H1961"\w* padre y \w sacerdote|strong="H3548"\w*; y yo te \w daré|strong="H5414"\w* \w diez|strong="H6235"\w* siclos \w de|strong="H5414"\w* \w plata|strong="H3701"\w* al año, las vestiduras necesarias y tu comida». \w Y|strong="H3068"\w* \w el|strong="H3427"\w* \w levita|strong="H3881"\w* \w se|strong="H1961"\w* \w quedó|strong="H1961"\w*.  
\v 11 Agradó, \w pues|strong="H1961"\w*, al \w levita|strong="H3881"\w* \w morar|strong="H3427"\w* con aquel \w hombre|strong="H1121"\w*, y \w él|strong="H1121"\w* lo \w tenía|strong="H1961"\w* \w como|strong="H1961"\w* \w a|strong="H3068"\w* uno \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w*.  
\v 12 Micaía \w consagró|strong="H4390"\w* al \w levita|strong="H3881"\w*, y aquel joven le \w servía|strong="H1961"\w* de \w sacerdote|strong="H3548"\w*, y permaneció en \w casa|strong="H1004"\w* de Micaía.  
\v 13 \w Y|strong="H3068"\w* Micaía dijo: «\w Ahora|strong="H6258"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* Yahvé \w me|strong="H3588"\w* \w hará|strong="H1961"\w* \w bien|strong="H3190"\w*, \w pues|strong="H3588"\w* tengo \w a|strong="H3068"\w* un \w levita|strong="H3881"\w* \w por|strong="H3588"\w* \w sacerdote|strong="H3548"\w*».   
\c 18
\p
\v 1 \w En|strong="H5704"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w no|strong="H3808"\w* \w había|strong="H3588"\w* \w rey|strong="H4428"\w* \w en|strong="H5704"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* \w en|strong="H5704"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w la|strong="H1931"\w* \w tribu|strong="H7626"\w* \w de|strong="H3588"\w* \w Dan|strong="H1839"\w* \w buscaba|strong="H1245"\w* \w posesión|strong="H5159"\w* \w donde|strong="H1931"\w* \w habitar|strong="H3427"\w*, \w porque|strong="H3588"\w* \w hasta|strong="H5704"\w* \w entonces|strong="H3117"\w* \w no|strong="H3808"\w* \w le|strong="H1931"\w* \w había|strong="H3588"\w* \w caído|strong="H5307"\w* \w heredad|strong="H5159"\w* \w entre|strong="H8432"\w* \w las|strong="H1992"\w* \w tribus|strong="H7626"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.  
\v 2 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Dan|strong="H1835"\w* \w enviaron|strong="H7971"\w* \w de|strong="H5704"\w* su estirpe \w cinco|strong="H2568"\w* \w hombres|strong="H1121"\w* \w de|strong="H5704"\w* \w entre|strong="H8033"\w* ellos, \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w*, \w de|strong="H5704"\w* Zora \w y|strong="H5704"\w* \w de|strong="H5704"\w* Estaol, \w para|strong="H5704"\w* \w que|strong="H5704"\w* fuesen \w a|strong="H3068"\w* reconocer la tierra \w y|strong="H5704"\w* \w a|strong="H3068"\w* explorarla; \w y|strong="H5704"\w* les dijeron: «\w Id|strong="H3212"\w* \w y|strong="H5704"\w* reconoced la tierra». Estos llegaron \w al|strong="H5704"\w* \w monte|strong="H2022"\w* \w de|strong="H5704"\w* Efraín, \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Micaía, \w y|strong="H5704"\w* \w posaron|strong="H3885"\w* \w allí|strong="H8033"\w*.  
\v 3 \w Cuando|strong="H4100"\w* estaban \w cerca|strong="H5973"\w* \w de|strong="H5973"\w* la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Micaía, \w reconocieron|strong="H5234"\w* \w el|strong="H5973"\w* acento \w del|strong="H5973"\w* joven \w levita|strong="H3881"\w*; y acercándose \w allá|strong="H8033"\w*, \w le|strong="H5973"\w* dijeron: «¿\w Quién|strong="H4310"\w* \w te|strong="H5973"\w* ha traído \w acá|strong="H2088"\w*? ¿\w Qué|strong="H4100"\w* \w haces|strong="H6213"\w* \w en|strong="H5973"\w* \w este|strong="H2088"\w* lugar? ¿\w Qué|strong="H4100"\w* tienes \w tú|strong="H6213"\w* \w aquí|strong="H6311"\w*?».   
\p
\v 4 \w Él|strong="H6213"\w* les respondió: «De \w esta|strong="H2088"\w* y de aquella manera ha \w hecho|strong="H6213"\w* \w conmigo|strong="H6213"\w* Micaía; me ha puesto \w a|strong="H3068"\w* sueldo, y \w yo|strong="H6213"\w* le sirvo de \w sacerdote|strong="H3548"\w*».   
\p
\v 5 \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* \w le|strong="H5921"\w* dijeron: «Consulta \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* Dios, \w para|strong="H5921"\w* \w que|strong="H4994"\w* \w sepamos|strong="H3045"\w* \w si|strong="H4994"\w* \w prosperará|strong="H6743"\w* nuestro \w viaje|strong="H1870"\w* \w que|strong="H4994"\w* emprendemos».   
\p
\v 6 El \w sacerdote|strong="H3548"\w* les respondió: «\w Id|strong="H3212"\w* \w en|strong="H3212"\w* \w paz|strong="H7965"\w*; el \w viaje|strong="H1870"\w* que hacéis está \w delante|strong="H5227"\w* de Yahvé».   
\p
\v 7 Entonces \w aquellos|strong="H1992"\w* \w cinco|strong="H2568"\w* hombres \w partieron|strong="H3212"\w* y llegaron \w a|strong="H3068"\w* \w Lais|strong="H3919"\w*; y \w vieron|strong="H7200"\w* \w que|strong="H5971"\w* \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w habitaba|strong="H3427"\w* \w en|strong="H5973"\w* ella \w estaba|strong="H3427"\w* seguro, \w a|strong="H3068"\w* la \w manera|strong="H1697"\w* \w de|strong="H5973"\w* \w los|strong="H1992"\w* \w sidonios|strong="H6722"\w*, \w quieto|strong="H8252"\w* y confiado; y \w que|strong="H5971"\w* no había nadie \w en|strong="H5973"\w* aquella tierra \w que|strong="H5971"\w* \w les|strong="H1992"\w* agraviase, \w ni|strong="H5973"\w* quien poseyera mando; y \w que|strong="H5971"\w* \w estaban|strong="H3427"\w* \w lejos|strong="H7350"\w* \w de|strong="H5973"\w* \w los|strong="H1992"\w* \w sidonios|strong="H6722"\w*, y no tenían tratos \w con|strong="H5973"\w* nadie.  
\v 8 Volvieron, \w pues|strong="H4100"\w*, \w a|strong="H3068"\w* sus hermanos en Zora y Estaol; y sus hermanos les preguntaron: «¿\w Qué|strong="H4100"\w* noticias traéis?».   
\p
\v 9 \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* respondieron: «\w Levantaos|strong="H6965"\w*, \w subamos|strong="H5927"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*; \w porque|strong="H3588"\w* hemos explorado \w la|strong="H5921"\w* tierra \w y|strong="H3588"\w* hemos \w visto|strong="H7200"\w* \w que|strong="H3588"\w* \w es|strong="H3588"\w* \w muy|strong="H3966"\w* \w buena|strong="H2896"\w*; ¿\w y|strong="H3588"\w* vosotros \w os|strong="H5921"\w* estáis \w aquí|strong="H2009"\w* quietos? \w No|strong="H3588"\w* seáis perezosos \w en|strong="H5921"\w* poneros \w en|strong="H5921"\w* marcha \w para|strong="H5921"\w* \w ir|strong="H3212"\w* \w a|strong="H3068"\w* poseer \w la|strong="H5921"\w* tierra.  
\v 10 \w Cuando|strong="H3588"\w* vayáis, llegaréis \w a|strong="H3068"\w* un \w pueblo|strong="H5971"\w* confiado \w y|strong="H3588"\w* \w a|strong="H3068"\w* una tierra vasta; \w pues|strong="H3588"\w* Dios \w la|strong="H3588"\w* ha \w entregado|strong="H5414"\w* \w en|strong="H3588"\w* \w vuestras|strong="H1697"\w* \w manos|strong="H3027"\w*; \w es|strong="H3027"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \w no|strong="H3588"\w* hay \w falta|strong="H4270"\w* \w de|strong="H3588"\w* \w cosa|strong="H1697"\w* \w alguna|strong="H3605"\w* \w que|strong="H3588"\w* haya \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra».   
\p
\v 11 \w Partieron|strong="H5265"\w*, pues, de \w allí|strong="H8033"\w*, de la estirpe de \w Dan|strong="H1839"\w*, de Zora y de Estaol, \w seiscientos|strong="H8337"\w* hombres \w ceñidos|strong="H2296"\w* de \w armas|strong="H3627"\w* de \w guerra|strong="H4421"\w*.  
\v 12 \w Subieron|strong="H5927"\w* \w y|strong="H5921"\w* acamparon \w en|strong="H5921"\w* Quiriat-jearim, \w en|strong="H5921"\w* \w Judá|strong="H3063"\w*; \w por|strong="H5921"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w llamaron|strong="H7121"\w* \w a|strong="H3068"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* Mahaneh-dan \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*; \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w está|strong="H2088"\w* \w a|strong="H3068"\w* espaldas \w de|strong="H5921"\w* Quiriat-jearim.  
\v 13 \w Y|strong="H3068"\w* \w pasaron|strong="H5674"\w* \w de|strong="H5704"\w* \w allí|strong="H8033"\w* \w al|strong="H5704"\w* \w monte|strong="H2022"\w* \w de|strong="H5704"\w* Efraín, \w y|strong="H5704"\w* vinieron \w hasta|strong="H5704"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Micaía.   
\p
\v 14 \w Entonces|strong="H3588"\w* \w los|strong="H3588"\w* \w cinco|strong="H2568"\w* hombres \w que|strong="H3588"\w* habían ido \w a|strong="H3068"\w* reconocer \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Lais|strong="H3919"\w* hablaron \w y|strong="H3588"\w* dijeron \w a|strong="H3068"\w* sus hermanos: «¿\w No|strong="H6213"\w* \w sabéis|strong="H3045"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w estas|strong="H6213"\w* \w casas|strong="H1004"\w* \w hay|strong="H3426"\w* un efod \w y|strong="H3588"\w* terafines,\f + \fr 18:14 \ft Los terafines eran ídolos domésticos vinculados a la protección y la herencia del hogar.\f* \w y|strong="H3588"\w* una \w imagen|strong="H6459"\w* \w de|strong="H3588"\w* talla \w y|strong="H3588"\w* una \w de|strong="H3588"\w* \w fundición|strong="H4541"\w*? Ved, \w pues|strong="H3588"\w*, \w ahora|strong="H6258"\w* \w lo|strong="H4100"\w* \w que|strong="H3588"\w* habéis \w de|strong="H3588"\w* \w hacer|strong="H6213"\w*».  
\v 15 \w Entonces|strong="H5493"\w* se apartaron \w hacia|strong="H8033"\w* \w allá|strong="H8033"\w*, y vinieron \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* del joven \w levita|strong="H3881"\w*, \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de Micaía, y le saludaron \w en|strong="H5493"\w* \w paz|strong="H7965"\w*.  
\v 16 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w seiscientos|strong="H8337"\w* \w hombres|strong="H1121"\w* \w que|strong="H1121"\w* eran \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w* \w estaban|strong="H5324"\w* \w a|strong="H3068"\w* la entrada \w de|strong="H1121"\w* la \w puerta|strong="H6607"\w*, \w ceñidos|strong="H2296"\w* \w de|strong="H1121"\w* sus \w armas|strong="H3627"\w* \w de|strong="H1121"\w* \w guerra|strong="H4421"\w*.  
\v 17 \w Y|strong="H3068"\w* \w subieron|strong="H5927"\w* los \w cinco|strong="H2568"\w* hombres que habían ido \w a|strong="H3068"\w* reconocer la tierra, y entraron \w allá|strong="H8033"\w* y \w tomaron|strong="H3947"\w* la imagen \w de|strong="H2568"\w* talla, el efod, los terafines y la imagen \w de|strong="H2568"\w* \w fundición|strong="H4541"\w*, mientras \w estaba|strong="H5324"\w* el \w sacerdote|strong="H3548"\w* \w a|strong="H3068"\w* la entrada \w de|strong="H2568"\w* la \w puerta|strong="H6607"\w* con los \w seiscientos|strong="H8337"\w* hombres \w ceñidos|strong="H2296"\w* \w de|strong="H2568"\w* \w armas|strong="H3627"\w* \w de|strong="H2568"\w* \w guerra|strong="H4421"\w*.   
\p
\v 18 Entrando, \w pues|strong="H4100"\w*, aquellos en la \w casa|strong="H1004"\w* de Micaía y \w tomando|strong="H3947"\w* la \w imagen|strong="H6459"\w* de talla, \w el|strong="H6213"\w* efod, los terafines y la \w imagen|strong="H6459"\w* de \w fundición|strong="H4541"\w*, \w el|strong="H6213"\w* \w sacerdote|strong="H3548"\w* les dijo: «¿\w Qué|strong="H4100"\w* \w hacéis|strong="H6213"\w* vosotros?».   
\p
\v 19 \w Y|strong="H3068"\w* \w ellos|strong="H3027"\w* \w le|strong="H5921"\w* respondieron: «\w Calla|strong="H2790"\w*, \w pon|strong="H7760"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* tu \w boca|strong="H6310"\w* \w y|strong="H5921"\w* \w ven|strong="H3212"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w seas|strong="H1961"\w* nuestro padre \w y|strong="H5921"\w* \w sacerdote|strong="H3548"\w*. ¿\w Es|strong="H1961"\w* \w mejor|strong="H2896"\w* ser \w sacerdote|strong="H3548"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* un solo hombre, \w que|strong="H5921"\w* serlo \w de|strong="H5921"\w* una \w tribu|strong="H7626"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* una \w familia|strong="H1004"\w* \w en|strong="H5921"\w* \w Israel|strong="H3478"\w*?».   
\p
\v 20 \w Y|strong="H3068"\w* \w se|strong="H5971"\w* alegró el \w corazón|strong="H3820"\w* del \w sacerdote|strong="H3548"\w*, el cual \w tomó|strong="H3947"\w* el efod, los terafines y la \w imagen|strong="H6459"\w* \w de|strong="H5971"\w* talla, y \w se|strong="H5971"\w* fue en \w medio|strong="H7130"\w* del \w pueblo|strong="H5971"\w*.  
\v 21 \w Y|strong="H3068"\w* \w volviéndose|strong="H6437"\w*, \w partieron|strong="H3212"\w* y \w pusieron|strong="H7760"\w* los pequeñuelos, el \w ganado|strong="H4735"\w* y el bagaje \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w sí|strong="H6440"\w*.  
