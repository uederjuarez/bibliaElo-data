\v 16 \w Y|strong="H3068"\w* \w lloró|strong="H1058"\w* \w la|strong="H5921"\w* mujer \w de|strong="H5921"\w* Sansón \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w dijo|strong="H5046"\w*: «\w Solo|strong="H7535"\w* \w me|strong="H5921"\w* \w aborreces|strong="H8130"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w me|strong="H5921"\w* amas, pues \w no|strong="H3808"\w* \w me|strong="H5921"\w* has \w declarado|strong="H5046"\w* \w el|strong="H5921"\w* \w enigma|strong="H2420"\w* \w que|strong="H3808"\w* propusiste \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*». \w Y|strong="H3068"\w* \w él|strong="H5921"\w* respondió: «He \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* padre \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* madre \w lo|strong="H3808"\w* he \w declarado|strong="H5046"\w*, ¿\w y|strong="H5921"\w* \w te|strong="H5921"\w* \w lo|strong="H3808"\w* había \w de|strong="H5921"\w* declarar \w a|strong="H3068"\w* \w ti|strong="H5921"\w*?».   
\p
\v 17 \w Y|strong="H3068"\w* \w ella|strong="H5921"\w* \w lloró|strong="H1058"\w* \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w* \w los|strong="H1121"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w que|strong="H3588"\w* \w ellos|strong="H5921"\w* \w tuvieron|strong="H1961"\w* \w el|strong="H5921"\w* \w convite|strong="H4960"\w*; \w mas|strong="H3588"\w* \w al|strong="H5921"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w él|strong="H5921"\w* \w se|strong="H1961"\w* \w lo|strong="H5921"\w* \w declaró|strong="H5046"\w*, \w porque|strong="H3588"\w* \w ella|strong="H5921"\w* \w le|strong="H5921"\w* presionaba; \w y|strong="H3588"\w* \w ella|strong="H5921"\w* \w lo|strong="H5921"\w* \w declaró|strong="H5046"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*.  
\v 18 Al \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w*, \w antes|strong="H2962"\w* \w que|strong="H4100"\w* el sol \w se|strong="H3808"\w* pusiese, los de la \w ciudad|strong="H5892"\w* le dijeron: «¿\w Qué|strong="H4100"\w* cosa \w más|strong="H3808"\w* \w dulce|strong="H4966"\w* \w que|strong="H4100"\w* la \w miel|strong="H1706"\w*? ¿\w Y|strong="H3068"\w* \w qué|strong="H4100"\w* cosa \w más|strong="H3808"\w* \w fuerte|strong="H5794"\w* \w que|strong="H4100"\w* el león?». \w Y|strong="H3068"\w* él les respondió:  
\q1 «\w Si|strong="H3884"\w* \w no|strong="H3808"\w* hubierais arado con mi \w novilla|strong="H5697"\w*,  
\q2 \w no|strong="H3808"\w* habríais \w hallado|strong="H4672"\w* mi \w enigma|strong="H2420"\w*».   
\p
\v 19 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Yahvé \w vino|strong="H3381"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w con|strong="H5921"\w* poder, \w y|strong="H5921"\w* \w descendió|strong="H3381"\w* \w a|strong="H3068"\w* Ascalón \w y|strong="H5921"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w treinta|strong="H7970"\w* hombres \w de|strong="H5921"\w* \w ellos|strong="H1992"\w*; \w y|strong="H5921"\w* \w tomando|strong="H3947"\w* \w sus|strong="H1992"\w* \w despojos|strong="H2488"\w*, \w dio|strong="H5414"\w* \w las|strong="H1992"\w* \w mudas|strong="H2487"\w* \w de|strong="H5921"\w* vestidos \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w que|strong="H5921"\w* habían explicado \w el|strong="H5921"\w* \w enigma|strong="H2420"\w*; \w y|strong="H5921"\w* encendido \w en|strong="H5921"\w* enojo \w se|strong="H5921"\w* \w volvió|strong="H5414"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w su|strong="H1992"\w* padre.  
\v 20 \w Y|strong="H3068"\w* la mujer de Sansón \w fue|strong="H1961"\w* dada \w a|strong="H3068"\w* su compañero, el cual \w había|strong="H1961"\w* \w sido|strong="H1961"\w* su \w amigo|strong="H4828"\w* íntimo.   
\c 15
\p
\v 1 \w Aconteció|strong="H1961"\w* \w después|strong="H1961"\w* \w de|strong="H5414"\w* algún \w tiempo|strong="H3117"\w*, en \w los|strong="H1961"\w* \w días|strong="H3117"\w* \w de|strong="H5414"\w* la siega del \w trigo|strong="H2406"\w*, \w que|strong="H3808"\w* Sansón \w visitó|strong="H6485"\w* \w a|strong="H3068"\w* su mujer con un \w cabrito|strong="H1423"\w*, diciendo: «Entraré \w a|strong="H3068"\w* \w mi|strong="H1961"\w* mujer en su aposento». \w Mas|strong="H6485"\w* el padre \w de|strong="H5414"\w* ella \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w dejó|strong="H5414"\w* entrar.  
\v 2 \w Y|strong="H3068"\w* dijo \w el|strong="H3588"\w* padre \w de|strong="H4480"\w* \w ella|strong="H4480"\w*: «\w Me|strong="H4480"\w* \w puse|strong="H5414"\w* \w a|strong="H3068"\w* pensar \w que|strong="H3588"\w* \w la|strong="H3588"\w* aborrecías \w del|strong="H4480"\w* todo, \w y|strong="H3588"\w* \w por|strong="H3588"\w* eso \w la|strong="H3588"\w* \w di|strong="H5414"\w* \w a|strong="H3068"\w* tu compañero. \w Pero|strong="H3588"\w* \w su|strong="H3588"\w* hermana \w menor|strong="H6996"\w*, ¿\w no|strong="H3808"\w* \w es|strong="H1961"\w* \w más|strong="H3588"\w* \w hermosa|strong="H2896"\w* \w que|strong="H3588"\w* \w ella|strong="H4480"\w*? \w Tómala|strong="H1961"\w*, \w pues|strong="H3588"\w*, \w en|strong="H4480"\w* \w su|strong="H3588"\w* \w lugar|strong="H8478"\w*».   
\p
\v 3 \w Entonces|strong="H3588"\w* Sansón \w les|strong="H5973"\w* respondió: «Sin \w culpa|strong="H5352"\w* seré esta \w vez|strong="H6471"\w* \w para|strong="H3588"\w* \w con|strong="H5973"\w* \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w*, \w si|strong="H3588"\w* \w les|strong="H5973"\w* \w hiciere|strong="H6213"\w* \w mal|strong="H7451"\w*».  
\v 4 \w Y|strong="H3068"\w* \w fue|strong="H3212"\w* Sansón y cazó \w trescientas|strong="H7969"\w* \w zorras|strong="H7776"\w*, y \w tomó|strong="H3947"\w* teas, y juntó las \w colas|strong="H2180"\w* de las \w zorras|strong="H7776"\w*, y \w puso|strong="H7760"\w* una \w tea|strong="H3940"\w* \w entre|strong="H8432"\w* cada \w dos|strong="H8147"\w* \w colas|strong="H2180"\w*.  
\v 5 \w Después|strong="H5704"\w*, \w encendiendo|strong="H1197"\w* las teas, soltó las zorras \w en|strong="H5704"\w* las mieses \w de|strong="H5704"\w* los \w filisteos|strong="H6430"\w*, \w y|strong="H5704"\w* quemó las gavillas \w y|strong="H5704"\w* el trigo \w en|strong="H5704"\w* pie, \w y|strong="H5704"\w* también las \w viñas|strong="H3754"\w* \w y|strong="H5704"\w* los \w olivares|strong="H2132"\w*.   
\p
\v 6 \w Y|strong="H3068"\w* preguntaron \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w*: «¿\w Quién|strong="H4310"\w* \w hizo|strong="H6213"\w* \w esto|strong="H2063"\w*?». \w Y|strong="H3068"\w* les respondieron: «Sansón, \w el|strong="H3588"\w* \w yerno|strong="H2860"\w* del timnateo, \w porque|strong="H3588"\w* \w este|strong="H2063"\w* \w le|strong="H4310"\w* \w quitó|strong="H3947"\w* \w su|strong="H3588"\w* mujer \w y|strong="H3588"\w* se \w la|strong="H3588"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* compañero». \w Y|strong="H3068"\w* \w subieron|strong="H5927"\w* \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* quemaron \w a|strong="H3068"\w* ella \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* padre.   
\p
\v 7 \w Entonces|strong="H3588"\w* Sansón les dijo: «\w Ya|strong="H3068"\w* \w que|strong="H3588"\w* os habéis portado \w así|strong="H2063"\w*, \w ciertamente|strong="H3588"\w* \w me|strong="H3588"\w* vengaré \w de|strong="H3588"\w* vosotros, \w y|strong="H3588"\w* después desistiré».  
\v 8 \w Y|strong="H3068"\w* \w los|strong="H3427"\w* \w hirió|strong="H5221"\w* \w con|strong="H5921"\w* \w gran|strong="H1419"\w* matanza, cadera \w y|strong="H5921"\w* \w muslo|strong="H3409"\w*; \w y|strong="H5921"\w* \w descendió|strong="H3381"\w* \w y|strong="H5921"\w* \w habitó|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* hendidura \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w peña|strong="H5553"\w* \w de|strong="H5921"\w* Etam.  
\v 9 Entonces los \w filisteos|strong="H6430"\w* \w subieron|strong="H5927"\w* y acamparon en \w Judá|strong="H3063"\w*, y se extendieron por \w Lehi|strong="H3896"\w*.   
\p
\v 10 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w les|strong="H5921"\w* dijeron: «¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* habéis \w subido|strong="H5927"\w* \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*?». \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* respondieron: «\w Para|strong="H5921"\w* prender \w a|strong="H3068"\w* Sansón hemos \w subido|strong="H5927"\w*, \w para|strong="H5921"\w* \w hacerle|strong="H6213"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w como|strong="H4100"\w* \w él|strong="H5921"\w* \w nos|strong="H5921"\w* ha \w hecho|strong="H6213"\w* \w a|strong="H3068"\w* \w nosotros|strong="H5921"\w*».   
\p
\v 11 \w Entonces|strong="H3588"\w* \w tres|strong="H7969"\w* mil hombres \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w descendieron|strong="H3381"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* hendidura \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w peña|strong="H5553"\w* \w de|strong="H3588"\w* Etam, \w y|strong="H3588"\w* dijeron \w a|strong="H3068"\w* Sansón: «¿\w No|strong="H3808"\w* \w sabes|strong="H3045"\w* \w tú|strong="H6213"\w* \w que|strong="H3588"\w* \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w* \w dominan|strong="H4910"\w* sobre nosotros? ¿\w Qué|strong="H3588"\w* \w es|strong="H3588"\w* \w esto|strong="H2063"\w* \w que|strong="H3588"\w* \w nos|strong="H4100"\w* has \w hecho|strong="H6213"\w*?». \w Y|strong="H3068"\w* \w él|strong="H3588"\w* les respondió: «\w Yo|strong="H3588"\w* les he \w hecho|strong="H6213"\w* \w como|strong="H4100"\w* ellos \w me|strong="H3588"\w* \w hicieron|strong="H6213"\w* \w a|strong="H3068"\w* mí».   
\p
\v 12 \w Ellos|strong="H3027"\w* entonces le dijeron: «Hemos venido \w para|strong="H5414"\w* prenderte y entregarte en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* los \w filisteos|strong="H6430"\w*». \w Y|strong="H3068"\w* Sansón les respondió: «\w Juradme|strong="H7650"\w* \w que|strong="H6435"\w* vosotros \w no|strong="H6435"\w* me mataréis».   
\p
\v 13 \w Y|strong="H3068"\w* \w ellos|strong="H3027"\w* le respondieron, diciendo: «\w No|strong="H3808"\w*; \w solamente|strong="H3588"\w* \w te|strong="H4480"\w* prenderemos \w y|strong="H3588"\w* \w te|strong="H4480"\w* entregaremos \w en|strong="H4480"\w* sus \w manos|strong="H3027"\w*; \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H4480"\w* \w mataremos|strong="H4191"\w*». \w Entonces|strong="H3588"\w* \w lo|strong="H3808"\w* ataron \w con|strong="H4480"\w* \w dos|strong="H8147"\w* \w cuerdas|strong="H5688"\w* \w nuevas|strong="H2319"\w* \w y|strong="H3588"\w* \w lo|strong="H3808"\w* sacaron \w de|strong="H4480"\w* \w la|strong="H3588"\w* \w peña|strong="H5553"\w*.   
\p
\v 14 \w Y|strong="H3068"\w* \w viniendo|strong="H1961"\w* \w él|strong="H1931"\w* \w hasta|strong="H5704"\w* \w Lehi|strong="H3896"\w*, \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* salieron \w a|strong="H3068"\w* \w su|strong="H1931"\w* encuentro \w con|strong="H5921"\w* gritos \w de|strong="H5921"\w* júbilo; pero \w el|strong="H1931"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Yahvé \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w cuerdas|strong="H5688"\w* \w que|strong="H1931"\w* \w estaban|strong="H1961"\w* \w en|strong="H5921"\w* \w sus|strong="H1931"\w* \w brazos|strong="H2220"\w* \w se|strong="H1961"\w* volvieron \w como|strong="H1961"\w* \w lino|strong="H6593"\w* \w quemado|strong="H1197"\w* \w con|strong="H5921"\w* fuego, \w y|strong="H5921"\w* \w las|strong="H5921"\w* ligaduras \w se|strong="H1961"\w* desprendieron \w de|strong="H5921"\w* \w sus|strong="H1931"\w* \w manos|strong="H3027"\w*.  
\v 15 \w Y|strong="H3068"\w* \w hallando|strong="H4672"\w* \w una|strong="H4672"\w* quijada de \w asno|strong="H2543"\w* todavía fresca, \w extendió|strong="H7971"\w* la \w mano|strong="H3027"\w* y la \w tomó|strong="H3947"\w*, y \w mató|strong="H5221"\w* con ella \w a|strong="H3068"\w* mil hombres.   
\p
\v 16 Entonces Sansón dijo: «Con la quijada de un \w asno|strong="H2543"\w*, un montón, dos montones; con la quijada de un \w asno|strong="H2543"\w* maté \w a|strong="H3068"\w* mil hombres».  
\v 17 \w Y|strong="H3068"\w* \w acabando|strong="H3615"\w* de \w hablar|strong="H1696"\w*, arrojó de \w su|strong="H1931"\w* \w mano|strong="H3027"\w* \w la|strong="H1931"\w* quijada; y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* Ramat-lehi.\f + \fr 15:17 \ft «Ramat-lehi» significa «Colina de la quijada».\f*   
\p
\v 18 \w Y|strong="H3068"\w* teniendo \w gran|strong="H1419"\w* \w sed|strong="H6772"\w*, \w clamó|strong="H7121"\w* \w a|strong="H3068"\w* Yahvé y dijo: «Tú \w has|strong="H4191"\w* \w dado|strong="H5414"\w* \w esta|strong="H2063"\w* \w gran|strong="H1419"\w* salvación \w por|strong="H3027"\w* \w mano|strong="H3027"\w* \w de|strong="H5414"\w* tu \w siervo|strong="H5650"\w*; ¿y \w moriré|strong="H4191"\w* yo \w ahora|strong="H6258"\w* \w de|strong="H5414"\w* \w sed|strong="H6772"\w* y caeré en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* los \w incircuncisos|strong="H6189"\w*?».   
\p
\v 19 \w Entonces|strong="H3117"\w* abrió Dios \w la|strong="H5921"\w* cuenca \w que|strong="H4480"\w* hay \w en|strong="H5921"\w* \w Lehi|strong="H3896"\w*, \w y|strong="H5921"\w* \w salió|strong="H3318"\w* \w agua|strong="H4325"\w* \w de|strong="H4480"\w* \w ella|strong="H4480"\w*; \w y|strong="H5921"\w* \w bebió|strong="H8354"\w*, \w y|strong="H5921"\w* recobró su \w espíritu|strong="H7307"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* reanimó. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w llamó|strong="H7121"\w* su \w nombre|strong="H8034"\w* En-hacore, \w el|strong="H5921"\w* cual \w está|strong="H2088"\w* \w en|strong="H5921"\w* \w Lehi|strong="H3896"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.  
\v 20 \w Y|strong="H3068"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* en los \w días|strong="H3117"\w* de los \w filisteos|strong="H6430"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w*.   
\c 16
\p
\v 1 \w Fue|strong="H3212"\w* Sansón \w a|strong="H3068"\w* \w Gaza|strong="H5804"\w*, y \w vio|strong="H7200"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* una \w ramera|strong="H2181"\w*, y entró \w a|strong="H3068"\w* \w ella|strong="H8033"\w*.  
\v 2 \w Y|strong="H3068"\w* se dijo \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w de|strong="H5704"\w* Gaza: «Sansón ha venido \w acá|strong="H2008"\w*». \w Y|strong="H3068"\w* \w lo|strong="H5704"\w* rodearon, \w y|strong="H5704"\w* pusieron espías \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H5704"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w noche|strong="H3915"\w*; \w y|strong="H5704"\w* estuvieron callados \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w noche|strong="H3915"\w*, diciendo: «Esperemos \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* luz \w de|strong="H5704"\w* \w la|strong="H3605"\w* \w mañana|strong="H1242"\w*, \w y|strong="H5704"\w* entonces \w lo|strong="H5704"\w* mataremos».  
\v 3 \w Mas|strong="H5921"\w* Sansón \w durmió|strong="H7901"\w* \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* medianoche; \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* medianoche \w se|strong="H5921"\w* \w levantó|strong="H6965"\w*, \w y|strong="H5921"\w* tomando \w las|strong="H5921"\w* \w puertas|strong="H1817"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w con|strong="H5973"\w* sus \w dos|strong="H8147"\w* \w pilares|strong="H4201"\w* \w y|strong="H5921"\w* su cerrojo, \w se|strong="H5921"\w* \w las|strong="H5921"\w* echó \w al|strong="H5921"\w* \w hombro|strong="H3802"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w del|strong="H5921"\w* \w monte|strong="H2022"\w* \w que|strong="H5921"\w* \w está|strong="H6965"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Hebrón|strong="H2275"\w*.   
\p
\v 4 \w Después|strong="H1961"\w* de \w esto|strong="H3651"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w se|strong="H1961"\w* enamoró de una mujer en el valle de Sorec, la cual \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* \w Dalila|strong="H1807"\w*.  
