\v 31 \w También|strong="H1571"\w* \w su|strong="H1931"\w* \w concubina|strong="H6370"\w* \w que|strong="H1931"\w* \w estaba|strong="H7760"\w* en Siquem \w le|strong="H1931"\w* \w dio|strong="H7760"\w* \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, \w y|strong="H1571"\w* \w le|strong="H1931"\w* \w puso|strong="H7760"\w* por \w nombre|strong="H8034"\w* Abimelec.  
\v 32 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Gedeón|strong="H1439"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joás|strong="H3101"\w* \w en|strong="H6912"\w* \w buena|strong="H2896"\w* \w vejez|strong="H7872"\w*, y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* \w el|strong="H1121"\w* \w sepulcro|strong="H6913"\w* \w de|strong="H1121"\w* su padre \w Joás|strong="H3101"\w*, \w en|strong="H6912"\w* Ofra \w de|strong="H1121"\w* \w los|strong="H1121"\w* abiezeritas.   
\p
\v 33 Pero \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w cuando|strong="H1961"\w* \w murió|strong="H4191"\w* \w Gedeón|strong="H1439"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w volvieron|strong="H7725"\w* \w a|strong="H3068"\w* prostituirse yendo tras \w los|strong="H1121"\w* baales, y escogieron \w a|strong="H3068"\w* Baal-berit por su dios.  
\v 34 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* acordaron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w de|strong="H1121"\w* Yahvé su \w Dios|strong="H3068"\w*, \w que|strong="H3808"\w* \w los|strong="H1121"\w* había \w librado|strong="H5337"\w* \w de|strong="H1121"\w* \w manos|strong="H3027"\w* \w de|strong="H1121"\w* \w todos|strong="H3605"\w* sus enemigos en \w derredor|strong="H5439"\w*;  
\v 35 \w ni|strong="H3808"\w* \w se|strong="H3808"\w* mostraron agradecidos \w con|strong="H5973"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Jerobaal|strong="H3378"\w* (\w Gedeón|strong="H1439"\w*), conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w bien|strong="H2896"\w* \w que|strong="H3808"\w* \w él|strong="H5973"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.   
\c 9
\p
\v 1 Abimelec \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jerobaal|strong="H3378"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Siquem, \w a|strong="H3068"\w* \w los|strong="H1121"\w* hermanos \w de|strong="H1121"\w* su madre, y \w habló|strong="H1696"\w* con \w ellos|strong="H3605"\w* y con \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w familia|strong="H1004"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* del padre \w de|strong="H1121"\w* su madre, \w diciendo|strong="H1696"\w*:  
\v 2 “Os \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* digáis \w a|strong="H3068"\w* oídos \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* Siquem: «¿\w Qué|strong="H3588"\w* os parece \w mejor|strong="H2896"\w*: \w que|strong="H3588"\w* os gobiernen \w setenta|strong="H7657"\w* \w hombres|strong="H1121"\w*, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Jerobaal|strong="H3378"\w*, \w o|strong="H3068"\w* \w que|strong="H3588"\w* os gobierne uno solo?». \w Acordaos|strong="H2142"\w* también \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy vuestro \w hueso|strong="H6106"\w* \w y|strong="H3588"\w* vuestra \w carne|strong="H1320"\w*”.   
\p
\v 3 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* hermanos \w de|strong="H5921"\w* \w su|strong="H1931"\w* madre \w hablaron|strong="H1696"\w* \w por|strong="H5921"\w* \w él|strong="H1931"\w* \w todas|strong="H3605"\w* estas \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* oídos \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* Siquem; \w y|strong="H3588"\w* \w el|strong="H1931"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* \w ellos|strong="H1931"\w* \w se|strong="H1931"\w* inclinó \w a|strong="H3068"\w* seguir \w a|strong="H3068"\w* Abimelec, \w porque|strong="H3588"\w* decían: «Nuestro hermano \w es|strong="H1931"\w*».  
\v 4 \w Y|strong="H3068"\w* le \w dieron|strong="H5414"\w* \w setenta|strong="H7657"\w* piezas \w de|strong="H5414"\w* \w plata|strong="H3701"\w* \w de|strong="H5414"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Baal-berit, con las cuales Abimelec \w alquiló|strong="H7936"\w* hombres \w ociosos|strong="H7386"\w* y vagabundos que le siguieron.  
\v 5 \w Y|strong="H3068"\w* viniendo \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* padre \w en|strong="H5921"\w* Ofra, \w mató|strong="H2026"\w* \w a|strong="H3068"\w* sus hermanos \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Jerobaal|strong="H3378"\w*, \w setenta|strong="H7657"\w* \w varones|strong="H3588"\w*, \w sobre|strong="H5921"\w* una misma piedra; \w pero|strong="H3588"\w* \w quedó|strong="H3498"\w* Jotam, \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w menor|strong="H6996"\w* \w de|strong="H5921"\w* \w Jerobaal|strong="H3378"\w*, \w que|strong="H3588"\w* \w se|strong="H5921"\w* \w había|strong="H3588"\w* \w escondido|strong="H2244"\w*.  
\v 6 Entonces se juntaron \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5973"\w* Siquem \w con|strong="H5973"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Milo, y \w fueron|strong="H3212"\w* y eligieron \w a|strong="H3068"\w* Abimelec \w por|strong="H4428"\w* \w rey|strong="H4428"\w*, \w cerca|strong="H5973"\w* \w de|strong="H5973"\w* \w la|strong="H3605"\w* encina \w del|strong="H5973"\w* pilar \w que|strong="H7927"\w* \w está|strong="H5324"\w* \w en|strong="H5973"\w* Siquem.  
\v 7 Cuando se lo dijeron \w a|strong="H3068"\w* Jotam, \w fue|strong="H3212"\w* \w este|strong="H5975"\w* y se \w puso|strong="H5975"\w* \w en|strong="H5975"\w* la \w cumbre|strong="H7218"\w* del \w monte|strong="H2022"\w* \w Gerizim|strong="H1630"\w*, y \w alzando|strong="H5375"\w* su \w voz|strong="H6963"\w* \w clamó|strong="H7121"\w* y les \w dijo|strong="H5046"\w*: “\w Oídme|strong="H8085"\w*, hombres de Siquem, y así os \w oiga|strong="H8085"\w* Dios.  
\v 8 \w Fueron|strong="H1980"\w* una vez \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* \w a|strong="H3068"\w* elegir \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w sí|strong="H5921"\w*, \w y|strong="H5921"\w* dijeron \w al|strong="H5921"\w* olivo: «\w Reina|strong="H4427"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*».   
\p
\v 9 \w Mas|strong="H5921"\w* \w el|strong="H5921"\w* olivo respondió: «¿He \w de|strong="H5921"\w* dejar \w mi|strong="H5921"\w* aceite, \w con|strong="H5921"\w* \w el|strong="H5921"\w* cual \w por|strong="H5921"\w* \w mí|strong="H5921"\w* \w se|strong="H5921"\w* \w honra|strong="H3513"\w* \w a|strong="H3068"\w* Dios \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* hombres, \w para|strong="H5921"\w* \w ir|strong="H1980"\w* \w a|strong="H3068"\w* ser grande \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*?».   
\p
\v 10 \w Y|strong="H3068"\w* dijeron \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* higuera: «\w Ven|strong="H3212"\w* tú, \w reina|strong="H4427"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*».   
\p
\v 11 \w Y|strong="H3068"\w* respondió \w la|strong="H5921"\w* higuera: «¿He \w de|strong="H5921"\w* dejar \w mi|strong="H5921"\w* dulzura \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w buen|strong="H2896"\w* \w fruto|strong="H8570"\w*, \w para|strong="H5921"\w* \w ir|strong="H1980"\w* \w a|strong="H3068"\w* ser grande \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*?».   
\p
\v 12 Dijeron luego \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w vid|strong="H1612"\w*: «\w Ven|strong="H3212"\w* tú, \w reina|strong="H4427"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*».   
\p
\v 13 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w vid|strong="H1612"\w* \w les|strong="H5921"\w* respondió: «¿He \w de|strong="H5921"\w* dejar \w mi|strong="H5921"\w* \w mosto|strong="H8492"\w*, \w que|strong="H5921"\w* \w alegra|strong="H8055"\w* \w a|strong="H3068"\w* Dios \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* hombres, \w para|strong="H5921"\w* \w ir|strong="H1980"\w* \w a|strong="H3068"\w* ser grande \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*?».   
\p
\v 14 Dijeron entonces \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* \w al|strong="H5921"\w* espino: «\w Ven|strong="H3212"\w* tú, \w reina|strong="H4427"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w*».   
\p
\v 15 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* espino respondió \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*: «\w Si|strong="H5921"\w* \w en|strong="H5921"\w* verdad \w me|strong="H4480"\w* ungís \w por|strong="H5921"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* vosotros, venid \w y|strong="H5921"\w* poneos \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w sombra|strong="H6738"\w*; \w y|strong="H5921"\w* \w si|strong="H5921"\w* \w no|strong="H5921"\w*, \w salga|strong="H3318"\w* fuego \w del|strong="H4480"\w* espino \w y|strong="H5921"\w* devore \w los|strong="H5921"\w* cedros \w del|strong="H4480"\w* \w Líbano|strong="H3844"\w*».   
\p
\v 16 «\w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, si \w con|strong="H5973"\w* verdad y \w con|strong="H5973"\w* integridad habéis procedido \w en|strong="H5973"\w* \w hacer|strong="H6213"\w* \w rey|strong="H4427"\w* \w a|strong="H3068"\w* Abimelec, y si habéis actuado \w bien|strong="H2895"\w* \w con|strong="H5973"\w* \w Jerobaal|strong="H3378"\w* y \w con|strong="H5973"\w* su \w casa|strong="H1004"\w*, y si \w le|strong="H5973"\w* habéis pagado conforme \w a|strong="H3068"\w* la \w obra|strong="H6213"\w* \w de|strong="H5973"\w* sus \w manos|strong="H3027"\w*  
\v 17 (pues \w mi|strong="H5921"\w* padre \w peleó|strong="H3898"\w* \w por|strong="H5921"\w* vosotros, \w y|strong="H5921"\w* expuso su \w vida|strong="H5315"\w* \w al|strong="H5921"\w* peligro \w para|strong="H5921"\w* \w libraros|strong="H5337"\w* \w de|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*,  
\v 18 \w y|strong="H3588"\w* vosotros \w os|strong="H5921"\w* habéis levantado \w hoy|strong="H3117"\w* \w contra|strong="H5921"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre, \w y|strong="H3588"\w* habéis matado \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*, \w setenta|strong="H7657"\w* \w varones|strong="H3588"\w*, \w sobre|strong="H5921"\w* una \w misma|strong="H1931"\w* piedra; \w y|strong="H3588"\w* habéis \w puesto|strong="H3588"\w* \w por|strong="H5921"\w* \w rey|strong="H4427"\w* \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w de|strong="H5921"\w* Siquem \w a|strong="H3068"\w* Abimelec, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* sierva, \w por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w es|strong="H1931"\w* vuestro hermano);  
\v 19 \w si|strong="H1571"\w*, \w pues|strong="H2088"\w*, \w con|strong="H5973"\w* verdad \w y|strong="H1571"\w* \w con|strong="H5973"\w* integridad habéis actuado \w hoy|strong="H3117"\w* \w con|strong="H5973"\w* \w Jerobaal|strong="H3378"\w* \w y|strong="H1571"\w* \w con|strong="H5973"\w* \w su|strong="H1931"\w* \w casa|strong="H1004"\w*, \w que|strong="H1931"\w* tengáis \w gozo|strong="H8055"\w* \w en|strong="H5973"\w* Abimelec, \w y|strong="H1571"\w* \w él|strong="H1931"\w* \w lo|strong="H1931"\w* tenga \w en|strong="H5973"\w* \w vosotros|strong="H5973"\w*.  
\v 20 \w Y|strong="H3068"\w* si no, fuego \w salga|strong="H3318"\w* de Abimelec \w que|strong="H7927"\w* devore \w a|strong="H3068"\w* \w los|strong="H1167"\w* de Siquem y \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de Milo, y fuego \w salga|strong="H3318"\w* de \w los|strong="H1167"\w* de Siquem y de la \w casa|strong="H1004"\w* de Milo \w que|strong="H7927"\w* consuma \w a|strong="H3068"\w* Abimelec».   
\p
\v 21 \w Y|strong="H3068"\w* Jotam \w huyó|strong="H1272"\w* y se puso \w a|strong="H3068"\w* salvo \w en|strong="H3212"\w* Beer\f + \fr 9:21 \ft «Beer» significa «pozo» en hebreo.\f*, y \w allí|strong="H8033"\w* \w estuvo|strong="H3427"\w* \w por|strong="H6440"\w* miedo \w de|strong="H6440"\w* Abimelec su hermano.   
\p
\v 22 \w Después|strong="H5921"\w* \w que|strong="H5921"\w* Abimelec hubo gobernado \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w tres|strong="H7969"\w* \w años|strong="H8141"\w*,  
\v 23 \w envió|strong="H7971"\w* Dios un \w espíritu|strong="H7307"\w* \w de|strong="H7451"\w* discordia entre Abimelec y \w los|strong="H1167"\w* hombres \w de|strong="H7451"\w* Siquem; y \w los|strong="H1167"\w* \w de|strong="H7451"\w* Siquem se rebelaron contra Abimelec,  
\v 24 \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w violencia|strong="H2555"\w* hecha \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w setenta|strong="H7657"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Jerobaal|strong="H3378"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w*, recayera \w sobre|strong="H5921"\w* Abimelec su hermano \w que|strong="H5921"\w* \w los|strong="H1121"\w* \w mató|strong="H2026"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H5921"\w* Siquem \w que|strong="H5921"\w* fortalecieron \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* aquel \w para|strong="H5921"\w* matar \w a|strong="H3068"\w* sus hermanos.  
\v 25 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* Siquem \w le|strong="H5921"\w* \w pusieron|strong="H7760"\w* emboscadas \w en|strong="H5921"\w* \w las|strong="H5921"\w* cumbres \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*, \w y|strong="H5921"\w* salteaban \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w pasaban|strong="H5674"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H5921"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*; \w de|strong="H5921"\w* \w lo|strong="H5921"\w* cual fue dado \w aviso|strong="H5046"\w* \w a|strong="H3068"\w* Abimelec.   
\p
\v 26 \w Y|strong="H3068"\w* \w Gaal|strong="H1603"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ebed|strong="H5651"\w* vino con sus hermanos y se \w pasaron|strong="H5674"\w* \w a|strong="H3068"\w* Siquem, y \w los|strong="H1121"\w* \w de|strong="H1121"\w* Siquem pusieron en \w él|strong="H1121"\w* su confianza.  
\v 27 \w Y|strong="H3068"\w* \w saliendo|strong="H3318"\w* al \w campo|strong="H7704"\w*, \w vendimiaron|strong="H1219"\w* sus \w viñas|strong="H3754"\w*, \w pisaron|strong="H1869"\w* la uva \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* fiesta; y entrando \w en|strong="H3318"\w* \w el|strong="H6213"\w* \w templo|strong="H1004"\w* de sus dioses, comieron y \w bebieron|strong="H8354"\w*, y maldijeron \w a|strong="H3068"\w* Abimelec.  
\v 28 \w Y|strong="H3068"\w* \w Gaal|strong="H1603"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Ebed|strong="H5651"\w* dijo: «¿\w Quién|strong="H4310"\w* \w es|strong="H3588"\w* Abimelec, \w y|strong="H3588"\w* \w qué|strong="H3588"\w* \w es|strong="H3588"\w* Siquem, \w para|strong="H3588"\w* \w que|strong="H3588"\w* nosotros \w le|strong="H4310"\w* \w sirvamos|strong="H5647"\w*? ¿\w No|strong="H3808"\w* \w es|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Jerobaal|strong="H3378"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w es|strong="H3588"\w* \w Zebul|strong="H2083"\w* \w su|strong="H3588"\w* oficial? \w Servid|strong="H5647"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* \w Hamor|strong="H2544"\w* padre \w de|strong="H3588"\w* Siquem; \w pero|strong="H3588"\w* ¿\w por|strong="H3588"\w* \w qué|strong="H3588"\w* hemos \w de|strong="H3588"\w* servirle \w a|strong="H3068"\w* \w él|strong="H3588"\w*?  
\v 29 ¡\w Ojalá|strong="H4310"\w* estuviera \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* bajo mi \w mano|strong="H3027"\w*, \w pues|strong="H2088"\w* yo arrojaría \w luego|strong="H3318"\w* \w a|strong="H3068"\w* Abimelec!». \w Y|strong="H3068"\w* decía \w a|strong="H3068"\w* Abimelec: «\w Aumenta|strong="H7235"\w* tu \w ejército|strong="H6635"\w*, y \w sal|strong="H3318"\w*».   
\p
\v 30 Cuando \w Zebul|strong="H2083"\w*, \w gobernador|strong="H8269"\w* \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w*, \w oyó|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* \w Gaal|strong="H1603"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ebed|strong="H5651"\w*, se encendió en ira,  
\v 31 \w y|strong="H5921"\w* \w envió|strong="H7971"\w* secretamente \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* Abimelec, diciendo: «He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w Gaal|strong="H1603"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Ebed|strong="H5651"\w* \w y|strong="H5921"\w* sus hermanos han venido \w a|strong="H3068"\w* Siquem, \w y|strong="H5921"\w* \w están|strong="H2009"\w* sublevando \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*.  
\v 32 \w Levántate|strong="H6965"\w*, \w pues|strong="H6258"\w*, \w ahora|strong="H6258"\w* \w de|strong="H5971"\w* \w noche|strong="H3915"\w*, tú y el \w pueblo|strong="H5971"\w* \w que|strong="H6258"\w* \w está|strong="H6965"\w* \w contigo|strong="H5971"\w*, y pon emboscadas en el \w campo|strong="H7704"\w*.  
\v 33 \w Y|strong="H3068"\w* \w por|strong="H5921"\w* \w la|strong="H1931"\w* \w mañana|strong="H1242"\w*, \w al|strong="H5921"\w* \w salir|strong="H3318"\w* \w el|strong="H1931"\w* \w sol|strong="H8121"\w*, \w levántate|strong="H7925"\w* \w y|strong="H5921"\w* arremete \w contra|strong="H5921"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w*; \w y|strong="H5921"\w* \w cuando|strong="H1961"\w* \w él|strong="H1931"\w* \w y|strong="H5921"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w con|strong="H5921"\w* \w él|strong="H1931"\w* \w salgan|strong="H3318"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w tú|strong="H6213"\w* \w harás|strong="H6213"\w* \w con|strong="H5921"\w* \w él|strong="H1931"\w* \w según|strong="H5921"\w* \w se|strong="H1961"\w* \w te|strong="H5921"\w* presentare \w la|strong="H1931"\w* ocasión».   
\p
\v 34 \w Levantóse|strong="H6965"\w*, pues, Abimelec \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w con|strong="H5973"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w* estaba, \w y|strong="H5921"\w* puso emboscada \w contra|strong="H5921"\w* Siquem repartido \w en|strong="H5921"\w* cuatro \w escuadrones|strong="H7218"\w*.  
\v 35 \w Y|strong="H3068"\w* \w Gaal|strong="H1603"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Ebed|strong="H5651"\w* \w salió|strong="H3318"\w*, y \w se|strong="H4480"\w* \w puso|strong="H5975"\w* \w a|strong="H3068"\w* la entrada \w de|strong="H4480"\w* la \w puerta|strong="H6607"\w* \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w*; y Abimelec y todo \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w* \w que|strong="H4480"\w* \w con|strong="H4480"\w* \w él|strong="H1121"\w* \w estaba|strong="H5975"\w* \w se|strong="H4480"\w* \w levantaron|strong="H6965"\w* \w de|strong="H4480"\w* la emboscada.   
\p
\v 36 \w Viendo|strong="H7200"\w* \w Gaal|strong="H1603"\w* al \w pueblo|strong="H5971"\w*, dijo \w a|strong="H3068"\w* \w Zebul|strong="H2083"\w*: «He \w aquí|strong="H2009"\w* \w gente|strong="H5971"\w* \w que|strong="H5971"\w* \w desciende|strong="H3381"\w* \w de|strong="H5971"\w* las cumbres \w de|strong="H5971"\w* los \w montes|strong="H2022"\w*». \w Y|strong="H3068"\w* \w Zebul|strong="H2083"\w* le respondió: «Tú \w ves|strong="H7200"\w* la \w sombra|strong="H6738"\w* \w de|strong="H5971"\w* los \w montes|strong="H2022"\w* como \w si|strong="H2009"\w* fueran hombres».   
\p
\v 37 \w Volvió|strong="H3254"\w* \w Gaal|strong="H1603"\w* \w a|strong="H3068"\w* \w hablar|strong="H1696"\w*, y \w dijo|strong="H1696"\w*: «He \w aquí|strong="H2009"\w* \w gente|strong="H5971"\w* \w que|strong="H5971"\w* \w desciende|strong="H3381"\w* \w por|strong="H1870"\w* \w el|strong="H5973"\w* centro \w de|strong="H5973"\w* la tierra, y un \w escuadrón|strong="H7218"\w* viene \w por|strong="H1870"\w* \w el|strong="H5973"\w* \w camino|strong="H1870"\w* \w de|strong="H5973"\w* la encina \w de|strong="H5973"\w* \w los|strong="H5973"\w* adivinos».   
\p
\v 38 \w Y|strong="H3068"\w* \w Zebul|strong="H2083"\w* \w le|strong="H4310"\w* respondió: “¿Dónde \w está|strong="H2088"\w* \w ahora|strong="H6258"\w* \w aquel|strong="H2088"\w* tu hablar \w de|strong="H3588"\w*: «¿\w Quién|strong="H4310"\w* \w es|strong="H2088"\w* Abimelec \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w le|strong="H4310"\w* \w sirvamos|strong="H5647"\w*?». ¿\w No|strong="H3808"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* tenías \w en|strong="H3588"\w* poco? \w Sal|strong="H3318"\w* \w pues|strong="H3588"\w*, \w ahora|strong="H6258"\w*, \w y|strong="H3588"\w* \w pelea|strong="H3898"\w* contra \w él|strong="H3588"\w*”.   
\p
\v 39 \w Y|strong="H3068"\w* \w Gaal|strong="H1603"\w* \w salió|strong="H3318"\w* al frente \w de|strong="H6440"\w* \w los|strong="H1167"\w* hombres \w de|strong="H6440"\w* Siquem, y \w peleó|strong="H3898"\w* \w contra|strong="H6440"\w* Abimelec.  
\v 40 \w Mas|strong="H7227"\w* Abimelec \w lo|strong="H5704"\w* \w persiguió|strong="H7291"\w*, \w y|strong="H5704"\w* Gaal \w huyó|strong="H5127"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H5307"\w*; \w y|strong="H5704"\w* \w cayeron|strong="H5307"\w* \w muchos|strong="H7227"\w* \w heridos|strong="H2491"\w* \w hasta|strong="H5704"\w* la entrada \w de|strong="H6440"\w* la \w puerta|strong="H6607"\w*.  
\v 41 \w Y|strong="H3068"\w* Abimelec se \w quedó|strong="H3427"\w* en Aruma; y \w Zebul|strong="H2083"\w* \w echó|strong="H1644"\w* fuera \w a|strong="H3068"\w* \w Gaal|strong="H1603"\w* y \w a|strong="H3068"\w* sus hermanos, para \w que|strong="H7927"\w* no morasen en Siquem.  
\v 42 Al día \w siguiente|strong="H4283"\w* el \w pueblo|strong="H5971"\w* \w salió|strong="H3318"\w* al \w campo|strong="H7704"\w*; y \w fue|strong="H1961"\w* dado \w aviso|strong="H5046"\w* \w a|strong="H3068"\w* Abimelec.  
\v 43 \w Él|strong="H5921"\w* entonces, \w tomando|strong="H3947"\w* \w gente|strong="H5971"\w*, \w la|strong="H5921"\w* repartió \w en|strong="H5921"\w* \w tres|strong="H7969"\w* \w escuadrones|strong="H7218"\w* \w y|strong="H5921"\w* puso emboscadas \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campo|strong="H7704"\w*; \w y|strong="H5921"\w* cuando \w vio|strong="H7200"\w* \w que|strong="H4480"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w salía|strong="H3318"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w hirió|strong="H5221"\w*.  
\v 44 \w Porque|strong="H5921"\w* Abimelec \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w escuadrón|strong="H7218"\w* \w que|strong="H5921"\w* \w estaba|strong="H5975"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w acometieron|strong="H6584"\w* \w con|strong="H5973"\w* ímpetu \w y|strong="H5921"\w* \w se|strong="H5921"\w* situaron \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w mientras|strong="H3605"\w* \w los|strong="H5921"\w* otros \w dos|strong="H8147"\w* \w escuadrones|strong="H7218"\w* acometían \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w estaban|strong="H5975"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campo|strong="H7704"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* herían.  
