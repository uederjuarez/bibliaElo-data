\v 12 También los de Sidón, los de \w Amalec|strong="H6002"\w* y los de \w Maón|strong="H4584"\w* os oprimieron, y clamando \w a|strong="H3068"\w* mí, ¿no os libré de sus \w manos|strong="H3027"\w*?  
\v 13 \w Mas|strong="H3254"\w* vosotros me habéis dejado y habéis servido \w a|strong="H3068"\w* otros dioses; \w por|strong="H3651"\w* \w tanto|strong="H3651"\w*, yo \w no|strong="H3808"\w* os \w libraré|strong="H3467"\w* \w más|strong="H3254"\w*.  
\v 14 \w Id|strong="H3212"\w* y clamad \w a|strong="H3068"\w* \w los|strong="H1992"\w* dioses \w que|strong="H6256"\w* habéis elegido; \w que|strong="H6256"\w* os libren \w ellos|strong="H1992"\w* \w en|strong="H3212"\w* \w el|strong="H1992"\w* \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* vuestra \w aflicción|strong="H6869"\w*».   
\p
\v 15 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* respondieron \w a|strong="H3068"\w* Yahvé: «Hemos \w pecado|strong="H2398"\w*; \w haz|strong="H6213"\w* \w tú|strong="H6213"\w* con \w nosotros|strong="H3605"\w* como \w bien|strong="H2896"\w* \w te|strong="H5869"\w* parezca; solo \w te|strong="H5869"\w* rogamos \w que|strong="H4994"\w* nos \w libres|strong="H5337"\w* en \w este|strong="H2088"\w* \w día|strong="H3117"\w*».  
\v 16 \w Y|strong="H3068"\w* \w quitaron|strong="H5493"\w* de \w entre|strong="H7130"\w* \w sí|strong="H5315"\w* los dioses \w ajenos|strong="H5236"\w* y \w sirvieron|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé; y su \w alma|strong="H5315"\w* fue movida \w a|strong="H3068"\w* lástima por la miseria de \w Israel|strong="H3478"\w*.   
\p
\v 17 Entonces se juntaron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón y acamparon en \w Galaad|strong="H1568"\w*; y se juntaron asimismo \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y acamparon en \w Mizpa|strong="H4709"\w*.  
\v 18 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w los|strong="H3427"\w* \w príncipes|strong="H8269"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, dijeron unos \w a|strong="H3068"\w* otros: «¿\w Quién|strong="H4310"\w* \w será|strong="H1961"\w* \w el|strong="H3605"\w* \w que|strong="H4310"\w* \w comenzará|strong="H2490"\w* \w la|strong="H3605"\w* batalla \w contra|strong="H1961"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón? \w Él|strong="H3605"\w* \w será|strong="H1961"\w* \w cabeza|strong="H7218"\w* \w sobre|strong="H1961"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*».   
\c 11
\p
\v 1 Jefté \w galaadita|strong="H1569"\w* \w era|strong="H1961"\w* \w esforzado|strong="H2428"\w* y \w valiente|strong="H1368"\w*; \w era|strong="H1961"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* una mujer \w ramera|strong="H2181"\w*, y \w el|strong="H1931"\w* padre \w de|strong="H1121"\w* Jefté \w era|strong="H1961"\w* \w Galaad|strong="H1568"\w*.  
\v 2 \w Pero|strong="H3588"\w* \w la|strong="H3588"\w* mujer \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* le dio \w hijos|strong="H1121"\w*, \w los|strong="H1121"\w* cuales, \w cuando|strong="H3588"\w* crecieron, echaron fuera \w a|strong="H3068"\w* Jefté, diciéndole: «\w No|strong="H3808"\w* \w heredarás|strong="H5157"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* nuestro padre, \w porque|strong="H3588"\w* eres \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* otra mujer».  
\v 3 \w Huyó|strong="H1272"\w*, pues, Jefté \w de|strong="H6440"\w* sus hermanos, y \w habitó|strong="H3427"\w* \w en|strong="H5973"\w* tierra \w de|strong="H6440"\w* Tob; y se juntaron \w con|strong="H5973"\w* \w él|strong="H5973"\w* hombres \w ociosos|strong="H7386"\w*, \w los|strong="H3427"\w* cuales \w salían|strong="H3318"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*.   
\p
\v 4 \w Aconteció|strong="H1961"\w* andando \w el|strong="H5973"\w* \w tiempo|strong="H3117"\w*, \w que|strong="H3117"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Amón hicieron \w guerra|strong="H3898"\w* \w contra|strong="H5973"\w* \w Israel|strong="H3478"\w*.  
\v 5 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Amón hicieron \w guerra|strong="H3898"\w* \w contra|strong="H5973"\w* \w Israel|strong="H3478"\w*, \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w* \w fueron|strong="H1961"\w* \w a|strong="H3068"\w* traer \w a|strong="H3068"\w* Jefté \w de|strong="H5973"\w* la tierra \w de|strong="H5973"\w* Tob;  
\v 6 y dijeron \w a|strong="H3068"\w* Jefté: «\w Ven|strong="H3212"\w*, y \w serás|strong="H1961"\w* nuestro jefe, \w para|strong="H1961"\w* \w que|strong="H1121"\w* peleemos \w contra|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón».   
\p
\v 7 Jefté \w respondió|strong="H3316"\w* \w a|strong="H3068"\w* los \w ancianos|strong="H2205"\w* de \w Galaad|strong="H1568"\w*: «¿\w No|strong="H3808"\w* me habéis odiado vosotros, y me \w echasteis|strong="H1644"\w* de la \w casa|strong="H1004"\w* de mi padre? ¿\w Por|strong="H4069"\w* \w qué|strong="H3808"\w*, \w pues|strong="H6258"\w*, venís \w ahora|strong="H6258"\w* \w a|strong="H3068"\w* mí cuando estáis en \w aflicción|strong="H6862"\w*?».   
\p
\v 8 \w Y|strong="H3068"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w* \w respondieron|strong="H7725"\w* \w a|strong="H3068"\w* Jefté: «\w Por|strong="H3651"\w* \w esta|strong="H1961"\w* misma causa volvemos \w ahora|strong="H6258"\w* \w a|strong="H3068"\w* \w ti|strong="H5973"\w*, \w para|strong="H1961"\w* \w que|strong="H6258"\w* vengas \w con|strong="H5973"\w* \w nosotros|strong="H3605"\w* y pelees \w contra|strong="H5973"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Amón, y \w seas|strong="H1961"\w* nuestro \w caudillo|strong="H7218"\w* \w sobre|strong="H1961"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w*».   
\p
\v 9 Jefté \w entonces|strong="H7725"\w* dijo \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H6440"\w* \w Galaad|strong="H1568"\w*: «\w Si|strong="H6440"\w* me hacéis \w volver|strong="H7725"\w* \w para|strong="H5414"\w* \w que|strong="H1121"\w* pelee \w contra|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* Amón, y Yahvé \w los|strong="H1121"\w* \w entregare|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H1961"\w*, ¿\w seré|strong="H1961"\w* yo vuestro \w caudillo|strong="H7218"\w*?».   
\p
\v 10 \w Y|strong="H3068"\w* \w los|strong="H1961"\w* \w ancianos|strong="H2205"\w* \w de|strong="H1697"\w* \w Galaad|strong="H1568"\w* respondieron \w a|strong="H3068"\w* Jefté: «Yahvé \w sea|strong="H1961"\w* testigo \w entre|strong="H3808"\w* nosotros, \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w hiciéremos|strong="H6213"\w* \w como|strong="H1961"\w* \w tú|strong="H6213"\w* \w dices|strong="H1697"\w*».   
\p
\v 11 Entonces Jefté \w vino|strong="H3212"\w* \w con|strong="H5973"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w lo|strong="H1697"\w* \w puso|strong="H7760"\w* \w por|strong="H5921"\w* su \w caudillo|strong="H7218"\w* \w y|strong="H5921"\w* \w jefe|strong="H7218"\w*; \w y|strong="H5921"\w* Jefté \w habló|strong="H1696"\w* \w todas|strong="H3605"\w* sus \w palabras|strong="H1697"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé \w en|strong="H5921"\w* \w Mizpa|strong="H4709"\w*.   
\p
\v 12 \w Y|strong="H3068"\w* \w envió|strong="H7971"\w* Jefté \w mensajeros|strong="H4397"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* amonitas, diciendo: «¿\w Qué|strong="H3588"\w* tienes tú conmigo, \w para|strong="H3588"\w* \w que|strong="H3588"\w* vengas \w a|strong="H3068"\w* pelear contra mi tierra?».   
\p
\v 13 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* amonitas \w respondió|strong="H7725"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w mensajeros|strong="H4397"\w* \w de|strong="H3588"\w* Jefté: «\w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w Israel|strong="H3478"\w* \w tomó|strong="H3947"\w* mi tierra, \w cuando|strong="H3588"\w* \w subió|strong="H5927"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w desde|strong="H5704"\w* \w el|strong="H3588"\w* Arnón \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w Jaboc|strong="H2999"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w Jordán|strong="H3383"\w*; \w por|strong="H3588"\w* tanto, devuélvela \w ahora|strong="H6258"\w* \w en|strong="H5704"\w* \w paz|strong="H7965"\w*».   
\p
\v 14 \w Y|strong="H3068"\w* Jefté \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* enviar \w otros|strong="H5750"\w* \w mensajeros|strong="H4397"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H5750"\w* \w los|strong="H1121"\w* amonitas,  
\v 15 para decirle: “Jefté \w ha|strong="H3541"\w* dicho \w así|strong="H3541"\w*: \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* \w tomó|strong="H3947"\w* tierra \w de|strong="H1121"\w* \w Moab|strong="H4124"\w*, \w ni|strong="H3808"\w* tierra \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón.  
\v 16 \w Porque|strong="H3588"\w* \w cuando|strong="H3588"\w* \w Israel|strong="H3478"\w* \w subió|strong="H5927"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w anduvo|strong="H3212"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w Mar|strong="H3220"\w* Rojo, \w y|strong="H3588"\w* \w llegó|strong="H5704"\w* \w a|strong="H3068"\w* \w Cades|strong="H6946"\w*.  
\v 17 \w Entonces|strong="H1571"\w* \w Israel|strong="H3478"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de Edom, diciendo: «\w Yo|strong="H4994"\w* te \w ruego|strong="H4994"\w* \w que|strong="H3808"\w* me dejes \w pasar|strong="H5674"\w* \w por|strong="H4428"\w* tu tierra»; pero \w el|strong="H5674"\w* \w rey|strong="H4428"\w* de Edom \w no|strong="H3808"\w* \w los|strong="H3427"\w* \w escuchó|strong="H8085"\w*. \w Envió|strong="H7971"\w* \w también|strong="H1571"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de \w Moab|strong="H4124"\w*, \w el|strong="H5674"\w* cual \w tampoco|strong="H1571"\w* quiso; \w se|strong="H3808"\w* \w quedó|strong="H3427"\w*, \w por|strong="H4428"\w* tanto, \w Israel|strong="H3478"\w* en \w Cades|strong="H6946"\w*.  
\v 18 Después, \w yendo|strong="H3212"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*, \w rodeó|strong="H5437"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* Edom \w y|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*, \w y|strong="H3588"\w* viniendo \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w lado|strong="H5676"\w* \w oriental|strong="H4217"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*, acampó al otro \w lado|strong="H5676"\w* del Arnón; \w y|strong="H3588"\w* \w no|strong="H3808"\w* entró \w en|strong="H3588"\w* \w el|strong="H3588"\w* territorio \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* Arnón \w es|strong="H3588"\w* frontera \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*.   
\p
\v 19 \w Y|strong="H3068"\w* \w envió|strong="H7971"\w* \w Israel|strong="H3478"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* \w Sehón|strong="H5511"\w* \w rey|strong="H4428"\w* \w de|strong="H5704"\w* los amorreos, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Hesbón|strong="H2809"\w*, diciéndole: «Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* nos dejes \w pasar|strong="H5674"\w* \w por|strong="H5704"\w* tu tierra \w hasta|strong="H5704"\w* nuestro \w lugar|strong="H4725"\w*».  
\v 20 \w Mas|strong="H3808"\w* \w Sehón|strong="H5511"\w* \w no|strong="H3808"\w* fío \w de|strong="H5973"\w* \w Israel|strong="H3478"\w* \w para|strong="H5973"\w* darle \w paso|strong="H5674"\w* por su territorio, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* reunió \w Sehón|strong="H5511"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* su \w gente|strong="H5971"\w*, y acampó \w en|strong="H5973"\w* Jahaza y \w peleó|strong="H3898"\w* \w contra|strong="H5973"\w* \w Israel|strong="H3478"\w*.  
\v 21 Pero Yahvé \w Dios|strong="H3068"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* \w Sehón|strong="H5511"\w* y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w en|strong="H5221"\w* \w mano|strong="H3027"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*, y \w los|strong="H3427"\w* \w hirió|strong="H5221"\w*; y \w poseyó|strong="H3423"\w* \w Israel|strong="H3478"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5971"\w* \w los|strong="H3427"\w* amorreos \w que|strong="H1931"\w* \w habitaban|strong="H3427"\w* \w en|strong="H5221"\w* \w aquella|strong="H1931"\w* región.  
\v 22 \w Poseyeron|strong="H3423"\w* también \w todo|strong="H3605"\w* \w el|strong="H3605"\w* territorio \w del|strong="H4480"\w* amorreo \w desde|strong="H4480"\w* \w el|strong="H3605"\w* Arnón \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w Jaboc|strong="H2999"\w*, \w y|strong="H5704"\w* \w desde|strong="H4480"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w*.  
\v 23 \w Así|strong="H6258"\w* \w que|strong="H6258"\w*, lo \w que|strong="H6258"\w* Yahvé \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* quitó al amorreo \w delante|strong="H6440"\w* \w de|strong="H6440"\w* su \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, ¿pretendes tú poseerlo?  
\v 24 \w Lo|strong="H3808"\w* \w que|strong="H3808"\w* te hiciere poseer Quemos tu \w dios|strong="H3068"\w*, ¿\w no|strong="H3808"\w* \w lo|strong="H3808"\w* poseerías tú? Así, \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* desposeyó Yahvé nuestro \w Dios|strong="H3068"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w nosotros|strong="H3605"\w*, \w nosotros|strong="H3605"\w* \w lo|strong="H3808"\w* poseeremos.  
\v 25 ¿Eres tú \w ahora|strong="H6258"\w* \w mejor|strong="H2896"\w* \w en|strong="H5973"\w* algo \w que|strong="H6258"\w* \w Balac|strong="H1111"\w* \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Zipor, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* \w Moab|strong="H4124"\w*? ¿Tuvo \w él|strong="H5973"\w* altercado \w con|strong="H5973"\w* \w Israel|strong="H3478"\w*, \w o|strong="H3068"\w* \w peleó|strong="H3898"\w* \w contra|strong="H5973"\w* ellos?  
\v 26 \w Cuando|strong="H6256"\w* \w Israel|strong="H3478"\w* \w ha|strong="H3808"\w* estado habitando \w en|strong="H5921"\w* \w Hesbón|strong="H2809"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w sus|strong="H1931"\w* \w aldeas|strong="H1323"\w*, \w en|strong="H5921"\w* \w Aroer|strong="H6177"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w sus|strong="H1931"\w* \w aldeas|strong="H1323"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w que|strong="H1931"\w* \w están|strong="H3427"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* ribera \w del|strong="H5921"\w* Arnón \w por|strong="H5921"\w* \w trescientos|strong="H7969"\w* \w años|strong="H8141"\w*, ¿\w por|strong="H5921"\w* \w qué|strong="H1931"\w* \w no|strong="H3808"\w* \w las|strong="H5921"\w* habéis recobrado \w en|strong="H5921"\w* \w ese|strong="H1931"\w* \w tiempo|strong="H6256"\w*?  
\v 27 Así \w que|strong="H3808"\w*, \w yo|strong="H6213"\w* \w nada|strong="H3808"\w* he \w pecado|strong="H2398"\w* \w contra|strong="H3478"\w* ti, \w mas|strong="H3808"\w* \w tú|strong="H8199"\w* \w haces|strong="H6213"\w* \w mal|strong="H7451"\w* \w conmigo|strong="H6213"\w* dándome \w guerra|strong="H3898"\w*. Yahvé, \w que|strong="H3808"\w* es \w el|strong="H1121"\w* \w Juez|strong="H8199"\w*, \w juzgue|strong="H8199"\w* \w hoy|strong="H3117"\w* \w entre|strong="H3808"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón”.   
\p
\v 28 \w Mas|strong="H3808"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón \w no|strong="H3808"\w* \w atendió|strong="H8085"\w* \w a|strong="H3068"\w* las \w razones|strong="H1697"\w* \w que|strong="H3808"\w* Jefté le \w envió|strong="H7971"\w*.  
\v 29 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Yahvé \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* Jefté; \w y|strong="H5921"\w* recorrió \w Galaad|strong="H1568"\w* \w y|strong="H5921"\w* \w Manasés|strong="H4519"\w*, \w y|strong="H5921"\w* \w de|strong="H5921"\w* allí \w pasó|strong="H5674"\w* \w a|strong="H3068"\w* Mizpa \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*, \w y|strong="H5921"\w* \w de|strong="H5921"\w* Mizpa \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w* \w pasó|strong="H5674"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón.   
\p
\v 30 \w Y|strong="H3068"\w* Jefté \w hizo|strong="H5088"\w* \w voto|strong="H5087"\w* \w a|strong="H3068"\w* Yahvé, diciendo: «Si \w entregares|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* amonitas en \w mis|strong="H5414"\w* \w manos|strong="H3027"\w*,  
\v 31 \w cualquiera|strong="H3318"\w* \w que|strong="H1121"\w* \w saliere|strong="H3318"\w* \w de|strong="H1121"\w* las \w puertas|strong="H1817"\w* \w de|strong="H1121"\w* \w mi|strong="H1961"\w* \w casa|strong="H1004"\w* \w a|strong="H3068"\w* recibirme, \w cuando|strong="H1961"\w* regrese victorioso \w de|strong="H1121"\w* \w los|strong="H1121"\w* amonitas, \w será|strong="H1961"\w* \w de|strong="H1121"\w* Yahvé, y lo \w ofreceré|strong="H5927"\w* \w en|strong="H3318"\w* \w holocausto|strong="H5930"\w*».   
\p
\v 32 \w Y|strong="H3068"\w* \w pasó|strong="H5674"\w* Jefté \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón \w para|strong="H5414"\w* pelear contra \w ellos|strong="H3027"\w*; y Yahvé \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* en su \w mano|strong="H3027"\w*.  
\v 33 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* derrotó \w con|strong="H5704"\w* \w muy|strong="H3966"\w* \w grande|strong="H1419"\w* matanza \w desde|strong="H5704"\w* \w Aroer|strong="H6177"\w* \w hasta|strong="H5704"\w* llegar \w a|strong="H3068"\w* Minit, \w veinte|strong="H6242"\w* \w ciudades|strong="H5892"\w*, \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* Abel-queramim. Así fueron sometidos \w los|strong="H1121"\w* amonitas \w por|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.   
\p
\v 34 Entonces volvió Jefté \w a|strong="H3068"\w* \w Mizpa|strong="H4709"\w*, \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w casa|strong="H1004"\w*; y he \w aquí|strong="H2009"\w* \w su|strong="H1931"\w* \w hija|strong="H1323"\w* \w que|strong="H4480"\w* \w salía|strong="H3318"\w* \w a|strong="H3068"\w* recibirle \w con|strong="H4480"\w* panderos y danzas, y \w ella|strong="H1931"\w* \w era|strong="H1931"\w* sola, \w su|strong="H1931"\w* única \w hija|strong="H1323"\w*; no \w tenía|strong="H1931"\w* \w fuera|strong="H4480"\w* \w de|strong="H4480"\w* \w ella|strong="H1931"\w* \w hijo|strong="H1121"\w* ni \w hija|strong="H1323"\w*.  
\v 35 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* él la \w vio|strong="H7200"\w*, \w rompió|strong="H7167"\w* sus vestidos, diciendo: «¡Ay, \w hija|strong="H1323"\w* mía! En verdad me has abatido, y tú misma has venido \w a|strong="H3068"\w* ser causa de \w mi|strong="H1961"\w* dolor; \w porque|strong="H3808"\w* yo he abierto \w mi|strong="H1961"\w* \w boca|strong="H6310"\w* \w a|strong="H3068"\w* Yahvé, y \w no|strong="H3808"\w* \w podré|strong="H3201"\w* \w retractarme|strong="H7725"\w*».   
\p
\v 36 Ella entonces le respondió: «Padre mío, si has abierto \w tu|strong="H6213"\w* \w boca|strong="H6310"\w* \w a|strong="H3068"\w* Yahvé, \w haz|strong="H6213"\w* \w de|strong="H1121"\w* mí \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* prometiste, ya \w que|strong="H1121"\w* Yahvé ha \w hecho|strong="H6213"\w* \w venganza|strong="H5360"\w* \w de|strong="H1121"\w* tus enemigos \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón».  
\v 37 \w Y|strong="H3068"\w* volvió \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* su padre: «Hágase \w esto|strong="H2088"\w* \w por|strong="H5921"\w* \w mí|strong="H5921"\w*: \w déjame|strong="H7503"\w* \w por|strong="H5921"\w* \w dos|strong="H8147"\w* \w meses|strong="H2320"\w*, \w para|strong="H5921"\w* \w que|strong="H4480"\w* \w vaya|strong="H3212"\w* \w y|strong="H5921"\w* \w descienda|strong="H3381"\w* \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*, \w y|strong="H5921"\w* \w llore|strong="H1058"\w* \w mi|strong="H5921"\w* virginidad, \w yo|strong="H4480"\w* \w y|strong="H5921"\w* mis compañeras».   
\p
\v 38 \w Él|strong="H1931"\w* respondió: «\w Ve|strong="H3212"\w*». \w Y|strong="H3068"\w* \w la|strong="H1931"\w* \w dejó|strong="H7971"\w* \w por|strong="H5921"\w* \w dos|strong="H8147"\w* \w meses|strong="H2320"\w*. \w Y|strong="H3068"\w* \w ella|strong="H1931"\w* \w fue|strong="H3212"\w* \w con|strong="H5921"\w* \w sus|strong="H1931"\w* compañeras, \w y|strong="H5921"\w* \w lloró|strong="H1058"\w* \w su|strong="H1931"\w* virginidad \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*.  
\v 39 \w Pasados|strong="H1961"\w* \w los|strong="H1931"\w* \w dos|strong="H8147"\w* \w meses|strong="H2320"\w*, \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w él|strong="H1931"\w* de \w ella|strong="H1931"\w* \w conforme|strong="H1931"\w* al \w voto|strong="H5087"\w* \w que|strong="H1931"\w* \w había|strong="H1961"\w* \w hecho|strong="H6213"\w*. \w Y|strong="H3068"\w* \w ella|strong="H1931"\w* \w nunca|strong="H3808"\w* \w conoció|strong="H3045"\w* varón.  
\v 40 \w Y|strong="H3068"\w* se hizo costumbre \w en|strong="H3212"\w* \w Israel|strong="H3478"\w*, \w que|strong="H3117"\w* de \w año|strong="H8141"\w* \w en|strong="H3212"\w* \w año|strong="H8141"\w* fuesen las doncellas de \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* llorar \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* de Jefté \w galaadita|strong="H1569"\w*, cuatro \w días|strong="H3117"\w* \w en|strong="H3212"\w* el \w año|strong="H8141"\w*.   
\c 12
\p
\v 1 \w Los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H5921"\w* Efraín \w se|strong="H5921"\w* reunieron \w y|strong="H5921"\w* \w pasaron|strong="H5674"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w norte|strong="H6828"\w*, \w y|strong="H5921"\w* dijeron \w a|strong="H3068"\w* Jefté: «¿\w Por|strong="H5921"\w* \w qué|strong="H3808"\w* pasaste \w a|strong="H3068"\w* pelear \w contra|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w nos|strong="H5921"\w* llamaste \w para|strong="H5921"\w* \w que|strong="H3808"\w* fuéramos \w contigo|strong="H5973"\w*? Quemaremos tu \w casa|strong="H1004"\w* \w contigo|strong="H5973"\w* \w dentro|strong="H5921"\w*».   
\p
\v 2 Jefté les \w respondió|strong="H3316"\w*: «Yo y \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* teníamos una \w gran|strong="H3966"\w* \w contienda|strong="H7379"\w* con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón; y \w cuando|strong="H1961"\w* os llamé, \w no|strong="H3808"\w* me librasteis \w de|strong="H1121"\w* su \w mano|strong="H3027"\w*.  
\v 3 \w Viendo|strong="H7200"\w*, \w pues|strong="H3588"\w*, \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w me|strong="H3588"\w* librabais, arriesgué \w mi|strong="H5315"\w* \w vida|strong="H5315"\w* \w y|strong="H3588"\w* \w pasé|strong="H5674"\w* contra \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Amón, \w y|strong="H3588"\w* Yahvé \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* \w en|strong="H3588"\w* \w mi|strong="H5315"\w* \w mano|strong="H3027"\w*. ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w*, \w pues|strong="H3588"\w*, habéis \w subido|strong="H5927"\w* \w hoy|strong="H3117"\w* contra \w mí|strong="H5315"\w* \w para|strong="H3588"\w* pelear conmigo?».   
\p
\v 4 \w Entonces|strong="H3588"\w* Jefté \w juntó|strong="H6908"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* \w y|strong="H3588"\w* \w peleó|strong="H3898"\w* contra Efraín; \w y|strong="H3588"\w* \w los|strong="H3605"\w* \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* \w hirieron|strong="H5221"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w de|strong="H3588"\w* Efraín, \w porque|strong="H3588"\w* \w estos|strong="H3605"\w* habían dicho: «Vosotros, \w los|strong="H3605"\w* galaaditas, sois fugitivos \w de|strong="H3588"\w* Efraín \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* Efraín \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w*».  
\v 5 \w Y|strong="H3068"\w* \w los|strong="H1961"\w* galaaditas \w tomaron|strong="H3920"\w* \w los|strong="H1961"\w* vados del \w Jordán|strong="H3383"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w de|strong="H3588"\w* Efraín; \w y|strong="H3588"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* alguno \w de|strong="H3588"\w* \w los|strong="H1961"\w* fugitivos \w de|strong="H3588"\w* Efraín decía: «Dejadme \w pasar|strong="H5674"\w*», \w los|strong="H1961"\w* hombres \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* le preguntaban: «¿\w Eres|strong="H1961"\w* tú efraimita?». \w Si|strong="H3588"\w* \w él|strong="H3588"\w* respondía: «\w No|strong="H3808"\w*»,  
\v 6 \w entonces|strong="H6256"\w* \w le|strong="H1931"\w* decían: «\w Pues|strong="H3651"\w* \w di|strong="H1696"\w* \w ahora|strong="H4994"\w* Schibboleth»; y \w él|strong="H1931"\w* decía «Sibboleth», \w porque|strong="H3808"\w* \w no|strong="H3808"\w* \w podía|strong="H3559"\w* pronunciarlo correctamente. \w Entonces|strong="H6256"\w* \w le|strong="H1931"\w* echaban \w mano|strong="H1931"\w* y \w lo|strong="H1931"\w* \w degollaban|strong="H7819"\w* en \w los|strong="H1931"\w* vados del \w Jordán|strong="H3383"\w*. \w Y|strong="H3068"\w* \w murieron|strong="H5307"\w* en \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* cuarenta y \w dos|strong="H8147"\w* mil \w de|strong="H6256"\w* \w los|strong="H1931"\w* \w de|strong="H6256"\w* Efraín.   
\p
\v 7 Jefté \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w seis|strong="H8337"\w* \w años|strong="H8141"\w*; y \w murió|strong="H4191"\w* Jefté \w galaadita|strong="H1569"\w*, y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* una de las \w ciudades|strong="H5892"\w* de \w Galaad|strong="H1568"\w*.   
\p
\v 8 Después de él \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* Ibzán de Belén,  
\v 9 \w el|strong="H1121"\w* cual \w tuvo|strong="H1961"\w* \w treinta|strong="H7970"\w* \w hijos|strong="H1121"\w* y \w treinta|strong="H7970"\w* \w hijas|strong="H1323"\w*; \w a|strong="H3068"\w* estas \w envió|strong="H7971"\w* \w fuera|strong="H2351"\w*, y tomó \w treinta|strong="H7970"\w* \w hijas|strong="H1323"\w* \w de|strong="H4480"\w* \w fuera|strong="H2351"\w* \w para|strong="H4480"\w* sus \w hijos|strong="H1121"\w*. \w Y|strong="H3068"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w*.  
\v 10 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* Ibzán, y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* Belén.   
\p
\v 11 Tras él \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* Elón \w zabulonita|strong="H2075"\w*, el cual \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w diez|strong="H6235"\w* \w años|strong="H8141"\w*.  
\v 12 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* Elón \w zabulonita|strong="H2075"\w*, y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* Ajalón, \w en|strong="H6912"\w* la tierra de \w Zabulón|strong="H2074"\w*.   
\p
\v 13 Tras \w él|strong="H1121"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w Abdón|strong="H5658"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hilel, \w piratonita|strong="H6553"\w*.  
\v 14 \w Este|strong="H1961"\w* \w tuvo|strong="H1961"\w* cuarenta \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* \w treinta|strong="H7970"\w* \w nietos|strong="H1121"\w*, \w que|strong="H5921"\w* cabalgaban \w sobre|strong="H5921"\w* \w setenta|strong="H7657"\w* \w asnos|strong="H5895"\w*. \w Y|strong="H3068"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w ocho|strong="H8083"\w* \w años|strong="H8141"\w*.  
\v 15 \w Y|strong="H3068"\w* \w murió|strong="H4191"\w* \w Abdón|strong="H5658"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hilel \w piratonita|strong="H6553"\w*, y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* Piratón, \w en|strong="H6912"\w* la tierra \w de|strong="H1121"\w* Efraín, \w en|strong="H6912"\w* \w el|strong="H1121"\w* \w monte|strong="H2022"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* amalecitas.   
\c 13
\p
\v 1 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* volvieron \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H1121"\w* Yahvé; y Yahvé \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w por|strong="H3027"\w* cuarenta \w años|strong="H8141"\w*.   
\p
\v 2 \w Y|strong="H3068"\w* \w había|strong="H1961"\w* un hombre de Zora, de la \w familia|strong="H4940"\w* de \w Dan|strong="H1839"\w*, el cual \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* \w Manoa|strong="H4495"\w*; y su mujer \w era|strong="H1961"\w* estéril, y \w nunca|strong="H3808"\w* \w había|strong="H1961"\w* tenido hijos.  
\v 3 \w A|strong="H3068"\w* esta mujer \w se|strong="H3808"\w* le \w apareció|strong="H7200"\w* \w el|strong="H1121"\w* \w Ángel|strong="H4397"\w* \w de|strong="H1121"\w* Yahvé, y le dijo: «He \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* tú eres estéril, y \w nunca|strong="H3808"\w* has tenido \w hijos|strong="H1121"\w*; pero concebirás y darás \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*.  
\v 4 \w Ahora|strong="H6258"\w*, \w pues|strong="H4994"\w*, \w guárdate|strong="H8104"\w*, te \w ruego|strong="H4994"\w*, de \w beber|strong="H8354"\w* \w vino|strong="H3196"\w* \w ni|strong="H6258"\w* \w sidra|strong="H7941"\w*, \w ni|strong="H6258"\w* comas \w cosa|strong="H3605"\w* \w inmunda|strong="H2931"\w*.  
\v 5 \w Pues|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* concebirás \w y|strong="H3588"\w* darás \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*; \w y|strong="H3588"\w* \w no|strong="H3808"\w* pasará \w navaja|strong="H4177"\w* \w por|strong="H5921"\w* \w su|strong="H1931"\w* \w cabeza|strong="H7218"\w*, \w porque|strong="H3588"\w* \w el|strong="H1931"\w* \w niño|strong="H5288"\w* \w será|strong="H1961"\w* \w nazareo|strong="H5139"\w* \w a|strong="H3068"\w* Dios \w desde|strong="H4480"\w* \w el|strong="H1931"\w* vientre; \w y|strong="H3588"\w* \w él|strong="H1931"\w* \w comenzará|strong="H2490"\w* \w a|strong="H3068"\w* \w salvar|strong="H3467"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w de|strong="H4480"\w* \w mano|strong="H3027"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*».   
\p
\v 6 \w Y|strong="H3068"\w* \w la|strong="H1931"\w* mujer vino y \w se|strong="H1931"\w* \w lo|strong="H1931"\w* \w contó|strong="H5046"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* marido, diciendo: “Un varón \w de|strong="H3372"\w* Dios vino \w a|strong="H3068"\w* mí, \w cuyo|strong="H1931"\w* \w aspecto|strong="H4758"\w* \w era|strong="H1931"\w* \w como|strong="H1931"\w* \w el|strong="H1931"\w* \w aspecto|strong="H4758"\w* \w de|strong="H3372"\w* un \w ángel|strong="H4397"\w* \w de|strong="H3372"\w* Dios, \w sobremanera|strong="H3966"\w* temible; y \w no|strong="H3808"\w* \w le|strong="H1931"\w* \w pregunté|strong="H7592"\w* \w de|strong="H3372"\w* \w dónde|strong="H8034"\w* \w era|strong="H1931"\w*, \w ni|strong="H3808"\w* \w él|strong="H1931"\w* me \w dijo|strong="H5046"\w* \w su|strong="H1931"\w* \w nombre|strong="H8034"\w*.  
\v 7 \w Y|strong="H3068"\w* \w me|strong="H4480"\w* dijo: «He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* concebirás, \w y|strong="H3588"\w* darás \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*; \w ahora|strong="H6258"\w*, \w pues|strong="H3588"\w*, \w no|strong="H3588"\w* \w bebas|strong="H8354"\w* \w vino|strong="H3196"\w* \w ni|strong="H5704"\w* \w sidra|strong="H7941"\w*, \w ni|strong="H5704"\w* comas \w cosa|strong="H3605"\w* \w inmunda|strong="H2932"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w niño|strong="H5288"\w* \w será|strong="H1961"\w* \w nazareo|strong="H5139"\w* \w a|strong="H3068"\w* Dios \w desde|strong="H4480"\w* \w el|strong="H3588"\w* vientre \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H4480"\w* \w su|strong="H3588"\w* \w muerte|strong="H4194"\w*»».   
\p
\v 8 Entonces oró \w Manoa|strong="H4495"\w* \w a|strong="H3068"\w* Yahvé, y dijo: «Ah, \w Señor|strong="H3068"\w* mío, \w yo|strong="H4994"\w* te \w ruego|strong="H4994"\w* \w que|strong="H4100"\w* \w aquel|strong="H6213"\w* varón \w de|strong="H5750"\w* \w Dios|strong="H3068"\w* \w que|strong="H4100"\w* \w enviaste|strong="H7971"\w*, vuelva \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* venir \w a|strong="H3068"\w* nosotros, y \w nos|strong="H4100"\w* \w enseñe|strong="H3384"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* hayamos \w de|strong="H5750"\w* \w hacer|strong="H6213"\w* con \w el|strong="H6213"\w* \w niño|strong="H5288"\w* \w que|strong="H4100"\w* ha \w de|strong="H5750"\w* nacer».   
\p
