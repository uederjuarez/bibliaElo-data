\v 17 Asimismo \w derribó|strong="H5422"\w* la \w torre|strong="H4026"\w* de Penuel, y \w mató|strong="H2026"\w* \w a|strong="H3068"\w* los de la \w ciudad|strong="H5892"\w*.   
\p
\v 18 Luego dijo \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* y \w a|strong="H3068"\w* Zalmunna: «¿\w Qué|strong="H1121"\w* aspecto tenían aquellos \w hombres|strong="H1121"\w* \w que|strong="H1121"\w* \w matasteis|strong="H2026"\w* en \w el|strong="H1121"\w* \w Tabor|strong="H8396"\w*?». Ellos respondieron: «\w Como|strong="H3644"\w* tú, así eran ellos; cada uno parecía \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w rey|strong="H4428"\w*».  
\v 19 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* dijo: «Mis hermanos \w eran|strong="H3808"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* mi madre. ¡\w Vive|strong="H2416"\w* Yahvé!, \w que|strong="H3808"\w* \w si|strong="H3863"\w* \w les|strong="H1992"\w* hubierais conservado la \w vida|strong="H2416"\w*, yo \w no|strong="H3808"\w* os mataría».  
\v 20 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* \w Jeter|strong="H3500"\w* \w su|strong="H3588"\w* \w primogénito|strong="H1060"\w*: «\w Levántate|strong="H6965"\w*, \w y|strong="H3588"\w* mátalos». \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* joven \w no|strong="H3808"\w* \w desenvainó|strong="H8025"\w* \w su|strong="H3588"\w* \w espada|strong="H2719"\w*, \w porque|strong="H3588"\w* tenía \w temor|strong="H3372"\w*, \w pues|strong="H3588"\w* era \w aún|strong="H5750"\w* \w muchacho|strong="H5288"\w*.   
\p
\v 21 \w Entonces|strong="H3588"\w* dijeron \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* Zalmunna: «\w Levántate|strong="H6965"\w* tú, \w y|strong="H3588"\w* arremete contra nosotros; \w porque|strong="H3588"\w* \w como|strong="H3588"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* varón, tal \w es|strong="H3588"\w* \w su|strong="H3588"\w* \w fortaleza|strong="H1369"\w*». \w Y|strong="H3068"\w* \w Gedeón|strong="H1439"\w* se \w levantó|strong="H6965"\w* \w y|strong="H3588"\w* \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Zalmunna; \w y|strong="H3588"\w* \w tomó|strong="H3947"\w* \w los|strong="H3588"\w* adornos \w de|strong="H3588"\w* lunetas \w que|strong="H3588"\w* sus \w camellos|strong="H1581"\w* traían al \w cuello|strong="H6677"\w*.   
\p
\v 22 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* israelitas dijeron \w a|strong="H3068"\w* \w Gedeón|strong="H1439"\w*: «Sé nuestro señor, tú, \w y|strong="H1571"\w* tu \w hijo|strong="H1121"\w*, \w y|strong="H1571"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* tu \w hijo|strong="H1121"\w*; \w pues|strong="H3588"\w* \w que|strong="H3588"\w* nos has librado \w de|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w Madián|strong="H4080"\w*».  
\v 23 \w Mas|strong="H3808"\w* \w Gedeón|strong="H1439"\w* respondió: «\w No|strong="H3808"\w* \w seré|strong="H3808"\w* \w señor|strong="H3068"\w* sobre vosotros, \w ni|strong="H3808"\w* mi \w hijo|strong="H1121"\w* os señoreará: Yahvé señoreará sobre vosotros».  
\v 24 \w Y|strong="H3068"\w* \w les|strong="H1992"\w* dijo \w Gedeón|strong="H1439"\w*: «Quiero haceros una \w petición|strong="H7596"\w*: \w que|strong="H3588"\w* cada uno \w me|strong="H4480"\w* \w dé|strong="H4480"\w* \w los|strong="H1992"\w* zarcillos \w de|strong="H4480"\w* \w su|strong="H1992"\w* botín» (\w pues|strong="H3588"\w* traían zarcillos \w de|strong="H4480"\w* \w oro|strong="H2091"\w*, \w porque|strong="H3588"\w* eran ismaelitas).  
\v 25 Ellos respondieron: «\w De|strong="H5414"\w* buena gana los \w daremos|strong="H5414"\w*». \w Y|strong="H3068"\w* tendiendo un manto, \w echó|strong="H7993"\w* \w allí|strong="H8033"\w* \w cada|strong="H8033"\w* uno los zarcillos \w de|strong="H5414"\w* su botín.  
\v 26 \w Y|strong="H3068"\w* \w fue|strong="H1961"\w* \w el|strong="H5921"\w* \w peso|strong="H4948"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* zarcillos \w de|strong="H4480"\w* \w oro|strong="H2091"\w* \w que|strong="H4480"\w* \w él|strong="H5921"\w* \w pidió|strong="H7592"\w*, \w mil|strong="H3967"\w* \w setecientos|strong="H7651"\w* \w siclos|strong="H4948"\w* \w de|strong="H4480"\w* \w oro|strong="H2091"\w*\f + \fr 8:26 \ft Un siclo equivale a unos 11,5 gramos; por tanto, 1700 siclos son unos 19,5 kilogramos.\f*, sin \w las|strong="H5921"\w* lunetas, \w las|strong="H5921"\w* \w joyas|strong="H5141"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* vestidos \w de|strong="H4480"\w* púrpura \w que|strong="H4480"\w* \w traían|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H4480"\w* \w Madián|strong="H4080"\w*, \w y|strong="H5921"\w* sin \w los|strong="H5921"\w* collares \w que|strong="H4480"\w* \w traían|strong="H5921"\w* sus \w camellos|strong="H1581"\w* \w al|strong="H5921"\w* \w cuello|strong="H6677"\w*.  
\v 27 \w Y|strong="H3068"\w* \w Gedeón|strong="H1439"\w* \w hizo|strong="H6213"\w* de \w ellos|strong="H3605"\w* un efod, \w el|strong="H3605"\w* cual \w hizo|strong="H6213"\w* colocar en su \w ciudad|strong="H5892"\w* de Ofra; y \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w fornicó|strong="H2181"\w* tras ese efod en \w aquel|strong="H3605"\w* lugar, y \w fue|strong="H1961"\w* tropezadero \w a|strong="H3068"\w* \w Gedeón|strong="H1439"\w* y \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*.  
\v 28 Así \w fue|strong="H3808"\w* \w humillado|strong="H3665"\w* \w Madián|strong="H4080"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, y \w nunca|strong="H3808"\w* \w más|strong="H3254"\w* \w levantó|strong="H5375"\w* su \w cabeza|strong="H7218"\w*. \w Y|strong="H3068"\w* \w reposó|strong="H8252"\w* la tierra cuarenta \w años|strong="H8141"\w* en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H6440"\w* \w Gedeón|strong="H1439"\w*.   
\p
\v 29 Luego \w Jerobaal|strong="H3378"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joás|strong="H3101"\w* se \w fue|strong="H3212"\w* y \w habitó|strong="H3427"\w* \w en|strong="H3212"\w* su \w casa|strong="H1004"\w*.  
