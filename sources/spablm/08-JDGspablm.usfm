\v 22 \w de|strong="H3588"\w* tal manera \w que|strong="H3588"\w* \w la|strong="H1571"\w* empuñadura entró \w también|strong="H1571"\w* \w tras|strong="H1157"\w* \w la|strong="H1571"\w* \w hoja|strong="H3851"\w*, \w y|strong="H1571"\w* \w la|strong="H1571"\w* gordura cubrió \w la|strong="H1571"\w* \w hoja|strong="H3851"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w sacó|strong="H3318"\w* \w el|strong="H3588"\w* puñal \w de|strong="H3588"\w* \w su|strong="H3588"\w* vientre; \w y|strong="H1571"\w* \w salió|strong="H3318"\w* \w el|strong="H3588"\w* estiércol.  
\v 23 \w Y|strong="H3068"\w* \w salió|strong="H3318"\w* Aod al corredor, y \w cerró|strong="H5462"\w* tras sí las \w puertas|strong="H1817"\w* de la sala y las aseguró con el cerrojo.   
\p
\v 24 \w Cuando|strong="H5650"\w* \w él|strong="H1931"\w* \w hubo|strong="H2009"\w* \w salido|strong="H3318"\w*, vinieron \w los|strong="H1931"\w* \w siervos|strong="H5650"\w* del rey, \w los|strong="H1931"\w* cuales \w viendo|strong="H7200"\w* las \w puertas|strong="H1817"\w* de \w la|strong="H1931"\w* sala cerradas, dijeron: «Sin duda \w él|strong="H1931"\w* \w cubre|strong="H1931"\w* \w sus|strong="H1931"\w* \w pies|strong="H7272"\w*\f + \fr 3:24 \ft Expresión eufemística para referirse a hacer sus necesidades.\f* \w en|strong="H3318"\w* \w la|strong="H1931"\w* sala de verano».  
\v 25 \w Y|strong="H3068"\w* habiendo esperado \w hasta|strong="H5704"\w* estar confusos, \w porque|strong="H2009"\w* \w él|strong="H5307"\w* no \w abría|strong="H6605"\w* las \w puertas|strong="H1817"\w* \w de|strong="H5704"\w* la sala, \w tomaron|strong="H3947"\w* la llave \w y|strong="H5704"\w* abrieron; \w y|strong="H5704"\w* he \w aquí|strong="H2009"\w* su señor \w caído|strong="H5307"\w* \w en|strong="H5704"\w* tierra, \w muerto|strong="H4191"\w*.   
