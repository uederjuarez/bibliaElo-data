\v 27 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* \w hubo|strong="H1961"\w* llegado, \w tocó|strong="H8628"\w* \w la|strong="H1931"\w* \w trompeta|strong="H7782"\w* \w en|strong="H4480"\w* \w el|strong="H1931"\w* \w monte|strong="H2022"\w* \w de|strong="H4480"\w* Efraín, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w descendieron|strong="H3381"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w* \w del|strong="H4480"\w* \w monte|strong="H2022"\w*, y \w él|strong="H1931"\w* iba \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w ellos|strong="H1931"\w*.   
\p
\v 28 \w Entonces|strong="H3588"\w* les dijo: «\w Seguidme|strong="H7291"\w*, \w porque|strong="H3588"\w* Yahvé \w ha|strong="H3808"\w* \w entregado|strong="H5414"\w* \w a|strong="H3068"\w* vuestros enemigos \w los|strong="H7291"\w* moabitas \w en|strong="H3588"\w* vuestras \w manos|strong="H3027"\w*». \w Y|strong="H3068"\w* \w descendieron|strong="H3381"\w* tras \w él|strong="H3588"\w*, \w y|strong="H3588"\w* \w tomaron|strong="H3920"\w* \w los|strong="H7291"\w* vados del \w Jordán|strong="H3383"\w* \w a|strong="H3068"\w* \w Moab|strong="H4124"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w dejaron|strong="H5414"\w* \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* \w ninguno|strong="H3808"\w*.  
\v 29 \w Y|strong="H3068"\w* \w en|strong="H5221"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w mataron|strong="H5221"\w* \w de|strong="H6256"\w* \w los|strong="H3605"\w* moabitas \w como|strong="H1931"\w* \w diez|strong="H6235"\w* \w mil|strong="H6235"\w* hombres, \w todos|strong="H3605"\w* \w valientes|strong="H2428"\w* y \w todos|strong="H3605"\w* hombres \w de|strong="H6256"\w* guerra; \w no|strong="H3808"\w* \w escapó|strong="H4422"\w* \w ninguno|strong="H3808"\w*.  
\v 30 \w Así|strong="H1931"\w* \w fue|strong="H1931"\w* subyugado \w Moab|strong="H4124"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w bajo|strong="H8478"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w*; y \w reposó|strong="H8252"\w* \w la|strong="H1931"\w* tierra \w ochenta|strong="H8084"\w* \w años|strong="H8141"\w*.   
