\v 13 \w Y|strong="H3068"\w* \w dejaron|strong="H5800"\w* \w a|strong="H3068"\w* Yahvé, y adoraron \w a|strong="H3068"\w* \w Baal|strong="H1168"\w* y \w a|strong="H3068"\w* Astarot.  
\v 14 \w Y|strong="H3068"\w* \w se|strong="H3808"\w* encendió \w contra|strong="H6440"\w* \w Israel|strong="H3478"\w* el furor \w de|strong="H6440"\w* Yahvé, el cual los \w entregó|strong="H5414"\w* \w en|strong="H5750"\w* \w manos|strong="H3027"\w* \w de|strong="H6440"\w* robadores \w que|strong="H3808"\w* los \w despojaron|strong="H8155"\w*, y los \w vendió|strong="H4376"\w* \w en|strong="H5750"\w* \w mano|strong="H3027"\w* \w de|strong="H6440"\w* sus enemigos \w de|strong="H6440"\w* \w alrededor|strong="H5439"\w*; y \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* ya hacer frente \w a|strong="H3068"\w* sus enemigos.  
\v 15 \w Por|strong="H3027"\w* dondequiera \w que|strong="H1961"\w* \w salían|strong="H3318"\w*, \w la|strong="H3605"\w* \w mano|strong="H3027"\w* \w de|strong="H7451"\w* Yahvé \w estaba|strong="H1961"\w* \w contra|strong="H1961"\w* \w ellos|strong="H3027"\w* \w para|strong="H1961"\w* \w mal|strong="H7451"\w*, \w como|strong="H1961"\w* Yahvé \w había|strong="H1961"\w* \w dicho|strong="H1696"\w*, y \w como|strong="H1961"\w* Yahvé \w se|strong="H1961"\w* \w lo|strong="H3605"\w* \w había|strong="H1961"\w* \w jurado|strong="H7650"\w*; y \w se|strong="H1961"\w* hallaron \w en|strong="H3318"\w* \w gran|strong="H3966"\w* aflicción.   
\p
\v 16 \w Y|strong="H3068"\w* Yahvé \w levantó|strong="H6965"\w* \w jueces|strong="H8199"\w* \w que|strong="H3027"\w* los librasen de \w mano|strong="H3027"\w* de los \w que|strong="H3027"\w* los despojaban.  
\v 17 \w Pero|strong="H3588"\w* \w tampoco|strong="H1571"\w* \w oyeron|strong="H8085"\w* \w a|strong="H3068"\w* sus \w jueces|strong="H8199"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w fueron|strong="H1980"\w* tras dioses ajenos, \w a|strong="H3068"\w* \w los|strong="H3588"\w* cuales \w adoraron|strong="H7812"\w*; \w se|strong="H4480"\w* apartaron \w pronto|strong="H4118"\w* \w del|strong="H4480"\w* \w camino|strong="H1870"\w* \w en|strong="H4480"\w* \w que|strong="H3588"\w* \w anduvieron|strong="H1980"\w* sus padres \w obedeciendo|strong="H8085"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w mandamientos|strong="H4687"\w* \w de|strong="H4480"\w* Yahvé; \w ellos|strong="H1571"\w* \w no|strong="H3808"\w* \w hicieron|strong="H6213"\w* \w así|strong="H3651"\w*.  
\v 18 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* Yahvé \w les|strong="H5973"\w* levantaba \w jueces|strong="H8199"\w*, Yahvé \w estaba|strong="H1961"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w juez|strong="H8199"\w*, \w y|strong="H3588"\w* \w los|strong="H3605"\w* libraba \w de|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* enemigos \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w tiempo|strong="H3117"\w* \w de|strong="H3588"\w* \w aquel|strong="H3605"\w* \w juez|strong="H8199"\w*; \w porque|strong="H3588"\w* Yahvé \w se|strong="H1961"\w* movía \w a|strong="H3068"\w* lástima \w por|strong="H3588"\w* sus gemidos \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w los|strong="H3605"\w* oprimían \w y|strong="H3588"\w* afligían.  
