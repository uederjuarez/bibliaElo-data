\v 9 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón \w pasaron|strong="H5674"\w* \w el|strong="H1121"\w* \w Jordán|strong="H3383"\w* para hacer \w guerra|strong="H3898"\w* \w también|strong="H1571"\w* \w contra|strong="H3478"\w* \w Judá|strong="H3063"\w*, \w contra|strong="H3478"\w* \w Benjamín|strong="H1144"\w* \w y|strong="H1571"\w* \w contra|strong="H3478"\w* \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Efraín, \w de|strong="H1121"\w* modo \w que|strong="H1571"\w* \w Israel|strong="H3478"\w* se halló en \w gran|strong="H3966"\w* aflicción.   
\p
\v 10 \w Entonces|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w clamaron|strong="H2199"\w* \w a|strong="H3068"\w* Yahvé, diciendo: «Nosotros hemos \w pecado|strong="H2398"\w* \w contra|strong="H3478"\w* ti; \w porque|strong="H3588"\w* hemos dejado \w a|strong="H3068"\w* nuestro \w Dios|strong="H3068"\w* \w y|strong="H3588"\w* servido \w a|strong="H3068"\w* \w los|strong="H1121"\w* baales».   
