\v 4 \w Y|strong="H3068"\w* \w fueron|strong="H1961"\w* dejadas \w para|strong="H1961"\w* probar \w por|strong="H3027"\w* ellas \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w para|strong="H1961"\w* \w saber|strong="H3045"\w* \w si|strong="H1961"\w* obedecerían \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w mandamientos|strong="H4687"\w* de Yahvé, \w que|strong="H3045"\w* él \w había|strong="H1961"\w* dado \w a|strong="H3068"\w* sus padres \w por|strong="H3027"\w* \w mano|strong="H3027"\w* de \w Moisés|strong="H4872"\w*.  
\v 5 Así \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w habitaban|strong="H3427"\w* \w entre|strong="H7130"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w*, hititas, amorreos, ferezeos, \w heveos|strong="H2340"\w* y \w jebuseos|strong="H2983"\w*.  
\v 6 \w Y|strong="H3068"\w* \w tomaron|strong="H3947"\w* \w de|strong="H1121"\w* \w sus|strong="H1992"\w* \w hijas|strong="H1323"\w* \w por|strong="H5414"\w* \w mujeres|strong="H1323"\w*, y \w dieron|strong="H5414"\w* \w sus|strong="H1992"\w* \w hijas|strong="H1323"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w ellos|strong="H1992"\w*, y \w sirvieron|strong="H5647"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* dioses.  
\v 7 \w Hicieron|strong="H6213"\w*, pues, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H1121"\w* Yahvé, y \w olvidaron|strong="H7911"\w* \w a|strong="H3068"\w* Yahvé su \w Dios|strong="H3068"\w*, y \w sirvieron|strong="H5647"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* baales y \w a|strong="H3068"\w* las imágenes \w de|strong="H1121"\w* Asera.  
