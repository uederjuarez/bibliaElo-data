\v 21 Pero \w Jael|strong="H3278"\w* mujer de \w Heber|strong="H2268"\w* \w tomó|strong="H3947"\w* una estaca de \w la|strong="H1931"\w* tienda, y \w poniendo|strong="H7760"\w* un mazo en \w su|strong="H1931"\w* \w mano|strong="H3027"\w*, \w se|strong="H1931"\w* acercó \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w calladamente|strong="H3814"\w* y \w le|strong="H1931"\w* \w metió|strong="H8628"\w* \w la|strong="H1931"\w* estaca \w por|strong="H3027"\w* las sienes, y \w la|strong="H1931"\w* enclavó en \w la|strong="H1931"\w* tierra, \w pues|strong="H1931"\w* \w él|strong="H1931"\w* \w estaba|strong="H7760"\w* cargado de sueño y cansado; y \w así|strong="H1931"\w* \w murió|strong="H4191"\w*.  
\v 22 \w Y|strong="H3068"\w* \w siguiendo|strong="H3212"\w* \w Barac|strong="H1301"\w* \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w*, \w Jael|strong="H3278"\w* \w salió|strong="H3318"\w* \w a|strong="H3068"\w* recibirlo, y le dijo: «\w Ven|strong="H3212"\w*, y te \w mostraré|strong="H7200"\w* al varón que tú \w buscas|strong="H1245"\w*». \w Y|strong="H3068"\w* \w él|strong="H5307"\w* entró donde ella \w estaba|strong="H2009"\w*, y he \w aquí|strong="H2009"\w* \w Sísara|strong="H5516"\w* \w yacía|strong="H5307"\w* \w muerto|strong="H4191"\w* con la estaca por sus sienes.  
\v 23 \w Así|strong="H1931"\w* abatió Dios \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w a|strong="H3068"\w* \w Jabín|strong="H2985"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Canaán|strong="H3667"\w*, \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.  
\v 24 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w fue|strong="H3212"\w* endureciéndose \w más|strong="H5921"\w* \w y|strong="H5921"\w* \w más|strong="H5921"\w* \w contra|strong="H5921"\w* \w Jabín|strong="H2985"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* \w lo|strong="H5921"\w* destruyeron.   
\c 5
\p
\v 1 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* cantaron \w Débora|strong="H1683"\w* y \w Barac|strong="H1301"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abinoam, diciendo:   
\q1
\v 2 “Por haberse puesto al frente los caudillos en \w Israel|strong="H3478"\w*,  
\q2 por haberse ofrecido el \w pueblo|strong="H5971"\w* \w voluntariamente|strong="H5068"\w*,  
\q1 ¡\w bendecid|strong="H1288"\w* \w a|strong="H3068"\w* Yahvé!   
\b  
\q1
\v 3 “¡\w Oíd|strong="H8085"\w*, \w reyes|strong="H4428"\w*!  
\q2 ¡\w Atended|strong="H8085"\w*, príncipes!  
\q1 Yo \w cantaré|strong="H7891"\w* \w a|strong="H3068"\w* Yahvé;  
\q2 \w cantaré|strong="H7891"\w* \w salmos|strong="H2167"\w* \w a|strong="H3068"\w* Yahvé, el \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*.   
\b  
\q1
\v 4 “Yahvé, \w cuando|strong="H1571"\w* \w saliste|strong="H3318"\w* \w de|strong="H4325"\w* \w Seír|strong="H8165"\w*,  
\q2 \w cuando|strong="H1571"\w* te marchaste \w de|strong="H4325"\w* los \w campos|strong="H7704"\w* \w de|strong="H4325"\w* Edom,  
\q1 \w la|strong="H1571"\w* tierra \w tembló|strong="H7493"\w* \w y|strong="H1571"\w* los \w cielos|strong="H8064"\w* \w destilaron|strong="H5197"\w*;  
\q2 \w también|strong="H1571"\w* las \w nubes|strong="H5645"\w* \w gotearon|strong="H5197"\w* \w aguas|strong="H4325"\w*.   
\q1
\v 5 Los \w montes|strong="H2022"\w* se derritieron \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé,  
\q2 \w aquel|strong="H2088"\w* \w Sinaí|strong="H5514"\w*, \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.   
\b  
\q1
\v 6 “\w En|strong="H3212"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Samgar|strong="H8044"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Anat,  
\q2 \w en|strong="H3212"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Jael|strong="H3278"\w*, quedaron abandonados \w los|strong="H1121"\w* caminos,  
\q2 y \w los|strong="H1121"\w* \w que|strong="H3117"\w* \w andaban|strong="H3212"\w* por las sendas \w iban|strong="H1980"\w* por desvíos tortuosos.   
\q1
\v 7 Las aldeas quedaron desiertas \w en|strong="H5704"\w* \w Israel|strong="H3478"\w*, cesaron,  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* yo, \w Débora|strong="H1683"\w*, me levanté;  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* me levanté \w como|strong="H5704"\w* madre \w en|strong="H5704"\w* \w Israel|strong="H3478"\w*.   
\q1
\v 8 Cuando escogían \w nuevos|strong="H2319"\w* dioses,  
\q2 la guerra estaba \w a|strong="H3068"\w* las \w puertas|strong="H8179"\w*.  
\q2 ¿Se \w veía|strong="H7200"\w* \w escudo|strong="H4043"\w* \w o|strong="H3068"\w* \w lanza|strong="H7420"\w* entre cuarenta mil en \w Israel|strong="H3478"\w*?   
\q1
\v 9 Mi \w corazón|strong="H3820"\w* está con los jefes \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*,  
\q2 con los \w que|strong="H5971"\w* \w voluntariamente|strong="H5068"\w* \w se|strong="H5971"\w* ofrecieron entre el \w pueblo|strong="H5971"\w*.  
\q2 ¡\w Bendecid|strong="H1288"\w* \w a|strong="H3068"\w* Yahvé!   
\b  
\q1
\v 10 “Vosotros, \w los|strong="H3427"\w* \w que|strong="H5921"\w* cabalgáis \w en|strong="H5921"\w* asnas \w blancas|strong="H6715"\w*,  
\q2 \w los|strong="H3427"\w* \w que|strong="H5921"\w* \w os|strong="H5921"\w* sentáis \w sobre|strong="H5921"\w* tapices,  
\q2 \w y|strong="H5921"\w* \w los|strong="H3427"\w* \w que|strong="H5921"\w* viajáis \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*, meditad.   
\q1
\v 11 Lejos del \w ruido|strong="H6963"\w* \w de|strong="H5971"\w* los arqueros, en los abrevaderos,  
\q2 \w allí|strong="H8033"\w* \w repetirán|strong="H8567"\w* los actos \w de|strong="H5971"\w* \w justicia|strong="H6666"\w* \w de|strong="H5971"\w* Yahvé,  
\q2 las \w justicias|strong="H6666"\w* \w de|strong="H5971"\w* su gobierno en \w Israel|strong="H3478"\w*.  
\b  
\q1 “Entonces el \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* Yahvé \w descendió|strong="H3381"\w* \w a|strong="H3068"\w* las \w puertas|strong="H8179"\w*.   
\q2
\v 12 “¡\w Despierta|strong="H5782"\w*, \w despierta|strong="H5782"\w*, \w Débora|strong="H1683"\w*!  
\q2 ¡\w Despierta|strong="H5782"\w*, \w despierta|strong="H5782"\w*, entona un \w cántico|strong="H7892"\w*!  
\q2 ¡\w Levántate|strong="H6965"\w*, \w Barac|strong="H1301"\w*, y lleva \w a|strong="H3068"\w* tus \w cautivos|strong="H7628"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abinoam!   
\b  
\q1
\v 13 “Entonces descendió un remanente \w de|strong="H5971"\w* los nobles y del \w pueblo|strong="H5971"\w*;  
\q2 Yahvé descendió por mí contra los \w poderosos|strong="H1368"\w*.   
\q1
\v 14 \w De|strong="H4480"\w* Efraín \w vinieron|strong="H3381"\w* los \w que|strong="H4480"\w* tenían su raíz \w en|strong="H4480"\w* \w Amalec|strong="H6002"\w*,  
\q2 \w en|strong="H4480"\w* pos \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, \w Benjamín|strong="H1144"\w*, \w entre|strong="H4480"\w* tus \w pueblos|strong="H5971"\w*.  
\q1 \w De|strong="H4480"\w* Maquir \w descendieron|strong="H3381"\w* caudillos,  
\q2 y \w de|strong="H4480"\w* \w Zabulón|strong="H2074"\w* los \w que|strong="H4480"\w* manejan el báculo \w de|strong="H4480"\w* mando.   
\q1
\v 15 \w Los|strong="H5973"\w* \w príncipes|strong="H8269"\w* \w de|strong="H5973"\w* Isacar estuvieron \w con|strong="H5973"\w* \w Débora|strong="H1683"\w*;  
\q2 \w e|strong="H3068"\w* Isacar, lo mismo que \w Barac|strong="H1301"\w*,  
\q2 \w se|strong="H3651"\w* lanzó al \w valle|strong="H6010"\w* \w tras|strong="H5973"\w* sus pasos.  
\q1 \w Entre|strong="H5973"\w* las divisiones \w de|strong="H5973"\w* \w Rubén|strong="H7205"\w*  
\q2 hubo \w grandes|strong="H1419"\w* resoluciones \w de|strong="H5973"\w* \w corazón|strong="H3820"\w*.   
\b  
\q1
\v 16 “¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* te quedaste \w sentado|strong="H3427"\w* entre \w los|strong="H3427"\w* apriscos,  
\q2 para \w oír|strong="H8085"\w* \w los|strong="H3427"\w* balidos de \w los|strong="H3427"\w* \w rebaños|strong="H5739"\w*?  
\q1 Entre las divisiones de \w Rubén|strong="H7205"\w*  
\q2 hubo \w grandes|strong="H1419"\w* escrutinios del \w corazón|strong="H3820"\w*.   
\q1
\v 17 \w Galaad|strong="H1568"\w* \w se|strong="H5921"\w* \w quedó|strong="H3427"\w* \w al|strong="H5921"\w* otro \w lado|strong="H5676"\w* \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w*;  
\q2 \w y|strong="H5921"\w* \w Dan|strong="H1835"\w*, ¿\w por|strong="H5921"\w* \w qué|strong="H4100"\w* \w se|strong="H5921"\w* detuvo \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* naves?  
\q2 Aser \w se|strong="H5921"\w* mantuvo quieto \w en|strong="H5921"\w* \w la|strong="H5921"\w* ribera \w del|strong="H5921"\w* \w mar|strong="H3220"\w*,  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w quedó|strong="H3427"\w* \w en|strong="H5921"\w* sus puertos.   
\q1
\v 18 \w Zabulón|strong="H2074"\w* fue \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w expuso|strong="H2778"\w* su \w vida|strong="H5315"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w muerte|strong="H4191"\w*,  
\q2 \w y|strong="H5921"\w* Neftalí también, \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w alturas|strong="H4791"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w*.   
\b  
\q1
\v 19 “Vinieron \w reyes|strong="H4428"\w* \w y|strong="H5921"\w* \w pelearon|strong="H3898"\w*;  
\q2 entonces \w pelearon|strong="H3898"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w* \w en|strong="H5921"\w* Taanac, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w de|strong="H5921"\w* Meguido,  
\q2 \w mas|strong="H5921"\w* \w no|strong="H3808"\w* \w llevaron|strong="H3947"\w* botín \w de|strong="H5921"\w* \w plata|strong="H3701"\w*.   
\q1
\v 20 \w Desde|strong="H4480"\w* \w los|strong="H5973"\w* \w cielos|strong="H8064"\w* \w pelearon|strong="H3898"\w* las \w estrellas|strong="H3556"\w*;  
\q2 \w desde|strong="H4480"\w* sus órbitas \w pelearon|strong="H3898"\w* \w contra|strong="H5973"\w* \w Sísara|strong="H5516"\w*.   
\q1
\v 21 Los barrió el \w torrente|strong="H5158"\w* de Cisón,  
\q2 el antiguo \w torrente|strong="H5158"\w*, el \w torrente|strong="H5158"\w* Cisón.  
\q2 ¡Marcha, \w alma|strong="H5315"\w* mía, con poder!   
\b  
\q1
\v 22 “Entonces resonaron los cascos de los \w caballos|strong="H5483"\w*  
\q2 por el galope, el galope de \w sus|strong="H1986"\w* corceles.   
\q1
\v 23 «Maldecid \w a|strong="H3068"\w* Meroz», dijo \w el|strong="H3588"\w* \w Ángel|strong="H4397"\w* \w de|strong="H3588"\w* Yahvé;  
\q2 «maldecid amargamente \w a|strong="H3068"\w* sus \w moradores|strong="H3427"\w*,  
\q2 \w porque|strong="H3588"\w* \w no|strong="H3808"\w* vinieron \w en|strong="H3588"\w* \w ayuda|strong="H5833"\w* \w de|strong="H3588"\w* Yahvé,  
\q2 \w en|strong="H3588"\w* \w ayuda|strong="H5833"\w* \w de|strong="H3588"\w* Yahvé contra \w los|strong="H3427"\w* \w fuertes|strong="H1368"\w*».   
\b  
\q1
\v 24 “\w Bendita|strong="H1288"\w* sea entre las mujeres \w Jael|strong="H3278"\w*,  
\q2 mujer de \w Heber|strong="H2268"\w* ceneo;  
\q2 entre las mujeres que habitan en tiendas sea \w bendita|strong="H1288"\w*.   
\q1
\v 25 Él \w pidió|strong="H7592"\w* \w agua|strong="H4325"\w*, y ella le \w dio|strong="H5414"\w* \w leche|strong="H2461"\w*;  
\q2 en tazón \w de|strong="H5414"\w* nobles le \w presentó|strong="H5414"\w* cuajada.   
\q1
\v 26 Alargó su \w mano|strong="H3027"\w* \w a|strong="H3068"\w* la clavija,  
\q2 y su \w diestra|strong="H3225"\w* al mazo de los trabajadores;  
\q1 y golpeó \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w*, y machacó su \w cabeza|strong="H7218"\w*,  
\q2 y horadó y atravesó \w sus|strong="H1986"\w* sienes.   
\q1
\v 27 Se encogió \w a|strong="H3068"\w* sus \w pies|strong="H7272"\w*, \w cayó|strong="H5307"\w*, quedó tendido;  
\q2 \w a|strong="H3068"\w* sus \w pies|strong="H7272"\w* se encogió, \w cayó|strong="H5307"\w*;  
\q2 \w donde|strong="H8033"\w* se encogió, \w allí|strong="H8033"\w* \w cayó|strong="H5307"\w* \w muerto|strong="H7703"\w*.   
\b  
\q1
\v 28 “La madre de \w Sísara|strong="H5516"\w* se asoma \w a|strong="H3068"\w* la ventana,  
\q2 y \w a|strong="H3068"\w* través de la celosía clama:  
\q1 «¿\w Por|strong="H1157"\w* \w qué|strong="H1157"\w* tarda su \w carro|strong="H4818"\w* en venir?  
\q2 ¿\w Por|strong="H1157"\w* \w qué|strong="H1157"\w* se detienen las ruedas de sus \w carros|strong="H7393"\w*?».   
\q1
\v 29 Las \w más|strong="H6030"\w* \w sabias|strong="H2450"\w* de \w sus|strong="H1931"\w* \w damas|strong="H8282"\w* \w le|strong="H1931"\w* respondían,  
\q2 y \w aun|strong="H7725"\w* \w ella|strong="H1931"\w* \w se|strong="H1931"\w* repetía \w a|strong="H3068"\w* \w sí|strong="H1931"\w* \w misma|strong="H1931"\w*:   
\q1
\v 30 «¿\w No|strong="H3808"\w* habrán \w hallado|strong="H4672"\w* botín, y \w lo|strong="H3808"\w* estarán repartiendo?  
\q2 \w A|strong="H3068"\w* cada uno \w una|strong="H4672"\w* doncella, \w o|strong="H3068"\w* dos;  
\q1 las vestiduras de colores para \w Sísara|strong="H5516"\w*,  
\q2 un botín de telas teñidas y bordadas,  
\q2 dos telas bordadas para el \w cuello|strong="H6677"\w* del vencedor».   
\b  
\q1
\v 31 «¡\w Así|strong="H3651"\w* perezcan \w todos|strong="H3605"\w* tus enemigos, Yahvé!  
\q2 Mas \w los|strong="H3605"\w* \w que|strong="H3605"\w* te aman sean \w como|strong="H3651"\w* \w el|strong="H3605"\w* \w sol|strong="H8121"\w* cuando \w nace|strong="H3318"\w* \w en|strong="H3318"\w* su fuerza».  
\b  
\p \w Y|strong="H3068"\w* \w la|strong="H3605"\w* tierra \w reposó|strong="H8252"\w* cuarenta \w años|strong="H8141"\w*.   
\c 6
\p
\v 1 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w hicieron|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H1121"\w* Yahvé; y Yahvé \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w Madián|strong="H4080"\w* \w por|strong="H3027"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w*.  
\v 2 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w Madián|strong="H4080"\w* \w prevaleció|strong="H5810"\w* \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w por|strong="H5921"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w madianitas|strong="H4080"\w*, \w se|strong="H5921"\w* \w hicieron|strong="H6213"\w* \w cuevas|strong="H4492"\w* \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w montes|strong="H2022"\w*, \w y|strong="H5921"\w* cavernas \w y|strong="H5921"\w* lugares fortificados.  
\v 3 \w Pues|strong="H1961"\w* \w sucedía|strong="H1961"\w* \w que|strong="H5921"\w* \w cuando|strong="H1961"\w* \w Israel|strong="H3478"\w* \w había|strong="H1961"\w* \w sembrado|strong="H2232"\w*, \w subían|strong="H5927"\w* \w los|strong="H1121"\w* \w madianitas|strong="H4080"\w* \w y|strong="H5921"\w* amalecitas \w y|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5921"\w* \w oriente|strong="H6924"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*; \w subían|strong="H5927"\w* \w y|strong="H5921"\w* \w los|strong="H1121"\w* atacaban.  
\v 4 \w Y|strong="H3068"\w* acampando \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* destruían \w los|strong="H5921"\w* frutos \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w hasta|strong="H5704"\w* llegar \w a|strong="H3068"\w* \w Gaza|strong="H5804"\w*; \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w dejaban|strong="H7604"\w* \w qué|strong="H3808"\w* comer \w en|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w ni|strong="H3808"\w* ovejas, \w ni|strong="H3808"\w* \w bueyes|strong="H7794"\w*, \w ni|strong="H3808"\w* \w asnos|strong="H2543"\w*.  
\v 5 \w Porque|strong="H3588"\w* \w subían|strong="H5927"\w* \w con|strong="H3588"\w* \w sus|strong="H1992"\w* \w ganados|strong="H4735"\w* \w y|strong="H3588"\w* \w con|strong="H3588"\w* \w sus|strong="H1992"\w* tiendas, \w y|strong="H3588"\w* venían numerosos \w como|strong="H3588"\w* langostas; \w ellos|strong="H1992"\w* \w y|strong="H3588"\w* \w sus|strong="H1992"\w* \w camellos|strong="H1581"\w* eran innumerables; \w así|strong="H3588"\w* venían \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra \w para|strong="H3588"\w* devastarla.  
\v 6 \w De|strong="H6440"\w* modo \w que|strong="H1121"\w* \w Israel|strong="H3478"\w* se empobreció en \w gran|strong="H3966"\w* \w manera|strong="H3966"\w* \w por|strong="H6440"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w Madián|strong="H4080"\w*; y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w clamaron|strong="H2199"\w* \w a|strong="H3068"\w* Yahvé.   
\p
\v 7 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w clamaron|strong="H2199"\w* \w a|strong="H3068"\w* Yahvé, \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w madianitas|strong="H4080"\w*,  
\v 8 Yahvé \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* un \w profeta|strong="H5030"\w*, \w el|strong="H1121"\w* cual les dijo: “\w Así|strong="H3541"\w* \w ha|strong="H3541"\w* dicho Yahvé \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: «Yo os hice \w salir|strong="H3318"\w* \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H3541"\w* os \w saqué|strong="H3318"\w* \w de|strong="H1121"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* servidumbre.  
\v 9 Os \w libré|strong="H5337"\w* \w de|strong="H6440"\w* \w mano|strong="H3027"\w* \w de|strong="H6440"\w* \w los|strong="H3605"\w* \w egipcios|strong="H4713"\w*, y \w de|strong="H6440"\w* \w mano|strong="H3027"\w* \w de|strong="H6440"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* os afligieron, \w a|strong="H3068"\w* \w los|strong="H3605"\w* cuales arrojé \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros y os \w di|strong="H5414"\w* su tierra.  
\v 10 \w Y|strong="H3068"\w* os dije: Yo soy Yahvé vuestro \w Dios|strong="H3068"\w*; \w no|strong="H3808"\w* \w temáis|strong="H3372"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* dioses \w de|strong="H3372"\w* \w los|strong="H3427"\w* amorreos, en cuya tierra \w habitáis|strong="H3427"\w*; pero \w no|strong="H3808"\w* habéis obedecido \w a|strong="H3068"\w* mi \w voz|strong="H6963"\w*»».   
\p
\v 11 \w Y|strong="H3068"\w* vino \w el|strong="H1121"\w* \w Ángel|strong="H4397"\w* \w de|strong="H8478"\w* Yahvé y se sentó \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* la encina \w que|strong="H1121"\w* \w está|strong="H3427"\w* \w en|strong="H8478"\w* Ofra, la cual \w era|strong="H1121"\w* \w de|strong="H8478"\w* \w Joás|strong="H3101"\w* abiezerita; y su \w hijo|strong="H1121"\w* \w Gedeón|strong="H1439"\w* \w estaba|strong="H3427"\w* sacudiendo \w el|strong="H1121"\w* \w trigo|strong="H2406"\w* \w en|strong="H8478"\w* \w el|strong="H1121"\w* lagar, para esconderlo \w de|strong="H8478"\w* \w los|strong="H3427"\w* \w madianitas|strong="H4080"\w*.  
\v 12 \w Y|strong="H3068"\w* \w el|strong="H5973"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5973"\w* Yahvé se \w le|strong="H5973"\w* \w apareció|strong="H7200"\w*, y \w le|strong="H5973"\w* dijo: «¡Yahvé está \w contigo|strong="H5973"\w*, varón \w esforzado|strong="H2428"\w* y \w valiente|strong="H1368"\w*!».   
\p
\v 13 \w Y|strong="H3068"\w* \w Gedeón|strong="H1439"\w* \w le|strong="H5973"\w* respondió: “Ah, \w señor|strong="H3068"\w* mío, \w si|strong="H3808"\w* Yahvé \w está|strong="H2063"\w* \w con|strong="H5973"\w* \w nosotros|strong="H3605"\w*, ¿\w por|strong="H4100"\w* \w qué|strong="H4100"\w* \w nos|strong="H4100"\w* \w ha|strong="H3808"\w* sobrevenido \w todo|strong="H3605"\w* \w esto|strong="H2063"\w*? ¿\w Y|strong="H3068"\w* dónde \w están|strong="H3426"\w* \w todas|strong="H3605"\w* sus \w maravillas|strong="H6381"\w*, \w que|strong="H4100"\w* nuestros padres \w nos|strong="H4100"\w* han \w contado|strong="H5608"\w*, diciendo: «¿\w No|strong="H3808"\w* \w nos|strong="H4100"\w* \w sacó|strong="H5927"\w* Yahvé \w de|strong="H5973"\w* \w Egipto|strong="H4714"\w*?». \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* Yahvé \w nos|strong="H4100"\w* \w ha|strong="H3808"\w* desamparado, y \w nos|strong="H4100"\w* \w ha|strong="H3808"\w* \w entregado|strong="H5414"\w* \w en|strong="H5973"\w* \w mano|strong="H3709"\w* \w de|strong="H5973"\w* \w los|strong="H3605"\w* \w madianitas|strong="H4080"\w*”.   
\p
\v 14 \w Y|strong="H3068"\w* mirándole Yahvé, le dijo: «\w Ve|strong="H3212"\w* con \w esta|strong="H2088"\w* tu \w fortaleza|strong="H3581"\w*, y \w salvarás|strong="H3467"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* de la \w mano|strong="H3709"\w* de los \w madianitas|strong="H4080"\w*. ¿\w No|strong="H3808"\w* te \w envío|strong="H7971"\w* yo?».   
\p
\v 15 Entonces le respondió: “Ah, Señor mío,\f + \fr 6:15 \ft El término hebreo es «Adonai».\f* ¿con \w qué|strong="H4100"\w* \w salvaré|strong="H3467"\w* \w yo|strong="H2009"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*? He \w aquí|strong="H2009"\w* \w que|strong="H4100"\w* \w mi|strong="H2009"\w* \w familia|strong="H1004"\w* es \w pobre|strong="H1800"\w* en \w Manasés|strong="H4519"\w*, y \w yo|strong="H2009"\w* el \w menor|strong="H6810"\w* en la \w casa|strong="H1004"\w* de \w mi|strong="H2009"\w* padre”.   
\p
\v 16 Yahvé \w le|strong="H5973"\w* dijo: «\w Ciertamente|strong="H3588"\w* \w yo|strong="H3588"\w* estaré \w contigo|strong="H5973"\w*, \w y|strong="H3588"\w* derrotarás \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w madianitas|strong="H4080"\w* \w como|strong="H3588"\w* \w a|strong="H3068"\w* un solo hombre».   
\p
\v 17 \w Y|strong="H3068"\w* \w él|strong="H5973"\w* respondió: «\w Yo|strong="H4994"\w* \w te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w si|strong="H4994"\w* he \w hallado|strong="H4672"\w* \w gracia|strong="H2580"\w* ante tus \w ojos|strong="H5869"\w*, \w me|strong="H5973"\w* des señal \w de|strong="H5973"\w* \w que|strong="H4994"\w* \w tú|strong="H6213"\w* has \w hablado|strong="H1696"\w* \w conmigo|strong="H5973"\w*.  
\v 18 Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w no|strong="H6440"\w* te vayas \w de|strong="H6440"\w* \w aquí|strong="H2088"\w* \w hasta|strong="H5704"\w* \w que|strong="H4994"\w* \w vuelva|strong="H7725"\w* \w a|strong="H3068"\w* ti, \w y|strong="H5704"\w* \w saque|strong="H3318"\w* \w mi|strong="H4994"\w* \w ofrenda|strong="H4503"\w* \w y|strong="H5704"\w* la ponga \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti». \w Y|strong="H3068"\w* \w él|strong="H3427"\w* \w respondió|strong="H7725"\w*: «\w Yo|strong="H4994"\w* \w esperaré|strong="H3427"\w* \w hasta|strong="H5704"\w* \w que|strong="H4994"\w* \w vuelvas|strong="H7725"\w*».   
\p
\v 19 \w Y|strong="H3068"\w* entró \w Gedeón|strong="H1439"\w*, y preparó un \w cabrito|strong="H1423"\w*, y panes \w ázimos|strong="H4682"\w* \w de|strong="H8478"\w* un efa\f + \fr 6:19 \ft Un efa equivale aproximadamente a 22 litros.\f* \w de|strong="H8478"\w* \w harina|strong="H7058"\w*; y \w puso|strong="H7760"\w* la \w carne|strong="H1320"\w* \w en|strong="H3318"\w* un \w canastillo|strong="H5536"\w*, y \w el|strong="H6213"\w* caldo \w en|strong="H3318"\w* una olla, y llevándolo todo \w bajo|strong="H8478"\w* aquella encina, se \w lo|strong="H6213"\w* presentó.   
\p
\v 20 \w Entonces|strong="H3651"\w* \w el|strong="H6213"\w* \w Ángel|strong="H4397"\w* de Dios le dijo: «\w Toma|strong="H3947"\w* la \w carne|strong="H1320"\w* y los panes \w ázimos|strong="H4682"\w*, y ponlos sobre \w esta|strong="H3651"\w* \w peña|strong="H5553"\w*, y vierte \w el|strong="H6213"\w* caldo». \w Y|strong="H3068"\w* \w él|strong="H6213"\w* \w lo|strong="H6213"\w* \w hizo|strong="H6213"\w* \w así|strong="H3651"\w*.  
\v 21 \w Y|strong="H3068"\w* \w extendiendo|strong="H7971"\w* el \w Ángel|strong="H4397"\w* \w de|strong="H4480"\w* Yahvé la punta \w del|strong="H4480"\w* \w cayado|strong="H4938"\w* \w que|strong="H4480"\w* tenía \w en|strong="H4480"\w* su \w mano|strong="H3027"\w*, \w tocó|strong="H5060"\w* la \w carne|strong="H1320"\w* y los panes \w ázimos|strong="H4682"\w*; y \w subió|strong="H5927"\w* fuego \w de|strong="H4480"\w* la peña, el cual consumió la \w carne|strong="H1320"\w* y los panes \w ázimos|strong="H4682"\w*. \w Y|strong="H3068"\w* el \w Ángel|strong="H4397"\w* \w de|strong="H4480"\w* Yahvé \w desapareció|strong="H1980"\w* \w de|strong="H4480"\w* su vista.   
\p
\v 22 \w Viendo|strong="H7200"\w* \w entonces|strong="H3588"\w* \w Gedeón|strong="H1439"\w* \w que|strong="H3588"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* Yahvé, dijo: «¡Ah, \w Señor|strong="H3068"\w* Yahvé, \w que|strong="H3588"\w* he \w visto|strong="H7200"\w* \w al|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* Yahvé \w cara|strong="H6440"\w* \w a|strong="H3068"\w* \w cara|strong="H6440"\w*!».   
\p
\v 23 Pero Yahvé le dijo: «\w Paz|strong="H7965"\w* \w a|strong="H3068"\w* ti; \w no|strong="H3808"\w* tengas \w temor|strong="H3372"\w*, \w no|strong="H3808"\w* \w morirás|strong="H4191"\w*».   
\p
