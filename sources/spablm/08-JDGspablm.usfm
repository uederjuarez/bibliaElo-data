\v 23 \w Y|strong="H3068"\w* juntándose \w los|strong="H3605"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w de|strong="H4480"\w* Neftalí, \w de|strong="H4480"\w* Aser y \w de|strong="H4480"\w* \w todo|strong="H3605"\w* \w Manasés|strong="H4519"\w*, \w siguieron|strong="H7291"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w madianitas|strong="H4080"\w*.  
\v 24 \w Gedeón|strong="H1439"\w* también \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w por|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w monte|strong="H2022"\w* \w de|strong="H5704"\w* Efraín, diciendo: «\w Descended|strong="H3381"\w* \w al|strong="H5704"\w* encuentro \w de|strong="H5704"\w* \w los|strong="H3605"\w* \w madianitas|strong="H4080"\w*, \w y|strong="H5704"\w* tomadles \w los|strong="H3605"\w* vados \w de|strong="H5704"\w* las \w aguas|strong="H4325"\w* \w hasta|strong="H5704"\w* Bet-bara \w y|strong="H5704"\w* \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w*». \w Y|strong="H3068"\w* juntándose \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5704"\w* Efraín, \w tomaron|strong="H3920"\w* \w los|strong="H3605"\w* vados \w de|strong="H5704"\w* las \w aguas|strong="H4325"\w* \w hasta|strong="H5704"\w* Bet-bara \w y|strong="H5704"\w* \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w*.  
\v 25 \w Y|strong="H3068"\w* \w tomaron|strong="H3920"\w* \w a|strong="H3068"\w* \w dos|strong="H8147"\w* \w príncipes|strong="H8269"\w* \w de|strong="H8269"\w* \w los|strong="H7291"\w* \w madianitas|strong="H4080"\w*, \w Oreb|strong="H6159"\w* y Zeeb; y \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w Oreb|strong="H6159"\w* en la peña \w de|strong="H8269"\w* \w Oreb|strong="H6159"\w*, y \w a|strong="H3068"\w* Zeeb lo \w mataron|strong="H2026"\w* en el \w lagar|strong="H3342"\w* \w de|strong="H8269"\w* Zeeb; y después que \w siguieron|strong="H7291"\w* \w a|strong="H3068"\w* \w los|strong="H7291"\w* \w madianitas|strong="H4080"\w*, trajeron las \w cabezas|strong="H7218"\w* \w de|strong="H8269"\w* \w Oreb|strong="H6159"\w* y \w de|strong="H8269"\w* Zeeb \w a|strong="H3068"\w* \w Gedeón|strong="H1439"\w* al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*.   
\c 8
\p
\v 1 \w Pero|strong="H3588"\w* \w los|strong="H3588"\w* hombres \w de|strong="H3588"\w* Efraín le \w dijeron|strong="H1697"\w*: «¿\w Qué|strong="H3588"\w* \w es|strong="H2088"\w* \w esto|strong="H2088"\w* \w que|strong="H3588"\w* has \w hecho|strong="H6213"\w* \w con|strong="H3588"\w* nosotros, \w no|strong="H6213"\w* llamándonos \w cuando|strong="H3588"\w* \w ibas|strong="H1980"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w guerra|strong="H3898"\w* contra \w Madián|strong="H4080"\w*?». \w Y|strong="H3068"\w* le reprendieron fuertemente.  
\v 2 \w A|strong="H3068"\w* los cuales \w él|strong="H6213"\w* respondió: «¿\w Qué|strong="H4100"\w* he \w hecho|strong="H6213"\w* \w yo|strong="H6213"\w* \w ahora|strong="H6258"\w* en comparación con vosotros? ¿\w No|strong="H3808"\w* es la rebusca de Efraín \w mejor|strong="H2896"\w* \w que|strong="H4100"\w* la vendimia de Abiezer?  
\v 3 Dios ha \w entregado|strong="H5414"\w* \w en|strong="H5921"\w* \w vuestras|strong="H1697"\w* \w manos|strong="H3027"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* caudillos \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*, \w a|strong="H3068"\w* \w Oreb|strong="H6159"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Zeeb; ¿\w qué|strong="H4100"\w* he podido \w hacer|strong="H6213"\w* \w yo|strong="H6213"\w* \w en|strong="H5921"\w* comparación \w con|strong="H5921"\w* vosotros?». Entonces \w el|strong="H5921"\w* enojo \w de|strong="H5921"\w* \w ellos|strong="H3027"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* aplacó, \w luego|strong="H2088"\w* \w que|strong="H4100"\w* \w él|strong="H5921"\w* \w habló|strong="H1696"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*.   
\p
\v 4 \w Y|strong="H3068"\w* llegó \w Gedeón|strong="H1439"\w* al \w Jordán|strong="H3383"\w*, y \w pasó|strong="H5674"\w* \w él|strong="H1931"\w* con \w los|strong="H7291"\w* \w trescientos|strong="H7969"\w* hombres \w que|strong="H1931"\w* traía consigo, \w cansados|strong="H5889"\w*, mas todavía persiguiendo.  
\v 5 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w de|strong="H3588"\w* Sucot: «\w Dad|strong="H5414"\w*, os \w ruego|strong="H4994"\w*, \w panes|strong="H3899"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w gente|strong="H5971"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* sigue, \w porque|strong="H3588"\w* están \w cansados|strong="H5889"\w*, \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w persigo|strong="H7291"\w* \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Zalmunna, \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* \w Madián|strong="H4080"\w*».   
\p
\v 6 \w Y|strong="H3068"\w* \w los|strong="H3588"\w* \w principales|strong="H8269"\w* \w de|strong="H3588"\w* Sucot respondieron: «¿Están \w ya|strong="H6258"\w* las \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* Zalmunna \w en|strong="H3588"\w* tu \w mano|strong="H3027"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w demos|strong="H5414"\w* \w pan|strong="H3899"\w* \w a|strong="H3068"\w* tu \w ejército|strong="H6635"\w*?».   
\p
\v 7 \w Y|strong="H3068"\w* \w Gedeón|strong="H1439"\w* dijo: «\w Pues|strong="H3651"\w* cuando Yahvé haya \w entregado|strong="H5414"\w* en mi \w mano|strong="H3027"\w* \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* y \w a|strong="H3068"\w* Zalmunna, yo trillaré vuestra \w carne|strong="H1320"\w* con \w espinos|strong="H6975"\w* del \w desierto|strong="H4057"\w* y con abrojos».   
\p
\v 8 De \w allí|strong="H8033"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* Penuel, y les \w dijo|strong="H1696"\w* las mismas \w palabras|strong="H1696"\w*. \w Y|strong="H3068"\w* los de Penuel le \w respondieron|strong="H6030"\w* de \w la|strong="H2063"\w* misma manera que habían respondido los de Sucot.  
\v 9 \w Y|strong="H3068"\w* \w él|strong="H1571"\w* habló \w también|strong="H1571"\w* \w a|strong="H3068"\w* los de Penuel, diciendo: «\w Cuando|strong="H1571"\w* yo \w vuelva|strong="H7725"\w* en \w paz|strong="H7965"\w*, \w derribaré|strong="H5422"\w* \w esta|strong="H2088"\w* \w torre|strong="H4026"\w*».   
\p
\v 10 \w Y|strong="H3068"\w* \w Zeba|strong="H2078"\w* y Zalmunna estaban \w en|strong="H5973"\w* Carcor, y \w con|strong="H5973"\w* \w ellos|strong="H3605"\w* su \w ejército|strong="H4264"\w* \w como|strong="H5973"\w* \w de|strong="H5973"\w* \w quince|strong="H2568"\w* \w mil|strong="H3967"\w* \w hombres|strong="H1121"\w*, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* habían quedado \w de|strong="H5973"\w* \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w ejército|strong="H4264"\w* \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5973"\w* \w oriente|strong="H6924"\w*; pues habían \w caído|strong="H5307"\w* \w ciento|strong="H3967"\w* \w veinte|strong="H6242"\w* \w mil|strong="H3967"\w* \w hombres|strong="H1121"\w* \w que|strong="H1121"\w* \w sacaban|strong="H8025"\w* \w espada|strong="H2719"\w*.  
\v 11 \w Subiendo|strong="H5927"\w*, \w pues|strong="H1961"\w*, \w Gedeón|strong="H1439"\w* \w por|strong="H1870"\w* \w el|strong="H4264"\w* \w camino|strong="H1870"\w* de \w los|strong="H1961"\w* \w que|strong="H1961"\w* habitaban \w en|strong="H5221"\w* tiendas al \w oriente|strong="H6924"\w* de \w Noba|strong="H5025"\w* y de Jogbehá, \w hirió|strong="H5221"\w* \w el|strong="H4264"\w* \w campamento|strong="H4264"\w*, porque \w el|strong="H4264"\w* \w ejército|strong="H4264"\w* \w estaba|strong="H1961"\w* descuidado.  
\v 12 \w Y|strong="H3068"\w* huyendo \w Zeba|strong="H2078"\w* y Zalmunna, \w él|strong="H3605"\w* \w los|strong="H3605"\w* \w siguió|strong="H7291"\w*; y prendió \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w dos|strong="H8147"\w* \w reyes|strong="H4428"\w* de \w Madián|strong="H4080"\w*, \w Zeba|strong="H2078"\w* y Zalmunna, y llenó de \w espanto|strong="H2729"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ejército|strong="H4264"\w*.  
\v 13 \w Entonces|strong="H7725"\w* \w Gedeón|strong="H1439"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Joás|strong="H3101"\w* \w volvió|strong="H7725"\w* \w de|strong="H4480"\w* la \w batalla|strong="H4421"\w* \w antes|strong="H4480"\w* \w de|strong="H4480"\w* la subida \w de|strong="H4480"\w* Heres.  
\v 14 \w Y|strong="H3068"\w* \w tomó|strong="H3920"\w* \w a|strong="H3068"\w* un joven \w de|strong="H8269"\w* los hombres \w de|strong="H8269"\w* Sucot y le interrogó; y él le dio \w por|strong="H3789"\w* \w escrito|strong="H3789"\w* los nombres \w de|strong="H8269"\w* los \w principales|strong="H8269"\w* \w de|strong="H8269"\w* Sucot y \w de|strong="H8269"\w* sus \w ancianos|strong="H2205"\w*, \w setenta|strong="H7657"\w* y \w siete|strong="H7651"\w* varones.  
\v 15 \w Y|strong="H3068"\w* viniendo \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w de|strong="H3588"\w* Sucot, dijo: «Ved \w aquí|strong="H2009"\w* \w a|strong="H3068"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Zalmunna, \w por|strong="H3588"\w* \w los|strong="H3588"\w* cuales \w me|strong="H3588"\w* denostasteis, diciendo: «¿\w Están|strong="H2009"\w* \w ya|strong="H6258"\w* \w en|strong="H3588"\w* tu \w mano|strong="H3027"\w* las \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w Zeba|strong="H2078"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* Zalmunna, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w demos|strong="H5414"\w* nosotros \w pan|strong="H3899"\w* \w a|strong="H3068"\w* tus hombres cansados?»».  
