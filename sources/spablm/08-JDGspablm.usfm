\p
\v 1 \w Aconteció|strong="H1961"\w* \w después|strong="H1961"\w* \w de|strong="H1121"\w* la \w muerte|strong="H4194"\w* \w de|strong="H1121"\w* \w Josué|strong="H3091"\w*, \w que|strong="H4310"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w consultaron|strong="H7592"\w* \w a|strong="H3068"\w* Yahvé,\f + \fr 1:1 \ft «Yahvé» es el nombre propio de Dios, a veces vertido como «SEÑOR» (en mayúsculas) en otras traducciones.\f* diciendo: «¿\w Quién|strong="H4310"\w* \w de|strong="H1121"\w* nosotros \w subirá|strong="H5927"\w* primero \w a|strong="H3068"\w* pelear \w contra|strong="H3478"\w* \w los|strong="H1121"\w* \w cananeos|strong="H3669"\w*?».   
\p
\v 2 \w Y|strong="H3068"\w* Yahvé respondió: “\w Judá|strong="H3063"\w* \w subirá|strong="H5927"\w*; he \w aquí|strong="H2009"\w* \w que|strong="H3027"\w*\f + \fr 1:2 \ft «He aquí», del hebreo «hinneh», es una interjección que invita a observar con atención, fijarse o contemplar.\f* \w yo|strong="H2009"\w* he \w entregado|strong="H5414"\w* la tierra en sus \w manos|strong="H3027"\w*”.   
\p
\v 3 \w Y|strong="H3068"\w* \w Judá|strong="H3063"\w* dijo \w a|strong="H3068"\w* su hermano \w Simeón|strong="H8095"\w*: «\w Sube|strong="H5927"\w* conmigo \w a|strong="H3068"\w* \w la|strong="H1571"\w* heredad \w que|strong="H1571"\w* me ha caído \w en|strong="H3212"\w* \w suerte|strong="H1486"\w*, \w y|strong="H1571"\w* peleemos contra \w el|strong="H1571"\w* \w cananeo|strong="H3669"\w*, \w y|strong="H1571"\w* yo \w también|strong="H1571"\w* \w iré|strong="H3212"\w* contigo \w a|strong="H3068"\w* \w la|strong="H1571"\w* tuya». \w Y|strong="H3068"\w* \w Simeón|strong="H8095"\w* \w fue|strong="H3212"\w* \w con|strong="H1571"\w* \w él|strong="H1571"\w*.  
\v 4 \w Y|strong="H3068"\w* \w subió|strong="H5927"\w* \w Judá|strong="H3063"\w*, y Yahvé \w entregó|strong="H5414"\w* \w en|strong="H5221"\w* sus \w manos|strong="H3027"\w* al \w cananeo|strong="H3669"\w* y al ferezeo; y \w mataron|strong="H5221"\w* \w de|strong="H5414"\w* \w ellos|strong="H3027"\w* \w en|strong="H5221"\w* Bezec \w a|strong="H3068"\w* \w diez|strong="H6235"\w* \w mil|strong="H6235"\w* hombres.  
\v 5 \w Y|strong="H3068"\w* \w hallaron|strong="H4672"\w* \w a|strong="H3068"\w* Adoni-bezec \w en|strong="H5221"\w* Bezec, y \w pelearon|strong="H3898"\w* contra él; y \w hirieron|strong="H5221"\w* al \w cananeo|strong="H3669"\w* y al ferezeo.  
\v 6 Mas Adoni-bezec \w huyó|strong="H5127"\w*; y le \w siguieron|strong="H7291"\w* y le prendieron, y le cortaron \w los|strong="H7291"\w* pulgares de las \w manos|strong="H3027"\w* y de \w los|strong="H7291"\w* \w pies|strong="H7272"\w*.  
\v 7 \w Entonces|strong="H3651"\w* dijo Adoni-bezec: «\w Setenta|strong="H7657"\w* \w reyes|strong="H4428"\w*, \w cortados|strong="H7112"\w* \w los|strong="H1961"\w* pulgares \w de|strong="H8478"\w* sus \w manos|strong="H3027"\w* y \w de|strong="H8478"\w* sus \w pies|strong="H7272"\w*, recogían las migajas \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w mi|strong="H3389"\w* \w mesa|strong="H7979"\w*; \w como|strong="H1961"\w* \w yo|strong="H6213"\w* \w hice|strong="H6213"\w*, \w así|strong="H3651"\w* me ha pagado Dios».\f + \fr 1:7 \ft El término hebreo traducido por «Dios» es «Elohim».\f* \w Y|strong="H3068"\w* le llevaron \w a|strong="H3068"\w* Jerusalén, \w donde|strong="H8033"\w* \w murió|strong="H4191"\w*.  
\v 8 \w Y|strong="H3068"\w* combatieron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* Jerusalén y la \w tomaron|strong="H3920"\w*, y la pasaron \w a|strong="H3068"\w* filo \w de|strong="H1121"\w* \w espada|strong="H2719"\w* y pusieron fuego \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w*.   
\p
\v 9 \w Después|strong="H3427"\w* \w de|strong="H1121"\w* esto \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* \w descendieron|strong="H3381"\w* para pelear contra \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H1121"\w* \w habitaban|strong="H3427"\w* en \w el|strong="H1121"\w* \w monte|strong="H2022"\w*, en \w el|strong="H1121"\w* Neguev y en la Sefela.  
\v 10 \w Y|strong="H3068"\w* marchó \w Judá|strong="H3063"\w* \w contra|strong="H6440"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* que \w habitaban|strong="H3427"\w* \w en|strong="H3212"\w* \w Hebrón|strong="H2275"\w* (la cual \w antes|strong="H6440"\w* se \w llamaba|strong="H8034"\w* Quiriat-arba); \w e|strong="H3068"\w* \w hirieron|strong="H5221"\w* \w a|strong="H3068"\w* Sesai, \w a|strong="H3068"\w* Ahimán y \w a|strong="H3068"\w* Talmai.  
\v 11 \w De|strong="H6440"\w* \w allí|strong="H8033"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H6440"\w* \w Debir|strong="H1688"\w* (que \w antes|strong="H6440"\w* se \w llamaba|strong="H8034"\w* Quiriat-sefer).  
\v 12 \w Y|strong="H3068"\w* dijo \w Caleb|strong="H3612"\w*: «Al \w que|strong="H1323"\w* atacare \w a|strong="H3068"\w* Quiriat-sefer y la \w tomare|strong="H3920"\w*, yo le \w daré|strong="H5414"\w* \w a|strong="H3068"\w* mi \w hija|strong="H1323"\w* Acsa \w por|strong="H5414"\w* mujer».  
\v 13 \w Y|strong="H3068"\w* la \w tomó|strong="H3920"\w* Otoniel \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Cenaz, hermano \w menor|strong="H6996"\w* \w de|strong="H4480"\w* \w Caleb|strong="H3612"\w*; y \w él|strong="H1121"\w* le \w dio|strong="H5414"\w* \w a|strong="H3068"\w* su \w hija|strong="H1323"\w* Acsa \w por|strong="H4480"\w* mujer.   
\p
\v 14 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H4100"\w* \w cuando|strong="H4100"\w* \w ella|strong="H5921"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w le|strong="H5921"\w* persuadió \w que|strong="H4100"\w* \w pidiese|strong="H7592"\w* \w a|strong="H3068"\w* su padre un \w campo|strong="H7704"\w*. \w Ella|strong="H5921"\w* \w se|strong="H1961"\w* apeó \w del|strong="H5921"\w* \w asno|strong="H2543"\w*, \w y|strong="H5921"\w* \w Caleb|strong="H3612"\w* \w le|strong="H5921"\w* \w preguntó|strong="H7592"\w*: «¿\w Qué|strong="H4100"\w* tienes?».  
\v 15 Ella \w entonces|strong="H3588"\w* le respondió: «Concédeme un don; \w puesto|strong="H5414"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w has|strong="H5414"\w* \w dado|strong="H5414"\w* tierra \w en|strong="H3588"\w* \w el|strong="H3588"\w* Neguev, \w dame|strong="H5414"\w* también fuentes \w de|strong="H3588"\w* \w aguas|strong="H4325"\w*». \w Y|strong="H3068"\w* \w Caleb|strong="H3612"\w* le \w dio|strong="H5414"\w* las fuentes \w de|strong="H3588"\w* arriba \w y|strong="H3588"\w* las \w de|strong="H3588"\w* abajo.  
\v 16 \w Y|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* del ceneo, \w suegro|strong="H2859"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*, \w subieron|strong="H5927"\w* \w de|strong="H1121"\w* la \w Ciudad|strong="H5892"\w* \w de|strong="H1121"\w* las \w Palmeras|strong="H8558"\w* con \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* al \w desierto|strong="H4057"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w que|strong="H5971"\w* \w está|strong="H3427"\w* al \w mediodía|strong="H5045"\w* \w de|strong="H1121"\w* \w Arad|strong="H6166"\w*; y \w fueron|strong="H3212"\w* y \w habitaron|strong="H3427"\w* con \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w*.  
\v 17 \w Y|strong="H3068"\w* \w fue|strong="H3212"\w* \w Judá|strong="H3063"\w* con su hermano \w Simeón|strong="H8095"\w*, \w e|strong="H3068"\w* \w hirieron|strong="H5221"\w* al \w cananeo|strong="H3669"\w* que \w habitaba|strong="H3427"\w* \w en|strong="H3212"\w* Zefat, y la \w destruyeron|strong="H2763"\w* por completo; y \w llamaron|strong="H7121"\w* \w el|strong="H3427"\w* \w nombre|strong="H8034"\w* de la \w ciudad|strong="H5892"\w* \w Horma|strong="H2767"\w*.  
\v 18 \w Tomó|strong="H3920"\w* también \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* \w Gaza|strong="H5804"\w* con su territorio, \w a|strong="H3068"\w* Ascalón con su territorio y \w a|strong="H3068"\w* \w Ecrón|strong="H6138"\w* con su territorio.  
\v 19 \w Y|strong="H3068"\w* Yahvé \w estaba|strong="H1961"\w* \w con|strong="H3588"\w* \w Judá|strong="H3063"\w*, quien arrojó \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* del \w monte|strong="H2022"\w*; \w mas|strong="H3588"\w* \w no|strong="H3808"\w* pudo arrojar \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w habitaban|strong="H3427"\w* \w en|strong="H3588"\w* \w los|strong="H3427"\w* llanos, \w los|strong="H3427"\w* cuales \w tenían|strong="H1961"\w* \w carros|strong="H7393"\w* \w de|strong="H3588"\w* \w hierro|strong="H1270"\w*.  
\v 20 \w Y|strong="H3068"\w* \w dieron|strong="H5414"\w* \w Hebrón|strong="H2275"\w* \w a|strong="H3068"\w* \w Caleb|strong="H3612"\w*, como \w Moisés|strong="H4872"\w* había \w dicho|strong="H1696"\w*; y \w él|strong="H1121"\w* arrojó \w de|strong="H1121"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Anac.  
\v 21 \w Mas|strong="H5704"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Benjamín|strong="H1144"\w* \w no|strong="H3808"\w* arrojaron \w al|strong="H5704"\w* \w jebuseo|strong="H2983"\w* \w que|strong="H3808"\w* \w habitaba|strong="H3427"\w* \w en|strong="H5704"\w* Jerusalén, \w y|strong="H5704"\w* \w así|strong="H2088"\w* \w habitó|strong="H3427"\w* \w el|strong="H1121"\w* \w jebuseo|strong="H2983"\w* \w con|strong="H5704"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Benjamín|strong="H1144"\w* \w en|strong="H5704"\w* Jerusalén \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\p
\v 22 \w También|strong="H1571"\w* \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w José|strong="H3130"\w* \w subió|strong="H5927"\w* \w contra|strong="H5973"\w* Bet-el; \w y|strong="H1571"\w* Yahvé \w estaba|strong="H1004"\w* \w con|strong="H5973"\w* \w ellos|strong="H1992"\w*.  
\v 23 \w Y|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w José|strong="H3130"\w* puso espías en Bet-el (la \w ciudad|strong="H5892"\w* que \w antes|strong="H6440"\w* se \w llamaba|strong="H8034"\w* \w Luz|strong="H3870"\w*).  
\v 24 \w Y|strong="H3068"\w* \w los|strong="H5973"\w* \w que|strong="H4480"\w* espiaban \w vieron|strong="H7200"\w* \w a|strong="H3068"\w* un hombre \w que|strong="H4480"\w* \w salía|strong="H3318"\w* \w de|strong="H4480"\w* \w la|strong="H8104"\w* \w ciudad|strong="H5892"\w*, y \w le|strong="H5973"\w* dijeron: «\w Muéstranos|strong="H7200"\w* \w ahora|strong="H4994"\w* \w la|strong="H8104"\w* \w entrada|strong="H3996"\w* \w de|strong="H4480"\w* \w la|strong="H8104"\w* \w ciudad|strong="H5892"\w*, y \w haremos|strong="H6213"\w* \w contigo|strong="H5973"\w* \w misericordia|strong="H2617"\w*».  
\v 25 \w Él|strong="H3605"\w* entonces les \w mostró|strong="H7200"\w* \w la|strong="H3605"\w* \w entrada|strong="H3996"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w*, y \w la|strong="H3605"\w* \w hirieron|strong="H5221"\w* \w a|strong="H3068"\w* filo de \w espada|strong="H2719"\w*; pero dejaron \w ir|strong="H7971"\w* \w a|strong="H3068"\w* \w aquel|strong="H3605"\w* hombre con \w toda|strong="H3605"\w* su \w familia|strong="H4940"\w*.  
\v 26 \w Y|strong="H3068"\w* \w se|strong="H1931"\w* \w fue|strong="H3212"\w* \w el|strong="H1931"\w* hombre \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5704"\w* \w los|strong="H1931"\w* hititas, \w y|strong="H5704"\w* \w edificó|strong="H1129"\w* una \w ciudad|strong="H5892"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w llamó|strong="H7121"\w* \w Luz|strong="H3870"\w*; \w y|strong="H5704"\w* \w este|strong="H2088"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w nombre|strong="H8034"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\p
\v 27 \w Tampoco|strong="H3808"\w* \w Manasés|strong="H4519"\w* arrojó \w a|strong="H3068"\w* \w los|strong="H3427"\w* de Bet-seán \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* de sus \w aldeas|strong="H1323"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* de Taanac y sus \w aldeas|strong="H1323"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de \w Dor|strong="H1756"\w* y sus \w aldeas|strong="H1323"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Ibleam y sus \w aldeas|strong="H1323"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Meguido y sus \w aldeas|strong="H1323"\w*; y \w el|strong="H3427"\w* \w cananeo|strong="H3669"\w* persistió en \w habitar|strong="H3427"\w* en \w aquella|strong="H2063"\w* tierra.  
\v 28 \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* hizo fuerte, \w puso|strong="H7760"\w* al \w cananeo|strong="H3669"\w* bajo \w tributo|strong="H4522"\w* \w de|strong="H3588"\w* servicio, \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* arrojó del todo.  
\v 29 \w Tampoco|strong="H3808"\w* Efraín arrojó \w al|strong="H7130"\w* \w cananeo|strong="H3669"\w* \w que|strong="H3808"\w* \w habitaba|strong="H3427"\w* en \w Gezer|strong="H1507"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w habitó|strong="H3427"\w* \w el|strong="H3427"\w* \w cananeo|strong="H3669"\w* en \w Gezer|strong="H1507"\w* en \w medio|strong="H7130"\w* de ellos.  
\v 30 \w Tampoco|strong="H3808"\w* \w Zabulón|strong="H2074"\w* arrojó \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Quitrón, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* de \w Naalal|strong="H5096"\w*; y \w el|strong="H3427"\w* \w cananeo|strong="H3669"\w* \w habitó|strong="H3427"\w* en \w medio|strong="H7130"\w* de \w él|strong="H3427"\w*, y le \w fue|strong="H1961"\w* \w tributario|strong="H4522"\w*.  
\v 31 \w Tampoco|strong="H3808"\w* Aser arrojó \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Aco, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* de \w Sidón|strong="H6721"\w*, \w ni|strong="H3808"\w* de Ahlab, \w ni|strong="H3808"\w* de Aczib, \w ni|strong="H3808"\w* de Helba, \w ni|strong="H3808"\w* de Afec, \w ni|strong="H3808"\w* de \w Rehob|strong="H7340"\w*.  
\v 32 \w Y|strong="H3068"\w* \w moró|strong="H3427"\w* Aser \w entre|strong="H7130"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3588"\w* \w habitaban|strong="H3427"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra; \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H3427"\w* arrojó.  
\v 33 \w Tampoco|strong="H3808"\w* Neftalí arrojó \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Bet-semes, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Bet-anat, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w moró|strong="H3427"\w* \w entre|strong="H7130"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3808"\w* \w habitaban|strong="H3427"\w* en la tierra; \w mas|strong="H3808"\w* le \w fueron|strong="H1961"\w* \w tributarios|strong="H4522"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Bet-semes y \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Bet-anat.  
\v 34 \w Los|strong="H1121"\w* amorreos acosaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Dan|strong="H1835"\w* hasta \w el|strong="H3588"\w* \w monte|strong="H2022"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w dejaron|strong="H5414"\w* descender \w a|strong="H3068"\w* \w los|strong="H1121"\w* llanos.  
\v 35 \w Y|strong="H3068"\w* \w el|strong="H3427"\w* amorreo persistió en \w habitar|strong="H3427"\w* en \w el|strong="H3427"\w* \w monte|strong="H2022"\w* de Heres, en Ajalón y en Saalabím; pero \w cuando|strong="H1961"\w* la \w mano|strong="H3027"\w* de la \w casa|strong="H1004"\w* de \w José|strong="H3130"\w* \w se|strong="H1961"\w* hizo fuerte, les hicieron \w tributarios|strong="H4522"\w*.  
\v 36 \w Y|strong="H3068"\w* el \w término|strong="H1366"\w* del amorreo fue desde \w la|strong="H1366"\w* subida de Acrabim, desde \w la|strong="H1366"\w* \w peña|strong="H5553"\w* \w hacia|strong="H1366"\w* \w arriba|strong="H4605"\w*.   
\c 2
\p
\v 1 El \w Ángel|strong="H4397"\w* \w de|strong="H4480"\w* Yahvé \w subió|strong="H5927"\w* \w de|strong="H4480"\w* \w Gilgal|strong="H1537"\w* \w a|strong="H3068"\w* Boquim, y dijo: “\w Yo|strong="H4480"\w* \w os|strong="H4480"\w* \w saqué|strong="H5927"\w* \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w* y \w os|strong="H4480"\w* introduje \w en|strong="H4480"\w* la tierra \w de|strong="H4480"\w* la cual había \w jurado|strong="H7650"\w* \w a|strong="H3068"\w* vuestros padres, diciendo: «\w No|strong="H3808"\w* \w invalidaré|strong="H6565"\w* \w jamás|strong="H5769"\w* mi \w pacto|strong="H1285"\w* \w con|strong="H4480"\w* vosotros,  
\v 2 con \w tal|strong="H2063"\w* \w que|strong="H4100"\w* \w vosotros|strong="H8085"\w* \w no|strong="H3808"\w* \w hagáis|strong="H6213"\w* \w alianza|strong="H1285"\w* con \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de \w esta|strong="H2063"\w* tierra, \w cuyos|strong="H4100"\w* \w altares|strong="H4196"\w* habéis de derribar». \w Mas|strong="H3808"\w* \w vosotros|strong="H8085"\w* \w no|strong="H3808"\w* habéis atendido \w a|strong="H3068"\w* mi \w voz|strong="H6963"\w*. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* habéis \w hecho|strong="H6213"\w* \w esto|strong="H2063"\w*?  
\v 3 \w Por|strong="H6440"\w* tanto, yo \w también|strong="H1571"\w* digo ahora: «\w No|strong="H3808"\w* \w los|strong="H1961"\w* arrojaré \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w serán|strong="H1961"\w* vuestros azotes, \w y|strong="H1571"\w* sus dioses os \w serán|strong="H1961"\w* \w por|strong="H6440"\w* tropezón»».   
\p
\v 4 \w Cuando|strong="H1961"\w* \w el|strong="H3605"\w* \w Ángel|strong="H4397"\w* \w de|strong="H1121"\w* Yahvé \w habló|strong="H1696"\w* estas \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w alzó|strong="H5375"\w* su \w voz|strong="H6963"\w* y \w lloró|strong="H1058"\w*.  
\v 5 \w Y|strong="H3068"\w* \w llamaron|strong="H7121"\w* \w el|strong="H1931"\w* \w nombre|strong="H8034"\w* de \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* Boquim\f + \fr 2:5 \ft «Boquim» significa «los que lloran».\f*, y ofrecieron \w allí|strong="H8033"\w* \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* Yahvé.  
\v 6 Porque habiendo \w Josué|strong="H3091"\w* despedido al \w pueblo|strong="H5971"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w se|strong="H5971"\w* \w fueron|strong="H3212"\w* cada uno \w a|strong="H3068"\w* su \w heredad|strong="H5159"\w* \w para|strong="H5971"\w* poseer la tierra.  
\v 7 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w sirvió|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w tiempo|strong="H3117"\w* \w de|strong="H5971"\w* \w Josué|strong="H3091"\w*, y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w tiempo|strong="H3117"\w* \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w que|strong="H5971"\w* sobrevivieron \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w los|strong="H3605"\w* cuales habían \w visto|strong="H7200"\w* \w todas|strong="H3605"\w* las \w grandes|strong="H1419"\w* \w obras|strong="H4639"\w* \w que|strong="H5971"\w* Yahvé \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* por \w Israel|strong="H3478"\w*.  
\v 8 Pero \w murió|strong="H4191"\w* \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, \w siervo|strong="H5650"\w* \w de|strong="H1121"\w* Yahvé, siendo \w de|strong="H1121"\w* \w ciento|strong="H3967"\w* \w diez|strong="H6235"\w* \w años|strong="H8141"\w*.  
\v 9 \w Y|strong="H3068"\w* lo \w sepultaron|strong="H6912"\w* \w en|strong="H6912"\w* su \w heredad|strong="H5159"\w* \w en|strong="H6912"\w* Timnat-heres, \w en|strong="H6912"\w* el \w monte|strong="H2022"\w* de Efraín, al \w norte|strong="H6828"\w* del \w monte|strong="H2022"\w* \w Gaas|strong="H1608"\w*.  
\v 10 \w Y|strong="H3068"\w* \w toda|strong="H3605"\w* \w aquella|strong="H1931"\w* \w generación|strong="H1755"\w* \w fue|strong="H1931"\w* \w también|strong="H1571"\w* reunida \w con|strong="H1571"\w* \w sus|strong="H1931"\w* padres. \w Y|strong="H3068"\w* \w se|strong="H3045"\w* \w levantó|strong="H6965"\w* después de \w ellos|strong="H1931"\w* \w otra|strong="H6213"\w* \w generación|strong="H1755"\w* \w que|strong="H1931"\w* \w no|strong="H3808"\w* \w conocía|strong="H3045"\w* \w a|strong="H3068"\w* Yahvé, \w ni|strong="H3808"\w* \w la|strong="H1931"\w* \w obra|strong="H4639"\w* \w que|strong="H1931"\w* \w él|strong="H1931"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* por \w Israel|strong="H3478"\w*.  
