\v 22 \w para|strong="H4616"\w* probar con \w ellas|strong="H1992"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w si|strong="H3808"\w* procurarían \w ellos|strong="H1992"\w* \w guardar|strong="H8104"\w* \w el|strong="H1992"\w* \w camino|strong="H1870"\w* de Yahvé, \w andando|strong="H3212"\w* \w por|strong="H1870"\w* \w él|strong="H1992"\w* como \w sus|strong="H1992"\w* padres \w lo|strong="H3808"\w* \w guardaron|strong="H8104"\w*, \w o|strong="H3068"\w* \w no|strong="H3808"\w*».  
