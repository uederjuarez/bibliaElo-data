\mt1 San Pedro Apóstol  
\c 1
\p
\v 1 \w Pedro|strong="G4074"\w*, apóstol de \w Jesucristo|strong="G2424"\w*, a \w los|strong="G2532"\w* \w elegidos|strong="G1588"\w* \w que|strong="G2532"\w* viven \w como|strong="G2532"\w* extranjeros \w en|strong="G2532"\w* la Dispersión \w en|strong="G2532"\w* \w el|strong="G2424"\w* Ponto, \w Galacia|strong="G1053"\w*, Capadocia, Asia \w y|strong="G2532"\w* Bitinia,  
\v 2 \w según|strong="G2596"\w* la previsión \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w Padre|strong="G3962"\w*, \w en|strong="G1722"\w* santificación \w del|strong="G1519"\w* \w Espíritu|strong="G4151"\w*, \w para|strong="G1519"\w* \w que|strong="G1519"\w* obedezcáis \w a|strong="G1519"\w* \w Jesucristo|strong="G2424"\w* \w y|strong="G2532"\w* seáis rociados \w con|strong="G1722"\w* \w su|strong="G2316"\w* sangre: \w Que|strong="G1519"\w* la \w gracia|strong="G5485"\w* \w y|strong="G2532"\w* la \w paz|strong="G1515"\w* \w se|strong="G2532"\w* \w os|strong="G5210"\w* multipliquen.   
\p
\v 3 \w Bendito|strong="G2128"\w* \w sea|strong="G3588"\w* \w el|strong="G3588"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w Padre|strong="G3962"\w* \w de|strong="G1537"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*, \w que|strong="G3588"\w* \w según|strong="G2596"\w* \w su|strong="G3588"\w* \w gran|strong="G4183"\w* \w misericordia|strong="G1656"\w* \w nos|strong="G2316"\w* hizo nacer \w de|strong="G1537"\w* nuevo \w a|strong="G1519"\w* \w una|strong="G3588"\w* \w esperanza|strong="G1680"\w* \w viva|strong="G2198"\w* \w por|strong="G1223"\w* \w la|strong="G3588"\w* resurrección \w de|strong="G1537"\w* \w Jesucristo|strong="G2424"\w* \w de|strong="G1537"\w* \w entre|strong="G1519"\w* \w los|strong="G3588"\w* \w muertos|strong="G3498"\w*,  
\v 4 \w a|strong="G1519"\w* \w una|strong="G1519"\w* \w herencia|strong="G2817"\w* incorruptible \w e|strong="G2532"\w* incontaminada \w que|strong="G1519"\w* \w no|strong="G4771"\w* \w se|strong="G2532"\w* desvanece, \w reservada|strong="G5083"\w* \w en|strong="G1722"\w* \w el|strong="G1722"\w* \w Cielo|strong="G3772"\w* \w para|strong="G1519"\w* \w vosotros|strong="G5210"\w*,  
\v 5 \w que|strong="G3588"\w* \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w poder|strong="G1411"\w* \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* estáis guardados \w por|strong="G1223"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w para|strong="G1519"\w* \w una|strong="G3588"\w* \w salvación|strong="G4991"\w* preparada \w para|strong="G1519"\w* ser revelada \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w último|strong="G2078"\w* \w tiempo|strong="G2540"\w*.  
\v 6 \w En|strong="G1722"\w* \w esto|strong="G3739"\w* os regocijáis \w en|strong="G1722"\w* gran medida, \w aunque|strong="G1487"\w* \w ahora|strong="G3739"\w* \w por|strong="G1722"\w* \w un|strong="G1722"\w* tiempo, \w si|strong="G1487"\w* \w es|strong="G1487"\w* \w necesario|strong="G1163"\w*, habéis sido afligidos \w en|strong="G1722"\w* \w diversas|strong="G4164"\w* pruebas,  
\v 7 \w para|strong="G1519"\w* \w que|strong="G3588"\w* \w la|strong="G3588"\w* \w prueba|strong="G1383"\w* \w de|strong="G1722"\w* \w vuestra|strong="G4771"\w* \w fe|strong="G4102"\w*, \w que|strong="G3588"\w* es \w más|strong="G1161"\w* \w preciosa|strong="G4186"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* \w oro|strong="G5553"\w* \w que|strong="G3588"\w* perece, \w aunque|strong="G2532"\w* \w sea|strong="G3588"\w* probada \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w fuego|strong="G4442"\w*, \w sea|strong="G3588"\w* \w hallada|strong="G2147"\w* \w para|strong="G1519"\w* \w que|strong="G3588"\w* resulte \w en|strong="G1722"\w* \w alabanza|strong="G1868"\w*, \w gloria|strong="G1391"\w* \w y|strong="G2532"\w* \w honor|strong="G5092"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* revelación \w de|strong="G1722"\w* \w Jesucristo|strong="G2424"\w*,  
\v 8 \w a|strong="G1519"\w* \w quien|strong="G3739"\w*, \w no|strong="G3756"\w* habiendo conocido, amáis. \w En|strong="G1519"\w* \w él|strong="G3739"\w*, \w aunque|strong="G2532"\w* \w ahora|strong="G1161"\w* \w no|strong="G3756"\w* \w lo|strong="G3739"\w* veáis, \w creyendo|strong="G4100"\w*, \w os|strong="G1519"\w* alegráis enormemente \w con|strong="G2532"\w* \w una|strong="G1519"\w* \w alegría|strong="G5479"\w* indecible \w y|strong="G2532"\w* llena \w de|strong="G1519"\w* gloria,  
\v 9 \w recibiendo|strong="G2865"\w* \w el|strong="G3588"\w* resultado \w de|strong="G3588"\w* \w vuestra|strong="G3588"\w* \w fe|strong="G4102"\w*, \w la|strong="G3588"\w* \w salvación|strong="G4991"\w* \w de|strong="G3588"\w* \w vuestras|strong="G3588"\w* \w almas|strong="G5590"\w*.   
\p
\v 10 \w Con|strong="G2532"\w* \w respecto|strong="G1519"\w* \w a|strong="G1519"\w* \w esta|strong="G3588"\w* \w salvación|strong="G4991"\w*, \w los|strong="G3588"\w* \w profetas|strong="G4396"\w* buscaron \w e|strong="G2532"\w* indagaron diligentemente. \w Profetizaron|strong="G4395"\w* \w sobre|strong="G1519"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w que|strong="G3588"\w* vendría \w a|strong="G1519"\w* \w vosotros|strong="G5210"\w*,  
\v 11 buscando \w a|strong="G1519"\w* \w quién|strong="G5101"\w* \w o|strong="G2228"\w* \w a|strong="G1519"\w* \w qué|strong="G3588"\w* \w tiempo|strong="G2540"\w* apuntaba \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* \w de|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w que|strong="G3588"\w* estaba \w en|strong="G1722"\w* \w ellos|strong="G3588"\w* \w cuando|strong="G1722"\w* predijo \w los|strong="G3588"\w* sufrimientos \w de|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w y|strong="G2532"\w* \w las|strong="G3588"\w* \w glorias|strong="G1391"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* seguirían.  
\v 12 \w A|strong="G1519"\w* \w ellos|strong="G3588"\w* \w se|strong="G1438"\w* \w les|strong="G1519"\w* reveló \w que|strong="G3754"\w* \w no|strong="G3756"\w* \w se|strong="G1438"\w* \w servían|strong="G1247"\w* \w a|strong="G1519"\w* \w sí|strong="G1438"\w* mismos, \w sino|strong="G1161"\w* \w a|strong="G1519"\w* \w vosotros|strong="G5210"\w*, \w en|strong="G1722"\w* \w estas|strong="G3588"\w* \w cosas|strong="G3739"\w* \w que|strong="G3754"\w* \w ahora|strong="G3568"\w* \w se|strong="G1438"\w* \w os|strong="G1438"\w* han anunciado \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3754"\w* \w os|strong="G1438"\w* han predicado \w la|strong="G3588"\w* Buena Nueva \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo enviado desde \w el|strong="G3588"\w* \w cielo|strong="G3772"\w*; \w cosas|strong="G3739"\w* \w que|strong="G3754"\w* \w los|strong="G3588"\w* ángeles \w desean|strong="G1937"\w* examinar.   
\p
\v 13 \w Por|strong="G1722"\w* \w lo|strong="G3588"\w* tanto, preparad \w vuestras|strong="G3588"\w* mentes \w para|strong="G1909"\w* \w la|strong="G3588"\w* acción. Sed sobrios, y poned \w vuestra|strong="G4771"\w* \w esperanza|strong="G1679"\w* plenamente \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w que|strong="G3588"\w* se \w os|strong="G5210"\w* traerá \w en|strong="G1722"\w* \w la|strong="G3588"\w* revelación \w de|strong="G1722"\w* \w Jesucristo|strong="G2424"\w*,  
\v 14 \w como|strong="G5613"\w* \w hijos|strong="G5043"\w* \w de|strong="G1722"\w* \w obediencia|strong="G5218"\w*, \w no|strong="G3361"\w* \w conformándoos|strong="G4964"\w* \w según|strong="G5613"\w* \w vuestras|strong="G3588"\w* antiguas \w concupiscencias|strong="G1939"\w*, \w como|strong="G5613"\w* \w en|strong="G1722"\w* \w vuestra|strong="G3588"\w* ignorancia,  
\v 15 sino \w que|strong="G3588"\w* \w así|strong="G2532"\w* \w como|strong="G2532"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w os|strong="G5210"\w* \w llamó|strong="G2564"\w* \w es|strong="G1096"\w* santo, \w sed|strong="G1096"\w* \w también|strong="G2532"\w* \w vosotros|strong="G5210"\w* santos \w en|strong="G1722"\w* \w toda|strong="G3956"\w* \w vuestra|strong="G4771"\w* conducta,  
\v 16 \w porque|strong="G1360"\w* está \w escrito|strong="G1125"\w*: «Seréis santos, \w porque|strong="G1360"\w* \w yo|strong="G1473"\w* \w soy|strong="G1510"\w* santo.»   
\p
\v 17 \w Si|strong="G1487"\w* \w invocáis|strong="G1941"\w* \w a|strong="G1722"\w* \w aquel|strong="G3588"\w* \w que|strong="G3588"\w*, \w sin|strong="G2532"\w* acepción \w de|strong="G1722"\w* personas, \w juzga|strong="G2919"\w* \w según|strong="G2596"\w* \w la|strong="G3588"\w* \w obra|strong="G2041"\w* \w de|strong="G1722"\w* \w cada|strong="G1538"\w* \w uno|strong="G1538"\w*, pasad \w el|strong="G3588"\w* \w tiempo|strong="G5550"\w* \w de|strong="G1722"\w* \w vuestra|strong="G4771"\w* \w peregrinación|strong="G3940"\w* aquí \w con|strong="G1722"\w* \w temor|strong="G5401"\w* reverente,  
\v 18 \w sabiendo|strong="G1492"\w* \w que|strong="G3754"\w* habéis sido redimidos, \w no|strong="G3756"\w* \w con|strong="G1537"\w* cosas corruptibles \w como|strong="G3754"\w* plata \w u|strong="G2228"\w* \w oro|strong="G5553"\w*, \w de|strong="G1537"\w* \w la|strong="G3588"\w* inútil forma \w de|strong="G1537"\w* vida transmitida \w por|strong="G1537"\w* \w vuestros|strong="G5210"\w* padres,  
\v 19 sino \w con|strong="G2532"\w* sangre \w preciosa|strong="G5093"\w*, \w como|strong="G5613"\w* la de un cordero \w sin|strong="G2532"\w* defecto \w ni|strong="G2532"\w* mancha, la sangre de \w Cristo|strong="G5547"\w*,  
\v 20 \w que|strong="G3588"\w* fue conocido \w de|strong="G1909"\w* antemano \w antes|strong="G4253"\w* \w de|strong="G1909"\w* \w la|strong="G3588"\w* \w fundación|strong="G2602"\w* \w del|strong="G3588"\w* \w mundo|strong="G2889"\w*, \w pero|strong="G1161"\w* \w que|strong="G3588"\w* fue revelado \w en|strong="G1909"\w* \w este|strong="G3588"\w* \w último|strong="G2078"\w* \w tiempo|strong="G5550"\w* \w por|strong="G1223"\w* \w causa|strong="G1223"\w* \w de|strong="G1909"\w* \w vosotros|strong="G5210"\w*,  
\v 21 \w que|strong="G3588"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1537"\w* \w él|strong="G3588"\w* \w sois|strong="G5210"\w* creyentes \w en|strong="G1519"\w* \w Dios|strong="G2316"\w*, \w que|strong="G3588"\w* \w lo|strong="G3588"\w* \w resucitó|strong="G1453"\w* \w de|strong="G1537"\w* \w entre|strong="G1519"\w* \w los|strong="G3588"\w* \w muertos|strong="G3498"\w* \w y|strong="G2532"\w* \w le|strong="G1519"\w* \w dio|strong="G1325"\w* \w gloria|strong="G1391"\w*, \w para|strong="G1519"\w* \w que|strong="G3588"\w* \w vuestra|strong="G4771"\w* \w fe|strong="G4102"\w* \w y|strong="G2532"\w* \w esperanza|strong="G1680"\w* estén \w en|strong="G1519"\w* \w Dios|strong="G2316"\w*.   
\p
\v 22 Habiendo purificado \w vuestras|strong="G3588"\w* \w almas|strong="G5590"\w* \w en|strong="G1722"\w* \w vuestra|strong="G4771"\w* \w obediencia|strong="G5218"\w* \w a|strong="G1519"\w* \w la|strong="G3588"\w* verdad \w por|strong="G1722"\w* medio \w del|strong="G3588"\w* Espíritu \w en|strong="G1722"\w* sincero afecto fraternal, amaos \w unos|strong="G3588"\w* \w a|strong="G1519"\w* \w otros|strong="G3588"\w* \w de|strong="G1537"\w* \w corazón|strong="G2588"\w* fervientemente,  
\v 23 habiendo nacido \w de|strong="G1537"\w* nuevo, \w no|strong="G3756"\w* \w de|strong="G1537"\w* semilla \w corruptible|strong="G5349"\w*, sino \w de|strong="G1537"\w* incorruptible, \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1537"\w* \w la|strong="G1537"\w* \w palabra|strong="G3056"\w* \w de|strong="G1537"\w* \w Dios|strong="G2316"\w*, \w que|strong="G2532"\w* \w vive|strong="G2198"\w* \w y|strong="G2532"\w* \w permanece|strong="G3306"\w* \w para|strong="G1223"\w* \w siempre|strong="G1223"\w*.  
\v 24 \w Pues|strong="G2532"\w*,  
\q1 «\w Toda|strong="G3956"\w* \w la|strong="G3588"\w* \w carne|strong="G4561"\w* es \w como|strong="G5613"\w* \w la|strong="G3588"\w* \w hierba|strong="G5528"\w*,  
\q2 \w y|strong="G2532"\w* \w toda|strong="G3956"\w* \w la|strong="G3588"\w* \w gloria|strong="G1391"\w* \w del|strong="G3588"\w* hombre \w como|strong="G5613"\w* \w la|strong="G3588"\w* flor \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w hierba|strong="G5528"\w*.  
\q1 \w La|strong="G3588"\w* \w hierba|strong="G5528"\w* \w se|strong="G2532"\w* marchita \w y|strong="G2532"\w* \w su|strong="G3588"\w* flor cae;   
\q2
\v 25 \w pero|strong="G1161"\w* \w la|strong="G3588"\w* \w palabra|strong="G4487"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w permanece|strong="G3306"\w* \w para|strong="G1519"\w* \w siempre|strong="G3588"\w*».  
\p \w Esta|strong="G3778"\w* \w es|strong="G3778"\w* \w la|strong="G3588"\w* \w palabra|strong="G4487"\w* \w de|strong="G1519"\w* \w la|strong="G3588"\w* Buena Nueva \w que|strong="G3588"\w* se \w os|strong="G5210"\w* ha predicado.   
\c 2
\p
\v 1 Desechando, \w pues|strong="G3767"\w*, \w toda|strong="G3956"\w* \w maldad|strong="G2549"\w*, \w todo|strong="G3956"\w* \w engaño|strong="G1388"\w*, hipocresías, \w envidias|strong="G5355"\w* \w y|strong="G2532"\w* \w toda|strong="G3956"\w* mala palabra,  
\v 2 \w como|strong="G5613"\w* \w niños|strong="G1025"\w* recién nacidos, anhelad \w la|strong="G3588"\w* \w leche|strong="G1051"\w* \w espiritual|strong="G3050"\w* pura, \w para|strong="G1519"\w* \w que|strong="G3588"\w* \w con|strong="G1722"\w* \w ella|strong="G3588"\w* crezcáis,  
\v 3 \w si|strong="G1487"\w* \w es|strong="G1487"\w* \w que|strong="G3754"\w* habéis probado \w que|strong="G3754"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w* \w es|strong="G1487"\w* clemente.  
\v 4 Venid \w a|strong="G4314"\w* \w él|strong="G3739"\w*, \w piedra|strong="G3037"\w* \w viva|strong="G2198"\w*, rechazada \w ciertamente|strong="G3303"\w* \w por|strong="G5259"\w* los hombres, \w pero|strong="G1161"\w* \w elegida|strong="G1588"\w* \w por|strong="G5259"\w* \w Dios|strong="G2316"\w*, \w preciosa|strong="G1784"\w*.  
\v 5 \w Vosotros|strong="G2532"\w* \w también|strong="G2532"\w*, \w como|strong="G5613"\w* \w piedras|strong="G3037"\w* \w vivas|strong="G2198"\w*, sois edificados \w como|strong="G5613"\w* \w una|strong="G1519"\w* \w casa|strong="G3624"\w* \w espiritual|strong="G4152"\w*, \w para|strong="G1519"\w* ser un \w sacerdocio|strong="G2406"\w* santo, \w para|strong="G1519"\w* ofrecer \w sacrificios|strong="G2378"\w* \w espirituales|strong="G4152"\w*, \w agradables|strong="G2144"\w* \w a|strong="G1519"\w* \w Dios|strong="G2316"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1519"\w* \w Jesucristo|strong="G2424"\w*.  
\v 6 \w Porque|strong="G1360"\w* \w así|strong="G2532"\w* \w lo|strong="G3588"\w* dice \w la|strong="G3588"\w* \w Escritura|strong="G1124"\w*:  
\q1 «He aquí \w que|strong="G3588"\w* \w pongo|strong="G5087"\w* \w en|strong="G1722"\w* \w Sión|strong="G4622"\w* \w una|strong="G3588"\w* \w piedra|strong="G3037"\w* angular, \w elegida|strong="G1588"\w* \w y|strong="G2532"\w* \w preciosa|strong="G1784"\w*.  
\q2 \w Quien|strong="G3588"\w* \w crea|strong="G4100"\w* \w en|strong="G1722"\w* \w él|strong="G3588"\w* \w no|strong="G3756"\w* quedará defraudado».   
\p
\v 7 \w Por|strong="G1519"\w* \w lo|strong="G3588"\w* \w tanto|strong="G3739"\w*, \w para|strong="G1519"\w* \w vosotros|strong="G5210"\w* \w que|strong="G3588"\w* \w creéis|strong="G4100"\w* \w es|strong="G1096"\w* \w el|strong="G3588"\w* \w honor|strong="G5092"\w*, \w pero|strong="G1161"\w* \w para|strong="G1519"\w* \w los|strong="G3588"\w* desobedientes:  
\q1 «\w La|strong="G3588"\w* \w piedra|strong="G3037"\w* \w que|strong="G3588"\w* desecharon \w los|strong="G3588"\w* constructores  
\q2 \w se|strong="G1096"\w* ha convertido \w en|strong="G1519"\w* \w la|strong="G3588"\w* principal \w piedra|strong="G3037"\w* angular»,   
\p
\v 8 \w y|strong="G2532"\w*:  
\q1 «\w Piedra|strong="G3037"\w* \w de|strong="G1519"\w* \w tropiezo|strong="G4348"\w* \w y|strong="G2532"\w* \w roca|strong="G4073"\w* \w de|strong="G1519"\w* ofensa».  
