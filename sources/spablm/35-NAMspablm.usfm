\mt1 Nahum  
\c 1
\p
\v 1 \w Profecía|strong="H2377"\w* sobre \w Nínive|strong="H5210"\w*. \w Libro|strong="H5612"\w* de la \w visión|strong="H2377"\w* de Nahúm de Elcos.  
\v 2 Yahvé \w es|strong="H1931"\w* \w Dios|strong="H3068"\w* \w celoso|strong="H7072"\w* y \w vengador|strong="H5358"\w*; Yahvé \w es|strong="H1931"\w* \w vengador|strong="H5358"\w* y \w lleno|strong="H1167"\w* de indignación; Yahvé \w se|strong="H1931"\w* venga de \w sus|strong="H1931"\w* \w adversarios|strong="H6862"\w* y \w guarda|strong="H5201"\w* \w el|strong="H1931"\w* \w enojo|strong="H2534"\w* para \w sus|strong="H1931"\w* \w enemigos|strong="H6862"\w*.  
\v 3 Yahvé es tardo para la ira y \w grande|strong="H1419"\w* en \w poder|strong="H3581"\w*, y \w no|strong="H3808"\w* \w tendrá|strong="H5352"\w* \w por|strong="H1870"\w* inocente \w al|strong="H5352"\w* culpable. Yahvé \w marcha|strong="H1870"\w* en el \w torbellino|strong="H5492"\w* y en la tempestad, y las \w nubes|strong="H6051"\w* \w son|strong="H3808"\w* el polvo de sus \w pies|strong="H7272"\w*.  
\v 4 \w Él|strong="H3605"\w* amenaza al \w mar|strong="H3220"\w* y \w lo|strong="H3605"\w* hace secar, y agota \w todos|strong="H3605"\w* \w los|strong="H3605"\w* ríos; \w Basán|strong="H1316"\w* y \w el|strong="H3605"\w* Carmelo languidecen, y \w la|strong="H3605"\w* \w flor|strong="H6525"\w* del \w Líbano|strong="H3844"\w* se marchita.  
\v 5 \w Los|strong="H3427"\w* \w montes|strong="H2022"\w* \w tiemblan|strong="H7493"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w él|strong="H3605"\w* y \w los|strong="H3427"\w* \w collados|strong="H1389"\w* \w se|strong="H4480"\w* derriten; \w la|strong="H3605"\w* tierra \w se|strong="H4480"\w* conmueve \w en|strong="H4480"\w* su \w presencia|strong="H6440"\w*, \w el|strong="H3605"\w* \w mundo|strong="H8398"\w* y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H4480"\w* \w en|strong="H4480"\w* \w él|strong="H3605"\w* \w habitan|strong="H3427"\w*.  
\v 6 ¿\w Quién|strong="H4310"\w* \w resistirá|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* su \w ira|strong="H2534"\w*? ¿\w Y|strong="H3068"\w* \w quién|strong="H4310"\w* \w quedará|strong="H6965"\w* \w en|strong="H4480"\w* \w pie|strong="H5975"\w* \w ante|strong="H6440"\w* \w el|strong="H4310"\w* ardor \w de|strong="H4480"\w* su \w enojo|strong="H2534"\w*? Su \w furor|strong="H2534"\w* \w se|strong="H4480"\w* derrama como fuego y \w por|strong="H4480"\w* \w él|strong="H4310"\w* \w se|strong="H4480"\w* hendirán las peñas.  
\v 7 \w Bueno|strong="H2896"\w* es Yahvé, \w fortaleza|strong="H4581"\w* en el \w día|strong="H3117"\w* de la \w angustia|strong="H6869"\w*; y \w conoce|strong="H3045"\w* \w a|strong="H3068"\w* los \w que|strong="H3045"\w* en él confían.  
\v 8 Mas con inundación \w impetuosa|strong="H5674"\w* consumirá \w el|strong="H6213"\w* \w lugar|strong="H4725"\w* de sus enemigos, y las \w tinieblas|strong="H2822"\w* \w perseguirán|strong="H7291"\w* \w a|strong="H3068"\w* sus adversarios.  
\v 9 ¿\w Qué|strong="H4100"\w* tramáis contra Yahvé? \w Él|strong="H1931"\w* \w hará|strong="H6213"\w* \w consumación|strong="H3617"\w*; \w no|strong="H3808"\w* tomará venganza \w dos|strong="H6471"\w* \w veces|strong="H6471"\w* de \w sus|strong="H1931"\w* enemigos.  
\v 10 \w Aunque|strong="H3588"\w* sean \w como|strong="H3588"\w* espinos entretejidos \w y|strong="H3588"\w* estén empapados \w en|strong="H5704"\w* \w su|strong="H3588"\w* bebida, serán consumidos \w como|strong="H3588"\w* hojarasca completamente \w seca|strong="H3002"\w*.  
\v 11 \w De|strong="H4480"\w* \w ti|strong="H5921"\w* \w salió|strong="H3318"\w* \w el|strong="H5921"\w* \w que|strong="H4480"\w* imaginó \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* Yahvé, un \w consejero|strong="H3289"\w* \w perverso|strong="H1100"\w*.   
\p
\v 12 \w Así|strong="H3541"\w* dice Yahvé: «\w Aunque|strong="H3808"\w* tengan \w reposo|strong="H8003"\w* \w y|strong="H3541"\w* sean tantos, \w aun|strong="H5750"\w* \w así|strong="H3541"\w* serán talados \w y|strong="H3541"\w* \w él|strong="H5674"\w* \w pasará|strong="H5674"\w*. \w Aunque|strong="H3808"\w* te he \w afligido|strong="H6031"\w*, \w no|strong="H3808"\w* te afligiré \w más|strong="H5750"\w*.  
\v 13 \w Porque|strong="H5921"\w* \w ahora|strong="H6258"\w* romperé su \w yugo|strong="H5921"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* \w quebrantaré|strong="H7665"\w* tus \w coyundas|strong="H4147"\w*».   
\p
\v 14 \w Pero|strong="H3588"\w* Yahvé \w ha|strong="H3808"\w* dado \w orden|strong="H6680"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*: «\w No|strong="H3808"\w* quedará \w más|strong="H5750"\w* \w de|strong="H5921"\w* tu \w nombre|strong="H8034"\w*; \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* tus dioses quitaré \w la|strong="H5921"\w* \w imagen|strong="H6459"\w* esculpida \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w de|strong="H5921"\w* \w fundición|strong="H4541"\w*; allí prepararé tu \w sepulcro|strong="H6913"\w*, \w porque|strong="H3588"\w* fuiste vil».   
\p
\v 15 ¡He aquí sobre los montes los pies del que trae buenas nuevas, del que anuncia la paz! Celebra, Judá, tus fiestas, cumple tus votos; porque nunca más pasará por ti el malvado; ha sido totalmente exterminado.   
\c 2
\p
\v 1 \w El|strong="H5921"\w* destructor sube \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*. ¡Guarda \w la|strong="H5921"\w* fortaleza! ¡Vigila \w el|strong="H5921"\w* camino! ¡Cíñete \w los|strong="H5921"\w* lomos! ¡Fortalece tu poder \w con|strong="H5921"\w* \w todas|strong="H3605"\w* tus fuerzas!   
\p
\v 2 \w Porque|strong="H5921"\w* Yahvé restaurará \w la|strong="H5921"\w* gloria \w de|strong="H5921"\w* Jacob \w como|strong="H5921"\w* \w la|strong="H5921"\w* gloria \w de|strong="H5921"\w* Israel, pues \w los|strong="H5921"\w* saqueadores \w los|strong="H5921"\w* han despojado \w y|strong="H5921"\w* han destruido sus sarmientos.   
\p
\v 3 \w El|strong="H3588"\w* escudo \w de|strong="H3588"\w* sus valientes \w es|strong="H3588"\w* \w de|strong="H3588"\w* color rojo. Sus guerreros van \w de|strong="H3588"\w* escarlata. \w Los|strong="H3588"\w* carros centellean \w con|strong="H3588"\w* acero \w en|strong="H3588"\w* \w el|strong="H3588"\w* día \w de|strong="H3588"\w* \w su|strong="H3588"\w* preparación, \w y|strong="H3588"\w* las lanzas \w de|strong="H3588"\w* ciprés se blanden.  
\v 4 Los \w carros|strong="H7393"\w* corren furiosos por las calles y se precipitan por las plazas. Su apariencia es como de antorchas; corren como los relámpagos.  
\v 5 Él convoca \w a|strong="H3068"\w* sus nobles, que tropiezan en su camino. Se apresuran hacia el muro, y el escudo protector ya está colocado.  
\v 6 Se abren las puertas de los ríos, y el palacio se desmorona.  
\v 7 Está decretado: la reina es despojada y llevada cautiva; sus doncellas gimen con voz de paloma, golpeándose el pecho.  
\v 8 Nínive ha sido \w como|strong="H5921"\w* estanque \w de|strong="H5921"\w* aguas \w desde|strong="H5921"\w* tiempos antiguos, pero ahora \w ellos|strong="H5921"\w* huyen. «¡Deteneos! ¡Deteneos!», gritan, \w mas|strong="H5921"\w* nadie vuelve \w la|strong="H5921"\w* vista.  
\v 9 ¡Saquead \w la|strong="H1931"\w* plata! ¡Saquead \w el|strong="H1931"\w* oro! \w Sus|strong="H1931"\w* tesoros no \w tienen|strong="H1992"\w* fin; hay abundancia \w de|strong="H4325"\w* toda clase \w de|strong="H4325"\w* objetos preciosos.  
\v 10 ¡Vacía, agotada \w y|strong="H3519"\w* desolada está! \w El|strong="H3605"\w* corazón desmaya, las rodillas tiemblan, hay dolor en \w todos|strong="H3605"\w* \w los|strong="H3605"\w* lomos \w y|strong="H3519"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* rostros han palidecido.  
\v 11 ¿Dónde está \w la|strong="H3605"\w* guarida \w de|strong="H6440"\w* \w los|strong="H3605"\w* leones y \w el|strong="H3605"\w* lugar donde se alimentaban \w los|strong="H3605"\w* cachorros, donde se paseaba \w el|strong="H3605"\w* león y \w la|strong="H3605"\w* leona con sus crías sin \w que|strong="H3605"\w* \w nadie|strong="H3605"\w* \w los|strong="H3605"\w* espantase?  
\v 12 \w El|strong="H1931"\w* león despedazaba \w lo|strong="H1931"\w* suficiente para \w sus|strong="H1931"\w* cachorros y estrangulaba \w la|strong="H1931"\w* presa para \w sus|strong="H1931"\w* leonas; llenaba de presas \w sus|strong="H1931"\w* cavernas y de rapiña \w sus|strong="H1931"\w* moradas.  
\v 13 «He aquí, yo estoy contra ti», dice Yahvé de los Ejércitos. «Quemaré tus carros hasta reducirlos \w a|strong="H3068"\w* humo, y la espada devorará \w a|strong="H3068"\w* tus \w cachorros|strong="H1484"\w* de león. Extirparé tu rapiña de la tierra, y nunca más se oirá la voz de tus embajadores».   
\c 3
\p
\v 1 ¡\w Ay|strong="H1945"\w* \w de|strong="H1818"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* sanguinaria, \w toda|strong="H3605"\w* llena \w de|strong="H1818"\w* \w mentira|strong="H3585"\w* y \w de|strong="H1818"\w* rapiña, \w que|strong="H3808"\w* \w no|strong="H3808"\w* cesa \w de|strong="H1818"\w* saquear!  
\v 2 ¡Chasquido de látigo, estrépito de ruedas, \w caballos|strong="H5483"\w* que galopan y \w carros|strong="H4818"\w* que saltan!  
\v 3 ¡\w Jinetes|strong="H6571"\w* que cargan, \w espadas|strong="H2719"\w* relucientes, lanzas centelleantes! ¡\w Multitud|strong="H7230"\w* de \w heridos|strong="H2491"\w*, montones de \w muertos|strong="H2491"\w*, cadáveres sin fin! ¡\w Tropiezan|strong="H3782"\w* con los \w cuerpos|strong="H1472"\w*!  
\v 4 Todo por las \w muchas|strong="H7230"\w* \w fornicaciones|strong="H2183"\w* de la \w ramera|strong="H2181"\w* de \w hermosa|strong="H2896"\w* \w gracia|strong="H2580"\w*, \w maestra|strong="H1172"\w* de hechizos, que seduce \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w* con sus \w fornicaciones|strong="H2183"\w* y \w a|strong="H3068"\w* los \w pueblos|strong="H1471"\w* con sus embrujos.  
\v 5 «He \w aquí|strong="H2005"\w* \w que|strong="H5921"\w* yo estoy \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*», \w dice|strong="H5002"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*. “\w Descubriré|strong="H1540"\w* tus faldas \w sobre|strong="H5921"\w* tu \w rostro|strong="H6440"\w* \w y|strong="H5921"\w* \w mostraré|strong="H7200"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* tu desnudez, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* tu vergüenza.  
\v 6 Arrojaré \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* inmundicias \w abominables|strong="H8251"\w*, \w te|strong="H5921"\w* envileceré \w y|strong="H5921"\w* \w te|strong="H5921"\w* convertiré \w en|strong="H5921"\w* un espectáculo.  
\v 7 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H4480"\w* \w te|strong="H4480"\w* \w vean|strong="H7200"\w* huirán \w de|strong="H4480"\w* \w ti|strong="H4480"\w* y dirán: ‘¡\w Nínive|strong="H5210"\w* ha \w sido|strong="H1961"\w* asolada! ¿\w Quién|strong="H4310"\w* \w tendrá|strong="H1961"\w* compasión \w de|strong="H4480"\w* \w ella|strong="H4480"\w*? ¿Dónde \w buscaré|strong="H1245"\w* \w quien|strong="H4310"\w* \w te|strong="H4480"\w* consuele?’”.   
\p
\v 8 ¿Eres tú mejor \w que|strong="H4325"\w* No-Amón, la \w que|strong="H4325"\w* \w estaba|strong="H3427"\w* asentada entre \w los|strong="H3427"\w* \w ríos|strong="H2975"\w*, rodeada \w de|strong="H4325"\w* \w aguas|strong="H4325"\w*, cuyo \w baluarte|strong="H2426"\w* era \w el|strong="H2975"\w* \w mar|strong="H3220"\w* y cuya muralla eran las \w aguas|strong="H4325"\w*?  
\v 9 \w Etiopía|strong="H3568"\w* y \w Egipto|strong="H4714"\w* \w eran|strong="H1961"\w* su fuerza ilimitada; Fut y Libia \w eran|strong="H1961"\w* sus aliados.  
\v 10 Sin embargo, \w ella|strong="H1931"\w* \w fue|strong="H1980"\w* \w llevada|strong="H1980"\w* \w al|strong="H5921"\w* destierro, \w fue|strong="H1980"\w* \w al|strong="H5921"\w* \w cautiverio|strong="H1473"\w*. \w Sus|strong="H1931"\w* \w niños|strong="H5768"\w* \w fueron|strong="H1980"\w* estrellados \w en|strong="H5921"\w* \w las|strong="H5921"\w* esquinas \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w*; \w echaron|strong="H3032"\w* \w suertes|strong="H1486"\w* \w sobre|strong="H5921"\w* \w sus|strong="H1931"\w* nobles \w y|strong="H1571"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w grandes|strong="H1419"\w* hombres \w fueron|strong="H1980"\w* encadenados.  
\v 11 Tú \w también|strong="H1571"\w* te embriagarás \w y|strong="H1571"\w* quedarás aturdida; tú \w también|strong="H1571"\w* \w buscarás|strong="H1245"\w* refugio \w a|strong="H3068"\w* causa del enemigo.  
\v 12 \w Todas|strong="H3605"\w* tus fortalezas \w serán|strong="H6310"\w* \w como|strong="H5973"\w* \w higueras|strong="H8384"\w* \w con|strong="H5973"\w* \w brevas|strong="H1061"\w* maduras: \w si|strong="H5921"\w* \w las|strong="H5921"\w* sacuden, \w caen|strong="H5307"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w del|strong="H5921"\w* \w que|strong="H5921"\w* \w las|strong="H5921"\w* ha \w de|strong="H5921"\w* comer.  
\v 13 He \w aquí|strong="H2009"\w* \w que|strong="H5971"\w* tus tropas en \w medio|strong="H7130"\w* \w de|strong="H5971"\w* ti son como mujeres; las \w puertas|strong="H8179"\w* \w de|strong="H5971"\w* tu tierra \w se|strong="H5971"\w* abren \w de|strong="H5971"\w* par en par \w a|strong="H3068"\w* tus enemigos, y el fuego devora tus \w cerrojos|strong="H1280"\w*.   
\p
\v 14 \w Provéete|strong="H7579"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w* para el asedio, refuerza tus fortalezas; entra en el lodo, \w pisa|strong="H7429"\w* la argamasa, repara el horno \w de|strong="H4325"\w* ladrillos.  
\v 15 \w Allí|strong="H8033"\w* te consumirá el fuego, te \w cortará|strong="H3772"\w* la \w espada|strong="H2719"\w*; te devorará como el pulgón. ¡\w Multiplícate|strong="H3513"\w* como el pulgón! ¡\w Multiplícate|strong="H3513"\w* como la langosta!  
\v 16 Aumentaste tus mercaderes \w más|strong="H7235"\w* que las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w*; el pulgón extiende sus alas y vuela.  
\v 17 Tus guardas \w son|strong="H3808"\w* como langostas y tus capitanes como nubes de langostas \w que|strong="H3808"\w* \w se|strong="H3045"\w* asientan en los vallados en \w día|strong="H3117"\w* de frío; pero \w sale|strong="H2224"\w* el \w sol|strong="H8121"\w* y vuelan, y \w nadie|strong="H3808"\w* \w sabe|strong="H3045"\w* \w dónde|strong="H4725"\w* están.   
\p
\v 18 Tus \w pastores|strong="H7462"\w* duermen, oh \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria; tus nobles descansan. Tu \w pueblo|strong="H5971"\w* \w está|strong="H7931"\w* disperso \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w* \w y|strong="H5921"\w* \w no|strong="H5921"\w* hay quien \w lo|strong="H5921"\w* reúna.  
\v 19 \w No|strong="H3808"\w* \w hay|strong="H4310"\w* medicina \w para|strong="H5921"\w* tu herida; tu \w llaga|strong="H4347"\w* \w es|strong="H3588"\w* mortal. \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w oigan|strong="H8085"\w* noticias \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w batirán|strong="H8628"\w* \w palmas|strong="H3709"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w porque|strong="H3588"\w* ¿\w sobre|strong="H5921"\w* \w quién|strong="H4310"\w* \w no|strong="H3808"\w* \w pasó|strong="H5674"\w* \w continuamente|strong="H8548"\w* tu infinita \w maldad|strong="H7451"\w*?   