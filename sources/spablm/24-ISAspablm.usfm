\v 7 \w En|strong="H4480"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w será|strong="H1931"\w* traída ofrenda \w a|strong="H3068"\w* Yahvé \w de|strong="H4480"\w* \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w* \w de|strong="H4480"\w* \w parte|strong="H4725"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* elevada estatura y piel brillante, \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* temible \w desde|strong="H4480"\w* \w su|strong="H1931"\w* principio y \w hasta|strong="H1931"\w* ahora, \w nación|strong="H1471"\w* fuerte y conquistadora, \w cuya|strong="H1931"\w* tierra dividen \w los|strong="H1931"\w* ríos, \w al|strong="H4480"\w* \w lugar|strong="H4725"\w* \w del|strong="H4480"\w* \w nombre|strong="H8034"\w* \w de|strong="H4480"\w* Yahvé \w de|strong="H4480"\w* \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w*, \w al|strong="H4480"\w* \w monte|strong="H2022"\w* \w Sión|strong="H6726"\w*.   
\c 19
\p
\v 1 Oráculo \w sobre|strong="H5921"\w* \w Egipto|strong="H4714"\w*.  
\p «He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* Yahvé \w cabalga|strong="H7392"\w* \w sobre|strong="H5921"\w* una \w nube|strong="H5645"\w* ligera \w y|strong="H5921"\w* entra \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w*. \w Los|strong="H5921"\w* ídolos \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* temblarán \w ante|strong="H6440"\w* su \w presencia|strong="H6440"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w corazón|strong="H3824"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w* \w se|strong="H5921"\w* \w desmayará|strong="H4549"\w* \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 2 Incitaré \w a|strong="H3068"\w* \w egipcios|strong="H4714"\w* contra \w egipcios|strong="H4714"\w*, y cada uno \w peleará|strong="H3898"\w* contra su hermano, y cada cual contra su \w prójimo|strong="H7453"\w*; \w ciudad|strong="H5892"\w* contra \w ciudad|strong="H5892"\w*, y \w reino|strong="H4467"\w* contra \w reino|strong="H4467"\w*.  
\v 3 El \w espíritu|strong="H7307"\w* de \w Egipto|strong="H4714"\w* se disipará en \w medio|strong="H7130"\w* de él, y yo destruiré su \w consejo|strong="H6098"\w*. Entonces consultarán \w a|strong="H3068"\w* los ídolos, \w a|strong="H3068"\w* los evocadores, \w a|strong="H3068"\w* los pitones y \w a|strong="H3068"\w* los \w adivinos|strong="H3049"\w*.  
\v 4 \w Y|strong="H3068"\w* entregaré \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* en \w manos|strong="H3027"\w* de un \w señor|strong="H3068"\w* cruel, y un \w rey|strong="H4428"\w* \w violento|strong="H5794"\w* se enseñoreará de \w ellos|strong="H3027"\w*», \w dice|strong="H5002"\w* el \w Señor|strong="H3068"\w*, Yahvé de los \w Ejércitos|strong="H6635"\w*.   
\p
\v 5 Las \w aguas|strong="H4325"\w* del \w mar|strong="H3220"\w* \w faltarán|strong="H5405"\w*, y el \w río|strong="H5104"\w* se agotará y se \w secará|strong="H3001"\w*.  
\v 6 Los \w ríos|strong="H2975"\w* se corromperán, los canales de Egipto disminuirán y se secarán; las \w cañas|strong="H7070"\w* y los juncos se marchitarán.  
\v 7 \w Las|strong="H5921"\w* praderas \w junto|strong="H5921"\w* \w al|strong="H5921"\w* Nilo, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* orilla \w del|strong="H5921"\w* \w río|strong="H2975"\w*, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* sembrado \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* \w secará|strong="H3001"\w*, \w se|strong="H5921"\w* dispersará \w y|strong="H5921"\w* \w no|strong="H5921"\w* existirá \w más|strong="H5921"\w*.  
\v 8 \w Los|strong="H5921"\w* pescadores también \w se|strong="H5921"\w* lamentarán; gemirán \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* echan anzuelo \w en|strong="H5921"\w* \w el|strong="H5921"\w* Nilo, \w y|strong="H5921"\w* desfallecerán \w los|strong="H5921"\w* \w que|strong="H5921"\w* extienden red \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*.  
\v 9 Los que trabajan el \w lino|strong="H6593"\w* \w fino|strong="H8305"\w* y los que tejen telas blancas quedarán confundidos.  
\v 10 Porque sus columnas \w serán|strong="H1961"\w* destruidas, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* jornaleros \w se|strong="H1961"\w* angustiarán de \w ánimo|strong="H5315"\w*.   
\p
\v 11 Ciertamente son necios \w los|strong="H1121"\w* \w príncipes|strong="H8269"\w* \w de|strong="H1121"\w* Zoán; \w el|strong="H1121"\w* \w consejo|strong="H6098"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* prudentes \w consejeros|strong="H6098"\w* \w de|strong="H1121"\w* \w Faraón|strong="H6547"\w* se ha vuelto estúpido. ¿Cómo decís \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*: «Yo soy \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w sabios|strong="H2450"\w*, \w e|strong="H3068"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w antiguos|strong="H6924"\w*»?  
\v 12 ¿\w Dónde|strong="H5921"\w* están \w ahora|strong="H4994"\w* vuestros \w sabios|strong="H2450"\w*? \w Que|strong="H4100"\w* \w os|strong="H5921"\w* digan \w ahora|strong="H4994"\w*, \w o|strong="H3068"\w* \w que|strong="H4100"\w* \w sepan|strong="H3045"\w* \w qué|strong="H4100"\w* es \w lo|strong="H4100"\w* \w que|strong="H4100"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* ha determinado \w sobre|strong="H5921"\w* \w Egipto|strong="H4714"\w*.  
\v 13 Se han acobardado los \w príncipes|strong="H8269"\w* \w de|strong="H8269"\w* Zoán, se han engañado los \w príncipes|strong="H8269"\w* \w de|strong="H8269"\w* Menfis; han hecho \w errar|strong="H8582"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* los que son la piedra \w angular|strong="H6438"\w* \w de|strong="H8269"\w* sus \w tribus|strong="H7626"\w*.  
\v 14 Yahvé \w mezcló|strong="H4537"\w* \w espíritu|strong="H7307"\w* de perversidad en \w medio|strong="H7130"\w* de \w él|strong="H3605"\w*; \w e|strong="H3068"\w* hicieron \w errar|strong="H8582"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* en \w toda|strong="H3605"\w* su \w obra|strong="H4639"\w*, como \w el|strong="H3605"\w* borracho se tambalea en su \w vómito|strong="H6892"\w*.  
\v 15 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* \w para|strong="H1961"\w* \w Egipto|strong="H4714"\w* \w obra|strong="H4639"\w* \w que|strong="H3808"\w* \w haga|strong="H6213"\w* \w cabeza|strong="H7218"\w* \w o|strong="H3068"\w* \w cola|strong="H2180"\w*, rama \w o|strong="H3068"\w* junco.  
\v 16 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w* \w serán|strong="H1961"\w* \w como|strong="H1961"\w* mujeres; \w porque|strong="H5921"\w* temerán \w y|strong="H5921"\w* temblarán \w ante|strong="H6440"\w* \w el|strong="H1931"\w* movimiento \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*, \w que|strong="H1931"\w* \w él|strong="H1931"\w* agitará \w sobre|strong="H5921"\w* \w ellos|strong="H3027"\w*.  
\v 17 \w Y|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w será|strong="H1961"\w* \w de|strong="H5921"\w* espanto \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*; \w todo|strong="H3605"\w* hombre \w que|strong="H1931"\w* \w de|strong="H5921"\w* \w ella|strong="H1931"\w* \w se|strong="H1961"\w* acordare temerá \w por|strong="H5921"\w* \w causa|strong="H6440"\w* \w del|strong="H5921"\w* \w consejo|strong="H6098"\w* \w que|strong="H1931"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* determinó \w contra|strong="H5921"\w* \w él|strong="H1931"\w*.  
\v 18 En \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w* \w habrá|strong="H1961"\w* \w cinco|strong="H2568"\w* \w ciudades|strong="H5892"\w* en \w la|strong="H1931"\w* tierra \w de|strong="H2568"\w* \w Egipto|strong="H4714"\w* \w que|strong="H1931"\w* \w hablen|strong="H1696"\w* \w la|strong="H1931"\w* \w lengua|strong="H8193"\w* \w de|strong="H2568"\w* \w Canaán|strong="H3667"\w*, y \w que|strong="H1931"\w* juren por Yahvé \w de|strong="H2568"\w* \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w*; una \w de|strong="H2568"\w* \w ellas|strong="H1931"\w* \w será|strong="H1961"\w* llamada «\w La|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w de|strong="H2568"\w* \w la|strong="H1931"\w* Destrucción».   
\p
\v 19 \w En|strong="H8432"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w habrá|strong="H1961"\w* un \w altar|strong="H4196"\w* \w para|strong="H1961"\w* Yahvé \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w la|strong="H1931"\w* tierra de \w Egipto|strong="H4714"\w*, y un monumento \w a|strong="H3068"\w* Yahvé junto \w a|strong="H3068"\w* \w su|strong="H1931"\w* frontera.  
\v 20 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w por|strong="H3588"\w* señal \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w testimonio|strong="H5707"\w* \w a|strong="H3068"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*; \w porque|strong="H3588"\w* \w clamarán|strong="H6817"\w* \w a|strong="H3068"\w* Yahvé \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* sus opresores, \w y|strong="H3588"\w* \w él|strong="H3588"\w* les \w enviará|strong="H7971"\w* \w salvador|strong="H3467"\w* \w y|strong="H3588"\w* príncipe \w que|strong="H3588"\w* \w los|strong="H1961"\w* \w libre|strong="H5337"\w*.  
\v 21 \w Y|strong="H3068"\w* Yahvé \w será|strong="H1931"\w* \w conocido|strong="H3045"\w* de \w Egipto|strong="H4714"\w*, y \w los|strong="H1931"\w* \w egipcios|strong="H4714"\w* \w conocerán|strong="H3045"\w* \w a|strong="H3068"\w* Yahvé en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*; y \w harán|strong="H5647"\w* \w sacrificio|strong="H2077"\w* y \w oblación|strong="H4503"\w*; y \w harán|strong="H5647"\w* \w votos|strong="H5087"\w* \w a|strong="H3068"\w* Yahvé y \w los|strong="H1931"\w* \w cumplirán|strong="H7999"\w*.  
\v 22 \w Y|strong="H3068"\w* \w herirá|strong="H5062"\w* Yahvé \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*; \w herirá|strong="H5062"\w* \w y|strong="H5704"\w* sanará; \w y|strong="H5704"\w* se convertirán \w a|strong="H3068"\w* Yahvé, \w y|strong="H5704"\w* les será propicio \w y|strong="H5704"\w* los sanará.   
\p
\v 23 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w habrá|strong="H1961"\w* una \w calzada|strong="H4546"\w* desde \w Egipto|strong="H4714"\w* \w hasta|strong="H3117"\w* Asiria, y asirios entrarán en \w Egipto|strong="H4714"\w* y \w egipcios|strong="H4714"\w* en Asiria; y \w los|strong="H1931"\w* \w egipcios|strong="H4714"\w* \w servirán|strong="H5647"\w* con \w los|strong="H1931"\w* asirios \w a|strong="H3068"\w* Yahvé.   
\p
\v 24 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w Israel|strong="H3478"\w* \w será|strong="H1961"\w* \w tercero|strong="H7992"\w* con \w Egipto|strong="H4714"\w* y con Asiria \w para|strong="H1961"\w* \w bendición|strong="H1293"\w* en \w medio|strong="H7130"\w* de \w la|strong="H1931"\w* tierra;  
\v 25 porque Yahvé \w de|strong="H5971"\w* los \w Ejércitos|strong="H6635"\w* los \w bendecirá|strong="H1288"\w* diciendo: «\w Bendito|strong="H1288"\w* el \w pueblo|strong="H5971"\w* \w mío|strong="H5971"\w* \w Egipto|strong="H4714"\w*, y el asirio \w obra|strong="H4639"\w* \w de|strong="H5971"\w* mis \w manos|strong="H3027"\w*, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* mi \w heredad|strong="H5159"\w*».   
\c 20
\p
\v 1 El \w año|strong="H8141"\w* en que el Tartán llegó \w a|strong="H3068"\w* Asdod, cuando lo \w envió|strong="H7971"\w* \w Sargón|strong="H5623"\w*, \w rey|strong="H4428"\w* \w de|strong="H3898"\w* Asiria, y combatió contra Asdod y la \w tomó|strong="H3920"\w*;  
\v 2 \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* Yahvé \w habló|strong="H1696"\w* \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w Isaías|strong="H3470"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz, \w diciendo|strong="H1696"\w*: «\w Ve|strong="H3212"\w*, desata \w el|strong="H1931"\w* cilicio \w de|strong="H5921"\w* tus \w lomos|strong="H4975"\w* \w y|strong="H5921"\w* quita \w las|strong="H5921"\w* sandalias \w de|strong="H5921"\w* tus \w pies|strong="H7272"\w*». \w Y|strong="H3068"\w* \w lo|strong="H1931"\w* \w hizo|strong="H6213"\w* \w así|strong="H3651"\w*, \w andando|strong="H1980"\w* \w desnudo|strong="H6174"\w* \w y|strong="H5921"\w* descalzo.  
\v 3 \w Y|strong="H3068"\w* dijo Yahvé: “\w Al|strong="H5921"\w* modo \w que|strong="H5921"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* \w Isaías|strong="H3470"\w* \w anduvo|strong="H1980"\w* \w desnudo|strong="H6174"\w* \w y|strong="H5921"\w* descalzo \w tres|strong="H7969"\w* \w años|strong="H8141"\w*, \w por|strong="H5921"\w* señal \w y|strong="H5921"\w* prodigio \w sobre|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w Etiopía|strong="H3568"\w*,  
\v 4 \w así|strong="H3651"\w* \w llevará|strong="H5090"\w* el \w rey|strong="H4428"\w* de Asiria \w a|strong="H3068"\w* los \w cautivos|strong="H7628"\w* de \w Egipto|strong="H4714"\w* y \w a|strong="H3068"\w* los exiliados de \w Etiopía|strong="H3568"\w*, jóvenes y \w ancianos|strong="H2205"\w*, \w desnudos|strong="H6174"\w*, descalzos y descubiertas las nalgas, para \w vergüenza|strong="H6172"\w* de \w Egipto|strong="H4714"\w*.  
\v 5 \w Y|strong="H3068"\w* \w se|strong="H4480"\w* turbarán y avergonzarán \w a|strong="H3068"\w* causa \w de|strong="H4480"\w* \w Etiopía|strong="H3568"\w*, su \w esperanza|strong="H4007"\w*, y \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*, su \w gloria|strong="H8597"\w*.  
\v 6 \w Y|strong="H3068"\w* dirán en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H6440"\w* \w esta|strong="H2088"\w* costa: ‘\w Mirad|strong="H2009"\w* \w qué|strong="H1931"\w* \w ha|strong="H3541"\w* sido \w de|strong="H6440"\w* nuestra \w esperanza|strong="H4007"\w*, \w a|strong="H3068"\w* \w donde|strong="H8033"\w* nos acogimos \w por|strong="H6440"\w* \w socorro|strong="H5833"\w* para ser \w librados|strong="H5337"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* \w presencia|strong="H6440"\w* del \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Asiria. ¿\w Y|strong="H3068"\w* \w nosotros|strong="H1931"\w*, \w cómo|strong="H1931"\w* \w escaparemos|strong="H4422"\w*?’”   
\c 21
\p
\v 1 Oráculo sobre el \w desierto|strong="H4057"\w* del \w mar|strong="H3220"\w*.  
\p Como los torbellinos del sur que lo recorren todo, así viene del \w desierto|strong="H4057"\w*, \w de|strong="H3372"\w* una tierra temible.  
\v 2 \w Visión|strong="H2380"\w* \w dura|strong="H7186"\w* me ha sido mostrada: \w el|strong="H3605"\w* traidor traiciona, y \w el|strong="H3605"\w* destructor \w destruye|strong="H7703"\w*. ¡\w Sube|strong="H5927"\w*, \w Elam|strong="H5867"\w*! ¡Sitia, \w Media|strong="H4074"\w*! He hecho cesar \w todo|strong="H3605"\w* su gemido.  
\v 3 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* mis \w lomos|strong="H4975"\w* \w se|strong="H5921"\w* han llenado \w de|strong="H5921"\w* angustia; dolores \w se|strong="H5921"\w* apoderaron \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w como|strong="H5921"\w* dolores \w de|strong="H5921"\w* mujer \w de|strong="H5921"\w* parto; \w me|strong="H5921"\w* agobié \w tanto|strong="H3651"\w* \w que|strong="H5921"\w* \w no|strong="H5921"\w* \w oía|strong="H8085"\w*, \w y|strong="H5921"\w* \w me|strong="H5921"\w* asombré \w de|strong="H5921"\w* \w tal|strong="H3651"\w* modo \w que|strong="H5921"\w* \w no|strong="H5921"\w* \w veía|strong="H7200"\w*.  
\v 4 Se pasmó mi \w corazón|strong="H3824"\w*, el horror me ha intimidado; la noche que deseaba se me volvió en espanto.  
\v 5 Disponed la \w mesa|strong="H7979"\w*, extended los tapices, comed, \w bebed|strong="H8354"\w*. ¡\w Levantaos|strong="H6965"\w*, \w príncipes|strong="H8269"\w*, engrasad el \w escudo|strong="H4043"\w*!  
\v 6 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* Señor \w me|strong="H3588"\w* \w dijo|strong="H5046"\w* \w así|strong="H3541"\w*: «\w Ve|strong="H3212"\w*, \w pon|strong="H5975"\w* \w centinela|strong="H6822"\w* \w que|strong="H3588"\w* haga \w saber|strong="H5046"\w* lo \w que|strong="H3588"\w* \w vea|strong="H7200"\w*».  
\v 7 \w Y|strong="H3068"\w* \w vio|strong="H7200"\w* una tropa, una pareja de \w jinetes|strong="H6571"\w*, \w hombres|strong="H6571"\w* \w montados|strong="H7393"\w* en \w asnos|strong="H2543"\w* y \w hombres|strong="H6571"\w* \w montados|strong="H7393"\w* en \w camellos|strong="H1581"\w*; y \w escuchó|strong="H7181"\w* con \w gran|strong="H7227"\w* atención.  
\v 8 Entonces \w gritó|strong="H7121"\w* \w como|strong="H5921"\w* un león: «Señor, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* atalaya \w estoy|strong="H5324"\w* yo \w de|strong="H5921"\w* \w continuo|strong="H8548"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w día|strong="H3119"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* puesto \w de|strong="H5921"\w* guardia permanezco \w noches|strong="H3915"\w* \w enteras|strong="H3605"\w*.  
\v 9 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w*, viene una tropa de \w hombres|strong="H6571"\w*, \w jinetes|strong="H6571"\w* de dos en dos». Después \w él|strong="H3605"\w* \w respondió|strong="H6030"\w* y dijo: «¡Caída, caída \w es|strong="H2088"\w* Babilonia! \w Y|strong="H3068"\w* \w todas|strong="H3605"\w* las imágenes grabadas de sus dioses \w cayeron|strong="H5307"\w* \w rotas|strong="H7665"\w* \w por|strong="H2088"\w* tierra».   
\p
\v 10 ¡\w Oh|strong="H1121"\w* pueblo mío, trillado y trigo \w de|strong="H1121"\w* mi \w era|strong="H1121"\w*! Lo \w que|strong="H1121"\w* \w oí|strong="H8085"\w* \w de|strong="H1121"\w* Yahvé \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, os lo he anunciado.   
\p
\v 11 Oráculo sobre \w Dumá|strong="H1746"\w*.  
\p Me dan voces desde \w Seir|strong="H8165"\w*: «Centinela, ¿\w qué|strong="H4100"\w* hay de \w la|strong="H8104"\w* \w noche|strong="H3915"\w*? Centinela, ¿\w qué|strong="H4100"\w* hay de \w la|strong="H8104"\w* \w noche|strong="H3915"\w*?».  
\v 12 \w El|strong="H1571"\w* centinela \w respondió|strong="H7725"\w*: «\w La|strong="H1571"\w* \w mañana|strong="H1242"\w* viene, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w la|strong="H1571"\w* \w noche|strong="H3915"\w*; \w si|strong="H1571"\w* queréis preguntar, \w preguntad|strong="H1158"\w*; \w volved|strong="H7725"\w*, venid».   
\p
\v 13 Oráculo sobre \w Arabia|strong="H6152"\w*.  
\p En la espesura de \w Arabia|strong="H6152"\w* os alojaréis, vosotros, caravanas de dedanitas.  
\v 14 Salid al encuentro del sediento y llevadle \w agua|strong="H4325"\w*; \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H4325"\w* la tierra \w de|strong="H4325"\w* Tema socorrieron con su \w pan|strong="H3899"\w* al \w que|strong="H4325"\w* huía.  
\v 15 \w Porque|strong="H3588"\w* \w ante|strong="H6440"\w* las \w espadas|strong="H2719"\w* huyen, \w ante|strong="H6440"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* \w desnuda|strong="H5203"\w*, \w ante|strong="H6440"\w* \w el|strong="H3588"\w* \w arco|strong="H7198"\w* \w entesado|strong="H1869"\w* \w y|strong="H3588"\w* \w ante|strong="H6440"\w* \w el|strong="H3588"\w* peso \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w*.  
\v 16 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* \w me|strong="H3588"\w* \w ha|strong="H3541"\w* dicho \w el|strong="H3588"\w* Señor: «\w Dentro|strong="H5750"\w* \w de|strong="H3588"\w* un \w año|strong="H8141"\w*, \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w año|strong="H8141"\w* \w de|strong="H3588"\w* un jornalero, \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w gloria|strong="H3519"\w* \w de|strong="H3588"\w* \w Cedar|strong="H6938"\w* se acabará;  
\v 17 \w y|strong="H3588"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* queden del \w número|strong="H4557"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w valientes|strong="H1368"\w* arqueros, \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Cedar|strong="H6938"\w*, serán \w pocos|strong="H4557"\w*; \w porque|strong="H3588"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, lo ha \w dicho|strong="H1696"\w*».   
\c 22
\p
\v 1 Oráculo del \w Valle|strong="H1516"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* \w Visión|strong="H2384"\w*. ¿\w Qué|strong="H3588"\w* os pasa ahora, \w que|strong="H3588"\w* \w todos|strong="H3605"\w* habéis \w subido|strong="H5927"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* terrados?  
\v 2 Tú, \w ciudad|strong="H5892"\w* llena de alboroto, \w ciudad|strong="H5892"\w* estrepitosa, pueblo \w alegre|strong="H5947"\w*; tus \w muertos|strong="H2491"\w* \w no|strong="H3808"\w* \w murieron|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w ni|strong="H3808"\w* \w murieron|strong="H4191"\w* en la \w guerra|strong="H4421"\w*.  
\v 3 \w Todos|strong="H3605"\w* tus \w príncipes|strong="H7101"\w* \w huyeron|strong="H5074"\w* \w juntos|strong="H3162"\w*, sin \w el|strong="H3605"\w* \w arco|strong="H7198"\w* fueron presos; \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* en ti se \w hallaron|strong="H4672"\w*, fueron presos \w juntos|strong="H3162"\w*, aunque habían huido \w lejos|strong="H7350"\w*.  
\v 4 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* dije: «Apartad \w la|strong="H5921"\w* vista \w de|strong="H4480"\w* \w mí|strong="H5921"\w*, lloraré amargamente; \w no|strong="H5921"\w* \w os|strong="H4480"\w* afanéis \w por|strong="H5921"\w* \w consolarme|strong="H5162"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w destrucción|strong="H7701"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H4480"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*».   
\p
\v 5 \w Porque|strong="H3588"\w* \w es|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* alboroto, \w de|strong="H3588"\w* angustia \w y|strong="H3588"\w* \w de|strong="H3588"\w* perplejidad, \w de|strong="H3588"\w* parte del Señor, Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w*, \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w Valle|strong="H1516"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w Visión|strong="H2384"\w*; \w día|strong="H3117"\w* \w de|strong="H3588"\w* derribar muros \w y|strong="H3588"\w* \w de|strong="H3588"\w* clamar \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w montes|strong="H2022"\w*.  
\v 6 \w Y|strong="H3068"\w* \w Elam|strong="H5867"\w* \w tomó|strong="H5375"\w* el carcaj con \w carros|strong="H7393"\w* de \w hombres|strong="H6571"\w* y de \w jinetes|strong="H6571"\w*, y Kir desembozó el \w escudo|strong="H4043"\w*.  
\v 7 Tus \w valles|strong="H6010"\w* más hermosos \w se|strong="H1961"\w* \w llenaron|strong="H4390"\w* de \w carros|strong="H7393"\w*, y \w los|strong="H1961"\w* \w jinetes|strong="H6571"\w* \w se|strong="H1961"\w* pusieron en orden \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w*.  
\v 8 \w Y|strong="H3068"\w* quitó \w la|strong="H1931"\w* cubierta de \w Judá|strong="H3063"\w*; y \w mirasteis|strong="H5027"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* hacia \w la|strong="H1931"\w* armería de \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* del \w Bosque|strong="H3293"\w*.  
\v 9 \w Visteis|strong="H7200"\w* las brechas \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w de|strong="H3588"\w* \w David|strong="H1732"\w*, \w que|strong="H3588"\w* eran \w muchas|strong="H7235"\w*; \w y|strong="H3588"\w* recogisteis las \w aguas|strong="H4325"\w* del \w estanque|strong="H1295"\w* inferior.  
\v 10 Contasteis las \w casas|strong="H1004"\w* de Jerusalén, y derribasteis \w casas|strong="H1004"\w* para fortificar el \w muro|strong="H2346"\w*.  
\v 11 \w Hicisteis|strong="H6213"\w* también un \w foso|strong="H4724"\w* \w entre|strong="H3808"\w* los dos \w muros|strong="H2346"\w* para las \w aguas|strong="H4325"\w* del \w estanque|strong="H1295"\w* viejo; y \w no|strong="H3808"\w* \w mirasteis|strong="H5027"\w* al \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w hizo|strong="H6213"\w*, \w ni|strong="H3808"\w* tuvisteis respeto al \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w formó|strong="H3335"\w* \w hace|strong="H6213"\w* mucho tiempo.   
\p
\v 12 Por tanto, \w el|strong="H1931"\w* Señor, Yahvé de \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w*, \w llamó|strong="H7121"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w a|strong="H3068"\w* \w llanto|strong="H1065"\w* y \w a|strong="H3068"\w* luto, \w a|strong="H3068"\w* raparse \w la|strong="H1931"\w* cabeza y \w a|strong="H3068"\w* vestir cilicio;  
\v 13 \w y|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w gozo|strong="H8057"\w* \w y|strong="H3588"\w* \w alegría|strong="H8057"\w*, \w matando|strong="H4191"\w* \w vacas|strong="H1241"\w* \w y|strong="H3588"\w* degollando \w ovejas|strong="H6629"\w*, comiendo \w carne|strong="H1320"\w* \w y|strong="H3588"\w* \w bebiendo|strong="H8354"\w* \w vino|strong="H3196"\w*, diciendo: «Comamos \w y|strong="H3588"\w* bebamos, \w porque|strong="H3588"\w* \w mañana|strong="H4279"\w* \w moriremos|strong="H4191"\w*».  
\v 14 \w Esto|strong="H2088"\w* \w fue|strong="H6635"\w* revelado \w a|strong="H3068"\w* mis oídos \w por|strong="H2088"\w* Yahvé \w de|strong="H5704"\w* los \w Ejércitos|strong="H6635"\w*: «\w Que|strong="H5704"\w* \w este|strong="H2088"\w* \w pecado|strong="H5771"\w* no \w os|strong="H5704"\w* será perdonado \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w muráis|strong="H4191"\w*», dice el \w Señor|strong="H3068"\w*, Yahvé \w de|strong="H5704"\w* los \w Ejércitos|strong="H6635"\w*.   
\p
\v 15 Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* dice \w así|strong="H3541"\w*: “\w Id|strong="H3212"\w*, entra \w a|strong="H3068"\w* \w este|strong="H2088"\w* administrador, \w a|strong="H3068"\w* \w Sebna|strong="H7644"\w* \w el|strong="H5921"\w* \w mayordomo|strong="H5921"\w* \w de|strong="H5921"\w* palacio, \w y|strong="H5921"\w* dile:  
\v 16 ‘¿\w Qué|strong="H3588"\w* tienes tú \w aquí|strong="H6311"\w*, \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w quién|strong="H4310"\w* tienes tú \w aquí|strong="H6311"\w*, \w que|strong="H3588"\w* \w labraste|strong="H2672"\w* \w aquí|strong="H6311"\w* \w sepulcro|strong="H6913"\w* \w para|strong="H3588"\w* ti?’. \w Como|strong="H4100"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* lugar \w alto|strong="H4791"\w* labra \w su|strong="H3588"\w* \w sepultura|strong="H6913"\w*, \w o|strong="H3068"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w esculpe|strong="H2710"\w* \w para|strong="H3588"\w* \w sí|strong="H3588"\w* morada \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w roca|strong="H5553"\w*.  
\v 17 He \w aquí|strong="H2009"\w* que Yahvé te transportará con duro transporte, y de cierto te cubrirá el rostro.  
\v 18 Te hará rodar con fuerza, \w y|strong="H3519"\w* te arrojará como \w a|strong="H3068"\w* una pelota \w a|strong="H3068"\w* tierra extensa; \w allá|strong="H8033"\w* \w morirás|strong="H4191"\w*, \w y|strong="H3519"\w* \w allá|strong="H8033"\w* estarán los \w carros|strong="H4818"\w* de tu \w gloria|strong="H3519"\w*, ¡oh vergüenza de la \w casa|strong="H1004"\w* de tu señor!  
\v 19 \w Y|strong="H3068"\w* te arrojaré de tu lugar, y de tu puesto te depondré.   
\p
\v 20 \w Y|strong="H3068"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w llamaré|strong="H7121"\w* \w a|strong="H3068"\w* \w mi|strong="H1961"\w* \w siervo|strong="H5650"\w* Eliaquim \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hilcías|strong="H2518"\w*,  
\v 21 y lo \w vestiré|strong="H3847"\w* \w de|strong="H3847"\w* tus \w vestiduras|strong="H3801"\w*, y lo ceñiré \w de|strong="H3847"\w* tu talabarte, y \w entregaré|strong="H5414"\w* en sus \w manos|strong="H3027"\w* tu potestad; y \w será|strong="H1961"\w* padre al \w morador|strong="H3427"\w* \w de|strong="H3847"\w* Jerusalén y \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H3847"\w* \w Judá|strong="H3063"\w*.  
\v 22 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* \w la|strong="H5921"\w* llave \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w sobre|strong="H5921"\w* su \w hombro|strong="H7926"\w*; \w y|strong="H5921"\w* \w abrirá|strong="H6605"\w*, \w y|strong="H5921"\w* nadie \w cerrará|strong="H5462"\w*; \w cerrará|strong="H5462"\w*, \w y|strong="H5921"\w* nadie \w abrirá|strong="H6605"\w*.  
\v 23 \w Y|strong="H3068"\w* lo hincaré \w como|strong="H1961"\w* clavo en \w lugar|strong="H4725"\w* firme; \w y|strong="H3519"\w* \w será|strong="H1961"\w* por \w trono|strong="H3678"\w* de \w gloria|strong="H3519"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de su padre.  
\v 24 \w Y|strong="H3068"\w* colgarán \w de|strong="H5921"\w* \w él|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w honra|strong="H3519"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su padre, \w los|strong="H5921"\w* hijos \w y|strong="H5921"\w* \w la|strong="H5921"\w* prole, \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w vasos|strong="H3627"\w* \w menores|strong="H6996"\w*, \w desde|strong="H5704"\w* \w las|strong="H5921"\w* tazas \w hasta|strong="H5704"\w* \w los|strong="H5921"\w* tinajones.  
\v 25 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* — \w dice|strong="H5002"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* — \w el|strong="H1931"\w* clavo \w hincado|strong="H8628"\w* \w en|strong="H5921"\w* \w lugar|strong="H4725"\w* firme \w será|strong="H1931"\w* quitado; \w será|strong="H1931"\w* quebrado \w y|strong="H3588"\w* \w caerá|strong="H5307"\w*, \w y|strong="H3588"\w* \w la|strong="H1931"\w* \w carga|strong="H4853"\w* \w que|strong="H3588"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* \w se|strong="H1931"\w* puso \w se|strong="H1931"\w* perderá, \w porque|strong="H3588"\w* Yahvé ha \w hablado|strong="H1696"\w*”.   
\c 23
\p
\v 1 Oráculo sobre \w Tiro|strong="H6865"\w*.  
\p ¡\w Aullad|strong="H3213"\w*, naves \w de|strong="H3588"\w* \w Tarsis|strong="H8659"\w*! \w Porque|strong="H3588"\w* \w Tiro|strong="H6865"\w* ha sido asolada hasta \w no|strong="H3588"\w* quedar \w casa|strong="H1004"\w* ni puerto donde entrar. Desde \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* Quitim les ha sido revelado.  
\v 2 \w Callad|strong="H1826"\w*, \w moradores|strong="H3427"\w* de la costa, vosotros \w a|strong="H3068"\w* quienes \w los|strong="H3427"\w* \w mercaderes|strong="H5503"\w* de \w Sidón|strong="H6721"\w*, que atraviesan \w el|strong="H5674"\w* \w mar|strong="H3220"\w*, habían enriquecido.  
\v 3 Por las \w grandes|strong="H7227"\w* \w aguas|strong="H4325"\w* le venía la \w simiente|strong="H2233"\w* \w de|strong="H4325"\w* Sijor; la cosecha del Nilo \w era|strong="H1961"\w* su renta, y ella \w era|strong="H1961"\w* \w el|strong="H2975"\w* mercado \w de|strong="H4325"\w* las \w naciones|strong="H1471"\w*.  
\v 4 Avergüénzate, \w Sidón|strong="H6721"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w mar|strong="H3220"\w* \w ha|strong="H3808"\w* hablado, \w la|strong="H3588"\w* \w fortaleza|strong="H4581"\w* del \w mar|strong="H3220"\w*, diciendo: «\w No|strong="H3808"\w* tuve dolores \w de|strong="H3588"\w* parto, \w ni|strong="H3808"\w* di \w a|strong="H3068"\w* luz, \w ni|strong="H3808"\w* \w crié|strong="H1431"\w* jóvenes, \w ni|strong="H3808"\w* eduqué \w vírgenes|strong="H1330"\w*».  
\v 5 Cuando la noticia llegue \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, tendrán gran \w dolor|strong="H2342"\w* al oír de \w Tiro|strong="H6865"\w*.  
\v 6 \w Pasad|strong="H5674"\w* \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*; \w aullad|strong="H3213"\w*, \w moradores|strong="H3427"\w* de la costa.  
\v 7 ¿\w Es|strong="H2063"\w* \w esta|strong="H2063"\w* \w vuestra|strong="H2063"\w* ciudad \w alegre|strong="H5947"\w*, cuya antigüedad \w es|strong="H2063"\w* de \w días|strong="H3117"\w* remotos, y cuyos \w pies|strong="H7272"\w* \w la|strong="H2063"\w* llevaron \w a|strong="H3068"\w* peregrinar \w lejos|strong="H7350"\w*?   
\p
\v 8 ¿\w Quién|strong="H4310"\w* ha planeado \w esto|strong="H2063"\w* \w contra|strong="H5921"\w* \w Tiro|strong="H6865"\w*, \w la|strong="H5921"\w* \w que|strong="H4310"\w* repartía coronas, \w cuyos|strong="H5921"\w* \w mercaderes|strong="H5503"\w* eran \w príncipes|strong="H8269"\w*, \w cuyos|strong="H5921"\w* comerciantes eran \w los|strong="H5921"\w* nobles \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra?  
\v 9 Yahvé de \w los|strong="H3605"\w* \w Ejércitos|strong="H6635"\w* \w lo|strong="H3605"\w* ha planeado, para abatir \w la|strong="H3605"\w* \w soberbia|strong="H1347"\w* de \w toda|strong="H3605"\w* \w gloria|strong="H6643"\w*, y para despreciar \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* nobles de \w la|strong="H3605"\w* tierra.  
\v 10 \w Pasa|strong="H5674"\w* \w por|strong="H5750"\w* tu tierra \w como|strong="H5750"\w* \w el|strong="H2975"\w* Nilo, \w hija|strong="H1323"\w* \w de|strong="H5750"\w* \w Tarsis|strong="H8659"\w*; porque ya no \w tienes|strong="H5750"\w* ningún vallado.  
\v 11 \w Él|strong="H5921"\w* \w extendió|strong="H5186"\w* su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, hizo temblar \w los|strong="H5921"\w* \w reinos|strong="H4467"\w*; Yahvé dio \w orden|strong="H6680"\w* respecto \w a|strong="H3068"\w* \w Canaán|strong="H3667"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* sus fortalezas sean destruidas.  
\v 12 \w Y|strong="H3068"\w* dijo: «\w No|strong="H3808"\w* te alegrarás \w más|strong="H5750"\w*, oh \w virgen|strong="H1330"\w* \w oprimida|strong="H6231"\w*, \w hija|strong="H1323"\w* \w de|strong="H5750"\w* \w Sidón|strong="H6721"\w*. \w Levántate|strong="H6965"\w* para \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* Quitim; \w aun|strong="H5750"\w* \w allí|strong="H8033"\w* \w no|strong="H3808"\w* tendrás \w reposo|strong="H5117"\w*».   
\p
\v 13 Mirad la tierra \w de|strong="H5971"\w* \w los|strong="H1961"\w* \w caldeos|strong="H3778"\w*. \w Este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* \w existía|strong="H1961"\w*; Asiria la \w fundó|strong="H3245"\w* \w para|strong="H1961"\w* \w los|strong="H1961"\w* habitantes del desierto. \w Levantaron|strong="H6965"\w* sus torres, destruyeron sus palacios y la convirtieron en ruinas.  
\v 14 ¡\w Aullad|strong="H3213"\w*, naves \w de|strong="H3588"\w* \w Tarsis|strong="H8659"\w*, \w porque|strong="H3588"\w* vuestra \w fortaleza|strong="H4581"\w* ha sido \w destruida|strong="H7703"\w*!  
\v 15 \w Acontecerá|strong="H1961"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H1931"\w* \w Tiro|strong="H6865"\w* \w será|strong="H1961"\w* puesta en \w olvido|strong="H7911"\w* \w por|strong="H4428"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*, \w como|strong="H1961"\w* \w los|strong="H1931"\w* \w días|strong="H3117"\w* \w de|strong="H7911"\w* un \w rey|strong="H4428"\w*. \w Pasados|strong="H1961"\w* \w los|strong="H1931"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*, \w le|strong="H1931"\w* \w sucederá|strong="H1961"\w* \w a|strong="H3068"\w* \w Tiro|strong="H6865"\w* \w como|strong="H1961"\w* en \w la|strong="H1931"\w* \w canción|strong="H7892"\w* \w de|strong="H7911"\w* \w la|strong="H1931"\w* \w ramera|strong="H2181"\w*:  
\v 16 «\w Toma|strong="H3947"\w* el \w arpa|strong="H3658"\w*, rodea la \w ciudad|strong="H5892"\w*, oh \w ramera|strong="H2181"\w* \w olvidada|strong="H7911"\w*; toca \w bien|strong="H3190"\w*, canta \w muchas|strong="H7235"\w* \w canciones|strong="H7892"\w*, \w para|strong="H4616"\w* \w que|strong="H4616"\w* seas recordada».  
\v 17 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H5921"\w* \w al|strong="H5921"\w* \w fin|strong="H7093"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*, Yahvé \w visitará|strong="H6485"\w* \w a|strong="H3068"\w* \w Tiro|strong="H6865"\w*; \w y|strong="H5921"\w* \w ella|strong="H5921"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* su comercio, \w y|strong="H5921"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* fornicar \w con|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w del|strong="H5921"\w* mundo \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
\v 18 \w Pero|strong="H3588"\w* sus negocios \w y|strong="H3588"\w* sus ganancias \w serán|strong="H1961"\w* consagrados \w a|strong="H3068"\w* Yahvé. \w No|strong="H3808"\w* \w se|strong="H1961"\w* guardarán \w ni|strong="H3808"\w* \w se|strong="H1961"\w* atesorarán, \w porque|strong="H3588"\w* sus ganancias \w serán|strong="H1961"\w* \w para|strong="H3588"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w habitan|strong="H3427"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Yahvé, \w para|strong="H3588"\w* \w que|strong="H3588"\w* coman hasta saciarse \w y|strong="H3588"\w* vistan ropas espléndidas.   
\c 24
\p
\v 1 He \w aquí|strong="H2009"\w* \w que|strong="H5753"\w* Yahvé \w vacía|strong="H1238"\w* la tierra y la desnuda, trastorna su \w faz|strong="H6440"\w* y dispersa \w a|strong="H3068"\w* sus \w moradores|strong="H3427"\w*.  
\v 2 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w como|strong="H1961"\w* al \w pueblo|strong="H5971"\w*, así al \w sacerdote|strong="H3548"\w*; \w como|strong="H1961"\w* al \w siervo|strong="H5650"\w*, así \w a|strong="H3068"\w* su señor; \w como|strong="H1961"\w* \w a|strong="H3068"\w* la criada, así \w a|strong="H3068"\w* su \w señora|strong="H1404"\w*; \w como|strong="H1961"\w* al comprador, así al vendedor; \w como|strong="H1961"\w* al acreedor, así al deudor; \w como|strong="H1961"\w* al \w que|strong="H5971"\w* cobra interés, así al \w que|strong="H5971"\w* lo paga.  
\v 3 \w La|strong="H3588"\w* tierra será del todo vaciada \w y|strong="H3588"\w* enteramente saqueada; \w porque|strong="H3588"\w* Yahvé ha pronunciado \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*.  
\v 4 \w Se|strong="H5971"\w* destruyó, \w cayó|strong="H5034"\w* la tierra; enfermó, \w cayó|strong="H5034"\w* el \w mundo|strong="H8398"\w*; enfermaron los altos \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* la tierra.  
\v 5 \w Y|strong="H3068"\w* \w la|strong="H3588"\w* tierra se contaminó \w bajo|strong="H8478"\w* sus \w moradores|strong="H3427"\w*; \w porque|strong="H3588"\w* \w traspasaron|strong="H5674"\w* las \w leyes|strong="H8451"\w*, \w falsearon|strong="H2498"\w* \w el|strong="H3588"\w* derecho \w y|strong="H3588"\w* quebrantaron \w el|strong="H3588"\w* \w pacto|strong="H1285"\w* \w sempiterno|strong="H5769"\w*.  
\v 6 \w Por|strong="H5921"\w* \w esta|strong="H3651"\w* causa \w la|strong="H5921"\w* maldición consumió \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* sus \w moradores|strong="H3427"\w* fueron hallados culpables; \w por|strong="H5921"\w* \w lo|strong="H5921"\w* cual fueron quemados \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* quedan pocos hombres.  
\v 7 Se perdió \w el|strong="H3605"\w* \w vino|strong="H8492"\w* nuevo, enfermó \w la|strong="H3605"\w* \w vid|strong="H1612"\w*, suspiraron \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* eran \w alegres|strong="H8056"\w* de \w corazón|strong="H3820"\w*.  
\v 8 \w Cesó|strong="H7673"\w* el regocijo de los \w tamboriles|strong="H8596"\w*, se acabó el estruendo de los que se alegran, \w cesó|strong="H7673"\w* la alegría de la cítara.  
\v 9 \w No|strong="H3808"\w* \w beberán|strong="H8354"\w* \w vino|strong="H3196"\w* con cantar; la \w bebida|strong="H7941"\w* fuerte \w será|strong="H3808"\w* amarga \w a|strong="H3068"\w* los \w que|strong="H3808"\w* la bebieren.  
\v 10 \w Quebrantada|strong="H7665"\w* está \w la|strong="H3605"\w* \w ciudad|strong="H7151"\w* del caos; \w toda|strong="H3605"\w* \w casa|strong="H1004"\w* se ha cerrado para \w que|strong="H3605"\w* no entre \w nadie|strong="H3605"\w*.  
\v 11 Hay clamores \w por|strong="H5921"\w* falta \w de|strong="H5921"\w* \w vino|strong="H3196"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w*; \w todo|strong="H3605"\w* \w gozo|strong="H8057"\w* \w se|strong="H5921"\w* oscureció, \w se|strong="H5921"\w* desterró \w la|strong="H5921"\w* \w alegría|strong="H8057"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
\v 12 En la \w ciudad|strong="H5892"\w* \w quedó|strong="H7604"\w* desolación, y con estrépito fue quebrantada la \w puerta|strong="H8179"\w*.  
\v 13 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* \w será|strong="H1961"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w pueblos|strong="H5971"\w*, \w como|strong="H3588"\w* \w cuando|strong="H3588"\w* \w se|strong="H1961"\w* varea \w el|strong="H3588"\w* olivo, \w o|strong="H3068"\w* \w como|strong="H3588"\w* \w los|strong="H1961"\w* rebuscos \w después|strong="H1961"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* vendimia.   
\p
\v 14 \w Estos|strong="H1992"\w* \w alzarán|strong="H5375"\w* \w su|strong="H1992"\w* \w voz|strong="H6963"\w*, \w cantarán|strong="H7442"\w* gozosos por la majestad de Yahvé; desde \w el|strong="H1992"\w* \w mar|strong="H3220"\w* darán \w voces|strong="H6963"\w*.  
\v 15 Dad gloria \w por|strong="H5921"\w* \w eso|strong="H3651"\w* \w a|strong="H3068"\w* Yahvé \w en|strong="H5921"\w* \w los|strong="H5921"\w* valles; \w en|strong="H5921"\w* \w las|strong="H5921"\w* costas \w del|strong="H5921"\w* \w mar|strong="H3220"\w* sea \w nombrado|strong="H8034"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 16 \w De|strong="H6662"\w* lo último \w de|strong="H6662"\w* la tierra \w oímos|strong="H8085"\w* \w cánticos|strong="H2158"\w*: «¡\w Gloria|strong="H6643"\w* al \w justo|strong="H6662"\w*!».  
\p \w Y|strong="H3068"\w* yo dije: «¡Ay \w de|strong="H6662"\w* mí, que me consumo! ¡Mi desdicha, mi desdicha!». Prevaricadores han prevaricado; y han prevaricado con prevaricación \w de|strong="H6662"\w* desleales.  
\v 17 \w Terror|strong="H6343"\w*, fosa \w y|strong="H5921"\w* \w lazo|strong="H6341"\w* \w sobre|strong="H5921"\w* vosotros, oh \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
\v 18 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w huye|strong="H5127"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* del \w terror|strong="H6343"\w* \w caerá|strong="H5307"\w* \w en|strong="H8432"\w* \w la|strong="H3588"\w* fosa; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* sale \w de|strong="H3588"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* fosa \w será|strong="H1961"\w* preso \w en|strong="H8432"\w* \w el|strong="H3588"\w* \w lazo|strong="H6341"\w*; \w porque|strong="H3588"\w* \w de|strong="H3588"\w* lo \w alto|strong="H4791"\w* \w se|strong="H1961"\w* abrieron ventanas, \w y|strong="H3588"\w* \w temblarán|strong="H7493"\w* \w los|strong="H1961"\w* cimientos \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra.  
\v 19 Se quebrantará del todo la tierra, \w enteramente|strong="H6565"\w* \w desmenuzada|strong="H6565"\w* será la tierra, en gran manera será la tierra \w conmovida|strong="H4131"\w*.  
\v 20 \w Temblará|strong="H5128"\w* \w la|strong="H5921"\w* tierra \w vacilando|strong="H5128"\w* \w como|strong="H5921"\w* un borracho, \w y|strong="H5921"\w* \w será|strong="H3808"\w* removida \w como|strong="H5921"\w* una choza \w de|strong="H5921"\w* pastor; \w y|strong="H5921"\w* \w se|strong="H3808"\w* agravará \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* su \w pecado|strong="H6588"\w*, \w y|strong="H5921"\w* \w caerá|strong="H5307"\w*, \w y|strong="H5921"\w* \w nunca|strong="H3808"\w* \w más|strong="H3254"\w* \w se|strong="H3808"\w* \w levantará|strong="H6965"\w*.   
\p
\v 21 \w Acontecerá|strong="H1961"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w que|strong="H1931"\w* Yahvé castigará \w al|strong="H5921"\w* \w ejército|strong="H6635"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* cielos \w en|strong="H5921"\w* \w lo|strong="H1931"\w* \w alto|strong="H4791"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* tierra.  
\v 22 \w Y|strong="H3068"\w* serán amontonados \w como|strong="H5921"\w* \w se|strong="H5921"\w* amontona \w a|strong="H3068"\w* \w los|strong="H5921"\w* presos \w en|strong="H5921"\w* \w la|strong="H5921"\w* fosa, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* cárcel quedarán encerrados, \w y|strong="H5921"\w* serán castigados \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w muchos|strong="H7230"\w* \w días|strong="H3117"\w*.  
\v 23 \w La|strong="H3588"\w* luna se avergonzará, \w y|strong="H3588"\w* \w el|strong="H3588"\w* sol se confundirá, \w cuando|strong="H3588"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w* \w reine|strong="H4427"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w monte|strong="H2022"\w* \w Sión|strong="H6726"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* Jerusalén, \w y|strong="H3588"\w* \w delante|strong="H5048"\w* \w de|strong="H3588"\w* sus \w ancianos|strong="H2205"\w* sea \w glorioso|strong="H3519"\w*.   
\c 25
\p
\v 1 Yahvé, \w tú|strong="H6213"\w* eres mi \w Dios|strong="H3068"\w*; \w te|strong="H3588"\w* exaltaré, \w alabaré|strong="H3034"\w* \w tu|strong="H6213"\w* \w nombre|strong="H8034"\w*, \w porque|strong="H3588"\w* has \w hecho|strong="H6213"\w* \w maravillas|strong="H6382"\w*; tus \w consejos|strong="H6098"\w* \w antiguos|strong="H7350"\w* \w son|strong="H3588"\w* fidelidad \w y|strong="H3588"\w* verdad.  
\v 2 \w Porque|strong="H3588"\w* has convertido \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w en|strong="H3588"\w* un \w montón|strong="H1530"\w* \w de|strong="H3588"\w* escombros, \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w fortalecida|strong="H1219"\w* \w en|strong="H3588"\w* ruina; \w el|strong="H3588"\w* palacio \w de|strong="H3588"\w* \w los|strong="H3588"\w* extraños \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* sea \w ciudad|strong="H5892"\w*, \w ni|strong="H3808"\w* \w nunca|strong="H3808"\w* \w más|strong="H3588"\w* sea reedificado.  
\v 3 \w Por|strong="H5921"\w* \w esto|strong="H3651"\w* \w te|strong="H5921"\w* glorificará \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w fuerte|strong="H5794"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w temerá|strong="H3372"\w* \w la|strong="H5921"\w* \w ciudad|strong="H7151"\w* \w de|strong="H5921"\w* \w naciones|strong="H1471"\w* \w robustas|strong="H6184"\w*.  
\v 4 \w Porque|strong="H3588"\w* \w fuiste|strong="H1961"\w* \w fortaleza|strong="H4581"\w* al \w pobre|strong="H1800"\w*, \w fortaleza|strong="H4581"\w* al menesteroso \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w aflicción|strong="H6862"\w*, refugio \w contra|strong="H1961"\w* \w el|strong="H3588"\w* turbión, \w sombra|strong="H6738"\w* \w contra|strong="H1961"\w* \w el|strong="H3588"\w* calor; \w porque|strong="H3588"\w* \w el|strong="H3588"\w* ímpetu \w de|strong="H3588"\w* \w los|strong="H1961"\w* violentos \w es|strong="H1961"\w* \w como|strong="H3588"\w* turbión \w contra|strong="H1961"\w* \w el|strong="H3588"\w* muro.  
\v 5 \w Como|strong="H5645"\w* el calor en lugar seco, así \w humillarás|strong="H3665"\w* el orgullo de los extraños; y \w como|strong="H5645"\w* calor \w debajo|strong="H6738"\w* de \w nube|strong="H5645"\w*, harás marchitar el renuevo de los terribles.   
\p
\v 6 \w Y|strong="H3068"\w* Yahvé \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w Ejércitos|strong="H6635"\w* \w hará|strong="H6213"\w* en \w este|strong="H2088"\w* \w monte|strong="H2022"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* \w banquete|strong="H4960"\w* \w de|strong="H5971"\w* manjares suculentos,\f + \fr 25:6 \ft literalmente, cosas gordas\f* \w banquete|strong="H4960"\w* \w de|strong="H5971"\w* vinos generosos, \w de|strong="H5971"\w* \w tuétanos|strong="H4229"\w* \w de|strong="H5971"\w* animales gruesos y \w de|strong="H5971"\w* vinos purificados.  
\v 7 \w Y|strong="H3068"\w* \w destruirá|strong="H1104"\w* \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w monte|strong="H2022"\w* \w la|strong="H5921"\w* cubierta \w con|strong="H5921"\w* \w que|strong="H5921"\w* \w están|strong="H2088"\w* cubiertos \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* velo \w que|strong="H5921"\w* envuelve \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.  
\v 8 \w Destruirá|strong="H1104"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w muerte|strong="H4194"\w* \w para|strong="H5921"\w* \w siempre|strong="H3605"\w*; \w y|strong="H3588"\w* enjugará \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* Yahvé \w toda|strong="H3605"\w* lágrima \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w rostros|strong="H6440"\w*; \w y|strong="H3588"\w* \w quitará|strong="H5493"\w* \w la|strong="H5921"\w* \w afrenta|strong="H2781"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra; \w porque|strong="H3588"\w* Yahvé \w lo|strong="H5921"\w* ha \w dicho|strong="H1696"\w*.   
\p
\v 9 \w Y|strong="H3068"\w* \w se|strong="H1931"\w* dirá en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*: «He \w aquí|strong="H2088"\w*, \w este|strong="H2088"\w* \w es|strong="H1931"\w* nuestro \w Dios|strong="H3068"\w*, \w le|strong="H1931"\w* hemos esperado, y nos \w salvará|strong="H3467"\w*; \w este|strong="H2088"\w* \w es|strong="H1931"\w* Yahvé \w a|strong="H3068"\w* \w quien|strong="H1931"\w* hemos esperado, nos \w gozaremos|strong="H1523"\w* y nos \w alegraremos|strong="H8055"\w* en \w su|strong="H1931"\w* salvación».  
\v 10 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* Yahvé \w reposará|strong="H5117"\w* \w en|strong="H3588"\w* \w este|strong="H2088"\w* \w monte|strong="H2022"\w*;  
\p \w y|strong="H3588"\w* \w Moab|strong="H4124"\w* será trillado \w en|strong="H3588"\w* \w su|strong="H3588"\w* mismo \w lugar|strong="H8478"\w*, \w como|strong="H3588"\w* \w es|strong="H2088"\w* trillada \w la|strong="H3588"\w* paja \w en|strong="H3588"\w* \w el|strong="H3588"\w* muladar.  
\v 11 \w Y|strong="H3068"\w* extenderá su \w mano|strong="H3027"\w* \w por|strong="H3027"\w* \w en|strong="H5973"\w* \w medio|strong="H7130"\w* \w de|strong="H5973"\w* \w él|strong="H5973"\w*, \w como|strong="H5973"\w* la \w extiende|strong="H6566"\w* \w el|strong="H5973"\w* nadador \w para|strong="H5973"\w* nadar; y abatirá su \w soberbia|strong="H1346"\w* \w con|strong="H5973"\w* la destreza \w de|strong="H5973"\w* sus \w manos|strong="H3027"\w*.  
\v 12 \w Y|strong="H3068"\w* abatirá la \w fortaleza|strong="H4013"\w* \w de|strong="H5704"\w* tus altos \w muros|strong="H2346"\w*; la humillará \w y|strong="H5704"\w* la echará \w a|strong="H3068"\w* \w tierra|strong="H6083"\w*, \w hasta|strong="H5704"\w* el \w polvo|strong="H6083"\w*.   
\c 26
\p
\v 1 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* \w cantará|strong="H7891"\w* \w este|strong="H2088"\w* \w cántico|strong="H7892"\w* en \w la|strong="H1931"\w* tierra de \w Judá|strong="H3063"\w*:  
\q1 «\w Fuerte|strong="H5794"\w* \w ciudad|strong="H5892"\w* tenemos;  
\q2 para \w muros|strong="H2346"\w* y baluartes \w puso|strong="H7896"\w* Dios \w la|strong="H1931"\w* salvación.   
\q1
\v 2 \w Abrid|strong="H6605"\w* las \w puertas|strong="H8179"\w*, y entrará \w la|strong="H8104"\w* \w nación|strong="H1471"\w* \w justa|strong="H6662"\w*,  
\q2 \w la|strong="H8104"\w* que \w guarda|strong="H8104"\w* \w la|strong="H8104"\w* fidelidad.   
\q1
\v 3 Tú \w guardarás|strong="H5341"\w* \w en|strong="H3588"\w* completa \w paz|strong="H7965"\w* \w a|strong="H3068"\w* aquel cuyo \w pensamiento|strong="H3336"\w* \w en|strong="H3588"\w* ti \w persevera|strong="H5564"\w*,  
\q2 \w porque|strong="H3588"\w* \w en|strong="H3588"\w* ti ha confiado.   
\q1
\v 4 Confiad \w en|strong="H5704"\w* Yahvé \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*,  
\q2 \w porque|strong="H3588"\w* \w en|strong="H5704"\w* \w Yah|strong="H3068"\w*, Yahvé, está \w la|strong="H3588"\w* \w Roca|strong="H6697"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w siglos|strong="H5769"\w*.   
\q1
\v 5 \w Porque|strong="H3588"\w* \w derribó|strong="H7817"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w moraban|strong="H3427"\w* \w en|strong="H5704"\w* lugar sublime; humilló \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w ciudad|strong="H7151"\w* exaltada,  
\q2 \w la|strong="H3588"\w* humilló \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* \w tierra|strong="H6083"\w*,  
\q2 \w la|strong="H3588"\w* abatió \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w polvo|strong="H6083"\w*.   
\q1
\v 6 La \w hollará|strong="H7429"\w* el \w pie|strong="H7272"\w*,  
\q2 los \w pies|strong="H7272"\w* del \w afligido|strong="H6041"\w*,  
\q2 los pasos de los menesterosos».   
\q1
\v 7 El \w camino|strong="H4570"\w* del \w justo|strong="H6662"\w* es rectitud;  
\q2 tú, que eres \w recto|strong="H3477"\w*, nivelas la senda del \w justo|strong="H6662"\w*.   
\b  
\q1
\v 8 También en el camino de tus \w juicios|strong="H4941"\w*, oh Yahvé, \w te|strong="H5315"\w* hemos esperado;  
\q2 tu \w nombre|strong="H8034"\w* y tu \w memoria|strong="H2143"\w* son el \w deseo|strong="H8378"\w* de nuestra \w alma|strong="H5315"\w*.   
\q1
\v 9 \w Con|strong="H3588"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w te|strong="H3588"\w* he deseado \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w noche|strong="H3915"\w*,  
\q2 \w y|strong="H3588"\w* \w en|strong="H3588"\w* tanto \w que|strong="H3588"\w* \w me|strong="H3588"\w* dure \w el|strong="H3588"\w* \w espíritu|strong="H7307"\w* \w dentro|strong="H7130"\w* \w de|strong="H3588"\w* \w mí|strong="H5315"\w*, madrugaré \w a|strong="H3068"\w* buscarte;  
\q2 \w porque|strong="H3588"\w* luego \w que|strong="H3588"\w* hay \w juicios|strong="H4941"\w* tuyos \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* del \w mundo|strong="H8398"\w* \w aprenden|strong="H3925"\w* \w justicia|strong="H6664"\w*.   
\q1
\v 10 Se \w mostrará|strong="H7200"\w* piedad al malvado,  
\q2 y \w no|strong="H1077"\w* \w aprenderá|strong="H3925"\w* \w justicia|strong="H6664"\w*;  
\q1 en tierra de rectitud hará iniquidad,  
\q2 y \w no|strong="H1077"\w* \w mirará|strong="H7200"\w* \w a|strong="H3068"\w* la majestad de Yahvé.   
\b  
\q1
\v 11 Yahvé, tu \w mano|strong="H3027"\w* está alzada, pero \w ellos|strong="H3027"\w* \w no|strong="H1077"\w* \w ven|strong="H2372"\w*;  
\q2 \w verán|strong="H2372"\w* y \w se|strong="H5971"\w* avergonzarán \w a|strong="H3068"\w* causa \w de|strong="H5971"\w* tu \w celo|strong="H7068"\w* \w por|strong="H3027"\w* el \w pueblo|strong="H5971"\w*;  
\q2 y el fuego \w de|strong="H5971"\w* tus \w enemigos|strong="H6862"\w* los consumirá.   
\q1
\v 12 Yahvé, tú nos darás \w paz|strong="H7965"\w*,  
\q2 \w porque|strong="H3588"\w* \w también|strong="H1571"\w* \w hiciste|strong="H6466"\w* \w por|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w todas|strong="H3605"\w* nuestras \w obras|strong="H4639"\w*.   
\q1
\v 13 Yahvé, \w Dios|strong="H3068"\w* nuestro, otros señores \w fuera|strong="H2108"\w* \w de|strong="H2108"\w* ti se han enseñoreado \w de|strong="H2108"\w* nosotros;  
\q2 pero solo \w de|strong="H2108"\w* tu \w nombre|strong="H8034"\w* haremos \w memoria|strong="H2142"\w*.   
\q1
\v 14 \w Muertos|strong="H4191"\w* son, \w no|strong="H1077"\w* \w vivirán|strong="H2421"\w*;  
\q2 las sombras \w no|strong="H1077"\w* \w se|strong="H3651"\w* levantarán;  
\q1 porque \w los|strong="H3605"\w* visitaste, y \w los|strong="H3605"\w* destruiste,  
\q2 y deshiciste \w todo|strong="H3605"\w* su recuerdo.   
\q1
\v 15 Aumentaste \w la|strong="H3605"\w* \w nación|strong="H1471"\w*, oh Yahvé,  
\q2 ¡aumentaste \w la|strong="H3605"\w* \w nación|strong="H1471"\w*!  
\q1 ¡Te hiciste \w glorioso|strong="H3513"\w*!  
\q2 Ensanchaste \w todos|strong="H3605"\w* \w los|strong="H3605"\w* confines de \w la|strong="H3605"\w* tierra.   
\b  
\q1
\v 16 Yahvé, en la \w tribulación|strong="H6862"\w* te buscaron;  
\q2 derramaron su queja cuando los castigaste.   
\q1
\v 17 \w Como|strong="H3644"\w* la mujer encinta \w cuando|strong="H1961"\w* \w se|strong="H1961"\w* acerca el parto  
\q2 \w se|strong="H1961"\w* duele y \w clama|strong="H2199"\w* en sus \w dolores|strong="H2256"\w*,  
\q2 \w así|strong="H3651"\w* hemos \w sido|strong="H1961"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, oh Yahvé.   
\q1
\v 18 \w Concebimos|strong="H2029"\w*, tuvimos dolores de parto,  
\q2 pero fue \w como|strong="H3644"\w* si diésemos \w a|strong="H3068"\w* luz \w viento|strong="H7307"\w*;  
\q1 ninguna liberación logramos en la tierra,  
\q2 \w ni|strong="H1077"\w* \w cayeron|strong="H5307"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* del \w mundo|strong="H8398"\w*.   
\q1
\v 19 Tus \w muertos|strong="H4191"\w* \w vivirán|strong="H2421"\w*;  
\q2 sus cadáveres \w resucitarán|strong="H6965"\w*.  
\q1 ¡\w Despertad|strong="H6974"\w* \w y|strong="H3588"\w* \w cantad|strong="H7442"\w*, \w moradores|strong="H7931"\w* del \w polvo|strong="H6083"\w*!  
\q2 \w Porque|strong="H3588"\w* tu \w rocío|strong="H2919"\w* \w es|strong="H3588"\w* \w cual|strong="H3588"\w* \w rocío|strong="H2919"\w* \w de|strong="H3588"\w* hortalizas,  
\q2 \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w tierra|strong="H6083"\w* entregará \w a|strong="H3068"\w* sus sombras.   
\b  
\q1
\v 20 \w Anda|strong="H3212"\w*, \w pueblo|strong="H5971"\w* \w mío|strong="H5971"\w*, entra \w en|strong="H5704"\w* tus aposentos,  
\q2 \w cierra|strong="H5462"\w* \w tras|strong="H1157"\w* \w de|strong="H5704"\w* ti tus \w puertas|strong="H1817"\w*;  
\q1 \w escóndete|strong="H2247"\w* un poquito, \w por|strong="H1157"\w* un \w momento|strong="H7281"\w*,  
\q2 \w en|strong="H5704"\w* tanto \w que|strong="H5704"\w* \w pasa|strong="H5674"\w* la indignación.   
\q1
\v 21 \w Porque|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* Yahvé \w sale|strong="H3318"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w lugar|strong="H4725"\w* \w para|strong="H5921"\w* castigar \w al|strong="H5921"\w* \w morador|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w por|strong="H5921"\w* \w su|strong="H3588"\w* \w maldad|strong="H5771"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w*;  
\q2 \w y|strong="H3588"\w* \w la|strong="H5921"\w* tierra \w descubrirá|strong="H1540"\w* \w su|strong="H3588"\w* \w sangre|strong="H1818"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w encubrirá|strong="H3680"\w* \w más|strong="H5750"\w* \w a|strong="H3068"\w* sus muertos.   
\c 27
\p
\v 1 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* Yahvé castigará \w con|strong="H5921"\w* \w su|strong="H1931"\w* \w espada|strong="H2719"\w* \w dura|strong="H7186"\w*, \w grande|strong="H1419"\w* \w y|strong="H5921"\w* \w fuerte|strong="H2389"\w* \w al|strong="H5921"\w* leviatán, \w la|strong="H1931"\w* \w serpiente|strong="H5175"\w* veloz, \w y|strong="H5921"\w* \w al|strong="H5921"\w* leviatán, \w la|strong="H1931"\w* \w serpiente|strong="H5175"\w* \w tortuosa|strong="H1281"\w*; \w y|strong="H5921"\w* \w matará|strong="H2026"\w* \w al|strong="H5921"\w* \w dragón|strong="H8577"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w mar|strong="H3220"\w*.   
\p
\v 2 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, cantadle: «¡Una \w viña|strong="H3754"\w* deleitosa!  
\v 3 Yo, Yahvé, soy su guardián; \w la|strong="H5921"\w* regaré \w a|strong="H3068"\w* \w cada|strong="H3117"\w* \w momento|strong="H7281"\w*. \w Para|strong="H5921"\w* \w que|strong="H5921"\w* nadie \w la|strong="H5921"\w* dañe, \w la|strong="H5921"\w* \w guardaré|strong="H5341"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w día|strong="H3117"\w*.  
\v 4 No \w hay|strong="H4310"\w* \w ira|strong="H2534"\w* en mí. ¿\w Quién|strong="H4310"\w* \w pondrá|strong="H5414"\w* contra mí \w cardos|strong="H8068"\w* y \w espinas|strong="H8068"\w* en \w batalla|strong="H4421"\w*? Yo marcharía contra ellos, los quemaría \w a|strong="H3068"\w* una.  
\v 5 ¿\w O|strong="H3068"\w* preferirá alguien acogerse \w a|strong="H3068"\w* mi protección? Que \w haga|strong="H6213"\w* las paces \w conmigo|strong="H6213"\w*; sí, que \w haga|strong="H6213"\w* las paces \w conmigo|strong="H6213"\w*».   
\p
\v 6 En los días venideros \w Jacob|strong="H3290"\w* echará raíces; \w Israel|strong="H3478"\w* \w florecerá|strong="H6524"\w* y brotará, y llenarán \w de|strong="H6440"\w* \w fruto|strong="H8570"\w* la \w faz|strong="H6440"\w* del \w mundo|strong="H8398"\w*.  
\v 7 ¿Acaso los ha herido él como \w hirió|strong="H5221"\w* \w a|strong="H3068"\w* los que los herían? ¿\w O|strong="H3068"\w* han sido ellos muertos como \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* los que los \w mataban|strong="H2026"\w*?  
\v 8 Con medida los castigaste al expulsarlos; él los \w echó|strong="H7971"\w* con su \w soplo|strong="H7307"\w* recio en el \w día|strong="H3117"\w* del \w viento|strong="H7307"\w* \w solano|strong="H6921"\w*.  
\v 9 De \w esta|strong="H2063"\w* manera, \w pues|strong="H3651"\w*, \w será|strong="H3808"\w* perdonada \w la|strong="H2063"\w* \w iniquidad|strong="H5771"\w* de \w Jacob|strong="H3290"\w*; y \w este|strong="H2088"\w* \w será|strong="H3808"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w fruto|strong="H6529"\w* de \w la|strong="H2063"\w* remoción de su \w pecado|strong="H2403"\w*: \w que|strong="H3808"\w* haga \w todas|strong="H3605"\w* las piedras \w del|strong="H4196"\w* \w altar|strong="H4196"\w* \w como|strong="H3651"\w* piedras de cal \w desmenuzadas|strong="H5310"\w*, y \w no|strong="H3808"\w* \w se|strong="H3808"\w* levanten \w más|strong="H3808"\w* las imágenes de Asera \w ni|strong="H3808"\w* \w los|strong="H3605"\w* \w altares|strong="H4196"\w* \w del|strong="H4196"\w* incienso.  
\v 10 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* fortificada \w está|strong="H8033"\w* solitaria, \w morada|strong="H5116"\w* \w desamparada|strong="H5800"\w* \w y|strong="H3588"\w* \w abandonada|strong="H5800"\w* \w como|strong="H3588"\w* un \w desierto|strong="H4057"\w*; \w allí|strong="H8033"\w* pastará \w el|strong="H3588"\w* \w becerro|strong="H5695"\w*, \w allí|strong="H8033"\w* se \w echará|strong="H7971"\w* \w y|strong="H3588"\w* \w consumirá|strong="H3615"\w* sus ramas.  
\v 11 \w Cuando|strong="H3588"\w* \w sus|strong="H1931"\w* sarmientos \w se|strong="H1931"\w* sequen, \w serán|strong="H1931"\w* quebrados; vendrán mujeres \w y|strong="H3588"\w* \w les|strong="H5921"\w* prenderán fuego; \w porque|strong="H3588"\w* \w este|strong="H1931"\w* \w no|strong="H3808"\w* \w es|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* entendimiento. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w su|strong="H1931"\w* \w Hacedor|strong="H6213"\w* \w no|strong="H3808"\w* tendrá \w de|strong="H5921"\w* \w ellos|strong="H1931"\w* \w misericordia|strong="H7355"\w*, \w ni|strong="H3808"\w* \w les|strong="H5921"\w* mostrará favor \w el|strong="H1931"\w* \w que|strong="H3588"\w* \w los|strong="H5921"\w* \w formó|strong="H3335"\w*.   
\p
\v 12 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* \w en|strong="H5704"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w que|strong="H1931"\w* trillará Yahvé \w desde|strong="H5704"\w* \w la|strong="H1931"\w* corriente del \w Río|strong="H5104"\w* \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w torrente|strong="H5158"\w* \w de|strong="H5704"\w* \w Egipto|strong="H4714"\w*; \w y|strong="H5704"\w* vosotros, \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w seréis|strong="H1961"\w* reunidos uno \w a|strong="H3068"\w* uno.   
\p
\v 13 \w Acontecerá|strong="H1961"\w* también en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w que|strong="H1931"\w* \w se|strong="H1961"\w* \w tocará|strong="H8628"\w* una \w gran|strong="H1419"\w* \w trompeta|strong="H7782"\w*; y vendrán \w los|strong="H1931"\w* \w que|strong="H1931"\w* andaban \w perdidos|strong="H5080"\w* en \w la|strong="H1931"\w* tierra de Asiria, y \w los|strong="H1931"\w* \w que|strong="H1931"\w* \w habían|strong="H1961"\w* \w sido|strong="H1961"\w* desterrados \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra de \w Egipto|strong="H4714"\w*, y adorarán \w a|strong="H3068"\w* Yahvé en \w el|strong="H1931"\w* \w monte|strong="H2022"\w* \w santo|strong="H6944"\w*, en Jerusalén.   
\c 28
\p
\v 1 ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w corona|strong="H5850"\w* \w de|strong="H5921"\w* soberbia \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w borrachos|strong="H7910"\w* \w de|strong="H5921"\w* Efraín, \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* flor marchita \w de|strong="H5921"\w* su gloriosa \w hermosura|strong="H6643"\w*, \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w del|strong="H5921"\w* \w fértil|strong="H8081"\w* \w valle|strong="H1516"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* aturdidos \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w vino|strong="H3196"\w*!  
\v 2 He \w aquí|strong="H2009"\w* \w que|strong="H4325"\w* el Señor tiene \w a|strong="H3068"\w* uno \w que|strong="H4325"\w* \w es|strong="H3027"\w* poderoso y \w fuerte|strong="H2389"\w*; como turbión \w de|strong="H4325"\w* \w granizo|strong="H1259"\w* y tormenta generadora \w de|strong="H4325"\w* ruina, como ímpetu \w de|strong="H4325"\w* recias \w aguas|strong="H4325"\w* \w que|strong="H4325"\w* inundan, los derribará \w a|strong="H3068"\w* tierra con su \w mano|strong="H3027"\w*.  
\v 3 Con los \w pies|strong="H7272"\w* será pisoteada la \w corona|strong="H5850"\w* de soberbia de los \w borrachos|strong="H7910"\w* de Efraín.  
\v 4 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* flor marchita \w de|strong="H5921"\w* su gloriosa \w hermosura|strong="H6643"\w*, \w que|strong="H5921"\w* \w está|strong="H1961"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w del|strong="H5921"\w* \w valle|strong="H1516"\w* \w fértil|strong="H8081"\w*, \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w la|strong="H5921"\w* breva \w que|strong="H5921"\w* madura \w antes|strong="H2962"\w* \w del|strong="H5921"\w* \w verano|strong="H7019"\w*, \w la|strong="H5921"\w* cual, \w en|strong="H5921"\w* \w cuanto|strong="H5921"\w* uno \w la|strong="H5921"\w* \w ve|strong="H7200"\w*, \w la|strong="H5921"\w* arrebata \w y|strong="H5921"\w* \w se|strong="H1961"\w* \w la|strong="H5921"\w* traga.  
\v 5 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, Yahvé \w de|strong="H5971"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w* \w será|strong="H1961"\w* por \w corona|strong="H5850"\w* \w de|strong="H5971"\w* \w gloria|strong="H8597"\w* y diadema \w de|strong="H5971"\w* \w hermosura|strong="H6643"\w* \w para|strong="H1961"\w* \w el|strong="H1931"\w* resto \w de|strong="H5971"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*;  
\v 6 \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w justicia|strong="H4941"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* sienta \w a|strong="H3068"\w* juzgar, \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w fortaleza|strong="H1369"\w* \w para|strong="H5921"\w* \w los|strong="H3427"\w* \w que|strong="H5921"\w* rechazan \w la|strong="H5921"\w* \w batalla|strong="H4421"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w*.   
\p
\v 7 Pero \w también|strong="H1571"\w* \w estos|strong="H1571"\w* \w erraron|strong="H7686"\w* \w con|strong="H4480"\w* \w el|strong="H5030"\w* \w vino|strong="H3196"\w*, \w y|strong="H1571"\w* \w con|strong="H4480"\w* \w la|strong="H1571"\w* \w sidra|strong="H7941"\w* \w se|strong="H4480"\w* entorpecieron; \w el|strong="H5030"\w* \w sacerdote|strong="H3548"\w* \w y|strong="H1571"\w* \w el|strong="H5030"\w* \w profeta|strong="H5030"\w* \w erraron|strong="H7686"\w* \w con|strong="H4480"\w* \w la|strong="H1571"\w* \w sidra|strong="H7941"\w*, fueron trastornados \w por|strong="H4480"\w* \w el|strong="H5030"\w* \w vino|strong="H3196"\w*; \w se|strong="H4480"\w* aturdieron \w con|strong="H4480"\w* \w la|strong="H1571"\w* \w sidra|strong="H7941"\w*, \w erraron|strong="H7686"\w* \w en|strong="H4480"\w* \w la|strong="H1571"\w* visión, \w tropezaron|strong="H6328"\w* \w en|strong="H4480"\w* \w el|strong="H5030"\w* juicio.  
\v 8 \w Porque|strong="H3588"\w* \w todas|strong="H3605"\w* las \w mesas|strong="H7979"\w* están \w llenas|strong="H4390"\w* \w de|strong="H3588"\w* \w vómito|strong="H6892"\w* \w e|strong="H3068"\w* inmundicia, \w hasta|strong="H1097"\w* \w no|strong="H1097"\w* quedar \w lugar|strong="H4725"\w* limpio.   
\p
\v 9 ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* se \w enseñará|strong="H3384"\w* la \w ciencia|strong="H1844"\w*, \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w quién|strong="H4310"\w* se hará entender \w el|strong="H4310"\w* mensaje? ¿\w A|strong="H3068"\w* los recién destetados? ¿\w A|strong="H3068"\w* los \w que|strong="H4310"\w* acaban de dejar los \w pechos|strong="H7699"\w*?  
\v 10 \w Porque|strong="H3588"\w* \w mandato|strong="H6673"\w* tras \w mandato|strong="H6673"\w*, \w mandato|strong="H6673"\w* sobre \w mandato|strong="H6673"\w*, \w renglón|strong="H6957"\w* tras \w renglón|strong="H6957"\w*, \w línea|strong="H6957"\w* sobre \w línea|strong="H6957"\w*, un \w poquito|strong="H2191"\w* \w allí|strong="H8033"\w*, otro \w poquito|strong="H2191"\w* \w allá|strong="H8033"\w*;   
\p
\v 11 \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w lengua|strong="H3956"\w* \w de|strong="H3588"\w* tartamudos, \w y|strong="H3588"\w* \w en|strong="H3588"\w* extraña \w lengua|strong="H3956"\w*, \w hablará|strong="H1696"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*,  
\v 12 al cual él dijo: «\w Este|strong="H2063"\w* \w es|strong="H2063"\w* el \w reposo|strong="H5117"\w*; dad \w reposo|strong="H5117"\w* al \w cansado|strong="H5889"\w*; \w este|strong="H2063"\w* \w es|strong="H2063"\w* el refrigerio»; \w mas|strong="H3808"\w* \w no|strong="H3808"\w* quisieron \w escuchar|strong="H8085"\w*.  
\v 13 La \w palabra|strong="H1697"\w*, \w pues|strong="H1961"\w*, \w de|strong="H1697"\w* Yahvé \w les|strong="H1992"\w* \w será|strong="H1961"\w* \w mandato|strong="H6673"\w* tras \w mandato|strong="H6673"\w*, \w mandato|strong="H6673"\w* \w sobre|strong="H1961"\w* \w mandato|strong="H6673"\w*, \w renglón|strong="H6957"\w* tras \w renglón|strong="H6957"\w*, \w línea|strong="H6957"\w* \w sobre|strong="H1961"\w* \w línea|strong="H6957"\w*, un \w poquito|strong="H2191"\w* \w allí|strong="H8033"\w*, \w otro|strong="H4616"\w* \w poquito|strong="H2191"\w* \w allá|strong="H8033"\w*; hasta \w que|strong="H1697"\w* \w vayan|strong="H3212"\w* y caigan \w de|strong="H1697"\w* espaldas, y \w sean|strong="H1961"\w* quebrantados, enredados y presos.   
\p
\v 14 \w Por|strong="H1697"\w* \w tanto|strong="H3651"\w*, \w oíd|strong="H8085"\w* la \w palabra|strong="H1697"\w* \w de|strong="H5971"\w* Yahvé, hombres \w burladores|strong="H3944"\w* \w que|strong="H5971"\w* gobernáis \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w está|strong="H2088"\w* en Jerusalén.  
\v 15 \w Puesto|strong="H3588"\w* \w que|strong="H3588"\w* habéis dicho: «Hemos \w hecho|strong="H6213"\w* \w pacto|strong="H1285"\w* \w con|strong="H5973"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w*, \w e|strong="H3068"\w* \w hicimos|strong="H6213"\w* convenio \w con|strong="H5973"\w* \w el|strong="H5973"\w* Seol.\f + \fr 28:15 \ft El Seol es el lugar de los muertos.\f* \w Cuando|strong="H3588"\w* \w pase|strong="H5674"\w* \w el|strong="H5973"\w* torrente \w del|strong="H5973"\w* azote, \w no|strong="H3808"\w* llegará \w a|strong="H3068"\w* \w nosotros|strong="H5973"\w*, \w porque|strong="H3588"\w* hemos \w puesto|strong="H3588"\w* nuestro refugio \w en|strong="H5973"\w* \w la|strong="H3588"\w* \w mentira|strong="H8267"\w*, \w y|strong="H3588"\w* \w en|strong="H5973"\w* \w la|strong="H3588"\w* falsedad nos hemos \w escondido|strong="H5641"\w*»;  
\v 16 \w por|strong="H3651"\w* \w eso|strong="H3651"\w*, el Señor Yahvé dice \w así|strong="H3541"\w*: «He \w aquí|strong="H3541"\w* \w que|strong="H3808"\w* yo he puesto en \w Sión|strong="H6726"\w* \w por|strong="H3651"\w* fundamento una piedra, piedra probada, \w angular|strong="H6438"\w*, \w preciosa|strong="H3368"\w*, de \w cimiento|strong="H3245"\w* \w estable|strong="H4143"\w*; el \w que|strong="H3808"\w* creyere, \w no|strong="H3808"\w* \w se|strong="H3808"\w* apresure.  
\v 17 \w Y|strong="H3068"\w* ajustaré el \w juicio|strong="H4941"\w* \w a|strong="H3068"\w* cordel, y \w a|strong="H3068"\w* nivel la \w justicia|strong="H6666"\w*; y el \w granizo|strong="H1259"\w* \w barrerá|strong="H3261"\w* el refugio \w de|strong="H4325"\w* la \w mentira|strong="H3577"\w*, y las \w aguas|strong="H4325"\w* inundarán el escondrijo.  
\v 18 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* anulado vuestro \w pacto|strong="H1285"\w* \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w*, \w y|strong="H3588"\w* vuestro convenio \w con|strong="H3588"\w* \w el|strong="H3588"\w* Seol \w no|strong="H3808"\w* \w subsistirá|strong="H6965"\w*; \w cuando|strong="H3588"\w* \w pase|strong="H5674"\w* \w el|strong="H3588"\w* torrente del \w azote|strong="H7752"\w*, \w seréis|strong="H1961"\w* \w por|strong="H3588"\w* \w él|strong="H3588"\w* pisoteados.  
\v 19 \w Luego|strong="H5674"\w* \w que|strong="H3588"\w* \w pase|strong="H5674"\w*, \w él|strong="H3588"\w* os arrebatará; \w porque|strong="H3588"\w* \w de|strong="H3588"\w* \w mañana|strong="H1242"\w* \w en|strong="H3588"\w* \w mañana|strong="H1242"\w* \w pasará|strong="H5674"\w*, \w de|strong="H3588"\w* \w día|strong="H3117"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w noche|strong="H3915"\w*; \w y|strong="H3588"\w* \w será|strong="H1961"\w* \w ciertamente|strong="H3588"\w* un espanto \w el|strong="H3588"\w* entender \w el|strong="H3588"\w* mensaje».  
\v 20 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* cama \w es|strong="H3588"\w* corta \w para|strong="H3588"\w* estirarse, \w y|strong="H3588"\w* \w la|strong="H3588"\w* manta estrecha \w para|strong="H3588"\w* envolverse.  
\v 21 \w Porque|strong="H3588"\w* Yahvé se \w levantará|strong="H6965"\w* \w como|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w monte|strong="H2022"\w* Perazim, \w y|strong="H3588"\w* \w como|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w valle|strong="H6010"\w* \w de|strong="H3588"\w* \w Gabaón|strong="H1391"\w* se enojará; \w para|strong="H3588"\w* \w hacer|strong="H6213"\w* \w su|strong="H3588"\w* \w obra|strong="H4639"\w*, \w su|strong="H3588"\w* \w extraña|strong="H5237"\w* \w obra|strong="H4639"\w*, \w y|strong="H3588"\w* \w para|strong="H3588"\w* \w hacer|strong="H6213"\w* \w su|strong="H3588"\w* \w labor|strong="H5656"\w*, \w su|strong="H3588"\w* \w ajena|strong="H5237"\w* \w labor|strong="H5656"\w*.  
\v 22 \w Ahora|strong="H6258"\w*, \w pues|strong="H3588"\w*, \w no|strong="H6435"\w* \w os|strong="H5921"\w* burléis, \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w no|strong="H6435"\w* \w se|strong="H5921"\w* aprieten vuestras \w ataduras|strong="H4147"\w*; \w porque|strong="H3588"\w* una destrucción \w ya|strong="H6258"\w* \w determinada|strong="H2782"\w* he \w oído|strong="H8085"\w* \w del|strong="H5921"\w* Señor, Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*, \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.   
\p
\v 23 Estad \w atentos|strong="H7181"\w* y \w oíd|strong="H8085"\w* mi \w voz|strong="H6963"\w*; estad \w atentos|strong="H7181"\w* y \w escuchad|strong="H8085"\w* mi dicho.  
\v 24 \w El|strong="H3605"\w* \w que|strong="H3117"\w* \w ara|strong="H2790"\w* para sembrar, ¿\w ará|strong="H2790"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w*? ¿\w Romperá|strong="H6605"\w* y \w quebrará|strong="H7702"\w* \w los|strong="H3605"\w* terrones de su tierra?  
\v 25 Cuando \w ha|strong="H3808"\w* nivelado su superficie, ¿\w no|strong="H3808"\w* derrama el eneldo, siembra el comino, pone el \w trigo|strong="H2406"\w* \w por|strong="H6440"\w* hileras, y la \w cebada|strong="H8184"\w* en su lugar señalado, y la escanda en su borde?  
\v 26 Porque su Dios le instruye y le \w enseña|strong="H3384"\w* lo que es recto.  
\v 27 \w Que|strong="H3588"\w* \w el|strong="H5921"\w* eneldo \w no|strong="H3808"\w* \w se|strong="H5921"\w* trilla \w con|strong="H5921"\w* \w trillo|strong="H2742"\w*, \w ni|strong="H3808"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* comino \w se|strong="H5921"\w* hace rodar rueda \w de|strong="H5921"\w* \w carro|strong="H5699"\w*; \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w con|strong="H5921"\w* un palo \w se|strong="H5921"\w* sacude \w el|strong="H5921"\w* eneldo, \w y|strong="H3588"\w* \w el|strong="H5921"\w* comino \w con|strong="H5921"\w* una \w vara|strong="H4294"\w*.  
\v 28 \w El|strong="H3588"\w* \w pan|strong="H3899"\w* \w se|strong="H3808"\w* trilla; \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w siempre|strong="H3899"\w* \w lo|strong="H3808"\w* trillará, \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* comprime \w con|strong="H3588"\w* \w la|strong="H3588"\w* rueda \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w carro|strong="H5699"\w*, \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* quebranta \w con|strong="H3588"\w* \w los|strong="H3588"\w* dientes \w de|strong="H3588"\w* \w su|strong="H3588"\w* trillo.  
\v 29 \w También|strong="H1571"\w* \w esto|strong="H2063"\w* \w salió|strong="H3318"\w* \w de|strong="H5973"\w* Yahvé \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w Ejércitos|strong="H6635"\w*, \w para|strong="H5973"\w* hacer maravilloso \w el|strong="H5973"\w* \w consejo|strong="H6098"\w* \w y|strong="H1571"\w* \w grande|strong="H1431"\w* \w la|strong="H1571"\w* \w sabiduría|strong="H8454"\w*.   
\c 29
\p
\v 1 ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* Ariel, Ariel, \w la|strong="H5921"\w* \w ciudad|strong="H7151"\w* \w donde|strong="H5921"\w* acampó \w David|strong="H1732"\w*! \w Añadid|strong="H5595"\w* \w año|strong="H8141"\w* \w a|strong="H3068"\w* \w año|strong="H8141"\w*; \w que|strong="H5921"\w* sigan \w las|strong="H5921"\w* fiestas su curso;  
\v 2 entonces afligiré \w a|strong="H3068"\w* Ariel, y \w habrá|strong="H1961"\w* luto y lamentación; y ella \w será|strong="H1961"\w* \w para|strong="H1961"\w* \w mí|strong="H1961"\w* \w como|strong="H1961"\w* un ara de altar.  
\v 3 Acamparé \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w a|strong="H3068"\w* tu \w alrededor|strong="H5921"\w*, \w te|strong="H5921"\w* sitiaré \w con|strong="H5921"\w* baluartes \w y|strong="H5921"\w* \w levantaré|strong="H6965"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* torres \w de|strong="H5921"\w* asalto.  
\v 4 Entonces \w serás|strong="H1961"\w* humillada, \w hablarás|strong="H1696"\w* desde la \w tierra|strong="H6083"\w* y tu \w habla|strong="H1696"\w* \w saldrá|strong="H7817"\w* del \w polvo|strong="H6083"\w*; \w será|strong="H1961"\w* tu \w voz|strong="H6963"\w* \w como|strong="H1961"\w* la de un evocador \w que|strong="H1961"\w* sale de la \w tierra|strong="H6083"\w*, y tu discurso \w susurrará|strong="H6850"\w* desde el \w polvo|strong="H6083"\w*.   
\p
\v 5 Pero la \w muchedumbre|strong="H1995"\w* de tus enemigos \w será|strong="H1961"\w* \w como|strong="H1961"\w* polvo \w menudo|strong="H1851"\w*, y la \w multitud|strong="H1995"\w* de \w los|strong="H1961"\w* tiranos \w como|strong="H1961"\w* paja \w que|strong="H1961"\w* \w pasa|strong="H5674"\w*; y \w será|strong="H1961"\w* \w repentinamente|strong="H6597"\w*, en un momento.  
\v 6 Por Yahvé \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w Ejércitos|strong="H6635"\w* serás visitada \w con|strong="H5973"\w* \w truenos|strong="H6963"\w*, \w con|strong="H5973"\w* terremotos y \w con|strong="H5973"\w* \w gran|strong="H1419"\w* \w ruido|strong="H6963"\w*, \w con|strong="H5973"\w* \w torbellino|strong="H5492"\w* y \w tempestad|strong="H5591"\w*, y \w con|strong="H5973"\w* \w llama|strong="H3851"\w* \w de|strong="H5973"\w* fuego devorador.  
\v 7 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w sueño|strong="H2472"\w* \w de|strong="H5921"\w* \w visión|strong="H2377"\w* \w nocturna|strong="H3915"\w* \w la|strong="H5921"\w* \w multitud|strong="H1995"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H5921"\w* pelean \w contra|strong="H5921"\w* Ariel, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* pelean \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* \w y|strong="H5921"\w* su fortaleza, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* ponen \w en|strong="H5921"\w* apretura.  
