\v 14 \w Al|strong="H6256"\w* \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* la \w tarde|strong="H6153"\w*, he \w aquí|strong="H2088"\w* el terror; pero \w antes|strong="H2962"\w* \w de|strong="H6256"\w* la \w mañana|strong="H1242"\w*, el enemigo \w ya|strong="H2088"\w* no existe. \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* la \w parte|strong="H2506"\w* \w de|strong="H6256"\w* los \w que|strong="H2088"\w* nos saquen, \w y|strong="H1091"\w* la \w suerte|strong="H1486"\w* \w de|strong="H6256"\w* los \w que|strong="H2088"\w* nos roban.   
\c 18
\p
\v 1 ¡\w Ah|strong="H1945"\w*, tierra del zumbido de \w alas|strong="H3671"\w*, que estás más allá de los ríos de \w Etiopía|strong="H3568"\w*;  
\v 2 \w que|strong="H4480"\w* \w envías|strong="H7971"\w* \w embajadores|strong="H4397"\w* \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w mar|strong="H3220"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* naves \w de|strong="H4480"\w* juncos \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*! \w Id|strong="H3212"\w*, veloces \w mensajeros|strong="H4397"\w*, \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w nación|strong="H1471"\w* \w de|strong="H4480"\w* elevada estatura \w y|strong="H5921"\w* piel brillante, \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* temible \w desde|strong="H4480"\w* \w su|strong="H1931"\w* principio \w y|strong="H5921"\w* \w hasta|strong="H5921"\w* ahora, \w nación|strong="H1471"\w* fuerte \w y|strong="H5921"\w* conquistadora, \w cuya|strong="H1931"\w* tierra dividen \w los|strong="H5921"\w* ríos.  
\v 3 \w Todos|strong="H3605"\w* \w vosotros|strong="H8085"\w*, \w moradores|strong="H3427"\w* del \w mundo|strong="H8398"\w* y \w habitantes|strong="H3427"\w* de \w la|strong="H3605"\w* tierra, cuando se levante \w el|strong="H3605"\w* \w pendón|strong="H5251"\w* en \w los|strong="H3427"\w* \w montes|strong="H2022"\w*, \w ved|strong="H7200"\w*; y cuando se toque \w la|strong="H3605"\w* \w trompeta|strong="H7782"\w*, \w oíd|strong="H8085"\w*.   
\p
\v 4 \w Porque|strong="H3588"\w* Yahvé \w me|strong="H5921"\w* dijo \w así|strong="H3541"\w*: «\w Me|strong="H5921"\w* estaré \w quieto|strong="H8252"\w* \w y|strong="H3588"\w* \w miraré|strong="H5027"\w* \w desde|strong="H5921"\w* \w mi|strong="H5921"\w* morada, \w como|strong="H3588"\w* calor sereno tras \w la|strong="H5921"\w* lluvia, \w como|strong="H3588"\w* \w nube|strong="H5645"\w* \w de|strong="H5921"\w* \w rocío|strong="H2919"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* calor \w de|strong="H5921"\w* \w la|strong="H5921"\w* siega».  
\v 5 \w Porque|strong="H3588"\w* \w antes|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* siega, \w cuando|strong="H3588"\w* \w la|strong="H3588"\w* \w flor|strong="H6525"\w* \w haya|strong="H1961"\w* caído \w y|strong="H3588"\w* \w el|strong="H3588"\w* fruto \w se|strong="H1961"\w* vaya madurando, \w él|strong="H3588"\w* \w cortará|strong="H3772"\w* \w los|strong="H1961"\w* sarmientos \w con|strong="H3588"\w* podaderas, \w y|strong="H3588"\w* podará \w y|strong="H3588"\w* \w quitará|strong="H5493"\w* las \w ramas|strong="H7105"\w*.  
