\b  
\p
\v 10 \w Acontecerá|strong="H1961"\w* \w en|strong="H5975"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* raíz \w de|strong="H5971"\w* Jesé, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w estará|strong="H1961"\w* puesta por \w pendón|strong="H5251"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w pueblos|strong="H5971"\w*, \w será|strong="H1961"\w* buscada por las \w gentes|strong="H1471"\w*; \w y|strong="H3519"\w* \w su|strong="H1931"\w* habitación \w será|strong="H1961"\w* gloriosa.   
\p
\v 11 Asimismo \w acontecerá|strong="H1961"\w* en \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w*, \w que|strong="H1931"\w* \w el|strong="H1931"\w* Señor \w tornará|strong="H3254"\w* \w a|strong="H3068"\w* poner \w su|strong="H1931"\w* \w mano|strong="H3027"\w* \w otra|strong="H8145"\w* vez \w para|strong="H1961"\w* rescatar \w el|strong="H1931"\w* remanente \w de|strong="H5971"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w que|strong="H1931"\w* \w aún|strong="H3254"\w* \w quede|strong="H7604"\w* en Asiria, \w Egipto|strong="H4714"\w*, Patros, \w Etiopía|strong="H3568"\w*, \w Elam|strong="H5867"\w*, Sinar y Hamat, y en las costas del \w mar|strong="H3220"\w*.  
\v 12 \w Y|strong="H3068"\w* \w levantará|strong="H5251"\w* \w pendón|strong="H5251"\w* \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*, y juntará los desterrados de \w Israel|strong="H3478"\w*, y reunirá los esparcidos de \w Judá|strong="H3063"\w* de los cuatro confines de la tierra.  
\v 13 \w Y|strong="H3068"\w* \w se|strong="H3808"\w* disipará la \w envidia|strong="H7065"\w* de Efraín, y los \w enemigos|strong="H6862"\w* de \w Judá|strong="H3063"\w* serán destruidos. Efraín \w no|strong="H3808"\w* tendrá \w envidia|strong="H7065"\w* contra \w Judá|strong="H3063"\w*, \w ni|strong="H3808"\w* \w Judá|strong="H3063"\w* \w afligirá|strong="H6862"\w* \w a|strong="H3068"\w* Efraín;  
\v 14 sino \w que|strong="H1121"\w* volarán sobre \w los|strong="H1121"\w* \w hombros|strong="H3802"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* al occidente, saquearán \w también|strong="H3162"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w oriente|strong="H6924"\w*; Edom y \w Moab|strong="H4124"\w* les servirán, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón les obedecerán.  
\v 15 \w Y|strong="H3068"\w* secará Yahvé \w la|strong="H5921"\w* \w lengua|strong="H3956"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*; \w y|strong="H5921"\w* levantará su \w mano|strong="H3027"\w* \w con|strong="H5921"\w* fortaleza \w de|strong="H5921"\w* su \w espíritu|strong="H7307"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w río|strong="H5104"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w herirá|strong="H5221"\w* \w en|strong="H5921"\w* sus \w siete|strong="H7651"\w* \w brazos|strong="H5158"\w*, \w y|strong="H5921"\w* hará \w que|strong="H5921"\w* pasen \w por|strong="H5921"\w* \w él|strong="H5921"\w* calzados.  
\v 16 \w Y|strong="H3068"\w* \w habrá|strong="H1961"\w* \w camino|strong="H4546"\w* \w para|strong="H1961"\w* el remanente \w de|strong="H5971"\w* su \w pueblo|strong="H5971"\w*, el \w que|strong="H5971"\w* \w quedó|strong="H7604"\w* \w de|strong="H5971"\w* Asiria, \w de|strong="H5971"\w* la manera \w que|strong="H5971"\w* lo \w hubo|strong="H1961"\w* \w para|strong="H1961"\w* \w Israel|strong="H3478"\w* el \w día|strong="H3117"\w* \w que|strong="H5971"\w* \w subió|strong="H5927"\w* \w de|strong="H5971"\w* la tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*.   
\c 12
\p
\v 1 \w En|strong="H3588"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* dirás: «\w Te|strong="H3588"\w* \w alabaré|strong="H3034"\w*, Yahvé; \w porque|strong="H3588"\w* \w aunque|strong="H3588"\w* \w te|strong="H3588"\w* enojaste conmigo, tu ira \w se|strong="H1931"\w* ha apartado \w y|strong="H3588"\w* \w me|strong="H3588"\w* has consolado.  
\v 2 He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w Dios|strong="H3068"\w* \w es|strong="H1961"\w* \w mi|strong="H2009"\w* salvación. Confiaré \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w temeré|strong="H6342"\w*; \w porque|strong="H3588"\w* \w Yah|strong="H3068"\w*, Yahvé, \w es|strong="H1961"\w* \w mi|strong="H2009"\w* \w fortaleza|strong="H5797"\w* \w y|strong="H3588"\w* \w mi|strong="H2009"\w* cántico; \w y|strong="H3588"\w* \w él|strong="H3588"\w* \w se|strong="H1961"\w* \w ha|strong="H3808"\w* convertido \w en|strong="H3588"\w* \w mi|strong="H2009"\w* salvación».  
\v 3 \w Por|strong="H7579"\w* tanto, \w sacaréis|strong="H7579"\w* con \w gozo|strong="H8342"\w* \w agua|strong="H4325"\w* \w de|strong="H4325"\w* las fuentes \w de|strong="H4325"\w* la salvación.  
\v 4 \w Y|strong="H3068"\w* diréis \w en|strong="H3588"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*: «¡Dad gracias \w a|strong="H3068"\w* Yahvé! ¡\w Invocad|strong="H7121"\w* \w su|strong="H1931"\w* \w nombre|strong="H8034"\w*! ¡Anunciad \w sus|strong="H1931"\w* \w obras|strong="H5949"\w* \w entre|strong="H3588"\w* \w los|strong="H1931"\w* \w pueblos|strong="H5971"\w*! \w Proclamad|strong="H7121"\w* \w que|strong="H3588"\w* \w su|strong="H1931"\w* \w nombre|strong="H8034"\w* \w es|strong="H1931"\w* excelso.  
\v 5 ¡\w Cantad|strong="H2167"\w* \w salmos|strong="H2167"\w* \w a|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* ha \w hecho|strong="H6213"\w* \w cosas|strong="H3045"\w* magníficas! ¡Sea \w esto|strong="H2063"\w* sabido \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra!  
\v 6 ¡Gritad \w y|strong="H3588"\w* dad voces \w de|strong="H3588"\w* júbilo, \w moradora|strong="H3427"\w* \w de|strong="H3588"\w* \w Sión|strong="H6726"\w*, \w porque|strong="H3588"\w* \w grande|strong="H1419"\w* \w es|strong="H3588"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* vosotros \w el|strong="H3588"\w* \w Santo|strong="H6918"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*!».   
\c 13
\p
\v 1 Oráculo sobre Babilonia \w que|strong="H1121"\w* \w vio|strong="H2372"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amoz.   
\p
\v 2 ¡\w Alzad|strong="H5375"\w* \w bandera|strong="H5251"\w* \w sobre|strong="H5921"\w* un \w monte|strong="H2022"\w* pelado! ¡\w Levantad|strong="H5375"\w* \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w hacia|strong="H5921"\w* \w ellos|strong="H3027"\w*! Agitad \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* entren \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H6607"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* príncipes.  
\v 3 \w Yo|strong="H6680"\w* \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* mis consagrados; \w asimismo|strong="H1571"\w* \w llamé|strong="H7121"\w* \w a|strong="H3068"\w* mis \w valientes|strong="H1368"\w* para mi ira, \w a|strong="H3068"\w* los \w que|strong="H1571"\w* se alegran \w con|strong="H1571"\w* mi grandeza.  
\v 4 \w Estruendo|strong="H6963"\w* \w de|strong="H5971"\w* \w multitud|strong="H1995"\w* en los \w montes|strong="H2022"\w*, \w como|strong="H1823"\w* \w de|strong="H5971"\w* \w mucho|strong="H7227"\w* \w pueblo|strong="H5971"\w*; \w estruendo|strong="H6963"\w* \w de|strong="H5971"\w* \w ruido|strong="H6963"\w* \w de|strong="H5971"\w* \w reinos|strong="H4467"\w*, \w de|strong="H5971"\w* \w naciones|strong="H1471"\w* reunidas. Yahvé \w de|strong="H5971"\w* los \w Ejércitos|strong="H6635"\w* pasa revista \w a|strong="H3068"\w* las tropas \w para|strong="H5971"\w* la \w batalla|strong="H4421"\w*.  
\v 5 Vienen de \w lejana|strong="H4801"\w* tierra, de \w lo|strong="H3605"\w* \w postrero|strong="H7097"\w* de \w los|strong="H3605"\w* \w cielos|strong="H8064"\w*, Yahvé y \w los|strong="H3605"\w* \w instrumentos|strong="H3627"\w* de su \w furor|strong="H2195"\w*, para destruir \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra.   
\p
\v 6 ¡\w Aullad|strong="H3213"\w*, \w porque|strong="H3588"\w* \w cerca|strong="H7138"\w* está \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* Yahvé! Vendrá \w como|strong="H3588"\w* \w asolamiento|strong="H7701"\w* del \w Todopoderoso|strong="H7706"\w*.  
\v 7 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w toda|strong="H3605"\w* \w mano|strong="H3027"\w* \w se|strong="H5921"\w* debilitará, \w y|strong="H5921"\w* desfallecerá \w todo|strong="H3605"\w* \w corazón|strong="H3824"\w* \w de|strong="H5921"\w* hombre.  
\v 8 \w Y|strong="H3068"\w* se llenarán \w de|strong="H6440"\w* terror; \w angustias|strong="H6735"\w* y \w dolores|strong="H2256"\w* se apoderarán \w de|strong="H6440"\w* ellos; tendrán \w dolores|strong="H2256"\w* como mujer \w de|strong="H6440"\w* parto; se asombrará cada cual al mirar \w a|strong="H3068"\w* su \w compañero|strong="H7453"\w*; sus \w rostros|strong="H6440"\w*, \w rostros|strong="H6440"\w* \w de|strong="H6440"\w* llamas.  
\v 9 He \w aquí|strong="H2009"\w* el \w día|strong="H3117"\w* \w de|strong="H4480"\w* Yahvé viene, cruel, y \w de|strong="H4480"\w* indignación y ardor \w de|strong="H4480"\w* \w ira|strong="H2740"\w*, \w para|strong="H4480"\w* poner la tierra \w en|strong="H4480"\w* \w soledad|strong="H8047"\w* y raer \w de|strong="H4480"\w* \w ella|strong="H4480"\w* \w a|strong="H3068"\w* sus \w pecadores|strong="H2400"\w*.  
\v 10 \w Por|strong="H3588"\w* \w lo|strong="H3808"\w* \w cual|strong="H3588"\w* las \w estrellas|strong="H3556"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w cielos|strong="H8064"\w* \w y|strong="H3588"\w* sus luceros \w no|strong="H3808"\w* darán \w su|strong="H3588"\w* luz; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w sol|strong="H8121"\w* \w se|strong="H3808"\w* oscurecerá al nacer, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w luna|strong="H3394"\w* \w no|strong="H3808"\w* dará \w su|strong="H3588"\w* resplandor.  
\v 11 \w Y|strong="H3068"\w* castigaré \w al|strong="H5921"\w* \w mundo|strong="H8398"\w* \w por|strong="H5921"\w* su \w maldad|strong="H5771"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w impíos|strong="H7563"\w* \w por|strong="H5921"\w* su \w iniquidad|strong="H5771"\w*; \w y|strong="H5921"\w* haré \w que|strong="H5921"\w* cese \w la|strong="H5921"\w* arrogancia \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w soberbios|strong="H2086"\w*, \w y|strong="H5921"\w* \w abatiré|strong="H8213"\w* \w la|strong="H5921"\w* altivez \w de|strong="H5921"\w* \w los|strong="H5921"\w* fuertes.  
\v 12 Haré al varón más preciado que el \w oro|strong="H3800"\w* \w fino|strong="H3800"\w*, y al hombre más que el \w oro|strong="H3800"\w* de Ofir.  
\v 13 \w Porque|strong="H5921"\w* haré mover \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w se|strong="H5921"\w* removerá \w de|strong="H5921"\w* su \w lugar|strong="H4725"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* indignación \w de|strong="H5921"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w del|strong="H5921"\w* ardor \w de|strong="H5921"\w* su \w ira|strong="H2740"\w*.  
\v 14 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w que|strong="H5971"\w* \w como|strong="H1961"\w* gacela acosada, y \w como|strong="H1961"\w* oveja sin \w pastor|strong="H6908"\w*, cada cual \w mirará|strong="H6437"\w* hacia su \w pueblo|strong="H5971"\w*, y cada uno \w huirá|strong="H5127"\w* \w a|strong="H3068"\w* su tierra.  
\v 15 \w Cualquiera|strong="H3605"\w* \w que|strong="H3605"\w* \w fuere|strong="H4672"\w* \w hallado|strong="H4672"\w* será alanceado; y \w cualquiera|strong="H3605"\w* \w que|strong="H3605"\w* por \w ellos|strong="H3605"\w* \w fuere|strong="H4672"\w* tomado, \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.  
\v 16 Sus \w niños|strong="H5768"\w* serán estrellados ante sus mismos \w ojos|strong="H5869"\w*; sus \w casas|strong="H1004"\w* serán saqueadas, y violadas sus mujeres.   
\p
\v 17 He \w aquí|strong="H2005"\w* \w que|strong="H3808"\w* yo despierto \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* medos, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w curarán|strong="H2803"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w plata|strong="H3701"\w*, \w ni|strong="H3808"\w* \w codiciarán|strong="H2654"\w* \w oro|strong="H2091"\w*.  
\v 18 \w Con|strong="H5921"\w* \w arco|strong="H7198"\w* derribarán \w a|strong="H3068"\w* \w los|strong="H1121"\w* jóvenes, \w y|strong="H5921"\w* \w no|strong="H3808"\w* tendrán \w misericordia|strong="H7355"\w* \w del|strong="H5921"\w* \w fruto|strong="H6529"\w* \w del|strong="H5921"\w* vientre, \w ni|strong="H3808"\w* su \w ojo|strong="H5869"\w* perdonará \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w*.  
\v 19 \w Y|strong="H3068"\w* Babilonia, \w hermosura|strong="H6643"\w* de \w reinos|strong="H4467"\w* y ornamento de la grandeza de \w los|strong="H1961"\w* \w caldeos|strong="H3778"\w*, \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w Sodoma|strong="H5467"\w* y \w Gomorra|strong="H6017"\w*, \w a|strong="H3068"\w* las \w que|strong="H1961"\w* trastornó Dios.  
\v 20 \w Nunca|strong="H3808"\w* \w más|strong="H5704"\w* \w será|strong="H3808"\w* \w habitada|strong="H3427"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* \w morará|strong="H3427"\w* \w en|strong="H5704"\w* \w ella|strong="H8033"\w* \w de|strong="H5704"\w* \w generación|strong="H1755"\w* \w en|strong="H5704"\w* \w generación|strong="H1755"\w*; \w ni|strong="H3808"\w* hincará \w allí|strong="H8033"\w* tienda \w el|strong="H3427"\w* árabe, \w ni|strong="H3808"\w* \w pastores|strong="H7462"\w* tendrán \w allí|strong="H8033"\w* \w majada|strong="H7257"\w*;  
\v 21 sino \w que|strong="H1323"\w* \w dormirán|strong="H7257"\w* \w allí|strong="H8033"\w* las fieras del desierto, y sus \w casas|strong="H1004"\w* se llenarán de búhos; \w allí|strong="H8033"\w* \w habitarán|strong="H7931"\w* avestruces, y \w allí|strong="H8033"\w* \w saltarán|strong="H7540"\w* las cabras salvajes.  
\v 22 En sus palacios aullarán hienas, y chacales en sus casas \w de|strong="H6256"\w* deleite; y \w cerca|strong="H7138"\w* está \w de|strong="H6256"\w* venir su \w tiempo|strong="H6256"\w*, y sus \w días|strong="H3117"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* prolongarán.   
\c 14
\p
\v 1 \w Porque|strong="H3588"\w* Yahvé tendrá piedad \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w*, \w y|strong="H3588"\w* \w todavía|strong="H5750"\w* escogerá \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w lo|strong="H5921"\w* pondrá \w en|strong="H5921"\w* \w su|strong="H3588"\w* propia tierra; \w y|strong="H3588"\w* \w extranjeros|strong="H1616"\w* \w se|strong="H5921"\w* unirán \w a|strong="H3068"\w* \w ellos|strong="H5921"\w*, \w y|strong="H3588"\w* \w se|strong="H5921"\w* juntarán \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w*.  
\v 2 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w los|strong="H5921"\w* \w tomarán|strong="H3947"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* llevarán \w a|strong="H3068"\w* su \w lugar|strong="H4725"\w*; \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w los|strong="H5921"\w* \w poseerá|strong="H5157"\w* \w por|strong="H5921"\w* \w siervos|strong="H5650"\w* \w y|strong="H5921"\w* \w siervas|strong="H8198"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Yahvé; \w y|strong="H5921"\w* cautivarán \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* cautivaron, \w y|strong="H5921"\w* señorearán \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* oprimieron.   
\p
\v 3 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* \w que|strong="H4480"\w* \w en|strong="H4480"\w* el \w día|strong="H3117"\w* \w que|strong="H4480"\w* Yahvé \w te|strong="H4480"\w* \w dé|strong="H4480"\w* \w reposo|strong="H5117"\w* \w de|strong="H4480"\w* tu trabajo y \w de|strong="H4480"\w* tu temor, y \w de|strong="H4480"\w* la \w dura|strong="H7186"\w* \w servidumbre|strong="H5656"\w* \w en|strong="H4480"\w* \w que|strong="H4480"\w* \w te|strong="H4480"\w* hicieron \w servir|strong="H5647"\w*,  
\v 4 entonarás \w este|strong="H2088"\w* escarnio \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w y|strong="H5921"\w* dirás: «¡\w Cómo|strong="H5921"\w* \w cesó|strong="H7673"\w* \w el|strong="H5921"\w* opresor, \w cómo|strong="H5921"\w* \w cesó|strong="H7673"\w* \w la|strong="H5921"\w* ciudad codiciosa \w de|strong="H5921"\w* oro!»  
\v 5 Yahvé \w quebrantó|strong="H7665"\w* el báculo de los \w impíos|strong="H7563"\w*, el \w cetro|strong="H7626"\w* de los señores;  
\v 6 el \w que|strong="H5971"\w* \w hería|strong="H5221"\w* \w a|strong="H3068"\w* los \w pueblos|strong="H5971"\w* con saña, con \w llaga|strong="H4347"\w* \w permanente|strong="H1115"\w*, el \w que|strong="H5971"\w* \w se|strong="H5971"\w* enseñoreaba \w de|strong="H5971"\w* las \w naciones|strong="H1471"\w* con ira, y las perseguía con crueldad.  
\v 7 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra descansa y está en \w reposo|strong="H8252"\w*; prorrumpieron en cánticos.  
\v 8 \w Aun|strong="H1571"\w* \w los|strong="H5921"\w* cipreses \w se|strong="H5921"\w* regocijaron \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H1571"\w* \w los|strong="H5921"\w* cedros \w del|strong="H5921"\w* \w Líbano|strong="H3844"\w*, diciendo: «\w Desde|strong="H5921"\w* \w que|strong="H3808"\w* tú pereciste, \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w subido|strong="H5927"\w* leñador \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*».  
\v 9 \w El|strong="H3605"\w* Seol\f + \fr 14:9 \ft El Seol es el lugar de los muertos.\f* \w abajo|strong="H8478"\w* se espantó \w de|strong="H8478"\w* ti; \w despertó|strong="H5782"\w* \w a|strong="H3068"\w* las sombras para recibirte \w en|strong="H8478"\w* tu venida; hizo \w levantar|strong="H6965"\w* \w de|strong="H8478"\w* sus tronos \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* príncipes \w de|strong="H8478"\w* \w la|strong="H3605"\w* tierra, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* \w de|strong="H8478"\w* las \w naciones|strong="H1471"\w*.  
\v 10 \w Todos|strong="H3605"\w* \w ellos|strong="H1571"\w* verán \w y|strong="H1571"\w* te dirán: «¿\w También|strong="H1571"\w* tú te debilitaste \w como|strong="H1571"\w* \w nosotros|strong="H3605"\w*, \w y|strong="H1571"\w* llegaste \w a|strong="H3068"\w* ser \w como|strong="H1571"\w* \w nosotros|strong="H3605"\w*?»  
\v 11 \w Descendió|strong="H3381"\w* \w al|strong="H8478"\w* Seol\f + \fr 14:11 \ft El Seol es el lugar de los muertos.\f* tu \w soberbia|strong="H1347"\w*, y el sonido \w de|strong="H8478"\w* tus liras; \w gusanos|strong="H8438"\w* \w serán|strong="H3331"\w* tu cama, y \w gusanos|strong="H8438"\w* te cubrirán.   
\p
\v 12 ¡\w Cómo|strong="H5921"\w* \w caíste|strong="H5307"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w oh|strong="H1121"\w* Lucero, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H7837"\w*! \w Cortado|strong="H1438"\w* fuiste \w por|strong="H5921"\w* tierra, tú \w que|strong="H5921"\w* debilitabas \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.  
\v 13 Tú que decías en tu \w corazón|strong="H3824"\w*: «\w Subiré|strong="H5927"\w* al \w cielo|strong="H8064"\w*; en lo \w alto|strong="H7311"\w*, junto \w a|strong="H3068"\w* las \w estrellas|strong="H3556"\w* de Dios, \w levantaré|strong="H7311"\w* mi \w trono|strong="H3678"\w*, y en \w el|strong="H3427"\w* \w monte|strong="H2022"\w* del testimonio me sentaré, \w a|strong="H3068"\w* \w los|strong="H3427"\w* lados del \w norte|strong="H6828"\w*;  
\v 14 \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* alturas \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w nubes|strong="H5645"\w* \w subiré|strong="H5927"\w*, \w y|strong="H5921"\w* seré semejante \w al|strong="H5921"\w* \w Altísimo|strong="H5945"\w*».  
\v 15 Mas tú derribado eres hasta el Seol\f + \fr 14:15 \ft El Seol es el lugar de los muertos.\f*, \w a|strong="H3068"\w* los lados de la fosa.  
\v 16 Se inclinarán hacia ti los \w que|strong="H2088"\w* te \w vean|strong="H7200"\w*, te \w contemplarán|strong="H7200"\w*, diciendo: «¿\w Es|strong="H2088"\w* \w este|strong="H2088"\w* \w aquel|strong="H2088"\w* varón \w que|strong="H2088"\w* hacía \w temblar|strong="H7493"\w* la tierra, \w que|strong="H2088"\w* trastornaba los \w reinos|strong="H4467"\w*;  
\v 17 \w que|strong="H3808"\w* \w puso|strong="H7760"\w* el \w mundo|strong="H8398"\w* como un \w desierto|strong="H4057"\w*, \w que|strong="H3808"\w* \w asoló|strong="H7760"\w* sus \w ciudades|strong="H5892"\w*, \w que|strong="H3808"\w* \w a|strong="H3068"\w* sus presos \w nunca|strong="H3808"\w* \w abrió|strong="H6605"\w* la cárcel?»   
\p
\v 18 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de las \w naciones|strong="H1471"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w yacen|strong="H7901"\w* con \w honra|strong="H3519"\w* \w cada|strong="H3605"\w* uno en su morada.  
\v 19 Pero tú eres \w echado|strong="H7993"\w* de tu \w sepulcro|strong="H6913"\w* como vástago \w abominable|strong="H8581"\w*, como \w vestido|strong="H3830"\w* de \w muertos|strong="H6297"\w* \w pasados|strong="H2944"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, que \w descienden|strong="H3381"\w* al fondo de la fosa; como cadáver pisoteado.  
\v 20 \w No|strong="H3808"\w* serás contado \w con|strong="H3588"\w* ellos \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w sepultura|strong="H6900"\w*; \w porque|strong="H3588"\w* tú destruiste tu tierra, \w mataste|strong="H2026"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*. \w No|strong="H3808"\w* \w será|strong="H3808"\w* nombrada \w para|strong="H3588"\w* \w siempre|strong="H5769"\w* \w la|strong="H3588"\w* \w descendencia|strong="H2233"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w malignos|strong="H7489"\w*.   
\p
\v 21 Preparad matadero para sus \w hijos|strong="H1121"\w* \w por|strong="H6440"\w* la \w maldad|strong="H5771"\w* \w de|strong="H6440"\w* sus padres; \w no|strong="H1077"\w* se levanten, \w ni|strong="H1077"\w* \w posean|strong="H3423"\w* la tierra, \w ni|strong="H1077"\w* llenen \w de|strong="H6440"\w* \w ciudades|strong="H5892"\w* la \w faz|strong="H6440"\w* del \w mundo|strong="H8398"\w*.  
\v 22 «\w Porque|strong="H5921"\w* yo \w me|strong="H5921"\w* \w levantaré|strong="H6965"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* — \w dice|strong="H5002"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* — \w y|strong="H5921"\w* raeré \w de|strong="H5921"\w* Babilonia \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* remanente, \w hijo|strong="H5209"\w* \w y|strong="H5921"\w* \w nieto|strong="H5220"\w* — \w dice|strong="H5002"\w* Yahvé —.  
\v 23 \w Y|strong="H3068"\w* la convertiré en posesión \w de|strong="H4325"\w* erizos, y en lagunas \w de|strong="H4325"\w* \w agua|strong="H4325"\w*; y la barreré con escoba \w de|strong="H4325"\w* destrucción», \w dice|strong="H5002"\w* Yahvé \w de|strong="H4325"\w* los \w Ejércitos|strong="H6635"\w*.   
\p
\v 24 Yahvé de \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w* \w juró|strong="H7650"\w* diciendo: «Ciertamente \w se|strong="H1961"\w* \w hará|strong="H1961"\w* de \w la|strong="H1931"\w* manera \w que|strong="H1931"\w* \w lo|strong="H1931"\w* he pensado, y \w será|strong="H1961"\w* \w confirmado|strong="H6965"\w* \w como|strong="H1961"\w* \w lo|strong="H1931"\w* he determinado:  
\v 25 \w que|strong="H5921"\w* \w quebrantaré|strong="H7665"\w* \w al|strong="H5921"\w* asirio \w en|strong="H5921"\w* \w mi|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w en|strong="H5921"\w* mis \w montes|strong="H2022"\w* \w lo|strong="H5921"\w* hollaré; \w y|strong="H5921"\w* su \w yugo|strong="H5923"\w* \w será|strong="H7665"\w* apartado \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* su \w carga|strong="H5448"\w* \w será|strong="H7665"\w* quitada \w de|strong="H5921"\w* su \w hombro|strong="H7926"\w*».  
\v 26 \w Este|strong="H2063"\w* \w es|strong="H3027"\w* \w el|strong="H5921"\w* \w consejo|strong="H6098"\w* \w que|strong="H5921"\w* \w está|strong="H2063"\w* determinado \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w esta|strong="H2063"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w extendida|strong="H5186"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.  
\v 27 \w Porque|strong="H3588"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w* ha determinado, ¿\w y|strong="H3588"\w* \w quién|strong="H4310"\w* lo impedirá? \w Y|strong="H3068"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w extendida|strong="H5186"\w*, ¿\w quién|strong="H4310"\w* \w la|strong="H3588"\w* hará retroceder?   
\p
\v 28 En el \w año|strong="H8141"\w* \w que|strong="H1961"\w* murió el \w rey|strong="H4428"\w* Acaz \w fue|strong="H1961"\w* \w esta|strong="H2088"\w* profecía:   
\p
\v 29 \w No|strong="H3588"\w* os alegréis vosotros, \w Filistea|strong="H6429"\w* \w toda|strong="H3605"\w*, \w por|strong="H3588"\w* haberse quebrado \w la|strong="H3588"\w* \w vara|strong="H7626"\w* del \w que|strong="H3588"\w* os \w hería|strong="H5221"\w*; \w porque|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* raíz \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w culebra|strong="H5175"\w* \w saldrá|strong="H3318"\w* áspid, \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w fruto|strong="H6529"\w* \w será|strong="H7665"\w* \w serpiente|strong="H5175"\w* voladora.  
\v 30 \w Y|strong="H3068"\w* los \w primogénitos|strong="H1060"\w* de los \w pobres|strong="H1800"\w* serán \w apacentados|strong="H7462"\w*, y los menesterosos se acostarán seguros; \w mas|strong="H4191"\w* yo haré \w morir|strong="H4191"\w* de \w hambre|strong="H7458"\w* tu raíz, y destruiré lo que de ti quedare.   
\p
\v 31 ¡\w Aullad|strong="H3213"\w*, \w puertas|strong="H8179"\w*! ¡Clamad, \w ciudad|strong="H5892"\w*! Disuelta estáis vosotros, \w Filistea|strong="H6429"\w* \w toda|strong="H3605"\w*; \w porque|strong="H3588"\w* \w humo|strong="H6227"\w* viene del \w norte|strong="H6828"\w*, \w y|strong="H3588"\w* \w no|strong="H3588"\w* quedará uno solo \w de|strong="H3588"\w* sus filas.   
\p
\v 32 ¿\w Y|strong="H3068"\w* \w qué|strong="H3588"\w* \w se|strong="H5971"\w* \w responderá|strong="H6030"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w mensajeros|strong="H4397"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w*? \w Que|strong="H3588"\w* Yahvé \w fundó|strong="H3245"\w* \w a|strong="H3068"\w* \w Sión|strong="H6726"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* ella \w se|strong="H5971"\w* acogerán \w los|strong="H3588"\w* afligidos \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*.   
\c 15
\p
\v 1 Oráculo sobre \w Moab|strong="H4124"\w*.  
\p \w Ciertamente|strong="H3588"\w*, \w en|strong="H3588"\w* una \w noche|strong="H3915"\w* \w Ar|strong="H6144"\w* \w de|strong="H3588"\w* \w Moab|strong="H4124"\w* fue asolada \w y|strong="H3588"\w* \w destruida|strong="H7703"\w*; \w ciertamente|strong="H3588"\w*, \w en|strong="H3588"\w* una \w noche|strong="H3915"\w* Kir \w de|strong="H3588"\w* \w Moab|strong="H4124"\w* fue asolada \w y|strong="H3588"\w* \w destruida|strong="H7703"\w*.  
\v 2 \w Subió|strong="H5927"\w* \w a|strong="H3068"\w* \w el|strong="H5921"\w* Templo \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w Dibón|strong="H1769"\w*, \w a|strong="H3068"\w* \w los|strong="H5921"\w* lugares \w altos|strong="H1116"\w*, \w para|strong="H5921"\w* llorar; \w sobre|strong="H5921"\w* \w Nebo|strong="H5015"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w Medeba|strong="H4311"\w* \w aullará|strong="H3213"\w* \w Moab|strong="H4124"\w*; \w toda|strong="H3605"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w* será rapada, \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w barba|strong="H2206"\w* rasurada.  
\v 3 \w Se|strong="H5921"\w* ceñirán \w de|strong="H5921"\w* cilicio \w en|strong="H5921"\w* sus \w calles|strong="H7339"\w*; \w en|strong="H5921"\w* sus terrados \w y|strong="H5921"\w* \w en|strong="H5921"\w* sus \w plazas|strong="H7339"\w* \w aullarán|strong="H3213"\w* \w todos|strong="H3605"\w*, deshaciéndose \w en|strong="H5921"\w* \w llanto|strong="H1065"\w*.  
\v 4 \w Hesbón|strong="H2809"\w* \w y|strong="H5921"\w* Eleale \w gritarán|strong="H2199"\w*, \w hasta|strong="H5704"\w* Jahaza \w se|strong="H5921"\w* \w oirá|strong="H8085"\w* su \w voz|strong="H6963"\w*; \w por|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* guerreros \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w clamarán|strong="H2199"\w*, \w y|strong="H5921"\w* su \w alma|strong="H5315"\w* \w se|strong="H5921"\w* estremecerá \w dentro|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 5 Mi \w corazón|strong="H3820"\w* dará \w gritos|strong="H2201"\w* \w por|strong="H3588"\w* \w Moab|strong="H4124"\w*; sus fugitivos huirán \w hasta|strong="H5704"\w* \w Zoar|strong="H6820"\w* \w y|strong="H3588"\w* \w hasta|strong="H5704"\w* Eglat Selisiyá. \w Por|strong="H3588"\w* \w la|strong="H3588"\w* subida \w de|strong="H3588"\w* Luhit \w subirán|strong="H5927"\w* \w llorando|strong="H1065"\w*, \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w Horonaim|strong="H2773"\w* lanzarán \w gritos|strong="H2201"\w* \w de|strong="H3588"\w* quebranto.  
\v 6 Las \w aguas|strong="H4325"\w* \w de|strong="H3588"\w* Nimrim \w se|strong="H1961"\w* agotarán, \w se|strong="H1961"\w* \w secará|strong="H3001"\w* \w la|strong="H3588"\w* \w hierba|strong="H2682"\w*, \w se|strong="H1961"\w* marchitarán \w los|strong="H1961"\w* brotes \w y|strong="H3588"\w* todo verdor \w perecerá|strong="H3808"\w*.  
\v 7 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w las|strong="H5921"\w* riquezas \w que|strong="H5921"\w* habrán adquirido \w y|strong="H5921"\w* sus reservas \w las|strong="H5921"\w* \w llevarán|strong="H5375"\w* \w al|strong="H5921"\w* otro lado \w del|strong="H5921"\w* \w Torrente|strong="H5158"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* Sauces.  
\v 8 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w clamor|strong="H2201"\w* \w rodeó|strong="H5362"\w* \w los|strong="H3588"\w* límites \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*; \w hasta|strong="H5704"\w* Eglaim \w llegó|strong="H5704"\w* \w su|strong="H3588"\w* alarido, \w y|strong="H3588"\w* \w hasta|strong="H5704"\w* Beer-elim \w su|strong="H3588"\w* \w clamor|strong="H2201"\w*.  
\v 9 \w Y|strong="H3068"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w de|strong="H5921"\w* \w Dimón|strong="H1775"\w* \w se|strong="H5921"\w* llenarán \w de|strong="H5921"\w* \w sangre|strong="H1818"\w*; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* traeré \w sobre|strong="H5921"\w* \w Dimón|strong="H1775"\w* males añadidos: leones \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* escapen \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w y|strong="H3588"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w resto|strong="H7611"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.   
\c 16
\p
\v 1 \w Enviad|strong="H7971"\w* \w corderos|strong="H3733"\w* al soberano de la tierra, desde Sela, por el \w desierto|strong="H4057"\w*, al \w monte|strong="H2022"\w* de la \w hija|strong="H1323"\w* de \w Sión|strong="H6726"\w*.  
\v 2 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* \w que|strong="H1961"\w* cual \w ave|strong="H5775"\w* \w espantada|strong="H7971"\w* \w que|strong="H1961"\w* huye de su \w nido|strong="H7064"\w*, así \w serán|strong="H1961"\w* las \w hijas|strong="H1323"\w* de \w Moab|strong="H4124"\w* en \w los|strong="H1961"\w* vados del Arnón.  
\v 3 «¡Dad \w consejo|strong="H6098"\w*, \w haced|strong="H6213"\w* justicia! \w Poned|strong="H7896"\w* vuestra \w sombra|strong="H6738"\w* como la \w noche|strong="H3915"\w* \w en|strong="H8432"\w* pleno mediodía; esconded \w a|strong="H3068"\w* los desterrados, \w no|strong="H6213"\w* entreguéis al que anda errante.  
\v 4 \w Moren|strong="H1481"\w* \w contigo|strong="H6440"\w* mis desterrados \w de|strong="H4480"\w* \w Moab|strong="H4124"\w*; \w sé|strong="H4480"\w* \w para|strong="H3588"\w* \w ellos|strong="H4480"\w* escondedero \w ante|strong="H6440"\w* \w la|strong="H3588"\w* \w presencia|strong="H6440"\w* \w del|strong="H4480"\w* devastador; \w porque|strong="H3588"\w* \w el|strong="H3588"\w* extorsionador ha fenecido, \w la|strong="H3588"\w* devastación ha cesado, \w y|strong="H3588"\w* \w los|strong="H3588"\w* opresores han sido \w consumidos|strong="H8552"\w* \w de|strong="H4480"\w* \w sobre|strong="H4480"\w* \w la|strong="H3588"\w* tierra.  
\v 5 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* dispondrá un \w trono|strong="H3678"\w* \w en|strong="H5921"\w* \w misericordia|strong="H2617"\w*; \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* sentará firmemente, \w en|strong="H5921"\w* \w el|strong="H5921"\w* tabernáculo \w de|strong="H5921"\w* \w David|strong="H1732"\w*, quien \w juzgue|strong="H8199"\w* \w y|strong="H5921"\w* \w busque|strong="H1875"\w* \w el|strong="H5921"\w* \w juicio|strong="H4941"\w*, \w y|strong="H5921"\w* apresure \w la|strong="H5921"\w* \w justicia|strong="H6664"\w*».   
\p
\v 6 Hemos \w oído|strong="H8085"\w* de la \w soberbia|strong="H1347"\w* de \w Moab|strong="H4124"\w*; es \w muy|strong="H3966"\w* orgulloso; de su arrogancia, de su altivez y de su furia; pero sus jactancias \w son|strong="H3808"\w* vanas.  
\v 7 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w aullará|strong="H3213"\w* \w Moab|strong="H4124"\w* \w por|strong="H3651"\w* \w Moab|strong="H4124"\w*; \w todos|strong="H3605"\w* \w aullarán|strong="H3213"\w*. \w Gemiréis|strong="H1897"\w* \w por|strong="H3651"\w* las tortas de pasas de Quir-hareset, ciertamente abatidos.  
\v 8 \w Porque|strong="H3588"\w* \w los|strong="H1167"\w* campos \w de|strong="H3588"\w* \w Hesbón|strong="H2809"\w* se han marchitado, \w y|strong="H3588"\w* las \w vides|strong="H1612"\w* \w de|strong="H3588"\w* Sibma; \w los|strong="H1167"\w* \w señores|strong="H1167"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w* pisotearon \w sus|strong="H1986"\w* generosos \w sarmientos|strong="H8291"\w*, \w que|strong="H3588"\w* llegaban \w hasta|strong="H5704"\w* \w Jazer|strong="H3270"\w* \w y|strong="H3588"\w* se extendían \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*; \w sus|strong="H1986"\w* ramas se prolongaban \w y|strong="H3588"\w* \w pasaban|strong="H5674"\w* \w más|strong="H3588"\w* allá del \w mar|strong="H3220"\w*.  
\v 9 \w Por|strong="H5921"\w* \w lo|strong="H5921"\w* \w cual|strong="H3588"\w* \w lamentaré|strong="H1058"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w lloro|strong="H1058"\w* \w de|strong="H5921"\w* \w Jazer|strong="H3270"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w viña|strong="H1612"\w* \w de|strong="H5921"\w* Sibma; \w te|strong="H5921"\w* regaré \w con|strong="H5921"\w* mis \w lágrimas|strong="H1832"\w*, oh \w Hesbón|strong="H2809"\w* \w y|strong="H3588"\w* Eleale; \w porque|strong="H3588"\w* \w sobre|strong="H5921"\w* tus \w frutos|strong="H7019"\w* \w de|strong="H5921"\w* \w verano|strong="H7019"\w* \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* tu cosecha \w cayó|strong="H5307"\w* \w el|strong="H5921"\w* grito \w de|strong="H5921"\w* guerra.  
\v 10 Quitado es el \w gozo|strong="H8057"\w* y la \w alegría|strong="H8057"\w* \w del|strong="H4480"\w* campo fértil; \w en|strong="H4480"\w* las \w viñas|strong="H3754"\w* \w no|strong="H3808"\w* \w cantarán|strong="H7442"\w*, \w ni|strong="H3808"\w* \w se|strong="H4480"\w* regocijarán; \w no|strong="H3808"\w* \w pisará|strong="H1869"\w* \w vino|strong="H3196"\w* el pisador \w en|strong="H4480"\w* los lagares; he hecho cesar el grito \w del|strong="H4480"\w* lagarero.  
\v 11 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, mis \w entrañas|strong="H4578"\w* vibrarán \w como|strong="H5921"\w* \w arpa|strong="H3658"\w* \w por|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w y|strong="H5921"\w* \w mi|strong="H5921"\w* corazón \w por|strong="H5921"\w* Quir-heres.  
\v 12 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w Moab|strong="H4124"\w* \w se|strong="H1961"\w* presentare \w cansado|strong="H3811"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* lugares \w altos|strong="H1116"\w*, \w y|strong="H3588"\w* \w viniere|strong="H1961"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w santuario|strong="H4720"\w* \w a|strong="H3068"\w* orar, \w no|strong="H3808"\w* \w le|strong="H5921"\w* valdrá.   
\p
\v 13 \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* la \w palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w pronunció|strong="H1696"\w* Yahvé sobre \w Moab|strong="H4124"\w* en el pasado;  
\v 14 pero \w ahora|strong="H6258"\w* Yahvé \w ha|strong="H3808"\w* \w hablado|strong="H1696"\w*, \w diciendo|strong="H1696"\w*: «Dentro de \w tres|strong="H7969"\w* \w años|strong="H8141"\w*, como \w los|strong="H3605"\w* \w años|strong="H8141"\w* de un jornalero, \w la|strong="H3605"\w* \w gloria|strong="H3519"\w* de \w Moab|strong="H4124"\w* \w será|strong="H3808"\w* despreciada con \w toda|strong="H3605"\w* su \w gran|strong="H7227"\w* \w multitud|strong="H1995"\w*; \w y|strong="H3519"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* quede \w será|strong="H3808"\w* muy \w poco|strong="H4592"\w*, pequeño \w y|strong="H3519"\w* débil».   
\c 17
\p
\v 1 Oráculo \w sobre|strong="H1961"\w* \w Damasco|strong="H1834"\w*.  
\p «He \w aquí|strong="H2009"\w* \w que|strong="H1961"\w* \w Damasco|strong="H1834"\w* dejará de ser \w ciudad|strong="H5892"\w*, y \w será|strong="H1961"\w* \w montón|strong="H4596"\w* de ruinas.  
\v 2 Las \w ciudades|strong="H5892"\w* de \w Aroer|strong="H6177"\w* \w están|strong="H1961"\w* \w desamparadas|strong="H5800"\w*; \w serán|strong="H1961"\w* \w para|strong="H1961"\w* \w los|strong="H1961"\w* \w rebaños|strong="H5739"\w*, \w que|strong="H1961"\w* \w se|strong="H1961"\w* echarán allí, y \w no|strong="H1961"\w* \w habrá|strong="H1961"\w* quien \w los|strong="H1961"\w* espante.  
\v 3 \w Y|strong="H3068"\w* cesará la \w fortaleza|strong="H4013"\w* \w de|strong="H1121"\w* Efraín, \w y|strong="H3519"\w* \w el|strong="H1121"\w* \w reino|strong="H4467"\w* \w de|strong="H1121"\w* \w Damasco|strong="H1834"\w*; \w y|strong="H3519"\w* lo \w que|strong="H1121"\w* \w quede|strong="H1961"\w* \w de|strong="H1121"\w* Siria \w será|strong="H1961"\w* \w como|strong="H1961"\w* la \w gloria|strong="H3519"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*», \w dice|strong="H5002"\w* Yahvé \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w*.   
\p
\v 4 «\w Acontecerá|strong="H1961"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* \w gloria|strong="H3519"\w* de \w Jacob|strong="H3290"\w* \w se|strong="H1961"\w* atenuará, \w y|strong="H3519"\w* \w se|strong="H1961"\w* enflaquecerá \w la|strong="H1931"\w* gordura de \w su|strong="H1931"\w* \w carne|strong="H1320"\w*.  
\v 5 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w cuando|strong="H1961"\w* el \w segador|strong="H7114"\w* recoge la \w mies|strong="H7105"\w*, y su \w brazo|strong="H2220"\w* \w siega|strong="H7114"\w* las \w espigas|strong="H7641"\w*; \w sí|strong="H1961"\w*, \w será|strong="H1961"\w* \w como|strong="H1961"\w* el \w que|strong="H7105"\w* recoge \w espigas|strong="H7641"\w* en el \w valle|strong="H6010"\w* de Refaim.  
\v 6 \w Y|strong="H3068"\w* quedarán en él rebuscos, como el vareo \w de|strong="H2568"\w* un olivo: \w dos|strong="H8147"\w* \w o|strong="H3068"\w* \w tres|strong="H7969"\w* \w aceitunas|strong="H2132"\w* en la punta \w de|strong="H2568"\w* la rama más alta, cuatro \w o|strong="H3068"\w* \w cinco|strong="H2568"\w* en las ramas más \w fructíferas|strong="H6509"\w*», \w dice|strong="H5002"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H2568"\w* \w Israel|strong="H3478"\w*.  
\v 7 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w mirará|strong="H7200"\w* \w el|strong="H1931"\w* hombre \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w Hacedor|strong="H6213"\w*, \w y|strong="H5921"\w* \w sus|strong="H1931"\w* \w ojos|strong="H5869"\w* \w se|strong="H1931"\w* volverán \w al|strong="H5921"\w* \w Santo|strong="H6918"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 8 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w mirará|strong="H7200"\w* \w a|strong="H3068"\w* los \w altares|strong="H4196"\w*, \w obra|strong="H4639"\w* de sus \w manos|strong="H3027"\w*, \w ni|strong="H3808"\w* \w mirará|strong="H7200"\w* \w a|strong="H3068"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w hicieron|strong="H6213"\w* sus dedos, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* las imágenes de Asera \w ni|strong="H3808"\w* \w a|strong="H3068"\w* los \w altares|strong="H4196"\w* \w del|strong="H4196"\w* incienso.  
