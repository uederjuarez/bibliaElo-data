\q1
\v 16 \w Porque|strong="H3588"\w* Yahvé \w juzgará|strong="H8199"\w* \w con|strong="H3588"\w* fuego \w y|strong="H3588"\w* \w con|strong="H3588"\w* \w su|strong="H3588"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w*;  
\q2 \w y|strong="H3588"\w* \w los|strong="H3605"\w* \w muertos|strong="H2491"\w* \w de|strong="H3588"\w* Yahvé serán muchos.   
\p
\v 17 «Los que se \w santifican|strong="H6942"\w* y los que se purifican \w en|strong="H8432"\w* los \w huertos|strong="H1593"\w*, unos tras otros, los que comen \w carne|strong="H1320"\w* de cerdo y abominación y ratón, \w juntamente|strong="H3162"\w* serán talados», \w dice|strong="H5002"\w* Yahvé.   
\p
\v 18 «Porque yo conozco sus \w obras|strong="H4639"\w* \w y|strong="H3519"\w* sus \w pensamientos|strong="H4284"\w*; tiempo viene para \w juntar|strong="H6908"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w y|strong="H3519"\w* lenguas; \w y|strong="H3519"\w* vendrán, \w y|strong="H3519"\w* \w verán|strong="H7200"\w* mi \w gloria|strong="H3519"\w*.   
\p
\v 19 \w Y|strong="H3068"\w* \w pondré|strong="H7760"\w* \w entre|strong="H3808"\w* \w ellos|strong="H1992"\w* señal, \w y|strong="H3519"\w* \w enviaré|strong="H7971"\w* de \w los|strong="H1992"\w* escapados de \w ellos|strong="H1992"\w* \w a|strong="H3068"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w*, \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*, \w a|strong="H3068"\w* Pul \w y|strong="H3519"\w* \w a|strong="H3068"\w* \w Lud|strong="H3865"\w* \w que|strong="H3808"\w* disparan \w arco|strong="H7198"\w*, \w a|strong="H3068"\w* \w Tubal|strong="H8422"\w* \w y|strong="H3519"\w* \w a|strong="H3068"\w* \w Javán|strong="H3120"\w*, \w a|strong="H3068"\w* \w las|strong="H1992"\w* costas lejanas \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w oyeron|strong="H8085"\w* de mí, \w ni|strong="H3808"\w* \w vieron|strong="H7200"\w* mi \w gloria|strong="H3519"\w*; \w y|strong="H3519"\w* publicarán mi \w gloria|strong="H3519"\w* \w entre|strong="H3808"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w*.  
\v 20 \w Y|strong="H3068"\w* traerán \w a|strong="H3068"\w* \w todos|strong="H3605"\w* vuestros hermanos \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, \w por|strong="H5921"\w* \w ofrenda|strong="H4503"\w* \w a|strong="H3068"\w* Yahvé, \w en|strong="H5921"\w* \w caballos|strong="H5483"\w*, \w en|strong="H5921"\w* \w carros|strong="H7393"\w*, \w en|strong="H5921"\w* literas, \w en|strong="H5921"\w* mulos \w y|strong="H5921"\w* \w en|strong="H5921"\w* camellos, \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w santo|strong="H6944"\w* \w monte|strong="H2022"\w* \w de|strong="H5921"\w* Jerusalén, dice Yahvé, \w al|strong="H5921"\w* modo \w que|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* traen \w la|strong="H5921"\w* \w ofrenda|strong="H4503"\w* \w en|strong="H5921"\w* utensilios \w limpios|strong="H2889"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé.  
\v 21 \w Y|strong="H3068"\w* \w tomaré|strong="H3947"\w* \w también|strong="H1571"\w* de \w ellos|strong="H1992"\w* para \w sacerdotes|strong="H3548"\w* \w y|strong="H1571"\w* \w levitas|strong="H3881"\w*», dice Yahvé.   
\p
\v 22 «\w Porque|strong="H3588"\w* \w como|strong="H3588"\w* \w los|strong="H3588"\w* \w cielos|strong="H8064"\w* \w nuevos|strong="H2319"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w nueva|strong="H2319"\w* tierra \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w hago|strong="H6213"\w* permanecerán \w delante|strong="H6440"\w* \w de|strong="H3588"\w* mí», \w dice|strong="H5002"\w* Yahvé, «\w así|strong="H3651"\w* \w permanecerá|strong="H5975"\w* vuestra \w descendencia|strong="H2233"\w* \w y|strong="H3588"\w* vuestro \w nombre|strong="H8034"\w*.  
\v 23 \w Y|strong="H3068"\w* \w de|strong="H6440"\w* \w mes|strong="H2320"\w* en \w mes|strong="H2320"\w*, y \w de|strong="H6440"\w* \w sábado|strong="H7676"\w* en \w sábado|strong="H7676"\w*, vendrán \w todos|strong="H3605"\w* \w a|strong="H3068"\w* adorar \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H1961"\w*», dice Yahvé.  
\v 24 «\w Y|strong="H3068"\w* \w saldrán|strong="H3318"\w*, \w y|strong="H3588"\w* \w verán|strong="H7200"\w* \w los|strong="H3605"\w* cadáveres \w de|strong="H3588"\w* \w los|strong="H3605"\w* hombres \w que|strong="H3588"\w* \w se|strong="H1961"\w* rebelaron \w contra|strong="H1961"\w* \w mí|strong="H1961"\w*; \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w gusano|strong="H8438"\w* \w nunca|strong="H3808"\w* \w morirá|strong="H4191"\w*, \w ni|strong="H3808"\w* \w su|strong="H3588"\w* fuego \w se|strong="H1961"\w* \w apagará|strong="H3518"\w*, \w y|strong="H3588"\w* \w serán|strong="H1961"\w* \w abominables|strong="H1860"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w*».   