\q1
\v 2 Entrará \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w paz|strong="H7965"\w*;  
\q2 \w descansarán|strong="H5117"\w* \w en|strong="H5921"\w* sus lechos todos aquellos \w que|strong="H5921"\w* \w caminaron|strong="H1980"\w* \w en|strong="H5921"\w* su rectitud.   
\b  
\q1
\v 3 “Pero vosotros, \w acercaos|strong="H7126"\w* \w acá|strong="H2008"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* la hechicera,  
