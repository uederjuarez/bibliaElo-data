\q2 \w cada|strong="H3605"\w* uno busca \w su|strong="H1992"\w* propio \w provecho|strong="H1215"\w*, \w cada|strong="H3605"\w* \w cual|strong="H5315"\w* \w por|strong="H1870"\w* \w su|strong="H1992"\w* lado.   
\q1
\v 12 «Venid», dicen, «tomemos \w vino|strong="H3196"\w*,  
\q2 \w embriaguémonos|strong="H5433"\w* de \w sidra|strong="H7941"\w*;  
\q2 y \w será|strong="H1961"\w* el \w día|strong="H3117"\w* de \w mañana|strong="H4279"\w* \w como|strong="H1961"\w* \w este|strong="H2088"\w*,  
\q2 \w o|strong="H3068"\w* \w mucho|strong="H3966"\w* \w más|strong="H3499"\w* \w excelente|strong="H1419"\w*».   
\c 57
\q1
\v 1 Perece \w el|strong="H5921"\w* \w justo|strong="H6662"\w*, \w y|strong="H3588"\w* \w no|strong="H3588"\w* hay quien \w lo|strong="H5921"\w* tome \w a|strong="H3068"\w* pecho;  
\q2 \w los|strong="H5921"\w* hombres piadosos mueren, \w y|strong="H3588"\w* \w no|strong="H3588"\w* hay quien entienda  
