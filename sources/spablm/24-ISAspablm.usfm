\p
\v 12 ¡\w Ay|strong="H1945"\w*! ¡\w Multitud|strong="H1995"\w* \w de|strong="H5971"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* \w que|strong="H5971"\w* harán ruido \w como|strong="H1993"\w* el estruendo del \w mar|strong="H3220"\w*; y estrépito \w de|strong="H5971"\w* naciones \w que|strong="H5971"\w* \w bramarán|strong="H1993"\w* \w como|strong="H1993"\w* el bramido \w de|strong="H5971"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*!  
