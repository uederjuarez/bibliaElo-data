\c 44
\q1
\v 1 “\w Escucha|strong="H8085"\w* \w ahora|strong="H6258"\w*, \w Jacob|strong="H3290"\w*, \w siervo|strong="H5650"\w* mío,  
\q2 \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* quien yo escogí.   
\q1
\v 2 \w Así|strong="H3541"\w* dice Yahvé, \w el|strong="H6213"\w* \w que|strong="H3541"\w* te \w hizo|strong="H6213"\w* \w y|strong="H3541"\w* te \w formó|strong="H3335"\w* desde \w el|strong="H6213"\w* vientre,  
\q2 \w el|strong="H6213"\w* cual te ayudará:  
\q1 «\w No|strong="H6213"\w* \w temas|strong="H3372"\w*, \w siervo|strong="H5650"\w* mío \w Jacob|strong="H3290"\w*,  
\q2 \w y|strong="H3541"\w* \w tú|strong="H6213"\w*, Jesurún, \w a|strong="H3068"\w* \w quien|strong="H6213"\w* \w yo|strong="H6213"\w* escogí.   
\q1
\v 3 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w derramaré|strong="H3332"\w* \w aguas|strong="H4325"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* suelo sediento,  
\q2 \w y|strong="H3588"\w* raudales \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w tierra|strong="H3004"\w* seca;  
\q1 \w mi|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w derramaré|strong="H3332"\w* \w sobre|strong="H5921"\w* tu \w generación|strong="H2233"\w*,  
\q2 \w y|strong="H3588"\w* \w mi|strong="H5921"\w* \w bendición|strong="H1293"\w* \w sobre|strong="H5921"\w* tus \w renuevos|strong="H6631"\w*;   
\q1
\v 4 \w y|strong="H5921"\w* brotarán \w entre|strong="H5921"\w* \w la|strong="H5921"\w* \w hierba|strong="H2682"\w*,  
\q2 \w como|strong="H5921"\w* sauces \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* riberas \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*».   
\q1
\v 5 \w Este|strong="H2088"\w* dirá: «Yo soy de Yahvé»;  
\q2 el \w otro|strong="H2088"\w* se \w llamará|strong="H7121"\w* del \w nombre|strong="H8034"\w* de \w Jacob|strong="H3290"\w*,  
\q2 y \w otro|strong="H2088"\w* \w escribirá|strong="H3789"\w* con su \w mano|strong="H3027"\w*: «\w A|strong="H3068"\w* Yahvé»,  
\q2 y se apellidará con el \w nombre|strong="H8034"\w* de \w Israel|strong="H3478"\w*”.   
\b  
\q1
\v 6 \w Así|strong="H3541"\w* dice Yahvé, \w Rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*,  
\q2 \w y|strong="H3541"\w* su \w Redentor|strong="H1350"\w*, Yahvé de los \w Ejércitos|strong="H6635"\w*:  
\q1 «Yo soy el \w primero|strong="H7223"\w* \w y|strong="H3541"\w* yo soy el último,  
\q2 \w y|strong="H3541"\w* \w fuera|strong="H1107"\w* de mí no hay \w Dios|strong="H3068"\w*.   
\q1
\v 7 ¿\w Y|strong="H3068"\w* \w quién|strong="H4310"\w* proclamará lo venidero, lo declarará y lo \w pondrá|strong="H7760"\w* en orden delante \w de|strong="H5971"\w* mí,  
\q2 \w como|strong="H3644"\w* hago yo desde \w que|strong="H4310"\w* establecí \w el|strong="H4310"\w* \w pueblo|strong="H5971"\w* \w antiguo|strong="H5769"\w*?  
\q1 ¡\w Anúncienles|strong="H5046"\w* lo \w que|strong="H4310"\w* viene,  
\q2 y lo \w que|strong="H4310"\w* está \w por|strong="H5769"\w* suceder!   
\q1
\v 8 \w No|strong="H3808"\w* \w temáis|strong="H6342"\w*, \w ni|strong="H3808"\w* os amedrentéis;  
\q2 ¿\w no|strong="H3808"\w* os \w lo|strong="H3808"\w* hice \w oír|strong="H8085"\w* y os \w lo|strong="H3808"\w* dije desde antiguo?  
\q1 Luego \w vosotros|strong="H3426"\w* sois mis \w testigos|strong="H5707"\w*.  
\q2 ¿\w Hay|strong="H3426"\w* Dios \w fuera|strong="H1107"\w* de mí?  
\q1 \w No|strong="H3808"\w* \w hay|strong="H3426"\w* \w Roca|strong="H6697"\w*;  
\q2 \w no|strong="H3808"\w* \w conozco|strong="H3045"\w* \w ninguna|strong="H3808"\w*».   
\b  
\q1
\v 9 \w Los|strong="H1992"\w* formadores de imágenes de talla, \w todos|strong="H3605"\w* \w ellos|strong="H1992"\w* son \w vanidad|strong="H8414"\w*,  
\q2 y \w lo|strong="H1992"\w* más precioso de \w ellos|strong="H1992"\w* \w para|strong="H4616"\w* \w nada|strong="H3605"\w* es provechoso;  
\q2 y \w ellos|strong="H1992"\w* \w mismos|strong="H1992"\w*, \w para|strong="H4616"\w* \w su|strong="H1992"\w* confusión, son \w testigos|strong="H5707"\w* de \w que|strong="H3045"\w* \w los|strong="H1992"\w* ídolos \w no|strong="H1077"\w* \w ven|strong="H7200"\w* \w ni|strong="H1077"\w* entienden.   
\q1
\v 10 ¿\w Quién|strong="H4310"\w* \w formó|strong="H3335"\w* un dios,  
\q2 \w o|strong="H3068"\w* \w quién|strong="H4310"\w* fundió una \w imagen|strong="H6459"\w* \w que|strong="H4310"\w* para nada es de \w provecho|strong="H3276"\w*?   
\q1
\v 11 He \w aquí|strong="H2005"\w* \w que|strong="H1992"\w* \w todos|strong="H3605"\w* \w sus|strong="H1992"\w* compañeros \w serán|strong="H1992"\w* avergonzados,  
\q2 porque \w los|strong="H1992"\w* \w artífices|strong="H2796"\w* \w mismos|strong="H1992"\w* son hombres.  
\q1 \w Todos|strong="H3605"\w* \w ellos|strong="H1992"\w* \w se|strong="H1992"\w* juntarán, \w se|strong="H1992"\w* presentarán,  
\q2 \w se|strong="H1992"\w* asombrarán y \w serán|strong="H1992"\w* avergonzados \w a|strong="H3068"\w* una.   
\b  
\q1
\v 12 \w El|strong="H1571"\w* \w herrero|strong="H2796"\w* toma \w la|strong="H1571"\w* tenaza,  
\q2 trabaja en las ascuas, le da forma \w con|strong="H1571"\w* los martillos  
\q2 \w y|strong="H1571"\w* trabaja en ello \w con|strong="H1571"\w* \w la|strong="H1571"\w* \w fuerza|strong="H3581"\w* \w de|strong="H4325"\w* su \w brazo|strong="H2220"\w*;  
\q1 tiene luego \w hambre|strong="H7456"\w*, \w y|strong="H1571"\w* le faltan las \w fuerzas|strong="H3581"\w*;  
\q2 \w no|strong="H3808"\w* \w bebe|strong="H8354"\w* \w agua|strong="H4325"\w*, \w y|strong="H1571"\w* \w se|strong="H3808"\w* desmaya.   
\q1
\v 13 \w El|strong="H6213"\w* carpintero \w tiende|strong="H5186"\w* la regla, \w lo|strong="H6213"\w* \w señala|strong="H8388"\w* con almagre,  
\q2 \w lo|strong="H6213"\w* labra con \w los|strong="H3427"\w* cepillos, \w lo|strong="H6213"\w* \w señala|strong="H8388"\w* con \w el|strong="H6213"\w* compás,  
\q2 le da forma de imagen de hombre, \w a|strong="H3068"\w* semejanza de \w hermoso|strong="H8597"\w* hombre,  
\q2 para tenerlo en \w casa|strong="H1004"\w*.   
\q1
\v 14 Corta cedros, y \w toma|strong="H3947"\w* ciprés y encina,  
\q2 que crecen entre los \w árboles|strong="H6086"\w* del \w bosque|strong="H3293"\w*;  
\q1 planta un pino,  
\q2 que se cría con la \w lluvia|strong="H1653"\w*.   
\q1
\v 15 De \w él|strong="H6213"\w* \w se|strong="H1961"\w* \w sirve|strong="H6213"\w* luego \w el|strong="H6213"\w* hombre \w para|strong="H1961"\w* quemar,  
\q2 \w y|strong="H1197"\w* \w toma|strong="H3947"\w* de \w ellos|strong="H1992"\w* \w para|strong="H1961"\w* calentarse;  
\q2 enciende también \w el|strong="H6213"\w* horno \w para|strong="H1961"\w* cocer \w panes|strong="H3899"\w*;  
\q1 \w hace|strong="H6213"\w* además un dios, \w y|strong="H1197"\w* \w lo|strong="H6213"\w* adora;  
\q2 fabrica un ídolo, \w y|strong="H1197"\w* \w se|strong="H1961"\w* arrodilla delante de \w él|strong="H6213"\w*.   
\q1
\v 16 Quema \w parte|strong="H2677"\w* \w del|strong="H5921"\w* leño \w en|strong="H5921"\w* \w el|strong="H5921"\w* fuego;  
\q2 \w con|strong="H5921"\w* \w parte|strong="H2677"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w* come \w carne|strong="H1320"\w*, adereza un \w asado|strong="H6748"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* sacia;  
\q2 \w después|strong="H5921"\w* \w se|strong="H5921"\w* calienta, \w y|strong="H5921"\w* dice:  
\q1 «¡\w Ah|strong="H1889"\w*! \w Me|strong="H5921"\w* he calentado,  
\q2 he \w visto|strong="H7200"\w* \w el|strong="H5921"\w* fuego».   
\q1
\v 17 \w Y|strong="H3068"\w* \w hace|strong="H6213"\w* del sobrante un dios, un ídolo suyo;  
\q2 se postra delante \w de|strong="H3588"\w* \w él|strong="H3588"\w*, \w lo|strong="H6213"\w* adora \w y|strong="H3588"\w* le \w ruega|strong="H6419"\w*, diciendo:  
\q2 «\w Líbrame|strong="H5337"\w*, \w porque|strong="H3588"\w* mi dios eres \w tú|strong="H6213"\w*».   
\b  
\q1
\v 18 \w No|strong="H3808"\w* \w supieron|strong="H3045"\w* \w ni|strong="H3808"\w* \w entendieron|strong="H7919"\w*;  
\q2 \w porque|strong="H3588"\w* cerrados están sus \w ojos|strong="H5869"\w* \w para|strong="H3588"\w* \w no|strong="H3808"\w* \w ver|strong="H7200"\w*,  
\q2 \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w* \w para|strong="H3588"\w* \w no|strong="H3808"\w* \w entender|strong="H7919"\w*.   
\q1
\v 19 \w No|strong="H3808"\w* \w discurre|strong="H7725"\w* \w para|strong="H5921"\w* \w consigo|strong="H5921"\w*,  
\q2 \w no|strong="H3808"\w* tiene sentido \w ni|strong="H3808"\w* \w entendimiento|strong="H3820"\w* \w para|strong="H5921"\w* decir:  
\q2 «\w Parte|strong="H2677"\w* \w de|strong="H5921"\w* ello quemé \w en|strong="H5921"\w* \w el|strong="H5921"\w* fuego, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* sus \w brasas|strong="H1513"\w* cocí \w pan|strong="H3899"\w*,  
\q2 \w asé|strong="H6740"\w* \w carne|strong="H1320"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* comí.  
\q2 ¿He \w de|strong="H5921"\w* \w hacer|strong="H6213"\w* \w del|strong="H5921"\w* \w resto|strong="H3499"\w* una \w abominación|strong="H8441"\w*?  
\q2 ¿He \w de|strong="H5921"\w* postrarme \w delante|strong="H5921"\w* \w de|strong="H5921"\w* un tronco \w de|strong="H5921"\w* \w árbol|strong="H6086"\w*?».   
\q1
\v 20 De ceniza \w se|strong="H3808"\w* alimenta;  
\q2 su \w corazón|strong="H3820"\w* engañado le desvía,  
\q2 para \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w libre|strong="H5337"\w* su \w alma|strong="H5315"\w*, \w ni|strong="H3808"\w* diga:  
\q2 «¿\w No|strong="H3808"\w* es pura \w mentira|strong="H8267"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* tengo en \w mi|strong="H5315"\w* mano \w derecha|strong="H3225"\w*?».   
\b  
\q1
\v 21 «\w Acuérdate|strong="H2142"\w* \w de|strong="H3588"\w* estas cosas, oh \w Jacob|strong="H3290"\w*,  
\q2 \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w porque|strong="H3588"\w* mi \w siervo|strong="H5650"\w* eres.  
\q1 \w Yo|strong="H3588"\w* \w te|strong="H3588"\w* \w formé|strong="H3335"\w*, \w siervo|strong="H5650"\w* mío eres tú;  
\q2 \w Israel|strong="H3478"\w*, \w no|strong="H3808"\w* \w me|strong="H3588"\w* olvides.   
\q1
\v 22 \w Yo|strong="H3588"\w* deshice \w como|strong="H3588"\w* una \w nube|strong="H6051"\w* tus \w rebeliones|strong="H6588"\w*,  
\q2 \w y|strong="H3588"\w* \w como|strong="H3588"\w* niebla tus \w pecados|strong="H2403"\w*;  
\q2 \w vuélvete|strong="H7725"\w* \w a|strong="H3068"\w* mí, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H3588"\w* \w redimí|strong="H1350"\w*».   
\b  
\q1
\v 23 \w Cantad|strong="H7321"\w* loores, oh \w cielos|strong="H8064"\w*, \w porque|strong="H3588"\w* Yahvé \w lo|strong="H6213"\w* \w hizo|strong="H6213"\w*;  
\q2 \w gritad|strong="H7321"\w* \w con|strong="H3588"\w* júbilo, profundidades \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra;  
\q2 \w prorrumpid|strong="H6476"\w* \w en|strong="H3588"\w* \w alabanza|strong="H7440"\w*, \w montes|strong="H2022"\w*, bosques \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w ellos|strong="H3605"\w* hay;  
\q2 \w porque|strong="H3588"\w* Yahvé \w redimió|strong="H1350"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*,  
\q2 \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w Israel|strong="H3478"\w* \w será|strong="H6213"\w* glorificado.   
\b  
\q1
\v 24 \w Así|strong="H3541"\w* dice Yahvé, \w tu|strong="H6213"\w* \w Redentor|strong="H1350"\w*,  
\q2 \w que|strong="H4325"\w* te \w formó|strong="H3335"\w* desde \w el|strong="H3605"\w* vientre:  
\q1 “\w Yo|strong="H6213"\w* Yahvé, \w que|strong="H4325"\w* \w lo|strong="H6213"\w* \w hago|strong="H6213"\w* \w todo|strong="H3605"\w*,  
\q2 \w que|strong="H4325"\w* despliego solo \w los|strong="H3605"\w* \w cielos|strong="H8064"\w*,  
\q2 \w que|strong="H4325"\w* extiendo \w la|strong="H3605"\w* tierra por mí \w mismo|strong="H3605"\w*;   
\q1
\v 25 que deshago las señales de \w los|strong="H2450"\w* \w adivinos|strong="H7080"\w*,  
\q2 y vuelvo locos \w a|strong="H3068"\w* \w los|strong="H2450"\w* agoreros;  
\q1 que hago \w volver|strong="H7725"\w* atrás \w a|strong="H3068"\w* \w los|strong="H2450"\w* \w sabios|strong="H2450"\w*,  
\q2 y convierto en necedad su \w ciencia|strong="H1847"\w*.   
\q1
\v 26 Yo, \w el|strong="H3427"\w* \w que|strong="H1697"\w* \w despierta|strong="H5892"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* su \w siervo|strong="H5650"\w*,  
\q2 y \w cumple|strong="H7999"\w* \w el|strong="H3427"\w* \w consejo|strong="H6098"\w* \w de|strong="H1697"\w* sus \w mensajeros|strong="H4397"\w*;  
\q1 \w que|strong="H1697"\w* \w dice|strong="H1697"\w* \w a|strong="H3068"\w* Jerusalén: «Serás \w habitada|strong="H3427"\w*»;  
\q2 y \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w*: «Reconstruidas seréis»,  
\q2 y sus ruinas \w levantaré|strong="H6965"\w*.   
\q1
\v 27 Que dice \w a|strong="H3068"\w* las profundidades: «Secaos,  
\q2 y vuestros ríos haré secar»;   
\q1
\v 28 \w que|strong="H3605"\w* dice de \w Ciro|strong="H3566"\w*: «Es \w mi|strong="H3389"\w* pastor, y cumplirá \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* yo quiero»,  
\q2 al decir \w a|strong="H3068"\w* Jerusalén: «Serás \w edificada|strong="H1129"\w*»,  
\q2 y al \w templo|strong="H1964"\w*: «Serán puestos tus \w cimientos|strong="H3245"\w*»».   
\c 45
\p
\v 1 \w Así|strong="H3541"\w* dice Yahvé \w a|strong="H3068"\w* su \w ungido|strong="H4899"\w*, \w a|strong="H3068"\w* \w Ciro|strong="H3566"\w*, \w al|strong="H4428"\w* cual \w tomé|strong="H2388"\w* yo \w por|strong="H6440"\w* su mano \w derecha|strong="H3225"\w*, para sujetar \w naciones|strong="H1471"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él \w y|strong="H3541"\w* desceñir \w lomos|strong="H4975"\w* \w de|strong="H6440"\w* \w reyes|strong="H4428"\w*; para abrir \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él las \w puertas|strong="H1817"\w*, \w y|strong="H3541"\w* las \w puertas|strong="H1817"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* cerrarán:   
\q1
\v 2 “Yo \w iré|strong="H3212"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti,  
\q2 y enderezaré los lugares torcidos;  
\q1 \w quebrantaré|strong="H7665"\w* \w puertas|strong="H1817"\w* \w de|strong="H6440"\w* bronce,  
\q2 y \w cerrojos|strong="H1280"\w* \w de|strong="H6440"\w* \w hierro|strong="H1270"\w* haré pedazos.   
\q1
\v 3 \w Te|strong="H3588"\w* \w daré|strong="H5414"\w* \w los|strong="H3588"\w* \w tesoros|strong="H4301"\w* \w escondidos|strong="H2822"\w*,  
\q2 \w y|strong="H3588"\w* \w los|strong="H3588"\w* secretos muy guardados,  
\q1 \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w sepas|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w el|strong="H3588"\w* \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*,  
\q2 \w que|strong="H3588"\w* \w te|strong="H3588"\w* \w pongo|strong="H5414"\w* \w nombre|strong="H8034"\w*.   
\q1
\v 4 \w Por|strong="H4616"\w* amor de mi \w siervo|strong="H5650"\w* \w Jacob|strong="H3290"\w*, y de \w Israel|strong="H3478"\w* mi escogido,  
\q2 te \w llamé|strong="H7121"\w* \w por|strong="H4616"\w* tu \w nombre|strong="H8034"\w*;  
\q2 te \w puse|strong="H7121"\w* sobrenombre, \w aunque|strong="H3808"\w* \w no|strong="H3808"\w* me conocieses.   
\q1
\v 5 Yo soy Yahvé, y \w ninguno|strong="H3808"\w* \w más|strong="H5750"\w* \w hay|strong="H5750"\w*;  
\q2 \w no|strong="H3808"\w* \w hay|strong="H5750"\w* \w Dios|strong="H3068"\w* \w fuera|strong="H2108"\w* \w de|strong="H5750"\w* mí.  
\q1 Yo te ceñiré\f + \fr 45:5 \ft La Septuaginta y los Rollos del Mar Muerto añaden: dando vista a los ciegos\f*,  
\q2 \w aunque|strong="H3808"\w* tú \w no|strong="H3808"\w* me conocieses,   
\q1
\v 6 \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w se|strong="H3045"\w* \w sepa|strong="H3045"\w* desde \w el|strong="H3588"\w* nacimiento del \w sol|strong="H8121"\w*,  
\q2 \w y|strong="H3588"\w* desde donde \w se|strong="H3045"\w* pone,  
\q1 \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w hay|strong="H5750"\w* \w más|strong="H5750"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w*;  
\q2 \w yo|strong="H3588"\w* soy Yahvé, \w y|strong="H3588"\w* \w ninguno|strong="H5750"\w* \w más|strong="H5750"\w* \w hay|strong="H5750"\w*.   
\q1
\v 7 \w Que|strong="H3605"\w* \w formo|strong="H3335"\w* \w la|strong="H3605"\w* luz  
\q2 y creo las \w tinieblas|strong="H2822"\w*,  
\q1 \w que|strong="H3605"\w* \w hago|strong="H6213"\w* \w la|strong="H3605"\w* \w paz|strong="H7965"\w*  
