\v 8 Ve, \w pues|strong="H6258"\w*, \w ahora|strong="H6258"\w*, \w y|strong="H5921"\w* \w escribe|strong="H3789"\w* esto \w en|strong="H5921"\w* una tabla \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* regístralo \w en|strong="H5921"\w* un \w libro|strong="H5612"\w*, \w para|strong="H5704"\w* \w que|strong="H6258"\w* \w quede|strong="H1961"\w* \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* postrero, \w por|strong="H5921"\w* \w siempre|strong="H5769"\w* \w y|strong="H5921"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.  
\v 9 \w Porque|strong="H3588"\w* \w este|strong="H1931"\w* \w es|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w rebelde|strong="H4805"\w*, \w hijos|strong="H1121"\w* \w mentirosos|strong="H3586"\w*, \w hijos|strong="H1121"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* quisieron \w oír|strong="H8085"\w* \w la|strong="H1931"\w* \w ley|strong="H8451"\w* \w de|strong="H3588"\w* Yahvé;  
\v 10 \w que|strong="H3808"\w* \w dicen|strong="H1696"\w* \w a|strong="H3068"\w* los \w videntes|strong="H2374"\w*: «\w No|strong="H3808"\w* \w veáis|strong="H7200"\w*»; y \w a|strong="H3068"\w* los profetas: «\w No|strong="H3808"\w* nos profeticéis \w lo|strong="H3808"\w* \w que|strong="H3808"\w* es recto, \w decidnos|strong="H1696"\w* cosas halagüeñas, \w profetizad|strong="H2372"\w* \w mentiras|strong="H4123"\w*.  
\v 11 \w Dejad|strong="H5493"\w* el \w camino|strong="H1870"\w*, \w apartaos|strong="H5493"\w* \w de|strong="H4480"\w* la senda, \w quitad|strong="H5493"\w* \w de|strong="H4480"\w* nuestra \w presencia|strong="H6440"\w* \w al|strong="H4480"\w* \w Santo|strong="H6918"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*».  
