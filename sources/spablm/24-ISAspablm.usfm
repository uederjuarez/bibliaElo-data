\q1
\v 11 \w Y|strong="H3068"\w* esos \w perros|strong="H3611"\w* \w son|strong="H3808"\w* comilones, \w nunca|strong="H3808"\w* \w se|strong="H3045"\w* sacian;  
\q2 y \w los|strong="H1992"\w* \w pastores|strong="H7462"\w* \w mismos|strong="H1992"\w* \w no|strong="H3808"\w* \w saben|strong="H3045"\w* entender;  
