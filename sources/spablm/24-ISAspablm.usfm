\v 13 \w por|strong="H2088"\w* \w tanto|strong="H3651"\w*, os \w será|strong="H1961"\w* \w este|strong="H2088"\w* \w pecado|strong="H5771"\w* \w como|strong="H1961"\w* grieta \w que|strong="H1961"\w* amenaza ruina, \w que|strong="H1961"\w* \w se|strong="H1961"\w* abre en un \w muro|strong="H2346"\w* \w alto|strong="H7682"\w*, cuya \w caída|strong="H7667"\w* viene de repente, en un instante.  
\v 14 \w Y|strong="H3068"\w* \w se|strong="H3808"\w* \w quebrará|strong="H7665"\w* como \w se|strong="H3808"\w* quiebra un vaso \w de|strong="H4325"\w* alfarero, \w que|strong="H3808"\w* \w sin|strong="H3808"\w* piedad \w se|strong="H3808"\w* hace pedazos; tanto \w que|strong="H3808"\w* \w entre|strong="H3808"\w* los trozos \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w halla|strong="H4672"\w* \w tiesto|strong="H2789"\w* para traer fuego del hogar, \w o|strong="H3068"\w* para sacar \w agua|strong="H4325"\w* \w de|strong="H4325"\w* la cisterna».   
\p
\v 15 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dijo \w el|strong="H3588"\w* Señor Yahvé, \w el|strong="H3588"\w* \w Santo|strong="H6918"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: «\w En|strong="H3588"\w* \w el|strong="H3588"\w* descanso \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* sosiego \w seréis|strong="H1961"\w* salvos; \w en|strong="H3588"\w* \w la|strong="H3588"\w* quietud \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* confianza \w estará|strong="H1961"\w* \w vuestra|strong="H1961"\w* \w fortaleza|strong="H1369"\w*». \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* quisisteis,  
