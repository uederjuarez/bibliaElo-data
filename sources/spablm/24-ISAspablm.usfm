\q2 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, cantaremos mis cánticos \w con|strong="H5921"\w* instrumentos \w de|strong="H5921"\w* cuerda \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* nuestra \w vida|strong="H2416"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé.   
\p
\v 21 \w E|strong="H3068"\w* \w Isaías|strong="H3470"\w* había dicho: «\w Tomen|strong="H5375"\w* una masa \w de|strong="H5921"\w* \w higos|strong="H8384"\w* \w y|strong="H5921"\w* pónganla \w en|strong="H5921"\w* \w la|strong="H5921"\w* llaga, \w y|strong="H5921"\w* sanará».  
\v 22 Ezequías también \w había|strong="H3588"\w* dicho: «¿\w Qué|strong="H3588"\w* señal tendré \w de|strong="H3588"\w* \w que|strong="H3588"\w* he \w de|strong="H3588"\w* \w subir|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé?».   
\c 39
\p
\v 1 \w En|strong="H3588"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w*, Merodac-baladán \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Baladán, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia, \w envió|strong="H7971"\w* \w cartas|strong="H5612"\w* \w y|strong="H3588"\w* un \w presente|strong="H4503"\w* \w a|strong="H3068"\w* Ezequías; \w porque|strong="H3588"\w* \w había|strong="H3588"\w* \w oído|strong="H8085"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* estado \w enfermo|strong="H2470"\w* \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* convalecido.  
\v 2 \w Y|strong="H3068"\w* \w se|strong="H1961"\w* regocijó \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* Ezequías, \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w mostró|strong="H7200"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su tesoro, \w la|strong="H5921"\w* \w plata|strong="H3701"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w oro|strong="H2091"\w*, \w las|strong="H5921"\w* \w especias|strong="H1314"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w ungüentos|strong="H8081"\w* \w preciosos|strong="H2896"\w*, \w y|strong="H5921"\w* \w toda|strong="H3605"\w* su armería, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w se|strong="H1961"\w* hallaba \w en|strong="H5921"\w* sus tesoros; \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w cosa|strong="H1697"\w* \w en|strong="H5921"\w* su \w casa|strong="H1004"\w* \w ni|strong="H3808"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* su dominio \w que|strong="H3808"\w* Ezequías \w no|strong="H3808"\w* \w les|strong="H5921"\w* mostrase.  
\v 3 Entonces \w el|strong="H5030"\w* \w profeta|strong="H5030"\w* \w Isaías|strong="H3470"\w* \w vino|strong="H4100"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* Ezequías, y le dijo: «¿\w Qué|strong="H4100"\w* dijeron estos hombres, y de dónde han venido \w a|strong="H3068"\w* ti?».  
\p \w Y|strong="H3068"\w* Ezequías respondió: «De tierra muy lejana han venido \w a|strong="H3068"\w* mí, de Babilonia».   
\p
\v 4 Dijo entonces: «¿\w Qué|strong="H4100"\w* han \w visto|strong="H7200"\w* en tu \w casa|strong="H1004"\w*?».  
\p \w Y|strong="H3068"\w* dijo Ezequías: «\w Todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H4100"\w* \w hay|strong="H1961"\w* en \w mi|strong="H1961"\w* \w casa|strong="H1004"\w* han \w visto|strong="H7200"\w*; \w ninguna|strong="H3605"\w* \w cosa|strong="H1697"\w* \w hay|strong="H1961"\w* en mis tesoros \w que|strong="H4100"\w* \w no|strong="H3808"\w* les \w haya|strong="H1961"\w* mostrado».   
\p
\v 5 Entonces dijo \w Isaías|strong="H3470"\w* \w a|strong="H3068"\w* Ezequías: “\w Oye|strong="H8085"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w de|strong="H1697"\w* los \w Ejércitos|strong="H6635"\w*:  
\v 6 «He \w aquí|strong="H2009"\w* vienen \w días|strong="H3117"\w* \w en|strong="H5704"\w* \w que|strong="H3808"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w está|strong="H2088"\w* \w en|strong="H5704"\w* tu \w casa|strong="H1004"\w*, \w y|strong="H5704"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* tus padres atesoraron \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*, \w será|strong="H3808"\w* \w llevado|strong="H5375"\w* \w a|strong="H3068"\w* Babilonia; \w no|strong="H3808"\w* \w quedará|strong="H3498"\w* \w nada|strong="H3808"\w*», \w dice|strong="H1697"\w* Yahvé.  
\v 7 «\w Y|strong="H3068"\w* \w de|strong="H4480"\w* tus \w hijos|strong="H1121"\w* \w que|strong="H4480"\w* \w saldrán|strong="H3318"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, y \w que|strong="H4480"\w* \w engendrarás|strong="H3205"\w*, \w tomarán|strong="H3947"\w*, y \w serán|strong="H1961"\w* \w eunucos|strong="H5631"\w* \w en|strong="H4480"\w* \w el|strong="H1121"\w* palacio \w del|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* Babilonia»».   
\p
\v 8 \w Y|strong="H3068"\w* \w dijo|strong="H1696"\w* Ezequías \w a|strong="H3068"\w* \w Isaías|strong="H3470"\w*: «\w La|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé \w que|strong="H3588"\w* has \w hablado|strong="H1696"\w* \w es|strong="H1961"\w* \w buena|strong="H2896"\w*». \w Y|strong="H3068"\w* añadió: «\w A|strong="H3068"\w* \w lo|strong="H1697"\w* \w menos|strong="H3588"\w* \w haya|strong="H1961"\w* \w paz|strong="H7965"\w* \w y|strong="H3588"\w* seguridad \w en|strong="H3588"\w* mis \w días|strong="H3117"\w*».   
\c 40
\p
\v 1 «Consolad, consolad \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w*», dice vuestro Dios.  
\v 2 «\w Hablad|strong="H1696"\w* \w al|strong="H5921"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* Jerusalén; \w decidle|strong="H1696"\w* \w a|strong="H3068"\w* voces \w que|strong="H3588"\w* \w su|strong="H3588"\w* tiempo \w de|strong="H5921"\w* servicio ha acabado, \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w iniquidad|strong="H5771"\w* \w está|strong="H5921"\w* perdonada, \w y|strong="H3588"\w* \w que|strong="H3588"\w* ya ha recibido \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* Yahvé \w el|strong="H5921"\w* \w doble|strong="H3718"\w* \w por|strong="H5921"\w* \w todos|strong="H3605"\w* sus \w pecados|strong="H2403"\w*».   
\q1
\v 3 \w Voz|strong="H6963"\w* que \w clama|strong="H7121"\w* en el \w desierto|strong="H4057"\w*:  
\q2 «¡Preparad el \w camino|strong="H1870"\w* de Yahvé;  
\q2 \w enderezad|strong="H3474"\w* \w calzada|strong="H4546"\w* en la \w soledad|strong="H4057"\w* para nuestro \w Dios|strong="H3068"\w*!   
\q1
\v 4 \w Todo|strong="H3605"\w* \w valle|strong="H1516"\w* \w sea|strong="H1961"\w* alzado,  
\q2 y bájese \w todo|strong="H3605"\w* \w monte|strong="H2022"\w* y \w collado|strong="H1389"\w*;  
\q2 \w lo|strong="H3605"\w* torcido \w se|strong="H1961"\w* \w enderece|strong="H4334"\w*,  
\q2 y \w lo|strong="H3605"\w* áspero \w se|strong="H1961"\w* \w allane|strong="H1237"\w*.   
\q1
\v 5 \w Y|strong="H3068"\w* \w la|strong="H3588"\w* \w gloria|strong="H3519"\w* \w de|strong="H3588"\w* Yahvé se manifestará,  
\q2 \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* \w juntamente|strong="H3162"\w* \w la|strong="H3588"\w* \w verá|strong="H7200"\w*;  
\q2 \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* Yahvé ha \w hablado|strong="H1696"\w*».   
\b  
\q1
\v 6 \w Voz|strong="H6963"\w* \w que|strong="H4100"\w* decía: «¡Da \w voces|strong="H6963"\w*!».  
\q2 \w Y|strong="H3068"\w* yo respondí: «¿\w Qué|strong="H4100"\w* tengo \w que|strong="H4100"\w* \w decir|strong="H7121"\w* \w a|strong="H3068"\w* \w voces|strong="H6963"\w*?».  
\q1 «\w Que|strong="H4100"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* es \w hierba|strong="H2682"\w*,  
\q2 y \w toda|strong="H3605"\w* su \w gloria|strong="H3605"\w* \w como|strong="H4100"\w* \w la|strong="H3605"\w* flor del \w campo|strong="H7704"\w*.   
\q1
\v 7 \w La|strong="H3588"\w* \w hierba|strong="H2682"\w* \w se|strong="H5971"\w* \w seca|strong="H3001"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* flor \w se|strong="H5971"\w* marchita,  
\q2 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w viento|strong="H7307"\w* \w de|strong="H3588"\w* Yahvé \w sopló|strong="H5380"\w* \w en|strong="H3588"\w* ella;  
\q2 \w ciertamente|strong="H3588"\w* \w como|strong="H3588"\w* \w hierba|strong="H2682"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*.   
\q1
\v 8 \w Sécase|strong="H3001"\w* la \w hierba|strong="H2682"\w*, marchítase la flor;  
\q2 mas la \w palabra|strong="H1697"\w* del Dios nuestro \w permanece|strong="H6965"\w* para \w siempre|strong="H5769"\w*».   
\b  
\q1
\v 9 \w Súbete|strong="H5927"\w* \w sobre|strong="H5921"\w* un \w monte|strong="H2022"\w* \w alto|strong="H1364"\w*, tú \w que|strong="H5921"\w* anuncias buenas nuevas \w a|strong="H3068"\w* \w Sión|strong="H6726"\w*;  
\q2 \w levanta|strong="H7311"\w* \w con|strong="H5921"\w* \w fuerza|strong="H3581"\w* tu \w voz|strong="H6963"\w*, tú \w que|strong="H5921"\w* anuncias buenas nuevas \w a|strong="H3068"\w* Jerusalén;  
\q2 levántala, \w no|strong="H5921"\w* \w temas|strong="H3372"\w*;  
\q2 di \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*: «¡Ved \w aquí|strong="H2009"\w* \w al|strong="H5921"\w* Dios vuestro!».   
\q1
\v 10 He \w aquí|strong="H2009"\w* que el Señor Yahvé vendrá con poder,  
\q2 y su \w brazo|strong="H2220"\w* señoreará;  
\q2 he \w aquí|strong="H2009"\w* que su \w recompensa|strong="H6468"\w* viene con él,  
\q2 y su \w paga|strong="H7939"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* su \w rostro|strong="H6440"\w*.   
\q1
\v 11 Como \w pastor|strong="H7462"\w* \w apacentará|strong="H7462"\w* su rebaño;  
\q2 en su \w brazo|strong="H2220"\w* recogerá los corderos,  
\q2 y en su \w seno|strong="H2436"\w* los \w llevará|strong="H5375"\w*;  
\q2 \w pastoreará|strong="H5095"\w* suavemente \w a|strong="H3068"\w* las recién paridas.   
\b  
\q1
\v 12 ¿\w Quién|strong="H4310"\w* \w midió|strong="H4058"\w* las \w aguas|strong="H4325"\w* con \w el|strong="H4310"\w* hueco \w de|strong="H4325"\w* su mano  
\q2 y los \w cielos|strong="H8064"\w* con su \w palmo|strong="H2239"\w*,  
\q2 con tres dedos juntó \w el|strong="H4310"\w* \w polvo|strong="H6083"\w* \w de|strong="H4325"\w* la \w tierra|strong="H6083"\w*,  
\q2 y \w pesó|strong="H3976"\w* los \w montes|strong="H2022"\w* con balanza  
\q2 y con pesas los \w collados|strong="H1389"\w*?   
\q1
\v 13 ¿\w Quién|strong="H4310"\w* \w enseñó|strong="H8505"\w* al \w Espíritu|strong="H7307"\w* de Yahvé,  
\q2 \w o|strong="H3068"\w* \w le|strong="H4310"\w* aconsejó enseñándole?   
\q1
\v 14 ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* pidió \w consejo|strong="H3289"\w* para ser avisado?  
\q2 ¿\w Quién|strong="H4310"\w* \w le|strong="H4310"\w* \w enseñó|strong="H3925"\w* \w el|strong="H4310"\w* \w camino|strong="H1870"\w* del \w juicio|strong="H4941"\w*,  
\q2 \w o|strong="H3068"\w* \w le|strong="H4310"\w* \w enseñó|strong="H3925"\w* \w ciencia|strong="H1847"\w*,  
\q2 \w o|strong="H3068"\w* \w le|strong="H4310"\w* mostró la senda de la prudencia?   
\q1
\v 15 He \w aquí|strong="H2005"\w* que las \w naciones|strong="H1471"\w* son como una gota de agua que cae del cubo,  
\q2 y como \w menudo|strong="H1851"\w* polvo en las \w balanzas|strong="H3976"\w* son estimadas;  
\q2 he \w aquí|strong="H2005"\w* que hace desaparecer las islas como polvo.   
\q1
\v 16 Ni el \w Líbano|strong="H3844"\w* \w bastará|strong="H1767"\w* para el fuego,  
\q2 ni todos sus \w animales|strong="H2416"\w* para un \w holocausto|strong="H5930"\w*.   
\q1
\v 17 Como \w nada|strong="H3605"\w* son \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* \w él|strong="H3605"\w*;  
\q2 y en su comparación serán estimadas en menos \w que|strong="H3605"\w* \w nada|strong="H3605"\w*, y como \w vanidad|strong="H8414"\w*.   
\b  
\q1
\v 18 ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w*, \w pues|strong="H4100"\w*, haréis semejante \w a|strong="H3068"\w* Dios,  
\q2 \w o|strong="H3068"\w* \w qué|strong="H4100"\w* \w imagen|strong="H1823"\w* \w le|strong="H4310"\w* compondréis?   
\q1
\v 19 El \w artífice|strong="H6884"\w* prepara la \w imagen|strong="H6459"\w* tallada,  
\q2 el platero la cubre de \w oro|strong="H2091"\w*  
\q2 y le funde \w cadenas|strong="H7577"\w* de \w plata|strong="H3701"\w*.   
\q1
\v 20 El pobre elige, para ofrecerle, \w madera|strong="H6086"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* apolille;  
\q2 \w se|strong="H3808"\w* \w busca|strong="H1245"\w* un maestro \w sabio|strong="H2450"\w*, \w que|strong="H3808"\w* le haga una \w imagen|strong="H6459"\w* tallada \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* mueva.   
\b  
\q1
\v 21 ¿\w No|strong="H3808"\w* \w sabéis|strong="H3045"\w*? ¿\w No|strong="H3808"\w* habéis \w oído|strong="H8085"\w*?  
\q2 ¿\w No|strong="H3808"\w* os \w lo|strong="H3808"\w* han dicho desde el principio?  
\q2 ¿\w No|strong="H3808"\w* habéis sido enseñados desde los cimientos de la tierra?   
\q1
\v 22 \w Él|strong="H5921"\w* \w está|strong="H3427"\w* \w sentado|strong="H3427"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* círculo \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra,  
\q2 \w cuyos|strong="H5921"\w* \w moradores|strong="H3427"\w* son \w como|strong="H5921"\w* langostas;  
\q2 \w él|strong="H5921"\w* \w extiende|strong="H5186"\w* \w los|strong="H3427"\w* \w cielos|strong="H8064"\w* \w como|strong="H5921"\w* una cortina,  
\q2 \w los|strong="H3427"\w* despliega \w como|strong="H5921"\w* una tienda \w para|strong="H5921"\w* \w morar|strong="H3427"\w*.   
\q1
\v 23 \w Él|strong="H6213"\w* convierte en nada \w a|strong="H3068"\w* los poderosos,  
\q2 y \w a|strong="H3068"\w* los que gobiernan la tierra \w hace|strong="H6213"\w* como cosa vana.   
\q1
\v 24 \w Como|strong="H1571"\w* \w si|strong="H1571"\w* nunca hubieran sido \w plantados|strong="H5193"\w*, \w como|strong="H1571"\w* \w si|strong="H1571"\w* nunca hubieran sido sembrados,  
\q2 \w como|strong="H1571"\w* \w si|strong="H1571"\w* nunca su tronco hubiera tenido raíz en \w la|strong="H1571"\w* tierra;  
\q2 tan pronto \w como|strong="H1571"\w* sopla en \w ellos|strong="H1571"\w* se secan,  
\q2 \w y|strong="H1571"\w* \w el|strong="H1571"\w* torbellino se los \w lleva|strong="H5375"\w* \w como|strong="H1571"\w* hojarasca.   
\b  
\q1
\v 25 «¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w*, pues, \w me|strong="H4310"\w* haréis semejante \w o|strong="H3068"\w* \w me|strong="H4310"\w* compararéis?»,  
\q2 dice \w el|strong="H4310"\w* \w Santo|strong="H6918"\w*.   
\q1
\v 26 \w Levantad|strong="H5375"\w* \w en|strong="H3318"\w* \w alto|strong="H4791"\w* vuestros \w ojos|strong="H5869"\w*,  
\q2 y \w mirad|strong="H7200"\w* \w quién|strong="H4310"\w* creó estas cosas;  
\q2 \w él|strong="H3605"\w* \w saca|strong="H3318"\w* \w a|strong="H3068"\w* su \w ejército|strong="H6635"\w* \w por|strong="H3581"\w* \w número|strong="H4557"\w*;  
\q2 \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w llama|strong="H7121"\w* \w por|strong="H3581"\w* sus \w nombres|strong="H8034"\w*;  
\q2 \w ninguna|strong="H3605"\w* \w faltará|strong="H5737"\w*; tal es \w la|strong="H3605"\w* grandeza \w de|strong="H5869"\w* su \w fuerza|strong="H3581"\w*,  
\q2 y \w el|strong="H3605"\w* \w poder|strong="H3581"\w* \w de|strong="H5869"\w* su dominio.   
\b  
\q1
\v 27 ¿\w Por|strong="H1870"\w* \w qué|strong="H4100"\w* \w dices|strong="H1696"\w*, \w oh|strong="H4100"\w* \w Jacob|strong="H3290"\w*,  
\q2 y hablas tú, \w Israel|strong="H3478"\w*:  
\q2 «Mi \w camino|strong="H1870"\w* está \w oculto|strong="H5641"\w* \w a|strong="H3068"\w* Yahvé,  
\q2 y de mi \w Dios|strong="H3068"\w* \w pasó|strong="H5674"\w* mi \w juicio|strong="H4941"\w*»?   
\q1
\v 28 ¿\w No|strong="H3808"\w* has sabido, \w no|strong="H3808"\w* has \w oído|strong="H8085"\w*  
\q2 \w que|strong="H3808"\w* el \w Dios|strong="H3068"\w* \w eterno|strong="H5769"\w* es Yahvé,  
\q2 el cual creó los confines de la tierra?  
\q2 \w No|strong="H3808"\w* desfallece, \w ni|strong="H3808"\w* \w se|strong="H3045"\w* fatiga con cansancio,  
\q2 y su \w entendimiento|strong="H8394"\w* \w no|strong="H3808"\w* hay quien \w lo|strong="H3808"\w* alcance.   
\q1
\v 29 Él \w da|strong="H5414"\w* \w esfuerzo|strong="H3581"\w* al cansado,  
\q2 y \w multiplica|strong="H7235"\w* las \w fuerzas|strong="H3581"\w* al \w que|strong="H3581"\w* no tiene ningunas.   
\q1
\v 30 Los muchachos se fatigan y se cansan,  
