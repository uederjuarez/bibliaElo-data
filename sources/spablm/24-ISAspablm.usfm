\q2 \w y|strong="H3588"\w* abracen mi \w pacto|strong="H1285"\w*,   
\q1
\v 5 yo les \w daré|strong="H5414"\w* lugar en mi \w casa|strong="H1004"\w* y dentro \w de|strong="H1121"\w* \w mis|strong="H5414"\w* \w muros|strong="H2346"\w*, y un \w nombre|strong="H8034"\w* \w mejor|strong="H2896"\w* \w que|strong="H3808"\w* \w el|strong="H1121"\w* \w de|strong="H1121"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*;  
\q2 les \w daré|strong="H5414"\w* un \w nombre|strong="H8034"\w* \w eterno|strong="H5769"\w* \w que|strong="H3808"\w* \w nunca|strong="H3808"\w* \w será|strong="H3808"\w* borrado.   
\b  
\q1
\v 6 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w extranjeros|strong="H1121"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* unan \w a|strong="H3068"\w* Yahvé  
