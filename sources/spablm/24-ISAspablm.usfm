\q2 \w y|strong="H5921"\w* habrá \w gozo|strong="H8057"\w* \w perpetuo|strong="H5769"\w* \w sobre|strong="H5921"\w* sus \w cabezas|strong="H7218"\w*;  
\q1 alcanzarán recreo \w y|strong="H5921"\w* \w alegría|strong="H8057"\w*,  
\q2 \w y|strong="H5921"\w* huirán \w la|strong="H5921"\w* \w tristeza|strong="H3015"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* gemido.   
\c 36
\p
\v 1 \w Aconteció|strong="H1961"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* catorce \w del|strong="H5921"\w* \w rey|strong="H4428"\w* Ezequías, \w que|strong="H5921"\w* Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, \w subió|strong="H5927"\w* \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w tomó|strong="H8610"\w*.  
\v 2 \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* de Asiria \w envió|strong="H7971"\w* \w al|strong="H4428"\w* \w Rabsaces|strong="H7262"\w* desde Laquis \w a|strong="H3068"\w* Jerusalén, \w al|strong="H4428"\w* \w rey|strong="H4428"\w* Ezequías, con un gran \w ejército|strong="H2426"\w*; y él se situó junto \w al|strong="H4428"\w* acueducto del \w estanque|strong="H1295"\w* superior, \w en|strong="H5975"\w* la \w calzada|strong="H4546"\w* del \w Campo|strong="H7704"\w* del Batanero.  
\v 3 \w Y|strong="H3068"\w* \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* recibirle Eliaquim \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Jilquías, \w mayordomo|strong="H5921"\w* \w de|strong="H5921"\w* palacio, \w y|strong="H5921"\w* \w Sebna|strong="H7644"\w*, \w secretario|strong="H5608"\w*, \w y|strong="H5921"\w* Joa \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Asaf, \w canciller|strong="H2142"\w*.   
\p
\v 4 \w A|strong="H3068"\w* los cuales dijo el \w Rabsaces|strong="H7262"\w*: “Decid \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* Ezequías: «\w Así|strong="H3541"\w* dice el \w gran|strong="H1419"\w* \w rey|strong="H4428"\w*, el \w rey|strong="H4428"\w* de Asiria: ¿\w Qué|strong="H4100"\w* confianza \w es|strong="H2088"\w* \w esta|strong="H2088"\w* en \w que|strong="H4100"\w* te apoyas?  
\v 5 \w Yo|strong="H3588"\w* digo \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w consejo|strong="H6098"\w* \w y|strong="H3588"\w* poder \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w* \w no|strong="H3588"\w* \w son|strong="H3588"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w palabras|strong="H1697"\w* vanas. ¿\w En|strong="H5921"\w* \w quién|strong="H4310"\w* confías \w ahora|strong="H6258"\w*, \w que|strong="H3588"\w* \w te|strong="H5921"\w* has rebelado \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*?  
\v 6 He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* confías \w en|strong="H5921"\w* \w el|strong="H5921"\w* báculo \w de|strong="H5921"\w* \w esta|strong="H2088"\w* \w caña|strong="H7070"\w* \w cascada|strong="H7533"\w*, \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w*; \w en|strong="H5921"\w* \w la|strong="H5921"\w* cual, \w si|strong="H2009"\w* alguien \w se|strong="H5921"\w* apoyare, \w se|strong="H5921"\w* \w le|strong="H5921"\w* entrará \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3709"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* atravesará. \w Tal|strong="H3651"\w* \w es|strong="H2088"\w* \w Faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w para|strong="H5921"\w* \w con|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w en|strong="H5921"\w* \w él|strong="H5921"\w* \w confían|strong="H5564"\w*.  
\v 7 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w me|strong="H3588"\w* decís: \w En|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w* confiamos; ¿\w no|strong="H3808"\w* \w es|strong="H1931"\w* \w este|strong="H2088"\w* \w aquel|strong="H1931"\w* \w cuyos|strong="H1931"\w* lugares \w altos|strong="H1116"\w* \w y|strong="H3588"\w* \w cuyos|strong="H1931"\w* \w altares|strong="H4196"\w* hizo \w quitar|strong="H5493"\w* Ezequías, diciendo \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Jerusalén: \w Delante|strong="H6440"\w* \w de|strong="H3588"\w* \w este|strong="H2088"\w* \w altar|strong="H4196"\w* \w adoraréis|strong="H7812"\w*?».  
\v 8 \w Ahora|strong="H6258"\w* \w pues|strong="H4994"\w*, haced apuesta \w con|strong="H5921"\w* \w mi|strong="H5921"\w* señor \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, \w y|strong="H5921"\w* \w yo|strong="H4994"\w* \w os|strong="H5921"\w* \w daré|strong="H5414"\w* dos mil \w caballos|strong="H5483"\w*, \w si|strong="H4994"\w* vosotros podéis \w dar|strong="H5414"\w* jinetes \w que|strong="H6258"\w* \w los|strong="H5921"\w* monten.  
\v 9 ¿\w Cómo|strong="H5921"\w* pues podréis resistir \w a|strong="H3068"\w* un solo \w capitán|strong="H6346"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w menores|strong="H6996"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w siervos|strong="H5650"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* señor, aunque confiéis \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w por|strong="H5921"\w* sus \w carros|strong="H7393"\w* \w y|strong="H5921"\w* \w jinetes|strong="H6571"\w*?  
\v 10 ¿Acaso he \w subido|strong="H5927"\w* yo \w ahora|strong="H6258"\w* \w sin|strong="H1107"\w* Yahvé \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* tierra \w para|strong="H5921"\w* destruirla? Yahvé \w me|strong="H5921"\w* dijo: \w Sube|strong="H5927"\w* \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* tierra \w y|strong="H5921"\w* destrúyela”».   
\p
\v 11 \w Entonces|strong="H3588"\w* \w dijeron|strong="H1696"\w* Eliaquim, \w Sebna|strong="H7644"\w* \w y|strong="H3588"\w* Joa \w al|strong="H5921"\w* \w Rabsaces|strong="H7262"\w*: «\w Te|strong="H5921"\w* rogamos \w que|strong="H3588"\w* \w hables|strong="H1696"\w* \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w* \w en|strong="H5921"\w* arameo, \w porque|strong="H3588"\w* \w nosotros|strong="H5921"\w* \w lo|strong="H5921"\w* entendemos; \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w hables|strong="H1696"\w* \w con|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w en|strong="H5921"\w* lengua judaica \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w*».   
\p
\v 12 Pero \w el|strong="H5921"\w* \w Rabsaces|strong="H7262"\w* \w dijo|strong="H1696"\w*: «¿Acaso \w me|strong="H5921"\w* \w ha|strong="H3808"\w* \w enviado|strong="H7971"\w* \w mi|strong="H5921"\w* señor \w a|strong="H3068"\w* decir estas \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* tu señor \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* hombres \w que|strong="H3808"\w* \w están|strong="H3427"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w*, condenados \w a|strong="H3068"\w* comer su propio estiércol \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w beber|strong="H8354"\w* su propia orina \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*?».  
\v 13 Entonces el \w Rabsaces|strong="H7262"\w* se \w puso|strong="H5975"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* y \w gritó|strong="H7121"\w* \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w* \w en|strong="H5975"\w* lengua judaica, diciendo: “¡\w Oíd|strong="H8085"\w* las \w palabras|strong="H1697"\w* del \w gran|strong="H1419"\w* \w rey|strong="H4428"\w*, el \w rey|strong="H4428"\w* \w de|strong="H1697"\w* Asiria!  
\v 14 \w Así|strong="H3541"\w* dice \w el|strong="H3588"\w* \w rey|strong="H4428"\w*: «\w No|strong="H3808"\w* os \w engañe|strong="H5377"\w* Ezequías, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* os \w podrá|strong="H3201"\w* \w librar|strong="H5337"\w*.  
\v 15 \w Ni|strong="H3808"\w* os \w haga|strong="H5414"\w* Ezequías confiar en Yahvé, diciendo: \w Ciertamente|strong="H5414"\w* Yahvé nos \w librará|strong="H5337"\w*; \w no|strong="H3808"\w* \w será|strong="H3808"\w* \w entregada|strong="H5414"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* en \w manos|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Asiria».  
\v 16 \w No|strong="H6213"\w* \w escuchéis|strong="H8085"\w* \w a|strong="H3068"\w* Ezequías; \w porque|strong="H3588"\w* \w así|strong="H3541"\w* dice \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Asiria: «\w Haced|strong="H6213"\w* \w la|strong="H3588"\w* \w paz|strong="H1293"\w* \w conmigo|strong="H6213"\w* \w y|strong="H3588"\w* \w salid|strong="H3318"\w* \w a|strong="H3068"\w* mí; \w y|strong="H3588"\w* coma cada uno \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w viña|strong="H1612"\w* \w y|strong="H3588"\w* cada uno \w de|strong="H3588"\w* \w su|strong="H3588"\w* higuera, \w y|strong="H3588"\w* beba cada \w cual|strong="H3588"\w* las \w aguas|strong="H4325"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* cisterna;  
\v 17 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* yo venga \w y|strong="H5704"\w* \w os|strong="H5704"\w* lleve \w a|strong="H3068"\w* una tierra \w como|strong="H5704"\w* la vuestra, tierra \w de|strong="H5704"\w* \w grano|strong="H1715"\w* \w y|strong="H5704"\w* \w de|strong="H5704"\w* \w vino|strong="H8492"\w*, tierra \w de|strong="H5704"\w* \w pan|strong="H3899"\w* \w y|strong="H5704"\w* \w de|strong="H5704"\w* \w viñas|strong="H3754"\w*.  
\v 18 Guardaos de \w que|strong="H6435"\w* \w no|strong="H6435"\w* os engañe Ezequías \w diciendo|strong="H5496"\w*: Yahvé nos \w librará|strong="H5337"\w*. ¿Acaso \w libraron|strong="H5337"\w* los dioses de las \w naciones|strong="H1471"\w* cada uno su tierra de la \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* de Asiria?  
\v 19 ¿Dónde están \w los|strong="H3588"\w* dioses \w de|strong="H3588"\w* Hamat \w y|strong="H3588"\w* \w de|strong="H3588"\w* Arpad? ¿Dónde están \w los|strong="H3588"\w* dioses \w de|strong="H3588"\w* Sefarvaim? ¿\w Libraron|strong="H5337"\w* acaso \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w* \w de|strong="H3588"\w* mi \w mano|strong="H3027"\w*?  
\v 20 ¿\w Quién|strong="H4310"\w* \w de|strong="H3588"\w* \w entre|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* dioses \w de|strong="H3588"\w* estas tierras ha \w librado|strong="H5337"\w* \w su|strong="H3588"\w* país \w de|strong="H3588"\w* \w mi|strong="H3389"\w* \w mano|strong="H3027"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* Yahvé \w libre|strong="H5337"\w* \w a|strong="H3068"\w* Jerusalén \w de|strong="H3588"\w* \w mi|strong="H3389"\w* \w mano|strong="H3027"\w*?»».   
\p
\v 21 \w Pero|strong="H3588"\w* \w ellos|strong="H1931"\w* callaron, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w le|strong="H1931"\w* \w respondieron|strong="H6030"\w* \w palabra|strong="H1697"\w*; \w porque|strong="H3588"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w así|strong="H3588"\w* \w lo|strong="H1931"\w* \w había|strong="H3588"\w* mandado, \w diciendo|strong="H4687"\w*: «\w No|strong="H3808"\w* \w le|strong="H1931"\w* \w respondáis|strong="H6030"\w*».   
\p
\v 22 Entonces Eliaquim \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Jilquías, \w mayordomo|strong="H5921"\w* \w de|strong="H5921"\w* palacio, \w y|strong="H5921"\w* \w Sebna|strong="H7644"\w*, \w secretario|strong="H5608"\w*, \w y|strong="H5921"\w* Joa \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Asaf, \w canciller|strong="H2142"\w*, \w vinieron|strong="H5046"\w* \w a|strong="H3068"\w* Ezequías \w con|strong="H5921"\w* sus vestiduras rasgadas, \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w contaron|strong="H1697"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w del|strong="H5921"\w* \w Rabsaces|strong="H7262"\w*.   
\c 37
\p
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H1961"\w*, \w cuando|strong="H1961"\w* el \w rey|strong="H4428"\w* Ezequías lo \w oyó|strong="H8085"\w*, \w rasgó|strong="H7167"\w* sus vestiduras, \w se|strong="H1961"\w* \w cubrió|strong="H3680"\w* de cilicio y entró en la \w casa|strong="H1004"\w* de Yahvé.  
\v 2 \w Y|strong="H3068"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Eliaquim, \w mayordomo|strong="H5921"\w* \w de|strong="H5921"\w* palacio, \w a|strong="H3068"\w* \w Sebna|strong="H7644"\w*, \w secretario|strong="H5608"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, \w cubiertos|strong="H3680"\w* \w de|strong="H5921"\w* cilicio, \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Isaías|strong="H3470"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz.  
\v 3 \w Y|strong="H3068"\w* le dijeron: «\w Así|strong="H3541"\w* dice Ezequías: \w Este|strong="H2088"\w* \w día|strong="H3117"\w* \w es|strong="H2088"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w angustia|strong="H6869"\w*, \w de|strong="H3588"\w* \w reprensión|strong="H8433"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* blasfemia; \w porque|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* han llegado \w al|strong="H5704"\w* punto \w de|strong="H3588"\w* nacer, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w que|strong="H3588"\w* da \w a|strong="H3068"\w* luz \w no|strong="H3588"\w* tiene \w fuerzas|strong="H3581"\w*.  
\v 4 Quizá \w oirá|strong="H8085"\w* Yahvé vuestro \w Dios|strong="H3068"\w* las \w palabras|strong="H1697"\w* del \w Rabsaces|strong="H7262"\w*, \w al|strong="H4428"\w* cual el \w rey|strong="H4428"\w* \w de|strong="H1697"\w* Asiria, su \w señor|strong="H3068"\w*, \w envió|strong="H7971"\w* para blasfemar \w al|strong="H4428"\w* \w Dios|strong="H3068"\w* \w vivo|strong="H2416"\w*, y para vituperar con las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* Yahvé vuestro \w Dios|strong="H3068"\w* ha \w oído|strong="H8085"\w*; \w eleva|strong="H5375"\w*, \w pues|strong="H7971"\w*, \w oración|strong="H8605"\w* \w por|strong="H1157"\w* el remanente \w que|strong="H1697"\w* aún queda».   
\p
\v 5 Vinieron, pues, los \w siervos|strong="H5650"\w* del \w rey|strong="H4428"\w* Ezequías \w a|strong="H3068"\w* \w Isaías|strong="H3470"\w*.   
\p
\v 6 \w e|strong="H3068"\w* \w Isaías|strong="H3470"\w* les dijo: “Decid \w así|strong="H3541"\w* \w a|strong="H3068"\w* vuestro \w señor|strong="H3068"\w*: «\w Así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé: \w No|strong="H6440"\w* \w temas|strong="H3372"\w* \w por|strong="H1697"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* has \w oído|strong="H8085"\w*, con las cuales \w me|strong="H3541"\w* han blasfemado los siervos del \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Asiria.  
\v 7 He \w aquí|strong="H2005"\w* que yo \w pondré|strong="H5414"\w* en \w él|strong="H5307"\w* un \w espíritu|strong="H7307"\w*, y \w oirá|strong="H8085"\w* un \w rumor|strong="H8052"\w*, y \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* su propia tierra; y yo \w haré|strong="H5414"\w* que en su tierra \w caiga|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*»».   
\p
\v 8 \w Vuelto|strong="H7725"\w*, \w pues|strong="H3588"\w*, \w el|strong="H5921"\w* \w Rabsaces|strong="H7262"\w*, \w halló|strong="H4672"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria \w combatiendo|strong="H3898"\w* \w contra|strong="H5921"\w* \w Libna|strong="H3841"\w*; \w porque|strong="H3588"\w* ya \w había|strong="H4672"\w* \w oído|strong="H8085"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* \w había|strong="H4672"\w* apartado \w de|strong="H5921"\w* Laquis.  
\v 9 \w Y|strong="H3068"\w* \w oyó|strong="H8085"\w* \w decir|strong="H8085"\w* \w de|strong="H5921"\w* Tirhaca, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Etiopía|strong="H3568"\w*: «Ha \w salido|strong="H3318"\w* \w para|strong="H5921"\w* hacerte \w guerra|strong="H3898"\w*». \w Y|strong="H3068"\w* \w al|strong="H5921"\w* oírlo, \w envió|strong="H7971"\w* \w embajadores|strong="H4397"\w* \w a|strong="H3068"\w* Ezequías, diciendo:  
\v 10 “Diréis \w así|strong="H3541"\w* \w a|strong="H3068"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*: «\w No|strong="H3808"\w* te \w engañe|strong="H5377"\w* tu Dios en quien confías, diciendo: Jerusalén \w no|strong="H3808"\w* \w será|strong="H3808"\w* \w entregada|strong="H5414"\w* en \w manos|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Asiria.  
\v 11 He \w aquí|strong="H2009"\w* \w que|strong="H3605"\w* \w tú|strong="H6213"\w* has \w oído|strong="H8085"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* han \w hecho|strong="H6213"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de Asiria \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las tierras, destruyéndolas \w por|strong="H4428"\w* completo; ¿y escaparás \w tú|strong="H6213"\w*?  
\v 12 ¿Acaso \w libraron|strong="H5337"\w* sus dioses \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w* \w que|strong="H1121"\w* mis padres \w destruyeron|strong="H7843"\w*, \w a|strong="H3068"\w* \w Gozán|strong="H1470"\w*, \w Harán|strong="H2771"\w*, Rezef y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Edén \w que|strong="H1121"\w* moraban en Telasar?  
\v 13 ¿Dónde está el \w rey|strong="H4428"\w* de Hamat, el \w rey|strong="H4428"\w* de Arpad, el \w rey|strong="H4428"\w* de la \w ciudad|strong="H5892"\w* de Sefarvaim, de Hena y de Ivá?»».   
\p
\v 14 \w Tomó|strong="H3947"\w* Ezequías la \w carta|strong="H5612"\w* \w de|strong="H6440"\w* \w mano|strong="H3027"\w* \w de|strong="H6440"\w* los \w embajadores|strong="H4397"\w* y la \w leyó|strong="H7121"\w*; y \w subió|strong="H5927"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* Yahvé, y la \w extendió|strong="H6566"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.  
\v 15 Entonces Ezequías \w oró|strong="H6419"\w* \w a|strong="H3068"\w* Yahvé, diciendo:  
\v 16 «Yahvé de \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w*, \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*, \w que|strong="H1931"\w* \w moras|strong="H3427"\w* entre \w los|strong="H3427"\w* \w querubines|strong="H3742"\w*, \w solo|strong="H1931"\w* \w tú|strong="H6213"\w* \w eres|strong="H1931"\w* \w Dios|strong="H3068"\w* de \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w reinos|strong="H4467"\w* de \w la|strong="H1931"\w* tierra; \w tú|strong="H6213"\w* \w hiciste|strong="H6213"\w* \w los|strong="H3427"\w* \w cielos|strong="H8064"\w* y \w la|strong="H1931"\w* tierra.  
\v 17 \w Inclina|strong="H5186"\w*, oh Yahvé, tu \w oído|strong="H8085"\w* y \w oye|strong="H8085"\w*; \w abre|strong="H6491"\w*, oh Yahvé, tus \w ojos|strong="H5869"\w* y \w mira|strong="H7200"\w*; y \w oye|strong="H8085"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* Senaquerib, \w que|strong="H1697"\w* ha \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* blasfemar al \w Dios|strong="H3068"\w* \w vivo|strong="H2416"\w*.  
\v 18 Ciertamente, oh Yahvé, \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de Asiria \w destruyeron|strong="H2717"\w* \w todas|strong="H3605"\w* las naciones y sus tierras,  
\v 19 \w y|strong="H3588"\w* entregaron \w los|strong="H1992"\w* dioses \w de|strong="H3588"\w* \w ellos|strong="H1992"\w* al fuego; \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w eran|strong="H3808"\w* dioses, \w sino|strong="H3588"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* hombres, \w madera|strong="H6086"\w* \w y|strong="H3588"\w* piedra; \w por|strong="H3588"\w* eso \w los|strong="H1992"\w* destruyeron.  
\v 20 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, Yahvé \w Dios|strong="H3068"\w* nuestro, \w líbranos|strong="H3467"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reinos|strong="H4467"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w sepan|strong="H3045"\w* \w que|strong="H3588"\w* solo tú eres Yahvé».   
\p
\v 21 Entonces \w Isaías|strong="H3470"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amoz \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Ezequías: “\w Así|strong="H3541"\w* dice Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: Respecto \w a|strong="H3068"\w* lo \w que|strong="H1121"\w* \w me|strong="H3541"\w* \w rogaste|strong="H6419"\w* acerca \w de|strong="H1121"\w* Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Asiria,  
\v 22 \w esta|strong="H2088"\w* \w es|strong="H2088"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w que|strong="H5921"\w* Yahvé \w habló|strong="H1696"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w*: \w La|strong="H5921"\w* \w virgen|strong="H1330"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Sión|strong="H6726"\w* \w te|strong="H5921"\w* menosprecia, \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w se|strong="H5921"\w* mofa; tras \w de|strong="H5921"\w* \w ti|strong="H5921"\w* mueve su \w cabeza|strong="H7218"\w* \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* Jerusalén.  
\v 23 ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* vituperaste \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w quién|strong="H4310"\w* \w blasfemaste|strong="H1442"\w*? ¿\w Contra|strong="H5921"\w* \w quién|strong="H4310"\w* has alzado tu \w voz|strong="H6963"\w* \w y|strong="H5921"\w* levantado \w en|strong="H5921"\w* \w alto|strong="H7311"\w* tus \w ojos|strong="H5869"\w*? \w Contra|strong="H5921"\w* \w el|strong="H5921"\w* \w Santo|strong="H6918"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
