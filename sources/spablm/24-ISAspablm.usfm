\q1
\v 30 \w Y|strong="H3068"\w* bramarán \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w como|strong="H5921"\w* bramido \w del|strong="H5921"\w* \w mar|strong="H3220"\w*;  
\q2 \w entonces|strong="H3117"\w* \w mirará|strong="H5027"\w* \w hacia|strong="H5921"\w* \w la|strong="H1931"\w* tierra, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w tinieblas|strong="H2822"\w* \w de|strong="H5921"\w* \w tribulación|strong="H6862"\w*,  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w sus|strong="H1931"\w* \w cielos|strong="H6183"\w* \w se|strong="H1931"\w* oscurecerá \w la|strong="H1931"\w* luz.   
\c 6
\p
\v 1 \w El|strong="H5921"\w* \w año|strong="H8141"\w* \w en|strong="H5921"\w* \w que|strong="H5921"\w* murió \w el|strong="H5921"\w* \w rey|strong="H4428"\w* Uzías, \w vi|strong="H7200"\w* yo \w al|strong="H5921"\w* Señor \w sentado|strong="H3427"\w* \w sobre|strong="H5921"\w* un \w trono|strong="H3678"\w* \w alto|strong="H7311"\w* \w y|strong="H5921"\w* sublime, \w y|strong="H5921"\w* \w las|strong="H5921"\w* faldas \w de|strong="H5921"\w* su manto llenaban \w el|strong="H5921"\w* \w templo|strong="H1964"\w*.  
\v 2 \w Por|strong="H6440"\w* \w encima|strong="H4605"\w* \w de|strong="H6440"\w* él \w había|strong="H5975"\w* \w serafines|strong="H8314"\w*; cada uno tenía \w seis|strong="H8337"\w* \w alas|strong="H3671"\w*; con \w dos|strong="H8147"\w* \w cubrían|strong="H3680"\w* sus \w rostros|strong="H6440"\w*, con \w dos|strong="H8147"\w* \w cubrían|strong="H3680"\w* sus \w pies|strong="H7272"\w*, y con \w dos|strong="H8147"\w* \w volaban|strong="H5774"\w*.  
\v 3 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* uno al \w otro|strong="H2088"\w* daba voces, diciendo:  
\q1 «¡\w Santo|strong="H6918"\w*, \w santo|strong="H6918"\w*, \w santo|strong="H6918"\w* \w es|strong="H2088"\w* Yahvé de \w los|strong="H3605"\w* \w Ejércitos|strong="H6635"\w*!  
\q2 ¡\w Toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w está|strong="H2088"\w* \w llena|strong="H4393"\w* de su \w gloria|strong="H3519"\w*!».   
\p
\v 4 \w Y|strong="H3068"\w* los quiciales de las puertas se estremecieron con la \w voz|strong="H6963"\w* del que clamaba, y la \w casa|strong="H1004"\w* se \w llenó|strong="H4390"\w* de \w humo|strong="H6227"\w*.  
\v 5 \w Entonces|strong="H3588"\w* dije: «¡Ay \w de|strong="H3588"\w* mí! \w Que|strong="H3588"\w* muerto soy; \w porque|strong="H3588"\w* siendo hombre \w inmundo|strong="H2931"\w* \w de|strong="H3588"\w* \w labios|strong="H8193"\w*, \w y|strong="H3588"\w* habitando \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* tiene \w labios|strong="H8193"\w* \w inmundos|strong="H2931"\w*, han \w visto|strong="H7200"\w* mis \w ojos|strong="H5869"\w* \w al|strong="H4428"\w* \w Rey|strong="H4428"\w*, Yahvé \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w*».   
\p
\v 6 \w Y|strong="H3068"\w* voló \w hacia|strong="H5921"\w* \w mí|strong="H5921"\w* uno \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w serafines|strong="H8314"\w*, teniendo \w en|strong="H5921"\w* su \w mano|strong="H3027"\w* un carbón encendido, \w tomado|strong="H3947"\w* \w del|strong="H4480"\w* \w altar|strong="H4196"\w* \w con|strong="H5921"\w* unas tenazas;  
\v 7 \w y|strong="H5921"\w* tocando \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w boca|strong="H6310"\w*, dijo: «He \w aquí|strong="H2088"\w* \w que|strong="H5921"\w* \w esto|strong="H2088"\w* ha tocado tus \w labios|strong="H8193"\w*, \w y|strong="H5921"\w* \w es|strong="H2088"\w* quitada tu culpa, \w y|strong="H5921"\w* limpio tu \w pecado|strong="H2403"\w*».   
\p
\v 8 Después \w oí|strong="H8085"\w* la \w voz|strong="H6963"\w* del Señor, \w que|strong="H4310"\w* decía: «¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* \w enviaré|strong="H7971"\w*, y \w quién|strong="H4310"\w* \w irá|strong="H3212"\w* por nosotros?».  
\p Entonces respondí: «Heme \w aquí|strong="H2005"\w*, \w envíame|strong="H7971"\w* \w a|strong="H3068"\w* mí».   
\p
\v 9 \w Y|strong="H3068"\w* dijo: “\w Anda|strong="H3212"\w*, y di \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*:  
\q1 ‘\w Oíd|strong="H8085"\w* \w bien|strong="H7200"\w*, y no entendáis;  
\q2 \w ved|strong="H7200"\w* \w por|strong="H2088"\w* cierto, mas no \w comprendáis|strong="H3045"\w*’.   
\q1
\v 10 Embotad el \w corazón|strong="H3820"\w* \w de|strong="H5971"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*,  
\q2 y \w haced|strong="H8085"\w* pesados sus \w oídos|strong="H8085"\w*, y cerrad sus \w ojos|strong="H5869"\w*,  
\q1 \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* \w vea|strong="H7200"\w* con sus \w ojos|strong="H5869"\w*, y \w oiga|strong="H8085"\w* con sus \w oídos|strong="H8085"\w*,  
\q2 y su \w corazón|strong="H3820"\w* \w entienda|strong="H8085"\w*, y \w se|strong="H5971"\w* convierta, y haya \w para|strong="H5971"\w* él sanidad”.   
\p
\v 11 \w Y|strong="H3068"\w* yo dije: «¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w*, Señor?».  
\p \w Y|strong="H3068"\w* respondió \w él|strong="H3427"\w*:  
\q1 «\w Hasta|strong="H5704"\w* \w que|strong="H5704"\w* las \w ciudades|strong="H5892"\w* estén \w asoladas|strong="H8077"\w* \w y|strong="H5704"\w* sin \w morador|strong="H3427"\w*,  
\q2 \w y|strong="H5704"\w* no haya hombre \w en|strong="H5704"\w* las \w casas|strong="H1004"\w*,  
\q2 \w y|strong="H5704"\w* la tierra esté hecha un desierto;  
\v 12 hasta que Yahvé haya alejado \w a|strong="H3068"\w* los hombres,  
\q2 y multiplicado los lugares abandonados en \w medio|strong="H7130"\w* de la tierra.   
\q1
\v 13 \w Y|strong="H3068"\w* \w si|strong="H1961"\w* quedare \w aún|strong="H5750"\w* \w en|strong="H5750"\w* ella una décima parte,  
\q2 \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* ser devastada;  
\q1 \w mas|strong="H5750"\w* \w como|strong="H1961"\w* el terebinto \w y|strong="H1197"\w* \w la|strong="H1197"\w* encina, \w que|strong="H1961"\w* al ser cortados conservan su tronco,  
\q2 así \w la|strong="H1197"\w* \w simiente|strong="H2233"\w* \w santa|strong="H6944"\w* \w será|strong="H1961"\w* su tronco».   
\c 7
\p
\v 1 \w Aconteció|strong="H1961"\w* \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Acaz \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Jotam, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Uzías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w que|strong="H3808"\w* \w Rezín|strong="H7526"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria \w y|strong="H5921"\w* \w Peka|strong="H6492"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Remalías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w subieron|strong="H5927"\w* \w contra|strong="H5921"\w* Jerusalén \w para|strong="H5921"\w* combatirla; pero \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* \w tomarla|strong="H3898"\w*.  
\v 2 \w Y|strong="H3068"\w* vino \w el|strong="H5921"\w* \w aviso|strong="H5046"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*, diciendo: «Siria \w se|strong="H5921"\w* ha aliado \w con|strong="H5921"\w* Efraín». \w Y|strong="H3068"\w* \w se|strong="H5921"\w* \w le|strong="H5921"\w* estremeció \w el|strong="H5921"\w* \w corazón|strong="H3824"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w corazón|strong="H3824"\w* \w de|strong="H5921"\w* su \w pueblo|strong="H5971"\w*, \w como|strong="H5921"\w* \w se|strong="H5921"\w* estremecen \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* \w del|strong="H5921"\w* \w monte|strong="H3293"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w del|strong="H5921"\w* \w viento|strong="H7307"\w*.   
\p
\v 3 Entonces dijo Yahvé \w a|strong="H3068"\w* \w Isaías|strong="H3470"\w*: “\w Sal|strong="H3318"\w* \w ahora|strong="H4994"\w* al encuentro \w de|strong="H1121"\w* Acaz, tú, y Sear-jasub tu \w hijo|strong="H1121"\w*, al \w extremo|strong="H7097"\w* del \w conducto|strong="H8585"\w* del \w estanque|strong="H1295"\w* superior, \w en|strong="H3318"\w* \w el|strong="H1121"\w* \w camino|strong="H4546"\w* \w de|strong="H1121"\w* la \w heredad|strong="H7704"\w* del batanero.  
\v 4 \w Y|strong="H3068"\w* dile: ‘\w Guardaos|strong="H8104"\w* y tened \w reposo|strong="H8252"\w*; no \w temáis|strong="H3372"\w*, ni se os desanime \w el|strong="H1121"\w* \w corazón|strong="H3824"\w* \w a|strong="H3068"\w* causa \w de|strong="H1121"\w* estos \w dos|strong="H8147"\w* \w cabos|strong="H2180"\w* \w de|strong="H1121"\w* tizones \w que|strong="H1121"\w* humean, por \w el|strong="H1121"\w* ardor \w de|strong="H1121"\w* \w la|strong="H8104"\w* ira \w de|strong="H1121"\w* \w Rezín|strong="H7526"\w* y \w de|strong="H1121"\w* Siria, y del \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Remalías.  
\v 5 \w Por|strong="H5921"\w* \w cuanto|strong="H3588"\w* Siria ha acordado \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w con|strong="H5921"\w* Efraín \w y|strong="H3588"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Remalías, diciendo:  
\v 6 «\w Subamos|strong="H5927"\w* contra \w Judá|strong="H3063"\w* y aterroricémosla, y repartámosla \w entre|strong="H8432"\w* nosotros, y pongamos \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* ella \w por|strong="H4428"\w* \w rey|strong="H4428"\w* \w al|strong="H4428"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Tabeel|strong="H2870"\w*»’.  
\v 7 El Señor Yahvé dice \w así|strong="H3541"\w*: «\w No|strong="H3808"\w* \w subsistirá|strong="H6965"\w*, \w ni|strong="H3808"\w* \w será|strong="H1961"\w*».  
\v 8 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* \w cabeza|strong="H7218"\w* \w de|strong="H3588"\w* Siria \w es|strong="H3588"\w* \w Damasco|strong="H1834"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w cabeza|strong="H7218"\w* \w de|strong="H3588"\w* \w Damasco|strong="H1834"\w*, \w Rezín|strong="H7526"\w*; \w y|strong="H3588"\w* dentro \w de|strong="H3588"\w* \w sesenta|strong="H8346"\w* \w y|strong="H3588"\w* \w cinco|strong="H2568"\w* \w años|strong="H8141"\w* Efraín será quebrantado hasta dejar \w de|strong="H3588"\w* ser \w pueblo|strong="H5971"\w*.  
\v 9 \w Y|strong="H3068"\w* \w la|strong="H3588"\w* \w cabeza|strong="H7218"\w* \w de|strong="H3588"\w* Efraín \w es|strong="H3588"\w* \w Samaria|strong="H8111"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w cabeza|strong="H7218"\w* \w de|strong="H3588"\w* \w Samaria|strong="H8111"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Remalías. \w Si|strong="H3588"\w* vosotros \w no|strong="H3808"\w* creyereis, \w de|strong="H3588"\w* \w cierto|strong="H3588"\w* \w no|strong="H3808"\w* permaneceréis’”.   
\p
\v 10 \w Habló|strong="H1696"\w* \w más|strong="H3254"\w* Yahvé \w a|strong="H3068"\w* Acaz, \w diciendo|strong="H1696"\w*:  
\v 11 «\w Pide|strong="H7592"\w* \w para|strong="H5973"\w* \w ti|strong="H5973"\w* señal \w de|strong="H5973"\w* Yahvé tu \w Dios|strong="H3068"\w*, \w demandándola|strong="H7585"\w* ya sea \w de|strong="H5973"\w* lo profundo, \w o|strong="H3068"\w* \w de|strong="H5973"\w* lo \w alto|strong="H4605"\w*».   
\p
\v 12 \w Y|strong="H3068"\w* respondió Acaz: «\w No|strong="H3808"\w* \w pediré|strong="H7592"\w*, y \w no|strong="H3808"\w* \w tentaré|strong="H5254"\w* \w a|strong="H3068"\w* Yahvé».   
\p
\v 13 Dijo \w entonces|strong="H3588"\w* Isaías: “\w Oíd|strong="H8085"\w* \w ahora|strong="H4994"\w*, \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w David|strong="H1732"\w*. ¿\w Os|strong="H4480"\w* \w es|strong="H3588"\w* \w poco|strong="H4592"\w* \w el|strong="H3588"\w* ser molestos \w a|strong="H3068"\w* \w los|strong="H3588"\w* hombres, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w también|strong="H1571"\w* lo seáis \w a|strong="H3068"\w* \w mi|strong="H4994"\w* Dios?  
\v 14 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w el|strong="H1931"\w* Señor \w mismo|strong="H1931"\w* os \w dará|strong="H5414"\w* señal: He \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* virgen \w concebirá|strong="H2030"\w* y \w dará|strong="H5414"\w* \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, y \w llamará|strong="H7121"\w* \w su|strong="H1931"\w* \w nombre|strong="H8034"\w* Emanuel. \f + \fr 7:14 \ft «Emanuel» significa «Dios con nosotros».\f*  
\v 15 Comerá leche cuajada y \w miel|strong="H1706"\w*, para \w que|strong="H3045"\w* \w sepa|strong="H3045"\w* \w desechar|strong="H3988"\w* lo \w malo|strong="H7451"\w* y escoger lo \w bueno|strong="H2896"\w*.  
\v 16 \w Porque|strong="H3588"\w* \w antes|strong="H6440"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w niño|strong="H5288"\w* \w sepa|strong="H3045"\w* \w desechar|strong="H3988"\w* lo \w malo|strong="H7451"\w* \w y|strong="H3588"\w* escoger lo \w bueno|strong="H2896"\w*, \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w dos|strong="H8147"\w* \w reyes|strong="H4428"\w* \w que|strong="H3588"\w* tú aborreces será \w abandonada|strong="H5800"\w*.  
\v 17 Yahvé traerá \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w sobre|strong="H5921"\w* tu \w pueblo|strong="H5971"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* tu padre, \w días|strong="H3117"\w* cuales \w nunca|strong="H3808"\w* vinieron \w desde|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w que|strong="H3808"\w* Efraín \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, esto es, \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria”.   
\p
\v 18 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* \w que|strong="H1931"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w silbará|strong="H8319"\w* Yahvé \w a|strong="H3068"\w* \w la|strong="H1931"\w* mosca \w que|strong="H1931"\w* \w está|strong="H1931"\w* en \w el|strong="H1931"\w* fin de \w los|strong="H1931"\w* \w ríos|strong="H2975"\w* de \w Egipto|strong="H4714"\w*, y \w a|strong="H3068"\w* \w la|strong="H1931"\w* abeja \w que|strong="H1931"\w* \w está|strong="H1931"\w* en \w la|strong="H1931"\w* tierra de Asiria.  
\v 19 \w Y|strong="H3068"\w* vendrán y posarán \w todas|strong="H3605"\w* en \w los|strong="H3605"\w* valles desiertos, y en las cavernas de las piedras, y en \w todos|strong="H3605"\w* \w los|strong="H3605"\w* zarzales, y en \w todos|strong="H3605"\w* \w los|strong="H3605"\w* pastizales.   
\p
\v 20 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* Señor \w raerá|strong="H1548"\w* \w con|strong="H1571"\w* \w navaja|strong="H8593"\w* alquilada, \w con|strong="H1571"\w* \w los|strong="H1931"\w* \w que|strong="H1931"\w* habitan \w al|strong="H4428"\w* otro \w lado|strong="H5676"\w* del \w río|strong="H5104"\w*, \w esto|strong="H1931"\w* \w es|strong="H1931"\w*, \w con|strong="H1571"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de Asiria, \w la|strong="H1931"\w* \w cabeza|strong="H7218"\w* \w y|strong="H1571"\w* \w los|strong="H1931"\w* pelos de \w los|strong="H1931"\w* \w pies|strong="H7272"\w*, \w y|strong="H1571"\w* \w aun|strong="H1571"\w* \w la|strong="H1931"\w* \w barba|strong="H2206"\w* \w también|strong="H1571"\w* \w quitará|strong="H5595"\w*.   
\p
\v 21 \w Acontecerá|strong="H1961"\w* en \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w*, \w que|strong="H1931"\w* criará un hombre una vaca joven \w y|strong="H1241"\w* \w dos|strong="H8147"\w* \w ovejas|strong="H6629"\w*;  
\v 22 \w y|strong="H3588"\w* \w será|strong="H1961"\w* \w que|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3605"\w* \w abundancia|strong="H7230"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* \w leche|strong="H2461"\w* \w que|strong="H3588"\w* \w darán|strong="H6213"\w*, comerá \w leche|strong="H2461"\w* cuajada; \w porque|strong="H3588"\w* \w leche|strong="H2461"\w* cuajada \w y|strong="H3588"\w* \w miel|strong="H1706"\w* comerá \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w quede|strong="H1961"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* tierra.   
\p
\v 23 \w Acontecera|strong="H1961"\w* también en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \w había|strong="H1961"\w* mil \w vides|strong="H1612"\w* \w que|strong="H1931"\w* valían mil siclos de \w plata|strong="H3701"\w*,\f + \fr 7:23 \ft Un siclo equivale a unos 10 gramos o unas 0,35 onzas, por lo que 1000 siclos equivalen a unos 10 kilogramos o 22 libras.\f* \w será|strong="H1961"\w* \w para|strong="H1961"\w* \w los|strong="H3605"\w* \w espinos|strong="H8068"\w* y \w los|strong="H3605"\w* \w cardos|strong="H8068"\w*.  
\v 24 \w Con|strong="H3588"\w* saetas \w y|strong="H3588"\w* \w arco|strong="H7198"\w* irán \w allá|strong="H8033"\w*, \w porque|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w será|strong="H1961"\w* \w espinos|strong="H8068"\w* \w y|strong="H3588"\w* \w cardos|strong="H8068"\w*.  
\v 25 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w montes|strong="H2022"\w* \w que|strong="H3808"\w* \w se|strong="H1961"\w* cavaban con azada, \w no|strong="H3808"\w* llegaréis \w allá|strong="H8033"\w* por \w el|strong="H3605"\w* \w temor|strong="H3374"\w* de \w los|strong="H3605"\w* \w espinos|strong="H8068"\w* \w y|strong="H7794"\w* de \w los|strong="H3605"\w* \w cardos|strong="H8068"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w servirán|strong="H1961"\w* \w para|strong="H1961"\w* pasto de \w bueyes|strong="H7794"\w* \w y|strong="H7794"\w* \w para|strong="H1961"\w* ser pisoteados por las ovejas.   
\c 8
\p
\v 1 \w Me|strong="H5921"\w* dijo Yahvé: “\w Toma|strong="H3947"\w* una tablilla \w grande|strong="H1419"\w* \w y|strong="H5921"\w* \w escribe|strong="H3789"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w con|strong="H5921"\w* \w estilo|strong="H2747"\w* \w de|strong="H5921"\w* hombre: ‘Perteneciente \w a|strong="H3068"\w* Maher-salal-has-baz’”; \f + \fr 8:1 \ft «Maher-salal-has-baz» significa «el despojo se apresura, la presa se precipita».\f*  
\v 2 y tomé conmigo \w testigos|strong="H5707"\w* fieles para dar \w testimonio|strong="H5707"\w*: al \w sacerdote|strong="H3548"\w* Urías y \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jeberequías.   
\p
\v 3 \w Y|strong="H3068"\w* me llegué \w a|strong="H3068"\w* la \w profetisa|strong="H5031"\w*, la cual \w concibió|strong="H2029"\w* y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*. \w Y|strong="H3068"\w* me dijo Yahvé: “\w Ponle|strong="H7121"\w* por \w nombre|strong="H8034"\w* Maher-salal-has-baz.  
\v 4 \w Porque|strong="H3588"\w* \w antes|strong="H6440"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w niño|strong="H5288"\w* \w sepa|strong="H3045"\w* \w decir|strong="H7121"\w* ‘padre mío’ \w y|strong="H3588"\w* ‘madre mía’, serán quitadas las \w riquezas|strong="H2428"\w* \w de|strong="H3588"\w* \w Damasco|strong="H1834"\w* \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w despojos|strong="H7998"\w* \w de|strong="H3588"\w* \w Samaria|strong="H8111"\w* \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Asiria”.   
\p
\v 5 \w Otra|strong="H5750"\w* vez \w volvió|strong="H3254"\w* Yahvé \w a|strong="H3068"\w* hablarme, \w diciendo|strong="H1696"\w*:  
\v 6 «\w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w desechó|strong="H3988"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* las \w aguas|strong="H4325"\w* \w de|strong="H3588"\w* Siloé \w que|strong="H3588"\w* corren mansamente, \w y|strong="H3588"\w* \w se|strong="H5971"\w* regocijó \w con|strong="H3588"\w* \w Rezín|strong="H7526"\w* \w y|strong="H3588"\w* \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Remalías;  
\v 7 he \w aquí|strong="H2009"\w*, \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w que|strong="H5921"\w* \w el|strong="H5921"\w* Señor hace \w subir|strong="H5927"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w aguas|strong="H4325"\w* \w de|strong="H5921"\w* ríos, \w fuertes|strong="H6099"\w* \w y|strong="H5921"\w* \w muchas|strong="H7227"\w*, \w esto|strong="H3651"\w* es, \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria \w con|strong="H5921"\w* \w toda|strong="H3605"\w* su \w gloria|strong="H3519"\w*; \w el|strong="H5921"\w* cual \w subirá|strong="H5927"\w* \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* sus cauces, \w y|strong="H5921"\w* \w pasará|strong="H1980"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* sus riberas.  
\v 8 \w Y|strong="H3068"\w* \w pasando|strong="H5674"\w* \w por|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w inundará|strong="H7857"\w* \w y|strong="H5704"\w* \w pasará|strong="H5674"\w* \w adelante|strong="H5704"\w*, \w y|strong="H5704"\w* \w llegará|strong="H5060"\w* \w hasta|strong="H5704"\w* \w el|strong="H5674"\w* \w cuello|strong="H6677"\w*; \w y|strong="H5704"\w* la extensión \w de|strong="H5704"\w* sus \w alas|strong="H3671"\w* \w llenará|strong="H4393"\w* la \w anchura|strong="H7341"\w* \w de|strong="H5704"\w* tu tierra, oh Emanuel.   
\p
\v 9 ¡Reuníos, \w pueblos|strong="H5971"\w*, y seréis \w quebrantados|strong="H2865"\w*! Escuchad, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H5971"\w* venís \w de|strong="H5971"\w* lejanas tierras: ¡ceñíos y sed destrozados! ¡Preparaos \w para|strong="H5971"\w* \w la|strong="H3605"\w* batalla y sed destrozados!  
\v 10 Tomad \w consejo|strong="H6098"\w*, \w y|strong="H3588"\w* \w será|strong="H3808"\w* \w anulado|strong="H6565"\w*; haced planes, \w y|strong="H3588"\w* \w no|strong="H3808"\w* subsistirán, \w porque|strong="H3588"\w* Dios \w está|strong="H6965"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*».   
\p
\v 11 \w Porque|strong="H3588"\w* Yahvé \w me|strong="H3588"\w* dijo \w de|strong="H3588"\w* \w esta|strong="H2088"\w* manera \w con|strong="H3588"\w* \w mano|strong="H3027"\w* fuerte, \w y|strong="H3588"\w* \w me|strong="H3588"\w* enseñó \w que|strong="H3588"\w* \w no|strong="H3588"\w* caminase \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, diciendo:  
\v 12 «\w No|strong="H3808"\w* llaméis conspiración \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H3808"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* llama conspiración; \w ni|strong="H3808"\w* \w temáis|strong="H3372"\w* \w lo|strong="H2088"\w* \w que|strong="H3808"\w* \w ellos|strong="H3605"\w* \w temen|strong="H3372"\w*, \w ni|strong="H3808"\w* tengáis \w miedo|strong="H3372"\w*.  
\v 13 \w A|strong="H3068"\w* Yahvé de \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w*, \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w santificad|strong="H6942"\w*; sea \w él|strong="H1931"\w* vuestro \w temor|strong="H4172"\w*, y \w él|strong="H1931"\w* sea vuestro miedo.  
\v 14 Entonces \w él|strong="H3427"\w* \w será|strong="H1961"\w* por \w santuario|strong="H4720"\w*; pero \w a|strong="H3068"\w* las \w dos|strong="H8147"\w* \w casas|strong="H1004"\w* de \w Israel|strong="H3478"\w* por piedra de \w tropiezo|strong="H4383"\w* y por \w roca|strong="H6697"\w* de caída, y al \w morador|strong="H3427"\w* de Jerusalén por \w lazo|strong="H6341"\w* y por red.  
\v 15 \w Y|strong="H3068"\w* \w muchos|strong="H7227"\w* \w tropezarán|strong="H3782"\w* entre ellos, y \w caerán|strong="H5307"\w*, y serán quebrantados; y se enredarán y serán apresados».   
\p
\v 16 \w Ata|strong="H6887"\w* el testimonio, \w sella|strong="H2856"\w* la \w ley|strong="H8451"\w* entre mis discípulos.  
\v 17 \w Esperaré|strong="H6960"\w*, pues, \w a|strong="H3068"\w* Yahvé, el cual \w escondió|strong="H5641"\w* su \w rostro|strong="H6440"\w* \w de|strong="H6440"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w Jacob|strong="H3290"\w*, y en él confiaré.  
\v 18 He \w aquí|strong="H2009"\w*, \w yo|strong="H2009"\w* y \w los|strong="H5973"\w* \w hijos|strong="H3206"\w* que \w me|strong="H5973"\w* \w dio|strong="H5414"\w* Yahvé somos \w por|strong="H5414"\w* señales y \w prodigios|strong="H4159"\w* \w en|strong="H5973"\w* \w Israel|strong="H3478"\w*, \w de|strong="H5973"\w* parte \w de|strong="H5973"\w* Yahvé \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w Ejércitos|strong="H6635"\w* que \w mora|strong="H7931"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w monte|strong="H2022"\w* \w Sión|strong="H6726"\w*.   
\p
\v 19 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* os dijeren: «\w Preguntad|strong="H1875"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* evocadores \w de|strong="H3588"\w* espíritus \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w adivinos|strong="H3049"\w*, \w que|strong="H3588"\w* pían \w y|strong="H3588"\w* susurran», responded: ¿\w No|strong="H3808"\w* \w consultará|strong="H1875"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* Dios? ¿\w Consultará|strong="H1875"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w muertos|strong="H4191"\w* \w por|strong="H3588"\w* \w los|strong="H3588"\w* \w vivos|strong="H2416"\w*?  
\v 20 ¡\w A|strong="H3068"\w* la \w ley|strong="H8451"\w* y al testimonio! \w Si|strong="H3808"\w* \w no|strong="H3808"\w* dijeren conforme \w a|strong="H3068"\w* \w esto|strong="H2088"\w*, \w es|strong="H2088"\w* \w porque|strong="H3808"\w* \w no|strong="H3808"\w* les \w ha|strong="H3808"\w* amanecido.  
\v 21 \w Y|strong="H3068"\w* \w pasarán|strong="H5674"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* tierra fatigados \w y|strong="H3588"\w* \w hambrientos|strong="H7457"\w*, \w y|strong="H3588"\w* \w acontecerá|strong="H1961"\w* \w que|strong="H3588"\w* teniendo \w hambre|strong="H7456"\w*, \w se|strong="H1961"\w* enfurecerán \w y|strong="H3588"\w* maldecirán \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w rey|strong="H4428"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* Dios, \w levantando|strong="H6437"\w* \w el|strong="H3588"\w* rostro \w en|strong="H3588"\w* \w alto|strong="H4605"\w*.  
\v 22 \w Y|strong="H3068"\w* mirarán \w a|strong="H3068"\w* la tierra, y he \w aquí|strong="H2009"\w* \w tribulación|strong="H6869"\w* y tinieblas, \w oscuridad|strong="H4588"\w* y \w angustia|strong="H6869"\w*; y serán sumidos en las tinieblas.   
\c 9
\p
\v 1 \w Mas|strong="H5921"\w* \w no|strong="H5921"\w* habrá \w siempre|strong="H5921"\w* \w oscuridad|strong="H2822"\w* \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H5921"\w* \w está|strong="H3427"\w* ahora \w en|strong="H5921"\w* angustia, tal \w como|strong="H5921"\w* \w la|strong="H5921"\w* aflicción \w que|strong="H5921"\w* \w le|strong="H5921"\w* \w vino|strong="H1980"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* tiempo \w en|strong="H5921"\w* \w que|strong="H5921"\w* livianamente tocaron \w la|strong="H5921"\w* primera vez \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Zabulón \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Neftalí; \w pues|strong="H7200"\w* \w al|strong="H5921"\w* fin llenará \w de|strong="H5921"\w* gloria \w el|strong="H5921"\w* \w camino|strong="H1980"\w* \w del|strong="H5921"\w* mar, \w al|strong="H5921"\w* otro lado \w del|strong="H5921"\w* Jordán, \w en|strong="H5921"\w* Galilea \w de|strong="H5921"\w* \w los|strong="H3427"\w* gentiles.   
\p
\v 2 El pueblo \w que|strong="H3808"\w* andaba en tinieblas vio \w gran|strong="H7235"\w* luz;  
\q2 los \w que|strong="H3808"\w* moraban en tierra \w de|strong="H6440"\w* sombra \w de|strong="H6440"\w* muerte, luz resplandeció sobre ellos.   
\q1
\v 3 Multiplicaste \w la|strong="H3588"\w* gente,  
\q2 \w y|strong="H3588"\w* aumentaste \w la|strong="H3588"\w* alegría.  
\p Se alegrarán delante \w de|strong="H3588"\w* ti según \w la|strong="H3588"\w* alegría \w de|strong="H3588"\w* \w la|strong="H3588"\w* siega, \w como|strong="H3588"\w* se gozan \w los|strong="H3588"\w* hombres \w cuando|strong="H3588"\w* reparten \w el|strong="H3588"\w* botín.  
\v 4 \w Porque|strong="H3588"\w* tú rompiste \w el|strong="H3588"\w* yugo \w de|strong="H3588"\w* \w su|strong="H3588"\w* carga, \w y|strong="H3588"\w* \w la|strong="H3605"\w* vara \w de|strong="H3588"\w* \w su|strong="H3588"\w* hombro, \w y|strong="H3588"\w* \w el|strong="H3588"\w* cetro \w de|strong="H3588"\w* \w su|strong="H3588"\w* opresor, \w como|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* día \w de|strong="H3588"\w* Madián.  
\v 5 \w Porque|strong="H3588"\w* todo calzado \w que|strong="H3588"\w* calza \w el|strong="H5921"\w* guerrero \w en|strong="H5921"\w* \w el|strong="H5921"\w* estrépito \w de|strong="H5921"\w* \w la|strong="H5921"\w* batalla, \w y|strong="H3588"\w* \w los|strong="H1121"\w* mantos revolcados \w en|strong="H5921"\w* sangre, \w serán|strong="H1961"\w* quemados, pasto \w del|strong="H5921"\w* fuego.  
\v 6 \w Porque|strong="H5921"\w* un niño \w nos|strong="H5921"\w* \w es|strong="H2063"\w* nacido, hijo \w nos|strong="H5921"\w* \w es|strong="H2063"\w* dado, \w y|strong="H5921"\w* \w el|strong="H5921"\w* principado \w sobre|strong="H5921"\w* su hombro; \w y|strong="H5921"\w* \w se|strong="H5921"\w* llamará su nombre Admirable, Consejero, \w Dios|strong="H3068"\w* Fuerte, Padre \w Eterno|strong="H5769"\w*, Príncipe \w de|strong="H5921"\w* \w Paz|strong="H7965"\w*.  
\v 7 \w Lo|strong="H1697"\w* dilatado \w de|strong="H1697"\w* su imperio y la paz no tendrán límite, sobre \w el|strong="H5307"\w* trono \w de|strong="H1697"\w* David y sobre su reino, disponiéndolo y confirmándolo en juicio y en justicia desde ahora y para siempre. \w El|strong="H5307"\w* celo \w de|strong="H1697"\w* Yahvé \w de|strong="H1697"\w* los Ejércitos hará \w esto|strong="H1697"\w*.   
\p
\v 8 \w El|strong="H3605"\w* Señor envió palabra \w a|strong="H3068"\w* Jacob,  
\q2 y cayó en Israel.   
\q1
\v 9 \w Y|strong="H3068"\w* la sabrá todo \w el|strong="H5307"\w* pueblo,  
\q2 Efraín y los moradores de Samaria, que con soberbia y con altivez de corazón dicen:   
\q1
\v 10 «\w Los|strong="H5921"\w* ladrillos cayeron,  
\q2 \w mas|strong="H5921"\w* edificaremos \w de|strong="H5921"\w* cantería;  
\q1 cortaron \w los|strong="H5921"\w* cabrahigos,  
\q2 \w mas|strong="H5921"\w* \w en|strong="H5921"\w* su lugar pondremos cedros».   
\q1
\v 11 Pero Yahvé levantará \w a|strong="H3068"\w* \w los|strong="H3605"\w* adversarios \w de|strong="H5750"\w* Rezín \w contra|strong="H3478"\w* \w él|strong="H3605"\w*,  
\q2 y juntará \w a|strong="H3068"\w* sus enemigos;   
\q2
\v 12 los sirios \w por|strong="H5704"\w* el oriente \w y|strong="H5704"\w* los filisteos \w por|strong="H5704"\w* el occidente;  
\q2 \w y|strong="H5704"\w* \w a|strong="H3068"\w* boca llena devorarán \w a|strong="H3068"\w* Israel.  
\q1 \w Ni|strong="H3808"\w* \w con|strong="H5704"\w* todo eso \w se|strong="H3808"\w* \w ha|strong="H3808"\w* aplacado su ira,  
\q2 \w sino|strong="H3808"\w* \w que|strong="H3808"\w* su mano todavía está extendida.   
\b  
\q1
\v 13 Pero el pueblo no se convirtió al \w que|strong="H3117"\w* lo hería,  
\q2 ni buscaron \w a|strong="H3068"\w* Yahvé de los Ejércitos.   
\q1
\v 14 \w Y|strong="H3068"\w* Yahvé cortará \w de|strong="H6440"\w* Israel \w cabeza|strong="H7218"\w* y \w cola|strong="H2180"\w*,  
\q2 rama y junco en un \w mismo|strong="H1931"\w* día.   
\q1
\v 15 El anciano y venerable \w de|strong="H5971"\w* rostro \w es|strong="H1961"\w* la cabeza,  
\q2 y el profeta \w que|strong="H5971"\w* enseña mentira \w es|strong="H1961"\w* la cola.   
\q1
\v 16 \w Porque|strong="H3588"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* guían \w a|strong="H3068"\w* \w este|strong="H2063"\w* pueblo \w son|strong="H3588"\w* engañadores,  
\q2 \w y|strong="H3588"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w por|strong="H5921"\w* \w ellos|strong="H3027"\w* \w son|strong="H3588"\w* guiados, \w son|strong="H3588"\w* perdidos.   
\q1
\v 17 \w Por|strong="H3588"\w* tanto, \w el|strong="H3588"\w* Señor \w no|strong="H3588"\w* tomará contentamiento \w en|strong="H3588"\w* sus jóvenes,  
\q2 ni \w de|strong="H3588"\w* sus huérfanos \w y|strong="H3588"\w* viudas tendrá misericordia;  
\q1 \w porque|strong="H3588"\w* todos \w son|strong="H3588"\w* falsos \w y|strong="H3588"\w* malhechores,  
\q2 \w y|strong="H3588"\w* toda boca habla necedades.  
\q1 Ni \w con|strong="H3588"\w* todo eso se ha aplacado \w su|strong="H3588"\w* ira,  
\q2 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* mano todavía está extendida.   
\b  
\q1
\v 18 \w Porque|strong="H3808"\w* la maldad \w se|strong="H1961"\w* encendió \w como|strong="H1961"\w* fuego,  
\q2 cardos y espinos devorará;  
\q2 y \w se|strong="H1961"\w* encenderá en \w lo|strong="H3808"\w* espeso del bosque,  
\q2 y \w serán|strong="H1961"\w* alzados \w como|strong="H1961"\w* remolinos \w de|strong="H5971"\w* humo.   
\q1
\v 19 \w Por|strong="H5921"\w* \w la|strong="H5921"\w* ira \w de|strong="H5921"\w* Yahvé \w de|strong="H5921"\w* \w los|strong="H5921"\w* Ejércitos \w se|strong="H5921"\w* oscureció \w la|strong="H5921"\w* tierra,  
\q2 \w y|strong="H5921"\w* \w será|strong="H3808"\w* \w el|strong="H5921"\w* pueblo \w como|strong="H5921"\w* pasto \w del|strong="H5921"\w* fuego;  
\q2 \w el|strong="H5921"\w* hombre \w no|strong="H3808"\w* tendrá piedad \w de|strong="H5921"\w* su hermano.   
\q1
\v 20 \w Cada|strong="H3605"\w* uno hurtará \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* derecha, \w y|strong="H5921"\w* tendrá hambre,  
\q2 \w y|strong="H5921"\w* comerá \w a|strong="H3068"\w* \w la|strong="H5921"\w* izquierda, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* saciará;  
\q1 \w cada|strong="H3605"\w* cual comerá \w la|strong="H5921"\w* carne \w de|strong="H5921"\w* \w su|strong="H1992"\w* propio brazo:   
\q2
\v 21 Manasés \w a|strong="H3068"\w* Efraín, y Efraín \w a|strong="H3068"\w* Manasés, y ambos contra Judá.  
\q1 Ni con todo eso se ha aplacado su ira,  
\q2 sino que su mano todavía está extendida.   
\c 10
\p
\v 1 ¡\w Ay|strong="H1945"\w* de los que decretan leyes injustas, y de los escribas que dictan decretos opresivos,  
\v 2 \w para|strong="H1961"\w* apartar del \w juicio|strong="H4941"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* necesitados, y \w para|strong="H1961"\w* quitar el \w derecho|strong="H4941"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w pobres|strong="H1800"\w* \w de|strong="H5971"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*; \w para|strong="H1961"\w* hacer \w de|strong="H5971"\w* las viudas su botín, y despojar \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w huérfanos|strong="H3490"\w*!  
\v 3 ¿\w Y|strong="H3068"\w* \w qué|strong="H4100"\w* \w haréis|strong="H6213"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w del|strong="H5921"\w* castigo, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* desolación \w que|strong="H4100"\w* vendrá \w de|strong="H5921"\w* lejos? ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* \w os|strong="H5921"\w* acogeréis \w para|strong="H5921"\w* \w que|strong="H4100"\w* \w os|strong="H5921"\w* ayude, \w y|strong="H5921"\w* \w dónde|strong="H5921"\w* \w dejaréis|strong="H5800"\w* vuestra \w gloria|strong="H3519"\w*?   
\p
\v 4 \w Sin|strong="H3808"\w* \w mí|strong="H1115"\w* \w no|strong="H3808"\w* queda \w sino|strong="H3808"\w* encorvarse \w entre|strong="H3808"\w* \w los|strong="H3605"\w* presos,  
\q2 y \w caer|strong="H5307"\w* \w entre|strong="H3808"\w* \w los|strong="H3605"\w* muertos.  
\q1 Con \w todo|strong="H3605"\w* \w esto|strong="H2063"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* aplacado su ira,  
\q2 \w sino|strong="H3808"\w* \w que|strong="H3808"\w* su \w mano|strong="H3027"\w* \w todavía|strong="H5750"\w* \w está|strong="H2063"\w* \w extendida|strong="H5186"\w*.   
\b  
\p
\v 5 ¡\w Ay|strong="H1945"\w* de Asiria, \w vara|strong="H4294"\w* y bastón de mi \w furor|strong="H2195"\w*! En \w su|strong="H1931"\w* \w mano|strong="H3027"\w* he puesto mi indignación.  
\v 6 \w Le|strong="H5921"\w* \w enviaré|strong="H7971"\w* \w contra|strong="H5921"\w* una \w nación|strong="H1471"\w* pérfida, \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* ira \w le|strong="H5921"\w* daré \w mando|strong="H6680"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* quite \w despojos|strong="H7998"\w*, \w y|strong="H5921"\w* arrebate botín, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* huelle \w como|strong="H5921"\w* lodo \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w*.  
