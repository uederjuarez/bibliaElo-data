\q1
\v 26 Sus \w puertas|strong="H6607"\w* se lamentarán y llorarán;  
\q2 y ella, desolada, se sentará en tierra.   
\c 4
\p
\v 1 Echarán \w mano|strong="H1931"\w* \w de|strong="H5921"\w* un \w solo|strong="H1931"\w* hombre \w siete|strong="H7651"\w* mujeres \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w*, diciendo: «Nuestro \w pan|strong="H3899"\w* comeremos, \w y|strong="H5921"\w* \w nos|strong="H5921"\w* vestiremos \w de|strong="H5921"\w* nuestras propias \w ropas|strong="H8071"\w*; \w tan|strong="H1931"\w* \w solo|strong="H1931"\w* déjanos llevar tu \w nombre|strong="H8034"\w*, quita nuestra \w afrenta|strong="H2781"\w*».   
\p
\v 2 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* \w renuevo|strong="H6780"\w* de Yahvé \w será|strong="H1961"\w* \w para|strong="H1961"\w* \w hermosura|strong="H6643"\w* \w y|strong="H3519"\w* \w gloria|strong="H3519"\w*, \w y|strong="H3519"\w* \w el|strong="H1931"\w* \w fruto|strong="H6529"\w* de \w la|strong="H1931"\w* tierra \w para|strong="H1961"\w* \w grandeza|strong="H3519"\w* \w y|strong="H3519"\w* \w honra|strong="H3519"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* sobrevivientes de \w Israel|strong="H3478"\w*.  
\v 3 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* \w que|strong="H1961"\w* \w el|strong="H3605"\w* \w que|strong="H1961"\w* \w quedare|strong="H7604"\w* en \w Sión|strong="H6726"\w*, y \w el|strong="H3605"\w* \w que|strong="H1961"\w* \w fuere|strong="H1961"\w* dejado en Jerusalén, \w será|strong="H1961"\w* llamado \w santo|strong="H6918"\w*; \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H1961"\w* en Jerusalén \w estén|strong="H1961"\w* inscritos entre \w los|strong="H3605"\w* \w vivientes|strong="H2416"\w*,  
\v 4 cuando el Señor hubiere lavado \w la|strong="H1197"\w* inmundicia \w de|strong="H1818"\w* las \w hijas|strong="H1323"\w* \w de|strong="H1818"\w* \w Sión|strong="H6726"\w*, \w y|strong="H1197"\w* limpiado \w la|strong="H1197"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* Jerusalén \w de|strong="H1818"\w* en \w medio|strong="H7130"\w* \w de|strong="H1818"\w* ella, con \w espíritu|strong="H7307"\w* \w de|strong="H1818"\w* \w juicio|strong="H4941"\w* \w y|strong="H1197"\w* con \w espíritu|strong="H7307"\w* \w de|strong="H1818"\w* fuego.  
\v 5 \w Y|strong="H3068"\w* creará Yahvé \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* morada \w del|strong="H5921"\w* \w monte|strong="H2022"\w* \w Sión|strong="H6726"\w*, \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* sus \w asambleas|strong="H4744"\w*, \w nube|strong="H6051"\w* \w y|strong="H3588"\w* oscuridad \w de|strong="H5921"\w* \w día|strong="H3119"\w*, \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w resplandor|strong="H5051"\w* \w de|strong="H5921"\w* fuego \w que|strong="H3588"\w* eche \w llamas|strong="H3852"\w*; \w porque|strong="H3588"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* habrá un dosel.  
\v 6 \w Y|strong="H3068"\w* \w habrá|strong="H1961"\w* un tabernáculo \w para|strong="H1961"\w* \w sombra|strong="H6738"\w* \w contra|strong="H1961"\w* el calor del \w día|strong="H3119"\w*, \w para|strong="H1961"\w* refugio y escondedero \w contra|strong="H1961"\w* el turbión y \w contra|strong="H1961"\w* el aguacero.   
\c 5
\q1
\v 1 Dejadme cantar \w ahora|strong="H4994"\w* por \w mi|strong="H1961"\w* \w amado|strong="H1730"\w* \w el|strong="H1121"\w* cantar \w de|strong="H1121"\w* \w mi|strong="H1961"\w* \w amado|strong="H1730"\w* \w a|strong="H3068"\w* su \w viña|strong="H3754"\w*.  
\q2 \w Tenía|strong="H1961"\w* \w mi|strong="H1961"\w* \w amado|strong="H1730"\w* una \w viña|strong="H3754"\w* en una ladera \w fértil|strong="H8081"\w*.   
\q1
\v 2 \w La|strong="H1571"\w* \w había|strong="H6213"\w* cercado \w y|strong="H1571"\w* despedregado,  
\q2 \w y|strong="H1571"\w* \w plantado|strong="H5193"\w* de vides escogidas;  
\q2 \w había|strong="H6213"\w* \w edificado|strong="H1129"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ella una \w torre|strong="H4026"\w*,  
\q2 \w y|strong="H1571"\w* \w también|strong="H1571"\w* excavado un \w lagar|strong="H3342"\w* \w en|strong="H8432"\w* ella;  
\q1 \w y|strong="H1571"\w* \w esperaba|strong="H6960"\w* \w que|strong="H1571"\w* diese \w uvas|strong="H6025"\w*,  
\q2 \w y|strong="H1571"\w* dio agraces.   
\b  
\q1
\v 3 «\w Ahora|strong="H6258"\w*, \w pues|strong="H4994"\w*, \w vecinos|strong="H3427"\w* de Jerusalén y varones de \w Judá|strong="H3063"\w*,  
