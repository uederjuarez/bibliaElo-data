\mt2 El libro del profeta  
\mt1 Isaías  
\c 1
\p
\v 1 \w Visión|strong="H2377"\w* \w de|strong="H5921"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz, \w la|strong="H5921"\w* cual \w vio|strong="H2372"\w* \w sobre|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* Jerusalén, \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Uzías, Jotam, Acaz \w y|strong="H5921"\w* Ezequías, \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\q1
\v 2 \w Oíd|strong="H8085"\w*, \w cielos|strong="H8064"\w*,  
\q2 \w y|strong="H3588"\w* \w escucha|strong="H8085"\w*, tierra; \w porque|strong="H3588"\w* Yahvé\f + \fr 1:2 \ft «Yahvé» es el nombre propio de Dios, a veces traducido como «SEÑOR» (en mayúsculas) en otras traducciones.\f* ha \w hablado|strong="H1696"\w*:  
\q1 «He alimentado \w y|strong="H3588"\w* criado \w a|strong="H3068"\w* \w hijos|strong="H1121"\w*,  
\q2 \w y|strong="H3588"\w* \w ellos|strong="H1992"\w* \w se|strong="H1992"\w* han rebelado contra \w mí|strong="H1431"\w*.   
\q1
\v 3 El \w buey|strong="H7794"\w* \w conoce|strong="H3045"\w* \w a|strong="H3068"\w* su \w dueño|strong="H1167"\w*,  
\q2 \w y|strong="H7794"\w* el \w asno|strong="H2543"\w* el pesebre \w de|strong="H5971"\w* su amo;  
\q1 pero \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* \w conoce|strong="H3045"\w*,  
\q2 mi \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* \w tiene|strong="H7069"\w* entendimiento».   
\q1
\v 4 ¡\w Ah|strong="H1945"\w*, \w nación|strong="H1471"\w* \w pecadora|strong="H2398"\w*,  
\q2 \w pueblo|strong="H5971"\w* \w cargado|strong="H3515"\w* \w de|strong="H1121"\w* \w maldad|strong="H5771"\w*,  
\q1 \w descendencia|strong="H2233"\w*\f + \fr 1:4 \ft o, semilla\f* \w de|strong="H1121"\w* malhechores,  
\q2 \w hijos|strong="H1121"\w* corruptores!  
\q1 Han abandonado \w a|strong="H3068"\w* Yahvé,  
\q2 han despreciado al \w Santo|strong="H6918"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*,  
\q2 \w se|strong="H5971"\w* han vuelto atrás.   
\q1
\v 5 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* habéis \w de|strong="H5921"\w* ser golpeados \w todavía|strong="H5750"\w*?  
\q2 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* persistís \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w rebelión|strong="H5627"\w*?  
\q1 \w Toda|strong="H3605"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w está|strong="H5921"\w* \w doliente|strong="H1742"\w*,  
\q2 \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w corazón|strong="H3824"\w* desfallecido.   
\q1
\v 6 \w Desde|strong="H5704"\w* la planta del \w pie|strong="H7272"\w* \w hasta|strong="H5704"\w* la \w cabeza|strong="H7218"\w* \w no|strong="H3808"\w* hay \w en|strong="H5704"\w* él cosa sana,  
\q2 \w sino|strong="H3808"\w* \w heridas|strong="H4347"\w*, hinchazones \w y|strong="H5704"\w* llagas vivas;  
\q1 \w no|strong="H3808"\w* están curadas, \w ni|strong="H3808"\w* \w vendadas|strong="H2280"\w*,  
\q2 \w ni|strong="H3808"\w* \w suavizadas|strong="H7401"\w* \w con|strong="H5704"\w* \w aceite|strong="H8081"\w*.   
\q1
\v 7 Vuestra tierra está destruida,  
\q2 vuestras \w ciudades|strong="H5892"\w* \w puestas|strong="H8313"\w* \w a|strong="H3068"\w* fuego,  
\q1 vuestra tierra \w delante|strong="H5048"\w* \w de|strong="H5048"\w* vosotros devorada por extranjeros,  
\q2 y \w asolada|strong="H8077"\w* como en \w asolamiento|strong="H8077"\w* \w de|strong="H5048"\w* extraños.   
\q1
\v 8 \w Y|strong="H3068"\w* \w queda|strong="H3498"\w* la \w hija|strong="H1323"\w* de \w Sión|strong="H6726"\w* como enramada en \w viña|strong="H3754"\w*,  
\q2 y como cabaña en melonar, como \w ciudad|strong="H5892"\w* sitiada.   
\q1
\v 9 \w Si|strong="H3884"\w* Yahvé de \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w* \w no|strong="H3884"\w* nos \w hubiese|strong="H1961"\w* dejado un resto pequeño,  
\q2 \w como|strong="H1961"\w* \w Sodoma|strong="H5467"\w* \w fuéramos|strong="H1961"\w*, y semejantes \w a|strong="H3068"\w* \w Gomorra|strong="H6017"\w*.   
\p
\v 10 ¡\w Oíd|strong="H8085"\w* la \w palabra|strong="H1697"\w* \w de|strong="H5971"\w* Yahvé, \w príncipes|strong="H7101"\w* \w de|strong="H5971"\w* \w Sodoma|strong="H5467"\w*!  
\v 11 Escuchad \w la|strong="H7646"\w* ley \w de|strong="H1818"\w* nuestro \w Dios|strong="H3068"\w*,\f + \fr 1:11 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f* ¡pueblo \w de|strong="H1818"\w* Gomorra!  
\q1 «¿Para \w qué|strong="H4100"\w* me sirve \w la|strong="H7646"\w* \w multitud|strong="H7230"\w* \w de|strong="H1818"\w* vuestros \w sacrificios|strong="H2077"\w*?», dice Yahvé.  
\q2 «Harto estoy \w de|strong="H1818"\w* \w holocaustos|strong="H5930"\w* \w de|strong="H1818"\w* carneros y \w de|strong="H1818"\w* grasa \w de|strong="H1818"\w* animales cebados;  
\q1 \w no|strong="H3808"\w* \w quiero|strong="H2654"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* \w bueyes|strong="H6499"\w*,  
\q2 \w ni|strong="H3808"\w* \w de|strong="H1818"\w* ovejas, \w ni|strong="H3808"\w* \w de|strong="H1818"\w* machos cabríos.  
\v 12 \w Cuando|strong="H3588"\w* venís \w a|strong="H3068"\w* presentaros \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w mí|strong="H1245"\w*,  
\q2 ¿\w quién|strong="H4310"\w* demanda \w esto|strong="H2063"\w* \w de|strong="H3588"\w* vuestras \w manos|strong="H3027"\w*, \w para|strong="H3588"\w* pisotear mis \w atrios|strong="H2691"\w*?  
\v 13 \w No|strong="H3808"\w* me traigáis \w más|strong="H3254"\w* \w vana|strong="H7723"\w* \w ofrenda|strong="H4503"\w*;  
\q2 \w el|strong="H1931"\w* incienso me \w es|strong="H1931"\w* \w abominación|strong="H8441"\w*;  
\q1 luna nueva y \w sábado|strong="H7676"\w*, \w el|strong="H1931"\w* convocar \w asambleas|strong="H4744"\w*,  
\q2 \w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w puedo|strong="H3201"\w* sufrir; \w son|strong="H3808"\w* iniquidad vuestras fiestas solemnes.  
\v 14 Vuestras lunas \w nuevas|strong="H2320"\w* \w y|strong="H5921"\w* vuestras fiestas solemnes \w las|strong="H5921"\w* \w tiene|strong="H1961"\w* aborrecidas \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*;  
\q2 \w me|strong="H5921"\w* \w son|strong="H1961"\w* \w gravosas|strong="H2960"\w*; \w cansado|strong="H3811"\w* \w estoy|strong="H1961"\w* \w de|strong="H5921"\w* soportarlas.  
\v 15 \w Cuando|strong="H3588"\w* extendáis vuestras \w manos|strong="H3027"\w*, \w yo|strong="H4480"\w* esconderé \w de|strong="H4480"\w* \w vosotros|strong="H8085"\w* mis \w ojos|strong="H5869"\w*;  
\q2 \w asimismo|strong="H1571"\w* \w cuando|strong="H3588"\w* \w multipliquéis|strong="H7235"\w* \w la|strong="H1571"\w* \w oración|strong="H8605"\w*, \w yo|strong="H4480"\w* \w no|strong="H3588"\w* \w oiré|strong="H8085"\w*;  
\q1 \w llenas|strong="H4390"\w* están \w de|strong="H4480"\w* \w sangre|strong="H1818"\w* vuestras \w manos|strong="H3027"\w*.  
\v 16 Lavaos y limpiaos;  
\q2 \w quitad|strong="H5493"\w* la \w maldad|strong="H7455"\w* \w de|strong="H5048"\w* vuestras \w obras|strong="H4611"\w* \w de|strong="H5048"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* mis \w ojos|strong="H5869"\w*;  
\q1 \w dejad|strong="H5493"\w* \w de|strong="H5048"\w* hacer lo malo;  
\v 17 \w aprended|strong="H3925"\w* \w a|strong="H3068"\w* hacer el \w bien|strong="H3190"\w*;  
\q2 \w buscad|strong="H1875"\w* el \w juicio|strong="H4941"\w*, restituid al agraviado,  
\q1 haced \w justicia|strong="H4941"\w* al \w huérfano|strong="H3490"\w*,  
\q2 \w amparad|strong="H7378"\w* \w a|strong="H3068"\w* la viuda».   
\p
\v 18 «\w Venid|strong="H3212"\w* \w ahora|strong="H4994"\w*, y razonemos», dice Yahvé:  
\q1 «\w Si|strong="H4994"\w* vuestros \w pecados|strong="H2399"\w* \w fueren|strong="H1961"\w* \w como|strong="H1961"\w* la grana, \w como|strong="H1961"\w* la nieve \w serán|strong="H1961"\w* emblanquecidos;  
\q2 \w si|strong="H4994"\w* \w fueren|strong="H1961"\w* rojos \w como|strong="H1961"\w* el carmesí, vendrán \w a|strong="H3068"\w* ser \w como|strong="H1961"\w* blanca \w lana|strong="H6785"\w*.  
\v 19 Si quisiereis y \w oyereis|strong="H8085"\w*,  
\q2 comeréis el \w bien|strong="H2898"\w* de la tierra;  
\v 20 \w si|strong="H3588"\w* \w no|strong="H3985"\w* quisiereis \w y|strong="H3588"\w* fuereis \w rebeldes|strong="H4784"\w*, seréis consumidos \w a|strong="H3068"\w* \w espada|strong="H2719"\w*;  
\q2 \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* Yahvé lo ha \w dicho|strong="H6310"\w*».   
\p
\v 21 ¡\w Cómo|strong="H1961"\w* \w se|strong="H1961"\w* ha convertido en \w ramera|strong="H2181"\w* la \w ciudad|strong="H7151"\w* fiel!  
\q1 Llena \w estuvo|strong="H1961"\w* de \w justicia|strong="H6664"\w*, en ella habitó la equidad;  
\q2 ¡pero \w ahora|strong="H6258"\w*, asesinos!  
\v 22 Tu \w plata|strong="H3701"\w* \w se|strong="H1961"\w* ha convertido en \w escorias|strong="H5509"\w*,  
\q2 tu \w vino|strong="H1961"\w* \w está|strong="H1961"\w* \w mezclado|strong="H4107"\w* con \w agua|strong="H4325"\w*.  
\v 23 Tus \w príncipes|strong="H8269"\w*, \w prevaricadores|strong="H5637"\w* y compañeros \w de|strong="H8269"\w* \w ladrones|strong="H1590"\w*;  
\q1 \w todos|strong="H3605"\w* aman \w el|strong="H3605"\w* \w soborno|strong="H7810"\w*, y van tras las recompensas;  
\q2 \w no|strong="H3808"\w* hacen justicia al \w huérfano|strong="H3490"\w*, \w ni|strong="H3808"\w* llega \w a|strong="H3068"\w* \w ellos|strong="H3605"\w* \w la|strong="H3605"\w* \w causa|strong="H7379"\w* \w de|strong="H8269"\w* \w la|strong="H3605"\w* viuda.   
\p
\v 24 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w dice|strong="H5002"\w* el \w Señor|strong="H3068"\w*,\f + \fr 1:24 \ft La palabra traducida «Señor» es «Adonai».\f* Yahvé de los \w Ejércitos|strong="H6635"\w*, el Fuerte de \w Israel|strong="H3478"\w*:  
\q1 “Ea, \w tomaré|strong="H1945"\w* \w satisfacción|strong="H5162"\w* de mis \w enemigos|strong="H6862"\w*,  
\q2 y me vengaré de mis \w adversarios|strong="H6862"\w*;  
\v 25 \w y|strong="H5921"\w* \w volveré|strong="H7725"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*,  
\q1 \w y|strong="H5921"\w* limpiaré \w hasta|strong="H5921"\w* \w lo|strong="H5921"\w* \w más|strong="H5921"\w* puro tus \w escorias|strong="H5509"\w*,  
\q2 \w y|strong="H5921"\w* \w quitaré|strong="H5493"\w* \w todo|strong="H3605"\w* tu estaño;\f + \fr 1:25 \ft El estaño es un metal que se separa de la plata durante el proceso de refinado y purificación.\f*  
\v 26 restauraré tus \w jueces|strong="H8199"\w* \w como|strong="H3651"\w* al principio,  
\q1 y tus \w consejeros|strong="H3289"\w* \w como|strong="H3651"\w* eran \w antes|strong="H8462"\w*;  
\q2 \w entonces|strong="H3651"\w* te \w llamarán|strong="H7121"\w* ‘\w Ciudad|strong="H5892"\w* de \w justicia|strong="H6664"\w*’, ‘\w Ciudad|strong="H5892"\w* fiel’”.  
\v 27 \w Sión|strong="H6726"\w* será rescatada con \w juicio|strong="H4941"\w*,  
\q2 y los convertidos de ella con \w justicia|strong="H6666"\w*.  
\v 28 Pero los rebeldes y \w pecadores|strong="H2400"\w* serán \w a|strong="H3068"\w* una quebrantados,  
\q2 y los que dejan \w a|strong="H3068"\w* Yahvé serán consumidos.  
\v 29 \w Entonces|strong="H3588"\w* os avergonzarán las encinas \w que|strong="H3588"\w* \w amasteis|strong="H2530"\w*,  
\q2 \w y|strong="H3588"\w* os confundirán \w los|strong="H3588"\w* \w huertos|strong="H1593"\w* \w que|strong="H3588"\w* escogisteis.  
\v 30 \w Porque|strong="H3588"\w* \w seréis|strong="H1961"\w* \w como|strong="H3588"\w* encina \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* le \w cae|strong="H5034"\w* \w la|strong="H3588"\w* hoja,  
\q2 \w y|strong="H3588"\w* \w como|strong="H3588"\w* huerto \w que|strong="H3588"\w* le faltan las \w aguas|strong="H4325"\w*.  
\v 31 \w Y|strong="H3068"\w* el fuerte \w será|strong="H1961"\w* \w como|strong="H1961"\w* estopa,  
\q1 \w y|strong="H1197"\w* su \w obra|strong="H6467"\w* \w como|strong="H1961"\w* centella;  
\q2 \w y|strong="H1197"\w* \w ambos|strong="H8147"\w* \w serán|strong="H1961"\w* \w encendidos|strong="H1197"\w* \w juntamente|strong="H3162"\w*, \w y|strong="H1197"\w* \w no|strong="H1961"\w* \w habrá|strong="H1961"\w* quien apague”.   
\c 2
\p
\v 1 Visión \w de|strong="H5921"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz, \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* Jerusalén.   
\q1
\v 2 \w Acontecerá|strong="H1961"\w* en \w lo|strong="H3605"\w* postrero de \w los|strong="H3605"\w* \w tiempos|strong="H3117"\w*, \w que|strong="H3117"\w* \w el|strong="H3605"\w* \w monte|strong="H2022"\w* de \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de Yahvé \w será|strong="H1961"\w* \w establecido|strong="H3559"\w* \w como|strong="H1961"\w* \w cabeza|strong="H7218"\w* de \w los|strong="H3605"\w* \w montes|strong="H2022"\w*,  
\q2 y \w será|strong="H1961"\w* exaltado \w sobre|strong="H1961"\w* \w los|strong="H3605"\w* \w collados|strong="H1389"\w*, y correrán \w a|strong="H3068"\w* \w él|strong="H3605"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w*.   
\q1
\v 3 Vendrán \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*, \w y|strong="H3588"\w* dirán:  
\q2 «\w Venid|strong="H3212"\w*, \w y|strong="H3588"\w* \w subamos|strong="H5927"\w* al \w monte|strong="H2022"\w* \w de|strong="H3588"\w* Yahvé, \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* del \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*;  
\q2 \w y|strong="H3588"\w* nos \w enseñará|strong="H3384"\w* sus \w caminos|strong="H1870"\w*, \w y|strong="H3588"\w* caminaremos \w por|strong="H3588"\w* sus sendas».  
\q1 \w Porque|strong="H3588"\w* \w de|strong="H3588"\w* \w Sión|strong="H6726"\w* \w saldrá|strong="H3318"\w* \w la|strong="H3588"\w* \w ley|strong="H8451"\w*,  
\q2 \w y|strong="H3588"\w* \w de|strong="H3588"\w* Jerusalén \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé.   
\q1
\v 4 \w Y|strong="H3068"\w* \w juzgará|strong="H8199"\w* \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w*, y \w reprenderá|strong="H3198"\w* \w a|strong="H3068"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*;  
\q2 y volverán sus \w espadas|strong="H2719"\w* \w en|strong="H5750"\w* rejas \w de|strong="H5750"\w* arado, y sus lanzas \w en|strong="H5750"\w* podaderas;  
\q1 \w no|strong="H3808"\w* \w alzará|strong="H5375"\w* \w espada|strong="H2719"\w* \w nación|strong="H1471"\w* contra \w nación|strong="H1471"\w*,  
\q2 \w ni|strong="H3808"\w* \w se|strong="H3808"\w* ensayarán \w más|strong="H5750"\w* \w para|strong="H5971"\w* la \w guerra|strong="H4421"\w*.   
\b  
\q1
\v 5 \w Venid|strong="H3212"\w*, oh \w casa|strong="H1004"\w* de \w Jacob|strong="H3290"\w*, y caminemos \w a|strong="H3068"\w* la luz de Yahvé.   
\q1
\v 6 \w Ciertamente|strong="H3588"\w* has dejado tu \w pueblo|strong="H5971"\w*, \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*, \w porque|strong="H3588"\w* están \w llenos|strong="H4390"\w* \w de|strong="H3588"\w* costumbres del \w oriente|strong="H6924"\w*,  
\q2 \w y|strong="H3588"\w* \w son|strong="H3588"\w* \w agoreros|strong="H6049"\w*, \w como|strong="H3588"\w* \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w*, \w y|strong="H3588"\w* pactan \w con|strong="H3588"\w* \w hijos|strong="H3206"\w* \w de|strong="H3588"\w* extranjeros.   
\q1
\v 7 Su tierra está \w llena|strong="H4390"\w* de \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w*, sus tesoros no tienen fin.  
\q1 También está su tierra \w llena|strong="H4390"\w* de \w caballos|strong="H5483"\w*, y sus \w carros|strong="H4818"\w* son innumerables.   
\q1
\v 8 Además su tierra está \w llena|strong="H4390"\w* de ídolos,  
\q2 y se han arrodillado ante la \w obra|strong="H4639"\w* de sus \w manos|strong="H3027"\w* y ante \w lo|strong="H6213"\w* \w que|strong="H3027"\w* \w fabricaron|strong="H6213"\w* sus dedos.   
\q1
\v 9 \w Y|strong="H3068"\w* se ha inclinado el hombre, y el varón se ha humillado;  
\q2 por tanto, no los \w perdones|strong="H5375"\w*.   
\q1
\v 10 Entra en la peña, y \w escóndete|strong="H2934"\w* en el \w polvo|strong="H6083"\w*,  
\q2 \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* temible \w de|strong="H6440"\w* Yahvé, y del resplandor \w de|strong="H6440"\w* su majestad.   
\q1
\v 11 \w La|strong="H1931"\w* altivez \w de|strong="H5869"\w* \w los|strong="H1931"\w* \w ojos|strong="H5869"\w* del hombre \w será|strong="H1931"\w* \w abatida|strong="H8213"\w*, y \w la|strong="H1931"\w* soberbia \w de|strong="H5869"\w* \w los|strong="H1931"\w* hombres \w será|strong="H1931"\w* humillada;  
