\b  
\p
\v 8 \w Así|strong="H3541"\w* dice Yahvé:  
\q1 “\w Como|strong="H3588"\w* \w si|strong="H3588"\w* \w alguno|strong="H3605"\w* \w hallase|strong="H4672"\w* \w mosto|strong="H8492"\w* \w en|strong="H3588"\w* un racimo, \w y|strong="H3588"\w* dijese:  
\q2 «\w No|strong="H6213"\w* \w lo|strong="H6213"\w* desperdicies, \w porque|strong="H3588"\w* \w bendición|strong="H1293"\w* hay \w en|strong="H3588"\w* \w él|strong="H3588"\w*»;  
\q1 \w así|strong="H3541"\w* \w haré|strong="H6213"\w* \w yo|strong="H3588"\w* \w por|strong="H3588"\w* amor \w de|strong="H3588"\w* mis \w siervos|strong="H5650"\w*,  
\q2 \w que|strong="H3588"\w* \w no|strong="H6213"\w* \w lo|strong="H6213"\w* \w destruiré|strong="H7843"\w* \w todo|strong="H3605"\w*.   
\q1
\v 9 Sacaré \w descendencia|strong="H2233"\w* de \w Jacob|strong="H3290"\w*,  
\q2 y de \w Judá|strong="H3063"\w* \w heredero|strong="H3423"\w* de mis \w montes|strong="H2022"\w*;  
\q1 y mis escogidos \w poseerán|strong="H3423"\w* la tierra por \w heredad|strong="H3423"\w*,  
\q2 y mis \w siervos|strong="H5650"\w* \w habitarán|strong="H7931"\w* \w allí|strong="H8033"\w*.   
\q1
\v 10 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w Sarón|strong="H8289"\w* \w para|strong="H1961"\w* habitación \w de|strong="H5971"\w* \w ovejas|strong="H6629"\w*,  
\q2 \w y|strong="H1241"\w* el \w valle|strong="H6010"\w* \w de|strong="H5971"\w* Acor \w para|strong="H1961"\w* majada \w de|strong="H5971"\w* \w vacas|strong="H1241"\w*,  
\q2 \w para|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* me \w buscó|strong="H1875"\w*.   
\b  
\q1
\v 11 Pero vosotros los que dejáis \w a|strong="H3068"\w* Yahvé,  
\q2 que olvidáis mi \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*,  
\q1 que ponéis \w mesa|strong="H7979"\w* para la Fortuna,  
\q2 y suministráis \w libaciones|strong="H4469"\w* para el Destino;   
\q1
\v 12 \w yo|strong="H6213"\w* \w os|strong="H5869"\w* destinaré \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w espada|strong="H2719"\w*,  
\q2 y \w todos|strong="H3605"\w* \w vosotros|strong="H8085"\w* \w os|strong="H5869"\w* arrodillaréis al degolladero,  
\q1 \w por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w llamé|strong="H7121"\w*, y \w no|strong="H3808"\w* \w respondisteis|strong="H6030"\w*;  
\q2 \w hablé|strong="H1696"\w*, y \w no|strong="H3808"\w* \w oísteis|strong="H8085"\w*,  
\q1 \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w hicisteis|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante mis \w ojos|strong="H5869"\w*,  
\q2 y escogisteis \w lo|strong="H3808"\w* \w que|strong="H3808"\w* me desagrada”.   
\b  
\p
\v 13 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dijo el Señor Yahvé:  
\q1 «He \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* mis \w siervos|strong="H5650"\w* comerán, \w y|strong="H3541"\w* vosotros tendréis \w hambre|strong="H7456"\w*;  
\q2 he \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* mis \w siervos|strong="H5650"\w* \w beberán|strong="H8354"\w*, \w y|strong="H3541"\w* vosotros tendréis \w sed|strong="H6770"\w*;  
\q1 he \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* mis \w siervos|strong="H5650"\w* \w se|strong="H3651"\w* alegrarán,  
\q2 \w y|strong="H3541"\w* vosotros seréis avergonzados;   
\q1
\v 14 he \w aquí|strong="H2009"\w* que mis \w siervos|strong="H5650"\w* \w cantarán|strong="H7442"\w* por júbilo del \w corazón|strong="H3820"\w*,  
\q2 y vosotros \w clamaréis|strong="H6817"\w* por el dolor del \w corazón|strong="H3820"\w*,  
\q2 y por el \w quebrantamiento|strong="H7667"\w* de \w espíritu|strong="H7307"\w* \w aullaréis|strong="H3213"\w*.   
\q1
\v 15 \w Y|strong="H3068"\w* dejaréis vuestro \w nombre|strong="H8034"\w* por maldición \w a|strong="H3068"\w* mis escogidos,  
\q2 y el Señor Yahvé te \w matará|strong="H4191"\w*,  
\q1 y \w a|strong="H3068"\w* sus \w siervos|strong="H5650"\w* \w llamará|strong="H7121"\w* por otro \w nombre|strong="H8034"\w*.   
\q1
\v 16 \w El|strong="H3588"\w* \w que|strong="H3588"\w* se bendijere \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w en|strong="H3588"\w* \w el|strong="H3588"\w* Dios \w de|strong="H3588"\w* verdad se \w bendecirá|strong="H1288"\w*;  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w jurare|strong="H7650"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w por|strong="H3588"\w* \w el|strong="H3588"\w* Dios \w de|strong="H3588"\w* verdad jurará;  
\q1 \w porque|strong="H3588"\w* las \w angustias|strong="H6869"\w* \w primeras|strong="H7223"\w* serán olvidadas,  
\q2 \w y|strong="H3588"\w* serán ocultas \w a|strong="H3068"\w* mis \w ojos|strong="H5869"\w*.   
\b  
\q1
\v 17 \w Porque|strong="H3588"\w* he \w aquí|strong="H2005"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* crearé \w cielos|strong="H8064"\w* \w nuevos|strong="H2319"\w* \w y|strong="H3588"\w* tierra \w nueva|strong="H2319"\w*;  
\q2 \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w lo|strong="H3808"\w* \w primero|strong="H7223"\w* \w no|strong="H3808"\w* habrá \w memoria|strong="H2142"\w*, \w ni|strong="H3808"\w* \w más|strong="H3588"\w* \w vendrá|strong="H5927"\w* \w al|strong="H5921"\w* \w pensamiento|strong="H3820"\w*.   
\q1
\v 18 \w Mas|strong="H3588"\w* \w os|strong="H5704"\w* gozaréis \w y|strong="H3588"\w* \w os|strong="H5704"\w* alegraréis \w para|strong="H5704"\w* \w siempre|strong="H5703"\w* \w en|strong="H5704"\w* las cosas \w que|strong="H3588"\w* \w yo|strong="H3588"\w* creo;  
\q2 \w porque|strong="H3588"\w* he \w aquí|strong="H2005"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* traigo \w a|strong="H3068"\w* Jerusalén \w alegría|strong="H1525"\w*,  
\q2 \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w gozo|strong="H4885"\w*.   
\q1
\v 19 \w Y|strong="H3068"\w* me alegraré con Jerusalén, y me gozaré con \w mi|strong="H3389"\w* \w pueblo|strong="H5971"\w*;  
\q2 y \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w se|strong="H3808"\w* \w oirá|strong="H8085"\w* \w en|strong="H5750"\w* ella \w voz|strong="H6963"\w* \w de|strong="H5750"\w* \w lloro|strong="H1065"\w*, \w ni|strong="H3808"\w* \w voz|strong="H6963"\w* \w de|strong="H5750"\w* \w clamor|strong="H2201"\w*.   
\b  
\q1
\v 20 \w No|strong="H3808"\w* \w habrá|strong="H1961"\w* \w más|strong="H5750"\w* \w allí|strong="H8033"\w* \w niño|strong="H5288"\w* \w que|strong="H3588"\w* \w muera|strong="H4191"\w* \w de|strong="H3588"\w* pocos \w días|strong="H3117"\w*,  
\q2 \w ni|strong="H3808"\w* \w viejo|strong="H2205"\w* \w que|strong="H3588"\w* sus \w días|strong="H3117"\w* \w no|strong="H3808"\w* \w cumpla|strong="H4390"\w*;  
\q1 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w niño|strong="H5288"\w* \w morirá|strong="H4191"\w* \w de|strong="H3588"\w* \w cien|strong="H3967"\w* \w años|strong="H8141"\w*,  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w pecador|strong="H2398"\w* \w de|strong="H3588"\w* \w cien|strong="H3967"\w* \w años|strong="H8141"\w* \w será|strong="H1961"\w* maldito.   
\q1
\v 21 \w Edificarán|strong="H1129"\w* \w casas|strong="H1004"\w*, y \w morarán|strong="H3427"\w* en ellas;  
\q2 \w plantarán|strong="H5193"\w* \w viñas|strong="H3754"\w*, y comerán \w el|strong="H3427"\w* \w fruto|strong="H6529"\w* de ellas.   
\q1
\v 22 \w No|strong="H3808"\w* \w edificarán|strong="H1129"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* otro habite, \w ni|strong="H3808"\w* \w plantarán|strong="H5193"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* otro coma;  
\q2 \w porque|strong="H3588"\w* según \w los|strong="H3427"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w árboles|strong="H6086"\w* serán \w los|strong="H3427"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*,  
\q2 \w y|strong="H3588"\w* mis escogidos disfrutarán \w la|strong="H3588"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* sus \w manos|strong="H3027"\w*.   
\q1
\v 23 \w No|strong="H3808"\w* \w trabajarán|strong="H3021"\w* \w en|strong="H3588"\w* vano, \w ni|strong="H3808"\w* darán \w a|strong="H3068"\w* luz \w para|strong="H3588"\w* maldición;  
\q2 \w porque|strong="H3588"\w* \w son|strong="H3588"\w* \w linaje|strong="H2233"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w benditos|strong="H1288"\w* \w de|strong="H3588"\w* Yahvé,  
\q2 \w y|strong="H3588"\w* \w sus|strong="H1992"\w* \w descendientes|strong="H6631"\w* \w con|strong="H3588"\w* \w ellos|strong="H1992"\w*.   
\q1
\v 24 \w Y|strong="H3068"\w* \w antes|strong="H2962"\w* \w que|strong="H1961"\w* clamen, \w responderé|strong="H6030"\w* yo;  
\q2 \w mientras|strong="H5750"\w* \w aún|strong="H5750"\w* \w hablan|strong="H1696"\w*, yo habré \w oído|strong="H8085"\w*.   
\q1
\v 25 \w El|strong="H3605"\w* \w lobo|strong="H2061"\w* \w y|strong="H1241"\w* \w el|strong="H3605"\w* \w cordero|strong="H2924"\w* serán \w apacentados|strong="H7462"\w* juntos,  
\q2 \w y|strong="H1241"\w* \w el|strong="H3605"\w* león comerá \w paja|strong="H8401"\w* como \w el|strong="H3605"\w* buey;  
\q2 \w y|strong="H1241"\w* \w el|strong="H3605"\w* \w polvo|strong="H6083"\w* \w será|strong="H3808"\w* \w el|strong="H3605"\w* alimento de \w la|strong="H3605"\w* \w serpiente|strong="H5175"\w*.  
\q1 \w No|strong="H3808"\w* \w afligirán|strong="H7489"\w* \w ni|strong="H3808"\w* harán \w mal|strong="H7489"\w* en \w todo|strong="H3605"\w* mi \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*»,  
\q2 dice Yahvé.   
\c 66
\p
\v 1 \w Así|strong="H3541"\w* dice Yahvé:  
\q1 «El \w cielo|strong="H8064"\w* \w es|strong="H2088"\w* mi \w trono|strong="H3678"\w*, \w y|strong="H3541"\w* la tierra el \w estrado|strong="H1916"\w* de mis \w pies|strong="H7272"\w*;  
\q2 ¿\w dónde|strong="H4725"\w* \w está|strong="H2088"\w* la \w casa|strong="H1004"\w* \w que|strong="H2088"\w* \w me|strong="H3541"\w* habéis de \w edificar|strong="H1129"\w*,  
\q2 \w y|strong="H3541"\w* \w dónde|strong="H4725"\w* el \w lugar|strong="H4725"\w* de mi \w reposo|strong="H4496"\w*?   
\q1
\v 2 \w Mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w hizo|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H2088"\w* \w cosas|strong="H1697"\w*, \w y|strong="H5921"\w* \w así|strong="H2088"\w* \w todas|strong="H3605"\w* \w estas|strong="H2088"\w* \w cosas|strong="H1697"\w* \w fueron|strong="H1961"\w*», \w dice|strong="H5002"\w* Yahvé;  
\q1 «pero \w miraré|strong="H5027"\w* \w a|strong="H3068"\w* \w aquel|strong="H2088"\w* \w que|strong="H5921"\w* \w es|strong="H1961"\w* \w pobre|strong="H6041"\w* \w y|strong="H5921"\w* \w humilde|strong="H6041"\w* \w de|strong="H5921"\w* \w espíritu|strong="H7307"\w*,  
\q2 \w y|strong="H5921"\w* \w que|strong="H5921"\w* tiembla \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w palabra|strong="H1697"\w*.   
\q1
\v 3 \w El|strong="H1571"\w* \w que|strong="H1571"\w* \w sacrifica|strong="H2076"\w* \w buey|strong="H7794"\w* es \w como|strong="H1571"\w* \w si|strong="H1571"\w* matase \w a|strong="H3068"\w* un hombre;  
\q2 \w el|strong="H1571"\w* \w que|strong="H1571"\w* \w sacrifica|strong="H2076"\w* \w oveja|strong="H7716"\w*, \w como|strong="H1571"\w* \w si|strong="H1571"\w* degollase \w a|strong="H3068"\w* un \w perro|strong="H3611"\w*;  
\q2 \w el|strong="H1571"\w* \w que|strong="H1571"\w* ofrece \w presente|strong="H4503"\w*, \w como|strong="H1571"\w* \w si|strong="H1571"\w* ofreciese \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* cerdo;  
\q2 \w el|strong="H1571"\w* \w que|strong="H1571"\w* quema \w incienso|strong="H3828"\w*, \w como|strong="H1571"\w* \w si|strong="H1571"\w* bendijese \w a|strong="H3068"\w* un ídolo.  
\q1 \w Y|strong="H3068"\w* \w pues|strong="H1571"\w* escogieron \w sus|strong="H1992"\w* propios \w caminos|strong="H1870"\w*,  
\q2 \w y|strong="H1571"\w* \w su|strong="H1992"\w* \w alma|strong="H5315"\w* \w amó|strong="H2654"\w* \w sus|strong="H1992"\w* \w abominaciones|strong="H8251"\w*,   
\q1
\v 4 \w también|strong="H1571"\w* \w yo|strong="H6213"\w* escogeré \w para|strong="H3282"\w* \w ellos|strong="H1992"\w* escarnios,  
\q2 \w y|strong="H1571"\w* traeré sobre \w ellos|strong="H1992"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* temieron;  
\q1 \w porque|strong="H3282"\w* \w llamé|strong="H7121"\w*, \w y|strong="H1571"\w* \w nadie|strong="H3808"\w* \w respondió|strong="H6030"\w*; \w hablé|strong="H1696"\w*, \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w oyeron|strong="H8085"\w*,  
\q2 \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w hicieron|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* \w delante|strong="H5869"\w* \w de|strong="H5869"\w* mis \w ojos|strong="H5869"\w*,  
\q2 \w y|strong="H1571"\w* escogieron \w lo|strong="H3808"\w* \w que|strong="H3808"\w* me desagrada».   
\b  
\q1
\v 5 \w Oíd|strong="H8085"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, \w vosotros|strong="H8085"\w* \w los|strong="H1992"\w* \w que|strong="H1697"\w* tembláis \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w palabra|strong="H1697"\w*:  
\q2 “Vuestros hermanos \w que|strong="H1697"\w* os \w aborrecen|strong="H8130"\w*,  
\q2 y os echan fuera \w por|strong="H4616"\w* \w causa|strong="H1697"\w* \w de|strong="H1697"\w* mi \w nombre|strong="H8034"\w*, \w dijeron|strong="H1697"\w*:  
\q1 «Sea Yahvé glorificado, \w para|strong="H4616"\w* \w que|strong="H1697"\w* \w veamos|strong="H7200"\w* nosotros vuestra \w alegría|strong="H8057"\w*»;  
\q2 mas \w ellos|strong="H1992"\w* \w serán|strong="H1992"\w* confundidos.   
\q1
\v 6 \w Voz|strong="H6963"\w* de estrépito de la \w ciudad|strong="H5892"\w*, \w voz|strong="H6963"\w* del \w templo|strong="H1964"\w*,  
\q2 \w voz|strong="H6963"\w* de Yahvé que da el \w pago|strong="H1576"\w* \w a|strong="H3068"\w* sus enemigos”.   
\b  
\q1
\v 7 \w Antes|strong="H2962"\w* que estuviese de parto, dio \w a|strong="H3068"\w* luz;  
\q2 \w antes|strong="H2962"\w* que le viniesen \w dolores|strong="H2256"\w*, \w parió|strong="H3205"\w* \w hijo|strong="H3205"\w*.   
\q1
\v 8 ¿\w Quién|strong="H4310"\w* \w oyó|strong="H8085"\w* \w cosa|strong="H2063"\w* semejante? ¿\w Quién|strong="H4310"\w* \w vio|strong="H7200"\w* \w tal|strong="H2063"\w* \w cosa|strong="H2063"\w*?  
\q2 ¿Concebirá \w la|strong="H1571"\w* tierra \w en|strong="H3588"\w* un \w día|strong="H3117"\w*? ¿\w Nacerá|strong="H3205"\w* \w una|strong="H6471"\w* \w nación|strong="H1471"\w* \w de|strong="H3588"\w* \w una|strong="H6471"\w* \w vez|strong="H6471"\w*?  
\q1 \w Pues|strong="H3588"\w* \w en|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w Sión|strong="H6726"\w* estuvo \w de|strong="H3588"\w* parto,  
\q2 dio \w a|strong="H3068"\w* luz sus \w hijos|strong="H1121"\w*.   
\q1
\v 9 «¿Yo \w que|strong="H3808"\w* hago dar \w a|strong="H3068"\w* luz, \w no|strong="H3808"\w* haré nacer?», dice Yahvé.  
\q2 «¿Yo \w que|strong="H3808"\w* hago engendrar, \w cerraré|strong="H6113"\w* la matriz?», dice el \w Dios|strong="H3068"\w* tuyo.   
\b  
\q1
\v 10 \w Alegraos|strong="H8055"\w* \w con|strong="H5921"\w* Jerusalén, \w y|strong="H5921"\w* gozaos \w con|strong="H5921"\w* \w ella|strong="H5921"\w*, \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* amáis;  
\q2 \w llenaos|strong="H7797"\w* \w con|strong="H5921"\w* \w ella|strong="H5921"\w* \w de|strong="H5921"\w* \w gozo|strong="H4885"\w*, \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w por|strong="H5921"\w* \w ella|strong="H5921"\w* hacíais duelo;   
\q1
\v 11 \w para|strong="H4616"\w* \w que|strong="H4616"\w* maméis \w y|strong="H3519"\w* os saciéis \w de|strong="H7646"\w* los \w pechos|strong="H7699"\w* \w de|strong="H7646"\w* sus \w consolaciones|strong="H8575"\w*;  
\q2 \w para|strong="H4616"\w* \w que|strong="H4616"\w* bebáis, \w y|strong="H3519"\w* os deleitéis con el resplandor \w de|strong="H7646"\w* su \w gloria|strong="H3519"\w*”.   
\b  
\q1
\v 12 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice Yahvé: «He \w aquí|strong="H3541"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* extiendo \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* \w paz|strong="H7965"\w* \w como|strong="H3588"\w* un \w río|strong="H5104"\w*,  
\q2 \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w como|strong="H3588"\w* \w torrente|strong="H5158"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* desborda;  
\q2 \w y|strong="H3588"\w* mamaréis, \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w brazos|strong="H5158"\w* seréis traídos,  
