\c 65
\q1
\v 1 “\w Fui|strong="H3808"\w* buscado por los \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w preguntaban|strong="H7592"\w* por \w mí|strong="H1245"\w*;  
