\p
\v 1 \w En|strong="H3588"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* Ezequías \w enfermó|strong="H2470"\w* \w de|strong="H3588"\w* \w muerte|strong="H4191"\w*. \w Y|strong="H3068"\w* vino \w a|strong="H3068"\w* \w él|strong="H3588"\w* \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* \w Isaías|strong="H3470"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Amoz, \w y|strong="H3588"\w* le dijo: «\w Así|strong="H3541"\w* dice Yahvé: «Pon \w en|strong="H3588"\w* \w orden|strong="H6680"\w* tu \w casa|strong="H1004"\w*, \w porque|strong="H3588"\w* \w morirás|strong="H4191"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w vivirás|strong="H2421"\w*»».   
