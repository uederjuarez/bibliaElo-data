\ms1 LIBRO 1  
\q1
\v 1 Bienaventurado \w el|strong="H3427"\w* hombre \w que|strong="H3808"\w* \w no|strong="H3808"\w* sigue \w el|strong="H3427"\w* \w consejo|strong="H6098"\w* de \w los|strong="H3427"\w* \w impíos|strong="H7563"\w*,  
