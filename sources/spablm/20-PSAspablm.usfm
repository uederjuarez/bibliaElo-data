\v 3 \w Será|strong="H1961"\w* \w como|strong="H1961"\w* un \w árbol|strong="H6086"\w* \w plantado|strong="H8362"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* corrientes \w de|strong="H5921"\w* \w agua|strong="H4325"\w*,  
\q2 \w que|strong="H3808"\w* \w da|strong="H5414"\w* su \w fruto|strong="H6529"\w* \w a|strong="H3068"\w* su \w tiempo|strong="H6256"\w*,  
\q2 \w y|strong="H5921"\w* cuya hoja \w no|strong="H3808"\w* \w se|strong="H1961"\w* marchita.  
\q2 \w Todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w hace|strong="H6213"\w*, \w prosperará|strong="H6743"\w*.   
\q1
\v 4 \w No|strong="H3808"\w* \w así|strong="H3651"\w* \w los|strong="H3588"\w* \w impíos|strong="H7563"\w*,  
\q2 \w que|strong="H3588"\w* \w son|strong="H3588"\w* \w como|strong="H3588"\w* \w la|strong="H3588"\w* paja \w que|strong="H3588"\w* \w se|strong="H3808"\w* lleva \w el|strong="H3588"\w* \w viento|strong="H7307"\w*.   
\q1
\v 5 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w no|strong="H3808"\w* \w se|strong="H3808"\w* sostendrán \w los|strong="H5921"\w* \w impíos|strong="H7563"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w juicio|strong="H4941"\w*,  
