\v 5 \w Porque|strong="G1063"\w* \w no|strong="G3756"\w* \w sometió|strong="G5293"\w* a \w los|strong="G3588"\w* ángeles \w el|strong="G3588"\w* \w mundo|strong="G3625"\w* \w venidero|strong="G3195"\w*, \w del|strong="G3588"\w* \w que|strong="G3588"\w* \w hablamos|strong="G2980"\w*.  
