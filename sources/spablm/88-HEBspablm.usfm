\p \w Porque|strong="G1063"\w* \w al|strong="G3588"\w* someter \w todas|strong="G3956"\w* \w las|strong="G3588"\w* cosas \w a|strong="G1722"\w* \w él|strong="G3588"\w*, \w no|strong="G3768"\w* dejó \w nada|strong="G3762"\w* \w que|strong="G3588"\w* \w no|strong="G3768"\w* \w le|strong="G1722"\w* estuviera sometido. \w Pero|strong="G1161"\w* \w ahora|strong="G3568"\w* todavía \w no|strong="G3768"\w* vemos \w que|strong="G3588"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* cosas \w le|strong="G1722"\w* estén sometidas.  
\v 9 \w Pero|strong="G1161"\w* vemos \w a|strong="G3844"\w* \w aquel|strong="G3588"\w* \w que|strong="G3588"\w* fue hecho \w un|strong="G5100"\w* \w poco|strong="G1024"\w* \w menor|strong="G1642"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* ángeles, \w a|strong="G3844"\w* \w Jesús|strong="G2424"\w*, \w coronado|strong="G4737"\w* \w de|strong="G3844"\w* \w gloria|strong="G1391"\w* \w y|strong="G2532"\w* \w honor|strong="G5092"\w* \w a|strong="G3844"\w* \w causa|strong="G1223"\w* \w del|strong="G3588"\w* padecimiento \w de|strong="G3844"\w* \w la|strong="G3588"\w* \w muerte|strong="G2288"\w*, \w para|strong="G3844"\w* \w que|strong="G3588"\w* \w por|strong="G1223"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w de|strong="G3844"\w* \w Dios|strong="G2316"\w* probara \w la|strong="G3588"\w* \w muerte|strong="G2288"\w* \w por|strong="G1223"\w* \w todos|strong="G3956"\w*.   
