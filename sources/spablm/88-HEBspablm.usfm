\v 1 \w Dios|strong="G2316"\w*, habiendo \w hablado|strong="G2980"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* pasado \w a|strong="G1909"\w* \w los|strong="G3588"\w* \w padres|strong="G3962"\w* \w por|strong="G1722"\w* medio \w de|strong="G1722"\w* \w los|strong="G3588"\w* \w profetas|strong="G4396"\w* \w en|strong="G1722"\w* muchas ocasiones \w y|strong="G2532"\w* \w de|strong="G1722"\w* diversas maneras,  
