\q1 «Declararé \w tu|strong="G4771"\w* \w nombre|strong="G3686"\w* \w a|strong="G1722"\w* mis hermanos.  
\q2 \w En|strong="G1722"\w* \w medio|strong="G3319"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w congregación|strong="G1577"\w* cantaré \w tu|strong="G4771"\w* alabanza».   
\p
\v 13 \w De|strong="G1909"\w* nuevo: «Pondré \w mi|strong="G3588"\w* confianza \w en|strong="G1909"\w* \w él|strong="G3588"\w*». \w Y|strong="G2532"\w* \w de|strong="G1909"\w* nuevo: «He aquí, \w yo|strong="G1473"\w* \w y|strong="G2532"\w* \w los|strong="G3588"\w* \w hijos|strong="G3813"\w* \w que|strong="G3588"\w* \w Dios|strong="G2316"\w* \w me|strong="G1473"\w* ha \w dado|strong="G1325"\w*».  
\v 14 Puesto \w que|strong="G3588"\w* \w los|strong="G3588"\w* \w hijos|strong="G3813"\w* \w participaron|strong="G2841"\w* \w de|strong="G1223"\w* \w la|strong="G3588"\w* \w carne|strong="G4561"\w* \w y|strong="G2532"\w* \w de|strong="G1223"\w* \w la|strong="G3588"\w* sangre, \w también|strong="G2532"\w* \w él|strong="G3588"\w* \w participó|strong="G3348"\w* \w de|strong="G1223"\w* \w lo|strong="G3588"\w* mismo, \w para|strong="G2443"\w* \w destruir|strong="G2673"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* \w la|strong="G3588"\w* \w muerte|strong="G2288"\w* \w al|strong="G3588"\w* \w que|strong="G3588"\w* \w tenía|strong="G2192"\w* \w el|strong="G3588"\w* \w imperio|strong="G2904"\w* \w de|strong="G1223"\w* \w la|strong="G3588"\w* \w muerte|strong="G2288"\w*, \w es|strong="G3348"\w* decir, \w al|strong="G3588"\w* \w diablo|strong="G1228"\w*,  
\v 15 \w y|strong="G2532"\w* librar \w a|strong="G1223"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w*, \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w temor|strong="G5401"\w* \w a|strong="G1223"\w* \w la|strong="G3588"\w* \w muerte|strong="G2288"\w*, estaban durante \w toda|strong="G3956"\w* \w su|strong="G3588"\w* \w vida|strong="G2198"\w* \w sujetos|strong="G1777"\w* \w a|strong="G1223"\w* esclavitud.  
\v 16 \w Porque|strong="G1063"\w* \w ciertamente|strong="G1063"\w* \w no|strong="G3756"\w* socorre a los ángeles, sino \w que|strong="G1063"\w* socorre a la descendencia de Abraham.  
\v 17 \w Por|strong="G1519"\w* eso \w debía|strong="G3784"\w* \w ser|strong="G1096"\w* \w hecho|strong="G1096"\w* \w semejante|strong="G3666"\w* \w a|strong="G1519"\w* \w sus|strong="G3588"\w* hermanos \w en|strong="G1519"\w* \w todo|strong="G3956"\w*, \w para|strong="G1519"\w* llegar \w a|strong="G1519"\w* \w ser|strong="G1096"\w* \w un|strong="G3588"\w* sumo sacerdote \w misericordioso|strong="G1655"\w* \w y|strong="G2532"\w* \w fiel|strong="G4103"\w* \w en|strong="G1519"\w* \w las|strong="G3588"\w* cosas \w que|strong="G3588"\w* \w a|strong="G1519"\w* \w Dios|strong="G2316"\w* \w se|strong="G1096"\w* refieren, \w para|strong="G1519"\w* \w expiar|strong="G2433"\w* \w los|strong="G3588"\w* pecados \w del|strong="G3588"\w* \w pueblo|strong="G2992"\w*.  
\v 18 \w Porque|strong="G1063"\w* \w por|strong="G1722"\w* \w cuanto|strong="G3739"\w* \w él|strong="G3588"\w* mismo \w padeció|strong="G3958"\w* siendo \w tentado|strong="G3985"\w*, \w es|strong="G3739"\w* poderoso \w para|strong="G1722"\w* socorrer \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* son \w tentados|strong="G3985"\w*.   
\c 3
\p
\v 1 \w Por|strong="G3606"\w* tanto, hermanos santos, \w partícipes|strong="G3353"\w* \w de|strong="G3588"\w* \w un|strong="G3588"\w* llamamiento \w celestial|strong="G2032"\w*, \w considerad|strong="G2657"\w* \w al|strong="G3588"\w* Apóstol \w y|strong="G2532"\w* Sumo Sacerdote \w de|strong="G3588"\w* \w nuestra|strong="G3588"\w* \w profesión|strong="G3671"\w*: \w Jesús|strong="G2424"\w*,  
