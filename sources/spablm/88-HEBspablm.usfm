\v 10 \w Porque|strong="G1063"\w* \w convenía|strong="G4241"\w* \w a|strong="G1519"\w* \w aquel|strong="G3588"\w* \w por|strong="G1223"\w* \w quien|strong="G3739"\w* son \w todas|strong="G3956"\w* \w las|strong="G3588"\w* \w cosas|strong="G3739"\w* \w y|strong="G2532"\w* mediante \w quien|strong="G3739"\w* son \w todas|strong="G3956"\w* \w las|strong="G3588"\w* \w cosas|strong="G3739"\w*, \w que|strong="G3588"\w* \w al|strong="G3588"\w* llevar \w a|strong="G1519"\w* \w muchos|strong="G4183"\w* \w hijos|strong="G5207"\w* \w a|strong="G1519"\w* \w la|strong="G3588"\w* \w gloria|strong="G1391"\w*, perfeccionase mediante \w aflicciones|strong="G3804"\w* \w al|strong="G3588"\w* autor \w de|strong="G1519"\w* \w la|strong="G3588"\w* \w salvación|strong="G4991"\w* \w de|strong="G1519"\w* \w ellos|strong="G3588"\w*.  
\v 11 \w Porque|strong="G1063"\w* \w tanto|strong="G3739"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* santifica \w como|strong="G2532"\w* \w los|strong="G3588"\w* santificados proceden \w todos|strong="G3956"\w* \w de|strong="G1537"\w* \w uno|strong="G1520"\w*, \w por|strong="G1223"\w* \w lo|strong="G3588"\w* \w cual|strong="G3739"\w* \w no|strong="G3756"\w* \w se|strong="G1438"\w* avergüenza \w de|strong="G1537"\w* llamarles hermanos,  
