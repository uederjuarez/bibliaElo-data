\p
\v 1 \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Joel|strong="H3100"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Petuel.   
\q1
\v 2 \w Oíd|strong="H8085"\w* \w esto|strong="H2063"\w*, \w ancianos|strong="H2205"\w*,  
\q2 ¡y \w escuchad|strong="H8085"\w*, \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de \w la|strong="H3605"\w* tierra!  
\q1 ¿Ha acontecido \w esto|strong="H2063"\w* en vuestros \w días|strong="H3117"\w*,  
\q2 \w o|strong="H3068"\w* en \w los|strong="H3427"\w* \w días|strong="H3117"\w* de vuestros padres?   
\q1
\v 3 Contadlo \w a|strong="H3068"\w* vuestros \w hijos|strong="H1121"\w*,  
\q2 \w y|strong="H5921"\w* \w que|strong="H5921"\w* vuestros \w hijos|strong="H1121"\w* \w lo|strong="H5921"\w* digan \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*,  
\q2 \w y|strong="H5921"\w* sus \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* otra \w generación|strong="H1755"\w*.   
\q1
\v 4 Lo que quedó de la oruga comió la langosta;  
\q2 lo que quedó de la langosta comió el pulgón;  
\q2 y el saltón comió lo que del pulgón había quedado.   
\q1
\v 5 ¡\w Despertad|strong="H6974"\w*, \w borrachos|strong="H7910"\w*, \w y|strong="H3588"\w* \w llorad|strong="H1058"\w*!  
\q2 \w Aullad|strong="H3213"\w*, \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w bebéis|strong="H8354"\w* \w vino|strong="H3196"\w*, \w a|strong="H3068"\w* causa \w del|strong="H5921"\w* \w mosto|strong="H6071"\w*,  
\q2 \w porque|strong="H3588"\w* \w os|strong="H5921"\w* \w es|strong="H3588"\w* quitado \w de|strong="H5921"\w* vuestra \w boca|strong="H6310"\w*.   
\q1
\v 6 \w Porque|strong="H3588"\w* una \w nación|strong="H1471"\w* ha \w subido|strong="H5927"\w* \w contra|strong="H5921"\w* \w mi|strong="H5921"\w* tierra, \w fuerte|strong="H6099"\w* \w e|strong="H3068"\w* innumerable.  
\q2 Sus \w dientes|strong="H8127"\w* \w son|strong="H3588"\w* \w dientes|strong="H8127"\w* \w de|strong="H5921"\w* león,  
\q2 \w y|strong="H3588"\w* tiene muelas \w de|strong="H5921"\w* leona.   
\q1
\v 7 Ha \w asolado|strong="H8047"\w* mi \w vid|strong="H1612"\w*,  
\q2 y descortezado mi higuera.  
\q2 Del todo la \w desnudó|strong="H2834"\w* y la \w derribó|strong="H7993"\w*;  
\q2 sus ramas quedaron blancas.   
\q1
\v 8 Llora tú \w como|strong="H5921"\w* joven \w vestida|strong="H2296"\w* \w de|strong="H5921"\w* cilicio  
\q2 ¡\w por|strong="H5921"\w* \w el|strong="H5921"\w* \w marido|strong="H1167"\w* \w de|strong="H5921"\w* su \w juventud|strong="H5271"\w*!   
\q1
\v 9 La \w ofrenda|strong="H4503"\w* y la \w libación|strong="H5262"\w* han sido quitadas de la \w casa|strong="H1004"\w* de Yahvé;  
\q2 los \w sacerdotes|strong="H3548"\w*, \w ministros|strong="H8334"\w* de Yahvé, están de duelo.   
\q1
\v 10 \w El|strong="H3588"\w* \w campo|strong="H7704"\w* está asolado.  
\q2 Se enlutó \w la|strong="H3588"\w* tierra, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w trigo|strong="H1715"\w* fue \w destruido|strong="H7703"\w*;  
\q2 \w el|strong="H3588"\w* \w mosto|strong="H8492"\w* se \w secó|strong="H3001"\w*,  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w aceite|strong="H3323"\w* languidece.   
\q1
\v 11 ¡Confundíos, labradores!  
\q2 \w Aullad|strong="H3213"\w*, viñaderos,  
\q2 \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w trigo|strong="H2406"\w* \w y|strong="H3588"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w cebada|strong="H8184"\w*;  
\q2 \w porque|strong="H3588"\w* \w la|strong="H5921"\w* \w mies|strong="H7105"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* ha perecido.   
\q1
\v 12 \w La|strong="H1571"\w* \w vid|strong="H1612"\w* \w se|strong="H4480"\w* \w secó|strong="H3001"\w*, \w y|strong="H1571"\w* pereció \w la|strong="H1571"\w* higuera;  
\q2 \w el|strong="H3588"\w* granado \w también|strong="H1571"\w*, \w la|strong="H1571"\w* palmera \w y|strong="H1571"\w* \w el|strong="H3588"\w* manzano;  
\q2 \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w árboles|strong="H6086"\w* \w del|strong="H4480"\w* \w campo|strong="H7704"\w* \w se|strong="H4480"\w* secaron,  
\q2 \w por|strong="H3588"\w* \w lo|strong="H3605"\w* \w cual|strong="H3588"\w* \w el|strong="H3588"\w* \w gozo|strong="H8342"\w* \w se|strong="H4480"\w* extinguió \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*.   
\q1
\v 13 ¡\w Ceñíos|strong="H2296"\w* \w de|strong="H3588"\w* cilicio \w y|strong="H3588"\w* lamentad, \w sacerdotes|strong="H3548"\w*!  
\q2 \w Aullad|strong="H3213"\w*, \w ministros|strong="H8334"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*.  
\q1 Venid, pasad \w la|strong="H3588"\w* noche \w en|strong="H3588"\w* cilicio, \w ministros|strong="H8334"\w* \w de|strong="H3588"\w* mi Dios,  
\q2 \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w ofrenda|strong="H4503"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w libación|strong="H5262"\w* han sido retenidas \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* vuestro Dios.   
\q1
\v 14 \w Proclamad|strong="H7121"\w* \w ayuno|strong="H6685"\w*.  
\q2 Convocad asamblea solemne.  
\q2 Congregad \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de \w la|strong="H3605"\w* tierra en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de Yahvé vuestro \w Dios|strong="H3068"\w*,  
\q2 y clamad \w a|strong="H3068"\w* Yahvé.   
\q1
\v 15 ¡Ay del \w día|strong="H3117"\w*!  
\q2 \w Porque|strong="H3588"\w* \w cercano|strong="H7138"\w* está \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* Yahvé,  
\q2 \w y|strong="H3588"\w* vendrá \w como|strong="H3588"\w* \w destrucción|strong="H7701"\w* del \w Todopoderoso|strong="H7706"\w*.   
\q1
\v 16 ¿\w No|strong="H3808"\w* \w ha|strong="H3808"\w* sido quitado el alimento \w de|strong="H5048"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* nuestros \w ojos|strong="H5869"\w*,  
\q2 y la \w alegría|strong="H8057"\w* y el \w gozo|strong="H8057"\w* \w de|strong="H5048"\w* la \w casa|strong="H1004"\w* \w de|strong="H5048"\w* nuestro Dios?   
\q1
\v 17 \w La|strong="H3588"\w* semilla se pudrió \w debajo|strong="H8478"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* terrones.  
\q2 \w Los|strong="H3588"\w* graneros fueron \w asolados|strong="H8074"\w*.  
\q2 \w Los|strong="H3588"\w* alfolíes fueron \w destruidos|strong="H2040"\w*, \w porque|strong="H3588"\w* se \w secó|strong="H3001"\w* \w el|strong="H3588"\w* \w trigo|strong="H1715"\w*.   
\q1
\v 18 ¡\w Cómo|strong="H4100"\w* gimen \w las|strong="H1992"\w* bestias!  
\q2 \w Cuán|strong="H4100"\w* turbados andan \w los|strong="H1992"\w* hatos \w de|strong="H3588"\w* \w bueyes|strong="H1241"\w*, \w porque|strong="H3588"\w* \w no|strong="H3588"\w* \w tienen|strong="H1992"\w* \w pastos|strong="H4829"\w*.  
\q2 \w También|strong="H1571"\w* \w son|strong="H3588"\w* asolados \w los|strong="H1992"\w* \w rebaños|strong="H5739"\w* \w de|strong="H3588"\w* \w ovejas|strong="H6629"\w*.   
\q1
\v 19 \w A|strong="H3068"\w* ti, oh Yahvé, \w clamaré|strong="H7121"\w*,  
\q2 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* fuego consumió \w los|strong="H3605"\w* pastos del \w desierto|strong="H4057"\w*,  
\q2 \w y|strong="H3588"\w* \w la|strong="H3605"\w* \w llama|strong="H7121"\w* \w abrasó|strong="H3857"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* del \w campo|strong="H7704"\w*.   
\q1
\v 20 Las bestias del \w campo|strong="H7704"\w* \w también|strong="H1571"\w* claman \w a|strong="H3068"\w* ti,  
\q2 \w porque|strong="H3588"\w* se secaron \w los|strong="H3588"\w* arroyos \w de|strong="H3588"\w* las \w aguas|strong="H4325"\w*,  
\q2 \w y|strong="H1571"\w* \w el|strong="H3588"\w* fuego consumió \w los|strong="H3588"\w* pastos del \w desierto|strong="H4057"\w*.   
\b  
\c 2
\q1
\v 1 ¡\w Tocad|strong="H8628"\w* \w la|strong="H3588"\w* \w trompeta|strong="H7782"\w* \w en|strong="H3588"\w* \w Sión|strong="H6726"\w*,  
\q2 \w y|strong="H3588"\w* dad \w la|strong="H3588"\w* alarma \w en|strong="H3588"\w* mi \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*!  
\q1 \w Que|strong="H3588"\w* \w tiemblen|strong="H7264"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra,  
\q2 \w porque|strong="H3588"\w* viene \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* Yahvé,  
\q2 \w porque|strong="H3588"\w* \w está|strong="H3427"\w* muy \w cercano|strong="H7138"\w*:   
\q1
\v 2 un \w día|strong="H3117"\w* \w de|strong="H4480"\w* \w tinieblas|strong="H2822"\w* \w y|strong="H5921"\w* \w oscuridad|strong="H6205"\w*,  
\q2 un \w día|strong="H3117"\w* \w de|strong="H4480"\w* \w nubes|strong="H6051"\w* \w y|strong="H5921"\w* densa niebla.  
\q1 \w Como|strong="H3644"\w* \w el|strong="H5921"\w* alba \w que|strong="H4480"\w* \w se|strong="H1961"\w* \w extiende|strong="H6566"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*,  
\q2 viene un \w pueblo|strong="H5971"\w* \w grande|strong="H7227"\w* \w y|strong="H5921"\w* \w fuerte|strong="H6099"\w*;  
\q2 \w nunca|strong="H3808"\w* \w ha|strong="H3808"\w* habido \w nada|strong="H3808"\w* semejante \w desde|strong="H4480"\w* \w la|strong="H5921"\w* antigüedad,  
\q2 \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* \w habrá|strong="H1961"\w* \w después|strong="H5921"\w* \w de|strong="H4480"\w* \w ellos|strong="H5921"\w*,  
\q2 \w ni|strong="H3808"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w años|strong="H8141"\w* \w de|strong="H4480"\w* \w muchas|strong="H7227"\w* \w generaciones|strong="H1755"\w*.   
\q1
\v 3 \w Delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H1571"\w* consume \w el|strong="H1571"\w* fuego,  
\q2 \w y|strong="H1571"\w* detrás \w de|strong="H6440"\w* \w ellos|strong="H1571"\w* arde una \w llama|strong="H3852"\w*.  
\q1 \w Como|strong="H1571"\w* \w el|strong="H1571"\w* \w huerto|strong="H1588"\w* del Edén \w es|strong="H1961"\w* \w la|strong="H1571"\w* tierra \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H1571"\w*,  
\q2 \w y|strong="H1571"\w* detrás \w de|strong="H6440"\w* \w ellos|strong="H1571"\w*, un \w desierto|strong="H4057"\w* desolado;  
\q1 \w sí|strong="H1571"\w*, \w y|strong="H1571"\w* \w nada|strong="H3808"\w* \w escapará|strong="H1961"\w* \w de|strong="H6440"\w* \w ellos|strong="H1571"\w*.   
\q1
\v 4 Su \w aspecto|strong="H4758"\w* es \w como|strong="H3651"\w* el \w aspecto|strong="H4758"\w* de los \w caballos|strong="H5483"\w*,  
\q2 y \w corren|strong="H7323"\w* \w como|strong="H3651"\w* \w jinetes|strong="H6571"\w*.   
\q1
\v 5 \w Como|strong="H5921"\w* \w estruendo|strong="H6963"\w* \w de|strong="H5921"\w* \w carros|strong="H4818"\w* saltan \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* cumbres \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*,  
\q2 \w como|strong="H5921"\w* \w el|strong="H5921"\w* crepitar \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w llama|strong="H3851"\w* \w de|strong="H5921"\w* fuego \w que|strong="H5921"\w* consume \w el|strong="H5921"\w* \w rastrojo|strong="H7179"\w*,  
\q2 \w como|strong="H5921"\w* un \w pueblo|strong="H5971"\w* \w fuerte|strong="H6099"\w* dispuesto \w en|strong="H5921"\w* orden \w de|strong="H5921"\w* \w batalla|strong="H4421"\w*.   
\q1
\v 6 \w Ante|strong="H6440"\w* \w ellos|strong="H3605"\w* \w se|strong="H5971"\w* angustian \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*;  
\q2 \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w rostros|strong="H6440"\w* palidecen.   
\q1
\v 7 \w Corren|strong="H7323"\w* como \w valientes|strong="H1368"\w*;  
\q2 escalan el \w muro|strong="H2346"\w* como \w hombres|strong="H1368"\w* de \w guerra|strong="H4421"\w*.  
\q2 Cada uno \w marcha|strong="H1870"\w* \w por|strong="H1870"\w* su \w camino|strong="H1870"\w*, y \w no|strong="H3808"\w* tuercen su rumbo.   
\q1
\v 8 \w Ninguno|strong="H3808"\w* empuja \w a|strong="H3068"\w* su compañero;  
\q2 cada cual marcha \w por|strong="H1157"\w* su propia senda.  
\q2 \w Se|strong="H3808"\w* abalanzan sobre las defensas  
\q2 \w sin|strong="H3808"\w* romper filas.   
\q1
\v 9 Se precipitan sobre la \w ciudad|strong="H5892"\w*,  
\q2 \w corren|strong="H7323"\w* \w por|strong="H1157"\w* la muralla,  
\q2 \w suben|strong="H5927"\w* \w a|strong="H3068"\w* las \w casas|strong="H1004"\w*,  
\q2 y entran \w por|strong="H1157"\w* las \w ventanas|strong="H2474"\w* como \w ladrones|strong="H1590"\w*.   
\q1
\v 10 La tierra \w tiembla|strong="H7493"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos;  
\q2 los \w cielos|strong="H8064"\w* se estremecen.  
\q2 El \w sol|strong="H8121"\w* y la \w luna|strong="H3394"\w* se oscurecen,  
\q2 y las \w estrellas|strong="H3556"\w* retiran su \w resplandor|strong="H5051"\w*.   
\q1
\v 11 Yahvé \w hace|strong="H6213"\w* oír \w su|strong="H3588"\w* \w voz|strong="H6963"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w ejército|strong="H2426"\w*,  
\q2 \w porque|strong="H3588"\w* \w muy|strong="H3966"\w* \w grande|strong="H1419"\w* \w es|strong="H3588"\w* \w su|strong="H3588"\w* \w campamento|strong="H4264"\w*;  
\q2 \w porque|strong="H3588"\w* \w fuerte|strong="H6099"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* ejecuta \w su|strong="H3588"\w* orden;  
\q2 \w porque|strong="H3588"\w* \w grande|strong="H1419"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* Yahvé, \w y|strong="H3588"\w* \w muy|strong="H3966"\w* \w terrible|strong="H3372"\w*.  
\q2 ¿\w Y|strong="H3068"\w* \w quién|strong="H4310"\w* podrá soportarlo?   
\q1
\v 12 «\w Por|strong="H5704"\w* eso \w ahora|strong="H6258"\w* —\w dice|strong="H5002"\w* Yahvé—, \w volveos|strong="H7725"\w* \w a|strong="H3068"\w* mí \w con|strong="H1571"\w* \w todo|strong="H3605"\w* vuestro \w corazón|strong="H3824"\w*,  
\q2 \w con|strong="H1571"\w* \w ayuno|strong="H6685"\w*, \w con|strong="H1571"\w* \w lloro|strong="H1065"\w* \w y|strong="H1571"\w* \w con|strong="H1571"\w* lamento».   
\q1
\v 13 Rasgad vuestro \w corazón|strong="H3824"\w* \w y|strong="H3588"\w* \w no|strong="H3588"\w* vuestros vestidos,  
\q2 \w y|strong="H3588"\w* \w convertíos|strong="H7725"\w* \w a|strong="H3068"\w* Yahvé vuestro \w Dios|strong="H3068"\w*;  
\q2 \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w es|strong="H1931"\w* \w clemente|strong="H2587"\w* \w y|strong="H3588"\w* \w misericordioso|strong="H7349"\w*,  
\q2 lento \w para|strong="H5921"\w* \w la|strong="H1931"\w* ira, \w grande|strong="H7227"\w* \w en|strong="H5921"\w* \w misericordia|strong="H2617"\w*,  
\q2 \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H1931"\w* duele \w del|strong="H5921"\w* \w castigo|strong="H7451"\w*.   
\q1
\v 14 ¿\w Quién|strong="H4310"\w* \w sabe|strong="H3045"\w* si \w volverá|strong="H7725"\w* y \w se|strong="H3045"\w* apiadará,  
\q2 y dejará tras sí una \w bendición|strong="H1293"\w*,  
\q2 una \w ofrenda|strong="H4503"\w* y una \w libación|strong="H5262"\w* para Yahvé, vuestro \w Dios|strong="H3068"\w*?   
\q1
\v 15 ¡\w Tocad|strong="H8628"\w* la \w trompeta|strong="H7782"\w* en \w Sión|strong="H6726"\w*!  
\q2 \w Proclamad|strong="H7121"\w* \w ayuno|strong="H6685"\w*,  
\q2 convocad asamblea solemne.   
\q1
\v 16 Congregad al \w pueblo|strong="H5971"\w*,  
\q2 \w santificad|strong="H6942"\w* la asamblea,  
\q2 reunid \w a|strong="H3068"\w* los \w ancianos|strong="H2205"\w*.  
\q2 Reunid \w a|strong="H3068"\w* los \w niños|strong="H5768"\w* y \w a|strong="H3068"\w* los \w de|strong="H5971"\w* pecho.  
\q1 \w Salga|strong="H3318"\w* el novio \w de|strong="H5971"\w* su alcoba,  
\q2 y la novia \w de|strong="H5971"\w* su \w cámara|strong="H2315"\w*.   
\q1
\v 17 \w Entre|strong="H5921"\w* \w el|strong="H5921"\w* pórtico \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w lloren|strong="H1058"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w*, \w ministros|strong="H8334"\w* \w de|strong="H5921"\w* Yahvé,  
\q2 \w y|strong="H5921"\w* digan: “Perdona, \w oh|strong="H4100"\w* Yahvé, \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*,  
\q2 \w y|strong="H5921"\w* \w no|strong="H5921"\w* \w entregues|strong="H5414"\w* tu \w heredad|strong="H5159"\w* \w al|strong="H5921"\w* \w oprobio|strong="H2781"\w*,  
\q2 \w para|strong="H5921"\w* \w que|strong="H4100"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w se|strong="H5921"\w* enseñoreen \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\q1 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* han \w de|strong="H5921"\w* decir \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w*:  
\q2 ‘\w Dónde|strong="H5921"\w* \w está|strong="H5921"\w* su \w Dios|strong="H3068"\w*’?”   
\q1
\v 18 Entonces Yahvé \w se|strong="H5921"\w* llenó \w de|strong="H5921"\w* \w celo|strong="H7065"\w* \w por|strong="H5921"\w* su tierra,  
\q2 \w y|strong="H5921"\w* \w perdonó|strong="H2550"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*.   
\q1
\v 19 \w Respondió|strong="H6030"\w* Yahvé \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*:  
\q2 «He \w aquí|strong="H2005"\w*, yo os \w enviaré|strong="H7971"\w* \w trigo|strong="H1715"\w*, \w mosto|strong="H8492"\w* y \w aceite|strong="H3323"\w*,  
\q2 y seréis saciados \w de|strong="H5750"\w* ellos;  
\q2 y \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* os \w pondré|strong="H5414"\w* \w como|strong="H5750"\w* \w oprobio|strong="H2781"\w* \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w*.   
\q1
\v 20 \w Y|strong="H3068"\w* alejaré \w de|strong="H5921"\w* vosotros \w al|strong="H5921"\w* ejército \w del|strong="H5921"\w* norte,  
\q2 \w y|strong="H3588"\w* \w lo|strong="H5921"\w* arrojaré \w a|strong="H3068"\w* una tierra \w seca|strong="H6723"\w* \w y|strong="H3588"\w* \w desierta|strong="H8077"\w*;  
\q2 \w su|strong="H3588"\w* vanguardia \w hacia|strong="H6213"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* oriental,  
\q2 \w y|strong="H3588"\w* \w su|strong="H3588"\w* retaguardia \w hacia|strong="H6213"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w occidental|strong="H3220"\w*;  
\q2 \w y|strong="H3588"\w* \w subirá|strong="H5927"\w* \w su|strong="H3588"\w* hedor,  
\q2 \w y|strong="H3588"\w* \w se|strong="H5921"\w* elevará \w su|strong="H3588"\w* pudrición».  
\q1 \w Porque|strong="H3588"\w* ha \w hecho|strong="H6213"\w* \w grandes|strong="H1431"\w* cosas.   
\q1
\v 21 Tierra, \w no|strong="H6213"\w* \w temas|strong="H3372"\w*;  
\q2 \w alégrate|strong="H8055"\w* \w y|strong="H3588"\w* regocíjate, \w porque|strong="H3588"\w* Yahvé ha \w hecho|strong="H6213"\w* \w grandes|strong="H1431"\w* cosas.   
\q1
\v 22 \w No|strong="H3588"\w* \w temáis|strong="H3372"\w*, bestias del \w campo|strong="H7704"\w*;  
\q2 \w porque|strong="H3588"\w* \w los|strong="H3588"\w* pastos del \w desierto|strong="H4057"\w* han reverdecido,  
\q2 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w árbol|strong="H6086"\w* ha \w dado|strong="H5414"\w* \w su|strong="H3588"\w* \w fruto|strong="H6529"\w*.  
\q2 \w La|strong="H3588"\w* higuera \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w vid|strong="H1612"\w* han \w entregado|strong="H5414"\w* \w su|strong="H3588"\w* vigor.   
\b  
\q1
\v 23 “\w Alegraos|strong="H8055"\w*, \w pues|strong="H3588"\w*, \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Sión|strong="H6726"\w*,  
\q2 \w y|strong="H3588"\w* regocijaos \w en|strong="H3588"\w* Yahvé vuestro \w Dios|strong="H3068"\w*;  
\q2 \w porque|strong="H3588"\w* os ha \w dado|strong="H5414"\w* \w la|strong="H3588"\w* \w primera|strong="H7223"\w* \w lluvia|strong="H1653"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* tiempo,  
\q2 \w y|strong="H3588"\w* \w hará|strong="H5414"\w* descender sobre vosotros \w la|strong="H3588"\w* \w lluvia|strong="H1653"\w*,  
\q2 \w la|strong="H3588"\w* \w lluvia|strong="H1653"\w* \w temprana|strong="H4175"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w tardía|strong="H4456"\w*, \w como|strong="H3588"\w* al \w principio|strong="H5414"\w*.   
\q1
\v 24 Las eras se llenarán de \w trigo|strong="H1250"\w*,  
\q2 y los lagares rebosarán de \w mosto|strong="H8492"\w* y \w aceite|strong="H3323"\w*.   
\q1
\v 25 Os restituiré los \w años|strong="H8141"\w* que devoró la langosta,  
\q2 el saltón, el pulgón y la oruga,  
\q2 mi \w gran|strong="H1419"\w* \w ejército|strong="H2428"\w* que \w envié|strong="H7971"\w* contra vosotros.   
\q1
\v 26 Comeréis hasta saciaros,  
\q2 y alabaréis \w el|strong="H5973"\w* \w nombre|strong="H8034"\w* \w de|strong="H5973"\w* Yahvé vuestro \w Dios|strong="H3068"\w*,  
\q2 \w el|strong="H5973"\w* \w cual|strong="H5973"\w* \w hizo|strong="H6213"\w* \w maravillas|strong="H6381"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*;  
\q2 y mi \w pueblo|strong="H5971"\w* \w nunca|strong="H3808"\w* \w más|strong="H3808"\w* \w será|strong="H3808"\w* avergonzado.   
\q1
\v 27 \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* estoy \w yo|strong="H3588"\w*,  
\q2 \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé vuestro \w Dios|strong="H3068"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w hay|strong="H5750"\w* \w otro|strong="H5750"\w*;  
\q2 \w y|strong="H3588"\w* mi \w pueblo|strong="H5971"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w será|strong="H3808"\w* avergonzado.   
\b  
\q1
\v 28 “\w Y|strong="H3068"\w* después de esto derramaré mi Espíritu sobre toda carne;  
\q2 y profetizarán vuestros hijos y vuestras hijas;  
\q2 vuestros ancianos soñarán sueños,  
\q2 y vuestros jóvenes verán visiones.   
\q1
\v 29 \w Y|strong="H3068"\w* también sobre los siervos y sobre las siervas derramaré mi Espíritu  
\q2 en aquellos días.   
\q1
\v 30 \w Y|strong="H3068"\w* daré prodigios en el cielo y en la tierra:  
\q2 sangre, fuego y columnas de humo.   
\q1
\v 31 El sol se convertirá en tinieblas,  
\q2 y la luna en sangre,  
\q2 antes que venga el día grande y espantoso de Yahvé.   
\q1
\v 32 \w Y|strong="H3068"\w* todo aquel que invoque el nombre de Yahvé será salvo;  
\q2 porque en el monte de Sión y en Jerusalén habrá salvación,  
\q2 como ha dicho Yahvé,  
\q2 y entre el remanente al cual él habrá llamado.   
\b  
\c 3
\q1
\v 1 “\w Porque|strong="H5921"\w* he aquí, \w en|strong="H5921"\w* \w aquellos|strong="H3605"\w* días  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w aquel|strong="H3605"\w* tiempo,  
\q2 \w cuando|strong="H1961"\w* yo haga volver \w a|strong="H3068"\w* \w los|strong="H1121"\w* cautivos \w de|strong="H5921"\w* Judá \w y|strong="H5921"\w* \w de|strong="H5921"\w* Jerusalén,   
\q1
\v 2 reuniré \w a|strong="H3068"\w* todas \w las|strong="H1992"\w* naciones,  
\q2 \w y|strong="H1571"\w* \w las|strong="H1992"\w* haré descender \w al|strong="H5921"\w* valle \w de|strong="H5921"\w* Josafat;  
\q2 \w y|strong="H1571"\w* allí entraré \w en|strong="H5921"\w* juicio \w con|strong="H5921"\w* \w ellas|strong="H1992"\w* \w a|strong="H3068"\w* favor \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H1992"\w*,  
\q2 \w y|strong="H1571"\w* \w por|strong="H5921"\w* \w mi|strong="H5921"\w* heredad, Israel, \w a|strong="H3068"\w* quien \w ellas|strong="H1992"\w* esparcieron \w entre|strong="H5921"\w* \w las|strong="H1992"\w* naciones.  
\q2 Han repartido \w mi|strong="H5921"\w* tierra,   
\q2
\v 3 y han echado suertes sobre mi pueblo;  
\q2 han \w dado|strong="H5414"\w* \w a|strong="H3068"\w* un niño \w a|strong="H3068"\w* cambio \w de|strong="H5414"\w* una ramera,  
\q2 y vendieron \w a|strong="H3068"\w* una muchacha \w por|strong="H5414"\w* vino, \w para|strong="H5414"\w* poder beber.   
\b  
\q1
\v 4 «\w Y|strong="H3068"\w* también, ¿\w qué|strong="H3117"\w* tenéis vosotras conmigo, Tiro y Sidón,  
\q2 y todas las regiones \w de|strong="H6440"\w* Filistea?  
\q1 ¿Queréis vengaros \w de|strong="H6440"\w* mí?  
\q2 \w Y|strong="H3068"\w* \w si|strong="H6440"\w* \w de|strong="H6440"\w* mí os vengáis,  
\q2 bien pronto haré recaer la paga sobre vuestra propia cabeza.   
\q1
\v 5 \w Porque|strong="H3588"\w* habéis tomado \w mi|strong="H3389"\w* plata \w y|strong="H3588"\w* \w mi|strong="H3389"\w* oro,  
\q2 \w y|strong="H3588"\w* habéis llevado mis mejores tesoros \w a|strong="H3068"\w* vuestros templos;   
\q2
\v 6 y habéis vendido los hijos de Judá y los hijos de Jerusalén \w a|strong="H3068"\w* los hijos de los griegos,  
\q2 para alejarlos de sus fronteras.   
\q1
\v 7 He aquí, yo los levantaré del lugar donde los habéis vendido,  
\q2 y haré recaer la paga sobre vuestra cabeza;   
\q1
\v 8 y venderé vuestros hijos y vuestras hijas en manos de los hijos de Judá,  
\q2 y ellos los venderán \w a|strong="H3068"\w* los sabeos,  
\q2 \w a|strong="H3068"\w* una nación lejana;  
\q2 porque Yahvé lo ha dicho».   
\b  
\q1
\v 9 Proclamad esto entre las naciones:  
\q2 “¡Preparaos para la guerra!  
\q2 Despertad \w a|strong="H3068"\w* los valientes.  
\q1 Que se acerquen todos los hombres de guerra.  
\q2 Que suban.  
\v 10 Forjad espadas de vuestros azadones,  
\q2 y lanzas de vuestras hoces.  
\q2 Diga el débil: «Fuerte soy».   
\q1
\v 11 Juntaos y venid, todas las naciones de alrededor,  
\q2 y congregaos”.  
\q1 Haz descender allí, oh Yahvé, \w a|strong="H3068"\w* tus valientes.   
\q1
\v 12 «Despiértense las naciones,  
\q2 y suban al valle de Josafat;  
\q2 porque allí me sentaré para juzgar \w a|strong="H3068"\w* todas las naciones de alrededor.   
\q1
\v 13 Meted la hoz,  
\q2 porque la mies está madura.  
\q2 Venid, pisad, porque el lagar está lleno;  
\q2 las cubas rebosan, porque grande es la maldad de ellos».   
\q1
\v 14 ¡Multitudes, multitudes en el valle de la decisión!  
\q2 Porque cercano está el día de Yahvé en el valle de la decisión.   
\q1
\v 15 El sol y la luna se oscurecen,  
\q2 y las estrellas retiran su resplandor.   
\q1
\v 16 \w Y|strong="H3068"\w* Yahvé rugirá desde Sión,  
\q2 y dará su voz desde Jerusalén;  
\q2 y los cielos y la tierra temblarán.  
\q2 Pero Yahvé será el refugio de su pueblo,  
\q2 y la fortaleza de los hijos de Israel.   
\q1
\v 17 «\w Y|strong="H3068"\w* sabréis que yo soy Yahvé vuestro Dios,  
\q2 que habito en Sión, mi santo monte.  
\q1 Entonces Jerusalén será santa,  
\q2 y los extraños no volverán \w a|strong="H3068"\w* pasar por ella.   
\q1
\v 18 \w Y|strong="H3068"\w* sucederá en aquel día,  
\q2 que los montes destilarán mosto,  
\q2 los collados fluirán con leche,  
\q2 y por todos los arroyos de Judá correrán las aguas;  
\q2 y saldrá un manantial de la casa de Yahvé,  
\q2 y regará el valle de Sitim.   
\q1
\v 19 Egipto será una desolación,  
\q2 y Edom será un desierto desolado,  
\q2 por la violencia hecha \w a|strong="H3068"\w* los hijos de Judá,  
\q2 porque derramaron sangre inocente en su tierra.   
\q1
\v 20 Pero Judá será habitada para siempre,  
\q2 y Jerusalén de generación en generación.   
\q1
\v 21 \w Y|strong="H3068"\w* limpiaré la sangre de ellos,  
\q2 la cual aún no había limpiado;  
\q2 porque Yahvé habita en Sión».   