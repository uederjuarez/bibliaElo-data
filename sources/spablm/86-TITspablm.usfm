\mt2 La carta del Apóstol San Pablo a  
\mt1 Tito  
\c 1
\p
\v 1 \w Pablo|strong="G3972"\w*, \w siervo|strong="G1401"\w* \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* apóstol \w de|strong="G2596"\w* \w Jesucristo|strong="G2424"\w*, \w conforme|strong="G2596"\w* \w a|strong="G2596"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w de|strong="G2596"\w* \w los|strong="G3588"\w* \w elegidos|strong="G1588"\w* \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w el|strong="G3588"\w* \w conocimiento|strong="G1922"\w* \w de|strong="G2596"\w* \w la|strong="G3588"\w* \w verdad|strong="G4102"\w* \w que|strong="G3588"\w* es \w según|strong="G2596"\w* \w la|strong="G3588"\w* \w piedad|strong="G2150"\w*,  
\v 2 \w en|strong="G1909"\w* \w la|strong="G3588"\w* \w esperanza|strong="G1680"\w* \w de|strong="G1909"\w* \w la|strong="G3588"\w* \w vida|strong="G2222"\w* eterna, \w la|strong="G3588"\w* \w cual|strong="G3739"\w* \w Dios|strong="G2316"\w*, \w que|strong="G3588"\w* no miente, \w prometió|strong="G1861"\w* \w desde|strong="G1909"\w* \w antes|strong="G4253"\w* \w del|strong="G3588"\w* principio \w de|strong="G1909"\w* \w los|strong="G3588"\w* siglos,  
\v 3 \w y|strong="G1161"\w* \w a|strong="G1722"\w* \w su|strong="G3588"\w* debido \w tiempo|strong="G2540"\w* \w manifestó|strong="G5319"\w* \w su|strong="G3588"\w* \w palabra|strong="G3056"\w* \w por|strong="G1722"\w* medio \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w predicación|strong="G2782"\w* \w que|strong="G3588"\w* \w me|strong="G1473"\w* fue encomendada \w por|strong="G1722"\w* mandato \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*,  
\v 4 \w a|strong="G2596"\w* \w Tito|strong="G5103"\w*, \w verdadero|strong="G1103"\w* \w hijo|strong="G5043"\w* \w en|strong="G2596"\w* \w la|strong="G3588"\w* \w común|strong="G2839"\w* \w fe|strong="G4102"\w*: \w Gracia|strong="G5485"\w*, misericordia \w y|strong="G2532"\w* \w paz|strong="G1515"\w* \w de|strong="G2596"\w* parte \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w Padre|strong="G3962"\w* \w y|strong="G2532"\w* \w del|strong="G3588"\w* \w Señor|strong="G2316"\w* \w Jesucristo|strong="G2424"\w*, \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*.   
\p
\v 5 \w Por|strong="G1722"\w* \w esta|strong="G3778"\w* \w causa|strong="G5484"\w* \w te|strong="G4771"\w* dejé \w en|strong="G1722"\w* \w Creta|strong="G2914"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w corrigieses|strong="G1930"\w* \w lo|strong="G3588"\w* deficiente \w y|strong="G2532"\w* establecieses \w ancianos|strong="G4245"\w* \w en|strong="G1722"\w* \w cada|strong="G2596"\w* \w ciudad|strong="G4172"\w*, \w así|strong="G2532"\w* \w como|strong="G5613"\w* \w te|strong="G4771"\w* \w mandé|strong="G1299"\w*:  
\v 6 \w el|strong="G5100"\w* \w que|strong="G5101"\w* \w fuere|strong="G2228"\w* irreprensible, marido \w de|strong="G1722"\w* \w una|strong="G1520"\w* sola \w mujer|strong="G1135"\w*, \w que|strong="G5101"\w* \w tenga|strong="G2192"\w* \w hijos|strong="G5043"\w* creyentes \w que|strong="G5101"\w* \w no|strong="G3361"\w* estén acusados \w de|strong="G1722"\w* disolución \w ni|strong="G2228"\w* \w de|strong="G1722"\w* rebeldía.  
\v 7 \w Porque|strong="G1063"\w* es \w necesario|strong="G1163"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* \w obispo|strong="G1985"\w* \w sea|strong="G3588"\w* irreprensible, \w como|strong="G5613"\w* administrador \w de|strong="G3588"\w* \w Dios|strong="G2316"\w*; \w no|strong="G3361"\w* soberbio, \w no|strong="G3361"\w* \w iracundo|strong="G3711"\w*, \w no|strong="G3361"\w* dado \w al|strong="G3588"\w* vino, \w no|strong="G3361"\w* pendenciero, \w no|strong="G3361"\w* codicioso \w de|strong="G3588"\w* ganancias deshonestas,  
\v 8 sino \w hospedador|strong="G5382"\w*, amante de lo bueno, sobrio, \w justo|strong="G1342"\w*, \w santo|strong="G3741"\w*, dueño de sí mismo,  
\v 9 retenedor \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w palabra|strong="G3056"\w* \w fiel|strong="G4103"\w* tal \w como|strong="G2532"\w* ha sido enseñada, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w también|strong="G2532"\w* \w pueda|strong="G1415"\w* \w exhortar|strong="G3870"\w* \w con|strong="G1722"\w* \w sana|strong="G5198"\w* \w enseñanza|strong="G1319"\w* \w y|strong="G2532"\w* \w convencer|strong="G1651"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* contradicen.   
\p
\v 10 \w Porque|strong="G1063"\w* \w hay|strong="G3588"\w* \w aún|strong="G2532"\w* \w muchos|strong="G4183"\w* contumaces, habladores \w de|strong="G1537"\w* vanidades \w y|strong="G2532"\w* \w engañadores|strong="G5423"\w*, \w mayormente|strong="G3122"\w* \w los|strong="G3588"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w circuncisión|strong="G4061"\w*,  
\v 11 a \w los|strong="G3748"\w* \w cuales|strong="G3739"\w* \w es|strong="G3739"\w* \w preciso|strong="G1163"\w* \w tapar|strong="G1993"\w* la boca; \w que|strong="G3739"\w* trastornan \w casas|strong="G3624"\w* \w enteras|strong="G3650"\w*, \w enseñando|strong="G1321"\w* \w por|strong="G5484"\w* ganancia deshonesta \w lo|strong="G3739"\w* \w que|strong="G3739"\w* \w no|strong="G3361"\w* \w conviene|strong="G1163"\w*.  
\v 12 \w Uno|strong="G5100"\w* \w de|strong="G1537"\w* \w ellos|strong="G1537"\w*, \w su|strong="G2398"\w* \w propio|strong="G2398"\w* \w profeta|strong="G4396"\w*, \w dijo|strong="G3004"\w*: «\w Los|strong="G5100"\w* \w cretenses|strong="G2912"\w*, siempre \w mentirosos|strong="G5583"\w*, \w malas|strong="G2556"\w* \w bestias|strong="G2342"\w*, glotones perezosos».  
\v 13 \w Este|strong="G3778"\w* \w testimonio|strong="G3141"\w* \w es|strong="G3739"\w* verdadero; \w por|strong="G1223"\w* \w tanto|strong="G3739"\w*, \w repréndelos|strong="G1651"\w* duramente, \w para|strong="G2443"\w* \w que|strong="G3588"\w* sean \w sanos|strong="G5198"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w*,  
\v 14 \w no|strong="G3361"\w* \w atendiendo|strong="G4337"\w* a \w fábulas|strong="G3454"\w* \w judaicas|strong="G2451"\w*, \w ni|strong="G2532"\w* a \w mandamientos|strong="G1785"\w* \w de|strong="G3588"\w* hombres \w que|strong="G3588"\w* \w se|strong="G2532"\w* apartan \w de|strong="G3588"\w* \w la|strong="G3588"\w* verdad.  
\v 15 \w Todas|strong="G3956"\w* \w las|strong="G3588"\w* cosas son puras para \w los|strong="G3588"\w* puros, \w mas|strong="G1161"\w* para \w los|strong="G3588"\w* corrompidos \w e|strong="G2532"\w* incrédulos \w nada|strong="G3762"\w* les es \w puro|strong="G2513"\w*; \w pues|strong="G1161"\w* hasta \w su|strong="G3588"\w* \w mente|strong="G3563"\w* \w y|strong="G2532"\w* \w su|strong="G3588"\w* \w conciencia|strong="G4893"\w* están corrompidas.  
\v 16 Profesan \w conocer|strong="G1492"\w* \w a|strong="G4314"\w* \w Dios|strong="G2316"\w*, \w pero|strong="G1161"\w* \w con|strong="G4314"\w* \w los|strong="G3588"\w* \w hechos|strong="G2041"\w* \w lo|strong="G3588"\w* niegan, \w siendo|strong="G1161"\w* abominables \w y|strong="G2532"\w* rebeldes, reprobados \w en|strong="G4314"\w* \w cuanto|strong="G3588"\w* \w a|strong="G4314"\w* \w toda|strong="G3956"\w* buena \w obra|strong="G2041"\w*.   
\c 2
\p
\v 1 \w Pero|strong="G1161"\w* \w tú|strong="G4771"\w* \w habla|strong="G2980"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \w está|strong="G3588"\w* \w de|strong="G3588"\w* acuerdo \w con|strong="G3739"\w* \w la|strong="G3588"\w* \w sana|strong="G5198"\w* \w doctrina|strong="G1319"\w*.  
\v 2 \w Que|strong="G3588"\w* \w los|strong="G3588"\w* ancianos sean sobrios, serios, \w prudentes|strong="G4998"\w*, \w sanos|strong="G5198"\w* \w en|strong="G3588"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w*, \w en|strong="G3588"\w* \w el|strong="G3588"\w* amor, \w en|strong="G3588"\w* \w la|strong="G3588"\w* \w paciencia|strong="G5281"\w*.  
\v 3 Las ancianas \w asimismo|strong="G5615"\w* sean reverentes \w en|strong="G1722"\w* su porte; \w no|strong="G3361"\w* \w calumniadoras|strong="G1228"\w*, \w no|strong="G3361"\w* esclavas del \w vino|strong="G3631"\w*, \w maestras|strong="G2567"\w* del bien;  
\v 4 \w que|strong="G3588"\w* \w enseñen|strong="G4994"\w* \w a|strong="G2443"\w* \w las|strong="G3588"\w* mujeres jóvenes \w a|strong="G2443"\w* amar \w a|strong="G2443"\w* \w sus|strong="G3588"\w* maridos \w y|strong="G1510"\w* \w a|strong="G2443"\w* \w sus|strong="G3588"\w* hijos,  
\v 5 \w a|strong="G2443"\w* ser \w prudentes|strong="G4998"\w*, castas, cuidadosas \w de|strong="G3588"\w* \w su|strong="G3588"\w* casa, buenas, \w sujetas|strong="G5293"\w* \w a|strong="G2443"\w* \w sus|strong="G3588"\w* maridos, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w la|strong="G3588"\w* \w palabra|strong="G3056"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* \w no|strong="G3361"\w* \w sea|strong="G3588"\w* blasfemada.   
\p
\v 6 \w Exhorta|strong="G3870"\w* \w asimismo|strong="G5615"\w* a \w los|strong="G3588"\w* jóvenes a \w que|strong="G3588"\w* sean prudentes;  
\v 7 presentándote \w tú|strong="G3588"\w* \w en|strong="G1722"\w* \w todo|strong="G3956"\w* \w como|strong="G1722"\w* \w ejemplo|strong="G5179"\w* \w de|strong="G4012"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w*; \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w enseñanza|strong="G1319"\w* mostrando integridad, seriedad,  
\v 8 \w palabra|strong="G3056"\w* \w sana|strong="G5199"\w* e irreprochable, \w de|strong="G1537"\w* modo \w que|strong="G3588"\w* \w el|strong="G3588"\w* \w adversario|strong="G1537"\w* se avergüence, \w y|strong="G2443"\w* \w no|strong="G3367"\w* \w tenga|strong="G2192"\w* \w nada|strong="G3367"\w* malo \w que|strong="G3588"\w* \w decir|strong="G3004"\w* \w de|strong="G1537"\w* \w vosotros|strong="G3588"\w*.   
\p
\v 9 Exhorta \w a|strong="G1722"\w* los \w siervos|strong="G1401"\w* \w a|strong="G1722"\w* \w que|strong="G3361"\w* se sujeten \w a|strong="G1722"\w* \w sus|strong="G2398"\w* \w amos|strong="G1203"\w*, \w que|strong="G3361"\w* agraden \w en|strong="G1722"\w* \w todo|strong="G3956"\w*, \w que|strong="G3361"\w* \w no|strong="G3361"\w* sean respondones;  
\v 10 \w no|strong="G3361"\w* \w defraudando|strong="G3557"\w*, \w sino|strong="G3361"\w* mostrándose \w fieles|strong="G4102"\w* \w en|strong="G1722"\w* \w todo|strong="G3956"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w en|strong="G1722"\w* \w todo|strong="G3956"\w* \w adornen|strong="G2885"\w* \w la|strong="G3588"\w* \w doctrina|strong="G1319"\w* \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*.  
\v 11 \w Porque|strong="G1063"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* se ha manifestado para \w salvación|strong="G4992"\w* a \w todos|strong="G3956"\w* \w los|strong="G3588"\w* hombres,  
\v 12 \w enseñándonos|strong="G3811"\w* \w que|strong="G3588"\w*, renunciando \w a|strong="G1722"\w* \w la|strong="G3588"\w* impiedad \w y|strong="G2532"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w deseos|strong="G1939"\w* \w mundanos|strong="G2886"\w*, \w vivamos|strong="G2198"\w* \w en|strong="G1722"\w* \w este|strong="G3588"\w* siglo sobria, \w justa|strong="G1346"\w* \w y|strong="G2532"\w* piadosamente,  
\v 13 aguardando \w la|strong="G3588"\w* \w esperanza|strong="G1680"\w* \w bienaventurada|strong="G3107"\w* \w y|strong="G2532"\w* \w la|strong="G3588"\w* \w manifestación|strong="G2015"\w* \w gloriosa|strong="G1391"\w* \w de|strong="G3588"\w* \w nuestro|strong="G2249"\w* \w gran|strong="G3173"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w Salvador|strong="G4990"\w* \w Jesucristo|strong="G2424"\w*,  
\v 14 \w quien|strong="G3739"\w* \w se|strong="G1438"\w* \w dio|strong="G1325"\w* \w a|strong="G2443"\w* \w sí|strong="G1438"\w* mismo \w por|strong="G5228"\w* \w nosotros|strong="G2249"\w* \w para|strong="G2443"\w* \w redimirnos|strong="G3084"\w* \w de|strong="G1325"\w* \w toda|strong="G3956"\w* iniquidad \w y|strong="G2532"\w* purificar \w para|strong="G2443"\w* \w sí|strong="G1438"\w* un \w pueblo|strong="G2992"\w* \w propio|strong="G4041"\w*, \w celoso|strong="G2207"\w* \w de|strong="G1325"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w*.   
\p
\v 15 \w Esto|strong="G3778"\w* \w habla|strong="G2980"\w*, \w y|strong="G2532"\w* \w exhorta|strong="G3870"\w* \w y|strong="G2532"\w* \w reprende|strong="G1651"\w* \w con|strong="G3326"\w* \w toda|strong="G3956"\w* \w autoridad|strong="G2003"\w*. \w Nadie|strong="G3367"\w* \w te|strong="G4771"\w* \w desprecie|strong="G4065"\w*.   
\c 3
\p
\v 1 \w Recuérdales|strong="G5279"\w* que \w se|strong="G1438"\w* sujeten \w a|strong="G4314"\w* los gobernantes \w y|strong="G1510"\w* autoridades, que obedezcan, que estén dispuestos \w a|strong="G4314"\w* \w toda|strong="G3956"\w* buena \w obra|strong="G2041"\w*.  
\v 2 Que \w a|strong="G4314"\w* \w nadie|strong="G3367"\w* difamen, que \w no|strong="G3367"\w* sean pendencieros, sino amables, \w mostrando|strong="G1731"\w* \w toda|strong="G3956"\w* \w mansedumbre|strong="G4240"\w* \w para|strong="G4314"\w* \w con|strong="G4314"\w* \w todos|strong="G3956"\w* los hombres.  
\v 3 \w Porque|strong="G1063"\w* \w nosotros|strong="G2249"\w* \w también|strong="G2532"\w* \w éramos|strong="G1510"\w* \w en|strong="G1722"\w* \w otro|strong="G4218"\w* tiempo insensatos, rebeldes, \w extraviados|strong="G4105"\w*, esclavos \w de|strong="G1722"\w* \w concupiscencias|strong="G1939"\w* \w y|strong="G2532"\w* \w deleites|strong="G2237"\w* \w diversos|strong="G4164"\w*, \w viviendo|strong="G1236"\w* \w en|strong="G1722"\w* \w malicia|strong="G2549"\w* \w y|strong="G2532"\w* \w envidia|strong="G5355"\w*, \w aborrecibles|strong="G4767"\w*, \w y|strong="G2532"\w* aborreciéndonos unos \w a|strong="G1722"\w* otros.  
\v 4 \w Pero|strong="G1161"\w* \w cuando|strong="G3753"\w* \w se|strong="G2532"\w* manifestó \w la|strong="G3588"\w* \w bondad|strong="G5544"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*, \w y|strong="G2532"\w* \w su|strong="G3588"\w* \w amor|strong="G5363"\w* para \w con|strong="G2532"\w* \w los|strong="G3588"\w* hombres,  
\v 5 nos \w salvó|strong="G4982"\w*, \w no|strong="G3756"\w* \w por|strong="G1223"\w* \w obras|strong="G2041"\w* \w de|strong="G1537"\w* \w justicia|strong="G1343"\w* \w que|strong="G3588"\w* \w nosotros|strong="G2249"\w* hubiéramos \w hecho|strong="G4160"\w*, sino \w por|strong="G1223"\w* \w su|strong="G3588"\w* \w misericordia|strong="G1656"\w*, \w por|strong="G1223"\w* \w el|strong="G3588"\w* lavamiento \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w regeneración|strong="G3824"\w* \w y|strong="G2532"\w* \w por|strong="G1223"\w* \w la|strong="G3588"\w* renovación \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo,  
\v 6 \w el|strong="G3588"\w* \w cual|strong="G3739"\w* \w derramó|strong="G1632"\w* \w en|strong="G1909"\w* \w nosotros|strong="G2249"\w* \w abundantemente|strong="G4146"\w* \w por|strong="G1223"\w* \w Jesucristo|strong="G2424"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*,  
\v 7 \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w justificados|strong="G1344"\w* \w por|strong="G2596"\w* \w su|strong="G3588"\w* \w gracia|strong="G5485"\w*, viniésemos \w a|strong="G2596"\w* \w ser|strong="G1096"\w* \w herederos|strong="G2818"\w* \w conforme|strong="G2596"\w* \w a|strong="G2596"\w* \w la|strong="G3588"\w* \w esperanza|strong="G1680"\w* \w de|strong="G2596"\w* \w la|strong="G3588"\w* \w vida|strong="G2222"\w* eterna.  
\v 8 \w Palabra|strong="G3056"\w* \w fiel|strong="G4103"\w* \w es|strong="G3778"\w* \w esta|strong="G3778"\w*, \w y|strong="G2532"\w* \w en|strong="G4012"\w* \w estas|strong="G3778"\w* cosas \w quiero|strong="G1014"\w* \w que|strong="G3588"\w* insistas \w con|strong="G2532"\w* firmeza, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w creen|strong="G4100"\w* \w en|strong="G4012"\w* \w Dios|strong="G2316"\w* \w procuren|strong="G5431"\w* ocuparse \w en|strong="G4012"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w*. \w Estas|strong="G3778"\w* cosas \w son|strong="G1510"\w* \w buenas|strong="G2570"\w* \w y|strong="G2532"\w* \w útiles|strong="G5624"\w* \w a|strong="G2443"\w* \w los|strong="G3588"\w* hombres.  
\v 9 \w Pero|strong="G1161"\w* \w evita|strong="G4026"\w* las \w cuestiones|strong="G2214"\w* \w necias|strong="G3474"\w*, \w y|strong="G2532"\w* \w genealogías|strong="G1076"\w*, \w y|strong="G2532"\w* \w contenciones|strong="G2054"\w*, \w y|strong="G2532"\w* discusiones acerca \w de|strong="G1161"\w* la ley; \w porque|strong="G1063"\w* \w son|strong="G1510"\w* vanas \w y|strong="G2532"\w* \w sin|strong="G2532"\w* provecho.  
\v 10 Al hombre \w que|strong="G2532"\w* cause divisiones, \w después|strong="G3326"\w* de \w una|strong="G1520"\w* \w y|strong="G2532"\w* \w otra|strong="G1208"\w* \w amonestación|strong="G3559"\w* deséchalo,  
