\q2 \w aun|strong="H3254"\w* \w dos|strong="H8147"\w* veces, \w mas|strong="H3254"\w* \w no|strong="H3808"\w* \w volveré|strong="H3254"\w* \w a|strong="H3068"\w* \w hablar|strong="H1696"\w*».   
\b  
\p
\v 6 \w Respondió|strong="H6030"\w* Yahvé \w a|strong="H3068"\w* Job \w desde|strong="H4480"\w* el torbellino, y dijo:   
\q1
\v 7 “Cíñete \w ahora|strong="H4994"\w* tus \w lomos|strong="H2504"\w* como un \w hombre|strong="H1397"\w*;  
\q2 \w yo|strong="H4994"\w* te \w preguntaré|strong="H7592"\w*, y tú me responderás.   
