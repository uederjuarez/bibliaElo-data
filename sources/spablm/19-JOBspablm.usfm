\q2 \w ni|strong="H3808"\w* \w león|strong="H7826"\w* \w pasó|strong="H5710"\w* \w por|strong="H5921"\w* \w ella|strong="H5921"\w*.   
\q1
\v 9 En el pedernal \w puso|strong="H7971"\w* su \w mano|strong="H3027"\w*,  
\q2 y \w trastornó|strong="H2015"\w* de raíz los \w montes|strong="H2022"\w*.   
\q1
\v 10 \w De|strong="H5869"\w* las peñas \w cortó|strong="H1234"\w* túneles,  
\q2 y su \w ojo|strong="H5869"\w* \w vio|strong="H7200"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* preciado.   
\q1
\v 11 \w Detuvo|strong="H2280"\w* los ríos \w en|strong="H3318"\w* su nacimiento,  
\q2 y \w sacó|strong="H3318"\w* \w a|strong="H3068"\w* luz lo escondido.   
\b  
\q1
\v 12 “\w Mas|strong="H2451"\w*, ¿\w dónde|strong="H4725"\w* se \w hallará|strong="H4672"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w dónde|strong="H4725"\w* \w está|strong="H2088"\w* el \w lugar|strong="H4725"\w* de \w la|strong="H2451"\w* inteligencia?   
\q1
\v 13 \w No|strong="H3808"\w* \w conoce|strong="H3045"\w* el hombre su valor,  
\q2 \w ni|strong="H3808"\w* \w se|strong="H3045"\w* \w halla|strong="H4672"\w* en la tierra de los \w vivientes|strong="H2416"\w*.   
\q1
\v 14 \w El|strong="H1931"\w* \w abismo|strong="H8415"\w* dice: ‘\w No|strong="H3808"\w* \w está|strong="H1931"\w* en mí’;  
\q2 y \w el|strong="H1931"\w* \w mar|strong="H3220"\w* dice: ‘\w Ni|strong="H3808"\w* \w conmigo|strong="H5978"\w*’.   
\q1
\v 15 \w No|strong="H3808"\w* \w se|strong="H3808"\w* \w dará|strong="H5414"\w* \w por|strong="H8478"\w* oro fino,  
\q2 \w ni|strong="H3808"\w* su \w precio|strong="H3701"\w* \w será|strong="H5414"\w* \w a|strong="H3068"\w* peso \w de|strong="H8478"\w* \w plata|strong="H3701"\w*.   
\q1
\v 16 \w No|strong="H3808"\w* puede ser pagada con \w oro|strong="H3800"\w* de Ofir,  
\q2 \w ni|strong="H3808"\w* con ónice \w precioso|strong="H3368"\w*, \w ni|strong="H3808"\w* con zafiro. \f + \fr 28:16 \ft Probablemente lapislázuli.\f*   
\q1
\v 17 El \w oro|strong="H2091"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* le iguala, \w ni|strong="H3808"\w* el diamante,  
\q2 \w ni|strong="H3808"\w* \w se|strong="H3808"\w* cambiará por \w alhajas|strong="H3627"\w* de \w oro|strong="H2091"\w* puro.   
\q1
\v 18 Del coral \w ni|strong="H3808"\w* del cristal \w se|strong="H3808"\w* hará mención;  
\q2 \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* vale \w más|strong="H2451"\w* \w que|strong="H3808"\w* las perlas.   
