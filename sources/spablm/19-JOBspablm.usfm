\v 15 \w Se|strong="H3808"\w* apoyará \w él|strong="H5921"\w* \w sobre|strong="H5921"\w* su \w casa|strong="H1004"\w*, \w mas|strong="H5921"\w* \w no|strong="H3808"\w* \w permanecerá|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w*;  
\q2 \w se|strong="H3808"\w* asirá \w a|strong="H3068"\w* \w ella|strong="H5921"\w*, \w mas|strong="H5921"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* detendrá.   
