\c 1
\p
\v 1 \w Hubo|strong="H1961"\w* un varón \w en|strong="H5493"\w* tierra \w de|strong="H7451"\w* \w Uz|strong="H5780"\w*, \w llamado|strong="H8034"\w* Job; y \w era|strong="H1961"\w* \w este|strong="H1931"\w* hombre \w perfecto|strong="H8535"\w* y \w recto|strong="H3477"\w*, \w temeroso|strong="H3373"\w* \w de|strong="H7451"\w* Dios y apartado del \w mal|strong="H7451"\w*.  
\v 2 \w Y|strong="H3068"\w* le \w nacieron|strong="H3205"\w* \w siete|strong="H7651"\w* \w hijos|strong="H1121"\w* y \w tres|strong="H7969"\w* \w hijas|strong="H1323"\w*.  
\v 3 \w Su|strong="H1931"\w* \w hacienda|strong="H4735"\w* \w era|strong="H1961"\w* \w de|strong="H2568"\w* \w siete|strong="H7651"\w* \w mil|strong="H3967"\w* \w ovejas|strong="H6629"\w*, \w tres|strong="H7969"\w* \w mil|strong="H3967"\w* \w camellos|strong="H1581"\w*, \w quinientas|strong="H2568"\w* \w yuntas|strong="H6776"\w* \w de|strong="H2568"\w* \w bueyes|strong="H1241"\w*, \w quinientas|strong="H2568"\w* asnas \w y|strong="H1241"\w* muchísimos \w criados|strong="H5657"\w*; \w de|strong="H2568"\w* modo \w que|strong="H1931"\w* \w aquel|strong="H1931"\w* varón \w era|strong="H1961"\w* \w el|strong="H1931"\w* \w más|strong="H7227"\w* \w grande|strong="H1419"\w* \w de|strong="H2568"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* orientales.  
\v 4 \w E|strong="H3068"\w* \w iban|strong="H1980"\w* sus \w hijos|strong="H1121"\w* y \w hacían|strong="H6213"\w* \w banquetes|strong="H4960"\w* \w en|strong="H5973"\w* sus \w casas|strong="H1004"\w*, \w cada|strong="H3117"\w* uno \w en|strong="H5973"\w* su \w día|strong="H3117"\w*; y enviaban \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* sus \w tres|strong="H7969"\w* hermanas \w para|strong="H5973"\w* \w que|strong="H3117"\w* comiesen y \w bebiesen|strong="H8354"\w* \w con|strong="H5973"\w* ellos.  
\v 5 \w Y|strong="H3068"\w* acontecía \w que|strong="H3588"\w*, \w habiendo|strong="H1961"\w* pasado turno \w los|strong="H1121"\w* \w días|strong="H3117"\w* del \w convite|strong="H4960"\w*, Job \w enviaba|strong="H7971"\w* \w y|strong="H3588"\w* \w los|strong="H1121"\w* santificaba, \w y|strong="H3588"\w* \w se|strong="H1961"\w* levantaba \w de|strong="H3588"\w* \w mañana|strong="H1242"\w* \w y|strong="H3588"\w* ofrecía \w holocaustos|strong="H5930"\w* \w conforme|strong="H5930"\w* \w al|strong="H5930"\w* \w número|strong="H4557"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w*. \w Porque|strong="H3588"\w* decía Job: «\w Quizá|strong="H3588"\w* habrán \w pecado|strong="H2398"\w* mis \w hijos|strong="H1121"\w*, \w y|strong="H3588"\w* habrán renunciado \w a|strong="H3068"\w* Dios \w en|strong="H3588"\w* sus \w corazones|strong="H3824"\w*». \w De|strong="H3588"\w* \w esta|strong="H1961"\w* manera \w hacía|strong="H6213"\w* Job \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w*.   
\p
\v 6 Un \w día|strong="H3117"\w* vinieron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Dios|strong="H3068"\w* \w a|strong="H3068"\w* presentarse \w delante|strong="H5921"\w* \w de|strong="H5921"\w* Yahvé, \w entre|strong="H8432"\w* \w los|strong="H1121"\w* cuales \w vino|strong="H1961"\w* \w también|strong="H1571"\w* Satanás.  
\v 7 Yahvé dijo \w a|strong="H3068"\w* Satanás: «¿De dónde vienes?»  
\p Entonces Satanás \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Yahvé, y dijo: «De rodear la tierra y de \w andar|strong="H1980"\w* por ella».   
\p
\v 8 Yahvé dijo \w a|strong="H3068"\w* Satanás: «¿Has considerado \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* Job? \w Porque|strong="H3588"\w* \w no|strong="H3588"\w* hay nadie \w como|strong="H3588"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra, un hombre \w perfecto|strong="H8535"\w* \w y|strong="H3588"\w* \w recto|strong="H3477"\w*, \w que|strong="H3588"\w* \w teme|strong="H3373"\w* \w a|strong="H3068"\w* \w Dios|strong="H3068"\w* \w y|strong="H3588"\w* \w se|strong="H5921"\w* \w aparta|strong="H5493"\w* \w del|strong="H5921"\w* \w mal|strong="H7451"\w*».   
\p
\v 9 Entonces Satanás \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Yahvé y dijo: «¿Acaso Job \w teme|strong="H3372"\w* \w a|strong="H3068"\w* \w Dios|strong="H3068"\w* \w de|strong="H3372"\w* balde?  
\v 10 ¿\w No|strong="H3808"\w* \w le|strong="H1157"\w* has cercado \w alrededor|strong="H5439"\w* \w a|strong="H3068"\w* \w él|strong="H3605"\w*, \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* tiene, \w por|strong="H1157"\w* \w todos|strong="H3605"\w* \w lados|strong="H5439"\w*? Has bendecido \w la|strong="H3605"\w* \w obra|strong="H4639"\w* de sus \w manos|strong="H3027"\w*, y su \w hacienda|strong="H4735"\w* \w ha|strong="H3808"\w* aumentado en \w la|strong="H3605"\w* tierra.  
\v 11 Pero \w extiende|strong="H7971"\w* \w ahora|strong="H4994"\w* tu \w mano|strong="H3027"\w* \w y|strong="H5921"\w* \w toca|strong="H5060"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* tiene, \w y|strong="H5921"\w* verás \w si|strong="H3808"\w* \w no|strong="H3808"\w* blasfema \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w en|strong="H5921"\w* tu misma \w cara|strong="H6440"\w*».   
\p
\v 12 Yahvé dijo \w a|strong="H3068"\w* Satanás: «He \w aquí|strong="H2009"\w*, \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tiene está \w en|strong="H5973"\w* tu \w mano|strong="H3027"\w*. \w Solamente|strong="H7535"\w* \w no|strong="H6440"\w* \w extiendas|strong="H7971"\w* tu \w mano|strong="H3027"\w* sobre \w él|strong="H5973"\w*».  
\p Entonces Satanás \w salió|strong="H3318"\w* \w de|strong="H6440"\w* \w la|strong="H3605"\w* \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.  
\v 13 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* un \w día|strong="H3117"\w* \w que|strong="H3117"\w* sus \w hijos|strong="H1121"\w* y sus \w hijas|strong="H1323"\w* \w estaban|strong="H1961"\w* comiendo y \w bebiendo|strong="H8354"\w* \w vino|strong="H3196"\w* en \w casa|strong="H1004"\w* \w de|strong="H1121"\w* su hermano \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*,  
\v 14 \w que|strong="H5921"\w* un \w mensajero|strong="H4397"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* Job \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijo: «\w Estando|strong="H1961"\w* arando \w los|strong="H5921"\w* \w bueyes|strong="H1241"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* asnas \w paciendo|strong="H7462"\w* \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w*,  
\v 15 los sabeos \w acometieron|strong="H5307"\w* y se los \w llevaron|strong="H3947"\w*. Sí, han matado \w a|strong="H3068"\w* los \w criados|strong="H5288"\w* \w a|strong="H3068"\w* filo de \w espada|strong="H2719"\w*, y \w solamente|strong="H7535"\w* yo he escapado \w para|strong="H7535"\w* contártelo».   
\p
\v 16 \w Mientras|strong="H5750"\w* \w él|strong="H5307"\w* seguía \w hablando|strong="H1696"\w*, \w vino|strong="H5307"\w* \w también|strong="H5750"\w* \w otro|strong="H2088"\w* \w y|strong="H1197"\w* \w dijo|strong="H1696"\w*: «Fuego \w de|strong="H4480"\w* Dios ha \w caído|strong="H5307"\w* \w del|strong="H4480"\w* \w cielo|strong="H8064"\w* \w y|strong="H1197"\w* ha \w quemado|strong="H1197"\w* \w a|strong="H3068"\w* las \w ovejas|strong="H6629"\w* \w y|strong="H1197"\w* \w a|strong="H3068"\w* los \w criados|strong="H5288"\w* \w y|strong="H1197"\w* los ha consumido, \w y|strong="H1197"\w* \w solamente|strong="H7535"\w* \w yo|strong="H4480"\w* he escapado \w para|strong="H4480"\w* contarlo».   
\p
\v 17 \w Mientras|strong="H5750"\w* \w él|strong="H5921"\w* seguía \w hablando|strong="H1696"\w*, llegó \w otro|strong="H2088"\w* \w y|strong="H5921"\w* \w dijo|strong="H1696"\w*: «\w Los|strong="H5921"\w* \w caldeos|strong="H3778"\w* han formado \w tres|strong="H7969"\w* \w escuadrones|strong="H7218"\w* \w y|strong="H5921"\w* han arremetido \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w camellos|strong="H1581"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w los|strong="H5921"\w* han llevado; \w sí|strong="H5921"\w*, \w y|strong="H5921"\w* han matado \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w criados|strong="H5288"\w* \w a|strong="H3068"\w* filo \w de|strong="H5921"\w* \w espada|strong="H2719"\w*; \w y|strong="H5921"\w* \w solamente|strong="H7535"\w* yo he escapado \w para|strong="H5921"\w* contártelo».   
\p
\v 18 \w Mientras|strong="H5704"\w* \w él|strong="H1121"\w* seguía \w hablando|strong="H1696"\w*, \w vino|strong="H3196"\w* \w también|strong="H2088"\w* \w otro|strong="H2088"\w* \w y|strong="H5704"\w* \w dijo|strong="H1696"\w*: «Tus \w hijos|strong="H1121"\w* \w y|strong="H5704"\w* tus \w hijas|strong="H1323"\w* estaban comiendo \w y|strong="H5704"\w* \w bebiendo|strong="H8354"\w* \w vino|strong="H3196"\w* \w en|strong="H5704"\w* \w casa|strong="H1004"\w* \w de|strong="H5704"\w* su hermano \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*,  
\v 19 \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w vino|strong="H5307"\w* un \w gran|strong="H1419"\w* \w viento|strong="H7307"\w* \w del|strong="H5921"\w* \w desierto|strong="H4057"\w* \w y|strong="H5921"\w* golpeó \w las|strong="H5921"\w* cuatro \w esquinas|strong="H6438"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, \w y|strong="H5921"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* jóvenes, \w y|strong="H5921"\w* \w están|strong="H2009"\w* \w muertos|strong="H4191"\w*. \w Sólo|strong="H7535"\w* \w yo|strong="H2009"\w* he escapado \w para|strong="H5921"\w* contarlo».   
\p
\v 20 Entonces Job se \w levantó|strong="H6965"\w*, \w rasgó|strong="H7167"\w* su \w manto|strong="H4598"\w*, se rasuró la \w cabeza|strong="H7218"\w*, se postró en tierra y \w adoró|strong="H7812"\w*.  
\v 21 \w Y|strong="H3068"\w* dijo: «\w Desnudo|strong="H6174"\w* \w salí|strong="H3318"\w* del vientre \w de|strong="H5414"\w* \w mi|strong="H1961"\w* madre, y \w desnudo|strong="H6174"\w* \w volveré|strong="H7725"\w* \w allá|strong="H8033"\w*. Yahvé \w dio|strong="H5414"\w*, y Yahvé ha quitado. \w Bendito|strong="H1288"\w* \w sea|strong="H1961"\w* el \w nombre|strong="H8034"\w* \w de|strong="H5414"\w* Yahvé».  
\v 22 En \w todo|strong="H3605"\w* \w esto|strong="H2063"\w*, Job \w no|strong="H3808"\w* \w pecó|strong="H2398"\w* \w ni|strong="H3808"\w* acusó \w a|strong="H3068"\w* Dios \w de|strong="H5414"\w* \w haber|strong="H3808"\w* obrado mal.   
\c 2
\p
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H5921"\w* otro \w día|strong="H3117"\w* vinieron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Dios|strong="H3068"\w* \w para|strong="H5921"\w* presentarse \w delante|strong="H5921"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H1571"\w* Satanás \w vino|strong="H1961"\w* \w también|strong="H1571"\w* \w entre|strong="H8432"\w* \w ellos|strong="H5921"\w* \w para|strong="H5921"\w* presentarse \w delante|strong="H5921"\w* \w de|strong="H5921"\w* Yahvé.  
\v 2 \w Y|strong="H3068"\w* dijo Yahvé \w a|strong="H3068"\w* Satanás: «¿De dónde vienes?»  
\p \w Respondió|strong="H6030"\w* Satanás \w a|strong="H3068"\w* Yahvé, y dijo: «De rodear la tierra, y de \w andar|strong="H1980"\w* \w por|strong="H2088"\w* ella».   
\p
\v 3 \w Y|strong="H3068"\w* Yahvé dijo \w a|strong="H3068"\w* Satanás: «¿\w No|strong="H3588"\w* has considerado \w a|strong="H3068"\w* mi \w siervo|strong="H5650"\w* Job, \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w hay|strong="H5750"\w* \w otro|strong="H5750"\w* \w como|strong="H3588"\w* \w él|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra, varón \w perfecto|strong="H8535"\w* \w y|strong="H3588"\w* \w recto|strong="H3477"\w*, \w temeroso|strong="H3373"\w* \w de|strong="H3588"\w* \w Dios|strong="H3068"\w* \w y|strong="H3588"\w* apartado del \w mal|strong="H7451"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w todavía|strong="H5750"\w* retiene \w su|strong="H3588"\w* integridad, \w a|strong="H3068"\w* pesar \w de|strong="H3588"\w* \w que|strong="H3588"\w* tú \w me|strong="H3588"\w* incitaste contra \w él|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* lo arruinase sin causa?»   
\p
\v 4 Respondiendo Satanás, dijo \w a|strong="H3068"\w* Yahvé: «\w Piel|strong="H5785"\w* \w por|strong="H1157"\w* \w piel|strong="H5785"\w*, \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1157"\w* \w el|strong="H3605"\w* hombre tiene \w dará|strong="H5414"\w* \w por|strong="H1157"\w* su \w vida|strong="H5315"\w*.  
\v 5 Pero \w extiende|strong="H7971"\w* \w ahora|strong="H4994"\w* tu \w mano|strong="H3027"\w*, y \w toca|strong="H5060"\w* su \w hueso|strong="H6106"\w* y su \w carne|strong="H1320"\w*, y verás \w si|strong="H3808"\w* \w no|strong="H3808"\w* blasfema \w contra|strong="H6440"\w* ti en tu misma \w cara|strong="H6440"\w*».   
\p
\v 6 \w Y|strong="H3068"\w* Yahvé dijo \w a|strong="H3068"\w* Satanás: «He \w aquí|strong="H2005"\w*, él está en tu \w mano|strong="H3027"\w*; mas \w guarda|strong="H8104"\w* su \w vida|strong="H5315"\w*».   
\p
\v 7 Entonces \w salió|strong="H3318"\w* Satanás \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, \w e|strong="H3068"\w* \w hirió|strong="H5221"\w* \w a|strong="H3068"\w* Job \w con|strong="H5704"\w* una \w sarna|strong="H7822"\w* maligna \w desde|strong="H5704"\w* la planta del \w pie|strong="H7272"\w* \w hasta|strong="H5704"\w* la coronilla \w de|strong="H6440"\w* la cabeza.  
\v 8 \w Y|strong="H3068"\w* \w tomaba|strong="H3947"\w* Job un \w tiesto|strong="H2789"\w* para rascarse con \w él|strong="H1931"\w*, y \w estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ceniza.  
\v 9 Entonces le dijo su mujer: «¿\w Aún|strong="H5750"\w* \w retienes|strong="H2388"\w* tu integridad? Renuncia \w a|strong="H3068"\w* Dios, y muérete».   
\p
\v 10 \w Y|strong="H3068"\w* \w él|strong="H3605"\w* le \w dijo|strong="H1696"\w*: «\w Como|strong="H1571"\w* suele \w hablar|strong="H1696"\w* \w cualquiera|strong="H3605"\w* \w de|strong="H7451"\w* las mujeres \w fatuas|strong="H5036"\w*, has \w hablado|strong="H1696"\w*. ¿\w Qué|strong="H3808"\w*? ¿\w Recibiremos|strong="H6901"\w* \w de|strong="H7451"\w* Dios \w el|strong="H3605"\w* \w bien|strong="H2896"\w*, \w y|strong="H1571"\w* \w el|strong="H3605"\w* \w mal|strong="H7451"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w recibiremos|strong="H6901"\w*?»  
\p En \w todo|strong="H3605"\w* \w esto|strong="H2063"\w* \w no|strong="H3808"\w* \w pecó|strong="H2398"\w* Job \w con|strong="H1571"\w* sus \w labios|strong="H8193"\w*.  
\v 11 \w Y|strong="H3068"\w* \w tres|strong="H7969"\w* \w amigos|strong="H7453"\w* \w de|strong="H5921"\w* Job, Elifaz \w temanita|strong="H8489"\w*, \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w*, \w y|strong="H5921"\w* Zofar \w naamatita|strong="H5284"\w*, luego \w que|strong="H5921"\w* \w oyeron|strong="H8085"\w* \w todo|strong="H3605"\w* \w este|strong="H2063"\w* \w mal|strong="H7451"\w* \w que|strong="H5921"\w* \w le|strong="H5921"\w* había sobrevenido, vinieron \w cada|strong="H3605"\w* uno \w de|strong="H5921"\w* su \w lugar|strong="H4725"\w*; \w porque|strong="H5921"\w* habían convenido \w en|strong="H5921"\w* venir \w juntos|strong="H3162"\w* \w para|strong="H5921"\w* condolerse \w de|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w para|strong="H5921"\w* consolarle.  
\v 12 \w Los|strong="H5921"\w* cuales, \w alzando|strong="H5375"\w* \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w desde|strong="H5921"\w* \w lejos|strong="H7350"\w*, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w conocieron|strong="H5234"\w*, \w y|strong="H5921"\w* \w lloraron|strong="H1058"\w* \w a|strong="H3068"\w* \w voz|strong="H6963"\w* \w en|strong="H5921"\w* grito; \w y|strong="H5921"\w* cada uno \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w rasgó|strong="H7167"\w* su \w manto|strong="H4598"\w*, \w y|strong="H5921"\w* esparcieron \w polvo|strong="H6083"\w* \w sobre|strong="H5921"\w* sus \w cabezas|strong="H7218"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*.  
\v 13 \w Así|strong="H3588"\w* se \w sentaron|strong="H3427"\w* \w con|strong="H3588"\w* \w él|strong="H3588"\w* \w en|strong="H3588"\w* tierra \w por|strong="H3588"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w y|strong="H3588"\w* \w siete|strong="H7651"\w* \w noches|strong="H3915"\w*, \w y|strong="H3588"\w* ninguno le \w hablaba|strong="H1696"\w* \w palabra|strong="H1697"\w*, \w porque|strong="H3588"\w* \w veían|strong="H7200"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* dolor era \w muy|strong="H3966"\w* \w grande|strong="H3966"\w*.   
\c 3
\p
\v 1 Después de \w esto|strong="H3651"\w*, \w abrió|strong="H6605"\w* Job su \w boca|strong="H6310"\w* y \w maldijo|strong="H7043"\w* su \w día|strong="H3117"\w*.  
\v 2 \w Y|strong="H3068"\w* \w respondió|strong="H6030"\w* Job, y dijo:   
\q1
\v 3 “Perezca el \w día|strong="H3117"\w* en \w que|strong="H3117"\w* yo \w nací|strong="H3205"\w*,  
\q2 y la \w noche|strong="H3915"\w* en \w que|strong="H3117"\w* se dijo: ‘\w Varón|strong="H1397"\w* es concebido’.   
\q1
\v 4 \w Sea|strong="H1961"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w sombrío|strong="H2822"\w*,  
\q2 \w y|strong="H5921"\w* \w no|strong="H1961"\w* \w cuide|strong="H1875"\w* \w de|strong="H5921"\w* \w él|strong="H1931"\w* Dios \w desde|strong="H5921"\w* \w lo|strong="H1931"\w* \w alto|strong="H4605"\w*,  
\q2 ni \w la|strong="H1931"\w* \w claridad|strong="H5105"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* \w resplandezca|strong="H3313"\w*.   
\q1
\v 5 Afórenlo \w las|strong="H5921"\w* \w tinieblas|strong="H2822"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* sombra \w de|strong="H5921"\w* \w muerte|strong="H6757"\w*;  
\q2 \w repose|strong="H7931"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* nublado,  
\q2 \w que|strong="H5921"\w* \w lo|strong="H5921"\w* haga horrible \w como|strong="H5921"\w* \w día|strong="H3117"\w* caliginoso.   
\q1
\v 6 \w Ocupe|strong="H3947"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w* \w la|strong="H1931"\w* oscuridad;  
\q2 no sea contada entre \w los|strong="H1931"\w* \w días|strong="H3117"\w* del \w año|strong="H8141"\w*,  
\q2 ni venga en \w el|strong="H1931"\w* \w número|strong="H4557"\w* de \w los|strong="H1931"\w* \w meses|strong="H3391"\w*.   
\q1
\v 7 ¡Oh, \w que|strong="H1931"\w* \w fuera|strong="H1961"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w* solitaria,  
\q2 \w que|strong="H1931"\w* \w no|strong="H1961"\w* viniera \w canción|strong="H7445"\w* de alegría en \w ella|strong="H1931"\w*!   
\q1
\v 8 \w Maldíganla|strong="H5344"\w* los \w que|strong="H3117"\w* maldicen el \w día|strong="H3117"\w*,  
\q2 los \w que|strong="H3117"\w* se aprestan para despertar al Leviatán.   
\q1
\v 9 \w Oscurézcanse|strong="H2821"\w* las \w estrellas|strong="H3556"\w* de su aurora;  
\q2 \w espere|strong="H6960"\w* la luz, y no venga,  
\q2 ni \w vea|strong="H7200"\w* los \w párpados|strong="H6079"\w* de la \w mañana|strong="H7837"\w*;   
\q1
\v 10 \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w no|strong="H3808"\w* \w cerró|strong="H5462"\w* las \w puertas|strong="H1817"\w* del vientre \w de|strong="H3588"\w* mi madre,  
\q2 \w ni|strong="H3808"\w* \w escondió|strong="H5641"\w* \w de|strong="H3588"\w* mis \w ojos|strong="H5869"\w* \w la|strong="H3588"\w* miseria.   
\b  
\q1
\v 11 “¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w no|strong="H3808"\w* \w morí|strong="H4191"\w* yo \w en|strong="H3318"\w* la \w matriz|strong="H7358"\w*,  
\q2 \w o|strong="H3068"\w* expiré al \w salir|strong="H3318"\w* del vientre?   
\q1
\v 12 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w me|strong="H3588"\w* recibieron las \w rodillas|strong="H1290"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w para|strong="H3588"\w* \w qué|strong="H3588"\w* \w los|strong="H3588"\w* \w pechos|strong="H7699"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w mamase|strong="H3243"\w*?   
\q1
\v 13 \w Pues|strong="H3588"\w* \w ahora|strong="H6258"\w* estuviera \w yo|strong="H3588"\w* muerto, \w y|strong="H3588"\w* reposaría;  
\q2 dormiría, \w y|strong="H3588"\w* \w entonces|strong="H3588"\w* tendría descanso   
\q1
\v 14 \w con|strong="H5973"\w* \w los|strong="H5973"\w* \w reyes|strong="H4428"\w* y \w con|strong="H5973"\w* \w los|strong="H5973"\w* \w consejeros|strong="H3289"\w* \w de|strong="H5973"\w* la tierra,  
\q2 que \w edifican|strong="H1129"\w* \w para|strong="H5973"\w* sí sepulcros \w en|strong="H5973"\w* \w los|strong="H5973"\w* desiertos;   
\q1
\v 15 \w o|strong="H3068"\w* \w con|strong="H5973"\w* \w los|strong="H1992"\w* \w príncipes|strong="H8269"\w* \w que|strong="H1992"\w* poseían \w el|strong="H5973"\w* \w oro|strong="H2091"\w*,  
\q2 \w que|strong="H1992"\w* llenaban \w sus|strong="H1992"\w* \w casas|strong="H1004"\w* \w de|strong="H5973"\w* \w plata|strong="H3701"\w*.   
\q1
\v 16 ¿\w O|strong="H3068"\w* por \w qué|strong="H3808"\w* \w no|strong="H3808"\w* \w fui|strong="H1961"\w* escondido \w como|strong="H1961"\w* aborto,  
\q2 \w como|strong="H1961"\w* \w los|strong="H1961"\w* pequeñuelos \w que|strong="H3808"\w* \w nunca|strong="H3808"\w* \w vieron|strong="H7200"\w* la luz?   
\q1
\v 17 \w Allí|strong="H8033"\w* los \w impíos|strong="H7563"\w* \w dejan|strong="H2308"\w* de perturbar,  
\q2 y \w allí|strong="H8033"\w* \w descansan|strong="H5117"\w* los agotados de \w fuerzas|strong="H3581"\w*.   
\q1
\v 18 Allí \w también|strong="H3162"\w* reposan los cautivos;  
\q2 \w no|strong="H3808"\w* \w oyen|strong="H8085"\w* la \w voz|strong="H6963"\w* del capataz.   
\q1
\v 19 \w Allí|strong="H8033"\w* están \w el|strong="H1931"\w* chico y \w el|strong="H1931"\w* \w grande|strong="H1419"\w*,  
\q2 y \w el|strong="H1931"\w* \w siervo|strong="H5650"\w* \w es|strong="H1931"\w* \w libre|strong="H2670"\w* de \w su|strong="H1931"\w* señor.   
\b  
\q1
\v 20 «¿\w Para|strong="H5414"\w* \w qué|strong="H4100"\w* \w se|strong="H4100"\w* \w da|strong="H5414"\w* luz al trabajado,  
\q2 y \w vida|strong="H5315"\w* \w a|strong="H3068"\w* los amargados \w de|strong="H5414"\w* \w ánimo|strong="H5315"\w*,   
\q1
\v 21 que esperan la \w muerte|strong="H4194"\w*, y ella no llega,  
\q2 aunque la buscan más que \w tesoros|strong="H4301"\w*;   
\q1
\v 22 \w que|strong="H3588"\w* se \w alegran|strong="H8055"\w* sobremanera,  
\q2 \w y|strong="H3588"\w* se gozan \w cuando|strong="H3588"\w* \w hallan|strong="H4672"\w* \w el|strong="H3588"\w* \w sepulcro|strong="H6913"\w*?   
\q1
\v 23 ¿\w Por|strong="H1157"\w* \w qué|strong="H1157"\w* se da vida \w al|strong="H1157"\w* \w hombre|strong="H1397"\w* \w que|strong="H1157"\w* \w no|strong="H1870"\w* \w sabe|strong="H5641"\w* \w por|strong="H1157"\w* dónde \w va|strong="H3068"\w*,  
\q2 y \w a|strong="H3068"\w* quien Dios ha cercado?   
\q1
\v 24 \w Pues|strong="H3588"\w* \w antes|strong="H6440"\w* \w de|strong="H3588"\w* mi \w pan|strong="H3899"\w* viene mi suspiro,  
\q2 \w y|strong="H3588"\w* mis gemidos \w corren|strong="H5413"\w* \w como|strong="H3588"\w* \w aguas|strong="H4325"\w*.   
\q1
\v 25 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w temor|strong="H6343"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* espantaba \w me|strong="H3588"\w* ha venido,  
\q2 \w y|strong="H3588"\w* \w me|strong="H3588"\w* ha acontecido lo \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w temía|strong="H3025"\w*.   
\q1
\v 26 \w No|strong="H3808"\w* he tenido paz, \w no|strong="H3808"\w* me aseguré, \w ni|strong="H3808"\w* estuve \w reposado|strong="H8252"\w*;  
\q2 \w no|strong="H3808"\w* obstante, me vino turbación».   
\c 4
\p
\v 1 Entonces \w respondió|strong="H6030"\w* Elifaz \w temanita|strong="H8489"\w*, y dijo:   
\q1
\v 2 “Si probáramos \w a|strong="H3068"\w* hablarte, ¿te sería molesto?  
\q2 Pero ¿\w quién|strong="H4310"\w* \w podrá|strong="H3201"\w* \w detener|strong="H6113"\w* las \w palabras|strong="H1697"\w*?   
\q1
\v 3 He \w aquí|strong="H2009"\w*, tú enseñabas \w a|strong="H3068"\w* \w muchos|strong="H7227"\w*,  
\q2 y las \w manos|strong="H3027"\w* \w flacas|strong="H7504"\w* fortalecías.   
\q1
\v 4 Al que tropezaba, sustentaban tus \w palabras|strong="H4405"\w*,  
\q2 y esforzabas las \w rodillas|strong="H1290"\w* que decaían.   
\q1
\v 5 \w Mas|strong="H3588"\w* \w ahora|strong="H6258"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* mal ha \w llegado|strong="H5060"\w* sobre ti, \w te|strong="H3588"\w* angustias;  
\q2 \w y|strong="H3588"\w* \w al|strong="H5704"\w* tocarte \w a|strong="H3068"\w* ti, \w te|strong="H3588"\w* conturbas.   
\q1
\v 6 ¿\w No|strong="H3808"\w* es tu temor \w a|strong="H3068"\w* Dios tu confianza?  
\q2 ¿\w No|strong="H3808"\w* es la perfección de tus \w caminos|strong="H1870"\w* tu \w esperanza|strong="H8615"\w*?   
\b  
\q1
\v 7 “Recuerda \w ahora|strong="H4994"\w*: ¿\w quién|strong="H4310"\w*, \w siendo|strong="H1931"\w* \w inocente|strong="H5355"\w*, pereció jamás?  
\q2 ¿\w Y|strong="H3068"\w* \w en|strong="H5355"\w* \w qué|strong="H4310"\w* lugar fueron \w los|strong="H1931"\w* \w rectos|strong="H3477"\w* destruidos?   
\q1
\v 8 Como yo he \w visto|strong="H7200"\w*, los que aran iniquidad  
\q2 y siembran aflicción, eso mismo \w siegan|strong="H7114"\w*.   
\q1
\v 9 Perecen por el aliento \w de|strong="H5397"\w* Dios,  
\q2 y por el \w soplo|strong="H7307"\w* \w de|strong="H5397"\w* su ira son consumidos.   
\q1
\v 10 Los bramidos del \w león|strong="H7826"\w*, y el rugido del rugiente,  
\q2 y los \w dientes|strong="H8127"\w* de los leoncillos son quebrantados.   
\q1
\v 11 \w El|strong="H1121"\w* león viejo perece por falta \w de|strong="H1121"\w* presa,  
\q2 y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* la leona son dispersos.   
\b  
\q1
\v 12 “El \w asunto|strong="H1697"\w* \w me|strong="H4480"\w* fue traído \w en|strong="H4480"\w* secreto;  
\q2 mi oído percibió un susurro \w de|strong="H4480"\w* ello.   
\q1
\v 13 \w En|strong="H5921"\w* \w visiones|strong="H2384"\w* \w de|strong="H5921"\w* \w pensamientos|strong="H5587"\w* nocturnos,  
\q2 cuando \w el|strong="H5921"\w* sueño profundo \w cae|strong="H5307"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* hombres,   
\q1
\v 14 me sobrevino un \w espanto|strong="H6343"\w* y un temblor,  
\q2 \w que|strong="H6343"\w* conmovió \w todos|strong="H7230"\w* mis \w huesos|strong="H6106"\w*;   
\q1
\v 15 \w y|strong="H5921"\w* cuando un \w espíritu|strong="H7307"\w* pasó \w por|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*,  
\q2 erizáronse \w los|strong="H5921"\w* pelos \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w carne|strong="H1320"\w*.   
\q1
\v 16 \w Paróse|strong="H5975"\w* él, \w mas|strong="H3808"\w* yo \w no|strong="H3808"\w* \w conocí|strong="H5234"\w* su \w aspecto|strong="H4758"\w*;  
\q2 una forma \w estaba|strong="H5975"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* mis \w ojos|strong="H5869"\w*;  
\q2 hubo silencio, y \w oí|strong="H8085"\w* una \w voz|strong="H6963"\w* \w que|strong="H3808"\w* decía:   
\q1
\v 17 ‘¿\w Será|strong="H6213"\w* \w el|strong="H6213"\w* \w hombre|strong="H1397"\w* mortal más justo que Dios?  
\q2 ¿\w Será|strong="H6213"\w* \w el|strong="H6213"\w* \w varón|strong="H1397"\w* más puro que su \w Hacedor|strong="H6213"\w*?’.   
\q1
\v 18 He \w aquí|strong="H2005"\w* \w que|strong="H3808"\w* en sus \w siervos|strong="H5650"\w* \w no|strong="H3808"\w* confía,  
\q2 y notó \w necedad|strong="H8417"\w* en sus \w ángeles|strong="H4397"\w*;   
\q1
\v 19 ¡cuánto más en los que \w habitan|strong="H7931"\w* en \w casas|strong="H1004"\w* \w de|strong="H6440"\w* lodo,  
\q2 cuyos cimientos están en el \w polvo|strong="H6083"\w*,  
\q2 y que serán quebrantados \w por|strong="H6440"\w* la \w polilla|strong="H6211"\w*!   
\q1
\v 20 De la \w mañana|strong="H1242"\w* \w a|strong="H3068"\w* la \w tarde|strong="H6153"\w* son destruidos,  
\q2 y perecen para siempre \w sin|strong="H1097"\w* haber quien lo considere.   
\q1
\v 21 ¿\w No|strong="H3808"\w* \w se|strong="H3808"\w* pierde su hermosura con ellos?  
\q2 \w Mueren|strong="H4191"\w*, y \w sin|strong="H3808"\w* \w sabiduría|strong="H2451"\w*”.   
\c 5
\b  
\q1
\v 1 “\w Llama|strong="H7121"\w*, \w pues|strong="H4994"\w*, \w ahora|strong="H4994"\w*; ¿\w habrá|strong="H3426"\w* \w quien|strong="H4310"\w* te \w responda|strong="H6030"\w*?  
\q2 ¿\w A|strong="H3068"\w* \w cuál|strong="H4310"\w* de los \w santos|strong="H6918"\w* te volverás?   
\q1
\v 2 \w Porque|strong="H3588"\w* al necio lo \w mata|strong="H4191"\w* \w la|strong="H3588"\w* ira,  
\q2 \w y|strong="H3588"\w* al insensato lo \w consume|strong="H4191"\w* \w el|strong="H3588"\w* \w celo|strong="H7068"\w*.   
\q1
\v 3 \w Yo|strong="H5344"\w* he \w visto|strong="H7200"\w* al necio echar raíces,  
\q2 y en el mismo punto \w maldije|strong="H5344"\w* su \w morada|strong="H5116"\w*.   
\q1
\v 4 Sus \w hijos|strong="H1121"\w* estarán \w lejos|strong="H7368"\w* \w de|strong="H1121"\w* la seguridad;  
\q2 en la \w puerta|strong="H8179"\w* serán quebrantados,  
\q2 y no habrá quien \w los|strong="H1121"\w* \w libre|strong="H5337"\w*.   
\q1
\v 5 Su \w mies|strong="H7105"\w* la comerán los hambrientos,  
\q2 y aun de entre las \w espinas|strong="H6791"\w* la \w tomarán|strong="H3947"\w*,  
\q2 y los sedientos \w beberán|strong="H7602"\w* su hacienda.   
\q1
\v 6 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* aflicción \w no|strong="H3808"\w* \w sale|strong="H3318"\w* del \w polvo|strong="H6083"\w*,  
\q2 \w ni|strong="H3808"\w* \w la|strong="H3588"\w* fatiga \w brota|strong="H6779"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w tierra|strong="H6083"\w*.   
\q1
\v 7 \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* \w hombre|strong="H1121"\w* \w nace|strong="H3205"\w* \w para|strong="H3588"\w* \w la|strong="H3588"\w* fatiga,  
\q2 \w como|strong="H3588"\w* las centellas \w para|strong="H3588"\w* elevarse \w y|strong="H3588"\w* volar.   
\b  
\q1
\v 8 “\w Ciertamente|strong="H1875"\w* yo \w buscaría|strong="H1875"\w* \w a|strong="H3068"\w* Dios,  
\q2 y encomendaría \w a|strong="H3068"\w* él mi causa;   
\q1
\v 9 \w el|strong="H6213"\w* cual \w hace|strong="H6213"\w* cosas \w grandes|strong="H1419"\w* \w e|strong="H3068"\w* inescrutables,  
\q2 \w y|strong="H5704"\w* \w maravillas|strong="H6381"\w* sin \w número|strong="H4557"\w*;   
\q1
\v 10 \w que|strong="H5921"\w* \w da|strong="H5414"\w* \w la|strong="H5921"\w* \w lluvia|strong="H4306"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra,  
\q2 \w y|strong="H5921"\w* \w envía|strong="H7971"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w por|strong="H5921"\w* \w los|strong="H5921"\w* campos;   
\q1
\v 11 que pone \w a|strong="H3068"\w* los humildes en altura,  
\q2 y los afligidos son ensalzados \w a|strong="H3068"\w* la \w salud|strong="H3468"\w*.   
\q1
\v 12 \w Que|strong="H3808"\w* frustra los \w pensamientos|strong="H4284"\w* de los astutos,  
\q2 para \w que|strong="H3808"\w* sus \w manos|strong="H3027"\w* \w no|strong="H3808"\w* realicen sus empresas.   
\q1
\v 13 Que prende \w a|strong="H3068"\w* \w los|strong="H2450"\w* \w sabios|strong="H2450"\w* en su propia astucia,  
\q2 y el \w consejo|strong="H6098"\w* de \w los|strong="H2450"\w* perversos se precipita.   
\q1
\v 14 De \w día|strong="H3119"\w* tropiezan con \w tinieblas|strong="H2822"\w*,  
\q2 y \w a|strong="H3068"\w* mediodía andan \w a|strong="H3068"\w* tientas como de \w noche|strong="H3915"\w*.   
\q1
\v 15 Así \w salva|strong="H3467"\w* de la \w espada|strong="H2719"\w* al pobre, de la \w boca|strong="H6310"\w* de \w ellos|strong="H3027"\w*,  
\q2 y de la \w mano|strong="H3027"\w* del violento.   
\q1
\v 16 \w Pues|strong="H1961"\w* el necesitado \w tendrá|strong="H1961"\w* \w esperanza|strong="H8615"\w*,  
\q2 y la \w iniquidad|strong="H5766"\w* \w cerrará|strong="H7092"\w* su \w boca|strong="H6310"\w*.   
\b  
\q1
\v 17 «He \w aquí|strong="H2009"\w*, bienaventurado es el hombre \w a|strong="H3068"\w* quien Dios \w corrige|strong="H3198"\w*;  
\q2 por tanto, no desprecies la reprensión del \w Omnipotente|strong="H7706"\w*.   
\q1
\v 18 \w Porque|strong="H3588"\w* \w él|strong="H1931"\w* \w es|strong="H1931"\w* \w quien|strong="H1931"\w* hace \w la|strong="H1931"\w* llaga, \w y|strong="H3588"\w* \w él|strong="H1931"\w* \w la|strong="H1931"\w* \w vendará|strong="H2280"\w*;  
\q2 \w él|strong="H1931"\w* \w hiere|strong="H4272"\w*, \w y|strong="H3588"\w* \w sus|strong="H1931"\w* \w manos|strong="H3027"\w* \w curan|strong="H7495"\w*.   
\q1
\v 19 En \w seis|strong="H8337"\w* \w tribulaciones|strong="H6869"\w* te \w librará|strong="H5337"\w*,  
\q2 y en la séptima \w no|strong="H3808"\w* te \w tocará|strong="H5060"\w* el \w mal|strong="H7451"\w*.   
\q1
\v 20 En el \w hambre|strong="H7458"\w* te salvará de la \w muerte|strong="H4194"\w*,  
\q2 y en la \w guerra|strong="H4421"\w*, del \w poder|strong="H3027"\w* de la \w espada|strong="H2719"\w*.   
\q1
\v 21 Del \w azote|strong="H7752"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w lengua|strong="H3956"\w* serás encubierto,  
\q2 \w ni|strong="H3808"\w* \w temerás|strong="H3372"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w destrucción|strong="H7701"\w* \w cuando|strong="H3588"\w* viniere.   
\q1
\v 22 \w De|strong="H3372"\w* la \w destrucción|strong="H7701"\w* y del hambre te reirás,  
\q2 y no \w temerás|strong="H3372"\w* \w de|strong="H3372"\w* las fieras \w de|strong="H3372"\w* la tierra;   
\q1
\v 23 \w pues|strong="H3588"\w* \w aun|strong="H3588"\w* \w con|strong="H5973"\w* las piedras \w del|strong="H5973"\w* \w campo|strong="H7704"\w* tendrás tu \w pacto|strong="H1285"\w*,  
\q2 \w y|strong="H3588"\w* las fieras \w del|strong="H5973"\w* \w campo|strong="H7704"\w* estarán \w en|strong="H5973"\w* \w paz|strong="H7999"\w* \w contigo|strong="H5973"\w*.   
\q1
\v 24 \w Y|strong="H3068"\w* \w sabrás|strong="H3045"\w* \w que|strong="H3588"\w* hay \w paz|strong="H7965"\w* \w en|strong="H3588"\w* tu tienda;  
\q2 visitarás tu majada, \w y|strong="H3588"\w* \w nada|strong="H3808"\w* \w te|strong="H3588"\w* faltará.   
\q1
\v 25 Asimismo \w sabrás|strong="H3045"\w* \w que|strong="H3588"\w* tu \w descendencia|strong="H2233"\w* será \w mucha|strong="H7227"\w*,  
\q2 \w y|strong="H3588"\w* tu \w prole|strong="H2233"\w* \w como|strong="H3588"\w* \w la|strong="H3588"\w* \w hierba|strong="H6212"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra.   
\q1
\v 26 Vendrás en la vejez \w a|strong="H3068"\w* la \w sepultura|strong="H6913"\w*,  
\q2 como la gavilla \w de|strong="H6256"\w* trigo \w que|strong="H6256"\w* se recoge \w a|strong="H3068"\w* su \w tiempo|strong="H6256"\w*.   
\q1
\v 27 He \w aquí|strong="H2009"\w*, \w esto|strong="H2063"\w* \w lo|strong="H1931"\w* hemos inquirido, y \w así|strong="H3651"\w* \w es|strong="H1931"\w*:  
\q2 óyelo, y conócelo para tu provecho».   
\b  
\c 6
\p
\v 1 Entonces \w respondió|strong="H6030"\w* Job, y dijo:   
\q1
\v 2 “¡\w Oh|strong="H3863"\w*, \w si|strong="H3863"\w* \w mi|strong="H5375"\w* angustia fuese pesada,  
\q2 y toda \w mi|strong="H5375"\w* calamidad puesta en la balanza!   
\q1
\v 3 \w Porque|strong="H3588"\w* \w ahora|strong="H6258"\w* pesaría \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H5921"\w* arena \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w mares|strong="H3220"\w*;  
\q2 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, mis \w palabras|strong="H1697"\w* han sido precipitadas.   
\q1
\v 4 \w Porque|strong="H3588"\w* las \w saetas|strong="H2671"\w* \w del|strong="H8354"\w* \w Todopoderoso|strong="H7706"\w* están \w en|strong="H3588"\w* mí,  
\q2 cuyo \w veneno|strong="H2534"\w* \w bebe|strong="H8354"\w* mi \w espíritu|strong="H7307"\w*;  
\q1 \w y|strong="H3588"\w* \w los|strong="H3588"\w* terrores \w de|strong="H3588"\w* Dios se han \w puesto|strong="H3588"\w* \w en|strong="H3588"\w* orden contra mí.   
\q2
\v 5 ¿Rebuzna \w el|strong="H5921"\w* asno \w montés|strong="H6501"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w hierba|strong="H1877"\w*?  
\q1 ¿\w O|strong="H3068"\w* brama \w el|strong="H5921"\w* \w buey|strong="H7794"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* su forraje?   
\q2
\v 6 ¿Se comerá lo desabrido \w sin|strong="H1097"\w* \w sal|strong="H4417"\w*?  
\q1 ¿\w O|strong="H3068"\w* \w habrá|strong="H3426"\w* \w gusto|strong="H2940"\w* en la clara del huevo?   
\q2
\v 7 \w Las|strong="H1992"\w* \w cosas|strong="H1992"\w* \w que|strong="H1992"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w no|strong="H3985"\w* quería \w tocar|strong="H5060"\w*,  
\q1 son ahora \w mi|strong="H5315"\w* \w comida|strong="H3899"\w* repugnante.   
\b  
\q1
\v 8 “¡\w Quién|strong="H4310"\w* \w me|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* viniese mi \w petición|strong="H7596"\w*,  
\q2 y \w que|strong="H4310"\w* Dios \w me|strong="H4310"\w* \w otorgase|strong="H5414"\w* lo \w que|strong="H4310"\w* anhelo!   
\q1
\v 9 ¡\w Que|strong="H3027"\w* pluguiera \w a|strong="H3068"\w* Dios \w quebrantarme|strong="H1792"\w*;  
\q2 \w que|strong="H3027"\w* soltara su \w mano|strong="H3027"\w* y acabara conmigo!   
\q1
\v 10 \w Sería|strong="H1961"\w* \w aún|strong="H5750"\w* \w mi|strong="H1961"\w* consuelo,  
\q2 \w si|strong="H3588"\w* \w bien|strong="H3588"\w* \w me|strong="H3588"\w* saltara \w de|strong="H3588"\w* \w dolor|strong="H2427"\w*, \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* perdonase,  
\q2 \w el|strong="H3588"\w* \w no|strong="H3808"\w* \w haber|strong="H1961"\w* negado las palabras del \w Santo|strong="H6918"\w*.   
\q1
\v 11 ¿\w Cuál|strong="H4100"\w* \w es|strong="H3588"\w* \w mi|strong="H5315"\w* \w fuerza|strong="H3581"\w* \w para|strong="H3588"\w* \w esperar|strong="H3176"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w cuál|strong="H4100"\w* \w mi|strong="H5315"\w* \w fin|strong="H7093"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* tenga paciencia?   
\q1
\v 12 ¿Es mi \w fuerza|strong="H3581"\w* la de las piedras?  
\q2 ¿\w O|strong="H3068"\w* es mi \w carne|strong="H1320"\w* de \w bronce|strong="H5153"\w*?   
\q1
\v 13 ¿Acaso no \w me|strong="H4480"\w* falta la \w ayuda|strong="H5833"\w* dentro \w de|strong="H4480"\w* mí,  
\q2 y la \w sabiduría|strong="H8454"\w* \w me|strong="H4480"\w* ha sido abandonada?   
\b  
\q1
\v 14 “Al que está atribulado, su \w amigo|strong="H7453"\w* debe mostrarle bondad,  
\q2 aun al que abandona el \w temor|strong="H3374"\w* del \w Todopoderoso|strong="H7706"\w*.   
\q1
\v 15 Pero mis hermanos han sido falaces \w como|strong="H3644"\w* un \w arroyo|strong="H5158"\w*,  
\q2 \w como|strong="H3644"\w* la corriente de los \w arroyos|strong="H5158"\w* que \w pasan|strong="H5674"\w*;   
\q1
\v 16 \w que|strong="H4480"\w* están turbios \w por|strong="H5921"\w* causa \w del|strong="H4480"\w* hielo,  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H4480"\w* \w se|strong="H5921"\w* esconde \w la|strong="H5921"\w* nieve.   
\q1
\v 17 \w Al|strong="H6256"\w* \w tiempo|strong="H6256"\w* del calor, se deshacen;  
\q2 y \w al|strong="H6256"\w* calentarse, \w desaparecen|strong="H1846"\w* \w de|strong="H6256"\w* su \w lugar|strong="H4725"\w*.   
\q1
\v 18 \w Apártanse|strong="H3943"\w* las caravanas de su \w camino|strong="H1870"\w*,  
\q2 \w van|strong="H5927"\w* \w por|strong="H1870"\w* el desierto y perecen.   
\q1
\v 19 \w Miraron|strong="H5027"\w* las caravanas de Tema,  
\q2 los caminantes de Sabá esperaron en ellos;   
\q1
\v 20 \w pero|strong="H3588"\w* fueron avergonzados \w por|strong="H3588"\w* \w su|strong="H3588"\w* confianza;  
\q2 \w porque|strong="H3588"\w* vinieron \w hasta|strong="H5704"\w* ellos \w y|strong="H3588"\w* se hallaron confusos.   
\q1
\v 21 \w Ciertamente|strong="H3588"\w* \w ahora|strong="H6258"\w* vosotros \w no|strong="H3808"\w* \w sois|strong="H1961"\w* \w nada|strong="H3808"\w*;  
\q2 \w veis|strong="H7200"\w* \w el|strong="H3588"\w* horror \w y|strong="H3588"\w* tenéis \w miedo|strong="H3372"\w*.   
\q1
\v 22 ¿Os he dicho \w yo|strong="H3588"\w*: ‘\w Dadme|strong="H3051"\w* algo’,  
\q2 \w o|strong="H3068"\w* ‘Pagad \w por|strong="H3588"\w* mí \w de|strong="H3588"\w* vuestra hacienda’,   
\q1
\v 23 \w o|strong="H3068"\w* ‘Libradme de la \w mano|strong="H3027"\w* del opresor’,  
\q2 \w o|strong="H3068"\w* ‘Rescatadme de \w mano|strong="H3027"\w* de los violentos’?   
\b  
\q1
\v 24 «\w Enseñadme|strong="H3384"\w*, y yo \w callaré|strong="H2790"\w*;  
\q2 hacedme entender en \w qué|strong="H4100"\w* he errado.   
\q1
\v 25 ¡\w Cuán|strong="H4100"\w* fuertes son las palabras \w de|strong="H4480"\w* rectitud!  
\q2 Pero vuestra reprensión, ¿\w qué|strong="H4100"\w* \w reprende|strong="H3198"\w*?   
\q1
\v 26 ¿\w Pensáis|strong="H2803"\w* \w censurar|strong="H2803"\w* las \w palabras|strong="H4405"\w*,  
\q2 siendo así que los discursos del desesperado son como el \w viento|strong="H7307"\w*?   
\q1
\v 27 \w Sí|strong="H5921"\w*, vosotros \w os|strong="H5921"\w* arrojáis \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w huérfano|strong="H3490"\w*,  
\q2 \w y|strong="H5921"\w* hacéis mercancía \w de|strong="H5921"\w* vuestro \w amigo|strong="H7453"\w*.   
\q1
\v 28 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w si|strong="H6440"\w* \w os|strong="H5921"\w* place, \w miradme|strong="H6437"\w*,  
\q2 \w y|strong="H5921"\w* ved \w si|strong="H6440"\w* \w miento|strong="H3576"\w* \w ante|strong="H6440"\w* vuestra \w cara|strong="H6440"\w*.   
\q1
\v 29 \w Volved|strong="H7725"\w* \w ahora|strong="H4994"\w*, y \w no|strong="H1961"\w* \w haya|strong="H1961"\w* \w iniquidad|strong="H5766"\w*;  
\q2 \w volved|strong="H7725"\w* \w aún|strong="H5750"\w*, \w que|strong="H4994"\w* \w mi|strong="H1961"\w* \w justicia|strong="H6664"\w* \w está|strong="H1961"\w* \w en|strong="H5750"\w* ello.   
\q1
\v 30 ¿\w Hay|strong="H3426"\w* \w iniquidad|strong="H5766"\w* en mi \w lengua|strong="H3956"\w*?  
\q2 ¿\w No|strong="H3808"\w* puede mi paladar discernir las cosas amargas?»   
\c 7
\b  
\q1
\v 1 “¿\w No|strong="H3808"\w* es acaso \w la|strong="H5921"\w* \w vida|strong="H3117"\w* \w del|strong="H5921"\w* hombre una milicia \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra?  
\q2 ¿\w No|strong="H3808"\w* \w son|strong="H3808"\w* sus \w días|strong="H3117"\w* \w como|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* un jornalero?   
\q1
\v 2 Como el \w siervo|strong="H5650"\w* que suspira por la \w sombra|strong="H6738"\w*,  
\q2 y como el asalariado que \w espera|strong="H6960"\w* el fin de su trabajo,   
\q1
\v 3 \w así|strong="H3651"\w* me han tocado \w meses|strong="H3391"\w* de \w vanidad|strong="H7723"\w*,  
\q2 y \w noches|strong="H3915"\w* de fatiga me fueron asignadas.   
\q1
\v 4 \w Cuando|strong="H4970"\w* me acuesto, digo:  
\q2 ‘¿\w Cuándo|strong="H4970"\w* me \w levantaré|strong="H6965"\w* \w y|strong="H5704"\w* se acabará \w la|strong="H7646"\w* noche?’.  
\q2 \w Y|strong="H3068"\w* estoy harto \w de|strong="H5704"\w* devaneos \w hasta|strong="H5704"\w* el alba.   
\q1
\v 5 Mi \w carne|strong="H1320"\w* está vestida \w de|strong="H3847"\w* \w gusanos|strong="H7415"\w* y \w de|strong="H3847"\w* costras \w de|strong="H3847"\w* \w polvo|strong="H6083"\w*;  
\q2 mi \w piel|strong="H5785"\w* se rompe y vuelve \w a|strong="H3068"\w* supurar.   
\q1
\v 6 Mis \w días|strong="H3117"\w* son \w más|strong="H4480"\w* veloces \w que|strong="H4480"\w* la lanzadera \w del|strong="H4480"\w* tejedor,  
\q2 y \w se|strong="H4480"\w* consumen sin \w esperanza|strong="H8615"\w* alguna.   
\q1
\v 7 Recuerda \w que|strong="H3588"\w* mi \w vida|strong="H2416"\w* \w es|strong="H3588"\w* un \w soplo|strong="H7307"\w*,  
\q2 \w y|strong="H3588"\w* \w que|strong="H3588"\w* mis \w ojos|strong="H5869"\w* \w no|strong="H3808"\w* \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w el|strong="H3588"\w* \w bien|strong="H2896"\w*.   
\q1
\v 8 Los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* los \w que|strong="H3808"\w* me ven, \w no|strong="H3808"\w* me verán \w más|strong="H3808"\w*;  
\q2 fijarás tus \w ojos|strong="H5869"\w* en mí, y ya \w no|strong="H3808"\w* existiré.   
\q1
\v 9 \w Como|strong="H3651"\w* la \w nube|strong="H6051"\w* \w se|strong="H3808"\w* consume y \w se|strong="H3808"\w* desvanece,  
\q2 \w así|strong="H3651"\w* el \w que|strong="H3808"\w* \w desciende|strong="H3381"\w* al Seol \w no|strong="H3808"\w* \w subirá|strong="H5927"\w* \w más|strong="H3808"\w*.   
\q1
\v 10 \w No|strong="H3808"\w* \w volverá|strong="H7725"\w* \w más|strong="H5750"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*,  
\q2 \w ni|strong="H3808"\w* su \w lugar|strong="H4725"\w* \w lo|strong="H3808"\w* conocerá \w más|strong="H5750"\w*.   
\b  
\q1
\v 11 “Por tanto, \w no|strong="H3808"\w* refrenaré \w mi|strong="H5315"\w* \w boca|strong="H6310"\w*;  
\q2 \w hablaré|strong="H1696"\w* en \w la|strong="H1571"\w* \w angustia|strong="H6862"\w* de \w mi|strong="H5315"\w* \w espíritu|strong="H7307"\w*,  
\q2 \w y|strong="H1571"\w* me quejaré en \w la|strong="H1571"\w* \w amargura|strong="H4751"\w* de \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*.   
\q1
\v 12 ¿Soy \w yo|strong="H3588"\w* acaso \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w o|strong="H3068"\w* un monstruo marino,  
\q2 \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w me|strong="H5921"\w* \w pongas|strong="H7760"\w* guardia?   
\q1
\v 13 \w Cuando|strong="H3588"\w* digo: ‘\w Mi|strong="H5375"\w* lecho \w me|strong="H3588"\w* \w consolará|strong="H5162"\w*,  
\q2 \w mi|strong="H5375"\w* \w cama|strong="H4904"\w* \w aliviará|strong="H5162"\w* \w mi|strong="H5375"\w* queja’,   
\q1
\v 14 entonces me aterras con \w sueños|strong="H2472"\w*,  
\q2 y me espantas con \w visiones|strong="H2384"\w*.   
\q1
\v 15 Por lo \w cual|strong="H5315"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* preferiría el estrangulamiento,  
\q2 y la \w muerte|strong="H4194"\w* más que estos mis \w huesos|strong="H6106"\w*.   
\q1
\v 16 Abomino \w de|strong="H4480"\w* mi \w vida|strong="H3117"\w*; \w no|strong="H3808"\w* he \w de|strong="H4480"\w* \w vivir|strong="H2421"\w* \w para|strong="H3588"\w* \w siempre|strong="H5769"\w*;  
\q2 \w déjame|strong="H2308"\w*, \w pues|strong="H3588"\w*, \w porque|strong="H3588"\w* mis \w días|strong="H3117"\w* \w son|strong="H3588"\w* \w vanidad|strong="H1892"\w*.   
\q1
\v 17 ¿\w Qué|strong="H3588"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w lo|strong="H4100"\w* engrandezcas,  
\q2 \w y|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w pongas|strong="H7896"\w* \w en|strong="H3588"\w* \w él|strong="H3588"\w* tu \w corazón|strong="H3820"\w*,   
\q1
\v 18 y lo visites todas las mañanas,  
\q2 y todos los momentos lo pruebes?   
\q1
\v 19 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4100"\w* \w no|strong="H3808"\w* apartarás \w de|strong="H4480"\w* mí tu mirada,  
\q2 \w ni|strong="H3808"\w* \w me|strong="H4480"\w* soltarás \w hasta|strong="H5704"\w* \w que|strong="H4100"\w* \w trague|strong="H1104"\w* mi saliva?   
\q1
\v 20 \w Si|strong="H1961"\w* he \w pecado|strong="H2398"\w*, ¿\w qué|strong="H4100"\w* \w te|strong="H5921"\w* he \w hecho|strong="H1961"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, \w oh|strong="H4100"\w* \w Guarda|strong="H5341"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* hombres?  
\q2 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w me|strong="H5921"\w* \w pones|strong="H7760"\w* \w por|strong="H5921"\w* blanco tuyo,  
\q2 \w hasta|strong="H5921"\w* convertirme \w en|strong="H5921"\w* una \w carga|strong="H4853"\w* \w para|strong="H5921"\w* \w mí|strong="H5921"\w* mismo?   
\q1
\v 21 ¿\w Y|strong="H3068"\w* \w por|strong="H3588"\w* \w qué|strong="H3588"\w* \w no|strong="H3808"\w* perdonas \w mi|strong="H5375"\w* \w rebelión|strong="H6588"\w* \w y|strong="H3588"\w* \w quitas|strong="H5375"\w* \w mi|strong="H5375"\w* \w iniquidad|strong="H5771"\w*?  
\q2 \w Porque|strong="H3588"\w* \w ahora|strong="H6258"\w* \w dormiré|strong="H7901"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w polvo|strong="H6083"\w*,  
\q2 \w y|strong="H3588"\w* \w si|strong="H3588"\w* \w me|strong="H3588"\w* buscares \w de|strong="H3588"\w* mañana, \w ya|strong="H6258"\w* \w no|strong="H3808"\w* \w seré|strong="H3808"\w*”.   
\c 8
\p
\v 1 \w Respondió|strong="H6030"\w* \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w*, y dijo:   
\q1
\v 2 “¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* \w hablarás|strong="H4448"\w* tales cosas,  
\q2 \w y|strong="H5704"\w* las \w palabras|strong="H6310"\w* \w de|strong="H5704"\w* tu \w boca|strong="H6310"\w* \w serán|strong="H6310"\w* \w como|strong="H5704"\w* \w viento|strong="H7307"\w* impetuoso?   
\q1
\v 3 ¿\w Pervertirá|strong="H5791"\w* Dios el \w derecho|strong="H4941"\w*?  
\q2 ¿\w O|strong="H3068"\w* el \w Todopoderoso|strong="H7706"\w* \w pervertirá|strong="H5791"\w* la \w justicia|strong="H6664"\w*?   
\q1
\v 4 Si tus \w hijos|strong="H1121"\w* \w pecaron|strong="H2398"\w* contra \w él|strong="H1121"\w*,  
\q2 \w él|strong="H1121"\w* \w los|strong="H1121"\w* entregó en \w mano|strong="H3027"\w* \w de|strong="H1121"\w* su transgresión.   
\q1
\v 5 Si tú de mañana buscares \w a|strong="H3068"\w* Dios,  
\q2 y pudieres tu ruego al \w Todopoderoso|strong="H7706"\w*;   
\q1
\v 6 \w si|strong="H3588"\w* fueras \w limpio|strong="H2134"\w* \w y|strong="H3588"\w* \w recto|strong="H3477"\w*,  
\q2 \w ciertamente|strong="H3588"\w* \w luego|strong="H6258"\w* \w se|strong="H5921"\w* \w despertará|strong="H5782"\w* \w por|strong="H5921"\w* \w ti|strong="H5921"\w*,  
