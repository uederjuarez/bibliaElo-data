\v 9 (\w porque|strong="H3588"\w* \w nosotros|strong="H5921"\w* somos \w de|strong="H5921"\w* \w ayer|strong="H8543"\w*, \w y|strong="H3588"\w* \w nada|strong="H3808"\w* \w sabemos|strong="H3045"\w*,  
