\b  
\q1
\v 22 “Una cosa resta, \w por|strong="H5921"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* dije:  
\q2 \w Al|strong="H5921"\w* \w perfecto|strong="H8535"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w impío|strong="H7563"\w* \w él|strong="H1931"\w* \w los|strong="H5921"\w* consume.   
\q1
\v 23 Si el \w azote|strong="H7752"\w* \w mata|strong="H4191"\w* de repente,  
\q2 se ríe del sufrimiento de los inocentes.   
\q1
\v 24 \w La|strong="H1931"\w* tierra \w es|strong="H1931"\w* \w entregada|strong="H5414"\w* en \w manos|strong="H3027"\w* \w de|strong="H6440"\w* \w los|strong="H1931"\w* \w impíos|strong="H7563"\w*,  
\q2 y \w él|strong="H1931"\w* \w cubre|strong="H3680"\w* \w el|strong="H1931"\w* \w rostro|strong="H6440"\w* \w de|strong="H6440"\w* \w sus|strong="H1931"\w* \w jueces|strong="H8199"\w*.  
\q2 \w Si|strong="H3808"\w* \w no|strong="H3808"\w* \w es|strong="H1931"\w* \w él|strong="H1931"\w*, ¿\w quién|strong="H4310"\w* \w es|strong="H1931"\w*? ¿\w dónde|strong="H1931"\w* \w está|strong="H1931"\w*?   
\b  
\q1
\v 25 “Mis \w días|strong="H3117"\w* han sido \w más|strong="H4480"\w* veloces \w que|strong="H4480"\w* un \w correo|strong="H7323"\w*;  
\q2 \w huyeron|strong="H1272"\w*, y \w no|strong="H3808"\w* \w vieron|strong="H7200"\w* el \w bien|strong="H2896"\w*.   
\q1
\v 26 \w Pasaron|strong="H2498"\w* \w como|strong="H5973"\w* naves veloces;  
\q2 \w como|strong="H5973"\w* \w el|strong="H5921"\w* águila \w que|strong="H5921"\w* \w se|strong="H5921"\w* arroja \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* presa.   
\q1
\v 27 \w Si|strong="H6440"\w* digo: ‘\w Olvidaré|strong="H7911"\w* mi queja,  
\q2 \w dejaré|strong="H5800"\w* mi triste semblante y me esforzaré’,   
\q1
\v 28 \w me|strong="H3588"\w* turban \w todos|strong="H3605"\w* mis dolores;  
\q2 \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* tendrás \w por|strong="H3588"\w* inocente.   
\q1
\v 29 Yo soy impío;  
\q2 ¿para \w qué|strong="H4100"\w*, \w pues|strong="H2088"\w*, \w trabajaré|strong="H3021"\w* en \w vano|strong="H1892"\w*?   
\q1
\v 30 Aunque me lave con aguas de nieve,  
\q2 y limpie mis \w manos|strong="H3709"\w* con la misma lejía,   
\q1
\v 31 aun así me hundirás en el hoyo,  
\q2 y mis propios \w vestidos|strong="H8008"\w* me abominarán.   
\q1
\v 32 \w Porque|strong="H3588"\w* \w él|strong="H3588"\w* \w no|strong="H3808"\w* \w es|strong="H3588"\w* hombre \w como|strong="H3588"\w* \w yo|strong="H3588"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* le \w responda|strong="H6030"\w*,  
\q2 \w y|strong="H3588"\w* vengamos \w juntos|strong="H3162"\w* \w a|strong="H3068"\w* \w juicio|strong="H4941"\w*.   
\q1
\v 33 \w No|strong="H3863"\w* \w hay|strong="H3426"\w* \w entre|strong="H5921"\w* \w nosotros|strong="H8147"\w* \w árbitro|strong="H3198"\w*  
\q2 \w que|strong="H5921"\w* \w ponga|strong="H7896"\w* su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w ambos|strong="H8147"\w*.   
\q1
\v 34 \w Quite|strong="H5493"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* su \w vara|strong="H7626"\w*,  
\q2 \w y|strong="H5921"\w* su terror \w no|strong="H5921"\w* \w me|strong="H5921"\w* espante.   
\q1
\v 35 \w Entonces|strong="H3588"\w* \w hablaré|strong="H1696"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* le \w temeré|strong="H3372"\w*;  
\q2 \w pues|strong="H3588"\w* \w en|strong="H3588"\w* este estado \w no|strong="H3808"\w* estoy \w en|strong="H3588"\w* mí mismo.   
\b  
\c 10
\b  
\q1
\v 1 “\w Está|strong="H5921"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* hastiada \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w vida|strong="H5315"\w*;  
\q2 daré rienda suelta \w a|strong="H3068"\w* \w mi|strong="H5921"\w* queja \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* mismo,  
\q2 \w hablaré|strong="H1696"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w amargura|strong="H4751"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*.   
\q1
\v 2 Diré \w a|strong="H3068"\w* Dios: \w No|strong="H5921"\w* \w me|strong="H5921"\w* condenes;  
\q2 hazme entender \w por|strong="H5921"\w* \w qué|strong="H4100"\w* contiendes conmigo.   
\q1
\v 3 ¿\w Te|strong="H5921"\w* parece \w bien|strong="H2896"\w* \w que|strong="H3588"\w* \w oprimas|strong="H6231"\w*,  
\q2 \w que|strong="H3588"\w* \w deseches|strong="H3988"\w* \w la|strong="H5921"\w* obra \w de|strong="H5921"\w* tus \w manos|strong="H3709"\w*,  
\q2 \w y|strong="H3588"\w* \w que|strong="H3588"\w* favorezcas \w el|strong="H5921"\w* \w consejo|strong="H6098"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w impíos|strong="H7563"\w*?   
\q1
\v 4 ¿Tienes tú acaso \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w carne|strong="H1320"\w*?  
\q2 ¿\w Ves|strong="H7200"\w* tú como \w ve|strong="H7200"\w* el hombre?   
\q1
\v 5 ¿Son tus \w días|strong="H3117"\w* como los \w días|strong="H3117"\w* del \w hombre|strong="H1397"\w*,  
\q2 \w o|strong="H3068"\w* tus \w años|strong="H8141"\w* como los \w tiempos|strong="H8141"\w* de los mortales,   
\q1
\v 6 \w para|strong="H3588"\w* \w que|strong="H3588"\w* inquieras \w mi|strong="H1245"\w* \w iniquidad|strong="H5771"\w*,  
\q2 \w y|strong="H3588"\w* \w busques|strong="H1245"\w* \w mi|strong="H1245"\w* \w pecado|strong="H2403"\w*,   
\q1
\v 7 \w aunque|strong="H3588"\w* tú sabes \w que|strong="H3588"\w* \w no|strong="H3808"\w* soy impío,  
\q2 \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* hay quien pueda \w librar|strong="H5337"\w* \w de|strong="H5921"\w* tu \w mano|strong="H3027"\w*?   
\b  
\q1
\v 8 “Tus \w manos|strong="H3027"\w* me \w hicieron|strong="H6213"\w* y me formaron del \w todo|strong="H5439"\w*,  
\q2 ¿y ahora te vuelves y me deshaces?   
\q1
\v 9 \w Acuérdate|strong="H2142"\w*, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w*, \w que|strong="H3588"\w* \w como|strong="H3588"\w* \w a|strong="H3068"\w* \w barro|strong="H2563"\w* \w me|strong="H3588"\w* diste forma;  
\q2 ¿\w y|strong="H3588"\w* \w en|strong="H3588"\w* \w polvo|strong="H6083"\w* \w me|strong="H3588"\w* has \w de|strong="H3588"\w* \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w convertir|strong="H7725"\w*?   
\q1
\v 10 ¿\w No|strong="H3808"\w* me vertiste como \w leche|strong="H2461"\w*,  
\q2 y como queso me cuajaste?   
\q1
\v 11 Me \w vestiste|strong="H3847"\w* \w de|strong="H3847"\w* \w piel|strong="H5785"\w* y \w carne|strong="H1320"\w*,  
\q2 y me tejiste con \w huesos|strong="H6106"\w* y nervios.   
\q1
\v 12 \w Vida|strong="H2416"\w* y \w misericordia|strong="H2617"\w* me concediste,  
\q2 y \w tu|strong="H6213"\w* providencia \w guardó|strong="H8104"\w* mi \w espíritu|strong="H7307"\w*.   
\q1
\v 13 \w Estas|strong="H2063"\w* \w cosas|strong="H3045"\w* \w tienes|strong="H3045"\w* guardadas \w en|strong="H5973"\w* tu \w corazón|strong="H3824"\w*;  
\q2 \w yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w esto|strong="H2063"\w* \w está|strong="H2063"\w* \w en|strong="H5973"\w* \w ti|strong="H5973"\w*:   
\q1
\v 14 \w Si|strong="H3808"\w* \w pequé|strong="H2398"\w*, tú me observas,  
\q2 y \w no|strong="H3808"\w* me limpiarás de mi \w iniquidad|strong="H5771"\w*.   
\q1
\v 15 \w Si|strong="H3808"\w* fuera malo, ¡ay \w de|strong="H7646"\w* \w mí|strong="H5375"\w*!;  
\q2 y \w si|strong="H3808"\w* fuera justo, \w no|strong="H3808"\w* levantaría \w mi|strong="H5375"\w* \w cabeza|strong="H7218"\w*,  
\q2 hastiado \w de|strong="H7646"\w* deshonra,  
\q2 y \w de|strong="H7646"\w* ver \w mi|strong="H5375"\w* \w aflicción|strong="H6040"\w*.   
\q1
\v 16 Si mi cabeza se alzase, me cazarías como \w a|strong="H3068"\w* \w león|strong="H7826"\w*,  
\q2 y volverías \w a|strong="H3068"\w* hacer en mí \w maravillas|strong="H6381"\w* terribles.   
\q1
\v 17 \w Renuevas|strong="H2318"\w* tus \w testigos|strong="H5707"\w* \w contra|strong="H5973"\w* mí,  
\q2 y aumentas \w conmigo|strong="H5973"\w* tu saña;  
\q2 se suceden relevos \w de|strong="H5048"\w* \w guerra|strong="H6635"\w* \w contra|strong="H5973"\w* mí.   
\b  
\q1
\v 18 «¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w*, \w pues|strong="H7200"\w*, me \w sacaste|strong="H3318"\w* \w de|strong="H5869"\w* la \w matriz|strong="H7358"\w*?  
\q2 Hubiera yo expirado, y \w ningún|strong="H3808"\w* \w ojo|strong="H5869"\w* me habría \w visto|strong="H7200"\w*.   
\q1
\v 19 \w Fuera|strong="H1961"\w* \w como|strong="H1961"\w* \w si|strong="H3808"\w* \w nunca|strong="H3808"\w* hubiera existido,  
\q2 \w llevado|strong="H2986"\w* desde el vientre \w a|strong="H3068"\w* la \w sepultura|strong="H6913"\w*.   
\q1
\v 20 ¿\w No|strong="H3808"\w* \w son|strong="H3808"\w* \w pocos|strong="H4592"\w* mis \w días|strong="H3117"\w*?  
\q2 ¡\w Cesa|strong="H2308"\w*, \w pues|strong="H4480"\w*!  
\q1 \w Déjame|strong="H2308"\w*, \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w me|strong="H4480"\w* consuele un \w poco|strong="H4592"\w*,   
\q2
\v 21 \w antes|strong="H2962"\w* \w que|strong="H3808"\w* \w vaya|strong="H3212"\w* para \w no|strong="H3808"\w* \w volver|strong="H7725"\w*,  
\q2 \w a|strong="H3068"\w* la tierra de \w tinieblas|strong="H2822"\w* y de sombra de \w muerte|strong="H6757"\w*;   
\q1
\v 22 tierra de \w oscuridad|strong="H5890"\w*, \w como|strong="H3644"\w* sombra de \w muerte|strong="H6757"\w* y \w sin|strong="H3808"\w* \w orden|strong="H5468"\w*,  
\q2 donde la claridad es \w como|strong="H3644"\w* la misma \w oscuridad|strong="H5890"\w*».   
\c 11
\p
\v 1 Entonces \w respondió|strong="H6030"\w* Zofar \w naamatita|strong="H5284"\w*, y dijo:   
\q1
\v 2 “¿\w No|strong="H3808"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* \w de|strong="H1697"\w* \w responder|strong="H6030"\w* \w a|strong="H3068"\w* la verborrea?  
\q2 ¿\w Y|strong="H3068"\w* el hombre \w que|strong="H3808"\w* tanto \w habla|strong="H1697"\w* \w será|strong="H3808"\w* \w por|strong="H1697"\w* ello \w justificado|strong="H6663"\w*?   
\q1
\v 3 ¿Harán tus jactancias \w callar|strong="H2790"\w* \w a|strong="H3068"\w* los \w hombres|strong="H4962"\w*?  
\q2 ¿Te burlarás y no habrá quien te \w avergüence|strong="H3637"\w*?   
\q1
\v 4 \w Pues|strong="H1961"\w* tú dices: ‘\w Mi|strong="H1961"\w* \w doctrina|strong="H3948"\w* \w es|strong="H1961"\w* \w pura|strong="H2134"\w*,  
\q2 y \w soy|strong="H1961"\w* \w limpio|strong="H1249"\w* \w delante|strong="H5869"\w* \w de|strong="H5869"\w* tus \w ojos|strong="H5869"\w*’.   
\q1
\v 5 Mas ¡\w oh|strong="H4310"\w*, \w quién|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* Dios \w hablara|strong="H1696"\w*,  
\q2 y abriera sus \w labios|strong="H8193"\w* \w contra|strong="H5973"\w* \w ti|strong="H5973"\w*,   
\q1
\v 6 \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* declarase \w los|strong="H3588"\w* secretos \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w sabiduría|strong="H2451"\w*,  
\q2 \w pues|strong="H3588"\w* ella \w es|strong="H3588"\w* \w de|strong="H3588"\w* \w doble|strong="H3718"\w* valor \w que|strong="H3588"\w* \w la|strong="H3588"\w* prudencia!  
\q2 \w Sabed|strong="H3045"\w*, \w pues|strong="H3588"\w*, \w que|strong="H3588"\w* Dios os exige \w menos|strong="H3588"\w* \w de|strong="H3588"\w* lo \w que|strong="H3588"\w* vuestra \w iniquidad|strong="H5771"\w* merece.   
\b  
\q1
\v 7 “¿Alcanzarás tú el rastro \w de|strong="H5704"\w* Dios?  
\q2 ¿\w Llegarás|strong="H4672"\w* tú \w a|strong="H3068"\w* la perfección del \w Todopoderoso|strong="H7706"\w*?   
\q1
\v 8 Es más alta \w que|strong="H4100"\w* los \w cielos|strong="H8064"\w*; ¿\w qué|strong="H4100"\w* \w harás|strong="H6466"\w*?  
\q2 Es más \w profunda|strong="H6013"\w* \w que|strong="H4100"\w* el Seol; ¿\w cómo|strong="H4100"\w* la \w conocerás|strong="H3045"\w*?   
\q1
\v 9 Su dimensión es \w más|strong="H4480"\w* \w larga|strong="H7342"\w* \w que|strong="H4480"\w* la tierra,  
\q2 y \w más|strong="H4480"\w* ancha \w que|strong="H4480"\w* el \w mar|strong="H3220"\w*.   
\q1
\v 10 Si \w él|strong="H4310"\w* pasa, y aprisiona,  
\q2 y llama \w a|strong="H3068"\w* juicio, ¿\w quién|strong="H4310"\w* podrá contrarrestarle?   
\q1
\v 11 \w Porque|strong="H3588"\w* \w él|strong="H1931"\w* \w conoce|strong="H3045"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w hombres|strong="H4962"\w* \w vanos|strong="H7723"\w*;  
\q2 \w ve|strong="H7200"\w* asimismo \w la|strong="H1931"\w* iniquidad, ¿\w y|strong="H3588"\w* \w no|strong="H3808"\w* \w la|strong="H1931"\w* considerará?   
\q1
\v 12 El hombre fatuo se hará sabio,  
\q2 cuando el pollino del asno \w montés|strong="H6501"\w* nazca hombre.   
\b  
\q1
\v 13 «Si tú dispusieres tu \w corazón|strong="H3820"\w*,  
\q2 y extendieres \w a|strong="H3068"\w* él tus \w manos|strong="H3709"\w*;   
\q1
\v 14 si alguna \w iniquidad|strong="H5766"\w* hubiere en tu \w mano|strong="H3027"\w*, y la echares de ti,  
\q2 y \w no|strong="H5766"\w* consintieres \w que|strong="H3027"\w* more la injusticia en tus tiendas,   
\q1
\v 15 \w entonces|strong="H3588"\w* \w levantarás|strong="H5375"\w* tu \w rostro|strong="H6440"\w* limpio \w de|strong="H3588"\w* \w mancha|strong="H3971"\w*,  
\q2 \w y|strong="H3588"\w* \w serás|strong="H1961"\w* \w fuerte|strong="H3332"\w* \w y|strong="H3588"\w* \w nada|strong="H3808"\w* \w temerás|strong="H3372"\w*;   
\q2
\v 16 \w y|strong="H3588"\w* olvidarás tu miseria,  
\q2 \w o|strong="H3068"\w* \w te|strong="H3588"\w* acordarás \w de|strong="H3588"\w* ella \w como|strong="H3588"\w* \w de|strong="H3588"\w* \w aguas|strong="H4325"\w* \w que|strong="H3588"\w* \w pasaron|strong="H5674"\w*.   
\q1
\v 17 La vida te \w será|strong="H1961"\w* más clara \w que|strong="H1961"\w* el mediodía;  
\q2 aunque oscureciere, \w será|strong="H1961"\w* \w como|strong="H1961"\w* la \w mañana|strong="H1242"\w*.   
\q1
\v 18 Tendrás confianza, \w porque|strong="H3588"\w* \w hay|strong="H3426"\w* \w esperanza|strong="H8615"\w*;  
\q2 mirarás alrededor, \w y|strong="H3588"\w* dormirás seguro.   
\q1
\v 19 Te acostarás, y \w no|strong="H6440"\w* habrá quien te espante;  
\q2 y \w muchos|strong="H7227"\w* suplicarán tu favor.   
\q1
\v 20 Pero los \w ojos|strong="H5869"\w* \w de|strong="H4480"\w* los malos \w se|strong="H4480"\w* consumirán,  
\q2 y \w no|strong="H7563"\w* tendrán \w refugio|strong="H4498"\w*;  
\q2 y su \w esperanza|strong="H8615"\w* será exhalar el espíritu».   
\c 12
\p
\v 1 Entonces \w respondió|strong="H6030"\w* Job, y dijo:   
\q1
\v 2 “\w Ciertamente|strong="H3588"\w* \w vosotros|strong="H5973"\w* sois \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w*,  
\q2 \w y|strong="H3588"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w* \w morirá|strong="H4191"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*.   
\q1
\v 3 Pero \w yo|strong="H4480"\w* \w también|strong="H1571"\w* tengo entendimiento \w como|strong="H1571"\w* vosotros;  
\q2 \w no|strong="H3808"\w* soy inferior \w a|strong="H3068"\w* vosotros.  
\q2 ¿\w Y|strong="H3068"\w* \w quién|strong="H4310"\w* habrá \w que|strong="H4480"\w* \w no|strong="H3808"\w* sepa cosas \w como|strong="H1571"\w* estas?   
\q1
\v 4 Yo \w soy|strong="H1961"\w* uno \w de|strong="H6662"\w* quien su \w amigo|strong="H7453"\w* hace \w escarnio|strong="H7814"\w*,  
\q2 yo, \w que|strong="H1961"\w* invoco \w a|strong="H3068"\w* Dios y él me \w responde|strong="H6030"\w*;  
\q2 el \w justo|strong="H6662"\w* \w e|strong="H3068"\w* \w íntegro|strong="H8549"\w* \w es|strong="H1961"\w* objeto \w de|strong="H6662"\w* burla.   
\q1
\v 5 Aquel cuyo \w pie|strong="H7272"\w* está \w a|strong="H3068"\w* punto de resbalar,  
\q2 es despreciado por el que está tranquilo.   
\q1
\v 6 Las tiendas de los ladrones \w prosperan|strong="H7951"\w*,  
\q2 y los \w que|strong="H3027"\w* provocan \w a|strong="H3068"\w* Dios viven seguros,  
\q2 los \w que|strong="H3027"\w* llevan \w a|strong="H3068"\w* su dios en su propia \w mano|strong="H3027"\w*.   
\b  
\q1
\v 7 “\w Y|strong="H3068"\w* en verdad, \w pregunta|strong="H7592"\w* \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* las bestias, \w que|strong="H4994"\w* ellas te enseñarán;  
\q2 \w a|strong="H3068"\w* las \w aves|strong="H5775"\w* de los \w cielos|strong="H8064"\w*, y ellas te lo mostrarán.   
\q1
\v 8 \w O|strong="H3068"\w* \w habla|strong="H7878"\w* \w a|strong="H3068"\w* la tierra, que ella \w te|strong="H3220"\w* instruirá;  
\q2 y los peces del \w mar|strong="H3220"\w* \w te|strong="H3220"\w* lo \w declararán|strong="H5608"\w*.   
\q1
\v 9 ¿\w Quién|strong="H4310"\w* \w entre|strong="H3808"\w* \w todos|strong="H3605"\w* \w estos|strong="H2063"\w* \w no|strong="H3808"\w* \w sabe|strong="H3045"\w*  
\q2 \w que|strong="H3588"\w* \w la|strong="H2063"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* Yahvé \w hizo|strong="H6213"\w* \w esto|strong="H2063"\w*?   
\q1
\v 10 En su \w mano|strong="H3027"\w* está \w el|strong="H3605"\w* \w alma|strong="H5315"\w* de \w todo|strong="H3605"\w* \w viviente|strong="H2416"\w*,  
\q2 y \w el|strong="H3605"\w* \w hálito|strong="H7307"\w* de \w todo|strong="H3605"\w* \w el|strong="H3605"\w* género humano.   
\q1
\v 11 ¿Acaso el oído \w no|strong="H3808"\w* distingue las \w palabras|strong="H4405"\w*,  
\q2 así como el paladar \w gusta|strong="H2938"\w* las viandas?   
\q1
\v 12 En los ancianos está \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*,  
\q2 y en \w la|strong="H2451"\w* larga \w edad|strong="H3117"\w* \w la|strong="H2451"\w* \w inteligencia|strong="H8394"\w*.   
\b  
\q1
\v 13 “\w Con|strong="H5973"\w* Dios está \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* y \w el|strong="H5973"\w* poder;  
\q2 suyo es \w el|strong="H5973"\w* \w consejo|strong="H6098"\w* y \w la|strong="H2451"\w* \w inteligencia|strong="H8394"\w*.   
\q1
\v 14 \w Si|strong="H2005"\w* \w él|strong="H5921"\w* derriba, \w no|strong="H3808"\w* habrá quien \w edifique|strong="H1129"\w*;  
\q2 \w si|strong="H2005"\w* encierra \w al|strong="H5921"\w* hombre, \w no|strong="H3808"\w* habrá quien \w le|strong="H5921"\w* abra.   
\q1
\v 15 \w Si|strong="H2005"\w* él detiene las \w aguas|strong="H4325"\w*, todo se \w seca|strong="H3001"\w*;  
\q2 \w si|strong="H2005"\w* las \w envía|strong="H7971"\w*, trastornan la tierra.   
\q1
\v 16 \w Con|strong="H5973"\w* \w él|strong="H5973"\w* está la \w fortaleza|strong="H5797"\w* \w y|strong="H5797"\w* la eficacia;  
\q2 suyo es \w el|strong="H5973"\w* que yerra \w y|strong="H5797"\w* \w el|strong="H5973"\w* que hace errar.   
\q1
\v 17 Él hace \w andar|strong="H3212"\w* \w despojados|strong="H7758"\w* \w a|strong="H3068"\w* los \w consejeros|strong="H3289"\w*,  
\q2 y entontece \w a|strong="H3068"\w* los \w jueces|strong="H8199"\w*.   
\q1
\v 18 Él rompe las cadenas de los \w reyes|strong="H4428"\w*,  
\q2 y les ata un cordel \w a|strong="H3068"\w* sus \w lomos|strong="H4975"\w*.   
\q1
\v 19 Él hace \w andar|strong="H3212"\w* \w despojados|strong="H7758"\w* \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w*,  
\q2 y trastorna \w a|strong="H3068"\w* los poderosos.   
\q1
\v 20 Él \w quita|strong="H5493"\w* la palabra \w a|strong="H3068"\w* los que son de confianza,  
\q2 y arrebata el discernimiento \w a|strong="H3068"\w* los \w ancianos|strong="H2205"\w*.   
\q1
\v 21 \w Él|strong="H5921"\w* vierte menosprecio \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* príncipes,  
\q2 \w y|strong="H5921"\w* debilita \w el|strong="H5921"\w* cinto \w de|strong="H5921"\w* \w los|strong="H5921"\w* fuertes.   
\q1
\v 22 Él \w descubre|strong="H1540"\w* las profundidades \w de|strong="H4480"\w* las \w tinieblas|strong="H2822"\w*,  
\q2 y \w saca|strong="H3318"\w* \w a|strong="H3068"\w* la \w luz|strong="H6757"\w* la sombra \w de|strong="H4480"\w* \w muerte|strong="H6757"\w*.   
\q1
\v 23 Él multiplica las \w naciones|strong="H1471"\w* y él las destruye;  
\q2 él dispersa las \w naciones|strong="H1471"\w* y las vuelve \w a|strong="H3068"\w* reunir.   
\q1
\v 24 Él \w quita|strong="H5493"\w* el juicio \w a|strong="H3068"\w* los \w jefes|strong="H7218"\w* \w de|strong="H5971"\w* los \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* la tierra,  
\q2 y los hace vagar \w por|strong="H1870"\w* un desierto \w sin|strong="H3808"\w* \w camino|strong="H1870"\w*.   
\q1
\v 25 Van \w a|strong="H3068"\w* tientas en las \w tinieblas|strong="H2822"\w*, \w sin|strong="H3808"\w* luz,  
\q2 y los hace tambalear como \w borrachos|strong="H7910"\w*.   
\b  
\c 13
\b  
\q1
\v 1 “He \w aquí|strong="H2005"\w* \w que|strong="H3605"\w* \w todas|strong="H3605"\w* estas cosas han \w visto|strong="H7200"\w* mis \w ojos|strong="H5869"\w*,  
\q2 y las han \w oído|strong="H8085"\w* y entendido mis \w oídos|strong="H8085"\w*.   
\q1
\v 2 \w Como|strong="H1571"\w* vosotros \w lo|strong="H3808"\w* \w sabéis|strong="H3045"\w*, \w lo|strong="H3808"\w* \w sé|strong="H3045"\w* \w yo|strong="H4480"\w* \w también|strong="H1571"\w*;  
\q2 \w no|strong="H3808"\w* soy inferior \w a|strong="H3068"\w* vosotros.   
\b  
\q1
\v 3 “Ciertamente yo \w hablaría|strong="H1696"\w* con el \w Todopoderoso|strong="H7706"\w*,  
\q2 y querría \w razonar|strong="H3198"\w* con Dios.   
\q1
\v 4 Porque ciertamente vosotros sois forjadores de \w mentiras|strong="H8267"\w*;  
\q2 \w todos|strong="H3605"\w* vosotros sois \w médicos|strong="H7495"\w* de \w ningún|strong="H3605"\w* valor.   
\q1
\v 5 ¡\w Quién|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* callaseis \w por|strong="H5414"\w* completo,  
\q2 porque ello os \w fuera|strong="H1961"\w* \w sabiduría|strong="H2451"\w*!   
\q1
\v 6 \w Oid|strong="H8085"\w* \w ahora|strong="H4994"\w* \w mi|strong="H4994"\w* razonamiento,  
\q2 y estad \w atentos|strong="H7181"\w* \w a|strong="H3068"\w* los argumentos de mis \w labios|strong="H8193"\w*.   
\q1
\v 7 ¿\w Hablaréis|strong="H1696"\w* \w iniquidad|strong="H5766"\w* por Dios?  
\q2 ¿\w Hablaréis|strong="H1696"\w* por él con \w engaño|strong="H7423"\w*?   
\q1
\v 8 ¿Haréis \w acepción|strong="H5375"\w* \w de|strong="H6440"\w* personas \w a|strong="H3068"\w* su favor?  
\q2 ¿Contenderéis vosotros \w por|strong="H6440"\w* Dios?   
\q1
\v 9 ¿Sería \w bueno|strong="H2896"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* os escudriñase?  
\q2 ¿Os burlaréis \w de|strong="H3588"\w* \w él|strong="H3588"\w* \w como|strong="H3588"\w* quien se burla \w de|strong="H3588"\w* un hombre?   
\q1
\v 10 Él os \w reprenderá|strong="H3198"\w* ciertamente,  
\q2 \w si|strong="H6440"\w* en lo oculto hacéis \w acepción|strong="H5375"\w* \w de|strong="H6440"\w* personas.   
\q1
\v 11 Su majestad, ¿\w no|strong="H3808"\w* \w os|strong="H5921"\w* espantaría,  
\q2 \w y|strong="H5921"\w* su pavor \w no|strong="H3808"\w* caería \w sobre|strong="H5921"\w* vosotros?   
\q1
\v 12 Vuestras máximas son proverbios de ceniza,  
\q2 y vuestros baluartes son baluartes de lodo.   
\b  
\q1
\v 13 “¡\w Escuchadme|strong="H2790"\w*!  
\q2 Dejadme \w en|strong="H5921"\w* paz, \w para|strong="H5921"\w* \w que|strong="H4100"\w* \w yo|strong="H4480"\w* \w hable|strong="H1696"\w*,  
\q2 \w y|strong="H5921"\w* \w que|strong="H4100"\w* \w me|strong="H4480"\w* venga \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w viniere|strong="H5674"\w*.   
\q1
\v 14 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* he \w de|strong="H5921"\w* tomar \w mi|strong="H5921"\w* \w carne|strong="H1320"\w* \w con|strong="H5921"\w* \w mis|strong="H5375"\w* \w dientes|strong="H8127"\w*,  
\q2 \w y|strong="H5921"\w* poner \w mi|strong="H5921"\w* \w vida|strong="H5315"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3709"\w*?   
\q1
