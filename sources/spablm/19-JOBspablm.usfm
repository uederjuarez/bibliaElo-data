\q2
\v 7 \w Y|strong="H3068"\w* tu \w principio|strong="H7225"\w* \w habrá|strong="H1961"\w* \w sido|strong="H1961"\w* \w pequeño|strong="H4705"\w*,  
\q1 mas tu postrer \w estado|strong="H1961"\w* \w crecerá|strong="H7685"\w* \w sobremanera|strong="H3966"\w*.   
