\q2 y detienes tú sola \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*?   
\q1
\v 9 ¿\w Qué|strong="H4100"\w* \w sabes|strong="H3045"\w* tú \w que|strong="H4100"\w* \w nosotros|strong="H5973"\w* \w no|strong="H3808"\w* \w sepamos|strong="H3045"\w*?  
\q2 ¿\w Qué|strong="H4100"\w* entiendes tú \w que|strong="H4100"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* halle \w en|strong="H5973"\w* \w nosotros|strong="H5973"\w*?   
\q1
\v 10 Cabezas canas \w y|strong="H1571"\w* hombres muy ancianos hay entre nosotros,  
\q2 \w mucho|strong="H3524"\w* mayores en \w días|strong="H3117"\w* \w que|strong="H1571"\w* tu padre.   
\q1
\v 11 ¿\w En|strong="H4480"\w* tan \w poco|strong="H4592"\w* \w tienes|strong="H4480"\w* las \w consolaciones|strong="H8575"\w* \w de|strong="H4480"\w* Dios,  
\q2 y la \w palabra|strong="H1697"\w* \w que|strong="H4480"\w* \w te|strong="H4480"\w* \w habla|strong="H1697"\w* dulcemente?   
\q1
\v 12 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w te|strong="H5869"\w* enajena tu \w corazón|strong="H3820"\w*,  
\q2 y \w por|strong="H4100"\w* \w qué|strong="H4100"\w* \w guiñan|strong="H7335"\w* tus \w ojos|strong="H5869"\w*,   
\q1
\v 13 \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w vuelvas|strong="H7725"\w* tu \w espíritu|strong="H7307"\w* contra Dios,  
\q2 \w y|strong="H3588"\w* saques tales \w palabras|strong="H4405"\w* \w de|strong="H3588"\w* tu \w boca|strong="H6310"\w*?   
\q1
\v 14 ¿\w Qué|strong="H3588"\w* cosa \w es|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w para|strong="H3588"\w* \w que|strong="H3588"\w* sea limpio,  
\q2 \w y|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H4100"\w* justifique \w el|strong="H3588"\w* \w nacido|strong="H3205"\w* \w de|strong="H3588"\w* mujer?   
\q1
\v 15 He \w aquí|strong="H2005"\w* \w que|strong="H3808"\w* en sus \w santos|strong="H6918"\w* \w no|strong="H3808"\w* confía,  
\q2 y \w ni|strong="H3808"\w* \w aun|strong="H3808"\w* los \w cielos|strong="H8064"\w* \w son|strong="H3808"\w* limpios \w delante|strong="H5869"\w* \w de|strong="H5869"\w* sus \w ojos|strong="H5869"\w*;   
\q1
\v 16 ¿\w cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w abominable|strong="H8581"\w* \w y|strong="H3588"\w* vil,  
\q2 \w que|strong="H3588"\w* \w bebe|strong="H8354"\w* \w la|strong="H3588"\w* \w iniquidad|strong="H5766"\w* \w como|strong="H3588"\w* \w agua|strong="H4325"\w*?   
\b  
\q1
\v 17 “\w Escúchame|strong="H8085"\w*, yo te mostraré;  
\q2 y te \w contaré|strong="H5608"\w* \w lo|strong="H2088"\w* \w que|strong="H2088"\w* he visto:   
\q1
\v 18 \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w los|strong="H2450"\w* \w sabios|strong="H2450"\w* \w nos|strong="H3582"\w* \w contaron|strong="H5046"\w* de sus padres,  
\q2 y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* encubrieron;   
\q1
\v 19 \w a|strong="H3068"\w* quienes solos \w fue|strong="H3808"\w* \w dada|strong="H5414"\w* la tierra,  
\q2 y \w no|strong="H3808"\w* \w pasó|strong="H5674"\w* \w extraño|strong="H2114"\w* \w por|strong="H5414"\w* \w medio|strong="H8432"\w* \w de|strong="H5414"\w* ellos.   
\q1
\v 20 \w Todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w días|strong="H3117"\w* \w el|strong="H1931"\w* \w impío|strong="H7563"\w* \w es|strong="H1931"\w* atormentado de \w dolor|strong="H2342"\w*,  
\q2 y \w el|strong="H1931"\w* \w número|strong="H4557"\w* de \w años|strong="H8141"\w* \w es|strong="H1931"\w* escondido al tirano.   
\q1
\v 21 \w Estruendo|strong="H6963"\w* de espantos hay en sus oídos;  
\q2 en la prosperidad el asolador vendrá sobre él.   
\q1
\v 22 \w Él|strong="H1931"\w* \w no|strong="H3808"\w* cree \w que|strong="H4480"\w* \w ha|strong="H3808"\w* \w de|strong="H4480"\w* \w volver|strong="H7725"\w* \w de|strong="H4480"\w* las \w tinieblas|strong="H2822"\w*,  
\q2 y \w está|strong="H1931"\w* señalado \w para|strong="H4480"\w* \w la|strong="H1931"\w* \w espada|strong="H2719"\w*.   
\q1
\v 23 Anda errante tras \w el|strong="H1931"\w* \w pan|strong="H3899"\w*, diciendo: ‘¿\w Dónde|strong="H1931"\w* \w está|strong="H1931"\w*?’.  
\q2 \w Sabe|strong="H3045"\w* \w que|strong="H3588"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* las \w tinieblas|strong="H2822"\w* \w le|strong="H1931"\w* \w está|strong="H1931"\w* preparado \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w*.   
\q1
\v 24 \w Tribulación|strong="H6862"\w* y \w angustia|strong="H6862"\w* le aterran,  
\q2 y prevalecen contra él como un \w rey|strong="H4428"\w* prevenido para la batalla.   
\q1
\v 25 \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w él|strong="H3588"\w* \w extendió|strong="H5186"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* contra Dios,  
\q2 \w y|strong="H3588"\w* se esforzó contra \w el|strong="H3588"\w* \w Omnipotente|strong="H7706"\w*.   
\q1
\v 26 \w Corrió|strong="H7323"\w* contra él con la cerviz erguida,  
\q2 con la espesura de los grabados de sus rodelas.   
\q1
\v 27 \w Porque|strong="H3588"\w* \w cubrió|strong="H3680"\w* \w su|strong="H3588"\w* \w rostro|strong="H6440"\w* \w con|strong="H5921"\w* \w su|strong="H3588"\w* gordura,  
\q2 \w y|strong="H3588"\w* puso \w grosura|strong="H2459"\w* \w sobre|strong="H5921"\w* sus ijares;   
\q1
\v 28 y \w habitó|strong="H3427"\w* las \w ciudades|strong="H5892"\w* \w asoladas|strong="H3582"\w*,  
\q2 las \w casas|strong="H1004"\w* \w no|strong="H3808"\w* \w habitadas|strong="H3427"\w*,  
\q2 \w que|strong="H3808"\w* \w estaban|strong="H3427"\w* \w asoladas|strong="H3582"\w* en montones.   
\q1
\v 29 \w No|strong="H3808"\w* \w enriquecerá|strong="H6238"\w*, \w ni|strong="H3808"\w* serás \w firme|strong="H6965"\w* su hacienda,  
\q2 \w ni|strong="H3808"\w* sus posesiones \w se|strong="H3808"\w* extenderán por la tierra.   
\q1
\v 30 \w No|strong="H3808"\w* \w escapará|strong="H3808"\w* \w de|strong="H4480"\w* las \w tinieblas|strong="H2822"\w*;  
\q2 la llama \w secará|strong="H3001"\w* sus renuevos,  
\q2 y \w con|strong="H4480"\w* el \w soplo|strong="H7307"\w* \w de|strong="H4480"\w* su \w boca|strong="H6310"\w* \w perecerá|strong="H5493"\w*.   
\q1
\v 31 \w No|strong="H3588"\w* confíe \w el|strong="H3588"\w* iluso \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w vanidad|strong="H7723"\w*,  
\q2 \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w vanidad|strong="H7723"\w* \w será|strong="H1961"\w* \w su|strong="H3588"\w* recompensa.   
\q1
\v 32 Él \w será|strong="H3808"\w* cortado antes de su \w tiempo|strong="H3117"\w*,  
\q2 y su renuevo \w no|strong="H3808"\w* reverdecerá.   
\q1
\v 33 Perderá su agraz como la \w vid|strong="H1612"\w*,  
\q2 y derramará su flor como el olivo.   
\q1
\v 34 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* congregación \w de|strong="H3588"\w* \w los|strong="H3588"\w* impíos será asolada,  
\q2 \w y|strong="H3588"\w* fuego consumirá las tiendas del \w cohecho|strong="H7810"\w*.   
\q1
\v 35 \w Concibieron|strong="H2029"\w* \w dolor|strong="H5999"\w*, y parieron iniquidad,  
\q2 y las entrañas de ellos traman \w engaño|strong="H4820"\w*”.   
\b  
\c 16
\p
\v 1 Entonces \w respondió|strong="H6030"\w* Job, y dijo:   
\q1
\v 2 “\w Muchas|strong="H7227"\w* veces he \w oído|strong="H8085"\w* \w cosas|strong="H7227"\w* como estas;  
\q2 ¡\w consoladores|strong="H5162"\w* \w molestos|strong="H5999"\w* sois \w todos|strong="H3605"\w* \w vosotros|strong="H8085"\w*!   
\q1
\v 3 ¿Tendrán \w fin|strong="H7093"\w* las \w palabras|strong="H1697"\w* vanas?  
\q2 ¿\w O|strong="H3068"\w* \w qué|strong="H3588"\w* \w te|strong="H3588"\w* provoca \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w respondas|strong="H6030"\w* \w así|strong="H3588"\w*?   
\q1
\v 4 \w También|strong="H1571"\w* \w yo|strong="H5315"\w* podría \w hablar|strong="H1696"\w* \w como|strong="H1571"\w* \w vosotros|strong="H3426"\w*;  
\q2 \w si|strong="H3863"\w* vuestra \w alma|strong="H5315"\w* \w estuviera|strong="H3426"\w* \w en|strong="H5921"\w* \w lugar|strong="H8478"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* mía,  
\q2 \w yo|strong="H5315"\w* podría ensartar \w palabras|strong="H1696"\w* \w contra|strong="H5921"\w* \w vosotros|strong="H3426"\w*,  
\q2 \w y|strong="H1571"\w* sacudir \w contra|strong="H5921"\w* \w vosotros|strong="H3426"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*.   
\q1
\v 5 Pero yo os alentaría con mi \w boca|strong="H6310"\w*,  
\q2 y la consolación de mis \w labios|strong="H8193"\w* aplacaría vuestro dolor.   
\b  
\q1
\v 6 “\w Si|strong="H3808"\w* \w hablo|strong="H1696"\w*, mi dolor \w no|strong="H3808"\w* \w cesa|strong="H2308"\w*;  
\q2 y \w si|strong="H3808"\w* \w dejo|strong="H2308"\w* \w de|strong="H4480"\w* \w hablar|strong="H1696"\w*, ¿\w qué|strong="H4100"\w* alivio \w tengo|strong="H1696"\w*?   
\q1
\v 7 Pero \w ahora|strong="H6258"\w* Dios me ha agotado;  
\q2 has \w asolado|strong="H8074"\w* \w toda|strong="H3605"\w* mi compañía.   
\q1
\v 8 Tú me has llenado \w de|strong="H6440"\w* arrugas, lo cual \w es|strong="H1961"\w* \w testigo|strong="H5707"\w* \w contra|strong="H6440"\w* \w mí|strong="H6030"\w*;  
\q2 \w mi|strong="H6030"\w* flacura \w se|strong="H1961"\w* levanta \w para|strong="H1961"\w* testificar \w contra|strong="H6440"\w* \w mí|strong="H6030"\w*,  
\q2 y en \w mi|strong="H6030"\w* \w cara|strong="H6440"\w* \w se|strong="H1961"\w* me convence.   
\q1
\v 9 Su furor \w me|strong="H5921"\w* despedazó \w y|strong="H5921"\w* \w me|strong="H5921"\w* ha sido contrario;  
\q2 \w crujió|strong="H2786"\w* sus \w dientes|strong="H8127"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*;  
\q2 \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* aguzó sus \w ojos|strong="H5869"\w* \w mi|strong="H5921"\w* adversario.   
\q1
\v 10 \w Abrieron|strong="H6473"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* su \w boca|strong="H6310"\w*;  
\q2 \w hirieron|strong="H5221"\w* mis mejillas \w con|strong="H5921"\w* \w oprobio|strong="H2781"\w*;  
\q2 \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w se|strong="H5921"\w* juntaron \w todos|strong="H3162"\w*.   
\q1
\v 11 \w Me|strong="H5921"\w* ha \w entregado|strong="H5462"\w* Dios \w al|strong="H5921"\w* \w mentiroso|strong="H5760"\w*,  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w impíos|strong="H7563"\w* \w me|strong="H5921"\w* hizo caer.   
\q1
\v 12 \w Próspero|strong="H7961"\w* \w estaba|strong="H1961"\w*, y me desmenuzó;  
\q2 me asió por la \w cerviz|strong="H6203"\w* y me despedazó,  
\q2 y me puso por blanco suyo.   
\q1
\v 13 \w Me|strong="H5921"\w* rodearon sus \w flecheros|strong="H7228"\w*,  
\q2 \w partió|strong="H6398"\w* mis \w riñones|strong="H3629"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* tuvo piedad;  
\q2 \w mi|strong="H5921"\w* hiel \w derramó|strong="H8210"\w* \w por|strong="H5921"\w* tierra.   
\q1
\v 14 \w Me|strong="H5921"\w* quebrantó \w con|strong="H5921"\w* quebrantamiento \w sobre|strong="H5921"\w* quebrantamiento;  
\q2 \w corrió|strong="H7323"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w como|strong="H5921"\w* un gigante.   
\q1
\v 15 Cosí cilicio \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* piel,  
\q2 \w y|strong="H5921"\w* puse \w mi|strong="H5921"\w* cabeza \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*.   
\q1
\v 16 \w Mi|strong="H5921"\w* \w rostro|strong="H6440"\w* \w está|strong="H5921"\w* inflamado \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w lloro|strong="H1065"\w*,  
\q2 \w y|strong="H5921"\w* mis \w párpados|strong="H6079"\w* \w entenebrecidos|strong="H6757"\w* \w con|strong="H5921"\w* sombra \w de|strong="H4480"\w* \w muerte|strong="H6757"\w*,   
\q1
\v 17 \w a|strong="H3068"\w* pesar \w de|strong="H5921"\w* \w no|strong="H3808"\w* \w haber|strong="H3808"\w* \w iniquidad|strong="H2555"\w* \w en|strong="H5921"\w* mis \w manos|strong="H3709"\w*,  
\q2 \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w haber|strong="H3808"\w* sido \w mi|strong="H5921"\w* \w oración|strong="H8605"\w* \w pura|strong="H2134"\w*.   
\b  
\q1
\v 18 “¡Oh tierra!, \w no|strong="H1961"\w* \w cubras|strong="H3680"\w* \w mi|strong="H1961"\w* \w sangre|strong="H1818"\w*,  
\q2 y \w no|strong="H1961"\w* \w haya|strong="H1961"\w* \w lugar|strong="H4725"\w* \w para|strong="H1961"\w* \w mi|strong="H1961"\w* \w clamor|strong="H2201"\w*.   
\q1
\v 19 \w Mas|strong="H1571"\w* he \w aquí|strong="H2009"\w* \w que|strong="H6258"\w* en los \w cielos|strong="H8064"\w* está \w mi|strong="H2009"\w* \w testigo|strong="H5707"\w*,  
\q2 \w y|strong="H1571"\w* \w mi|strong="H2009"\w* fiador en las \w alturas|strong="H4791"\w*.   
\q1
\v 20 \w Disputadores|strong="H3887"\w* son mis \w amigos|strong="H7453"\w*;  
\q2 \w mas|strong="H7453"\w* ante Dios derramarán mis \w ojos|strong="H5869"\w* lágrimas.   
\q1
\v 21 ¡Ojalá pudiese disputar \w el|strong="H5973"\w* \w hombre|strong="H1397"\w* \w con|strong="H5973"\w* Dios,  
\q2 \w como|strong="H5973"\w* \w el|strong="H5973"\w* \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w hombre|strong="H1397"\w* \w con|strong="H5973"\w* su \w prójimo|strong="H7453"\w*!   
\q1
\v 22 \w Mas|strong="H3588"\w* \w los|strong="H3588"\w* \w años|strong="H8141"\w* \w contados|strong="H4557"\w* vendrán,  
\q2 \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w iré|strong="H1980"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1980"\w* \w de|strong="H3588"\w* donde \w no|strong="H3808"\w* \w volveré|strong="H7725"\w*.   
\c 17
\q1
\v 1 “Mi aliento se agota, mis \w días|strong="H3117"\w* se apagan,  
\q2 y el \w sepulcro|strong="H6913"\w* me aguarda.   
\q1
\v 2 \w No|strong="H3808"\w* hay \w conmigo|strong="H5978"\w* \w sino|strong="H3808"\w* escarnecedores,  
\q2 y mis \w ojos|strong="H5869"\w* deben tolerar su provocación.   
\b  
\q1
\v 3 “\w Dame|strong="H7760"\w* \w fianza|strong="H6148"\w*, \w oh|strong="H4310"\w* Dios; sea \w yo|strong="H4994"\w* avalado \w contigo|strong="H5973"\w*.  
\q2 ¿\w Quién|strong="H4310"\w* habría \w de|strong="H5973"\w* darme \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w si|strong="H1931"\w* no fueras tú?   
\q1
\v 4 \w Porque|strong="H3588"\w* has cerrado \w el|strong="H5921"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w al|strong="H5921"\w* \w entendimiento|strong="H7922"\w*;  
\q2 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w no|strong="H3808"\w* \w los|strong="H5921"\w* exaltarás.   
\q1
\v 5 Al \w que|strong="H1121"\w* denuncia \w a|strong="H3068"\w* sus \w amigos|strong="H7453"\w* por una \w parte|strong="H2506"\w* del botín,  
\q2 aun \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* desfallecerán.   
\b  
\q1
\v 6 “Él me ha puesto \w como|strong="H1961"\w* refrán \w de|strong="H6440"\w* \w los|strong="H1961"\w* \w pueblos|strong="H5971"\w*,  
\q2 y me han escupido en la \w cara|strong="H6440"\w*.   
\q1
\v 7 Mis \w ojos|strong="H5869"\w* se han \w oscurecido|strong="H3543"\w* por \w el|strong="H3605"\w* dolor,  
\q2 y \w todos|strong="H3605"\w* mis miembros son como una \w sombra|strong="H6738"\w*.   
\q1
\v 8 \w Los|strong="H5921"\w* \w rectos|strong="H3477"\w* \w se|strong="H5921"\w* asombrarán \w de|strong="H5921"\w* \w esto|strong="H2063"\w*,  
\q2 \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w inocente|strong="H5355"\w* \w se|strong="H5921"\w* levantará \w contra|strong="H5921"\w* \w el|strong="H5921"\w* impío.   
\q1
\v 9 \w No|strong="H1870"\w* obstante, el \w justo|strong="H6662"\w* se mantendrá en su \w camino|strong="H1870"\w*,  
\q2 y el \w limpio|strong="H2891"\w* \w de|strong="H6662"\w* \w manos|strong="H3027"\w* \w aumentará|strong="H3254"\w* su fuerza.   
\q1
\v 10 \w Mas|strong="H3808"\w* \w volved|strong="H7725"\w* \w todos|strong="H3605"\w* vosotros, y venid \w ahora|strong="H4994"\w*,  
\q2 \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w hallaré|strong="H4672"\w* \w entre|strong="H3808"\w* vosotros \w sabio|strong="H2450"\w* \w alguno|strong="H3605"\w*.   
\q1
\v 11 \w Pasaron|strong="H5674"\w* mis \w días|strong="H3117"\w*, y mis planes se desbarataron,  
\q2 aun los deseos de mi \w corazón|strong="H3824"\w*.   
\q1
\v 12 Ellos cambian la \w noche|strong="H3915"\w* en \w día|strong="H3117"\w*,  
\q2 y dicen \w que|strong="H3117"\w* la luz está \w cerca|strong="H7138"\w* frente \w a|strong="H3068"\w* las \w tinieblas|strong="H2822"\w*.   
\q1
\v 13 Si yo \w espero|strong="H6960"\w* el Seol como mi \w casa|strong="H1004"\w*,  
\q2 y tiendo mi lecho en las \w tinieblas|strong="H2822"\w*;   
\q1
\v 14 si \w a|strong="H3068"\w* la \w corrupción|strong="H7845"\w* digo: ‘Tú eres mi padre’,  
\q2 y \w a|strong="H3068"\w* los \w gusanos|strong="H7415"\w*: ‘Mi madre’ y ‘Mi hermana’,   
\q1
\v 15 ¿dónde estará entonces mi \w esperanza|strong="H8615"\w*?  
\q2 \w Y|strong="H3068"\w* mi \w esperanza|strong="H8615"\w*, ¿\w quién|strong="H4310"\w* la verá?   
\q1
\v 16 \w A|strong="H3068"\w* \w las|strong="H5921"\w* puertas \w del|strong="H5921"\w* Seol \w descenderán|strong="H3381"\w*,  
\q2 \w y|strong="H5921"\w* \w juntos|strong="H3162"\w* descansaremos \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*”.   
\b  
\c 18
\p
\v 1 \w Respondió|strong="H6030"\w* \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w*, y dijo:   
\q1
\v 2 “¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* \w pondréis|strong="H7760"\w* \w fin|strong="H7078"\w* \w a|strong="H3068"\w* las \w palabras|strong="H1696"\w*?  
\q2 Entended vosotros, \w y|strong="H5704"\w* \w después|strong="H5704"\w* \w hablemos|strong="H1696"\w*.   
\q1
\v 3 ¿\w Por|strong="H4069"\w* qué somos \w tenidos|strong="H2803"\w* \w por|strong="H4069"\w* bestias,  
\q2 y \w a|strong="H3068"\w* vuestros \w ojos|strong="H5869"\w* somos viles?   
\q1
\v 4 Oh tú, \w que|strong="H4616"\w* \w te|strong="H5315"\w* despedazas en tu furor,  
\q2 ¿será \w abandonada|strong="H5800"\w* la tierra \w por|strong="H4616"\w* amor de ti,  
\q2 \w o|strong="H3068"\w* serán removidas las peñas de su \w lugar|strong="H4725"\w*?   
\b  
\q1
\v 5 «\w Ciertamente|strong="H1571"\w* \w la|strong="H1571"\w* luz de los \w impíos|strong="H7563"\w* \w se|strong="H3808"\w* apagará,  
\q2 \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w resplandecerá|strong="H5050"\w* \w la|strong="H1571"\w* centella de su fuego.   
\q1
\v 6 \w La|strong="H5921"\w* luz \w se|strong="H5921"\w* oscurecerá \w en|strong="H5921"\w* su tienda,  
\q2 \w y|strong="H5921"\w* su \w lámpara|strong="H5216"\w* \w se|strong="H5921"\w* apagará \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*.   
\q1
\v 7 Los \w pasos|strong="H6806"\w* de su fuerza serán acortados,  
\q2 y su propio \w consejo|strong="H6098"\w* lo hará caer.   
\q1
\v 8 \w Porque|strong="H3588"\w* sus propios \w pies|strong="H7272"\w* \w lo|strong="H5921"\w* arrojan \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w red|strong="H7568"\w*,  
\q2 \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* malla \w camina|strong="H1980"\w*.   
\q1
\v 9 \w El|strong="H5921"\w* \w lazo|strong="H6341"\w* \w lo|strong="H5921"\w* prenderá \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w calcañar|strong="H6119"\w*;  
\q2 \w la|strong="H5921"\w* trampa prevalecerá \w contra|strong="H5921"\w* \w él|strong="H5921"\w*.   
\q1
\v 10 Su cuerda \w está|strong="H5921"\w* escondida \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra,  
\q2 \w y|strong="H5921"\w* una celada \w le|strong="H5921"\w* aguarda \w en|strong="H5921"\w* \w el|strong="H5921"\w* sendero.   
\q1
\v 11 Por \w todas|strong="H5439"\w* \w partes|strong="H5439"\w* lo espantarán \w terrores|strong="H1091"\w*,  
\q2 \w y|strong="H1091"\w* le perseguirán paso \w a|strong="H3068"\w* paso.   
\q1
\v 12 \w Hambrienta|strong="H7457"\w* \w será|strong="H1961"\w* su fuerza,  
\q2 y el quebranto \w estará|strong="H1961"\w* preparado \w a|strong="H3068"\w* su \w lado|strong="H6763"\w*.   
\q1
\v 13 Las enfermedades devorarán los miembros de su cuerpo;  
\q2 el \w primogénito|strong="H1060"\w* de la \w muerte|strong="H4194"\w* devorará sus miembros.   
\q1
\v 14 De su tienda, donde estaba seguro, será arrancado,  
\q2 \w y|strong="H1091"\w* será llevado \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de los \w terrores|strong="H1091"\w*.   
\q1
\v 15 \w En|strong="H5921"\w* su tienda \w habitará|strong="H7931"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w no|strong="H1097"\w* es suyo;  
\q2 \w azufre|strong="H1614"\w* será esparcido \w sobre|strong="H5921"\w* su \w morada|strong="H5116"\w*.   
\q1
\v 16 \w Por|strong="H8478"\w* \w abajo|strong="H8478"\w* se secarán sus \w raíces|strong="H8328"\w*,  
\q2 y \w por|strong="H8478"\w* \w arriba|strong="H4605"\w* serán cortadas sus \w ramas|strong="H7105"\w*.   
\q1
\v 17 Su \w memoria|strong="H2143"\w* \w perecerá|strong="H3808"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra,  
\q2 \w y|strong="H5921"\w* \w no|strong="H3808"\w* tendrá \w nombre|strong="H8034"\w* \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w*.   
\q1
\v 18 De la luz será lanzado \w a|strong="H3068"\w* las \w tinieblas|strong="H2822"\w*,  
\q2 y será expulsado del \w mundo|strong="H8398"\w*.   
\q1
\v 19 \w No|strong="H3808"\w* tendrá \w hijo|strong="H5209"\w* \w ni|strong="H3808"\w* \w nieto|strong="H5220"\w* en su \w pueblo|strong="H5971"\w*,  
\q2 \w ni|strong="H3808"\w* quien le \w suceda|strong="H8300"\w* en sus moradas.   
\q1
\v 20 \w Sobre|strong="H5921"\w* su \w día|strong="H3117"\w* \w se|strong="H5921"\w* espantarán \w los|strong="H5921"\w* venideros,  
\q2 \w como|strong="H5921"\w* \w el|strong="H5921"\w* terror sobrecogió \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w antiguos|strong="H6931"\w*.   
\q1
\v 21 Ciertamente tales \w son|strong="H3808"\w* las \w moradas|strong="H4908"\w* de los injustos,  
\q2 y \w este|strong="H2088"\w* \w es|strong="H2088"\w* el \w lugar|strong="H4725"\w* del \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w conoció|strong="H3045"\w* \w a|strong="H3068"\w* Dios».   
\c 19
\p
\v 1 Entonces \w respondió|strong="H6030"\w* Job, y dijo:   
\q1
\v 2 “¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* \w angustiaréis|strong="H3013"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*,  
\q2 \w y|strong="H5704"\w* me quebrantaréis \w con|strong="H5704"\w* \w palabras|strong="H4405"\w*?   
\q1
\v 3 \w Ya|strong="H3068"\w* me habéis vituperado \w diez|strong="H6235"\w* \w veces|strong="H6471"\w*;  
\q2 ¿\w no|strong="H3808"\w* os avergonzáis de injuriarme?   
\q1
\v 4 Aun siendo verdad que yo haya errado,  
\q2 conmigo se quedaría mi error.   
\q1
\v 5 \w Si|strong="H5921"\w* \w de|strong="H5921"\w* verdad \w os|strong="H5921"\w* engrandecéis \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* alegáis \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w mi|strong="H5921"\w* \w oprobio|strong="H2781"\w*,   
\q1
\v 6 \w sabed|strong="H3045"\w* ahora \w que|strong="H3588"\w* Dios \w me|strong="H5921"\w* ha trastornado,  
\q2 \w y|strong="H3588"\w* \w me|strong="H5921"\w* ha rodeado \w con|strong="H5921"\w* \w su|strong="H3588"\w* \w red|strong="H4686"\w*.   
\b  
\q1
\v 7 “He \w aquí|strong="H2005"\w*, yo \w clamo|strong="H6817"\w*: ‘¡\w Agravio|strong="H2555"\w*!’, \w mas|strong="H6030"\w* \w no|strong="H3808"\w* soy oído;  
\q2 doy gritos, \w mas|strong="H6030"\w* \w no|strong="H3808"\w* hay \w justicia|strong="H4941"\w*.   
\q1
\v 8 \w Cercó|strong="H1443"\w* \w mi|strong="H5921"\w* camino, \w y|strong="H5921"\w* \w no|strong="H3808"\w* puedo \w pasar|strong="H5674"\w*;  
\q2 \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* mis \w veredas|strong="H5410"\w* \w puso|strong="H7760"\w* \w tinieblas|strong="H2822"\w*.   
\q1
\v 9 \w Me|strong="H5921"\w* ha despojado \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w gloria|strong="H3519"\w*,  
\q2 \w y|strong="H5921"\w* ha quitado \w la|strong="H5921"\w* \w corona|strong="H5850"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*.   
\q1
\v 10 Me arruinó por todos \w lados|strong="H5439"\w*, y pereceré;  
\q2 y ha hecho pasar mi \w esperanza|strong="H8615"\w* como \w árbol|strong="H6086"\w* arrancado.   
\q1
\v 11 Hizo arder \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* su furor,  
\q2 \w y|strong="H5921"\w* \w me|strong="H5921"\w* contó \w entre|strong="H5921"\w* sus \w enemigos|strong="H6862"\w*.   
\q1
\v 12 Vinieron sus \w ejércitos|strong="H1416"\w* \w a|strong="H3068"\w* una,  
\q2 \w y|strong="H5921"\w* trazaron su \w camino|strong="H1870"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* acamparon \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* tienda.   
\b  
\q1
\v 13 “Hizo alejar \w de|strong="H4480"\w* \w mí|strong="H5921"\w* \w a|strong="H3068"\w* mis hermanos,  
\q2 \w y|strong="H5921"\w* mis conocidos totalmente \w se|strong="H3045"\w* extrañaron \w de|strong="H4480"\w* \w mí|strong="H5921"\w*.   
\q1
\v 14 Mis parientes \w se|strong="H3045"\w* detuvieron,  
\q2 y mis amigos íntimos me \w olvidaron|strong="H7911"\w*.   
\q1
\v 15 \w Los|strong="H1961"\w* moradores \w de|strong="H5869"\w* \w mi|strong="H1961"\w* \w casa|strong="H1004"\w* y mis criadas me \w tuvieron|strong="H1961"\w* por \w extraño|strong="H5237"\w*;  
\q2 \w forastero|strong="H5237"\w* \w fui|strong="H1961"\w* yo \w a|strong="H3068"\w* sus \w ojos|strong="H5869"\w*.   
\q1
\v 16 \w Llamé|strong="H7121"\w* \w a|strong="H3068"\w* \w mi|strong="H6030"\w* \w siervo|strong="H5650"\w*, y \w no|strong="H3808"\w* \w respondió|strong="H6030"\w*;  
\q2 con \w mi|strong="H6030"\w* propia \w boca|strong="H6310"\w* le suplicaba.   
\q1
\v 17 Mi \w hálito|strong="H7307"\w* vino \w a|strong="H3068"\w* ser \w extraño|strong="H1121"\w* \w a|strong="H3068"\w* mi mujer,  
\q2 aunque por \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* mi propia matriz le \w rogaba|strong="H2603"\w*.   
\q1
\v 18 \w Aun|strong="H1571"\w* los muchachos me \w menospreciaron|strong="H3988"\w*;  
\q2 al \w levantarme|strong="H6965"\w*, \w hablaban|strong="H1696"\w* contra mí.   
\q1
\v 19 \w Todos|strong="H3605"\w* mis íntimos me aborrecieron,  
\q2 y \w los|strong="H3605"\w* \w que|strong="H2088"\w* yo amaba se \w volvieron|strong="H2015"\w* contra mí.   
\q1
\v 20 Mi \w piel|strong="H5785"\w* y mi \w carne|strong="H1320"\w* se pegaron \w a|strong="H3068"\w* mis \w huesos|strong="H6106"\w*,  
\q2 y he escapado con la \w piel|strong="H5785"\w* de mis \w dientes|strong="H8127"\w*.   
\b  
\q1
\v 21 “¡Oh, vosotros mis \w amigos|strong="H7453"\w*, \w tened|strong="H7453"\w* \w compasión|strong="H2603"\w* \w de|strong="H3588"\w* mí, \w tened|strong="H7453"\w* \w compasión|strong="H2603"\w* \w de|strong="H3588"\w* mí!,  
\q2 \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* Dios \w me|strong="H3588"\w* ha tocado.   
\q1
\v 22 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* me perseguís \w como|strong="H4100"\w* Dios,  
\q2 y \w ni|strong="H3808"\w* \w aun|strong="H3808"\w* \w de|strong="H7646"\w* mi \w carne|strong="H1320"\w* os saciáis?   
\b  
\q1
\v 23 “¡\w Quién|strong="H4310"\w* \w diera|strong="H5414"\w* ahora \w que|strong="H4310"\w* \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w* fuesen \w escritas|strong="H3789"\w*!  
\q2 ¡\w Quién|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* se fuesen grabando en un \w libro|strong="H5612"\w*;   
\q1
\v 24 que con cincel de \w hierro|strong="H1270"\w* y con plomo  
\q2 fuesen \w esculpidas|strong="H2672"\w* en piedra \w para|strong="H5703"\w* \w siempre|strong="H5703"\w*!   
\q1
\v 25 Yo \w sé|strong="H3045"\w* \w que|strong="H5921"\w* \w mi|strong="H5921"\w* \w Redentor|strong="H1350"\w* \w vive|strong="H2416"\w*,  
\q2 \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w al|strong="H5921"\w* fin \w se|strong="H3045"\w* \w levantará|strong="H6965"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*;   
\q1
\v 26 y después de deshecha \w esta|strong="H2063"\w* mi \w piel|strong="H5785"\w*,  
\q2 en mi \w carne|strong="H1320"\w* he de ver \w a|strong="H3068"\w* Dios;   
\q1
\v 27 al cual \w veré|strong="H7200"\w* por mí mismo,  
\q2 y mis \w ojos|strong="H5869"\w* \w lo|strong="H3808"\w* \w verán|strong="H7200"\w*, y \w no|strong="H3808"\w* otro.  
\b  
\q1 “Mis entrañas \w se|strong="H3808"\w* consumen \w dentro|strong="H2436"\w* \w de|strong="H5869"\w* mí.   
\q1
\v 28 \w Mas|strong="H3588"\w* \w si|strong="H3588"\w* decís: ‘¿\w Cómo|strong="H4100"\w* le perseguiremos?’,  
\q2 ya \w que|strong="H3588"\w* \w la|strong="H3588"\w* raíz del \w asunto|strong="H1697"\w* \w se|strong="H4100"\w* \w halla|strong="H4672"\w* \w en|strong="H3588"\w* mí,   
\q1
\v 29 \w temed|strong="H1481"\w* vosotros \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w*;  
\q2 \w porque|strong="H3588"\w* sobreviene \w el|strong="H3588"\w* \w furor|strong="H2534"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w causa|strong="H1779"\w* \w de|strong="H3588"\w* las injusticias,  
\q2 \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w sepáis|strong="H3045"\w* \w que|strong="H3588"\w* hay un \w juicio|strong="H1779"\w*”.   
\c 20
\p
\v 1 \w Respondió|strong="H6030"\w* Zofar \w naamatita|strong="H5284"\w*, y dijo:   
\q1
\v 2 “\w Por|strong="H5668"\w* \w cierto|strong="H3651"\w* mis turbados \w pensamientos|strong="H5587"\w* me hacen \w responder|strong="H7725"\w*,  
\q2 y \w por|strong="H5668"\w* \w tanto|strong="H3651"\w* me apresuro.   
\q1
\v 3 La reprensión de \w mi|strong="H6030"\w* censura he \w oído|strong="H8085"\w*,  
\q2 y me hace \w responder|strong="H6030"\w* el \w espíritu|strong="H7307"\w* de \w mi|strong="H6030"\w* inteligencia.   
\q1
\v 4 ¿\w No|strong="H5921"\w* \w sabes|strong="H3045"\w* \w esto|strong="H2063"\w* \w desde|strong="H4480"\w* antiguo,  
\q2 \w desde|strong="H4480"\w* \w que|strong="H4480"\w* fue puesto \w el|strong="H5921"\w* hombre \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra,   
\q1
\v 5 \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w alegría|strong="H8057"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w impíos|strong="H7563"\w* \w es|strong="H3588"\w* breve,  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w gozo|strong="H8057"\w* del hipotócrita dura solo un \w momento|strong="H7281"\w*?   
\q1
\v 6 Aunque su altivez \w subiere|strong="H5927"\w* hasta los \w cielos|strong="H8064"\w*,  
\q2 y su \w cabeza|strong="H7218"\w* \w tocare|strong="H5060"\w* en las \w nubes|strong="H5645"\w*,   
\q1
\v 7 como su propio estiércol perecerá para siempre;  
\q2 los que le hubieren \w visto|strong="H7200"\w* dirán: ‘¿Qué hay de él?’.   
\q1
\v 8 Como \w sueño|strong="H2472"\w* \w volará|strong="H5774"\w*, y \w no|strong="H3808"\w* \w será|strong="H3808"\w* \w hallado|strong="H4672"\w*;  
\q2 y \w se|strong="H3808"\w* disipará como \w visión|strong="H2384"\w* \w nocturna|strong="H3915"\w*.   
\q1
\v 9 El \w ojo|strong="H5869"\w* \w que|strong="H3808"\w* \w le|strong="H3254"\w* vio, \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w le|strong="H3254"\w* verá,  
\q2 \w ni|strong="H3808"\w* su \w lugar|strong="H4725"\w* \w le|strong="H3254"\w* conocerá \w más|strong="H5750"\w*.   
\q1
\v 10 Sus \w hijos|strong="H1121"\w* buscarán \w el|strong="H1121"\w* favor \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w pobres|strong="H1800"\w*,  
\q2 y sus \w manos|strong="H3027"\w* devolverán sus riquezas.   
\q1
\v 11 Sus \w huesos|strong="H6106"\w* están \w llenos|strong="H4390"\w* \w de|strong="H5921"\w* su vigor juvenil,  
\q2 \w mas|strong="H5921"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w* \w yacerán|strong="H7901"\w*.   
\b  
\q1
\v 12 “Aunque la \w maldad|strong="H7451"\w* sea dulce \w en|strong="H8478"\w* su \w boca|strong="H6310"\w*,  
\q2 y la \w oculte|strong="H3582"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* su \w lengua|strong="H3956"\w*,   
\q1
\v 13 \w aunque|strong="H3808"\w* \w la|strong="H5921"\w* guarde \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w la|strong="H5921"\w* \w deje|strong="H5800"\w*,  
\q2 \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w la|strong="H5921"\w* retenga \w en|strong="H5921"\w* su paladar;   
\q1
\v 14 su \w comida|strong="H3899"\w* se \w mudará|strong="H2015"\w* en sus \w entrañas|strong="H4578"\w*;  
\q2 \w hiel|strong="H4846"\w* de áspides será \w dentro|strong="H7130"\w* de él.   
\q1
\v 15 \w Devoró|strong="H1104"\w* \w riquezas|strong="H2428"\w*, pero las vomitará;  
\q2 de su vientre las sacará Dios.   
\q1
\v 16 Hiel de áspides \w chupará|strong="H3243"\w*;  
\q2 lo \w matará|strong="H2026"\w* \w lengua|strong="H3956"\w* de víbora.   
\q1
\v 17 No \w verá|strong="H7200"\w* los \w arroyos|strong="H5158"\w*,  
\q2 los ríos de \w miel|strong="H1706"\w* y de \w manteca|strong="H2529"\w*.   
\q1
\v 18 \w Restituirá|strong="H7725"\w* el trabajo \w sin|strong="H3808"\w* haberlo \w tragado|strong="H1104"\w*;  
\q2 \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w gozará|strong="H5965"\w* según la hacienda de su comercio.   
\q1
\v 19 \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* oprimió \w y|strong="H3588"\w* desamparó \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w pobres|strong="H1800"\w*,  
\q2 \w robó|strong="H1497"\w* \w casas|strong="H1004"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* las \w edificó|strong="H1129"\w*.   
\b  
\q1
\v 20 «\w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w no|strong="H3808"\w* \w sintió|strong="H3045"\w* sosiego \w en|strong="H3588"\w* \w su|strong="H3588"\w* vientre,  
\q2 \w ni|strong="H3808"\w* \w salvará|strong="H4422"\w* \w nada|strong="H3808"\w* \w de|strong="H3588"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* codiciaba.   
\q1
\v 21 \w No|strong="H3808"\w* \w quedó|strong="H8300"\w* \w nada|strong="H3808"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* devorase;  
\q2 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, su bienestar \w no|strong="H3808"\w* \w será|strong="H3808"\w* duradero.   
\q1
\v 22 En \w la|strong="H3605"\w* plenitud de su abundancia tendrá angustia;  
\q2 \w la|strong="H3605"\w* \w mano|strong="H3027"\w* de \w todos|strong="H3605"\w* \w los|strong="H3605"\w* malvados vendrá sobre \w él|strong="H3605"\w*.   
\q1
\v 23 \w Cuando|strong="H1961"\w* \w se|strong="H1961"\w* pusiere \w a|strong="H3068"\w* llenar su vientre, Dios \w enviará|strong="H7971"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w el|strong="H5921"\w* ardor \w de|strong="H5921"\w* su \w ira|strong="H2740"\w*,  
\q2 \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w lloverá|strong="H4305"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* su comida.   
\q1
\v 24 \w Huirá|strong="H1272"\w* de las \w armas|strong="H5402"\w* de \w hierro|strong="H1270"\w*,  
\q2 y el \w arco|strong="H7198"\w* de bronce le atravesará.   
\q1
\v 25 \w La|strong="H5921"\w* saeta \w saldrá|strong="H3318"\w* \w y|strong="H5921"\w* \w pasará|strong="H1980"\w* \w por|strong="H5921"\w* su cuerpo,  
\q2 \w y|strong="H5921"\w* \w el|strong="H5921"\w* hierro reluciente \w por|strong="H5921"\w* su \w hiel|strong="H4846"\w*;  
\q2 \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* vendrán terrores.   
\q1
\v 26 \w Todas|strong="H3605"\w* las \w tinieblas|strong="H2822"\w* están reservadas para sus tesoros;  
\q2 fuego \w no|strong="H3808"\w* \w soplado|strong="H5301"\w* \w los|strong="H3605"\w* devorará;  
\q2 consumirá \w lo|strong="H3808"\w* \w que|strong="H3808"\w* hubiere quedado en su tienda.   
\q1
\v 27 Los \w cielos|strong="H8064"\w* \w descubrirán|strong="H1540"\w* su \w iniquidad|strong="H5771"\w*,  
\q2 y la tierra se \w levantará|strong="H6965"\w* contra él.   
\q1
\v 28 Los renuevos de su \w casa|strong="H1004"\w* serán transportados;  
\q2 se derramarán en el \w día|strong="H3117"\w* de su furor.   
\q1
\v 29 \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* la porción \w que|strong="H2088"\w* Dios prepara al hombre \w impío|strong="H7563"\w*,  
\q2 y la \w heredad|strong="H5159"\w* \w que|strong="H2088"\w* Dios le señala \w por|strong="H2088"\w* su palabra».   
\c 21
\p
\v 1 Entonces \w respondió|strong="H6030"\w* Job, y dijo:   
\q1
\v 2 “\w Oíd|strong="H8085"\w* \w atentamente|strong="H8085"\w* \w mi|strong="H1961"\w* discurso,  
\q2 y \w sea|strong="H1961"\w* \w esto|strong="H2063"\w* el consuelo \w que|strong="H1961"\w* me deis.   
\q1
\v 3 Soportadme, y yo \w hablaré|strong="H1696"\w*;  
\q2 y después que haya \w hablado|strong="H1696"\w*, mofaos si queréis.   
\q1
\v 4 ¿Acaso es al hombre \w a|strong="H3068"\w* quien dirijo mi queja?  
\q2 ¿\w Y|strong="H3068"\w* \w por|strong="H4069"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* habría de estar mi \w espíritu|strong="H7307"\w* impaciente?   
\q1
\v 5 \w Miradme|strong="H6437"\w*, \w y|strong="H5921"\w* \w espantaos|strong="H8074"\w*,  
\q2 \w y|strong="H5921"\w* \w poned|strong="H7760"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* vuestra \w boca|strong="H6310"\w*.   
\q1
\v 6 Aun yo mismo, cuando me acuerdo, me horrorizo,  
\q2 y el \w temblor|strong="H6427"\w* estremece mi \w carne|strong="H1320"\w*.   
\b  
\q1
\v 7 “¿\w Por|strong="H4069"\w* \w qué|strong="H1571"\w* \w viven|strong="H7563"\w* los \w impíos|strong="H7563"\w*,  
\q2 \w y|strong="H1571"\w* envejecen, \w y|strong="H1571"\w* \w aun|strong="H1571"\w* se hacen poderosos en \w riquezas|strong="H2428"\w*?   
\q1
\v 8 Su \w descendencia|strong="H2233"\w* se robustece \w en|strong="H5973"\w* su \w presencia|strong="H6440"\w*,  
\q2 y sus \w renuevos|strong="H6631"\w* están \w delante|strong="H6440"\w* \w de|strong="H6440"\w* sus \w ojos|strong="H5869"\w*.   
\q1
\v 9 Sus \w casas|strong="H1004"\w* están libres \w de|strong="H5921"\w* \w temor|strong="H6343"\w*,  
\q2 \w ni|strong="H3808"\w* azota \w la|strong="H5921"\w* \w vara|strong="H7626"\w* \w de|strong="H5921"\w* Dios \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
\q1
\v 10 Sus toros engendran \w sin|strong="H3808"\w* fallar;  
\q2 sus \w vacas|strong="H6510"\w* \w paren|strong="H6403"\w* \w y|strong="H7794"\w* \w no|strong="H3808"\w* \w malogran|strong="H7921"\w* su cría.   
\q1
\v 11 \w Salen|strong="H7971"\w* sus pequeñuelos como un \w rebaño|strong="H6629"\w*,  
\q2 y sus \w hijos|strong="H3206"\w* andan saltando.   
\q1
\v 12 Al son del tamboril y de la cítara cantan,  
\q2 y se regocijan al son de la flauta.   
\q1
\v 13 Pasan sus \w días|strong="H3117"\w* en prosperidad,  
\q2 y en un \w momento|strong="H7281"\w* descienden al Seol.   
\q1
\v 14 Dicen, \w pues|strong="H4480"\w*, \w a|strong="H3068"\w* Dios: ‘\w Apártate|strong="H5493"\w* \w de|strong="H4480"\w* nosotros,  
\q2 \w porque|strong="H3808"\w* \w no|strong="H3808"\w* deseamos el \w conocimiento|strong="H1847"\w* \w de|strong="H4480"\w* tus \w caminos|strong="H1870"\w*.   
\q1
\v 15 ¿\w Quién|strong="H4100"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w Todopoderoso|strong="H7706"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* le \w sirvamos|strong="H5647"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w de|strong="H3588"\w* \w qué|strong="H3588"\w* \w nos|strong="H4100"\w* aprovechará \w que|strong="H3588"\w* le \w oremos|strong="H6293"\w*?’.   
\q1
\v 16 \w Mas|strong="H4480"\w* he \w aquí|strong="H2005"\w* \w que|strong="H4480"\w* su \w bien|strong="H2898"\w* \w no|strong="H3808"\w* está \w en|strong="H4480"\w* \w mano|strong="H3027"\w* \w de|strong="H4480"\w* \w ellos|strong="H3027"\w*;  
\q2 ¡\w lejos|strong="H7368"\w* esté \w de|strong="H4480"\w* mí el \w consejo|strong="H6098"\w* \w de|strong="H4480"\w* los \w impíos|strong="H7563"\w*!   
\b  
\q1
\v 17 “¿\w Cuántas|strong="H4100"\w* veces \w se|strong="H5921"\w* apaga \w la|strong="H5921"\w* \w lámpara|strong="H5216"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w impíos|strong="H7563"\w*,  
\q2 \w o|strong="H3068"\w* viene \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* su quebranto,  
\q2 \w y|strong="H5921"\w* Dios \w en|strong="H5921"\w* su ira \w les|strong="H5921"\w* reparte \w dolores|strong="H2256"\w*?   
\q1
\v 18 ¿\w Serán|strong="H1961"\w* ellos \w como|strong="H1961"\w* el tamo \w delante|strong="H6440"\w* del \w viento|strong="H7307"\w*,  
\q2 y \w como|strong="H1961"\w* la \w paja|strong="H8401"\w* \w que|strong="H1961"\w* arrebata el \w torbellino|strong="H5492"\w*?   
\q1
\v 19 Diréis: ‘Dios guarda para \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w él|strong="H1121"\w* su iniquidad’.  
\q2 ¡\w Que|strong="H3045"\w* le \w dé|strong="H1121"\w* \w a|strong="H3068"\w* \w él|strong="H1121"\w* \w el|strong="H1121"\w* pago, para \w que|strong="H3045"\w* aprenda!   
\q1
\v 20 \w Vean|strong="H7200"\w* sus propios \w ojos|strong="H5869"\w* su destrucción,  
\q2 y beba \w de|strong="H5869"\w* la \w ira|strong="H2534"\w* \w del|strong="H8354"\w* \w Omnipotente|strong="H7706"\w*.   
\q1
\v 21 \w Porque|strong="H3588"\w* ¿\w qué|strong="H3588"\w* \w deleite|strong="H2656"\w* tendrá \w él|strong="H3588"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w* después \w de|strong="H3588"\w* \w sí|strong="H3588"\w*,  
\q2 \w cuando|strong="H3588"\w* \w el|strong="H3588"\w* \w número|strong="H4557"\w* \w de|strong="H3588"\w* sus \w meses|strong="H2320"\w* \w se|strong="H4100"\w* haya cortado?   
\b  
\q1
\v 22 “¿\w Enseñará|strong="H3925"\w* alguien \w a|strong="H3068"\w* Dios \w sabiduría|strong="H1847"\w*,  
\q2 \w juzgando|strong="H8199"\w* \w él|strong="H1931"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w que|strong="H1931"\w* están elevados?   
\q1
\v 23 \w Este|strong="H2088"\w* muere en \w el|strong="H3605"\w* vigor de su hermosura,  
\q2 \w todo|strong="H3605"\w* \w quieto|strong="H7946"\w* y pacífico;   
\q1
\v 24 sus vasijas están \w llenas|strong="H4390"\w* de \w leche|strong="H2461"\w*,  
\q2 y sus \w huesos|strong="H6106"\w* humedecidos de tuétano.   
\q1
\v 25 \w Y|strong="H3068"\w* \w otro|strong="H2088"\w* muere en \w amargura|strong="H4751"\w* de \w ánimo|strong="H5315"\w*,  
\q2 y \w sin|strong="H3808"\w* \w haber|strong="H3808"\w* comido \w jamás|strong="H3808"\w* con gusto.   
\q1
\v 26 \w Igualmente|strong="H3162"\w* \w yacen|strong="H7901"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*,  
\q2 \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w gusanos|strong="H7415"\w* \w los|strong="H5921"\w* \w cubren|strong="H3680"\w*.   
\b  
\q1
\v 27 “He \w aquí|strong="H2005"\w*, yo \w conozco|strong="H3045"\w* vuestros \w pensamientos|strong="H4284"\w*,  
\q2 \w y|strong="H5921"\w* \w los|strong="H5921"\w* planes \w que|strong="H5921"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* tramáis.   
\q1
\v 28 \w Porque|strong="H3588"\w* decís: ‘¿Dónde está \w la|strong="H3588"\w* \w casa|strong="H1004"\w* del príncipe,  
\q2 \w y|strong="H3588"\w* dónde \w la|strong="H3588"\w* tienda \w de|strong="H3588"\w* las \w moradas|strong="H4908"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w impíos|strong="H7563"\w*?’.   
\q1
\v 29 ¿\w No|strong="H3808"\w* habéis preguntado \w a|strong="H3068"\w* los \w que|strong="H3808"\w* \w pasan|strong="H5674"\w* \w por|strong="H1870"\w* los \w caminos|strong="H1870"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w no|strong="H3808"\w* habéis conocido sus testimonios?   
\q1
\v 30 \w Que|strong="H3588"\w* \w el|strong="H3588"\w* \w malo|strong="H7451"\w* \w es|strong="H3588"\w* preservado \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* destrucción,  
\q2 \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* ira será conducido.   
\q1
\v 31 ¿\w Quién|strong="H4310"\w* \w le|strong="H1931"\w* \w denunciará|strong="H5046"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w cara|strong="H6440"\w* \w su|strong="H1931"\w* \w camino|strong="H1870"\w*?  
\q2 \w Y|strong="H3068"\w* \w de|strong="H5921"\w* \w lo|strong="H1931"\w* \w que|strong="H4310"\w* \w él|strong="H1931"\w* \w hizo|strong="H6213"\w*, ¿\w quién|strong="H4310"\w* \w le|strong="H1931"\w* \w dará|strong="H7999"\w* \w el|strong="H1931"\w* pago?   
\q1
\v 32 \w Pues|strong="H1931"\w* \w llevado|strong="H2986"\w* \w será|strong="H1931"\w* \w él|strong="H1931"\w* \w al|strong="H5921"\w* \w sepulcro|strong="H6913"\w*,  
\q2 \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* túmulo \w se|strong="H1931"\w* velará.   
\q1
\v 33 \w Los|strong="H3605"\w* terrones del valle le serán dulces;  
\q2 tras \w él|strong="H3605"\w* irá \w todo|strong="H3605"\w* hombre,  
\q2 y \w antes|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H3605"\w* hubo innumerables.   
\q1
\v 34 ¿Cómo, pues, me consoláis en \w vano|strong="H1892"\w*,  
\q2 cuando en vuestras respuestas solo \w queda|strong="H7604"\w* la falsedad?”.   
\c 22
\p
\v 1 \w Respondió|strong="H6030"\w* Elifaz \w temanita|strong="H8489"\w*, y dijo:   
\q1
\v 2 “¿Será \w el|strong="H5921"\w* \w hombre|strong="H1397"\w* \w de|strong="H5921"\w* \w provecho|strong="H5532"\w* \w a|strong="H3068"\w* Dios?  
\q2 \w Ciertamente|strong="H3588"\w* \w el|strong="H5921"\w* sabio solo \w para|strong="H5921"\w* \w sí|strong="H3588"\w* mismo \w es|strong="H3588"\w* provechoso.   
\q1
\v 3 ¿Tiene \w el|strong="H3588"\w* \w Omnipotente|strong="H7706"\w* algún \w deleite|strong="H2656"\w* \w en|strong="H3588"\w* \w que|strong="H3588"\w* tú seas justo,  
\q2 \w o|strong="H3068"\w* lucro \w en|strong="H3588"\w* \w que|strong="H3588"\w* tú hagas perfectos tus \w caminos|strong="H1870"\w*?   
\q1
\v 4 ¿Acaso \w te|strong="H5973"\w* \w reprende|strong="H3198"\w* por \w temor|strong="H3374"\w* \w de|strong="H5973"\w* \w ti|strong="H5973"\w*,  
\q2 \w o|strong="H3068"\w* entra \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w* \w en|strong="H5973"\w* \w juicio|strong="H4941"\w*?   
\q1
\v 5 Por \w cierto|strong="H3808"\w*, ¿\w no|strong="H3808"\w* es \w grande|strong="H7227"\w* tu \w maldad|strong="H5771"\w*,  
\q2 y tus \w iniquidades|strong="H5771"\w* \w sin|strong="H3808"\w* \w fin|strong="H7093"\w*?   
\q1
\v 6 \w Porque|strong="H3588"\w* tomaste fianza \w de|strong="H3588"\w* tus hermanos sin causa,  
\q2 \w y|strong="H3588"\w* despojaste \w de|strong="H3588"\w* sus ropas \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w desnudos|strong="H6174"\w*.   
\q1
\v 7 \w No|strong="H3808"\w* diste \w de|strong="H4325"\w* \w beber|strong="H8248"\w* \w agua|strong="H4325"\w* al \w cansado|strong="H5889"\w*,  
\q2 y negaste el \w pan|strong="H3899"\w* al hambriento.   
\q1
\v 8 Pero \w el|strong="H3427"\w* hombre pudiente poseía la tierra,  
\q2 y \w el|strong="H3427"\w* distinguido \w habitaba|strong="H3427"\w* en ella.   
\q1
\v 9 \w A|strong="H3068"\w* las viudas \w enviaste|strong="H7971"\w* \w vacías|strong="H7387"\w*,  
\q2 y los \w brazos|strong="H2220"\w* de los \w huérfanos|strong="H3490"\w* fueron quebrantados.   
\q1
\v 10 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, hay \w lazos|strong="H6341"\w* \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* \w te|strong="H5921"\w* turba un pavor \w repentino|strong="H6597"\w*;   
\q1
\v 11 \w o|strong="H3068"\w* \w tinieblas|strong="H2822"\w*, para \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w veas|strong="H7200"\w*,  
\q2 y abundancia \w de|strong="H4325"\w* \w aguas|strong="H4325"\w* te \w cubre|strong="H3680"\w*.   
\b  
\q1
\v 12 “¿\w No|strong="H3808"\w* está Dios \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w altura|strong="H1363"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w cielos|strong="H8064"\w*?  
\q2 \w Mira|strong="H7200"\w* \w lo|strong="H3808"\w* elevado \w de|strong="H3588"\w* las \w estrellas|strong="H3556"\w*, ¡\w cuán|strong="H3588"\w* altas están!   
\q1
\v 13 \w Y|strong="H3068"\w* \w tú|strong="H8199"\w* dices: ‘¿\w Qué|strong="H4100"\w* \w sabe|strong="H3045"\w* Dios?  
\q2 ¿\w Cómo|strong="H4100"\w* \w juzgará|strong="H8199"\w* \w a|strong="H3068"\w* través de la densa \w oscuridad|strong="H6205"\w*?   
\q1
\v 14 Las \w nubes|strong="H5645"\w* le rodean, y \w no|strong="H3808"\w* \w ve|strong="H1980"\w*;  
\q2 y por la bóveda del \w cielo|strong="H8064"\w* \w se|strong="H3808"\w* \w pasea|strong="H1980"\w*’.   
\q1
\v 15 ¿Quieres tú seguir \w la|strong="H8104"\w* senda \w antigua|strong="H5769"\w*  
\q2 \w que|strong="H1869"\w* \w pisaron|strong="H1869"\w* los \w hombres|strong="H4962"\w* inicuos,   
\q1
\v 16 los cuales fueron cortados antes \w de|strong="H6256"\w* \w tiempo|strong="H6256"\w*,  
\q2 cuyo \w fundamento|strong="H3247"\w* \w fue|strong="H3808"\w* como un \w río|strong="H5104"\w* \w derramado|strong="H3332"\w*?   
\q1
\v 17 Decían \w a|strong="H3068"\w* Dios: ‘\w Apártate|strong="H5493"\w* \w de|strong="H4480"\w* nosotros’.  
\q2 ¿\w Y|strong="H3068"\w* \w qué|strong="H4100"\w* les había \w de|strong="H4480"\w* hacer el \w Omnipotente|strong="H7706"\w*?   
\q1
\v 18 Había \w él|strong="H1931"\w* llenado \w sus|strong="H1931"\w* \w casas|strong="H1004"\w* \w de|strong="H4480"\w* bienes.  
\q2 ¡\w Lejos|strong="H7368"\w* sea \w de|strong="H4480"\w* mí \w el|strong="H1931"\w* \w consejo|strong="H6098"\w* \w de|strong="H4480"\w* \w los|strong="H1931"\w* \w impíos|strong="H7563"\w*!   
\q1
\v 19 \w Verán|strong="H7200"\w* los \w justos|strong="H6662"\w* \w y|strong="H5355"\w* se gozarán;  
\q2 \w y|strong="H5355"\w* el \w inocente|strong="H5355"\w* los escarnecerá, diciendo:   
\q1
\v 20 ‘Fueron destruidos nuestros adversarios,  
\q2 y el fuego consumió \w lo|strong="H3808"\w* \w que|strong="H3808"\w* de ellos quedó’.   
\b  
\q1
\v 21 “Amístate \w ahora|strong="H4994"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*, y tendrás \w paz|strong="H7999"\w*;  
\q2 y por ello \w te|strong="H5973"\w* vendrá \w bien|strong="H2896"\w*.   
\q1
\v 22 \w Toma|strong="H3947"\w* \w ahora|strong="H4994"\w* la \w ley|strong="H8451"\w* de su \w boca|strong="H6310"\w*,  
\q2 y \w pon|strong="H7760"\w* sus \w palabras|strong="H6310"\w* en tu \w corazón|strong="H3824"\w*.   
\q1
\v 23 Si te \w volvieres|strong="H7725"\w* \w al|strong="H5704"\w* \w Omnipotente|strong="H7706"\w*, serás \w edificado|strong="H1129"\w*;  
\q2 si apartares \w de|strong="H5704"\w* vuestras tiendas la aflicción,   
\q1
\v 24 \w y|strong="H5921"\w* tuvieres \w por|strong="H5921"\w* \w tierra|strong="H6083"\w* \w el|strong="H5921"\w* \w oro|strong="H1220"\w*,  
\q2 \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w oro|strong="H1220"\w* \w de|strong="H5921"\w* Ofir \w como|strong="H5921"\w* piedras \w de|strong="H5921"\w* \w arroyos|strong="H5158"\w*;   
\q1
\v 25 el \w Todopoderoso|strong="H7706"\w* \w será|strong="H1961"\w* tu defensa,  
\q2 y \w tendrás|strong="H1961"\w* \w plata|strong="H3701"\w* \w a|strong="H3068"\w* montones.   
\q1
\v 26 \w Porque|strong="H3588"\w* \w entonces|strong="H3588"\w* \w te|strong="H5921"\w* deleitarás \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w Omnipotente|strong="H7706"\w*,  
\q2 \w y|strong="H3588"\w* \w levantarás|strong="H5375"\w* \w a|strong="H3068"\w* Dios tu \w rostro|strong="H6440"\w*.   
\q1
\v 27 \w Orarás|strong="H6279"\w* \w a|strong="H3068"\w* él, y él te \w oirá|strong="H8085"\w*;  
\q2 y tú pagarás tus \w votos|strong="H5088"\w*.   
\q1
\v 28 \w Determinarás|strong="H1504"\w* asimismo una cosa, \w y|strong="H5921"\w* \w te|strong="H5921"\w* será \w firme|strong="H6965"\w*,  
\q2 \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* tus \w caminos|strong="H1870"\w* \w resplandecerá|strong="H5050"\w* \w la|strong="H5921"\w* luz.   
\q1
\v 29 \w Cuando|strong="H3588"\w* otros fueren abatidos, dirás tú: ‘Enaltecimiento habrá’;  
\q2 \w y|strong="H3588"\w* Dios \w salvará|strong="H3467"\w* al humilde \w de|strong="H3588"\w* \w ojos|strong="H5869"\w*.   
\q1
\v 30 Él libertará al \w inocente|strong="H5355"\w*;  
\q2 \w y|strong="H5355"\w* por la limpieza de tus \w manos|strong="H3709"\w* serás \w librado|strong="H4422"\w*”.   
\c 23
\p
\v 1 \w Respondió|strong="H6030"\w* Job, y dijo:   
\q1
\v 2 “\w Hoy|strong="H3117"\w* \w también|strong="H1571"\w* \w es|strong="H3027"\w* amarga \w mi|strong="H5921"\w* queja;  
\q2 \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w es|strong="H3027"\w* pesada \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w mi|strong="H5921"\w* gemido.   
\q1
\v 3 ¡\w Quién|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* yo \w supiese|strong="H3045"\w* dónde hallarle!  
\q2 Yo iría \w hasta|strong="H5704"\w* su tribunal.   
\q1
\v 4 Expondría mi \w causa|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él,  
\q2 y llenaría mi \w boca|strong="H6310"\w* \w de|strong="H6440"\w* argumentos.   
\q1
\v 5 Yo sabría las \w palabras|strong="H4405"\w* \w que|strong="H4100"\w* él me respondería,  
\q2 y entendería \w lo|strong="H4100"\w* \w que|strong="H4100"\w* me dijese.   
\q1
\v 6 ¿Contendería \w conmigo|strong="H5978"\w* \w con|strong="H5978"\w* \w la|strong="H1931"\w* grandeza de \w su|strong="H1931"\w* \w fuerza|strong="H3581"\w*?  
\q2 \w No|strong="H3808"\w*; antes \w él|strong="H1931"\w* me atendería.   
\q1
\v 7 \w Allí|strong="H8033"\w* \w el|strong="H5973"\w* justo \w razonaría|strong="H3198"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*;  
\q2 y yo escaparía \w para|strong="H5973"\w* siempre \w de|strong="H5973"\w* mi \w juez|strong="H8199"\w*.   
\b  
\q1
\v 8 «He \w aquí|strong="H2005"\w*, \w si|strong="H2005"\w* \w voy|strong="H1980"\w* al \w oriente|strong="H6924"\w*, \w no|strong="H3808"\w* está allí;  
\q2 y \w si|strong="H2005"\w* al occidente, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* percibo;   
\q1
\v 9 \w si|strong="H3808"\w* al norte \w él|strong="H6213"\w* actúa, \w yo|strong="H6213"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w veré|strong="H7200"\w*;  
\q2 al sur \w se|strong="H3808"\w* esconderá, y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w veré|strong="H7200"\w*.   
\b  
\q1
\v 10 \w Mas|strong="H3588"\w* \w él|strong="H3588"\w* \w conoce|strong="H3045"\w* mi \w camino|strong="H1870"\w*;  
\q2 \w si|strong="H3588"\w* \w me|strong="H3588"\w* probara, saldría \w yo|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w oro|strong="H2091"\w*.   
\q1
\v 11 Mis \w pies|strong="H7272"\w* han seguido sus pisadas;  
\q2 \w guardé|strong="H8104"\w* su \w camino|strong="H1870"\w*, y \w no|strong="H3808"\w* me aparté.   
\q1
\v 12 Del \w mandamiento|strong="H6310"\w* de sus \w labios|strong="H8193"\w* \w nunca|strong="H3808"\w* me separé;  
\q2 \w guardé|strong="H6845"\w* las \w palabras|strong="H6310"\w* de su \w boca|strong="H6310"\w* \w más|strong="H3808"\w* \w que|strong="H3808"\w* mi comida necesaria.   
\q1
\v 13 Pero \w si|strong="H1931"\w* \w él|strong="H1931"\w* determina una \w cosa|strong="H5315"\w*, ¿\w quién|strong="H4310"\w* \w lo|strong="H1931"\w* \w hará|strong="H6213"\w* desistir?  
\q2 \w Su|strong="H1931"\w* \w alma|strong="H5315"\w* deseó, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w*.   
\q1
\v 14 \w Él|strong="H5973"\w*, \w pues|strong="H3588"\w*, \w acabará|strong="H7999"\w* \w lo|strong="H2007"\w* \w que|strong="H3588"\w* ha determinado \w de|strong="H3588"\w* mí;  
\q2 \w y|strong="H3588"\w* \w muchas|strong="H7227"\w* \w cosas|strong="H7227"\w* \w como|strong="H3588"\w* \w estas|strong="H2007"\w* \w hay|strong="H2007"\w* \w en|strong="H5973"\w* \w él|strong="H5973"\w*.   
\q1
\v 15 \w Por|strong="H5921"\w* \w lo|strong="H5921"\w* cual \w yo|strong="H4480"\w* \w me|strong="H4480"\w* espanto \w en|strong="H5921"\w* su \w presencia|strong="H6440"\w*;  
\q2 cuando \w lo|strong="H5921"\w* considero, \w tengo|strong="H5921"\w* temblor \w de|strong="H4480"\w* \w él|strong="H5921"\w*.   
\q1
\v 16 Dios ha hecho desmayar mi \w corazón|strong="H3820"\w*,  
\q2 y me ha turbado el \w Omnipotente|strong="H7706"\w*.   
\q1
\v 17 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w no|strong="H3808"\w* \w fui|strong="H3808"\w* \w yo|strong="H3588"\w* cortado \w delante|strong="H6440"\w* \w de|strong="H3588"\w* las \w tinieblas|strong="H2822"\w*,  
\q2 \w ni|strong="H3808"\w* \w cubrió|strong="H3680"\w* \w la|strong="H3588"\w* \w oscuridad|strong="H2822"\w* mi \w rostro|strong="H6440"\w*?»   
\c 24
\b  
\q1
\v 1 “¿\w Por|strong="H4069"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* \w son|strong="H3808"\w* señalados los \w tiempos|strong="H3117"\w* \w por|strong="H4069"\w* el \w Omnipotente|strong="H7706"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w por|strong="H4069"\w* \w qué|strong="H3808"\w* los \w que|strong="H3808"\w* le \w conocen|strong="H3045"\w* \w no|strong="H3808"\w* \w ven|strong="H2372"\w* sus \w días|strong="H3117"\w*?   
\q1
\v 2 Hay quienes \w traspasan|strong="H5381"\w* los términos;  
\q2 \w roban|strong="H1497"\w* los ganados y los \w apacientan|strong="H7462"\w*.   
\q1
\v 3 Se llevan el \w asno|strong="H2543"\w* de los \w huérfanos|strong="H3490"\w*,  
\q2 \w y|strong="H7794"\w* toman en prenda el \w buey|strong="H7794"\w* de la viuda.   
\q1
\v 4 Apartan del \w camino|strong="H1870"\w* \w a|strong="H3068"\w* los menesterosos,  
\q2 y \w todos|strong="H3162"\w* los pobres de la tierra se esconden.   
\q1
\v 5 He \w aquí|strong="H2005"\w*, como asnos monteses \w en|strong="H3318"\w* el \w desierto|strong="H4057"\w*,  
\q2 \w salen|strong="H3318"\w* \w a|strong="H3068"\w* su \w obra|strong="H6467"\w* \w madrugando|strong="H7836"\w* para buscar presa;  
\q1 el \w desierto|strong="H4057"\w* les da \w pan|strong="H3899"\w* para sus hijos.   
\q2
\v 6 \w Siegan|strong="H7114"\w* su forraje en \w campo|strong="H7704"\w* ajeno,  
\q1 y \w vendimian|strong="H3953"\w* la \w viña|strong="H3754"\w* del \w impío|strong="H7563"\w*.   
\q2
\v 7 Pasan la noche \w desnudos|strong="H6174"\w* \w sin|strong="H1097"\w* ropa,  
\q1 y \w no|strong="H1097"\w* tienen \w cobertura|strong="H3682"\w* contra \w el|strong="H3885"\w* frío.   
\q2
\v 8 Con las lluvias de los \w montes|strong="H2022"\w* se mojan,  
\q1 y abrazan las peñas por falta de abrigo.   
\q2
\v 9 \w Quitan|strong="H1497"\w* al \w huérfano|strong="H3490"\w* del pecho,  
\q1 y del \w pobre|strong="H6041"\w* toman prenda.   
\q2
\v 10 Les hacen \w andar|strong="H1980"\w* \w desnudos|strong="H6174"\w*, \w sin|strong="H1097"\w* \w vestido|strong="H3830"\w*,  
\q2 y \w a|strong="H3068"\w* los hambrientos \w quitan|strong="H5375"\w* las gavillas.   
\q1
\v 11 Dentro de sus \w muros|strong="H7791"\w* exprimen el aceite;  
\q2 \w pisan|strong="H1869"\w* los lagares, y mueren de \w sed|strong="H6770"\w*.   
\q1
\v 12 Desde la \w ciudad|strong="H5892"\w* \w gimen|strong="H5008"\w* los \w hombres|strong="H4962"\w*,  
\q2 y clama el \w alma|strong="H5315"\w* de los \w heridos|strong="H2491"\w*,  
\q2 \w mas|strong="H3808"\w* Dios \w no|strong="H3808"\w* les atribuye su desatino.   
\b  
\q1
\v 13 “\w Ellos|strong="H1992"\w* \w son|strong="H1961"\w* \w los|strong="H1992"\w* \w que|strong="H3808"\w* \w se|strong="H1961"\w* rebelan \w contra|strong="H1961"\w* la luz;  
\q2 \w no|strong="H3808"\w* conocen \w sus|strong="H1992"\w* \w caminos|strong="H1870"\w*,  
\q2 \w ni|strong="H3808"\w* permanecen en \w sus|strong="H1992"\w* sendas.   
\q1
\v 14 Con la luz \w se|strong="H1961"\w* levanta el matador;  
\q2 \w mata|strong="H6991"\w* al \w pobre|strong="H6041"\w* y al necesitado,  
\q2 y de \w noche|strong="H3915"\w* \w es|strong="H1961"\w* \w como|strong="H1961"\w* \w ladrón|strong="H1590"\w*.   
\q1
\v 15 El \w ojo|strong="H5869"\w* del adúltero aguarda el crepúsculo,  
\q2 diciendo: ‘\w No|strong="H3808"\w* me verá \w ojo|strong="H5869"\w*’,  
\q2 y disimula su \w rostro|strong="H6440"\w*.   
\q1
\v 16 En las \w tinieblas|strong="H2822"\w* \w minan|strong="H2864"\w* las \w casas|strong="H1004"\w*  
\q2 \w que|strong="H3808"\w* de \w día|strong="H3119"\w* para \w sí|strong="H3808"\w* señalaron;  
\q2 \w no|strong="H3808"\w* \w conocen|strong="H3045"\w* la luz.   
\q1
\v 17 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* \w mañana|strong="H1242"\w* \w es|strong="H3588"\w* \w para|strong="H3588"\w* \w todos|strong="H3162"\w* ellos sombra \w de|strong="H3588"\w* \w muerte|strong="H6757"\w*;  
\q2 \w si|strong="H3588"\w* \w son|strong="H3588"\w* \w conocidos|strong="H5234"\w*, \w terrores|strong="H1091"\w* \w de|strong="H3588"\w* sombra \w de|strong="H3588"\w* \w muerte|strong="H6757"\w* \w los|strong="H3588"\w* asaltan.   
\b  
\q1
\v 18 «\w Son|strong="H3808"\w* \w ligeros|strong="H7031"\w* \w como|strong="H5921"\w* corriente \w de|strong="H5921"\w* \w aguas|strong="H4325"\w*;  
\q2 \w su|strong="H1931"\w* heredad \w es|strong="H1931"\w* maldita \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w tierra|strong="H2513"\w*;  
\q2 \w no|strong="H3808"\w* \w andarán|strong="H6437"\w* \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w viñas|strong="H3754"\w*.   
\q1
\v 19 \w La|strong="H1571"\w* sequía \w y|strong="H1571"\w* \w el|strong="H1571"\w* calor \w arrebatan|strong="H1497"\w* las \w aguas|strong="H4325"\w* \w de|strong="H4325"\w* \w la|strong="H1571"\w* nieve;  
\q2 \w así|strong="H1571"\w* \w también|strong="H1571"\w* \w el|strong="H1571"\w* Seol\f + \fr 24:19 \ft El Seol es el lugar de los muertos.\f* \w a|strong="H3068"\w* los pecadores.   
\q1
\v 20 \w De|strong="H5750"\w* ellos \w se|strong="H3808"\w* olvidará la \w matriz|strong="H7358"\w*;  
\q2 \w de|strong="H5750"\w* ellos sentirán los \w gusanos|strong="H7415"\w* \w dulzura|strong="H4988"\w*;  
\q2 \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* habrá \w de|strong="H5750"\w* ellos \w memoria|strong="H2142"\w*,  
\q2 y la \w iniquidad|strong="H5766"\w* \w será|strong="H7665"\w* \w quebrantada|strong="H7665"\w* \w como|strong="H5750"\w* un \w árbol|strong="H6086"\w*.   
\q1
\v 21 \w A|strong="H3068"\w* la estéril \w que|strong="H3808"\w* \w no|strong="H3808"\w* concebía \w afligió|strong="H7462"\w*,  
\q2 y \w a|strong="H3068"\w* la viuda \w nunca|strong="H3808"\w* hizo \w bien|strong="H3190"\w*.   
\q1
\v 22 Pero \w a|strong="H3068"\w* los fuertes \w adelantó|strong="H4900"\w* con su \w poder|strong="H3581"\w*;  
\q2 cuando él \w se|strong="H3808"\w* levanta, \w ninguno|strong="H3808"\w* \w está|strong="H6965"\w* seguro de la \w vida|strong="H2416"\w*.   
\q1
\v 23 \w Él|strong="H5921"\w* \w les|strong="H5921"\w* \w da|strong="H5414"\w* seguridad \w y|strong="H5921"\w* descanso,  
\q2 pero sus \w ojos|strong="H5869"\w* están \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w caminos|strong="H1870"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
\q1
\v 24 Fueron ensalzados por un \w poco|strong="H4592"\w*, mas desaparecen,  
\q2 y son abatidos como \w todos|strong="H3605"\w* \w los|strong="H3605"\w* demás; serán encerrados,  
\q2 y cortados como \w cabezas|strong="H7218"\w* de \w espigas|strong="H7641"\w*.   
\q1
\v 25 \w Y|strong="H3068"\w* \w si|strong="H3808"\w* \w no|strong="H3808"\w* es así ahora, ¿\w quién|strong="H4310"\w* \w me|strong="H4310"\w* desmentirá,  
\q2 \w o|strong="H3068"\w* reducirá \w a|strong="H3068"\w* \w nada|strong="H3808"\w* \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w*?»   
\b  
\c 25
\p
\v 1 \w Respondió|strong="H6030"\w* \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w*, y dijo:   
\q1
\v 2 «\w El|strong="H5973"\w* \w señorío|strong="H4910"\w* y \w el|strong="H5973"\w* \w temor|strong="H6343"\w* están \w con|strong="H5973"\w* \w él|strong="H5973"\w*;  
\q2 \w él|strong="H5973"\w* \w hace|strong="H6213"\w* la \w paz|strong="H7965"\w* \w en|strong="H5973"\w* sus \w alturas|strong="H4791"\w*.   
\q1
\v 3 ¿\w Tienen|strong="H3426"\w* sus \w ejércitos|strong="H1416"\w* \w número|strong="H4557"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w sobre|strong="H5921"\w* \w quién|strong="H4310"\w* \w no|strong="H3808"\w* sale su luz?   
\q1
\v 4 ¿\w Cómo|strong="H4100"\w*, \w pues|strong="H4100"\w*, \w se|strong="H4100"\w* \w justificará|strong="H6663"\w* \w el|strong="H5973"\w* hombre \w con|strong="H5973"\w* Dios?  
\q2 ¿\w Y|strong="H3068"\w* \w cómo|strong="H4100"\w* será limpio \w el|strong="H5973"\w* \w que|strong="H4100"\w* \w nace|strong="H3205"\w* \w de|strong="H5973"\w* mujer?   
\q1
\v 5 He \w aquí|strong="H2005"\w* \w que|strong="H3808"\w* \w ni|strong="H3808"\w* \w aun|strong="H5704"\w* la misma \w luna|strong="H3394"\w* es resplandeciente,  
\q2 \w ni|strong="H3808"\w* las \w estrellas|strong="H3556"\w* \w son|strong="H3808"\w* puras \w delante|strong="H5869"\w* \w de|strong="H5704"\w* sus \w ojos|strong="H5869"\w*;   
\q1
\v 6 ¿\w cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w el|strong="H3588"\w* \w hombre|strong="H1121"\w*, \w que|strong="H3588"\w* \w es|strong="H3588"\w* un \w gusano|strong="H8438"\w*,  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w hombre|strong="H1121"\w*, \w que|strong="H3588"\w* \w es|strong="H3588"\w* una oruga?».   
\c 26
\p
\v 1 \w Respondió|strong="H6030"\w* Job, y dijo:   
\q1
\v 2 “¡En \w qué|strong="H4100"\w* manera has ayudado al \w que|strong="H4100"\w* \w no|strong="H3808"\w* tiene \w poder|strong="H3581"\w*!  
\q2 ¡\w Cómo|strong="H4100"\w* has amparado al \w brazo|strong="H2220"\w* \w sin|strong="H3808"\w* \w fuerza|strong="H3581"\w*!   
\q1
\v 3 ¡\w Qué|strong="H4100"\w* buen \w consejo|strong="H3289"\w* has dado al \w que|strong="H4100"\w* \w no|strong="H3808"\w* tiene \w sabiduría|strong="H2451"\w*,  
\q2 y \w qué|strong="H4100"\w* plenitud de inteligencia has manifestado!   
\q1
\v 4 ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* has pronunciado \w palabras|strong="H4405"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w de|strong="H4480"\w* \w quién|strong="H4310"\w* es \w el|strong="H4310"\w* espíritu \w que|strong="H4480"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w* procede?   
\b  
\q1
\v 5 «Las sombras tiemblan \w en|strong="H8478"\w* lo profundo,  
\q2 \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* las \w aguas|strong="H4325"\w* y \w de|strong="H8478"\w* sus \w moradores|strong="H7931"\w*.   
\q1
\v 6 El Seol\f + \fr 26:6 \ft El Seol es el lugar de los muertos.\f* está \w desnudo|strong="H6174"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* él,  
\q2 y el Abadón\f + \fr 26:6 \ft Abadón significa Destructor.\f* no tiene \w cobertura|strong="H3682"\w*.   
\q1
\v 7 \w Él|strong="H5921"\w* \w extiende|strong="H5186"\w* \w el|strong="H5921"\w* \w norte|strong="H6828"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w vacío|strong="H8414"\w*,  
\q2 \w y|strong="H5921"\w* \w cuelga|strong="H8518"\w* \w la|strong="H5921"\w* tierra \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w nada|strong="H1099"\w*.   
\q1
\v 8 \w Ata|strong="H6887"\w* las \w aguas|strong="H4325"\w* \w en|strong="H8478"\w* sus \w nubes|strong="H6051"\w*,  
\q2 y las \w nubes|strong="H6051"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* rompen \w bajo|strong="H8478"\w* su peso.   
\q1
\v 9 \w Él|strong="H5921"\w* encubre \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* su \w trono|strong="H3678"\w*,  
\q2 \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* extiende su \w nube|strong="H6051"\w*.   
\q1
\v 10 Trazó un límite circular \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*,  
\q2 \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* confín \w de|strong="H5921"\w* \w la|strong="H5921"\w* luz \w con|strong="H5973"\w* \w las|strong="H5921"\w* \w tinieblas|strong="H2822"\w*.   
\q1
\v 11 Las \w columnas|strong="H5982"\w* del \w cielo|strong="H8064"\w* \w tiemblan|strong="H7322"\w*,  
\q2 y se espantan de su reprensión.   
\q1
\v 12 Él agita el \w mar|strong="H3220"\w* con su \w poder|strong="H3581"\w*,  
\q2 y con su \w entendimiento|strong="H8394"\w* \w hiere|strong="H4272"\w* \w a|strong="H3068"\w* Rahab.   
\q1
\v 13 Su \w espíritu|strong="H7307"\w* \w adornó|strong="H8235"\w* los \w cielos|strong="H8064"\w*;  
\q2 su \w mano|strong="H3027"\w* traspasó \w a|strong="H3068"\w* la \w serpiente|strong="H5175"\w* huidiza.   
\q1
\v 14 He \w aquí|strong="H2005"\w*, estas \w cosas|strong="H1697"\w* \w no|strong="H1870"\w* son sino los bordes \w de|strong="H1697"\w* sus \w caminos|strong="H1870"\w*;  
\q2 ¡y \w cuán|strong="H4100"\w* leve \w es|strong="H1697"\w* \w el|strong="H4310"\w* susurro \w que|strong="H4100"\w* hemos \w oído|strong="H8085"\w* \w de|strong="H1697"\w* \w él|strong="H4310"\w*!  
\q2 Pero \w el|strong="H4310"\w* estruendo \w de|strong="H1697"\w* su poder, ¿\w quién|strong="H4310"\w* \w lo|strong="H1697"\w* podrá comprender?»   
\c 27
\p
\v 1 Prosiguió Job su discurso, y dijo:   
\q1
\v 2 “¡\w Vive|strong="H2416"\w* Dios, que ha quitado \w mi|strong="H5315"\w* \w derecho|strong="H4941"\w*,  
\q2 y el \w Omnipotente|strong="H7706"\w*, que ha amargado \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*,   
\q1
\v 3 \w que|strong="H3588"\w* \w mientras|strong="H5750"\w* haya \w hálito|strong="H7307"\w* \w en|strong="H3588"\w* mí,  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w espíritu|strong="H7307"\w* \w de|strong="H3588"\w* Dios esté \w en|strong="H3588"\w* mis narices,   
\q1
\v 4 mis \w labios|strong="H8193"\w* \w no|strong="H5766"\w* \w hablarán|strong="H1696"\w* \w iniquidad|strong="H5766"\w*,  
\q2 ni mi \w lengua|strong="H3956"\w* \w pronunciará|strong="H1897"\w* \w engaño|strong="H7423"\w*!   
\q1
\v 5 \w Nunca|strong="H3808"\w* tal acontezca \w que|strong="H4480"\w* \w yo|strong="H4480"\w* \w os|strong="H4480"\w* \w dé|strong="H4480"\w* la razón;  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H4480"\w* muera, \w no|strong="H3808"\w* \w quitaré|strong="H5493"\w* \w de|strong="H4480"\w* mí mi integridad.   
\q1
\v 6 Mi \w justicia|strong="H6666"\w* tengo asida, y \w no|strong="H3808"\w* la cederé;  
\q2 \w no|strong="H3808"\w* me \w reprochará|strong="H2778"\w* mi \w corazón|strong="H3824"\w* mientras viva.   
\b  
\q1
\v 7 “\w Sea|strong="H1961"\w* \w como|strong="H1961"\w* el \w impío|strong="H7563"\w* \w mi|strong="H1961"\w* enemigo,  
\q2 y \w como|strong="H1961"\w* el inicuo \w mi|strong="H1961"\w* adversario.   
\b  
\q1
\v 8 \w Porque|strong="H3588"\w* ¿\w cuál|strong="H4100"\w* \w es|strong="H3588"\w* \w la|strong="H3588"\w* \w esperanza|strong="H8615"\w* del impío, \w por|strong="H3588"\w* mucho \w que|strong="H3588"\w* haya robado,  
\q2 \w cuando|strong="H3588"\w* Dios le cortare \w el|strong="H3588"\w* \w alma|strong="H5315"\w*?   
\q1
\v 9 ¿\w Oirá|strong="H8085"\w* Dios \w su|strong="H3588"\w* \w clamor|strong="H6818"\w*  
