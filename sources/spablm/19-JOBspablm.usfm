\q1
\v 6 Aparta \w de|strong="H5921"\w* \w él|strong="H5921"\w* tu mirada \w para|strong="H5704"\w* \w que|strong="H5921"\w* descanse,  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H5921"\w*, \w como|strong="H5921"\w* jornalero, cumpla su jornada.   
\b  
\q1
\v 7 “\w Porque|strong="H3588"\w* \w si|strong="H3588"\w* \w el|strong="H3588"\w* \w árbol|strong="H6086"\w* fuere \w cortado|strong="H3772"\w*, \w aún|strong="H5750"\w* queda \w esperanza|strong="H8615"\w*  
