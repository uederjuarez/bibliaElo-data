\v 10 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, dije: ‘\w Escuchadme|strong="H8085"\w*;  
\q2 \w declararé|strong="H2331"\w* yo \w también|strong="H3651"\w* \w mi|strong="H2331"\w* \w opinión|strong="H1843"\w*’.   
\b  
\q1
\v 11 “He \w aquí|strong="H2005"\w* \w que|strong="H5704"\w* yo he esperado \w a|strong="H3068"\w* \w vuestras|strong="H1697"\w* \w razones|strong="H4405"\w*,  
\q2 he escuchado vuestros \w argumentos|strong="H8394"\w*  
\q2 \w mientras|strong="H5704"\w* buscabais \w palabras|strong="H1697"\w*.   
\q1
\v 12 \w Os|strong="H4480"\w* he prestado atención,  
\q2 \w y|strong="H5704"\w* he \w aquí|strong="H2009"\w* \w que|strong="H4480"\w* no hay \w de|strong="H4480"\w* vosotros quien haya convencido \w a|strong="H3068"\w* Job,  
\q2 \w ni|strong="H5704"\w* quien haya respondido \w a|strong="H3068"\w* sus palabras.   
\q1
\v 13 Para \w que|strong="H3808"\w* \w no|strong="H3808"\w* digáis: ‘Nosotros hemos \w hallado|strong="H4672"\w* \w sabiduría|strong="H2451"\w*;  
\q2 Dios \w lo|strong="H3808"\w* vence, \w no|strong="H3808"\w* el hombre’.   
\q1
\v 14 Ahora bien, él \w no|strong="H3808"\w* dirigió \w a|strong="H3068"\w* mí sus \w palabras|strong="H4405"\w*,  
\q2 \w ni|strong="H3808"\w* yo le responderé con vuestras \w razones|strong="H4405"\w*.   
\b  
\q1
\v 15 “Espantados están, \w no|strong="H3808"\w* responden \w más|strong="H5750"\w*;  
\q2 \w se|strong="H1992"\w* \w les|strong="H1992"\w* han acabado \w las|strong="H1992"\w* \w palabras|strong="H4405"\w*.   
\q1
\v 16 \w Yo|strong="H3588"\w*, \w pues|strong="H3588"\w*, he esperado, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w hablaban|strong="H1696"\w*;  
\q2 \w antes|strong="H3588"\w* \w bien|strong="H3588"\w* callaron \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w respondieron|strong="H6030"\w* \w más|strong="H5750"\w*.   
\q1
\v 17 Yo también \w responderé|strong="H6030"\w* \w mi|strong="H2331"\w* \w parte|strong="H2506"\w*;  
\q2 también yo \w declararé|strong="H2331"\w* \w mi|strong="H2331"\w* parecer.   
\q1
\v 18 \w Porque|strong="H3588"\w* \w lleno|strong="H4390"\w* estoy \w de|strong="H3588"\w* \w palabras|strong="H4405"\w*,  
\q2 \w y|strong="H3588"\w* \w me|strong="H3588"\w* apremia \w el|strong="H3588"\w* \w espíritu|strong="H7307"\w* dentro \w de|strong="H3588"\w* mi cuerpo.   
\q1
\v 19 De \w cierto|strong="H3808"\w* \w mi|strong="H2009"\w* vientre está como el \w vino|strong="H3196"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* tiene respiradero,  
\q2 y como odres \w nuevos|strong="H2319"\w* \w que|strong="H3808"\w* \w están|strong="H2009"\w* para reventar.   
\q1
\v 20 \w Hablaré|strong="H1696"\w*, pues, y respiraré;  
\q2 \w abriré|strong="H6605"\w* mis \w labios|strong="H8193"\w*, y \w responderé|strong="H6030"\w*.   
\q1
\v 21 \w No|strong="H3808"\w* haré \w ahora|strong="H4994"\w* \w acepción|strong="H5375"\w* \w de|strong="H6440"\w* personas,  
\q2 \w ni|strong="H3808"\w* usaré con \w nadie|strong="H3808"\w* \w de|strong="H6440"\w* títulos lisonjeros.   
\q1
\v 22 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* \w sé|strong="H3045"\w* lisonjear;  
\q2 \w de|strong="H3588"\w* \w otra|strong="H6213"\w* manera, \w en|strong="H3588"\w* breve \w mi|strong="H5375"\w* \w Hacedor|strong="H6213"\w* \w me|strong="H3588"\w* consumiría.   
\b  
\c 33
\b  
\q1
\v 1 “\w Por|strong="H1697"\w* tanto, Job, \w oye|strong="H8085"\w* \w ahora|strong="H4994"\w* \w mis|strong="H4405"\w* \w razones|strong="H4405"\w*,  
\q2 y presta \w oído|strong="H8085"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w mis|strong="H4405"\w* \w palabras|strong="H1697"\w*.   
\q1
\v 2 He \w aquí|strong="H2009"\w* \w que|strong="H4994"\w* \w yo|strong="H2009"\w* he \w abierto|strong="H6605"\w* \w mi|strong="H4994"\w* \w boca|strong="H6310"\w*,  
\q2 y \w mi|strong="H4994"\w* \w lengua|strong="H3956"\w* \w habla|strong="H1696"\w* en \w mi|strong="H4994"\w* paladar.   
\q1
\v 3 Mis palabras declararán la rectitud de mi \w corazón|strong="H3820"\w*,  
\q2 y mis \w labios|strong="H8193"\w* expresarán con pureza lo que saben.   
\q1
\v 4 \w El|strong="H6213"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5397"\w* Dios me \w hizo|strong="H6213"\w*,  
\q2 y \w el|strong="H6213"\w* \w hálito|strong="H5397"\w* del \w Omnipotente|strong="H7706"\w* me dio \w vida|strong="H2421"\w*.   
\q1
\v 5 \w Respóndeme|strong="H7725"\w*, \w si|strong="H6440"\w* \w puedes|strong="H3201"\w*;  
\q2 ordena tus palabras \w delante|strong="H6440"\w* \w de|strong="H6440"\w* mí, ¡levántate!   
\q1
\v 6 He \w aquí|strong="H2005"\w* \w que|strong="H1571"\w* yo soy ante Dios lo \w mismo|strong="H1571"\w* \w que|strong="H1571"\w* tú;  
\q2 de \w la|strong="H1571"\w* arcilla fui yo \w también|strong="H1571"\w* \w formado|strong="H7169"\w*.   
\q1
\v 7 He \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w mi|strong="H5921"\w* terror \w no|strong="H3808"\w* \w te|strong="H5921"\w* \w espantará|strong="H1204"\w*,  
\q2 \w ni|strong="H3808"\w* \w mi|strong="H5921"\w* mano \w será|strong="H3808"\w* pesada \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*.   
\b  
\q1
\v 8 “De cierto tú dijiste \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* míos,  
\q2 y yo \w oí|strong="H8085"\w* la \w voz|strong="H6963"\w* de tus \w palabras|strong="H4405"\w* que decían:   
\q1
\v 9 ‘Yo soy \w limpio|strong="H2134"\w* y \w sin|strong="H3808"\w* \w defecto|strong="H6588"\w*;  
\q2 soy inocente, y \w no|strong="H3808"\w* hay \w iniquidad|strong="H5771"\w* en mí.   
\q1
\v 10 He \w aquí|strong="H2005"\w* \w que|strong="H5921"\w* Dios buscó pretextos \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w tiene|strong="H2803"\w* \w por|strong="H5921"\w* su enemigo;   
\q1
\v 11 \w puso|strong="H7760"\w* mis \w pies|strong="H7272"\w* en \w el|strong="H3605"\w* cepo,  
\q2 y vigila \w todas|strong="H3605"\w* mis sendas’.   
\b  
\q1
\v 12 “He \w aquí|strong="H2005"\w*, \w en|strong="H3588"\w* \w esto|strong="H2063"\w* \w no|strong="H3808"\w* has hablado justamente;  
\q2 \w yo|strong="H3588"\w* \w te|strong="H3588"\w* \w responderé|strong="H6030"\w* \w que|strong="H3588"\w* Dios \w es|strong="H3588"\w* \w mayor|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* hombre.   
\q1
\v 13 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* contiendes contra \w él|strong="H3588"\w*?  
\q2 \w Porque|strong="H3588"\w* \w él|strong="H3588"\w* \w no|strong="H3808"\w* da \w cuenta|strong="H1697"\w* \w de|strong="H3588"\w* \w ninguna|strong="H3605"\w* \w de|strong="H3588"\w* sus \w razones|strong="H1697"\w*.   
\q1
\v 14 \w Sin|strong="H3808"\w* embargo, Dios \w habla|strong="H1696"\w* una vez,  
\q2 \w y|strong="H3588"\w* otra vez, \w aunque|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w no|strong="H3808"\w* \w lo|strong="H3808"\w* perciba.   
\q1
\v 15 \w Por|strong="H5921"\w* \w sueño|strong="H2472"\w*, \w en|strong="H5921"\w* \w visión|strong="H2384"\w* \w nocturna|strong="H3915"\w*,  
\q2 cuando \w el|strong="H5921"\w* \w sueño|strong="H2472"\w* profundo \w cae|strong="H5307"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* hombres,  
\q2 mientras dormitan \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* lecho;   
\q1
\v 16 entonces \w abre|strong="H1540"\w* el oído de los hombres,  
\q2 y \w sella|strong="H2856"\w* su instrucción,   
\q1
\v 17 \w para|strong="H5493"\w* \w quitar|strong="H5493"\w* al \w hombre|strong="H1397"\w* de su \w obra|strong="H4639"\w*,  
\q2 y apartar del \w varón|strong="H1397"\w* la \w soberbia|strong="H1466"\w*.   
\q1
\v 18 Así libra su \w alma|strong="H5315"\w* \w del|strong="H4480"\w* \w sepulcro|strong="H7845"\w*,  
\q2 y su \w vida|strong="H5315"\w* \w de|strong="H4480"\w* perecer \w a|strong="H3068"\w* espada.   
\b  
\q1
\v 19 “También \w sobre|strong="H5921"\w* su \w cama|strong="H4904"\w* es castigado \w con|strong="H5921"\w* \w dolor|strong="H4341"\w*,  
\q2 \w y|strong="H5921"\w* \w con|strong="H5921"\w* fuerte temblor \w en|strong="H5921"\w* todos sus \w huesos|strong="H6106"\w*,   
\q1
\v 20 de suerte que su \w vida|strong="H5315"\w* aborrece el \w pan|strong="H3899"\w*,  
\q2 y su \w alma|strong="H5315"\w* la \w comida|strong="H3978"\w* deleitosa.   
\q1
\v 21 Su \w carne|strong="H1320"\w* \w desfallece|strong="H3615"\w* y desaparece de la vista,  
\q2 y sus \w huesos|strong="H6106"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w veían|strong="H7200"\w*, \w aparecen|strong="H7200"\w*.   
\q1
\v 22 Su \w alma|strong="H5315"\w* se acerca al \w sepulcro|strong="H7845"\w*,  
\q2 y su \w vida|strong="H5315"\w* \w a|strong="H3068"\w* los que causan la \w muerte|strong="H4191"\w*.   
\b  
\q1
\v 23 “\w Si|strong="H5921"\w* tuviese \w cerca|strong="H5921"\w* \w de|strong="H4480"\w* \w él|strong="H5921"\w* un \w ángel|strong="H4397"\w*,  
\q2 un intérprete, uno \w entre|strong="H5921"\w* mil,  
\q2 \w que|strong="H4480"\w* \w anuncie|strong="H5046"\w* \w al|strong="H5921"\w* hombre su deber;   
\q1
\v 24 que le diga que Dios tuvo de él \w misericordia|strong="H2603"\w*,  
\q2 que lo libró de descender al \w sepulcro|strong="H7845"\w*,  
\q2 que \w halló|strong="H4672"\w* \w rescate|strong="H3724"\w*;   
\q1
\v 25 su \w carne|strong="H1320"\w* será más tierna \w que|strong="H3117"\w* la del niño,  
\q2 \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* los \w días|strong="H3117"\w* de su juventud.   
\q1
\v 26 \w Orará|strong="H6279"\w* \w a|strong="H3068"\w* Dios, y este le será propicio,  
\q2 y \w verá|strong="H7200"\w* su \w faz|strong="H6440"\w* con \w júbilo|strong="H8643"\w*;  
\q2 y él \w restituirá|strong="H7725"\w* al hombre su \w justicia|strong="H6666"\w*.   
\q1
\v 27 \w Él|strong="H5921"\w* mira \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* hombres; \w y|strong="H5921"\w* \w si|strong="H3808"\w* alguno dijere:  
\q2 ‘\w Pequé|strong="H2398"\w*, \w y|strong="H5921"\w* pervertí \w lo|strong="H3808"\w* \w recto|strong="H3477"\w*,  
\q2 \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w me|strong="H5921"\w* \w ha|strong="H3808"\w* aprovechado’,   
\q1
\v 28 Dios \w redimirá|strong="H6299"\w* su \w alma|strong="H5315"\w* para que no \w pase|strong="H5674"\w* al \w sepulcro|strong="H7845"\w*,  
\q2 y su \w vida|strong="H5315"\w* \w verá|strong="H7200"\w* la luz.   
\b  
\q1
\v 29 «He \w aquí|strong="H2005"\w*, \w todas|strong="H3605"\w* estas cosas hace Dios  
\q2 \w dos|strong="H6471"\w* y \w tres|strong="H7969"\w* \w veces|strong="H6471"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w hombre|strong="H1397"\w*,   
\q1
\v 30 \w para|strong="H4480"\w* apartar su \w alma|strong="H5315"\w* \w del|strong="H4480"\w* \w sepulcro|strong="H7845"\w*,  
\q2 y \w para|strong="H4480"\w* iluminarlo \w con|strong="H4480"\w* la luz \w de|strong="H4480"\w* los \w vivientes|strong="H2416"\w*.   
\q1
\v 31 \w Escucha|strong="H8085"\w*, Job, y \w óyeme|strong="H8085"\w*;  
\q2 \w calla|strong="H2790"\w*, y yo \w hablaré|strong="H1696"\w*.   
\q1
\v 32 \w Si|strong="H3588"\w* \w tienes|strong="H3426"\w* algo \w que|strong="H3588"\w* decir, \w respóndeme|strong="H7725"\w*;  
\q2 \w habla|strong="H1696"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H3588"\w* \w quiero|strong="H2654"\w* \w justificar|strong="H6663"\w*.   
\q1
\v 33 \w Y|strong="H3068"\w* si no, \w óyeme|strong="H8085"\w* tú \w a|strong="H3068"\w* mí;  
\q2 \w calla|strong="H2790"\w*, y te enseñaré \w sabiduría|strong="H2451"\w*».   
\c 34
\p
\v 1 Además, Elihú prosiguió y dijo:   
\q1
\v 2 “\w Oíd|strong="H8085"\w*, \w sabios|strong="H2450"\w*, \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w*;  
\q2 y \w vosotros|strong="H8085"\w*, \w doctos|strong="H3045"\w*, prestadme \w oído|strong="H8085"\w*.   
\q1
\v 3 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* oído prueba las \w palabras|strong="H4405"\w*,  
\q2 \w como|strong="H3588"\w* \w el|strong="H3588"\w* paladar \w gusta|strong="H2938"\w* \w lo|strong="H4405"\w* \w que|strong="H3588"\w* se come.   
\q1
\v 4 Escojamos para nosotros \w lo|strong="H4100"\w* \w que|strong="H4100"\w* es justo;  
\q2 \w conozcamos|strong="H3045"\w* entre nosotros \w lo|strong="H4100"\w* \w que|strong="H4100"\w* es \w bueno|strong="H2896"\w*.   
\q1
\v 5 \w Porque|strong="H3588"\w* Job ha dicho: ‘\w Yo|strong="H3588"\w* soy justo,  
\q2 \w y|strong="H3588"\w* Dios \w me|strong="H3588"\w* ha quitado mi \w derecho|strong="H4941"\w*.   
\q1
\v 6 ¿He \w de|strong="H5921"\w* mentir yo \w contra|strong="H5921"\w* \w mi|strong="H5921"\w* \w derecho|strong="H4941"\w*?  
\q2 \w Mi|strong="H5921"\w* herida es incurable, aunque estoy \w sin|strong="H1097"\w* transgresión’.   
\q1
\v 7 ¿\w Qué|strong="H4310"\w* \w hombre|strong="H1397"\w* \w hay|strong="H4310"\w* como Job,  
\q2 \w que|strong="H4310"\w* \w bebe|strong="H8354"\w* \w el|strong="H4310"\w* escarnio como \w agua|strong="H4325"\w*,   
\q1
\v 8 y \w va|strong="H3068"\w* \w en|strong="H5973"\w* compañía \w de|strong="H5973"\w* \w los|strong="H5973"\w* que obran iniquidad,  
\q2 y camina \w con|strong="H5973"\w* \w los|strong="H5973"\w* hombres impíos?   
\q1
\v 9 \w Porque|strong="H3588"\w* \w ha|strong="H3808"\w* dicho: ‘\w De|strong="H3588"\w* \w nada|strong="H3808"\w* sirve al \w hombre|strong="H1397"\w*  
\q2 \w el|strong="H5973"\w* deleitarse \w en|strong="H5973"\w* Dios’.   
\b  
\q1
\v 10 “\w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, varones de entendimiento, \w oídme|strong="H8085"\w*:  
\q2 ¡\w Lejos|strong="H2486"\w* de Dios la \w impiedad|strong="H7562"\w*,  
\q2 y del \w Omnipotente|strong="H7706"\w* la \w iniquidad|strong="H5766"\w*!   
\q1
\v 11 \w Porque|strong="H3588"\w* \w él|strong="H3588"\w* \w paga|strong="H7999"\w* al hombre según \w su|strong="H3588"\w* \w obra|strong="H6467"\w*,  
\q2 \w y|strong="H3588"\w* le retribuye conforme \w a|strong="H3068"\w* \w su|strong="H3588"\w* camino.   
\q1
\v 12 \w Sí|strong="H3808"\w*, por \w cierto|strong="H3808"\w*, Dios \w no|strong="H3808"\w* hará injusticia,  
\q2 \w ni|strong="H3808"\w* el \w Omnipotente|strong="H7706"\w* \w pervertirá|strong="H5791"\w* el \w derecho|strong="H4941"\w*.   
\q1
\v 13 ¿\w Quién|strong="H4310"\w* \w le|strong="H5921"\w* encomendó \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w la|strong="H5921"\w* tierra?  
\q2 ¿\w Y|strong="H3068"\w* \w quién|strong="H4310"\w* \w puso|strong="H7760"\w* \w en|strong="H5921"\w* sus manos \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w mundo|strong="H8398"\w*?   
\q1
\v 14 Si él pusiera su \w corazón|strong="H3820"\w* contra el hombre,  
\q2 y recogiese para sí su \w espíritu|strong="H7307"\w* y su \w hálito|strong="H7307"\w*,   
\q1
\v 15 \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* \w perecería|strong="H1478"\w* \w juntamente|strong="H3162"\w*,  
\q2 \w y|strong="H5921"\w* \w el|strong="H5921"\w* hombre volvería \w al|strong="H5921"\w* \w polvo|strong="H6083"\w*.   
\b  
\q1
\v 16 “Si, pues, hay en ti entendimiento, \w oye|strong="H8085"\w* \w esto|strong="H2063"\w*;  
\q2 \w escucha|strong="H8085"\w* \w la|strong="H2063"\w* \w voz|strong="H6963"\w* de \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w*.   
\q1
\v 17 ¿Gobernará el que \w aborrece|strong="H8130"\w* el \w juicio|strong="H4941"\w*?  
\q2 ¿\w Y|strong="H3068"\w* condenarás tú al que es tan \w justo|strong="H6662"\w* y poderoso?   
\q1
\v 18 ¿Se dirá \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ‘¡Vil!’,  
\q2 y \w a|strong="H3068"\w* los príncipes: ‘¡\w Impíos|strong="H7563"\w*!’?   
\q1
\v 19 ¿\w Cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w a|strong="H3068"\w* \w aquel|strong="H3605"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* hace \w acepción|strong="H5375"\w* \w de|strong="H3588"\w* personas \w de|strong="H3588"\w* \w príncipes|strong="H8269"\w*,  
\q2 \w ni|strong="H3808"\w* respeta \w más|strong="H3588"\w* al rico \w que|strong="H3588"\w* al \w pobre|strong="H1800"\w*,  
\q2 \w porque|strong="H3588"\w* \w todos|strong="H3605"\w* \w son|strong="H3588"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* sus \w manos|strong="H3027"\w*?   
\q1
\v 20 \w En|strong="H5493"\w* un \w momento|strong="H7281"\w* \w mueren|strong="H4191"\w*, y \w a|strong="H3068"\w* medianoche;  
\q2 los \w pueblos|strong="H5971"\w* \w se|strong="H3808"\w* alborotan y \w pasan|strong="H5674"\w*,  
\q2 y los poderosos \w son|strong="H3808"\w* quitados \w sin|strong="H3808"\w* \w mano|strong="H3027"\w* humana.   
\b  
\q1
\v 21 “\w Porque|strong="H3588"\w* sus \w ojos|strong="H5869"\w* están \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w caminos|strong="H1870"\w* \w del|strong="H5921"\w* hombre,  
\q2 \w y|strong="H3588"\w* \w ve|strong="H7200"\w* \w todos|strong="H3605"\w* sus \w pasos|strong="H6806"\w*.   
\q1
\v 22 No hay \w tinieblas|strong="H2822"\w* ni sombra de \w muerte|strong="H6757"\w*  
\q2 \w donde|strong="H8033"\w* se escondan los que obran iniquidad.   
\q1
\v 23 \w No|strong="H3808"\w* necesita \w él|strong="H5921"\w* cargar \w al|strong="H5921"\w* hombre \w más|strong="H5750"\w* \w de|strong="H5921"\w* \w lo|strong="H3808"\w* debido,  
\q2 \w para|strong="H5921"\w* \w que|strong="H3588"\w* vaya \w con|strong="H5921"\w* Dios \w a|strong="H3068"\w* \w juicio|strong="H4941"\w*.   
\q1
\v 24 Él quebranta \w a|strong="H3068"\w* los fuertes \w sin|strong="H3808"\w* indagación,  
\q2 y pone \w a|strong="H3068"\w* otros \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w*.   
\q1
\v 25 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, él \w conoce|strong="H5234"\w* sus obras;  
\q2 los trastorna en la \w noche|strong="H3915"\w*, y son quebrantados.   
\q1
\v 26 \w Como|strong="H8478"\w* \w a|strong="H3068"\w* malos los \w hiere|strong="H5606"\w*  
\q2 \w en|strong="H8478"\w* \w lugar|strong="H4725"\w* \w donde|strong="H4725"\w* todos lo \w vean|strong="H7200"\w*;   
\q1
\v 27 \w por|strong="H5921"\w* \w cuanto|strong="H3651"\w* \w se|strong="H3808"\w* apartaron \w de|strong="H5921"\w* \w él|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w consideraron|strong="H7919"\w* \w ninguno|strong="H3808"\w* \w de|strong="H5921"\w* sus \w caminos|strong="H1870"\w*,   
\q1
\v 28 haciendo venir ante \w él|strong="H5921"\w* \w el|strong="H5921"\w* \w clamor|strong="H6818"\w* \w del|strong="H5921"\w* \w pobre|strong="H1800"\w*,  
\q2 \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w oiga|strong="H8085"\w* \w el|strong="H5921"\w* \w clamor|strong="H6818"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* necesitados.   
\q1
\v 29 \w Si|strong="H1931"\w* \w él|strong="H1931"\w* da \w reposo|strong="H8252"\w*, ¿\w quién|strong="H4310"\w* \w inquietará|strong="H7561"\w*?  
\q2 \w Si|strong="H1931"\w* \w esconde|strong="H5641"\w* \w su|strong="H1931"\w* \w rostro|strong="H6440"\w*, ¿\w quién|strong="H4310"\w* \w lo|strong="H1931"\w* mirará?  
\q2 \w Esto|strong="H1931"\w* hace \w tanto|strong="H5921"\w* \w con|strong="H5921"\w* una \w nación|strong="H1471"\w* \w como|strong="H5921"\w* \w con|strong="H5921"\w* \w un|strong="H3162"\w* hombre;   
\q1
\v 30 \w para|strong="H5971"\w* \w que|strong="H5971"\w* no \w reine|strong="H4427"\w* el hombre \w hipócrita|strong="H2611"\w*  
\q2 \w para|strong="H5971"\w* enredo del \w pueblo|strong="H5971"\w*.   
\b  
\q1
\v 31 “\w Ciertamente|strong="H3588"\w*, ¿\w se|strong="H3808"\w* \w ha|strong="H3808"\w* dicho \w a|strong="H3068"\w* Dios:  
\q2 ‘He \w llevado|strong="H5375"\w* \w mi|strong="H5375"\w* castigo, \w no|strong="H3808"\w* \w ofenderé|strong="H2254"\w* \w más|strong="H3588"\w*;   
\q1
\v 32 \w enséñame|strong="H3384"\w* tú \w lo|strong="H3808"\w* \w que|strong="H3808"\w* yo \w no|strong="H3808"\w* veo;  
\q2 \w si|strong="H3808"\w* hice \w iniquidad|strong="H5766"\w*, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* haré \w más|strong="H3254"\w*’?   
\q1
\v 33 ¿\w Ha|strong="H3808"\w* \w de|strong="H3588"\w* ser tu recompensa \w como|strong="H4100"\w* tú quieras, \w para|strong="H3588"\w* \w que|strong="H3588"\w* tú \w la|strong="H3588"\w* rehúses?  
\q2 Tú eres \w quien|strong="H4100"\w* debe elegir, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w yo|strong="H3588"\w*;  
\q2 \w di|strong="H1696"\w*, \w pues|strong="H3588"\w*, \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \w sabes|strong="H3045"\w*.   
\q1
\v 34 \w Los|strong="H2450"\w* \w hombres|strong="H1397"\w* inteligentes me dirán,  
\q2 y el \w varón|strong="H1397"\w* \w sabio|strong="H2450"\w* que me \w oiga|strong="H8085"\w*:   
\q1
\v 35 ‘Job \w habla|strong="H1696"\w* \w sin|strong="H3808"\w* \w conocimiento|strong="H1847"\w*,  
\q2 y sus \w palabras|strong="H1697"\w* \w no|strong="H3808"\w* \w son|strong="H3808"\w* con \w sabiduría|strong="H1847"\w*’.   
\q1
\v 36 Deseo yo \w que|strong="H5921"\w* Job sea probado \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* fin,  
\q2 \w por|strong="H5921"\w* sus respuestas semejantes \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* hombres inicuos.   
\q1
\v 37 \w Porque|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pecado|strong="H2403"\w* \w añadió|strong="H3254"\w* rebeldía;  
\q2 bate \w las|strong="H5921"\w* palmas \w entre|strong="H5921"\w* \w nosotros|strong="H5921"\w*,  
\q2 \w y|strong="H3588"\w* \w multiplica|strong="H7235"\w* sus palabras \w contra|strong="H5921"\w* Dios”.   
\c 35
\p
\v 1 Además, Elihú prosiguió y dijo:   
\q1
\v 2 “¿\w Piensas|strong="H2803"\w* que \w esto|strong="H2063"\w* \w es|strong="H2063"\w* recto?  
\q2 Dijiste: ‘Más justo soy yo que Dios’.   
\q1
\v 3 \w Porque|strong="H3588"\w* preguntaste: ‘¿\w Qué|strong="H3588"\w* \w provecho|strong="H3276"\w* \w te|strong="H3588"\w* vendrá \w de|strong="H3588"\w* ello?  
\q2 ¿\w O|strong="H3068"\w* \w qué|strong="H3588"\w* \w ventaja|strong="H5532"\w* tendré \w yo|strong="H3588"\w* \w de|strong="H3588"\w* \w no|strong="H3588"\w* haber \w pecado|strong="H2403"\w*?’.   
\q1
\v 4 Yo \w te|strong="H5973"\w* responderé \w palabras|strong="H4405"\w*,  
\q2 \w a|strong="H3068"\w* \w ti|strong="H5973"\w* y \w a|strong="H3068"\w* vuestros \w compañeros|strong="H7453"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*.   
\q1
\v 5 \w Mira|strong="H7200"\w* \w a|strong="H3068"\w* los \w cielos|strong="H8064"\w*, y \w ve|strong="H7200"\w*;  
\q2 y considera las nubes, \w que|strong="H4480"\w* están \w más|strong="H4480"\w* altas \w que|strong="H4480"\w* tú.   
\q1
\v 6 Si pecaras, ¿\w qué|strong="H4100"\w* habrías de \w hacer|strong="H6213"\w* contra \w él|strong="H6213"\w*?  
\q2 \w Y|strong="H3068"\w* si tus transgresiones \w se|strong="H4100"\w* multiplicaran, ¿\w qué|strong="H4100"\w* le harías \w tú|strong="H6213"\w*?   
\q1
\v 7 Si fueras justo, ¿\w qué|strong="H4100"\w* le darías \w a|strong="H3068"\w* él?  
\q2 ¿\w O|strong="H3068"\w* \w qué|strong="H4100"\w* recibiría él \w de|strong="H5414"\w* tu \w mano|strong="H3027"\w*?   
\q1
\v 8 Al \w hombre|strong="H1121"\w* \w como|strong="H3644"\w* tú dañará tu \w impiedad|strong="H7562"\w*,  
\q2 y al \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w* aprovechará tu \w justicia|strong="H6666"\w*.   
\b  
\q1
\v 9 “\w A|strong="H3068"\w* causa de la \w multitud|strong="H7227"\w* de las \w opresiones|strong="H6217"\w* \w claman|strong="H7768"\w*,  
\q2 y se lamentan por el \w poder|strong="H7230"\w* de los \w grandes|strong="H7227"\w*.   
\q1
\v 10 Pero \w ninguno|strong="H3808"\w* dice: ‘¿Dónde está Dios mi \w Hacedor|strong="H6213"\w*,  
\q2 \w que|strong="H3808"\w* \w da|strong="H5414"\w* \w cánticos|strong="H2158"\w* en la \w noche|strong="H3915"\w*,   
\q1
\v 11 que nos enseña más que \w a|strong="H3068"\w* las bestias de la tierra,  
\q2 y nos hace más sabios que \w a|strong="H3068"\w* las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w*?’.   
\q1
\v 12 \w Allí|strong="H8033"\w* \w claman|strong="H6817"\w*, y él \w no|strong="H3808"\w* oye,  
\q2 \w por|strong="H6440"\w* la \w soberbia|strong="H1347"\w* \w de|strong="H6440"\w* los \w malos|strong="H7451"\w*.   
\q1
\v 13 \w Ciertamente|strong="H8085"\w* Dios \w no|strong="H3808"\w* \w oirá|strong="H8085"\w* la \w vanidad|strong="H7723"\w*,  
\q2 \w ni|strong="H3808"\w* la mirará el \w Omnipotente|strong="H7706"\w*.   
\q1
\v 14 ¿\w Cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w cuando|strong="H3588"\w* tú dices \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* ves?  
\q2 \w La|strong="H3588"\w* \w causa|strong="H6440"\w* está \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*; \w por|strong="H3588"\w* tanto, espérale.   
\q1
\v 15 \w Mas|strong="H3588"\w* \w ahora|strong="H6258"\w*, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* ira \w no|strong="H3808"\w* \w ha|strong="H3808"\w* castigado,  
\q2 \w ni|strong="H3808"\w* \w ha|strong="H3808"\w* considerado \w con|strong="H3588"\w* rigor \w la|strong="H3588"\w* arrogancia,   
\q1
\v 16 por eso Job \w abre|strong="H6475"\w* su \w boca|strong="H6310"\w* \w vanamente|strong="H1892"\w*,  
\q2 y multiplica \w palabras|strong="H4405"\w* \w sin|strong="H1097"\w* \w conocimiento|strong="H1847"\w*”.   
\b  
\c 36
\p
\v 1 Elihú prosiguió y dijo:   
\q1
\v 2 “Tened un poco \w de|strong="H3588"\w* paciencia conmigo, \w y|strong="H3588"\w* os enseñaré;  
\q2 \w porque|strong="H3588"\w* \w todavía|strong="H5750"\w* tengo \w palabras|strong="H4405"\w* \w en|strong="H3588"\w* defensa \w de|strong="H3588"\w* Dios.   
\q1
\v 3 Traeré \w mi|strong="H5375"\w* saber desde \w lejos|strong="H7350"\w*,  
\q2 y atribuiré \w justicia|strong="H6664"\w* \w a|strong="H3068"\w* \w mi|strong="H5375"\w* Hacedor.   
\q1
\v 4 \w Porque|strong="H3588"\w* \w en|strong="H5973"\w* verdad \w no|strong="H3808"\w* \w son|strong="H3588"\w* mentirosas \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w*;  
\q2 uno \w que|strong="H3588"\w* \w es|strong="H3588"\w* \w perfecto|strong="H8549"\w* \w en|strong="H5973"\w* \w conocimiento|strong="H1844"\w* está \w contigo|strong="H5973"\w*.   
\b  
\q1
\v 5 “He \w aquí|strong="H2005"\w* \w que|strong="H3808"\w* Dios es poderoso, \w mas|strong="H3808"\w* \w no|strong="H3808"\w* \w desprecia|strong="H3988"\w* \w a|strong="H3068"\w* \w nadie|strong="H3808"\w*;  
\q2 es poderoso en \w fuerza|strong="H3581"\w* de \w entendimiento|strong="H3820"\w*.   
\q1
\v 6 \w No|strong="H3808"\w* otorga \w vida|strong="H2421"\w* al \w impío|strong="H7563"\w*,  
\q2 pero \w a|strong="H3068"\w* los afligidos \w da|strong="H5414"\w* su \w derecho|strong="H4941"\w*.   
\q1
\v 7 \w No|strong="H3808"\w* aparta sus \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w los|strong="H3427"\w* \w justos|strong="H6662"\w*;  
\q2 antes \w bien|strong="H5869"\w*, con \w los|strong="H3427"\w* \w reyes|strong="H4428"\w* \w los|strong="H3427"\w* pone en \w el|strong="H3427"\w* \w trono|strong="H3678"\w* para siempre,  
\q2 y \w son|strong="H3808"\w* exaltados.   
