\q1
\v 21 Porque encubierta está \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w todo|strong="H3605"\w* \w viviente|strong="H2416"\w*,  
\q2 y aun \w a|strong="H3068"\w* las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w* es oculta.   
\q1
\v 22 El Abadón y la \w muerte|strong="H4194"\w* dijeron:  
\q2 ‘Su fama hemos \w oído|strong="H8085"\w* con nuestros \w oídos|strong="H8085"\w*’.   
\b  
\q1
\v 23 “Dios \w entiende|strong="H3045"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* de \w ella|strong="H1931"\w*,  
\q2 y \w él|strong="H1931"\w* \w conoce|strong="H3045"\w* \w su|strong="H1931"\w* \w lugar|strong="H4725"\w*.   
\q1
\v 24 \w Porque|strong="H3588"\w* \w él|strong="H1931"\w* \w mira|strong="H7200"\w* \w hasta|strong="H1931"\w* \w los|strong="H3605"\w* fines \w de|strong="H3588"\w* \w la|strong="H1931"\w* tierra,  
\q2 \w y|strong="H3588"\w* \w ve|strong="H7200"\w* \w cuanto|strong="H3588"\w* hay \w bajo|strong="H8478"\w* \w los|strong="H3605"\w* \w cielos|strong="H8064"\w*.   
\q1
\v 25 Al dar \w peso|strong="H4948"\w* al \w viento|strong="H7307"\w*,  
\q2 y poner las \w aguas|strong="H4325"\w* por \w medida|strong="H4060"\w*;   
\q1
\v 26 cuando \w él|strong="H6213"\w* dio \w ley|strong="H2706"\w* \w a|strong="H3068"\w* la \w lluvia|strong="H4306"\w*,  
\q2 y \w camino|strong="H1870"\w* al relámpago de los \w truenos|strong="H6963"\w*;   
\q1
\v 27 \w entonces|strong="H1571"\w* \w la|strong="H1571"\w* \w vio|strong="H7200"\w* \w él|strong="H1571"\w*, \w y|strong="H1571"\w* \w la|strong="H1571"\w* manifestó;  
\q2 \w la|strong="H1571"\w* \w preparó|strong="H3559"\w* \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w la|strong="H1571"\w* escudriñó.   
\q1
\v 28 \w Y|strong="H3068"\w* dijo al hombre:  
\q2 ‘He \w aquí|strong="H2005"\w* \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w temor|strong="H3374"\w* del Señor\f + \fr 28:28 \ft La palabra traducida como «Señor» es «Adonai».\f* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w sabiduría|strong="H2451"\w*,  
\q2 y \w el|strong="H1931"\w* \w apartarse|strong="H5493"\w* del \w mal|strong="H7451"\w*, \w la|strong="H1931"\w* inteligencia’”.   
\c 29
\p
\v 1 Prosiguió Job su discurso, y dijo:   
\q1
\v 2 “¡\w Quién|strong="H4310"\w* \w me|strong="H4310"\w* \w diera|strong="H5414"\w* volver \w a|strong="H3068"\w* ser como en los \w meses|strong="H3391"\w* \w pasados|strong="H6924"\w*,  
\q2 como en los \w días|strong="H3117"\w* en \w que|strong="H4310"\w* Dios \w me|strong="H4310"\w* guardaba;   
\q1
\v 3 cuando \w hacía|strong="H5921"\w* resplandecer su \w lámpara|strong="H5216"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*,  
\q2 \w a|strong="H3068"\w* cuya luz yo \w caminaba|strong="H3212"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w oscuridad|strong="H2822"\w*;   
\q1
\v 4 \w como|strong="H1961"\w* \w fui|strong="H1961"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* madurez,  
\q2 \w cuando|strong="H3117"\w* \w el|strong="H5921"\w* favor \w de|strong="H5921"\w* Dios velaba \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* tienda;   
\q1
\v 5 cuando el \w Omnipotente|strong="H7706"\w* estaba \w aún|strong="H5750"\w* \w conmigo|strong="H5978"\w*,  
\q2 y mis hijos \w alrededor|strong="H5439"\w* \w de|strong="H5750"\w* mí;   
\q1
\v 6 cuando lavaba mis pasos \w con|strong="H5978"\w* leche,  
\q2 y la \w roca|strong="H6697"\w* me derramaba \w ríos|strong="H6388"\w* de \w aceite|strong="H8081"\w*!   
\q1
\v 7 Cuando \w salía|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w a|strong="H3068"\w* \w juicio|strong="H7176"\w*,  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* plaza preparaba \w mi|strong="H5921"\w* asiento,   
\q1
\v 8 los jóvenes me \w veían|strong="H7200"\w* y se escondían,  
\q2 y los ancianos se levantaban y permanecían \w en|strong="H5975"\w* \w pie|strong="H5975"\w*.   
\q1
\v 9 Los \w príncipes|strong="H8269"\w* \w detenían|strong="H6113"\w* sus \w palabras|strong="H4405"\w*  
\q2 y \w ponían|strong="H7760"\w* la \w mano|strong="H3709"\w* sobre su \w boca|strong="H6310"\w*.   
\q1
\v 10 La \w voz|strong="H6963"\w* \w de|strong="H5057"\w* los nobles se apagaba,  
\q2 y su \w lengua|strong="H3956"\w* se pegaba \w a|strong="H3068"\w* su paladar.   
\q1
\v 11 \w Los|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w oían|strong="H8085"\w*, \w me|strong="H3588"\w* llamaban bienaventurado,  
\q2 \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w veían|strong="H7200"\w*, daban testimonio \w de|strong="H3588"\w* mí,   
\q1
\v 12 \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w libraba|strong="H4422"\w* al \w pobre|strong="H6041"\w* \w que|strong="H3588"\w* \w clamaba|strong="H7768"\w*,  
\q2 \w y|strong="H3588"\w* al \w huérfano|strong="H3490"\w* \w que|strong="H3588"\w* carecía \w de|strong="H3588"\w* \w ayudador|strong="H5826"\w*.   
\q1
\v 13 \w La|strong="H5921"\w* \w bendición|strong="H1293"\w* \w del|strong="H5921"\w* \w que|strong="H5921"\w* estaba \w a|strong="H3068"\w* punto \w de|strong="H5921"\w* perecer venía \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* viuda yo daba alegría.   
\q1
\v 14 Me vestía \w de|strong="H3847"\w* \w justicia|strong="H6664"\w*, y ella me cubría;  
\q2 como \w manto|strong="H4598"\w* y diadema era mi \w derecho|strong="H4941"\w*.   
\q1
\v 15 Yo \w era|strong="H1961"\w* \w ojos|strong="H5869"\w* \w para|strong="H1961"\w* el \w ciego|strong="H5787"\w*,  
\q2 y \w pies|strong="H7272"\w* \w para|strong="H1961"\w* el \w cojo|strong="H6455"\w*.   
\q1
\v 16 \w A|strong="H3068"\w* los menesterosos era padre,  
\q2 y de la \w causa|strong="H7379"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w conocía|strong="H3045"\w*, me informaba con diligencia.   
\q1
\v 17 Quebrantaba los colmillos del inicuo,  
\q2 y de sus \w dientes|strong="H8127"\w* hacía soltar la presa.   
\q1
\v 18 Decía yo: ‘\w En|strong="H5973"\w* mi \w nido|strong="H7064"\w* \w moriré|strong="H1478"\w*,  
\q2 y \w como|strong="H5973"\w* la arena \w multiplicaré|strong="H7235"\w* mis \w días|strong="H3117"\w*’.   
\q1
\v 19 Mi raíz estaba \w abierta|strong="H6605"\w* junto \w a|strong="H3068"\w* las \w aguas|strong="H4325"\w*,  
\q2 y en mis \w ramas|strong="H7105"\w* permanecía \w el|strong="H3885"\w* \w rocío|strong="H2919"\w*.   
\q1
\v 20 Mi \w honra|strong="H3519"\w* se renovaba en mí,  
\q2 \w y|strong="H3519"\w* mi \w arco|strong="H7198"\w* se fortalecía en mi \w mano|strong="H3027"\w*.   
\b  
\q1
\v 21 “Me \w oían|strong="H8085"\w*, y esperaban,  
\q2 y callaban \w a|strong="H3068"\w* mi \w consejo|strong="H6098"\w*.   
\q1
\v 22 Tras \w mi|strong="H5921"\w* \w palabra|strong="H1697"\w* \w no|strong="H3808"\w* \w replicaban|strong="H8138"\w*,  
\q2 \w y|strong="H5921"\w* \w mi|strong="H5921"\w* razón \w destilaba|strong="H5197"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
\q1
\v 23 Me esperaban como \w a|strong="H3068"\w* la \w lluvia|strong="H4306"\w*,  
\q2 y abrían su \w boca|strong="H6310"\w* como \w a|strong="H3068"\w* la \w lluvia|strong="H4306"\w* \w tardía|strong="H4456"\w*.   
\q1
\v 24 \w Si|strong="H3808"\w* me reía con ellos, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* creían;  
\q2 y \w no|strong="H3808"\w* \w abatían|strong="H5307"\w* la luz \w de|strong="H6440"\w* mi vuestro \w rostro|strong="H6440"\w*.   
\q1
\v 25 Calificaba yo \w el|strong="H3427"\w* \w camino|strong="H1870"\w* de ellos, y me sentaba \w como|strong="H7931"\w* \w jefe|strong="H7218"\w*;  
\q2 y \w moraba|strong="H3427"\w* \w como|strong="H7931"\w* \w rey|strong="H4428"\w* en \w el|strong="H3427"\w* \w ejército|strong="H1416"\w*,  
\q2 \w como|strong="H7931"\w* \w el|strong="H3427"\w* \w que|strong="H1416"\w* \w consuela|strong="H5162"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* llorosos.   
