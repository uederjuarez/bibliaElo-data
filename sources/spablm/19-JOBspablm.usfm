\p Las \w palabras|strong="H1697"\w* \w de|strong="H8478"\w* Job han terminado.   
\c 32
\p
\v 1 \w Cesaron|strong="H7673"\w* \w estos|strong="H1931"\w* \w tres|strong="H7969"\w* \w varones|strong="H3588"\w* \w de|strong="H3588"\w* \w responder|strong="H6030"\w* \w a|strong="H3068"\w* Job, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w él|strong="H1931"\w* \w era|strong="H1931"\w* \w justo|strong="H6662"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* propios \w ojos|strong="H5869"\w*.  
\v 2 Entonces \w se|strong="H5921"\w* encendió \w la|strong="H5921"\w* ira \w de|strong="H5921"\w* Elihú \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Baraquel buzita, \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w familia|strong="H4940"\w* \w de|strong="H5921"\w* \w Ram|strong="H7410"\w*, \w contra|strong="H5921"\w* Job; \w se|strong="H5921"\w* encendió su ira \w por|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* justificaba \w a|strong="H3068"\w* \w sí|strong="H5921"\w* mismo \w más|strong="H5921"\w* \w que|strong="H5921"\w* \w a|strong="H3068"\w* Dios.  
\v 3 Asimismo \w se|strong="H5921"\w* encendió su ira \w contra|strong="H5921"\w* sus \w tres|strong="H7969"\w* \w amigos|strong="H7453"\w*, \w porque|strong="H5921"\w* \w no|strong="H3808"\w* habían \w hallado|strong="H4672"\w* \w respuesta|strong="H4617"\w*, \w y|strong="H5921"\w* \w sin|strong="H3808"\w* embargo habían condenado \w a|strong="H3068"\w* Job.  
\v 4 \w Y|strong="H3068"\w* Elihú \w había|strong="H3588"\w* esperado \w a|strong="H3068"\w* Job \w en|strong="H4480"\w* \w el|strong="H3588"\w* \w hablar|strong="H1697"\w*, \w porque|strong="H3588"\w* \w ellos|strong="H1992"\w* eran \w más|strong="H3588"\w* \w ancianos|strong="H2205"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w*.  
\v 5 \w Pero|strong="H3588"\w* \w viendo|strong="H7200"\w* Elihú \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w había|strong="H3588"\w* \w respuesta|strong="H4617"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* aquellos \w tres|strong="H7969"\w* \w varones|strong="H3588"\w*, \w su|strong="H3588"\w* ira se encendió.   
\b  
\p
\v 6 \w Y|strong="H3068"\w* \w respondió|strong="H6030"\w* Elihú \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Baraquel buzita, \w y|strong="H5921"\w* dijo:  
\q1 “Yo soy joven, \w y|strong="H5921"\w* vosotros sois muy ancianos;  
\q2 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, he tenido \w miedo|strong="H3372"\w*, \w y|strong="H5921"\w* he \w temido|strong="H3372"\w* declararos \w mi|strong="H5921"\w* \w opinión|strong="H1843"\w*.   
\q1
\v 7 Yo decía: ‘Los \w días|strong="H3117"\w* \w hablarán|strong="H1696"\w*,  
\q2 y \w la|strong="H2451"\w* \w multitud|strong="H7230"\w* de \w años|strong="H8141"\w* enseñará \w sabiduría|strong="H2451"\w*’.   
\q1
\v 8 Ciertamente \w espíritu|strong="H7307"\w* hay en \w el|strong="H1931"\w* hombre,  
\q2 y \w el|strong="H1931"\w* \w hálito|strong="H5397"\w*\f + \fr 32:8 \ft o, aliento\f* del \w Omnipotente|strong="H7706"\w* les hace entender.   
\q1
\v 9 \w No|strong="H3808"\w* \w son|strong="H3808"\w* siempre los \w grandes|strong="H7227"\w* los sabios,  
\q2 \w ni|strong="H3808"\w* los \w ancianos|strong="H2205"\w* los \w que|strong="H3808"\w* entienden el \w derecho|strong="H4941"\w*.   
