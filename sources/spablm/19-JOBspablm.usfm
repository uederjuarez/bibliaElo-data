\q1
\v 14 \w Si|strong="H3808"\w* sus \w hijos|strong="H1121"\w* \w se|strong="H3808"\w* multiplicaren, serán para \w la|strong="H7646"\w* \w espada|strong="H2719"\w*;  
\q2 y sus pequeños \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w saciarán|strong="H7646"\w* \w de|strong="H1121"\w* \w pan|strong="H3899"\w*.   
\q1
\v 15 Los \w que|strong="H3808"\w* de él quedaren, \w en|strong="H6912"\w* \w muerte|strong="H4194"\w* serán \w sepultados|strong="H6912"\w*,  
\q2 y \w no|strong="H3808"\w* los \w llorarán|strong="H1058"\w* sus viudas.   
\q1
\v 16 Aunque amontone \w plata|strong="H3701"\w* como \w polvo|strong="H6083"\w*,  
\q2 y prepare ropa como \w barro|strong="H2563"\w*;   
\q1
\v 17 la preparará él, mas el \w justo|strong="H6662"\w* se \w vestirá|strong="H3847"\w*,  
\q2 \w y|strong="H5355"\w* el \w inocente|strong="H5355"\w* \w repartirá|strong="H2505"\w* la \w plata|strong="H3701"\w*.   
\q1
\v 18 \w Edificó|strong="H1129"\w* su \w casa|strong="H1004"\w* como la \w polilla|strong="H6211"\w*,  
\q2 y como enramada que \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w guarda|strong="H5341"\w*.   
\q1
\v 19 \w Rico|strong="H6223"\w* \w se|strong="H3808"\w* acuesta, \w mas|strong="H3808"\w* \w no|strong="H3808"\w* volverá \w a|strong="H3068"\w* hacerlo;  
\q2 \w abrirá|strong="H6491"\w* sus \w ojos|strong="H5869"\w*, y \w nada|strong="H3808"\w* tendrá.   
