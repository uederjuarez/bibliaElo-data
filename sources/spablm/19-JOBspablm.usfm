\q1
\v 9 “\w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* yo \w soy|strong="H1961"\w* \w su|strong="H1992"\w* canción,  
\q2 y \w les|strong="H1992"\w* sirvo de \w refrán|strong="H4405"\w*.   
\q1
\v 10 \w Me|strong="H4480"\w* abominan, \w se|strong="H3808"\w* alejan \w de|strong="H4480"\w* mí,  
\q2 y \w aun|strong="H3808"\w* \w en|strong="H4480"\w* mi \w presencia|strong="H6440"\w* \w no|strong="H3808"\w* dejan \w de|strong="H4480"\w* escupirme.   
\q1
\v 11 \w Porque|strong="H3588"\w* Dios ha desatado mi cuerda, \w y|strong="H3588"\w* \w me|strong="H3588"\w* ha \w afligido|strong="H6031"\w*,  
\q2 \w por|strong="H3588"\w* eso ellos se desenfrenaron \w delante|strong="H6440"\w* \w de|strong="H3588"\w* mi \w rostro|strong="H6440"\w*.   
\q1
\v 12 \w A|strong="H3068"\w* \w mi|strong="H5921"\w* \w derecha|strong="H3225"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w la|strong="H5921"\w* zupia;  
\q2 \w empujaron|strong="H7971"\w* mis \w pies|strong="H7272"\w*,  
