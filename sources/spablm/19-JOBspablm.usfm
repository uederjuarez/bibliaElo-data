\v 16 \w Si|strong="H3588"\w* \w yo|strong="H3588"\w* le invocase, \w y|strong="H3588"\w* \w él|strong="H3588"\w* \w me|strong="H3588"\w* \w respondiese|strong="H6030"\w*,  
\q2 \w aún|strong="H3808"\w* \w no|strong="H3808"\w* creeré \w que|strong="H3588"\w* haya escuchado \w mi|strong="H6030"\w* \w voz|strong="H6963"\w*.   
\q1
\v 17 Porque me ha quebrantado con tempestad,  
\q2 y ha aumentado mis heridas sin causa.   
\q1
\v 18 \w No|strong="H3808"\w* \w me|strong="H3588"\w* \w ha|strong="H3808"\w* concedido \w que|strong="H3588"\w* tome aliento,  
\q2 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w ha|strong="H3808"\w* hartado \w de|strong="H3588"\w* amarguras.   
\q1
\v 19 \w Si|strong="H2009"\w* hablamos de \w fuerza|strong="H3581"\w*, fuerte es \w él|strong="H4310"\w*;  
\q2 \w si|strong="H2009"\w* de \w juicio|strong="H4941"\w*, ‘¿\w quién|strong="H4310"\w* \w me|strong="H4310"\w* emplazará?’.   
