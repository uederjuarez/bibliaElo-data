\q1
\v 20 “\w A|strong="H3068"\w* \w lo|strong="H3808"\w* menos \w dos|strong="H8147"\w* \w cosas|strong="H8147"\w* \w no|strong="H3808"\w* \w hagas|strong="H6213"\w* \w conmigo|strong="H5978"\w*;  
