\q2 y soy \w semejante|strong="H4911"\w* al \w polvo|strong="H6083"\w* y \w a|strong="H3068"\w* la ceniza.   
\q1
\v 20 \w Clamo|strong="H7768"\w* \w a|strong="H3068"\w* ti, y \w no|strong="H3808"\w* me oyes;  
\q2 me presento, y \w no|strong="H3808"\w* me atiendes.   
\q1
\v 21 Te has vuelto cruel para conmigo;  
\q2 con el \w poder|strong="H3027"\w* de tu \w mano|strong="H3027"\w* me persigues.   
\q1
\v 22 Me \w alzaste|strong="H5375"\w* sobre el \w viento|strong="H7307"\w*, me hiciste cabalgar en él,  
\q2 y disolviste \w mi|strong="H5375"\w* sustancia.   
\q1
\v 23 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* conduces \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w muerte|strong="H4194"\w*,  
