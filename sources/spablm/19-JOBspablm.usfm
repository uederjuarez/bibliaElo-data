\v 23 \w Batirán|strong="H5606"\w* \w las|strong="H5921"\w* \w palmas|strong="H3709"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* \w desde|strong="H5921"\w* su \w lugar|strong="H4725"\w* \w le|strong="H5921"\w* \w silbarán|strong="H8319"\w*».   
\c 28
\b  
\q1
\v 1 “\w Ciertamente|strong="H3588"\w* \w hay|strong="H3426"\w* minas \w de|strong="H3588"\w* \w donde|strong="H4725"\w* se saca \w la|strong="H3588"\w* \w plata|strong="H3701"\w*,  
