\v 8 \w siembre|strong="H2232"\w* yo, y otro coma,  
\q2 y sea arrancada mi siembra.   
\b  
\q1
\v 9 “\w Si|strong="H5921"\w* fue \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w* \w engañado|strong="H6601"\w* \w por|strong="H5921"\w* mujer,  
\q2 \w y|strong="H5921"\w* \w si|strong="H5921"\w* estuve acechando \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w prójimo|strong="H7453"\w*,   
\q1
\v 10 \w muela|strong="H2912"\w* \w para|strong="H5921"\w* otro \w mi|strong="H5921"\w* mujer,  
\q2 \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* otros \w se|strong="H5921"\w* encorven.   
\q1
\v 11 \w Porque|strong="H3588"\w* \w es|strong="H1931"\w* \w maldad|strong="H5771"\w* detestable  
\q2 \w e|strong="H3068"\w* \w iniquidad|strong="H5771"\w* latente ante \w los|strong="H1931"\w* \w jueces|strong="H6414"\w*.   
\q1
\v 12 \w Porque|strong="H3588"\w* \w es|strong="H1931"\w* fuego \w que|strong="H3588"\w* devoraría \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* Abadón,  
\q2 \w y|strong="H3588"\w* destruiría \w toda|strong="H3605"\w* mi hacienda.   
\q1
\v 13 “Si hubiera tenido en poco el \w derecho|strong="H4941"\w* de mi \w siervo|strong="H5650"\w*  
\q2 \w o|strong="H3068"\w* de mi sierva, \w cuando|strong="H5650"\w* ellos contendían \w conmigo|strong="H5978"\w*,   
\q1
\v 14 ¿\w qué|strong="H3588"\w* \w haría|strong="H6213"\w* \w yo|strong="H3588"\w* \w cuando|strong="H3588"\w* Dios \w se|strong="H4100"\w* levantase?  
\q2 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w él|strong="H3588"\w* \w me|strong="H3588"\w* preguntase, ¿\w qué|strong="H3588"\w* le respondería \w yo|strong="H3588"\w*?   
\q1
\v 15 \w El|strong="H6213"\w* \w que|strong="H3808"\w* en \w el|strong="H6213"\w* vientre me \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* mí, ¿\w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w él|strong="H6213"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w no|strong="H3808"\w* nos \w dispuso|strong="H6213"\w* uno mismo en la \w matriz|strong="H7358"\w*?   
\q1
\v 16 “Si \w estorbé|strong="H4513"\w* el \w deseo|strong="H2656"\w* \w de|strong="H5869"\w* los \w pobres|strong="H1800"\w*,  
\q2 \w e|strong="H3068"\w* hice desfallecer los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* la viuda;   
\q1
\v 17 \w si|strong="H3808"\w* comí mi bocado solo,  
\q2 y \w no|strong="H3808"\w* comió \w de|strong="H4480"\w* él el \w huérfano|strong="H3490"\w*   
\q1
\v 18 (\w porque|strong="H3588"\w* desde \w mi|strong="H1431"\w* \w juventud|strong="H5271"\w* \w creció|strong="H1431"\w* conmigo \w como|strong="H3588"\w* \w con|strong="H3588"\w* un padre,  
\q2 \w y|strong="H3588"\w* desde \w el|strong="H3588"\w* vientre \w de|strong="H3588"\w* \w mi|strong="H1431"\w* madre fui guía \w de|strong="H3588"\w* \w la|strong="H3588"\w* viuda);   
\q1
\v 19 si he \w visto|strong="H7200"\w* que alguno perecía por falta de \w vestido|strong="H3830"\w*,  
\q2 y que carecía de manta el necesitado;   
\q1
\v 20 \w si|strong="H3808"\w* \w no|strong="H3808"\w* me \w bendijeron|strong="H1288"\w* sus \w lomos|strong="H2504"\w*,  
\q2 y del vellón de mis ovejas \w se|strong="H3808"\w* calentaron;   
\q1
\v 21 \w si|strong="H3588"\w* alcé \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w huérfano|strong="H3490"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*,  
\q2 \w porque|strong="H3588"\w* \w vi|strong="H7200"\w* \w que|strong="H3588"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w me|strong="H5921"\w* ayudarían;   
\q1
\v 22 mi espalda se \w caiga|strong="H5307"\w* de mi \w hombro|strong="H3802"\w*,  
\q2 y mi \w brazo|strong="H7070"\w* sea quebrado de su hueso.   
\q1
\v 23 \w Porque|strong="H3588"\w* \w temí|strong="H6343"\w* \w el|strong="H3588"\w* castigo \w de|strong="H3588"\w* Dios,  
\q2 contra cuya majestad \w yo|strong="H3588"\w* \w no|strong="H3808"\w* tendría poder.   
\q1
\v 24 “Si \w puse|strong="H7760"\w* en el \w oro|strong="H2091"\w* mi \w esperanza|strong="H4009"\w*,  
\q2 y dije al \w oro|strong="H2091"\w* \w fino|strong="H3800"\w*: ‘Mi \w confianza|strong="H4009"\w* eres tú’;   
\q1
\v 25 \w si|strong="H3588"\w* \w me|strong="H3588"\w* alegré \w de|strong="H3588"\w* \w que|strong="H3588"\w* mis \w riquezas|strong="H2428"\w* se multiplicasen,  
\q2 \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w que|strong="H3588"\w* mi \w mano|strong="H3027"\w* \w hallase|strong="H4672"\w* \w mucho|strong="H7227"\w*;   
\q1
\v 26 \w si|strong="H3588"\w* he mirado al sol \w cuando|strong="H3588"\w* \w resplandecía|strong="H1984"\w*,  
\q2 \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w luna|strong="H3394"\w* \w cuando|strong="H3588"\w* \w iba|strong="H1980"\w* \w hermosa|strong="H3368"\w*,   
\q1
\v 27 y mi \w corazón|strong="H3820"\w* se engañó en secreto,  
\q2 y mi \w boca|strong="H6310"\w* \w besó|strong="H5401"\w* mi \w mano|strong="H3027"\w*;   
\q1
\v 28 \w esto|strong="H1931"\w* \w también|strong="H1571"\w* sería \w maldad|strong="H5771"\w* juzgada,  
\q2 \w porque|strong="H3588"\w* habría negado al Dios \w soberano|strong="H4605"\w*.   
\q1
\v 29 “\w Si|strong="H3588"\w* \w me|strong="H3588"\w* alegré \w en|strong="H3588"\w* \w el|strong="H3588"\w* quebrantamiento del \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w aborrecía|strong="H8130"\w*,  
\q2 \w y|strong="H3588"\w* \w me|strong="H3588"\w* regocijé \w cuando|strong="H3588"\w* le \w halló|strong="H4672"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w*   
\q1
\v 30 (\w ni|strong="H3808"\w* \w aun|strong="H3808"\w* \w entregué|strong="H5414"\w* \w mi|strong="H5315"\w* lengua al \w pecado|strong="H2398"\w*  
\q2 \w para|strong="H5414"\w* pedir su \w vida|strong="H5315"\w* con maldición);   
\q1
\v 31 \w si|strong="H3808"\w* los siervos \w de|strong="H5414"\w* mi tienda \w no|strong="H3808"\w* decían:  
