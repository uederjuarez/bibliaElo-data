\q1
\v 8 Si se \w envejeciere|strong="H2204"\w* su raíz en la \w tierra|strong="H6083"\w*,  
\q2 y su tronco \w muriere|strong="H4191"\w* en el \w polvo|strong="H6083"\w*,   
\q1
\v 9 al percibir \w el|strong="H6213"\w* \w agua|strong="H4325"\w* \w reverdecerá|strong="H6524"\w*,  
\q2 y \w hará|strong="H6213"\w* \w copa|strong="H7105"\w* \w como|strong="H3644"\w* \w planta|strong="H5194"\w* nueva.   
\q1
\v 10 \w Mas|strong="H4191"\w* el \w hombre|strong="H1397"\w* \w morirá|strong="H4191"\w* y será cortado;  
\q2 perecerá el \w hombre|strong="H1397"\w*, ¿y dónde estará él?   
\q1
\v 11 Como las \w aguas|strong="H4325"\w* \w se|strong="H4480"\w* van \w del|strong="H4480"\w* \w mar|strong="H3220"\w*,  
\q2 y el \w río|strong="H5104"\w* \w se|strong="H4480"\w* agota y \w se|strong="H4480"\w* \w seca|strong="H3001"\w*,   
\q1
\v 12 así el hombre \w yace|strong="H7901"\w* \w y|strong="H5704"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* vuelve \w a|strong="H3068"\w* \w levantar|strong="H6965"\w*;  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* haya \w cielo|strong="H8064"\w*, \w no|strong="H3808"\w* \w despertarán|strong="H5782"\w*,  
\q2 \w ni|strong="H3808"\w* \w se|strong="H3808"\w* levantarán \w de|strong="H5704"\w* su \w sueño|strong="H8142"\w*.   
\b  
\q1
\v 13 “¡\w Oh|strong="H4310"\w*, \w quién|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* \w me|strong="H4310"\w* \w escondieses|strong="H6845"\w* \w en|strong="H5704"\w* \w el|strong="H4310"\w* Seol,  
\q2 \w que|strong="H4310"\w* \w me|strong="H4310"\w* ocultases \w hasta|strong="H5704"\w* \w que|strong="H4310"\w* se pase tu ira,  
\q2 \w que|strong="H4310"\w* \w me|strong="H4310"\w* \w pusieses|strong="H7896"\w* \w plazo|strong="H2706"\w* \w y|strong="H5704"\w* \w de|strong="H5704"\w* mí te acordases!   
\q1
\v 14 Si \w el|strong="H3605"\w* \w hombre|strong="H1397"\w* \w muriere|strong="H4191"\w*, ¿volverá \w a|strong="H3068"\w* \w vivir|strong="H2421"\w*?  
\q2 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H5704"\w* mi milicia \w esperaré|strong="H3176"\w*,  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* venga mi liberación.   
\q1
\v 15 \w Llamarás|strong="H7121"\w*, y yo te \w responderé|strong="H6030"\w*;  
\q2 tendrás afecto \w a|strong="H3068"\w* la \w obra|strong="H4639"\w* de tus \w manos|strong="H3027"\w*.   
