\q1
\v 14 \w Buscad|strong="H1875"\w* el \w bien|strong="H2896"\w* y \w no|strong="H1961"\w* el \w mal|strong="H7451"\w*,  
\q2 \w para|strong="H4616"\w* \w que|strong="H1961"\w* \w viváis|strong="H2421"\w*;  
\q2 y \w así|strong="H3651"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H7451"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w*, \w estará|strong="H1961"\w* con vosotros,  
\q2 \w tal|strong="H3651"\w* \w como|strong="H1961"\w* decís.   
\q1
\v 15 Odiad el \w mal|strong="H7451"\w* y amad el \w bien|strong="H2896"\w*,  
\q2 y estableced la \w justicia|strong="H4941"\w* en los tribunales;  
\q2 quizá Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H7451"\w* los \w Ejércitos|strong="H6635"\w*, tenga piedad del remanente \w de|strong="H7451"\w* \w José|strong="H3130"\w*.   
\p
\v 16 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* de \w los|strong="H3605"\w* \w Ejércitos|strong="H6635"\w*, \w el|strong="H3605"\w* \w Señor|strong="H3068"\w*:  
\q1 “En \w todas|strong="H3605"\w* las \w plazas|strong="H7339"\w* habrá \w llanto|strong="H4553"\w*,  
\q2 \w y|strong="H3541"\w* en \w todas|strong="H3605"\w* las \w calles|strong="H7339"\w* dirán: ‘¡\w Ay|strong="H1930"\w*! ¡\w Ay|strong="H1930"\w*!’.  
\q2 \w Llamarán|strong="H7121"\w* al labrador al luto,  
\q2 \w y|strong="H3541"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H3045"\w* son expertos en lamentos, \w a|strong="H3068"\w* \w la|strong="H3605"\w* lamentación.   
\q1
\v 17 \w En|strong="H3588"\w* \w todas|strong="H3605"\w* las \w viñas|strong="H3754"\w* habrá \w llanto|strong="H4553"\w*,  
\q2 \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w pasaré|strong="H5674"\w* \w por|strong="H3588"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* ti”, dice Yahvé.   
\q1
\v 18 «¡\w Ay|strong="H1945"\w* de \w los|strong="H1931"\w* \w que|strong="H4100"\w* deseáis \w el|strong="H1931"\w* \w día|strong="H3117"\w* de Yahvé!  
\q2 ¿Para \w qué|strong="H4100"\w* queréis \w el|strong="H1931"\w* \w día|strong="H3117"\w* de Yahvé?  
\q1 \w Será|strong="H1931"\w* de \w tinieblas|strong="H2822"\w*  
\q2 y \w no|strong="H3808"\w* de luz.   
\q1
\v 19 Será \w como|strong="H5921"\w* \w si|strong="H6440"\w* un hombre huyera \w delante|strong="H6440"\w* \w de|strong="H5921"\w* un león  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* encontrara \w con|strong="H5921"\w* un \w oso|strong="H1677"\w*;  
\q1 \w o|strong="H3068"\w* \w como|strong="H5921"\w* \w si|strong="H6440"\w* entrara \w en|strong="H5921"\w* \w casa|strong="H1004"\w*, apoyara su \w mano|strong="H3027"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w pared|strong="H7023"\w*  
\q2 \w y|strong="H5921"\w* \w le|strong="H5921"\w* mordiera una \w serpiente|strong="H5175"\w*.   
\q1
\v 20 ¿\w No|strong="H3808"\w* \w será|strong="H3808"\w* el \w día|strong="H3117"\w* de Yahvé \w oscuridad|strong="H2822"\w* y \w no|strong="H3808"\w* luz?  
\q2 ¿\w No|strong="H3808"\w* \w será|strong="H3808"\w* sombra densa, \w sin|strong="H3808"\w* \w nada|strong="H3808"\w* de \w resplandor|strong="H5051"\w*?   
\q1
\v 21 Detesto y rechazo vuestras fiestas,  
\q2 y \w no|strong="H3808"\w* me agradan vuestras asambleas solemnes.   
\q1
\v 22 \w Aunque|strong="H3588"\w* \w me|strong="H3588"\w* ofrezcáis vuestros \w holocaustos|strong="H5930"\w* \w y|strong="H3588"\w* vuestras ofrendas \w de|strong="H3588"\w* grano,  
\q2 \w no|strong="H3808"\w* \w los|strong="H3588"\w* aceptaré;  
\q2 \w ni|strong="H3808"\w* \w miraré|strong="H5027"\w* las ofrendas \w de|strong="H3588"\w* paz \w de|strong="H3588"\w* vuestros animales cebados.   
\q1
\v 23 Aleja \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w el|strong="H5921"\w* estrépito \w de|strong="H5921"\w* tus cánticos,  
\q2 pues \w no|strong="H3808"\w* \w escucharé|strong="H8085"\w* \w la|strong="H5921"\w* \w música|strong="H7892"\w* \w de|strong="H5921"\w* tus arpas.   
\q1
\v 24 Pero corra el \w derecho|strong="H4941"\w* como el \w agua|strong="H4325"\w*,  
\q2 y la \w justicia|strong="H6666"\w* como un \w torrente|strong="H5158"\w* inagotable.   
\p
\v 25 ¿Me ofrecisteis \w sacrificios|strong="H2077"\w* y ofrendas en \w el|strong="H5066"\w* \w desierto|strong="H4057"\w* durante cuarenta \w años|strong="H8141"\w*, \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*?  
\v 26 Antes bien, llevasteis la tienda de vuestro \w rey|strong="H6213"\w* y \w el|strong="H6213"\w* pedestal de vuestras \w imágenes|strong="H6754"\w*, la \w estrella|strong="H3556"\w* de vuestro dios que os fabricasteis.  
\v 27 Por tanto, os haré ir al cautiverio más \w allá|strong="H1973"\w* de \w Damasco|strong="H1834"\w*», dice Yahvé, cuyo \w nombre|strong="H8034"\w* es \w Dios|strong="H3068"\w* de los \w Ejércitos|strong="H6635"\w*.   
\c 6
\p
\v 1 ¡\w Ay|strong="H1945"\w* de \w los|strong="H1992"\w* \w que|strong="H1992"\w* viven tranquilos en \w Sión|strong="H6726"\w*,  
\q2 y de \w los|strong="H1992"\w* \w que|strong="H1992"\w* \w se|strong="H1992"\w* sienten seguros en \w el|strong="H1992"\w* \w monte|strong="H2022"\w* de \w Samaria|strong="H8111"\w*,  
\q2 \w los|strong="H1992"\w* hombres insignes de la principal de \w las|strong="H1992"\w* \w naciones|strong="H1471"\w*,  
\q2 \w a|strong="H3068"\w* quienes acude la \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*!   
\q1
\v 2 \w Id|strong="H3212"\w* \w a|strong="H3068"\w* Calne y \w mirad|strong="H7200"\w*;  
\q2 y \w de|strong="H4480"\w* \w allí|strong="H8033"\w* \w pasad|strong="H5674"\w* \w a|strong="H3068"\w* Hamat \w la|strong="H1366"\w* \w grande|strong="H7227"\w*;  
\q2 \w descended|strong="H3381"\w* \w luego|strong="H5674"\w* \w a|strong="H3068"\w* Gat \w de|strong="H4480"\w* los \w filisteos|strong="H6430"\w*.  
\q1 ¿Son \w ellos|strong="H4480"\w* \w mejores|strong="H2896"\w* \w que|strong="H4480"\w* estos \w reinos|strong="H4467"\w*?  
\q2 ¿Es su territorio \w mayor|strong="H7227"\w* \w que|strong="H4480"\w* \w el|strong="H5674"\w* vuestro?   
\q1
\v 3 ¡Ay \w de|strong="H7451"\w* vosotros, \w que|strong="H3117"\w* alejáis \w el|strong="H5066"\w* \w día|strong="H3117"\w* funesto,  
\q2 y entronizáis \w el|strong="H5066"\w* estrado \w de|strong="H7451"\w* la \w violencia|strong="H2555"\w*!   
\q2
\v 4 Dormís \w en|strong="H5921"\w* \w camas|strong="H4296"\w* \w de|strong="H5921"\w* \w marfil|strong="H8127"\w*,  
\q2 \w y|strong="H5921"\w* \w os|strong="H5921"\w* repantingáis \w en|strong="H5921"\w* vuestros divanes;  
\q2 coméis \w los|strong="H5921"\w* \w corderos|strong="H6629"\w* \w del|strong="H5921"\w* \w rebaño|strong="H6629"\w*,  
\q2 \w y|strong="H5921"\w* \w los|strong="H5921"\w* terneros sacados \w del|strong="H5921"\w* engordadero.   
\q2
\v 5 Gorjeáis \w al|strong="H5921"\w* \w son|strong="H6310"\w* \w del|strong="H5921"\w* arpa,  
\q2 \w e|strong="H3068"\w* inventáis \w instrumentos|strong="H3627"\w* musicales \w como|strong="H5921"\w* \w David|strong="H1732"\w*;   
\q2
\v 6 \w bebéis|strong="H8354"\w* \w vino|strong="H3196"\w* \w en|strong="H5921"\w* \w cuencos|strong="H4219"\w*,  
\q2 \w y|strong="H5921"\w* \w os|strong="H5921"\w* ungís \w con|strong="H5921"\w* \w los|strong="H5921"\w* mejores perfumes,  
\q2 pero \w no|strong="H3808"\w* \w os|strong="H5921"\w* afligís \w por|strong="H5921"\w* \w la|strong="H5921"\w* ruina \w de|strong="H5921"\w* \w José|strong="H3130"\w*.   
\q1
\v 7 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w ahora|strong="H6258"\w* iréis al cautiverio \w a|strong="H3068"\w* la \w cabeza|strong="H7218"\w* de los desterrados,  
\q2 y \w se|strong="H3651"\w* acabará la disipación de los \w que|strong="H6258"\w* \w se|strong="H3651"\w* entregan al banquete.   
\q1
\v 8 El \w Señor|strong="H3068"\w* Yahvé ha \w jurado|strong="H7650"\w* por \w sí|strong="H5315"\w* mismo, \w dice|strong="H5002"\w* Yahvé, el \w Dios|strong="H3069"\w* de los \w Ejércitos|strong="H6635"\w*:  
\q2 «\w Aborrezco|strong="H8130"\w* la \w soberbia|strong="H1347"\w* de \w Jacob|strong="H3290"\w*,  
\q2 y detesto sus fortalezas;  
\q2 por eso entregaré la \w ciudad|strong="H5892"\w* con todo lo que hay en ella».   
\q1
\v 9 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H1961"\w*, \w si|strong="H1961"\w* \w diez|strong="H6235"\w* hombres quedan en una \w casa|strong="H1004"\w*,  
\q2 \w morirán|strong="H4191"\w*.   
\p
\v 10 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w el|strong="H5973"\w* pariente \w de|strong="H4480"\w* uno \w de|strong="H4480"\w* \w ellos|strong="H4480"\w*, \w el|strong="H5973"\w* \w que|strong="H3588"\w* debe quemar \w los|strong="H5973"\w* cuerpos, venga \w para|strong="H3588"\w* sacar \w los|strong="H5973"\w* cadáveres \w de|strong="H4480"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w*, preguntará \w al|strong="H4480"\w* \w que|strong="H3588"\w* esté \w en|strong="H4480"\w* \w lo|strong="H3808"\w* \w más|strong="H5750"\w* profundo \w de|strong="H4480"\w* \w la|strong="H3588"\w* vivienda: «¿Queda alguien \w más|strong="H5750"\w* \w contigo|strong="H5973"\w*?». \w Y|strong="H3068"\w* \w si|strong="H3588"\w* este responde: «\w Nadie|strong="H3808"\w*», \w el|strong="H5973"\w* \w otro|strong="H5750"\w* dirá: «¡\w Calla|strong="H2013"\w*!», \w pues|strong="H3588"\w* \w no|strong="H3808"\w* debemos mencionar \w el|strong="H5973"\w* \w nombre|strong="H8034"\w* \w de|strong="H4480"\w* Yahvé.   
\b  
\q1
\v 11 \w Porque|strong="H3588"\w*, he \w aquí|strong="H2009"\w*, Yahvé \w ordena|strong="H6680"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w grande|strong="H1419"\w* sea hecha pedazos,  
\q2 \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w pequeña|strong="H6996"\w* quede reducida \w a|strong="H3068"\w* escombros.   
\q1
\v 12 ¿\w Corren|strong="H7323"\w* acaso \w los|strong="H3588"\w* \w caballos|strong="H5483"\w* \w por|strong="H3588"\w* \w los|strong="H3588"\w* peñascos?  
\q2 ¿Se \w ara|strong="H2790"\w* \w en|strong="H3588"\w* ellos \w con|strong="H3588"\w* \w bueyes|strong="H1241"\w*?  
\q1 \w Pues|strong="H3588"\w* habéis convertido \w el|strong="H3588"\w* \w derecho|strong="H4941"\w* \w en|strong="H3588"\w* \w veneno|strong="H7219"\w*,  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w fruto|strong="H6529"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w justicia|strong="H6666"\w* \w en|strong="H3588"\w* ajenjo;   
\q1
\v 13 vosotros, \w que|strong="H3808"\w* os alegráis \w por|strong="H1697"\w* una \w cosa|strong="H1697"\w* \w de|strong="H1697"\w* \w nada|strong="H3808"\w* y decís:  
\q2 «¿\w No|strong="H3808"\w* hemos conquistado poder \w por|strong="H1697"\w* nuestra propia fuerza?».   
\q1
\v 14 «\w Pues|strong="H3588"\w* he \w aquí|strong="H2005"\w*, \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w levantaré|strong="H6965"\w* \w contra|strong="H5921"\w* vosotros una \w nación|strong="H1471"\w*»,  
\q2 \w dice|strong="H5002"\w* Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*;  
\q2 «\w y|strong="H3588"\w* \w os|strong="H5921"\w* oprimirán \w desde|strong="H5704"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* Hamat \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w arroyo|strong="H5158"\w* \w del|strong="H5921"\w* Arabá».   
\c 7
\p
\v 1 \w Así|strong="H3541"\w* \w me|strong="H3541"\w* lo \w mostró|strong="H7200"\w* el Señor Yahvé: he \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* él formaba langostas cuando comenzaba \w a|strong="H3068"\w* brotar la hierba tardía; \w y|strong="H3541"\w* era la hierba tardía después de la siega del \w rey|strong="H4428"\w*.  
\v 2 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w ellas|strong="H1931"\w* \w acabaron|strong="H3615"\w* \w de|strong="H3588"\w* comer \w la|strong="H1931"\w* \w hierba|strong="H6212"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* tierra, \w yo|strong="H3588"\w* dije: «Señor Yahvé, \w perdona|strong="H5545"\w*, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w*. ¿\w Cómo|strong="H3588"\w* podrá \w Jacob|strong="H3290"\w* subsistir? \w Porque|strong="H3588"\w* \w es|strong="H1931"\w* \w pequeño|strong="H6996"\w*».   
\p
\v 3 \w Se|strong="H1961"\w* arrepintió Yahvé \w de|strong="H5921"\w* \w esto|strong="H2063"\w*. «\w No|strong="H3808"\w* \w será|strong="H1961"\w*», dijo Yahvé.   
\p
\v 4 El Señor Yahvé \w me|strong="H3541"\w* \w mostró|strong="H7200"\w* \w así|strong="H3541"\w*: he \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* el Señor Yahvé \w llamaba|strong="H7121"\w* para juzgar con fuego; \w y|strong="H3541"\w* el fuego consumió el \w gran|strong="H7227"\w* \w abismo|strong="H8415"\w* \w y|strong="H3541"\w* devoró la tierra.  
\v 5 \w Entonces|strong="H3588"\w* dije: «Señor Yahvé, detente, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w*. ¿\w Cómo|strong="H3588"\w* podrá \w Jacob|strong="H3290"\w* subsistir? \w Porque|strong="H3588"\w* \w es|strong="H1931"\w* \w pequeño|strong="H6996"\w*».   
\p
\v 6 \w Se|strong="H1961"\w* arrepintió Yahvé \w de|strong="H5921"\w* \w esto|strong="H2063"\w*. «\w Tampoco|strong="H3808"\w* \w esto|strong="H2063"\w* \w será|strong="H1961"\w*», dijo \w el|strong="H1931"\w* \w Señor|strong="H3068"\w* Yahvé.   
\p
\v 7 \w Me|strong="H5921"\w* \w mostró|strong="H7200"\w* también \w esto|strong="H3541"\w*: he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* Señor \w estaba|strong="H5324"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* un \w muro|strong="H2346"\w* hecho \w a|strong="H3068"\w* plomo, \w y|strong="H5921"\w* tenía una plomada \w en|strong="H5921"\w* su \w mano|strong="H3027"\w*.  
\v 8 Yahvé me preguntó: «¿\w Qué|strong="H4100"\w* \w ves|strong="H7200"\w*, \w Amós|strong="H5986"\w*?». \w Y|strong="H3068"\w* respondí: «Una plomada». Entonces \w el|strong="H5674"\w* \w Señor|strong="H3068"\w* dijo: «He \w aquí|strong="H2005"\w*, yo \w pongo|strong="H7760"\w* una plomada \w en|strong="H5750"\w* \w medio|strong="H7130"\w* \w de|strong="H5750"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*; \w no|strong="H3808"\w* \w volveré|strong="H3254"\w* \w a|strong="H3068"\w* perdonarlos \w más|strong="H5750"\w*.  
\v 9 \w Los|strong="H5921"\w* lugares \w altos|strong="H1116"\w* \w de|strong="H5921"\w* Isaac serán \w asolados|strong="H8074"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* santuarios \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* serán \w destruidos|strong="H8074"\w*; \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w levantaré|strong="H6965"\w* \w con|strong="H5921"\w* \w espada|strong="H2719"\w* \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Jeroboam|strong="H3379"\w*».   
\p
\v 10 Entonces Amasías, \w sacerdote|strong="H3548"\w* \w de|strong="H5921"\w* Betel, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w Jeroboam|strong="H3379"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: “\w Amós|strong="H5986"\w* \w ha|strong="H3808"\w* conspirado \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*; \w la|strong="H5921"\w* tierra \w no|strong="H3808"\w* \w puede|strong="H3201"\w* \w sufrir|strong="H3557"\w* \w más|strong="H5921"\w* sus \w palabras|strong="H1697"\w*.  
\v 11 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice \w Amós|strong="H5986"\w*: ‘\w Jeroboam|strong="H3379"\w* \w morirá|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* será llevado cautivo fuera \w de|strong="H5921"\w* \w su|strong="H3588"\w* tierra’”.   
\p
\v 12 \w Y|strong="H3068"\w* Amasías dijo \w a|strong="H3068"\w* \w Amós|strong="H5986"\w*: «\w Vidente|strong="H2374"\w*, \w vete|strong="H3212"\w*, huye \w a|strong="H3068"\w* la tierra de \w Judá|strong="H3063"\w*; come \w allí|strong="H8033"\w* tu \w pan|strong="H3899"\w* y \w profetiza|strong="H5012"\w* \w allá|strong="H8033"\w*,  
\v 13 \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w profetices|strong="H5012"\w* \w más|strong="H5750"\w* \w en|strong="H3588"\w* Betel, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w santuario|strong="H4720"\w* del \w rey|strong="H4428"\w* \w y|strong="H3588"\w* \w casa|strong="H1004"\w* del \w reino|strong="H4467"\w*».   
\p
\v 14 \w Entonces|strong="H3588"\w* \w respondió|strong="H6030"\w* \w Amós|strong="H5986"\w* \w y|strong="H3588"\w* dijo \w a|strong="H3068"\w* Amasías: “\w No|strong="H3808"\w* soy \w profeta|strong="H5030"\w*, \w ni|strong="H3808"\w* soy \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w profeta|strong="H5030"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* soy pastor \w y|strong="H3588"\w* recolector \w de|strong="H3588"\w* higos \w de|strong="H3588"\w* sicómoro.  
\v 15 Pero Yahvé me \w tomó|strong="H3947"\w* \w de|strong="H5971"\w* detrás del \w rebaño|strong="H6629"\w* y me dijo: ‘\w Ve|strong="H3212"\w* y \w profetiza|strong="H5012"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*’.  
\v 16 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w escucha|strong="H8085"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé. Tú \w dices|strong="H1697"\w*: ‘\w No|strong="H3808"\w* \w profetices|strong="H5012"\w* \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w ni|strong="H3808"\w* prediques \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Isaac’.  
\v 17 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé: ‘Tu mujer será prostituida \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, tus \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* tus \w hijas|strong="H1323"\w* \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, tu tierra será repartida \w a|strong="H3068"\w* cordel, \w y|strong="H5921"\w* tú \w morirás|strong="H4191"\w* \w en|strong="H5921"\w* una tierra \w inmunda|strong="H2931"\w*; \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* será llevado cautivo fuera \w de|strong="H5921"\w* su propia tierra’”.   
\c 8
\p
\v 1 \w Así|strong="H3541"\w* \w me|strong="H3541"\w* \w mostró|strong="H7200"\w* el Señor Yahvé: he \w aquí|strong="H2009"\w* un canastillo de fruta de \w verano|strong="H7019"\w*.   
\p
\v 2 \w Y|strong="H3068"\w* dijo: «\w Amós|strong="H5986"\w*, ¿\w qué|strong="H4100"\w* \w ves|strong="H7200"\w*?». \w Y|strong="H3068"\w* respondí: «Un canastillo \w de|strong="H5750"\w* fruta \w de|strong="H5750"\w* \w verano|strong="H7019"\w*». Entonces Yahvé me dijo:  
\q1 «\w El|strong="H5674"\w* \w fin|strong="H7093"\w* \w ha|strong="H3808"\w* llegado \w para|strong="H5971"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*;  
\q2 \w no|strong="H3808"\w* \w volveré|strong="H3254"\w* \w a|strong="H3068"\w* perdonarlos \w más|strong="H5750"\w*.   
\q1
\v 3 \w Los|strong="H3605"\w* cantos del palacio \w se|strong="H1931"\w* tornarán en alaridos en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*», \w dice|strong="H5002"\w* \w el|strong="H1931"\w* Señor Yahvé.  
\q2 “\w Habrá|strong="H3117"\w* \w multitud|strong="H7227"\w* de cadáveres; en \w cualquier|strong="H3605"\w* \w lugar|strong="H4725"\w* \w serán|strong="H1931"\w* arrojados en silencio.   
\q1
\v 4 \w Escuchad|strong="H8085"\w* \w esto|strong="H2063"\w*, \w vosotros|strong="H8085"\w* que pisoteáis al necesitado  
\q2 y queréis arruinar \w a|strong="H3068"\w* los pobres de \w la|strong="H2063"\w* tierra,   
\q2
\v 5 diciendo: ‘¿\w Cuándo|strong="H4970"\w* \w pasará|strong="H5674"\w* la luna nueva para \w que|strong="H4970"\w* vendamos \w el|strong="H5674"\w* grano,  
\q2 y \w el|strong="H5674"\w* \w sábado|strong="H7676"\w* para \w que|strong="H4970"\w* abramos los graneros de \w trigo|strong="H1250"\w*,  
\q2 achicando \w el|strong="H5674"\w* efa, aumentando \w el|strong="H5674"\w* precio  
\q2 y falseando las \w balanzas|strong="H3976"\w* para engañar;   
\q1
\v 6 para comprar \w a|strong="H3068"\w* los \w pobres|strong="H1800"\w* \w por|strong="H5668"\w* \w plata|strong="H3701"\w*  
\q2 y \w a|strong="H3068"\w* los necesitados \w por|strong="H5668"\w* un par de sandalias,  
\q2 y vender hasta el desecho del \w trigo|strong="H1250"\w*?’”.   
\q1
\v 7 Yahvé ha \w jurado|strong="H7650"\w* por \w la|strong="H3605"\w* \w gloria|strong="H3605"\w* \w de|strong="H7911"\w* \w Jacob|strong="H3290"\w*:  
\q2 «Ciertamente, no \w olvidaré|strong="H7911"\w* jamás \w ninguna|strong="H3605"\w* \w de|strong="H7911"\w* sus \w obras|strong="H4639"\w*.   
\q1
\v 8 ¿\w No|strong="H3808"\w* \w se|strong="H5921"\w* conmoverá \w la|strong="H5921"\w* tierra \w por|strong="H5921"\w* \w esto|strong="H2063"\w*,  
\q2 \w y|strong="H5921"\w* llorarán \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w en|strong="H5921"\w* \w ella|strong="H3605"\w* \w habitan|strong="H3427"\w*?  
\q1 \w Subirá|strong="H5927"\w* \w toda|strong="H3605"\w* \w ella|strong="H3605"\w* \w como|strong="H5921"\w* \w el|strong="H5921"\w* Nilo;  
\q2 \w se|strong="H5921"\w* agitará \w y|strong="H5921"\w* bajará \w como|strong="H5921"\w* \w el|strong="H5921"\w* \w río|strong="H2975"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.   
\q1
\v 9 \w Sucederá|strong="H1961"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*», \w dice|strong="H5002"\w* \w el|strong="H1931"\w* Señor Yahvé,  
\q2 «\w que|strong="H1931"\w* haré \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w sol|strong="H8121"\w* \w se|strong="H1961"\w* ponga al mediodía,  
\q2 y cubriré de tinieblas \w la|strong="H1931"\w* tierra en pleno \w día|strong="H3117"\w*.   
\q1
\v 10 Convertiré vuestras fiestas \w en|strong="H5921"\w* luto  
\q2 \w y|strong="H5921"\w* \w todos|strong="H3605"\w* vuestros cantos \w en|strong="H5921"\w* lamentaciones;  
\q1 \w haré|strong="H7760"\w* \w que|strong="H5921"\w* \w todos|strong="H3605"\w* \w os|strong="H5921"\w* vistáis \w de|strong="H5921"\w* cilicio  
\q2 \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* rape \w toda|strong="H3605"\w* \w cabeza|strong="H7218"\w*.  
\q1 \w Lo|strong="H5921"\w* \w haré|strong="H7760"\w* \w como|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* luto \w por|strong="H5921"\w* \w el|strong="H5921"\w* hijo \w único|strong="H3173"\w*,  
\q2 \w y|strong="H5921"\w* su final será \w como|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w amargura|strong="H4751"\w*.   
\q1
\v 11 He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* vienen \w días|strong="H3117"\w*», \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* Yahvé,  
\q2 “\w en|strong="H3588"\w* \w que|strong="H3588"\w* \w enviaré|strong="H7971"\w* \w hambre|strong="H7458"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra;  
\q2 \w no|strong="H3808"\w* \w hambre|strong="H7458"\w* \w de|strong="H3588"\w* \w pan|strong="H3899"\w*, \w ni|strong="H3808"\w* \w sed|strong="H6772"\w* \w de|strong="H3588"\w* \w agua|strong="H4325"\w*,  
\q2 \w sino|strong="H3588"\w* \w de|strong="H3588"\w* \w oír|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé.   
\q1
\v 12 \w E|strong="H3068"\w* irán \w errantes|strong="H5128"\w* \w de|strong="H5704"\w* \w mar|strong="H3220"\w* \w a|strong="H3068"\w* \w mar|strong="H3220"\w*;  
\q2 \w desde|strong="H5704"\w* el \w norte|strong="H6828"\w* \w hasta|strong="H5704"\w* el \w oriente|strong="H4217"\w*  
\q2 correrán \w de|strong="H5704"\w* un lado \w a|strong="H3068"\w* otro \w buscando|strong="H1245"\w* la \w palabra|strong="H1697"\w* \w de|strong="H5704"\w* Yahvé,  
\q2 \w y|strong="H5704"\w* \w no|strong="H3808"\w* la encontrarán.   
\q1
\v 13 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* las \w doncellas|strong="H1330"\w* \w hermosas|strong="H3303"\w*  
\q2 y \w los|strong="H1931"\w* jóvenes \w desmayarán|strong="H5968"\w* de \w sed|strong="H6772"\w*.   
\q1
\v 14 Los \w que|strong="H3808"\w* juran \w por|strong="H1870"\w* \w el|strong="H5307"\w* pecado \w de|strong="H5750"\w* \w Samaria|strong="H8111"\w*,  
\q2 y dicen: ‘¡\w Por|strong="H1870"\w* la \w vida|strong="H2416"\w* \w de|strong="H5750"\w* tu dios, \w Dan|strong="H1835"\w*!’  
\q2 y ‘¡\w Por|strong="H1870"\w* la \w vida|strong="H2416"\w* del \w camino|strong="H1870"\w* \w de|strong="H5750"\w* Beerseba!’,  
\q2 \w caerán|strong="H5307"\w* y \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w se|strong="H3808"\w* levantarán”.   
\c 9
\p
\v 1 \w Vi|strong="H7200"\w* \w al|strong="H5921"\w* Señor \w que|strong="H3808"\w* \w estaba|strong="H5324"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w*, \w y|strong="H5921"\w* dijo: «\w Hiere|strong="H5221"\w* \w los|strong="H5921"\w* capiteles \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* sacudan \w los|strong="H5921"\w* umbrales, \w y|strong="H5921"\w* hazlos pedazos \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w ellos|strong="H5921"\w*. \w Al|strong="H5921"\w* último \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w lo|strong="H3808"\w* \w mataré|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*; \w no|strong="H3808"\w* habrá \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w quien|strong="H3605"\w* huya, \w ni|strong="H3808"\w* uno solo \w escapará|strong="H4422"\w*.  
\v 2 \w Aunque|strong="H8033"\w* caven hasta el Seol, de \w allí|strong="H8033"\w* los \w tomará|strong="H3947"\w* mi \w mano|strong="H3027"\w*; y \w aunque|strong="H8033"\w* suban hasta el \w cielo|strong="H8064"\w*, de \w allí|strong="H8033"\w* los haré descender.  
\v 3 \w Aunque|strong="H8033"\w* se escondan en la \w cumbre|strong="H7218"\w* del Carmelo, \w allí|strong="H8033"\w* los buscaré y los \w tomaré|strong="H3947"\w*; y \w aunque|strong="H8033"\w* se oculten \w de|strong="H5048"\w* mi vista en el fondo del \w mar|strong="H3220"\w*, \w allí|strong="H8033"\w* \w mandaré|strong="H6680"\w* \w a|strong="H3068"\w* la \w serpiente|strong="H5175"\w* y los \w morderá|strong="H5391"\w*.  
\v 4 \w Aunque|strong="H8033"\w* \w vayan|strong="H3212"\w* \w al|strong="H5921"\w* destierro \w delante|strong="H6440"\w* \w de|strong="H5921"\w* sus enemigos, \w allí|strong="H8033"\w* \w mandaré|strong="H6680"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w matará|strong="H2026"\w*. \w Pondré|strong="H7760"\w* mis \w ojos|strong="H5869"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w para|strong="H5921"\w* \w mal|strong="H7451"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w para|strong="H5921"\w* \w bien|strong="H2896"\w*».  
\v 5 \w El|strong="H3605"\w* Señor, Yahvé de \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w*, es \w el|strong="H3605"\w* \w que|strong="H3605"\w* \w toca|strong="H5060"\w* \w la|strong="H3605"\w* tierra y \w ella|strong="H3605"\w* se derrite, y lloran \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H3605"\w* en \w ella|strong="H3605"\w* \w habitan|strong="H3427"\w*; \w sube|strong="H5927"\w* \w toda|strong="H3605"\w* \w ella|strong="H3605"\w* \w como|strong="H5060"\w* \w el|strong="H3605"\w* Nilo, y baja de nuevo \w como|strong="H5060"\w* \w el|strong="H3605"\w* \w río|strong="H2975"\w* de \w Egipto|strong="H4714"\w*.  
\v 6 \w Él|strong="H5921"\w* es quien construye sus altas estancias \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*, \w y|strong="H5921"\w* ha fundado su bóveda \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra; \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w llama|strong="H7121"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w derrama|strong="H8210"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra: Yahvé es su \w nombre|strong="H8034"\w*.  
\v 7 «¿\w No|strong="H3808"\w* sois vosotros para mí, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, como \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* etíopes?», \w dice|strong="H5002"\w* Yahvé. «¿\w No|strong="H3808"\w* hice yo \w subir|strong="H5927"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w de|strong="H1121"\w* Caftor y \w a|strong="H3068"\w* \w los|strong="H1121"\w* sirios \w de|strong="H1121"\w* Kir?  
\v 8 He \w aquí|strong="H2009"\w*, \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w del|strong="H5921"\w* \w Señor|strong="H3068"\w* Yahvé \w están|strong="H2009"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w reino|strong="H4467"\w* pecador, \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w lo|strong="H3808"\w* borraré \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra; \w aunque|strong="H3588"\w* \w no|strong="H3808"\w* \w destruiré|strong="H8045"\w* \w del|strong="H5921"\w* todo \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w*», \w dice|strong="H5002"\w* Yahvé.  
\v 9 “\w Porque|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* daré \w la|strong="H3588"\w* \w orden|strong="H6680"\w* \w y|strong="H3588"\w* cribaré \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w entre|strong="H3808"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w*, \w como|strong="H3588"\w* \w se|strong="H3808"\w* criba \w el|strong="H3588"\w* grano \w en|strong="H3588"\w* \w la|strong="H3588"\w* criba, \w sin|strong="H3808"\w* \w que|strong="H3588"\w* \w caiga|strong="H5307"\w* \w a|strong="H3068"\w* tierra \w ni|strong="H3808"\w* un solo grano.  
\v 10 \w A|strong="H3068"\w* \w espada|strong="H2719"\w* \w morirán|strong="H4191"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pecadores|strong="H2400"\w* \w de|strong="H5704"\w* mi \w pueblo|strong="H5971"\w*, \w que|strong="H3808"\w* dicen: ‘\w No|strong="H3808"\w* \w se|strong="H3808"\w* acercará \w ni|strong="H3808"\w* nos \w alcanzará|strong="H6923"\w* \w el|strong="H3605"\w* \w mal|strong="H7451"\w*’.  
\v 11 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w levantaré|strong="H6965"\w* \w el|strong="H1931"\w* tabernáculo \w caído|strong="H5307"\w* de \w David|strong="H1732"\w*; cerraré \w sus|strong="H1931"\w* brechas, \w levantaré|strong="H6965"\w* \w sus|strong="H1931"\w* ruinas y \w lo|strong="H1931"\w* \w edificaré|strong="H1129"\w* \w como|strong="H1931"\w* en \w los|strong="H1931"\w* \w tiempos|strong="H3117"\w* \w antiguos|strong="H5769"\w*,  
\v 12 \w para|strong="H4616"\w* \w que|strong="H5921"\w* \w posean|strong="H3423"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* queda \w de|strong="H5921"\w* Edom \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* cuales \w es|strong="H2063"\w* \w invocado|strong="H7121"\w* \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w*”, \w dice|strong="H5002"\w* Yahvé, \w que|strong="H5921"\w* \w hace|strong="H6213"\w* \w esto|strong="H2063"\w*.   
\q1
\v 13 «He \w aquí|strong="H2009"\w* \w que|strong="H1869"\w* vienen \w días|strong="H3117"\w*», \w dice|strong="H5002"\w* Yahvé,  
\q2 «en \w que|strong="H1869"\w* \w el|strong="H3605"\w* \w que|strong="H1869"\w* \w ara|strong="H2790"\w* \w alcanzará|strong="H5066"\w* al \w segador|strong="H7114"\w*,  
\q2 y \w el|strong="H3605"\w* \w que|strong="H1869"\w* pisa las \w uvas|strong="H6025"\w* al \w que|strong="H1869"\w* lleva \w la|strong="H3605"\w* semilla;  
\q2 \w los|strong="H3605"\w* \w montes|strong="H2022"\w* \w destilarán|strong="H5197"\w* vino dulce,  
\q2 y \w todas|strong="H3605"\w* las colinas se derretirán.   
\q1
\v 14 Restauraré \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w* \w de|strong="H5971"\w* su cautiverio;  
\q2 reconstruirán las \w ciudades|strong="H5892"\w* \w asoladas|strong="H8074"\w* y las \w habitarán|strong="H3427"\w*;  
\q2 \w plantarán|strong="H5193"\w* \w viñas|strong="H3754"\w* y \w beberán|strong="H8354"\w* su \w vino|strong="H3196"\w*,  
\q1 y \w harán|strong="H6213"\w* \w huertos|strong="H1593"\w*,  
\q2 y comerán sus \w frutos|strong="H6529"\w*.   
\q1
