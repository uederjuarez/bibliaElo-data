\mt1 Amós  
\c 1
\p
\v 1 \w Las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w Amós|strong="H5986"\w*, \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w entre|strong="H5921"\w* \w los|strong="H1121"\w* pastores \w de|strong="H5921"\w* Tecoa, \w las|strong="H5921"\w* cuales recibió \w en|strong="H5921"\w* visión \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Uzías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w dos|strong="H6440"\w* \w años|strong="H8141"\w* \w antes|strong="H6440"\w* \w del|strong="H5921"\w* terremoto.  
\v 2 Dijo:  
\q1 «Yahvé \w rugirá|strong="H7580"\w* desde \w Sión|strong="H6726"\w*,  
\q2 y \w hará|strong="H5414"\w* oír su \w voz|strong="H6963"\w* desde Jerusalén;  
\q1 y los pastos \w de|strong="H5414"\w* los \w pastores|strong="H7462"\w* se enlutarán,  
\q2 y la cima del Carmelo se \w secará|strong="H3001"\w*».   
\p
\v 3 Yahvé dice:  
\q1 «\w Por|strong="H5921"\w* \w tres|strong="H7969"\w* transgresiones \w de|strong="H5921"\w* \w Damasco|strong="H1834"\w*, \w sí|strong="H3808"\w*, \w por|strong="H5921"\w* cuatro,  
\q2 \w no|strong="H3808"\w* revocaré su castigo,  
\q2 \w porque|strong="H5921"\w* han trillado \w Galaad|strong="H1568"\w* \w con|strong="H5921"\w* trillos \w de|strong="H5921"\w* \w hierro|strong="H1270"\w*;   
\q1
\v 4 pero \w enviaré|strong="H7971"\w* fuego \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de \w Hazael|strong="H2371"\w*,  
\q2 y devorará los palacios de Ben Hadad.   
\q1
\v 5 Romperé \w el|strong="H3427"\w* cerrojo \w de|strong="H5971"\w* \w Damasco|strong="H1834"\w*,  
\q2 y exterminaré al \w morador|strong="H3427"\w* del valle \w de|strong="H5971"\w* Avén,  
\q2 y al \w que|strong="H5971"\w* empuña \w el|strong="H3427"\w* \w cetro|strong="H7626"\w* \w de|strong="H5971"\w* la \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Edén;  
\q2 y \w el|strong="H3427"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* Siria irá en destierro \w a|strong="H3068"\w* Kir»,  
\p dice Yahvé.   
\p
\v 6 Yahvé dice:  
\q1 «\w Por|strong="H5921"\w* \w tres|strong="H7969"\w* transgresiones \w de|strong="H5921"\w* \w Gaza|strong="H5804"\w*, \w sí|strong="H3808"\w*, \w por|strong="H5921"\w* cuatro,  
\q2 \w no|strong="H3808"\w* revocaré su castigo,  
\q2 \w porque|strong="H5921"\w* \w se|strong="H5921"\w* llevaron cautiva \w a|strong="H3068"\w* \w toda|strong="H5921"\w* una población,  
\q2 \w para|strong="H5921"\w* entregarlos \w a|strong="H3068"\w* Edom;   
\q1
\v 7 pero \w enviaré|strong="H7971"\w* fuego sobre el \w muro|strong="H2346"\w* de \w Gaza|strong="H5804"\w*,  
\q2 y devorará sus palacios.   
\q1
\v 8 Exterminaré \w al|strong="H5921"\w* \w morador|strong="H3427"\w* \w de|strong="H5921"\w* Asdod,  
\q2 \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w que|strong="H5921"\w* empuña \w el|strong="H5921"\w* \w cetro|strong="H7626"\w* \w de|strong="H5921"\w* Ascalón;  
\q1 \w y|strong="H5921"\w* \w volveré|strong="H7725"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w Ecrón|strong="H6138"\w*;  
\q2 \w y|strong="H5921"\w* \w el|strong="H5921"\w* remanente \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w* \w perecerá|strong="H3772"\w*»,  
\p dice \w el|strong="H5921"\w* Señor Yahvé.   
\p
\v 9 Yahvé dice:  
\q1 «\w Por|strong="H5921"\w* \w tres|strong="H7969"\w* transgresiones \w de|strong="H5921"\w* \w Tiro|strong="H6865"\w*, \w sí|strong="H3808"\w*, \w por|strong="H5921"\w* cuatro,  
\q2 \w no|strong="H3808"\w* revocaré su castigo;  
\q2 \w porque|strong="H5921"\w* \w entregaron|strong="H5462"\w* \w a|strong="H3068"\w* \w toda|strong="H5921"\w* una población \w a|strong="H3068"\w* Edom,  
\q2 \w y|strong="H5921"\w* \w no|strong="H3808"\w* recordaron \w el|strong="H5921"\w* \w pacto|strong="H1285"\w* \w entre|strong="H5921"\w* hermanos;   
\q1
\v 10 pero \w enviaré|strong="H7971"\w* fuego sobre el \w muro|strong="H2346"\w* de \w Tiro|strong="H6865"\w*,  
\q2 y devorará sus palacios».   
\p
\v 11 Yahvé dice:  
\q1 «\w Por|strong="H5921"\w* \w tres|strong="H7969"\w* transgresiones \w de|strong="H5921"\w* Edom, \w sí|strong="H3808"\w*, \w por|strong="H5921"\w* cuatro,  
\q2 \w no|strong="H3808"\w* revocaré su castigo,  
\q2 \w porque|strong="H5921"\w* \w persiguió|strong="H7291"\w* \w a|strong="H3068"\w* su hermano \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*  
\q2 \w y|strong="H5921"\w* sofocó \w toda|strong="H5921"\w* compasión,  
\q2 \w y|strong="H5921"\w* su cólera desgarró incesantemente,  
\q2 \w y|strong="H5921"\w* \w guardó|strong="H8104"\w* su ira \w para|strong="H5921"\w* \w siempre|strong="H5703"\w*;   
\q1
\v 12 pero \w enviaré|strong="H7971"\w* fuego sobre \w Temán|strong="H8487"\w*,  
\q2 y devorará los palacios de \w Bosra|strong="H1224"\w*».   
\p
\v 13 Yahvé dice:  
\q1 «\w Por|strong="H5921"\w* \w tres|strong="H7969"\w* transgresiones \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, \w sí|strong="H3808"\w*, \w por|strong="H5921"\w* cuatro,  
\q2 \w no|strong="H3808"\w* revocaré su castigo,  
\q2 \w porque|strong="H5921"\w* \w abrieron|strong="H1234"\w* \w el|strong="H5921"\w* vientre \w de|strong="H5921"\w* \w las|strong="H5921"\w* encintas \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*,  
\q2 \w para|strong="H4616"\w* poder ampliar sus fronteras.   
\q1
\v 14 Pero yo encenderé fuego en la muralla de Rabá,  
\q2 y devorará sus palacios,  
\q2 con \w gritos|strong="H8643"\w* en el \w día|strong="H3117"\w* de la \w batalla|strong="H4421"\w*,  
\q2 con \w tempestad|strong="H5591"\w* en el \w día|strong="H3117"\w* del \w torbellino|strong="H5492"\w*;   
\q1
\v 15 y \w su|strong="H1931"\w* \w rey|strong="H4428"\w* \w irá|strong="H1980"\w* \w al|strong="H4428"\w* destierro,  
\q2 \w él|strong="H1931"\w* y \w sus|strong="H1931"\w* \w príncipes|strong="H8269"\w* \w juntos|strong="H3162"\w*»,  
\p dice Yahvé.   
\c 2
\p
\v 1 Yahvé dice:  
\q1 «\w Por|strong="H5921"\w* \w tres|strong="H7969"\w* transgresiones \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w sí|strong="H3808"\w*, \w por|strong="H5921"\w* cuatro,  
\q2 \w no|strong="H3808"\w* revocaré su castigo,  
\q2 \w porque|strong="H5921"\w* \w quemó|strong="H8313"\w* \w los|strong="H5921"\w* \w huesos|strong="H6106"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Edom \w hasta|strong="H5921"\w* calcinarlos;   
\q1
\v 2 pero \w enviaré|strong="H7971"\w* fuego sobre \w Moab|strong="H4124"\w*,  
\q2 y devorará los palacios de Queriot;  
\q2 y \w Moab|strong="H4124"\w* \w morirá|strong="H4191"\w* en medio del tumulto, con \w gritos|strong="H8643"\w* y \w sonido|strong="H6963"\w* de \w trompeta|strong="H7782"\w*;   
\q1
\v 3 y exterminaré \w al|strong="H7130"\w* \w juez|strong="H8199"\w* \w de|strong="H5973"\w* \w entre|strong="H7130"\w* \w ellos|strong="H3605"\w*,  
\q2 y \w mataré|strong="H2026"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w príncipes|strong="H8269"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*»,  
\p dice Yahvé.   
\p
\v 4 Yahvé dice:  
\q1 «\w Por|strong="H5921"\w* \w tres|strong="H7969"\w* transgresiones \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w sí|strong="H3808"\w*, \w por|strong="H5921"\w* cuatro,  
\q2 \w no|strong="H3808"\w* revocaré su castigo,  
\q2 \w porque|strong="H5921"\w* han rechazado \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* Yahvé,  
\q2 \w y|strong="H5921"\w* \w no|strong="H3808"\w* han \w guardado|strong="H8104"\w* sus \w estatutos|strong="H2706"\w*,  
\q2 \w y|strong="H5921"\w* sus \w mentiras|strong="H3577"\w* \w los|strong="H5921"\w* han \w extraviado|strong="H8582"\w*,  
\q2 tras \w las|strong="H5921"\w* cuales \w caminaron|strong="H1980"\w* sus padres;   
\q1
\v 5 pero \w enviaré|strong="H7971"\w* fuego sobre \w Judá|strong="H3063"\w*,  
\q2 y devorará los palacios de Jerusalén».   
\p
\v 6 Yahvé dice:  
\q1 «\w Por|strong="H5921"\w* \w tres|strong="H7969"\w* transgresiones \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w sí|strong="H3808"\w*, \w por|strong="H5921"\w* cuatro,  
\q2 \w no|strong="H3808"\w* revocaré su castigo,  
\q2 \w porque|strong="H5921"\w* han vendido \w al|strong="H5921"\w* \w justo|strong="H6662"\w* \w por|strong="H5921"\w* \w plata|strong="H3701"\w*,  
\q2 \w y|strong="H5921"\w* \w al|strong="H5921"\w* necesitado \w por|strong="H5921"\w* un par \w de|strong="H5921"\w* sandalias;   
\q2
\v 7 Pisotean \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* desvalidos \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tierra|strong="H6083"\w*  
\q2 \w y|strong="H5921"\w* tuercen \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* humildes.  
\q1 Un hombre \w y|strong="H5921"\w* su padre \w se|strong="H5921"\w* llegan \w a|strong="H3068"\w* \w la|strong="H5921"\w* misma joven, \w profanando|strong="H2490"\w* \w mi|strong="H5921"\w* \w santo|strong="H6944"\w* \w nombre|strong="H8034"\w*.   
\q2
\v 8 \w Se|strong="H5921"\w* acuestan \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w cada|strong="H3605"\w* \w altar|strong="H4196"\w* \w sobre|strong="H5921"\w* ropas tomadas \w en|strong="H5921"\w* prenda.  
\q2 \w En|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su Dios \w beben|strong="H8354"\w* \w el|strong="H5921"\w* \w vino|strong="H3196"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* han sido multados.   
\q1
\v 9 Sin embargo, yo \w destruí|strong="H8045"\w* \w al|strong="H8478"\w* amorreo \w ante|strong="H6440"\w* \w ellos|strong="H1931"\w*,  
\q2 \w cuya|strong="H1931"\w* \w altura|strong="H1363"\w* \w era|strong="H1931"\w* \w como|strong="H8478"\w* \w la|strong="H1931"\w* \w de|strong="H8478"\w* \w los|strong="H1931"\w* cedros,  
\q2 y \w era|strong="H1931"\w* fuerte \w como|strong="H8478"\w* las encinas;  
\q2 \w destruí|strong="H8045"\w* \w su|strong="H1931"\w* \w fruto|strong="H6529"\w* \w por|strong="H8478"\w* \w arriba|strong="H4605"\w*  
\q2 y \w sus|strong="H1931"\w* \w raíces|strong="H8328"\w* \w por|strong="H8478"\w* \w abajo|strong="H8478"\w*.   
\q1
\v 10 También os \w saqué|strong="H5927"\w* de la tierra de \w Egipto|strong="H4714"\w*  
\q2 y os conduje cuarenta \w años|strong="H8141"\w* por el \w desierto|strong="H4057"\w*,  
\q2 para que poseyerais la tierra de los amorreos.   
\q1
\v 11 Yo levanté \w a|strong="H3068"\w* algunos \w de|strong="H1121"\w* vuestros \w hijos|strong="H1121"\w* como \w profetas|strong="H5030"\w*,  
\q2 y \w a|strong="H3068"\w* algunos \w de|strong="H1121"\w* vuestros jóvenes como nazireos.  
\q1 ¿No \w es|strong="H2063"\w* \w esto|strong="H2063"\w* cierto,  
\q2 \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*?», \w dice|strong="H5002"\w* Yahvé.   
\q1
\v 12 “Pero disteis \w de|strong="H5921"\w* \w beber|strong="H8248"\w* \w vino|strong="H3196"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* nazireos,  
\q2 \w y|strong="H5921"\w* \w mandasteis|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w* diciendo: «\w No|strong="H3808"\w* profetizéis».   
\q1
\v 13 He \w aquí|strong="H2009"\w*, \w yo|strong="H2009"\w* os aplastaré contra el suelo,  
\q2 \w como|strong="H8478"\w* aplasta el \w carro|strong="H5699"\w* cargado \w de|strong="H8478"\w* gavillas.   
\q1
\v 14 El veloz \w no|strong="H3808"\w* hallará escapatoria,  
\q2 el \w fuerte|strong="H2389"\w* \w no|strong="H3808"\w* reafirmará su \w fuerza|strong="H3581"\w*,  
\q2 \w ni|strong="H3808"\w* el \w valiente|strong="H1368"\w* \w librará|strong="H4422"\w* su \w vida|strong="H5315"\w*.   
\q1
\v 15 El \w que|strong="H3808"\w* maneja el \w arco|strong="H7198"\w* \w no|strong="H3808"\w* \w resistirá|strong="H5975"\w*,  
\q2 el ligero de \w pies|strong="H7272"\w* \w no|strong="H3808"\w* \w escapará|strong="H4422"\w*,  
\q2 \w ni|strong="H3808"\w* el \w que|strong="H3808"\w* \w cabalga|strong="H7392"\w* \w se|strong="H3808"\w* \w salvará|strong="H4422"\w*.   
\q1
\v 16 \w El|strong="H1931"\w* más \w valiente|strong="H1368"\w* entre \w los|strong="H1931"\w* guerreros  
\q2 \w huirá|strong="H5127"\w* \w desnudo|strong="H6174"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*”,  
\p \w dice|strong="H5002"\w* Yahvé.   
\c 3
\p
\v 1 \w Escuchad|strong="H8085"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w* \w que|strong="H5921"\w* Yahvé ha pronunciado \w contra|strong="H5921"\w* \w vosotros|strong="H8085"\w*, \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w contra|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w familia|strong="H4940"\w* \w que|strong="H5921"\w* \w saqué|strong="H5927"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*:   
\q1
\v 2 «\w Solo|strong="H7535"\w* \w a|strong="H3068"\w* vosotros \w os|strong="H5921"\w* he elegido \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w familias|strong="H4940"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra;  
\q2 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w os|strong="H5921"\w* pediré cuentas \w por|strong="H5921"\w* \w todas|strong="H3605"\w* vuestras \w iniquidades|strong="H5771"\w*».   
\q1
\v 3 ¿\w Andarán|strong="H3212"\w* \w dos|strong="H8147"\w* \w juntos|strong="H3162"\w* si \w no|strong="H1115"\w* estuvieren de acuerdo?   
\q1
\v 4 ¿\w Rugirá|strong="H7580"\w* el león en la espesura sin tener presa?  
\q2 ¿Lanzará el \w leoncillo|strong="H3715"\w* su \w voz|strong="H6963"\w* desde la guarida si \w no|strong="H1115"\w* ha atrapado nada?   
\q1
\v 5 ¿\w Cae|strong="H5307"\w* \w el|strong="H5921"\w* \w pájaro|strong="H6833"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w lazo|strong="H6341"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra \w sin|strong="H3808"\w* \w que|strong="H4480"\w* haya trampa \w para|strong="H5921"\w* \w él|strong="H5921"\w*?  
\q2 ¿Salta \w la|strong="H5921"\w* trampa \w del|strong="H4480"\w* suelo \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* apresado \w algo|strong="H3920"\w*?   
\q1
\v 6 ¿\w Se|strong="H1961"\w* toca la \w trompeta|strong="H7782"\w* en la \w ciudad|strong="H5892"\w* \w sin|strong="H3808"\w* \w que|strong="H3808"\w* \w el|strong="H6213"\w* \w pueblo|strong="H5971"\w* \w se|strong="H1961"\w* alarme?  
\q2 ¿\w Sucederá|strong="H1961"\w* una desgracia en la \w ciudad|strong="H5892"\w* \w sin|strong="H3808"\w* \w que|strong="H3808"\w* Yahvé la \w haya|strong="H1961"\w* causado?   
\q1
\v 7 \w Ciertamente|strong="H3588"\w*, \w el|strong="H3588"\w* Señor Yahvé \w no|strong="H3808"\w* \w hace|strong="H6213"\w* \w nada|strong="H3808"\w*  
\q2 \w sin|strong="H3808"\w* revelar \w su|strong="H3588"\w* secreto \w a|strong="H3068"\w* sus \w siervos|strong="H5650"\w* \w los|strong="H3588"\w* \w profetas|strong="H5030"\w*.   
\q1
\v 8 \w El|strong="H4310"\w* león \w ha|strong="H3808"\w* rugido, ¿\w quién|strong="H4310"\w* \w no|strong="H3808"\w* \w temerá|strong="H3372"\w*?  
\q2 \w El|strong="H4310"\w* Señor Yahvé \w ha|strong="H3808"\w* \w hablado|strong="H1696"\w*, ¿\w quién|strong="H4310"\w* \w podrá|strong="H3808"\w* \w sino|strong="H3808"\w* profetizar?   
\q1
\v 9 Proclamad \w en|strong="H5921"\w* \w los|strong="H5921"\w* palacios \w de|strong="H5921"\w* Asdod \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* palacios \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*,  
\q2 \w y|strong="H5921"\w* decid: «Reuníos \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w* \w de|strong="H5921"\w* \w Samaria|strong="H8111"\w*,  
