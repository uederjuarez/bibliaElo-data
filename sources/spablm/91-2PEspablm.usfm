\v 1 \w Simón|strong="G4826"\w* \w Pedro|strong="G4074"\w*, \w siervo|strong="G1401"\w* \w y|strong="G2532"\w* apóstol \w de|strong="G1722"\w* \w Jesucristo|strong="G2424"\w*, \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* han alcanzado \w una|strong="G3588"\w* \w fe|strong="G4102"\w* tan preciosa \w como|strong="G2532"\w* \w la|strong="G3588"\w* \w nuestra|strong="G3588"\w* \w por|strong="G1722"\w* \w la|strong="G3588"\w* \w justicia|strong="G1343"\w* \w de|strong="G1722"\w* \w nuestro|strong="G2249"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w Salvador|strong="G4990"\w* \w Jesucristo|strong="G2424"\w*:  
\v 2 \w Gracia|strong="G5485"\w* \w y|strong="G2532"\w* \w paz|strong="G1515"\w* \w os|strong="G5210"\w* sean multiplicadas \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w conocimiento|strong="G1922"\w* \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w de|strong="G1722"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w*.  
\v 3 \w Como|strong="G5613"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* cosas \w que|strong="G3588"\w* pertenecen \w a|strong="G4314"\w* \w la|strong="G3588"\w* \w vida|strong="G2222"\w* \w y|strong="G2532"\w* \w a|strong="G4314"\w* \w la|strong="G3588"\w* \w piedad|strong="G2150"\w* nos han sido dadas \w por|strong="G1223"\w* \w su|strong="G3588"\w* divino \w poder|strong="G1411"\w*, mediante \w el|strong="G3588"\w* \w conocimiento|strong="G1922"\w* \w de|strong="G1223"\w* \w aquel|strong="G3588"\w* \w que|strong="G3588"\w* nos \w llamó|strong="G2564"\w* \w por|strong="G1223"\w* \w su|strong="G3588"\w* \w gloria|strong="G1391"\w* \w y|strong="G2532"\w* excelencia,  
\v 4 \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1722"\w* \w las|strong="G3588"\w* \w cuales|strong="G3739"\w* nos ha dado \w preciosas|strong="G5093"\w* \w y|strong="G2532"\w* \w grandísimas|strong="G3176"\w* \w promesas|strong="G1862"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w por|strong="G1223"\w* \w ellas|strong="G3588"\w* llegaseis \w a|strong="G1722"\w* \w ser|strong="G1096"\w* \w partícipes|strong="G2844"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w naturaleza|strong="G5449"\w* \w divina|strong="G2304"\w*, \w habiendo|strong="G1096"\w* huido \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w corrupción|strong="G5356"\w* \w que|strong="G3588"\w* \w hay|strong="G3588"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w mundo|strong="G2889"\w* \w a|strong="G1722"\w* \w causa|strong="G1223"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w concupiscencia|strong="G1939"\w*;  
\v 5 \w vosotros|strong="G5210"\w* \w también|strong="G2532"\w*, \w poniendo|strong="G3923"\w* \w toda|strong="G3956"\w* \w diligencia|strong="G4710"\w* \w por|strong="G1722"\w* \w esto|strong="G3778"\w* mismo, añadid \w a|strong="G1722"\w* \w vuestra|strong="G4771"\w* \w fe|strong="G4102"\w* virtud; \w a|strong="G1722"\w* \w la|strong="G3588"\w* virtud, \w conocimiento|strong="G1108"\w*;  
\v 6 \w al|strong="G3588"\w* \w conocimiento|strong="G1108"\w*, dominio propio; \w al|strong="G3588"\w* dominio propio, \w paciencia|strong="G5281"\w*; \w a|strong="G1722"\w* \w la|strong="G3588"\w* \w paciencia|strong="G5281"\w*, \w piedad|strong="G2150"\w*;  
\v 7 \w a|strong="G1722"\w* \w la|strong="G3588"\w* \w piedad|strong="G2150"\w*, afecto fraternal; \w y|strong="G1161"\w* \w al|strong="G3588"\w* afecto fraternal, amor.  
\v 8 \w Porque|strong="G1063"\w* \w si|strong="G2532"\w* \w estas|strong="G3778"\w* cosas \w están|strong="G5225"\w* \w en|strong="G1519"\w* \w vosotros|strong="G5210"\w*, \w y|strong="G2532"\w* \w abundan|strong="G4121"\w*, \w no|strong="G3756"\w* \w os|strong="G5210"\w* dejarán estar ociosos \w ni|strong="G3761"\w* \w sin|strong="G3756"\w* fruto \w en|strong="G1519"\w* \w cuanto|strong="G3588"\w* \w al|strong="G3588"\w* \w conocimiento|strong="G1922"\w* \w de|strong="G1519"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*.  
\v 9 \w Pero|strong="G1063"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* carece \w de|strong="G3588"\w* \w estas|strong="G3778"\w* \w cosas|strong="G3739"\w* \w está|strong="G3778"\w* \w ciego|strong="G5185"\w*, teniendo \w la|strong="G3588"\w* vista muy corta, \w habiendo|strong="G2983"\w* \w olvidado|strong="G3024"\w* \w la|strong="G3588"\w* \w purificación|strong="G2512"\w* \w de|strong="G3588"\w* \w sus|strong="G3588"\w* \w antiguos|strong="G3819"\w* pecados.  
\v 10 \w Por|strong="G1063"\w* \w lo|strong="G3588"\w* \w cual|strong="G3588"\w*, hermanos, tanto \w más|strong="G2532"\w* \w procurad|strong="G4704"\w* \w hacer|strong="G4160"\w* firme \w vuestra|strong="G4771"\w* \w vocación|strong="G2821"\w* \w y|strong="G2532"\w* \w elección|strong="G1589"\w*; \w porque|strong="G1063"\w* \w haciendo|strong="G4160"\w* \w estas|strong="G3778"\w* cosas, \w no|strong="G3756"\w* \w caeréis|strong="G4417"\w* \w jamás|strong="G3588"\w*.  
\v 11 \w Porque|strong="G1063"\w* \w de|strong="G1519"\w* \w esta|strong="G3588"\w* \w manera|strong="G3779"\w* \w os|strong="G5210"\w* será otorgada amplia \w y|strong="G2532"\w* generosa \w entrada|strong="G1529"\w* \w en|strong="G1519"\w* \w el|strong="G3588"\w* reino eterno \w de|strong="G1519"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w y|strong="G2532"\w* \w Salvador|strong="G4990"\w* \w Jesucristo|strong="G2424"\w*.   
\p
\v 12 \w Por|strong="G1722"\w* \w esto|strong="G3778"\w*, yo \w no|strong="G4771"\w* dejaré \w de|strong="G4012"\w* recordaros \w siempre|strong="G3588"\w* \w estas|strong="G3778"\w* cosas, \w aunque|strong="G2532"\w* \w vosotros|strong="G5210"\w* \w las|strong="G3588"\w* \w sepáis|strong="G1492"\w*, \w y|strong="G2532"\w* estéis confirmados \w en|strong="G1722"\w* \w la|strong="G3588"\w* verdad \w presente|strong="G3918"\w*.  
\v 13 \w Pues|strong="G1161"\w* \w tengo|strong="G2233"\w* \w por|strong="G1722"\w* \w justo|strong="G1342"\w*, \w en|strong="G1722"\w* \w tanto|strong="G3745"\w* \w que|strong="G3588"\w* \w estoy|strong="G1510"\w* \w en|strong="G1722"\w* \w este|strong="G3778"\w* \w tabernáculo|strong="G4638"\w*, \w el|strong="G3588"\w* despertaros \w con|strong="G1722"\w* \w amonestación|strong="G5280"\w*;  
\v 14 \w sabiendo|strong="G1492"\w* \w que|strong="G3754"\w* \w en|strong="G3588"\w* breve debo abandonar \w mi|strong="G3588"\w* \w tabernáculo|strong="G4638"\w*, \w como|strong="G2531"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w* \w me|strong="G1473"\w* ha declarado.  
\v 15 \w También|strong="G2532"\w* yo procuraré \w con|strong="G3326"\w* diligencia \w que|strong="G3588"\w* \w después|strong="G3326"\w* \w de|strong="G3588"\w* \w mi|strong="G1699"\w* \w partida|strong="G1841"\w* \w vosotros|strong="G5210"\w* \w podáis|strong="G2192"\w* \w en|strong="G3588"\w* todo momento \w tener|strong="G2192"\w* \w memoria|strong="G3420"\w* \w de|strong="G3588"\w* \w estas|strong="G3778"\w* cosas.   
\p
\v 16 \w Porque|strong="G1063"\w* \w no|strong="G3756"\w* \w os|strong="G5210"\w* hemos dado a conocer \w el|strong="G3588"\w* \w poder|strong="G1411"\w* \w y|strong="G2532"\w* \w la|strong="G3588"\w* \w venida|strong="G3952"\w* \w de|strong="G3588"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w* \w siguiendo|strong="G1811"\w* \w fábulas|strong="G3454"\w* artificiosas, sino \w como|strong="G2532"\w* \w habiendo|strong="G1096"\w* visto \w con|strong="G2532"\w* nuestros propios ojos \w su|strong="G3588"\w* \w majestad|strong="G3168"\w*.  
\v 17 \w Pues|strong="G1063"\w* cuando \w él|strong="G3588"\w* \w recibió|strong="G2983"\w* \w de|strong="G3844"\w* \w Dios|strong="G2316"\w* \w Padre|strong="G3962"\w* \w honra|strong="G5092"\w* \w y|strong="G2532"\w* \w gloria|strong="G1391"\w*, \w le|strong="G1519"\w* fue \w enviada|strong="G5342"\w* desde \w la|strong="G3588"\w* \w magnífica|strong="G3169"\w* \w gloria|strong="G1391"\w* \w una|strong="G3588"\w* \w voz|strong="G5456"\w* \w que|strong="G3588"\w* decía: «\w Este|strong="G3778"\w* \w es|strong="G3739"\w* \w mi|strong="G3588"\w* \w Hijo|strong="G5207"\w* amado, \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w cual|strong="G3739"\w* tengo complacencia».  
\v 18 \w Y|strong="G2532"\w* \w nosotros|strong="G2249"\w* oímos \w esta|strong="G3778"\w* \w voz|strong="G5456"\w* \w enviada|strong="G5342"\w* \w del|strong="G3588"\w* \w cielo|strong="G3772"\w*, \w cuando|strong="G1722"\w* \w estábamos|strong="G1510"\w* \w con|strong="G1722"\w* \w él|strong="G3588"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w monte|strong="G3735"\w* santo.   
\p
\v 19 \w Tenemos|strong="G2192"\w* \w también|strong="G2532"\w* \w la|strong="G3588"\w* \w palabra|strong="G3056"\w* \w profética|strong="G4397"\w* \w más|strong="G2532"\w* segura, \w a|strong="G1722"\w* \w la|strong="G3588"\w* \w cual|strong="G3739"\w* \w hacéis|strong="G4160"\w* \w bien|strong="G2573"\w* \w en|strong="G1722"\w* estar atentos \w como|strong="G5613"\w* \w a|strong="G1722"\w* \w una|strong="G3588"\w* \w antorcha|strong="G3088"\w* \w que|strong="G3588"\w* \w alumbra|strong="G5316"\w* \w en|strong="G1722"\w* \w lugar|strong="G5117"\w* oscuro, \w hasta|strong="G2193"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* \w día|strong="G2250"\w* \w esclarezca|strong="G1306"\w* \w y|strong="G2532"\w* \w el|strong="G3588"\w* lucero \w de|strong="G1722"\w* \w la|strong="G3588"\w* mañana salga \w en|strong="G1722"\w* \w vuestros|strong="G5210"\w* \w corazones|strong="G2588"\w*;  
\v 20 \w entendiendo|strong="G1097"\w* \w primero|strong="G4413"\w* \w esto|strong="G3778"\w*, \w que|strong="G3754"\w* \w ninguna|strong="G3756"\w* \w profecía|strong="G4394"\w* \w de|strong="G3754"\w* la \w Escritura|strong="G1124"\w* \w es|strong="G1096"\w* \w de|strong="G3754"\w* \w interpretación|strong="G1955"\w* privada,  
\v 21 \w porque|strong="G1063"\w* \w nunca|strong="G3756"\w* la \w profecía|strong="G4394"\w* fue \w traída|strong="G5342"\w* \w por|strong="G5259"\w* \w voluntad|strong="G2307"\w* humana, sino \w que|strong="G1063"\w* los santos hombres \w de|strong="G5259"\w* \w Dios|strong="G2316"\w* \w hablaron|strong="G2980"\w* siendo inspirados \w por|strong="G5259"\w* el \w Espíritu|strong="G4151"\w* Santo.   
\c 2
\p
\v 1 \w Pero|strong="G1161"\w* \w hubo|strong="G1096"\w* \w también|strong="G2532"\w* falsos profetas \w entre|strong="G1722"\w* \w el|strong="G3588"\w* \w pueblo|strong="G2992"\w*, \w como|strong="G5613"\w* \w habrá|strong="G1096"\w* \w entre|strong="G1722"\w* \w vosotros|strong="G5210"\w* falsos maestros, \w que|strong="G3588"\w* \w introducirán|strong="G3919"\w* encubiertamente herejías destructoras, \w y|strong="G2532"\w* \w aun|strong="G2532"\w* negarán \w al|strong="G3588"\w* \w Señor|strong="G1203"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* rescató, \w atrayendo|strong="G1863"\w* \w sobre|strong="G1722"\w* \w sí|strong="G1438"\w* mismos destrucción repentina.  
\v 2 \w Y|strong="G2532"\w* \w muchos|strong="G4183"\w* \w seguirán|strong="G1811"\w* \w sus|strong="G3588"\w* disoluciones, \w por|strong="G1223"\w* \w causa|strong="G1223"\w* \w de|strong="G1223"\w* \w los|strong="G3588"\w* \w cuales|strong="G3739"\w* \w el|strong="G3588"\w* \w camino|strong="G3598"\w* \w de|strong="G1223"\w* \w la|strong="G3588"\w* verdad será blasfemado,  
\v 3 \w y|strong="G2532"\w* \w por|strong="G1722"\w* \w avaricia|strong="G4124"\w* harán mercadería \w de|strong="G1722"\w* \w vosotros|strong="G5210"\w* \w con|strong="G1722"\w* \w palabras|strong="G3056"\w* \w fingidas|strong="G4112"\w*. \w Sobre|strong="G1722"\w* \w los|strong="G3588"\w* tales \w ya|strong="G2532"\w* \w de|strong="G1722"\w* largo tiempo \w la|strong="G3588"\w* \w condenación|strong="G2917"\w* \w no|strong="G3756"\w* \w se|strong="G2532"\w* tarda, \w y|strong="G2532"\w* \w su|strong="G3588"\w* perdición \w no|strong="G3756"\w* \w se|strong="G2532"\w* duerme.   
\p
\v 4 \w Porque|strong="G1063"\w* \w si|strong="G1487"\w* \w Dios|strong="G2316"\w* \w no|strong="G3756"\w* \w perdonó|strong="G5339"\w* \w a|strong="G1519"\w* \w los|strong="G3588"\w* ángeles \w que|strong="G3588"\w* pecaron, \w sino|strong="G1487"\w* \w que|strong="G3588"\w* arrojándolos \w al|strong="G3588"\w* Tártaro \w los|strong="G3588"\w* \w entregó|strong="G3860"\w* \w a|strong="G1519"\w* prisiones \w de|strong="G1519"\w* \w oscuridad|strong="G2217"\w*, \w para|strong="G1519"\w* ser reservados \w al|strong="G3588"\w* \w juicio|strong="G2920"\w*;  
\v 5 \w y|strong="G2532"\w* \w si|strong="G2532"\w* \w no|strong="G3756"\w* \w perdonó|strong="G5339"\w* al \w mundo|strong="G2889"\w* antiguo, sino \w que|strong="G2532"\w* \w guardó|strong="G5442"\w* a \w Noé|strong="G3575"\w*, \w pregonero|strong="G2783"\w* de \w justicia|strong="G1343"\w*, \w con|strong="G2532"\w* otras siete personas, \w trayendo|strong="G1863"\w* el \w diluvio|strong="G2627"\w* sobre el \w mundo|strong="G2889"\w* de \w los|strong="G2532"\w* impíos;  
\v 6 \w y|strong="G2532"\w* \w si|strong="G2532"\w* \w condenó|strong="G2632"\w* por destrucción a las \w ciudades|strong="G4172"\w* de \w Sodoma|strong="G4670"\w* \w y|strong="G2532"\w* de \w Gomorra|strong="G1116"\w*, reduciéndolas a ceniza \w y|strong="G2532"\w* poniéndolas de \w ejemplo|strong="G5262"\w* a \w los|strong="G2532"\w* \w que|strong="G2532"\w* \w habían|strong="G3195"\w* de vivir impíamente,  
\v 7 \w y|strong="G2532"\w* \w libró|strong="G4506"\w* \w al|strong="G3588"\w* \w justo|strong="G1342"\w* \w Lot|strong="G3091"\w*, abrumado \w por|strong="G1722"\w* \w la|strong="G3588"\w* \w nefanda|strong="G1722"\w* conducta \w de|strong="G1722"\w* \w los|strong="G3588"\w* malvados  
\v 8 (\w porque|strong="G1063"\w* \w este|strong="G3588"\w* \w justo|strong="G1342"\w*, \w que|strong="G3588"\w* moraba \w entre|strong="G1722"\w* \w ellos|strong="G3588"\w*, afligía \w cada|strong="G1722"\w* \w día|strong="G2250"\w* \w su|strong="G3588"\w* \w alma|strong="G5590"\w* \w justa|strong="G1342"\w*, viendo \w y|strong="G2532"\w* \w oyendo|strong="G1722"\w* \w los|strong="G3588"\w* \w hechos|strong="G2041"\w* inicuos \w de|strong="G1537"\w* \w ellos|strong="G3588"\w*),  
\v 9 \w el|strong="G1161"\w* \w Señor|strong="G2962"\w* \w sabe|strong="G1492"\w* \w librar|strong="G4506"\w* \w de|strong="G1537"\w* \w tentación|strong="G3986"\w* \w a|strong="G1519"\w* los piadosos, \w y|strong="G1161"\w* \w reservar|strong="G5083"\w* \w a|strong="G1519"\w* los injustos \w para|strong="G1519"\w* ser castigados \w en|strong="G1519"\w* \w el|strong="G1161"\w* \w día|strong="G2250"\w* \w del|strong="G1537"\w* \w juicio|strong="G2920"\w*;  
\v 10 \w y|strong="G2532"\w* \w mayormente|strong="G3122"\w* \w a|strong="G1722"\w* \w aquellos|strong="G3588"\w* \w que|strong="G3588"\w*, \w siguiendo|strong="G3694"\w* \w la|strong="G3588"\w* \w carne|strong="G4561"\w*, \w andan|strong="G4198"\w* \w en|strong="G1722"\w* \w deseos|strong="G1939"\w* inmundos, \w y|strong="G2532"\w* \w desprecian|strong="G2706"\w* \w el|strong="G3588"\w* \w señorío|strong="G2963"\w*. \w Atrevidos|strong="G5113"\w* \w y|strong="G2532"\w* contumaces, \w no|strong="G3756"\w* \w temen|strong="G5141"\w* decir mal \w de|strong="G1722"\w* \w las|strong="G3588"\w* potestades superiores,  
\v 11 mientras \w que|strong="G3844"\w* \w los|strong="G2532"\w* ángeles, \w que|strong="G3844"\w* \w son|strong="G1510"\w* \w mayores|strong="G3173"\w* \w en|strong="G2596"\w* \w fuerza|strong="G1411"\w* \w y|strong="G2532"\w* \w en|strong="G2596"\w* \w potencia|strong="G1411"\w*, \w no|strong="G3756"\w* \w pronuncian|strong="G5342"\w* \w juicio|strong="G2920"\w* \w de|strong="G3844"\w* maldición \w contra|strong="G2596"\w* ellas \w delante|strong="G3844"\w* \w del|strong="G3844"\w* \w Señor|strong="G2962"\w*.  
\v 12 \w Pero|strong="G1161"\w* \w estos|strong="G3778"\w*, hablando mal \w de|strong="G1722"\w* \w cosas|strong="G3739"\w* \w que|strong="G3588"\w* no entienden, \w como|strong="G5613"\w* \w animales|strong="G2226"\w* irracionales, nacidos \w para|strong="G1519"\w* presa \w y|strong="G2532"\w* \w destrucción|strong="G5356"\w*, perecerán \w en|strong="G1722"\w* \w su|strong="G3588"\w* propia \w perdición|strong="G5356"\w*,  
