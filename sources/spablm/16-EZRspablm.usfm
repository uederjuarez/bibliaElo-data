\c 9
\p
\v 1 Acabadas estas cosas, los \w príncipes|strong="H8269"\w* \w se|strong="H3808"\w* me acercaron, diciendo: «\w El|strong="H5066"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*, los \w sacerdotes|strong="H3548"\w* y los \w levitas|strong="H3881"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* han separado \w de|strong="H5971"\w* los \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* estas tierras, y siguen sus \w abominaciones|strong="H8441"\w*, las \w de|strong="H5971"\w* los \w cananeos|strong="H3669"\w*, hititas, ferezeos, \w jebuseos|strong="H2983"\w*, amonitas, moabitas, \w egipcios|strong="H4713"\w* y amorreos.  
\v 2 \w Porque|strong="H3588"\w* han tomado \w de|strong="H3588"\w* \w sus|strong="H1992"\w* \w hijas|strong="H1323"\w* \w para|strong="H3588"\w* \w sí|strong="H3588"\w* \w y|strong="H3588"\w* \w para|strong="H3588"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w*, \w de|strong="H3588"\w* modo \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w linaje|strong="H2233"\w* \w santo|strong="H6944"\w* \w se|strong="H1961"\w* ha mezclado \w con|strong="H3588"\w* \w los|strong="H1992"\w* \w pueblos|strong="H5971"\w* \w de|strong="H3588"\w* \w las|strong="H1992"\w* tierras; \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w príncipes|strong="H8269"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* gobernantes ha \w sido|strong="H1961"\w* \w la|strong="H3588"\w* \w primera|strong="H7223"\w* \w en|strong="H3588"\w* \w esta|strong="H2088"\w* \w prevaricación|strong="H4604"\w*».   
\p
\v 3 Cuando \w oí|strong="H8085"\w* \w esto|strong="H2088"\w*, \w rasgué|strong="H7167"\w* mi vestido y mi \w manto|strong="H4598"\w*, me arranqué pelos \w de|strong="H1697"\w* mi \w cabeza|strong="H7218"\w* y \w de|strong="H1697"\w* mi \w barba|strong="H2206"\w*, y me senté \w atónito|strong="H8074"\w*.  
\v 4 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* reunieron conmigo \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H5921"\w* temblaban ante \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w del|strong="H5921"\w* Dios \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w transgresión|strong="H4604"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w del|strong="H5921"\w* \w cautiverio|strong="H1473"\w*; \w mas|strong="H5921"\w* yo \w estuve|strong="H3427"\w* \w sentado|strong="H3427"\w* \w atónito|strong="H8074"\w* \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tarde|strong="H6153"\w*.   
\p
\v 5 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* hora \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tarde|strong="H6153"\w* \w me|strong="H5921"\w* levanté \w de|strong="H5921"\w* \w mi|strong="H5921"\w* aflicción, \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w mi|strong="H5921"\w* vestido \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w manto|strong="H4598"\w* \w rasgados|strong="H7167"\w*, \w me|strong="H5921"\w* puse \w de|strong="H5921"\w* \w rodillas|strong="H1290"\w* \w y|strong="H5921"\w* \w extendí|strong="H6566"\w* mis \w manos|strong="H3709"\w* \w a|strong="H3068"\w* Yahvé \w mi|strong="H5921"\w* \w Dios|strong="H3068"\w*,  
\v 6 \w y|strong="H3588"\w* dije: “Dios mío, \w confuso|strong="H3637"\w* \w y|strong="H3588"\w* \w avergonzado|strong="H3637"\w* estoy \w para|strong="H5704"\w* levantar, oh Dios mío, \w mi|strong="H1431"\w* \w rostro|strong="H6440"\w* \w a|strong="H3068"\w* ti, \w porque|strong="H3588"\w* nuestras \w iniquidades|strong="H5771"\w* se han multiplicado \w sobre|strong="H4605"\w* nuestra \w cabeza|strong="H7218"\w*, \w y|strong="H3588"\w* nuestros delitos han \w crecido|strong="H1431"\w* \w hasta|strong="H5704"\w* \w los|strong="H3588"\w* \w cielos|strong="H8064"\w*.  
\v 7 \w Desde|strong="H5704"\w* los \w días|strong="H3117"\w* \w de|strong="H6440"\w* nuestros padres \w hasta|strong="H5704"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w* hemos vivido \w en|strong="H5704"\w* \w gran|strong="H1419"\w* \w pecado|strong="H5771"\w*; \w y|strong="H5704"\w* \w por|strong="H6440"\w* nuestras \w iniquidades|strong="H5771"\w* nosotros, nuestros \w reyes|strong="H4428"\w* \w y|strong="H5704"\w* nuestros \w sacerdotes|strong="H3548"\w* hemos sido entregados \w en|strong="H5704"\w* \w manos|strong="H3027"\w* \w de|strong="H6440"\w* los \w reyes|strong="H4428"\w* \w de|strong="H6440"\w* las tierras, \w a|strong="H3068"\w* la \w espada|strong="H2719"\w*, \w al|strong="H5704"\w* \w cautiverio|strong="H7628"\w*, \w al|strong="H5704"\w* robo \w y|strong="H5704"\w* \w a|strong="H3068"\w* la \w confusión|strong="H1322"\w* \w de|strong="H6440"\w* \w rostro|strong="H6440"\w*, \w como|strong="H5704"\w* sucede \w en|strong="H5704"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w*.  
\v 8 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, \w por|strong="H5414"\w* un breve \w momento|strong="H7281"\w*, ha venido la gracia \w de|strong="H5414"\w* \w parte|strong="H4725"\w* \w de|strong="H5414"\w* Yahvé nuestro \w Dios|strong="H3068"\w*, \w para|strong="H5414"\w* dejarnos un resto \w que|strong="H6258"\w* escape y \w para|strong="H5414"\w* darnos una estaca en su \w lugar|strong="H4725"\w* \w santo|strong="H6944"\w*, \w a|strong="H3068"\w* fin \w de|strong="H5414"\w* \w que|strong="H6258"\w* nuestro \w Dios|strong="H3068"\w* alumbre nuestros \w ojos|strong="H5869"\w* y nos \w dé|strong="H5414"\w* un \w poco|strong="H4592"\w* \w de|strong="H5414"\w* \w vida|strong="H4241"\w* en nuestra \w servidumbre|strong="H5659"\w*.  
\v 9 \w Porque|strong="H3588"\w* \w siervos|strong="H5650"\w* somos; \w mas|strong="H3588"\w* \w en|strong="H5921"\w* nuestra \w servidumbre|strong="H5659"\w* \w no|strong="H3808"\w* \w nos|strong="H5921"\w* \w ha|strong="H3808"\w* \w desamparado|strong="H5800"\w* nuestro Dios, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w extendió|strong="H5186"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w su|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*, \w para|strong="H5921"\w* darnos \w vida|strong="H4241"\w* \w para|strong="H5921"\w* levantar \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* nuestro Dios \w y|strong="H3588"\w* restaurar sus ruinas, \w y|strong="H3588"\w* \w para|strong="H5921"\w* darnos un muro \w en|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* Jerusalén.   
\p
\v 10 \w Pero|strong="H3588"\w* \w ahora|strong="H6258"\w*, ¿\w qué|strong="H3588"\w* diremos, Dios nuestro, después \w de|strong="H3588"\w* \w esto|strong="H2063"\w*? \w Porque|strong="H3588"\w* hemos abandonado tus \w mandamientos|strong="H4687"\w*,  
\v 11 \w que|strong="H1931"\w* prescribiste \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H5971"\w* tus \w siervos|strong="H5650"\w* \w los|strong="H1931"\w* \w profetas|strong="H5030"\w*, diciendo: «\w La|strong="H1931"\w* tierra \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w cual|strong="H1931"\w* vais \w para|strong="H5971"\w* poseerla \w es|strong="H1931"\w* tierra \w inmunda|strong="H2932"\w* \w a|strong="H3068"\w* causa \w de|strong="H5971"\w* \w la|strong="H1931"\w* \w inmundicia|strong="H2932"\w* \w de|strong="H5971"\w* \w los|strong="H1931"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* las tierras, \w por|strong="H3027"\w* las \w abominaciones|strong="H8441"\w* con \w que|strong="H1931"\w* \w la|strong="H1931"\w* han llenado \w de|strong="H5971"\w* un extremo \w a|strong="H3068"\w* otro con \w su|strong="H1931"\w* impureza.  
\v 12 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w no|strong="H3808"\w* deis vuestras \w hijas|strong="H1323"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* ellos, \w ni|strong="H3808"\w* toméis sus \w hijas|strong="H1323"\w* \w para|strong="H5704"\w* vuestros \w hijos|strong="H1121"\w*, \w ni|strong="H3808"\w* procuréis \w jamás|strong="H5769"\w* su \w paz|strong="H7965"\w* \w ni|strong="H3808"\w* su prosperidad; \w para|strong="H5704"\w* \w que|strong="H3808"\w* seáis \w fuertes|strong="H1121"\w* \w y|strong="H5704"\w* comáis \w el|strong="H1121"\w* \w bien|strong="H2896"\w* \w de|strong="H5704"\w* la tierra, \w y|strong="H5704"\w* la dejéis \w por|strong="H4616"\w* \w heredad|strong="H3423"\w* \w a|strong="H3068"\w* vuestros \w hijos|strong="H1121"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*».   
\p
\v 13 \w Mas|strong="H3588"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w nos|strong="H5921"\w* ha sobrevenido \w por|strong="H5921"\w* nuestras \w malas|strong="H7451"\w* \w obras|strong="H4639"\w* \w y|strong="H3588"\w* \w por|strong="H5921"\w* nuestro \w gran|strong="H1419"\w* \w delito|strong="H5771"\w*, viendo \w que|strong="H3588"\w* tú, Dios nuestro, \w nos|strong="H5921"\w* \w has|strong="H5414"\w* castigado \w menos|strong="H3588"\w* \w de|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* nuestras \w iniquidades|strong="H5771"\w* merecían, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w nos|strong="H5921"\w* \w has|strong="H5414"\w* \w dado|strong="H5414"\w* un resto \w como|strong="H3588"\w* \w este|strong="H2063"\w*,  
\v 14 ¿hemos \w de|strong="H5704"\w* \w volver|strong="H7725"\w* \w a|strong="H3068"\w* quebrantar tus \w mandamientos|strong="H4687"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* emparentar \w con|strong="H5704"\w* los \w pueblos|strong="H5971"\w* \w que|strong="H3808"\w* cometen estas \w abominaciones|strong="H8441"\w*? ¿\w No|strong="H3808"\w* te indignarías contra nosotros \w hasta|strong="H5704"\w* \w consumirnos|strong="H3615"\w*, \w sin|strong="H3808"\w* \w que|strong="H3808"\w* quedara \w resto|strong="H7611"\w* \w ni|strong="H3808"\w* quien escape?  
\v 15 Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, tú eres \w justo|strong="H6662"\w*, \w puesto|strong="H3588"\w* \w que|strong="H3588"\w* hemos quedado un resto \w que|strong="H3588"\w* ha escapado, \w como|strong="H3588"\w* \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w*. Henos \w aquí|strong="H2088"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w en|strong="H5921"\w* nuestros delitos; \w porque|strong="H3588"\w* \w no|strong="H3588"\w* \w es|strong="H2088"\w* posible estar \w en|strong="H5921"\w* tu \w presencia|strong="H6440"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w esto|strong="H2063"\w*”.   
\c 10
\p
\v 1 \w Mientras|strong="H3588"\w* \w Esdras|strong="H5830"\w* oraba \w y|strong="H3588"\w* \w hacía|strong="H6440"\w* confesión, \w llorando|strong="H1058"\w* \w y|strong="H3588"\w* \w postrándose|strong="H5307"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Dios, \w se|strong="H5971"\w* reunió \w con|strong="H3588"\w* \w él|strong="H3588"\w* una \w muy|strong="H3966"\w* \w grande|strong="H7227"\w* asamblea \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, hombres, mujeres \w y|strong="H3588"\w* \w niños|strong="H3206"\w*; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w lloraba|strong="H1058"\w* \w amargamente|strong="H1058"\w*.  
\v 2 Entonces Secanías \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Jehiel|strong="H3171"\w*, \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Elam|strong="H5867"\w*, \w habló|strong="H6030"\w* \w y|strong="H5921"\w* dijo \w a|strong="H3068"\w* \w Esdras|strong="H5830"\w*: «\w Nosotros|strong="H5921"\w* hemos prevaricado \w contra|strong="H5921"\w* nuestro Dios, \w pues|strong="H6258"\w* tomamos mujeres \w extranjeras|strong="H5237"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra; \w mas|strong="H5921"\w* \w a|strong="H3068"\w* pesar \w de|strong="H5921"\w* \w esto|strong="H2063"\w*, \w aún|strong="H6258"\w* \w hay|strong="H3426"\w* \w esperanza|strong="H4723"\w* \w para|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 3 \w Hagamos|strong="H6213"\w* \w ahora|strong="H6258"\w* \w pacto|strong="H1285"\w* con nuestro Dios, \w que|strong="H6258"\w* despediremos \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H1992"\w* mujeres y \w a|strong="H3068"\w* \w los|strong="H1992"\w* nacidos de \w ellas|strong="H1992"\w*, según \w el|strong="H3605"\w* \w consejo|strong="H6098"\w* de mi señor y de \w los|strong="H1992"\w* \w que|strong="H6258"\w* temen \w el|strong="H3605"\w* \w mandamiento|strong="H4687"\w* de nuestro Dios; y hágase conforme \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w ley|strong="H8451"\w*.  
\v 4 \w Levántate|strong="H6965"\w*, \w porque|strong="H3588"\w* \w esta|strong="H6965"\w* \w es|strong="H3588"\w* \w tu|strong="H6213"\w* obligación, \w y|strong="H3588"\w* \w nosotros|strong="H5973"\w* estaremos \w contigo|strong="H5973"\w*; \w esfuérzate|strong="H2388"\w*, \w y|strong="H3588"\w* pon mano \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w obra|strong="H6213"\w*».   
\p
\v 5 Entonces se \w levantó|strong="H6965"\w* \w Esdras|strong="H5830"\w* y juramentó \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w príncipes|strong="H8269"\w* \w de|strong="H1697"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w de|strong="H1697"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w*, y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w que|strong="H1697"\w* harían conforme \w a|strong="H3068"\w* \w esto|strong="H2088"\w*; y \w ellos|strong="H3605"\w* \w juraron|strong="H7650"\w*.  
\v 6 \w Se|strong="H5921"\w* \w levantó|strong="H6965"\w* luego \w Esdras|strong="H5830"\w* \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Dios, \w y|strong="H3588"\w* \w se|strong="H5921"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w cámara|strong="H3957"\w* \w de|strong="H5921"\w* \w Johanán|strong="H3076"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Eliasib; \w e|strong="H3068"\w* \w ido|strong="H3212"\w* \w allá|strong="H8033"\w*, \w no|strong="H3808"\w* comió \w pan|strong="H3899"\w* \w ni|strong="H3808"\w* \w bebió|strong="H8354"\w* \w agua|strong="H4325"\w*, \w porque|strong="H3588"\w* \w se|strong="H5921"\w* entristeció \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w prevaricación|strong="H4604"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w del|strong="H5921"\w* \w cautiverio|strong="H1473"\w*.  
\v 7 \w E|strong="H3068"\w* hicieron \w pregonar|strong="H5674"\w* por \w Judá|strong="H3063"\w* y por Jerusalén \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* cautividad, \w que|strong="H1121"\w* se reuniesen en Jerusalén;  
\v 8 y \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w no|strong="H3808"\w* \w viniese|strong="H3808"\w* dentro \w de|strong="H8269"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w*, \w conforme|strong="H1931"\w* al acuerdo \w de|strong="H8269"\w* \w los|strong="H3605"\w* \w príncipes|strong="H8269"\w* y \w de|strong="H8269"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w*, \w perdiese|strong="H2763"\w* \w toda|strong="H3605"\w* \w su|strong="H1931"\w* \w hacienda|strong="H7399"\w*, y \w él|strong="H1931"\w* fuese excluido \w de|strong="H8269"\w* \w la|strong="H1931"\w* \w congregación|strong="H6951"\w* \w de|strong="H8269"\w* \w los|strong="H3605"\w* del \w cautiverio|strong="H1473"\w*.   
