\mi
\v 17 \w Ahora|strong="H3705"\w*, \w pues|strong="H1768"\w*, \w si|strong="H2006"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w* le parece \w bien|strong="H2869"\w*, \w búsquese|strong="H1240"\w* \w en|strong="H5922"\w* la \w casa|strong="H1005"\w* \w de|strong="H4481"\w* los tesoros \w del|strong="H4481"\w* \w rey|strong="H4430"\w* \w que|strong="H1768"\w* \w está|strong="H1836"\w* \w allí|strong="H8536"\w* \w en|strong="H5922"\w* Babilonia, \w si|strong="H2006"\w* es verdad \w que|strong="H1768"\w* \w por|strong="H4481"\w* el \w rey|strong="H4430"\w* \w Ciro|strong="H3567"\w* había sido dada la \w orden|strong="H2942"\w* \w para|strong="H5922"\w* reedificar \w esta|strong="H1836"\w* \w casa|strong="H1005"\w* \w de|strong="H4481"\w* Dios \w en|strong="H5922"\w* Jerusalén, y envíenos el \w rey|strong="H4430"\w* su voluntad \w sobre|strong="H5922"\w* \w esto|strong="H1836"\w*.   
\c 6
\p
\v 1 Entonces el \w rey|strong="H4430"\w* \w Darío|strong="H1868"\w* \w dio|strong="H7761"\w* una \w orden|strong="H2942"\w*, y buscaron en la \w casa|strong="H1005"\w* \w de|strong="H1768"\w* los archivos, \w donde|strong="H1768"\w* \w guardaban|strong="H5182"\w* los tesoros \w allí|strong="H8536"\w* en Babilonia.  
\v 2 \w Y|strong="H3068"\w* hallaron en Acmeta, en el palacio \w que|strong="H1768"\w* está en la provincia \w de|strong="H1768"\w* Media, un pergamino en el cual estaba escrito \w así|strong="H3652"\w*: «\w Memoria|strong="H1799"\w*:   
\b  
\mi
\v 3 En el \w año|strong="H8140"\w* \w primero|strong="H2298"\w* del \w rey|strong="H4430"\w* \w Ciro|strong="H3567"\w*, el mismo \w rey|strong="H4430"\w* \w Ciro|strong="H3567"\w* \w dio|strong="H7761"\w* una \w orden|strong="H2942"\w* acerca \w de|strong="H1768"\w* la \w casa|strong="H1005"\w* \w de|strong="H1768"\w* Dios en Jerusalén: Sea \w edificada|strong="H1124"\w* la \w casa|strong="H1005"\w* como lugar \w donde|strong="H1768"\w* se ofrecen \w sacrificios|strong="H1685"\w*, y sus cimientos sean bien echados; su \w altura|strong="H7314"\w* \w de|strong="H1768"\w* sesenta codos, y su anchura \w de|strong="H1768"\w* sesenta codos;  
\v 4 con \w tres|strong="H8532"\w* hileras \w de|strong="H4481"\w* piedras grandes y una hilera \w de|strong="H4481"\w* madera \w nueva|strong="H2323"\w*; y \w que|strong="H1768"\w* el gasto sea pagado \w de|strong="H4481"\w* la \w casa|strong="H1005"\w* \w del|strong="H4481"\w* \w rey|strong="H4430"\w*.  
\v 5 \w Y|strong="H3068"\w* también los \w vasos|strong="H3984"\w* \w de|strong="H4481"\w* \w oro|strong="H1722"\w* y \w de|strong="H4481"\w* \w plata|strong="H3702"\w* \w de|strong="H4481"\w* la \w casa|strong="H1005"\w* \w de|strong="H4481"\w* Dios, los cuales \w Nabucodonosor|strong="H5020"\w* \w sacó|strong="H5312"\w* \w del|strong="H4481"\w* \w templo|strong="H1965"\w* \w que|strong="H1768"\w* estaba \w en|strong="H4481"\w* Jerusalén y transportó \w a|strong="H3068"\w* Babilonia, sean devueltos y vayan \w a|strong="H3068"\w* su lugar, \w al|strong="H4481"\w* \w templo|strong="H1965"\w* \w que|strong="H1768"\w* está \w en|strong="H4481"\w* Jerusalén, y ponlos \w en|strong="H4481"\w* la \w casa|strong="H1005"\w* \w de|strong="H4481"\w* Dios».   
\mi
\v 6 «\w Ahora|strong="H3705"\w*, \w pues|strong="H1768"\w*, \w Tatnai|strong="H8674"\w*, \w gobernador|strong="H6347"\w* \w de|strong="H4481"\w* allende \w el|strong="H1934"\w* río, Setar-boznai y vuestros compañeros los gobernadores \w que|strong="H1768"\w* estáis \w de|strong="H4481"\w* la otra parte \w del|strong="H4481"\w* río, permaneced lejos \w de|strong="H4481"\w* \w allí|strong="H8536"\w*.  
\v 7 \w Dejad|strong="H7662"\w* \w que|strong="H5922"\w* se haga la obra \w de|strong="H5922"\w* esa \w casa|strong="H1005"\w* \w de|strong="H5922"\w* Dios; \w que|strong="H5922"\w* el \w gobernador|strong="H6347"\w* \w de|strong="H5922"\w* los \w judíos|strong="H3062"\w* y sus ancianos reedifiquen esa \w casa|strong="H1005"\w* \w de|strong="H5922"\w* Dios \w en|strong="H5922"\w* su lugar.  
\v 8 \w Y|strong="H3068"\w* \w por|strong="H4481"\w* mí es dada \w orden|strong="H2942"\w* \w de|strong="H4481"\w* lo \w que|strong="H1768"\w* habéis \w de|strong="H4481"\w* hacer \w con|strong="H5974"\w* esos ancianos \w de|strong="H4481"\w* los \w judíos|strong="H3062"\w* para reedificar esa \w casa|strong="H1005"\w* \w de|strong="H4481"\w* Dios: \w que|strong="H1768"\w* \w de|strong="H4481"\w* la hacienda \w del|strong="H4481"\w* \w rey|strong="H4430"\w*, \w del|strong="H4481"\w* \w tributo|strong="H4061"\w* \w de|strong="H4481"\w* allende \w el|strong="H1934"\w* río, sean dados puntualmente los gastos \w a|strong="H3068"\w* esos \w varones|strong="H1400"\w*, para \w que|strong="H1768"\w* \w no|strong="H3809"\w* cese la obra.  
\v 9 \w Y|strong="H3068"\w* lo \w que|strong="H1768"\w* fuere necesario, \w becerros|strong="H1123"\w*, \w carneros|strong="H1798"\w* \w y|strong="H3809"\w* corderos para holocaustos al Dios del \w cielo|strong="H8065"\w*, \w trigo|strong="H2591"\w*, \w sal|strong="H4416"\w*, \w vino|strong="H2562"\w* \w y|strong="H3809"\w* aceite, conforme \w a|strong="H3068"\w* lo \w que|strong="H1768"\w* \w dijeren|strong="H3983"\w* los sacerdotes \w que|strong="H1768"\w* están en Jerusalén, dádselos \w día|strong="H3118"\w* \w a|strong="H3068"\w* \w día|strong="H3118"\w* \w sin|strong="H3809"\w* falta alguna,  
\v 10 para \w que|strong="H1768"\w* ofrezcan sacrificios \w de|strong="H1768"\w* olor grato al Dios del \w cielo|strong="H8065"\w*, y oren \w por|strong="H1768"\w* la vida del \w rey|strong="H4430"\w* y \w de|strong="H1768"\w* \w sus|strong="H1934"\w* \w hijos|strong="H1123"\w*.  
\v 11 También \w por|strong="H4481"\w* mí es dada \w orden|strong="H2942"\w* \w que|strong="H1768"\w* \w a|strong="H3068"\w* \w cualquiera|strong="H3606"\w* \w que|strong="H1768"\w* altere \w este|strong="H1836"\w* \w decreto|strong="H6600"\w*, se le arranque \w una|strong="H5648"\w* viga \w de|strong="H4481"\w* su \w casa|strong="H1005"\w*, y alzado, sea colgado \w en|strong="H5922"\w* ella; y su \w casa|strong="H1005"\w* sea hecha un \w muladar|strong="H5122"\w* \w por|strong="H4481"\w* \w esto|strong="H1836"\w*.  
\v 12 \w Y|strong="H3068"\w* el Dios \w que|strong="H1768"\w* \w hizo|strong="H5648"\w* habitar \w allí|strong="H8536"\w* su \w nombre|strong="H8036"\w*, \w destruya|strong="H4049"\w* \w a|strong="H3068"\w* \w todo|strong="H3606"\w* \w rey|strong="H4430"\w* y \w pueblo|strong="H5972"\w* \w que|strong="H1768"\w* \w pusiere|strong="H7972"\w* su \w mano|strong="H3028"\w* para alterar \w o|strong="H3068"\w* destruir esa \w casa|strong="H1005"\w* \w de|strong="H1768"\w* Dios, la cual \w está|strong="H1791"\w* en Jerusalén. Yo, \w Darío|strong="H1868"\w*, he dado el decreto; sea cumplido puntualmente».   
\b  
\p
\v 13 Entonces \w Tatnai|strong="H8674"\w*, \w gobernador|strong="H6347"\w* \w de|strong="H1768"\w* allende el río, Setar-boznai y sus compañeros, cumplieron puntualmente según lo \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Darío|strong="H1868"\w* había enviado.   
\p
\v 14 \w Y|strong="H3068"\w* los ancianos \w de|strong="H4481"\w* los \w judíos|strong="H3062"\w* \w edificaban|strong="H1124"\w* y prosperaban, conforme \w a|strong="H3068"\w* la profecía \w del|strong="H4481"\w* \w profeta|strong="H5029"\w* Hageo y \w de|strong="H4481"\w* \w Zacarías|strong="H2148"\w* \w hijo|strong="H1247"\w* \w de|strong="H4481"\w* \w Iddo|strong="H5714"\w*. \w Edificaron|strong="H1124"\w*, pues, y terminaron, \w por|strong="H4481"\w* mandato \w del|strong="H4481"\w* Dios \w de|strong="H4481"\w* \w Israel|strong="H3479"\w*, y \w por|strong="H4481"\w* mandado \w de|strong="H4481"\w* \w Ciro|strong="H3567"\w*, \w de|strong="H4481"\w* \w Darío|strong="H1868"\w*, y \w de|strong="H4481"\w* Artajerjes \w rey|strong="H4430"\w* \w de|strong="H4481"\w* Persia.  
\v 15 \w Esta|strong="H1836"\w* \w casa|strong="H1005"\w* fue terminada \w el|strong="H1932"\w* tercer \w día|strong="H3118"\w* del mes \w de|strong="H1768"\w* Adar, \w que|strong="H1768"\w* \w era|strong="H1932"\w* \w el|strong="H1932"\w* sexto \w año|strong="H8140"\w* del reinado del \w rey|strong="H4430"\w* \w Darío|strong="H1868"\w*.   
\p
\v 16 Entonces los \w hijos|strong="H1123"\w* de \w Israel|strong="H3479"\w*, los sacerdotes, los levitas y los demás que habían venido de la cautividad, \w hicieron|strong="H5648"\w* la dedicación de \w esta|strong="H1836"\w* \w casa|strong="H1005"\w* de Dios con gozo.  
\v 17 \w Y|strong="H3068"\w* ofrecieron \w en|strong="H5922"\w* la dedicación \w de|strong="H5922"\w* \w esta|strong="H1836"\w* \w casa|strong="H1005"\w* \w de|strong="H5922"\w* Dios \w cien|strong="H3969"\w* \w becerros|strong="H8450"\w*, \w doscientos|strong="H3969"\w* \w carneros|strong="H1798"\w* y cuatrocientos corderos; y como expiación \w por|strong="H5922"\w* \w todo|strong="H3606"\w* \w Israel|strong="H3479"\w*, doce machos cabríos, conforme \w al|strong="H5922"\w* número \w de|strong="H5922"\w* las tribus \w de|strong="H5922"\w* \w Israel|strong="H3479"\w*.  
\v 18 \w Y|strong="H3068"\w* pusieron \w a|strong="H3068"\w* los sacerdotes \w en|strong="H5922"\w* sus turnos, y \w a|strong="H3068"\w* los levitas \w en|strong="H5922"\w* sus divisiones \w para|strong="H5922"\w* el servicio \w de|strong="H5922"\w* Dios \w en|strong="H5922"\w* Jerusalén, conforme \w a|strong="H3068"\w* lo escrito \w en|strong="H5922"\w* el libro \w de|strong="H5922"\w* Moisés.   
\p
\v 19 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* la cautividad celebraron la \w Pascua|strong="H6453"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* catorce días del \w mes|strong="H2320"\w* \w primero|strong="H7223"\w*.  
\v 20 \w Porque|strong="H3588"\w* \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w los|strong="H1992"\w* \w levitas|strong="H3881"\w* \w se|strong="H1992"\w* habían \w purificado|strong="H3588"\w* \w a|strong="H3068"\w* una; \w todos|strong="H3605"\w* estaban \w limpios|strong="H2889"\w*, \w y|strong="H3588"\w* sacrificaron \w la|strong="H3605"\w* víctima \w de|strong="H3588"\w* \w la|strong="H3605"\w* \w Pascua|strong="H6453"\w* \w por|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* cautividad, \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w sus|strong="H1992"\w* hermanos \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w*, \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w sí|strong="H3588"\w* \w mismos|strong="H1992"\w*.  
