\c 3
\p
\v 1 \w Llegado|strong="H5060"\w* \w el|strong="H1121"\w* \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w*, una vez \w que|strong="H5971"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w se|strong="H5971"\w* hallaban ya en sus \w ciudades|strong="H5892"\w*, \w se|strong="H5971"\w* congregó \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w* \w como|strong="H5060"\w* un solo \w hombre|strong="H1121"\w* en Jerusalén.  
\v 2 Entonces \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w Jesúa|strong="H3442"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Josadac, \w con|strong="H5921"\w* sus hermanos \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, \w y|strong="H5921"\w* \w Zorobabel|strong="H2216"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Salatiel, \w con|strong="H5921"\w* sus parientes, \w y|strong="H5921"\w* \w edificaron|strong="H1129"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w del|strong="H5921"\w* Dios \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w para|strong="H5921"\w* ofrecer \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w holocaustos|strong="H5930"\w*, \w como|strong="H5921"\w* \w está|strong="H6965"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*, varón \w de|strong="H5921"\w* Dios.  
\v 3 \w Y|strong="H3068"\w* colocaron \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w sobre|strong="H5921"\w* \w su|strong="H3588"\w* base, \w a|strong="H3068"\w* pesar \w del|strong="H5921"\w* miedo \w que|strong="H3588"\w* tenían \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* aquellas tierras, \w y|strong="H3588"\w* ofrecieron \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w holocaustos|strong="H5930"\w* \w a|strong="H3068"\w* Yahvé, \w holocaustos|strong="H5930"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w* \w y|strong="H3588"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w tarde|strong="H6153"\w*.  
\v 4 Celebraron asimismo la \w fiesta|strong="H2282"\w* \w de|strong="H1697"\w* los Tabernáculos, según \w está|strong="H3789"\w* \w escrito|strong="H3789"\w*, y ofrecieron los \w holocaustos|strong="H5930"\w* diarios \w por|strong="H1697"\w* su \w número|strong="H4557"\w* y \w conforme|strong="H5930"\w* \w al|strong="H5930"\w* rito, según la norma \w de|strong="H1697"\w* \w cada|strong="H1697"\w* \w día|strong="H3117"\w*;  
\v 5 y además de esto, \w el|strong="H3605"\w* \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, \w los|strong="H3605"\w* de las lunas \w nuevas|strong="H2320"\w*, \w los|strong="H3605"\w* de \w todas|strong="H3605"\w* las \w solemnidades|strong="H4150"\w* consagradas \w a|strong="H3068"\w* Yahvé, y \w los|strong="H3605"\w* de \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w que|strong="H5071"\w* ofrecía \w voluntariamente|strong="H5071"\w* ofrenda \w a|strong="H3068"\w* Yahvé.  
\v 6 Desde el primer \w día|strong="H3117"\w* del \w mes|strong="H2320"\w* \w séptimo|strong="H7637"\w* \w comenzaron|strong="H2490"\w* \w a|strong="H3068"\w* ofrecer \w holocaustos|strong="H5930"\w* \w a|strong="H3068"\w* Yahvé; \w mas|strong="H3808"\w* los \w cimientos|strong="H3245"\w* del \w templo|strong="H1964"\w* de Yahvé \w aún|strong="H3808"\w* \w no|strong="H3808"\w* habían sido echados.  
\v 7 \w Y|strong="H3068"\w* \w dieron|strong="H5414"\w* \w dinero|strong="H3701"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w canteros|strong="H2672"\w* \w y|strong="H5921"\w* \w carpinteros|strong="H2796"\w*; asimismo \w dieron|strong="H5414"\w* \w comida|strong="H3978"\w*, bebida \w y|strong="H5921"\w* \w aceite|strong="H8081"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w sidonios|strong="H6722"\w* \w y|strong="H5921"\w* tirios \w para|strong="H5921"\w* \w que|strong="H4480"\w* trajesen \w madera|strong="H6086"\w* \w de|strong="H4480"\w* cedro \w del|strong="H4480"\w* \w Líbano|strong="H3844"\w* \w por|strong="H5921"\w* \w mar|strong="H3220"\w* \w a|strong="H3068"\w* Jope, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* concesión \w que|strong="H4480"\w* \w les|strong="H5921"\w* había hecho \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Persia|strong="H6539"\w*.   
\p
\v 8 \w En|strong="H5921"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* \w segundo|strong="H8145"\w* \w de|strong="H5921"\w* su llegada \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Dios|strong="H3068"\w* \w en|strong="H5921"\w* Jerusalén, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w mes|strong="H2320"\w* \w segundo|strong="H8145"\w*, \w comenzaron|strong="H2490"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w Zorobabel|strong="H2216"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Salatiel, \w Jesúa|strong="H3442"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Josadac, \w con|strong="H5921"\w* \w el|strong="H5921"\w* resto \w de|strong="H5921"\w* sus hermanos, \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* habían venido \w del|strong="H5921"\w* \w cautiverio|strong="H7628"\w* \w a|strong="H3068"\w* Jerusalén; \w y|strong="H5921"\w* \w pusieron|strong="H5975"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w de|strong="H5921"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* \w arriba|strong="H4605"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* dirigiesen \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé.  
\v 9 \w Jesúa|strong="H3442"\w* también, \w con|strong="H5921"\w* sus \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* sus hermanos, \w Cadmiel|strong="H6934"\w* \w y|strong="H5921"\w* sus \w hijos|strong="H1121"\w*, \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w se|strong="H5921"\w* presentaron \w como|strong="H5921"\w* un solo \w hombre|strong="H1121"\w* \w para|strong="H5921"\w* activar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* \w hacían|strong="H6213"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Dios, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Henadad, sus \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* sus hermanos \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*.   
\p
\v 10 \w Y|strong="H3068"\w* cuando \w los|strong="H1121"\w* albañiles \w del|strong="H5921"\w* \w templo|strong="H1964"\w* \w de|strong="H5921"\w* Yahvé echaban \w los|strong="H1121"\w* \w cimientos|strong="H3245"\w*, \w pusieron|strong="H5975"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* revestidos \w de|strong="H5921"\w* sus ornamentos, \w con|strong="H5921"\w* \w trompetas|strong="H2689"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Asaf \w con|strong="H5921"\w* \w címbalos|strong="H4700"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* alabasen \w a|strong="H3068"\w* Yahvé, \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w ordenanza|strong="H3027"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 11 \w Y|strong="H3068"\w* cantaban, \w alabando|strong="H1984"\w* \w y|strong="H3588"\w* dando gracias \w a|strong="H3068"\w* Yahvé, diciendo: «\w Porque|strong="H3588"\w* \w él|strong="H5921"\w* \w es|strong="H3588"\w* \w bueno|strong="H2896"\w*, \w porque|strong="H3588"\w* \w para|strong="H5921"\w* \w siempre|strong="H5769"\w* \w es|strong="H3588"\w* \w su|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*». \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* jubilaba \w con|strong="H5921"\w* \w gran|strong="H1419"\w* gozo, \w alabando|strong="H1984"\w* \w a|strong="H3068"\w* Yahvé \w porque|strong="H3588"\w* \w se|strong="H5921"\w* echaban \w los|strong="H5921"\w* \w cimientos|strong="H3245"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé.   
\p
\v 12 \w Y|strong="H3068"\w* \w muchos|strong="H7227"\w* \w de|strong="H5869"\w* los \w sacerdotes|strong="H3548"\w*, \w de|strong="H5869"\w* los \w levitas|strong="H3881"\w* y \w de|strong="H5869"\w* los \w jefes|strong="H7218"\w* \w de|strong="H5869"\w* \w casas|strong="H1004"\w* paternas, \w ancianos|strong="H2205"\w* \w que|strong="H2088"\w* habían \w visto|strong="H7200"\w* la \w casa|strong="H1004"\w* \w primera|strong="H7223"\w*, \w viendo|strong="H7200"\w* echar los \w cimientos|strong="H3245"\w* \w de|strong="H5869"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w*, \w lloraban|strong="H1058"\w* en \w alta|strong="H7311"\w* \w voz|strong="H6963"\w*, mientras \w muchos|strong="H7227"\w* otros daban \w grandes|strong="H1419"\w* \w gritos|strong="H8643"\w* \w de|strong="H5869"\w* \w alegría|strong="H8057"\w*.  
\v 13 \w Y|strong="H3068"\w* \w no|strong="H3588"\w* podía distinguir \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w el|strong="H3588"\w* \w clamor|strong="H8643"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w gritos|strong="H8643"\w* \w de|strong="H3588"\w* \w alegría|strong="H8057"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* del \w llanto|strong="H1065"\w*; \w porque|strong="H3588"\w* gritaba \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w con|strong="H3588"\w* \w gran|strong="H1419"\w* \w júbilo|strong="H8643"\w*, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w ruido|strong="H6963"\w* \w se|strong="H5971"\w* \w oía|strong="H8085"\w* \w hasta|strong="H5704"\w* \w de|strong="H3588"\w* \w lejos|strong="H7350"\w*.   
\c 4
\p
\v 1 \w Cuando|strong="H3588"\w* \w los|strong="H1121"\w* \w adversarios|strong="H6862"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Benjamín|strong="H1144"\w* \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* cautividad \w edificaban|strong="H1129"\w* \w el|strong="H3588"\w* \w templo|strong="H1964"\w* \w a|strong="H3068"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*,  
\v 2 \w se|strong="H3808"\w* acercaron \w a|strong="H3068"\w* \w Zorobabel|strong="H2216"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w jefes|strong="H7218"\w* \w de|strong="H3588"\w* \w las|strong="H1992"\w* casas paternas, \w y|strong="H3588"\w* \w les|strong="H1992"\w* dijeron: «Dejadnos \w edificar|strong="H1129"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*, \w porque|strong="H3588"\w* \w como|strong="H3588"\w* \w vosotros|strong="H5973"\w* buscamos \w a|strong="H3068"\w* vuestro Dios, \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w él|strong="H5973"\w* ofrecemos \w sacrificios|strong="H2076"\w* desde \w los|strong="H1992"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* Esar-hadón, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Asiria, \w que|strong="H3588"\w* nos \w hizo|strong="H5927"\w* \w subir|strong="H5927"\w* \w aquí|strong="H6311"\w*».   
\p
\v 3 \w Pero|strong="H3588"\w* \w Zorobabel|strong="H2216"\w*, \w Jesúa|strong="H3442"\w* \w y|strong="H3588"\w* \w los|strong="H3588"\w* demás \w jefes|strong="H7218"\w* \w de|strong="H3588"\w* las \w casas|strong="H1004"\w* paternas \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* dijeron: «\w No|strong="H3808"\w* tenéis vosotros \w nada|strong="H3808"\w* \w que|strong="H3588"\w* ver \w con|strong="H3588"\w* nosotros \w en|strong="H3588"\w* \w la|strong="H3588"\w* edificación \w de|strong="H3588"\w* una \w casa|strong="H1004"\w* \w a|strong="H3068"\w* nuestro \w Dios|strong="H3068"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* nosotros \w solos|strong="H3162"\w* \w la|strong="H3588"\w* \w edificaremos|strong="H1129"\w* \w a|strong="H3068"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w como|strong="H3588"\w* nos \w mandó|strong="H6680"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Persia|strong="H6539"\w*».   
\p
\v 4 Entonces la \w gente|strong="H5971"\w* del país desanimó al \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w Judá|strong="H3063"\w* y lo atribuló \w para|strong="H1961"\w* \w que|strong="H5971"\w* \w no|strong="H1961"\w* siguiera \w edificando|strong="H1129"\w*.  
\v 5 Sobornaron \w además|strong="H5921"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* \w consejeros|strong="H6098"\w* \w para|strong="H5704"\w* frustrar su propósito, durante \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w tiempo|strong="H3117"\w* \w de|strong="H5921"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*, \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w reinado|strong="H4428"\w* \w de|strong="H5921"\w* \w Darío|strong="H1867"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*.  
\v 6 \w Y|strong="H3068"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w reinado|strong="H4438"\w* \w de|strong="H5921"\w* Asuero, \w al|strong="H5921"\w* principio \w de|strong="H5921"\w* su \w reinado|strong="H4438"\w*, \w escribieron|strong="H3789"\w* una acusación \w contra|strong="H5921"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* Jerusalén.   
\p
\v 7 También \w en|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Artajerjes, \w Bislam|strong="H1312"\w*, \w Mitrídates|strong="H4990"\w*, \w Tabeel|strong="H2870"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* demás compañeros suyos, \w escribieron|strong="H3789"\w* \w a|strong="H3068"\w* Artajerjes, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*; \w y|strong="H5921"\w* \w la|strong="H5921"\w* carta estaba \w escrita|strong="H3789"\w* \w en|strong="H5921"\w* caracteres sirios \w y|strong="H5921"\w* traducida \w al|strong="H5921"\w* sirio.  
\v 8 \w Rehum|strong="H7348"\w*, el \w canciller|strong="H1169"\w*, y Simsai, el \w secretario|strong="H5613"\w*, \w escribieron|strong="H3790"\w* una carta \w contra|strong="H5922"\w* Jerusalén \w al|strong="H5922"\w* \w rey|strong="H4430"\w* Artajerjes, \w de|strong="H5922"\w* esta manera:  
\v 9 En aquel tiempo firmaban \w Rehum|strong="H7348"\w*, el \w canciller|strong="H1169"\w*, y Simsai, el \w secretario|strong="H5613"\w*, y los demás compañeros suyos, los jueces, los gobernadores y oficiales, los \w de|strong="H1768"\w* Persia, \w de|strong="H1768"\w* Erech, \w de|strong="H1768"\w* Babilonia, \w de|strong="H1768"\w* Susa, esto es, los elamitas,  
\v 10 y las demás naciones \w que|strong="H1768"\w* el grande y noble Osnapar transportó \w e|strong="H3068"\w* instaló en las ciudades \w de|strong="H1768"\w* Samaria y en las demás provincias \w de|strong="H1768"\w* allende el río, etc.   
\p
\v 11 \w Esta|strong="H1836"\w* es la copia \w de|strong="H5922"\w* la carta \w que|strong="H1768"\w* \w enviaron|strong="H7972"\w*:  
\b  
\mi \w Al|strong="H5922"\w* \w rey|strong="H4430"\w* Artajerjes, \w de|strong="H5922"\w* parte \w de|strong="H5922"\w* tus \w siervos|strong="H5649"\w*, los hombres \w de|strong="H5922"\w* allende el río.   
\mi
\v 12 \w Sea|strong="H1934"\w* \w notorio|strong="H3046"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w* \w que|strong="H1768"\w* los \w judíos|strong="H3062"\w* \w que|strong="H1768"\w* \w subieron|strong="H5559"\w* \w de|strong="H4481"\w* tu parte han venido \w a|strong="H3068"\w* nosotros \w a|strong="H3068"\w* Jerusalén; y edifican la \w ciudad|strong="H7149"\w* \w rebelde|strong="H4779"\w* y malvada, y han levantado \w ya|strong="H1768"\w* los muros y reparado los cimientos.  
\v 13 Sepa \w ahora|strong="H3705"\w* \w el|strong="H1934"\w* \w rey|strong="H4430"\w* \w que|strong="H1768"\w* \w si|strong="H2006"\w* \w aquella|strong="H1791"\w* \w ciudad|strong="H7149"\w* \w fuere|strong="H7149"\w* reedificada \w y|strong="H3809"\w* los muros fueren acabados, \w no|strong="H3809"\w* pagarán \w tributo|strong="H4061"\w*, \w ni|strong="H3809"\w* impuesto, \w ni|strong="H3809"\w* peaje, \w y|strong="H3809"\w* \w el|strong="H1934"\w* fisco \w real|strong="H4430"\w* será perjudicado.  
\v 14 \w Ahora|strong="H3705"\w* bien, \w por|strong="H5922"\w* cuanto estamos mantenidos \w por|strong="H5922"\w* la \w sal|strong="H4416"\w* del palacio, \w y|strong="H3809"\w* \w no|strong="H3809"\w* nos es justo ver el menosprecio del \w rey|strong="H4430"\w*, hemos enviado \w a|strong="H3068"\w* dar aviso \w al|strong="H5922"\w* \w rey|strong="H4430"\w*,  
\v 15 \w para|strong="H5922"\w* \w que|strong="H1768"\w* se busque \w en|strong="H5922"\w* el libro \w de|strong="H4481"\w* las memorias \w de|strong="H4481"\w* tus padres. Hallarás \w en|strong="H5922"\w* el libro \w de|strong="H4481"\w* las memorias y sabrás \w que|strong="H1768"\w* \w esta|strong="H1836"\w* \w ciudad|strong="H7149"\w* es \w ciudad|strong="H7149"\w* \w rebelde|strong="H4779"\w* y perjudicial \w a|strong="H3068"\w* los \w reyes|strong="H4430"\w* y \w a|strong="H3068"\w* las provincias, y \w que|strong="H1768"\w* \w en|strong="H5922"\w* \w medio|strong="H1459"\w* \w de|strong="H4481"\w* ella se han fomentado sediciones desde tiempos antiguos, \w por|strong="H4481"\w* lo cual la \w ciudad|strong="H7149"\w* fue destruida.  
\v 16 Hacemos \w saber|strong="H3046"\w* al \w rey|strong="H4430"\w* \w que|strong="H1768"\w* \w si|strong="H2006"\w* \w esta|strong="H1836"\w* \w ciudad|strong="H7149"\w* \w fuere|strong="H7149"\w* reedificada \w y|strong="H3809"\w* sus muros acabados, la región \w de|strong="H1768"\w* allende el río \w no|strong="H3809"\w* será más tuya.   
\b  
\p
\v 17 El \w rey|strong="H4430"\w* \w envió|strong="H7972"\w* esta \w respuesta|strong="H6600"\w* \w a|strong="H3068"\w* \w Rehum|strong="H7348"\w*, el \w canciller|strong="H1169"\w*, y \w a|strong="H3068"\w* Simsai, el \w secretario|strong="H5613"\w*, y \w a|strong="H3068"\w* los demás compañeros suyos \w que|strong="H1768"\w* habitaban \w en|strong="H5922"\w* Samaria y \w en|strong="H5922"\w* el resto \w de|strong="H5922"\w* la provincia \w de|strong="H5922"\w* allende el río:  
\b  
\mi Salud.   
\b  
\mi
\v 18 La carta \w que|strong="H1768"\w* nos \w enviasteis|strong="H7972"\w* ha sido leída \w claramente|strong="H6568"\w* ante \w mí|strong="H6925"\w*.  
\v 19 \w Y|strong="H3068"\w* \w por|strong="H4481"\w* mi \w orden|strong="H2942"\w* se ha buscado, y \w hallado|strong="H7912"\w* \w que|strong="H1768"\w* \w aquella|strong="H1791"\w* \w ciudad|strong="H7149"\w* \w de|strong="H4481"\w* \w antiguo|strong="H5957"\w* se levanta \w contra|strong="H5922"\w* los \w reyes|strong="H4430"\w* y se rebela \w contra|strong="H5922"\w* \w ellos|strong="H4481"\w*.  
\v 20 \w Y|strong="H3068"\w* \w que|strong="H5922"\w* \w hubo|strong="H1934"\w* \w en|strong="H5922"\w* Jerusalén \w reyes|strong="H4430"\w* poderosos \w que|strong="H5922"\w* dominaron \w en|strong="H5922"\w* \w todo|strong="H3606"\w* \w el|strong="H1934"\w* país \w de|strong="H5922"\w* allende \w el|strong="H1934"\w* río, y \w que|strong="H5922"\w* se les pagaba \w tributo|strong="H4061"\w*, impuesto y peaje.  
\v 21 \w Dad|strong="H7761"\w*, pues, \w orden|strong="H2942"\w* \w de|strong="H4481"\w* \w que|strong="H5705"\w* cesen aquellos \w hombres|strong="H1400"\w*, \w y|strong="H3809"\w* \w no|strong="H3809"\w* sea esa \w ciudad|strong="H7149"\w* reedificada \w hasta|strong="H5705"\w* \w que|strong="H5705"\w* \w por|strong="H4481"\w* mí se \w dé|strong="H4481"\w* nueva \w orden|strong="H2942"\w*.  
\v 22 \w Y|strong="H3068"\w* guardaos \w de|strong="H5922"\w* ser negligentes \w en|strong="H5922"\w* \w esto|strong="H1836"\w*; ¿\w por|strong="H5922"\w* \w qué|strong="H4101"\w* habrá \w de|strong="H5922"\w* crecer \w el|strong="H1934"\w* daño \w en|strong="H5922"\w* perjuicio \w de|strong="H5922"\w* los \w reyes|strong="H4430"\w*?   
\b  
\p
\v 23 Entonces, tan pronto como la copia \w de|strong="H4481"\w* la carta \w del|strong="H4481"\w* \w rey|strong="H4430"\w* Artajerjes fue leída \w delante|strong="H6925"\w* \w de|strong="H4481"\w* \w Rehum|strong="H7348"\w*, y \w de|strong="H4481"\w* Simsai el \w secretario|strong="H5613"\w* y sus compañeros, partieron \w a|strong="H3068"\w* toda prisa hacia Jerusalén, \w a|strong="H3068"\w* \w los|strong="H1994"\w* \w judíos|strong="H3062"\w*, y les obligaron \w a|strong="H3068"\w* detener la obra \w por|strong="H4481"\w* la fuerza \w de|strong="H4481"\w* las armas.  
\v 24 Así cesó la obra \w de|strong="H1768"\w* la \w casa|strong="H1005"\w* \w de|strong="H1768"\w* Dios \w que|strong="H1768"\w* estaba \w en|strong="H5705"\w* Jerusalén, y quedó suspendida \w hasta|strong="H5705"\w* \w el|strong="H1934"\w* \w año|strong="H8140"\w* \w segundo|strong="H8648"\w* del reinado \w de|strong="H1768"\w* \w Darío|strong="H1868"\w*, \w rey|strong="H4430"\w* \w de|strong="H1768"\w* Persia.   
\c 5
\p
\v 1 Los profetas Hageo y \w Zacarías|strong="H2148"\w* \w hijo|strong="H1247"\w* \w de|strong="H5922"\w* \w Iddo|strong="H5714"\w* profetizaron \w a|strong="H3068"\w* los \w judíos|strong="H3062"\w* \w que|strong="H1768"\w* estaban \w en|strong="H5922"\w* \w Judá|strong="H3061"\w* y \w en|strong="H5922"\w* Jerusalén \w en|strong="H5922"\w* el \w nombre|strong="H8036"\w* del Dios \w de|strong="H5922"\w* \w Israel|strong="H3479"\w* \w que|strong="H1768"\w* estaba \w sobre|strong="H5922"\w* ellos.  
\v 2 Entonces se levantaron \w Zorobabel|strong="H2217"\w* \w hijo|strong="H1247"\w* \w de|strong="H1768"\w* Salatiel y Jesúa \w hijo|strong="H1247"\w* \w de|strong="H1768"\w* Josadac, y comenzaron \w a|strong="H3068"\w* reedificar la \w casa|strong="H1005"\w* \w de|strong="H1768"\w* Dios \w que|strong="H1768"\w* estaba en Jerusalén; y \w con|strong="H5974"\w* ellos estaban los \w profetas|strong="H5029"\w* \w de|strong="H1768"\w* Dios \w que|strong="H1768"\w* les ayudaban.   
\p
\v 3 \w En|strong="H5922"\w* aquel \w tiempo|strong="H2166"\w* vino \w a|strong="H3068"\w* ellos \w Tatnai|strong="H8674"\w*, \w gobernador|strong="H6347"\w* \w de|strong="H5922"\w* allende el río, y Setar-boznai y sus compañeros, y les dijeron \w así|strong="H3652"\w*: «¿\w Quién|strong="H4479"\w* os ha dado mandato \w para|strong="H5922"\w* edificar \w esta|strong="H1836"\w* \w casa|strong="H1005"\w* y reparar estos muros?».  
\v 4 También les preguntamos cuáles eran los nombres \w de|strong="H1768"\w* los \w varones|strong="H1400"\w* \w que|strong="H1768"\w* \w edificaban|strong="H1124"\w* \w este|strong="H1836"\w* \w edificio|strong="H1147"\w*.  
