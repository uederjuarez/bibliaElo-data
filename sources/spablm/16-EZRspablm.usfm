\v 26 \w El|strong="H1934"\w* \w que|strong="H1768"\w* \w no|strong="H3809"\w* cumpla la ley \w de|strong="H4481"\w* tu Dios \w y|strong="H3809"\w* la ley \w del|strong="H4481"\w* \w rey|strong="H4430"\w*, \w que|strong="H1768"\w* se ejecute sobre \w él|strong="H1934"\w* \w el|strong="H1934"\w* \w juicio|strong="H1780"\w* con \w toda|strong="H3606"\w* diligencia, \w ya|strong="H1768"\w* \w sea|strong="H1934"\w* \w a|strong="H3068"\w* muerte, \w ya|strong="H1768"\w* \w sea|strong="H1934"\w* \w a|strong="H3068"\w* destierro, \w ya|strong="H1768"\w* \w sea|strong="H1934"\w* \w a|strong="H3068"\w* confiscación \w de|strong="H4481"\w* bienes, \w ya|strong="H1768"\w* \w sea|strong="H1934"\w* \w a|strong="H3068"\w* prisión.   
\b  
\p
\v 27 \w Bendito|strong="H1288"\w* sea Yahvé, el \w Dios|strong="H3068"\w* \w de|strong="H5414"\w* nuestros padres, que ha \w puesto|strong="H5414"\w* algo \w así|strong="H2063"\w* en el \w corazón|strong="H3820"\w* del \w rey|strong="H4428"\w*, \w para|strong="H5414"\w* embellecer \w la|strong="H2063"\w* \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Yahvé que \w está|strong="H2063"\w* en Jerusalén;  
\v 28 \w y|strong="H5921"\w* ha \w extendido|strong="H5186"\w* su bondad \w conmigo|strong="H5973"\w* \w ante|strong="H6440"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H5921"\w* sus \w consejeros|strong="H3289"\w*, \w y|strong="H5921"\w* \w ante|strong="H6440"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w poderosos|strong="H1368"\w* \w príncipes|strong="H8269"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*. \w Me|strong="H5921"\w* he fortalecido \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w del|strong="H5921"\w* \w Señor|strong="H3068"\w*, \w mi|strong="H5921"\w* \w Dios|strong="H3068"\w*, \w y|strong="H5921"\w* he reunido \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* suban \w conmigo|strong="H5973"\w*.   
\c 8
\p
\v 1 Estos son \w los|strong="H5973"\w* \w jefes|strong="H7218"\w* \w de|strong="H5973"\w* familia \w de|strong="H5973"\w* sus padres, y esta es la genealogía \w de|strong="H5973"\w* \w los|strong="H5973"\w* que \w subieron|strong="H5927"\w* \w conmigo|strong="H5973"\w* desde Babilonia, \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w reinado|strong="H4428"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w* Artajerjes:   
\m
\v 2 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Finehas, Gershom.  
\m \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ithamar, \w Daniel|strong="H1840"\w*.  
