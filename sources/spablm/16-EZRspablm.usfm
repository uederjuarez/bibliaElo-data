\mt1 Esdras  
\c 1
\p
\v 1 En \w el|strong="H3605"\w* primer \w año|strong="H8141"\w* \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, para \w que|strong="H1571"\w* se cumpliera \w la|strong="H1571"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé\f + \fr 1:1 \ft «Yahvé» es el nombre propio de Dios, a veces traducido como «SEÑOR» (en mayúsculas) en otras traducciones.\f* \w por|strong="H1697"\w* \w boca|strong="H6310"\w* \w de|strong="H1697"\w* \w Jeremías|strong="H3414"\w*, Yahvé \w despertó|strong="H5782"\w* \w el|strong="H3605"\w* \w espíritu|strong="H7307"\w* \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, \w de|strong="H1697"\w* modo \w que|strong="H1571"\w* hizo \w pregonar|strong="H5674"\w* \w por|strong="H1697"\w* \w todo|strong="H3605"\w* su \w reino|strong="H4438"\w*, \w y|strong="H1571"\w* \w lo|strong="H1697"\w* puso \w también|strong="H1571"\w* \w por|strong="H1697"\w* escrito, diciendo:   
\mi
\v 2 “\w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*, dice: “Yahvé, \w el|strong="H1931"\w* \w Dios|strong="H3068"\w*\f + \fr 1:2 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w me|strong="H5921"\w* \w ha|strong="H3541"\w* \w dado|strong="H5414"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra; \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w ha|strong="H3541"\w* ordenado \w que|strong="H1931"\w* \w le|strong="H1931"\w* \w edifique|strong="H1129"\w* una \w casa|strong="H1004"\w* \w en|strong="H5921"\w* Jerusalén, \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 3 Quienquiera \w de|strong="H5973"\w* \w entre|strong="H5973"\w* \w vosotros|strong="H5973"\w* \w que|strong="H4310"\w* pertenezca \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*, \w sea|strong="H1961"\w* \w su|strong="H1931"\w* \w Dios|strong="H3068"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w*, y \w suba|strong="H5927"\w* \w a|strong="H3068"\w* Jerusalén, \w que|strong="H4310"\w* \w está|strong="H1931"\w* \w en|strong="H5973"\w* \w Judá|strong="H3063"\w*, \w para|strong="H1961"\w* \w edificar|strong="H1129"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w* (\w él|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w Dios|strong="H3068"\w* \w que|strong="H4310"\w* habita \w en|strong="H5973"\w* Jerusalén).  
\v 4 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w que|strong="H1931"\w* haya quedado, \w en|strong="H5973"\w* \w cualquier|strong="H3605"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* more, \w que|strong="H1931"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5973"\w* \w su|strong="H1931"\w* \w lugar|strong="H4725"\w* \w le|strong="H1931"\w* ayuden \w con|strong="H5973"\w* \w plata|strong="H3701"\w*, \w oro|strong="H2091"\w*, bienes y acémilas, además \w de|strong="H5973"\w* las ofrendas \w voluntarias|strong="H5071"\w* \w para|strong="H5973"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Dios \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H5973"\w* Jerusalén”».   
\p
\v 5 Entonces se \w levantaron|strong="H6965"\w* \w los|strong="H3605"\w* \w jefes|strong="H7218"\w* de las \w casas|strong="H1004"\w* paternas de \w Judá|strong="H3063"\w* y de \w Benjamín|strong="H1144"\w*, con \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w levitas|strong="H3881"\w*, \w todos|strong="H3605"\w* \w aquellos|strong="H3605"\w* cuyo \w espíritu|strong="H7307"\w* \w Dios|strong="H3068"\w* había conmovido para \w subir|strong="H5927"\w* \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de Yahvé \w que|strong="H3605"\w* \w está|strong="H6965"\w* en Jerusalén.  
\v 6 \w Y|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* estaban \w a|strong="H3068"\w* su \w alrededor|strong="H5439"\w* \w les|strong="H5921"\w* prestaron ayuda \w con|strong="H5921"\w* vajilla \w de|strong="H5921"\w* \w plata|strong="H3701"\w*, \w con|strong="H5921"\w* \w oro|strong="H2091"\w*, bienes, acémilas \w y|strong="H5921"\w* cosas preciosas, \w además|strong="H5921"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* ofreció \w voluntariamente|strong="H5068"\w*.  
\v 7 \w También|strong="H3318"\w* el \w rey|strong="H4428"\w* \w Ciro|strong="H3566"\w* \w sacó|strong="H3318"\w* los utensilios \w de|strong="H5414"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Yahvé, que \w Nabucodonosor|strong="H5019"\w* había tomado \w de|strong="H5414"\w* Jerusalén y \w puesto|strong="H5414"\w* \w en|strong="H3318"\w* el \w templo|strong="H1004"\w* \w de|strong="H5414"\w* sus dioses;  
\v 8 \w los|strong="H5921"\w* \w sacó|strong="H3318"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*, \w por|strong="H5921"\w* \w mano|strong="H3027"\w* \w del|strong="H5921"\w* \w tesorero|strong="H1489"\w* \w Mitrídates|strong="H4990"\w*, quien \w los|strong="H5921"\w* entregó \w por|strong="H5921"\w* \w cuenta|strong="H5608"\w* \w a|strong="H3068"\w* Sesbasar, \w príncipe|strong="H5387"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 9 \w Y|strong="H3068"\w* este es el \w número|strong="H4557"\w* de ellos: \w treinta|strong="H7970"\w* fuentes de \w oro|strong="H2091"\w*, mil fuentes de \w plata|strong="H3701"\w*, \w veintinueve|strong="H6242"\w* \w cuchillos|strong="H4252"\w*,  
\v 10 \w treinta|strong="H7970"\w* \w tazones|strong="H3713"\w* de \w oro|strong="H2091"\w*, cuatrocientos \w diez|strong="H6235"\w* \w tazones|strong="H3713"\w* de \w plata|strong="H3701"\w* de segunda clase, y otros \w mil|strong="H6235"\w* recipientes.  
\v 11 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w de|strong="H5973"\w* \w oro|strong="H2091"\w* y \w de|strong="H5973"\w* \w plata|strong="H3701"\w* eran \w cinco|strong="H2568"\w* \w mil|strong="H3967"\w* cuatrocientos. \w Todo|strong="H3605"\w* esto \w lo|strong="H3605"\w* llevó Sesbasar cuando \w los|strong="H3605"\w* \w cautivos|strong="H1473"\w* \w fueron|strong="H5927"\w* subidos \w de|strong="H5973"\w* Babilonia \w a|strong="H3068"\w* Jerusalén.   
\c 2
\p
\v 1 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* la \w provincia|strong="H4082"\w* \w que|strong="H1121"\w* \w subieron|strong="H5927"\w* del \w cautiverio|strong="H1473"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* deportados, \w a|strong="H3068"\w* quienes \w Nabucodonosor|strong="H5020"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia, había llevado \w cautivos|strong="H7628"\w* \w a|strong="H3068"\w* Babilonia, y \w que|strong="H1121"\w* \w volvieron|strong="H7725"\w* \w a|strong="H3068"\w* Jerusalén y \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*, cada uno \w a|strong="H3068"\w* su \w ciudad|strong="H5892"\w*;  
\v 2 \w los|strong="H5973"\w* cuales vinieron \w con|strong="H5973"\w* \w Zorobabel|strong="H2216"\w*, \w Jesúa|strong="H3442"\w*, \w Nehemías|strong="H5166"\w*, \w Seraías|strong="H8304"\w*, \w Reelaías|strong="H7480"\w*, Mardoqueo, \w Bilsán|strong="H1114"\w*, \w Mispar|strong="H4558"\w*, Bigvai, \w Rehum|strong="H7348"\w* y \w Baana|strong="H1196"\w*.  
