\v 11 \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* \w la|strong="H5921"\w* copia \w de|strong="H5921"\w* \w la|strong="H5921"\w* carta \w que|strong="H5921"\w* \w dio|strong="H5414"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* Artajerjes \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Esdras|strong="H5830"\w*, \w escriba|strong="H5608"\w* versado \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w mandamientos|strong="H4687"\w* \w de|strong="H5921"\w* Yahvé \w y|strong="H5921"\w* \w en|strong="H5921"\w* sus \w estatutos|strong="H2706"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*:   
