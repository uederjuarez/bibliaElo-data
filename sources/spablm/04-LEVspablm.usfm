\v 22 De \w ellos|strong="H1992"\w* podréis comer: cualquier \w especie|strong="H4327"\w* de langosta migratoria, la langosta devoradora, \w el|strong="H1992"\w* grillo y \w el|strong="H1992"\w* saltamontes.  
\v 23 Pero \w cualquier|strong="H3605"\w* otro insecto \w alado|strong="H5775"\w* \w que|strong="H1931"\w* tenga cuatro patas os \w será|strong="H1931"\w* abominación.   
\p
\v 24 “‘\w Por|strong="H5704"\w* \w ellos|strong="H3605"\w* quedaréis impuros: \w cualquiera|strong="H3605"\w* \w que|strong="H5704"\w* toque sus cadáveres quedará impuro \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* \w tarde|strong="H6153"\w*.  
\v 25 \w Cualquiera|strong="H3605"\w* \w que|strong="H5704"\w* levante \w alguna|strong="H3605"\w* parte \w de|strong="H5704"\w* sus cadáveres \w lavará|strong="H3526"\w* sus vestidos \w y|strong="H5704"\w* quedará impuro \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* \w tarde|strong="H6153"\w*.   
\p
\v 26 “‘\w Todo|strong="H3605"\w* animal \w que|strong="H1931"\w* tenga \w la|strong="H1931"\w* \w pezuña|strong="H6536"\w* \w hendida|strong="H6536"\w* pero \w que|strong="H1931"\w* no \w esté|strong="H1931"\w* partida en dos, \w o|strong="H3068"\w* \w que|strong="H1931"\w* no rumie, os \w será|strong="H1931"\w* impuro. \w Todo|strong="H3605"\w* \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w los|strong="H1992"\w* toque \w será|strong="H1931"\w* impuro.  
