\v 44 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*. \w Santificaos|strong="H6942"\w*, \w pues|strong="H3588"\w*, \w y|strong="H3588"\w* \w sed|strong="H1961"\w* \w santos|strong="H6918"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* \w santo|strong="H6918"\w*. \w No|strong="H3808"\w* \w os|strong="H5921"\w* contaminaréis \w con|strong="H5921"\w* \w ningún|strong="H3605"\w* \w animal|strong="H5315"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* arrastra \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
