\v 14 \w De|strong="H4480"\w* esa \w ofrenda|strong="H7133"\w* \w presentará|strong="H7126"\w*, \w como|strong="H5921"\w* \w ofrenda|strong="H7133"\w* quemada \w a|strong="H3068"\w* Yahvé, \w la|strong="H5921"\w* grasa \w que|strong="H4480"\w* \w cubre|strong="H3680"\w* \w las|strong="H5921"\w* entrañas \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* grasa \w que|strong="H4480"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w*,  
\v 15 \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w riñones|strong="H3629"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w los|strong="H5921"\w* cubre \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* lomos, \w y|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w del|strong="H5921"\w* \w hígado|strong="H3516"\w*, \w que|strong="H5921"\w* \w quitará|strong="H5493"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w riñones|strong="H3629"\w*.  
\v 16 \w El|strong="H3605"\w* \w sacerdote|strong="H3548"\w* \w quemará|strong="H6999"\w* esto en \w el|strong="H3605"\w* \w altar|strong="H4196"\w*. Es alimento, una ofrenda \w quemada|strong="H6999"\w* de aroma agradable. \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* grasa le pertenece \w a|strong="H3068"\w* Yahvé.   
\p
\v 17 “‘Este \w será|strong="H3808"\w* un \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w* para \w todas|strong="H3605"\w* sus \w generaciones|strong="H1755"\w*, dondequiera \w que|strong="H3808"\w* vivan: \w No|strong="H3808"\w* deberán comer \w ninguna|strong="H3605"\w* grasa \w ni|strong="H3808"\w* \w ninguna|strong="H3605"\w* \w sangre|strong="H1818"\w*’”.   
\c 4
\p
\v 1 Yahvé le \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 2 “\w Diles|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: ‘\w Si|strong="H3588"\w* alguien \w peca|strong="H2398"\w* involuntariamente \w contra|strong="H3478"\w* \w cualquiera|strong="H3605"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w mandamientos|strong="H4687"\w* \w de|strong="H3588"\w* Yahvé, \w haciendo|strong="H6213"\w* algo \w que|strong="H3588"\w* \w no|strong="H3808"\w* está permitido \w hacer|strong="H6213"\w*, \w se|strong="H3808"\w* procederá \w así|strong="H3588"\w*:  
\v 3 \w Si|strong="H5921"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w ungido|strong="H4899"\w* \w peca|strong="H2398"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* ello hace culpable \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w ofrecerá|strong="H7126"\w* \w a|strong="H3068"\w* Yahvé un \w becerro|strong="H6499"\w* sin defecto \w como|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* su \w pecado|strong="H2403"\w*.  
\v 4 Llevará \w el|strong="H5921"\w* \w becerro|strong="H6499"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w ante|strong="H6440"\w* Yahvé, pondrá su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w del|strong="H5921"\w* animal \w y|strong="H5921"\w* \w lo|strong="H5921"\w* degollará \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé.  
\v 5 Luego el \w sacerdote|strong="H3548"\w* \w ungido|strong="H4899"\w* \w tomará|strong="H3947"\w* un poco \w de|strong="H1818"\w* la \w sangre|strong="H1818"\w* del \w becerro|strong="H6499"\w* y la \w llevará|strong="H3947"\w* \w a|strong="H3068"\w* la Tienda del Encuentro.  
\v 6 Mojará su dedo \w en|strong="H4480"\w* la \w sangre|strong="H1818"\w* y la \w rociará|strong="H5137"\w* \w siete|strong="H7651"\w* \w veces|strong="H6471"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* Yahvé, frente \w al|strong="H4480"\w* velo \w del|strong="H4480"\w* \w santuario|strong="H6944"\w*.  
\v 7 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w pondrá|strong="H5414"\w* también un poco \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w cuernos|strong="H7161"\w* \w del|strong="H4480"\w* \w altar|strong="H4196"\w* \w del|strong="H4480"\w* incienso \w aromático|strong="H5561"\w* \w que|strong="H4480"\w* \w está|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H4480"\w* Encuentro, \w delante|strong="H6440"\w* \w de|strong="H4480"\w* Yahvé, \w y|strong="H5921"\w* \w derramará|strong="H8210"\w* \w el|strong="H5921"\w* resto \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w del|strong="H4480"\w* \w becerro|strong="H6499"\w* \w al|strong="H5921"\w* \w pie|strong="H3247"\w* \w del|strong="H4480"\w* \w altar|strong="H4196"\w* \w del|strong="H4480"\w* \w holocausto|strong="H5930"\w*, \w que|strong="H4480"\w* \w está|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H4480"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H4480"\w* Encuentro.  
\v 8 \w Le|strong="H5921"\w* quitará \w toda|strong="H3605"\w* \w la|strong="H5921"\w* grasa \w al|strong="H5921"\w* \w becerro|strong="H6499"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w*: \w la|strong="H5921"\w* grasa \w que|strong="H4480"\w* \w cubre|strong="H3680"\w* \w las|strong="H5921"\w* entrañas \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H4480"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w*,  
\v 9 \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w riñones|strong="H3629"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w los|strong="H5921"\w* cubre \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* lomos, \w y|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w del|strong="H5921"\w* \w hígado|strong="H3516"\w*, \w que|strong="H5921"\w* \w quitará|strong="H5493"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w riñones|strong="H3629"\w*,  
\v 10 tal \w como|strong="H5921"\w* \w se|strong="H5921"\w* \w le|strong="H5921"\w* \w quita|strong="H7311"\w* \w al|strong="H5921"\w* toro \w del|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w de|strong="H5921"\w* paz. \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w los|strong="H5921"\w* \w quemará|strong="H6999"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w del|strong="H5921"\w* \w holocausto|strong="H5930"\w*.  
\v 11 Pero \w la|strong="H5921"\w* \w piel|strong="H5785"\w* \w del|strong="H5921"\w* \w becerro|strong="H6499"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* su \w carne|strong="H1320"\w*, \w con|strong="H5921"\w* su \w cabeza|strong="H7218"\w*, sus patas, sus entrañas \w y|strong="H5921"\w* su excremento,  
\v 12 es decir, \w todo|strong="H3605"\w* \w el|strong="H5921"\w* resto \w del|strong="H5921"\w* \w becerro|strong="H6499"\w*, \w lo|strong="H5921"\w* \w sacará|strong="H3318"\w* \w fuera|strong="H2351"\w* \w del|strong="H5921"\w* \w campamento|strong="H4264"\w* \w a|strong="H3068"\w* un \w lugar|strong="H4725"\w* \w limpio|strong="H2889"\w*, \w donde|strong="H5921"\w* \w se|strong="H5921"\w* \w echan|strong="H8211"\w* \w las|strong="H5921"\w* cenizas, \w y|strong="H5921"\w* allí \w lo|strong="H5921"\w* \w quemará|strong="H8313"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w*. \w Lo|strong="H5921"\w* \w quemará|strong="H8313"\w* \w donde|strong="H5921"\w* \w se|strong="H5921"\w* \w echan|strong="H8211"\w* \w las|strong="H5921"\w* cenizas.   
\p
\v 13 “‘\w Si|strong="H3808"\w* \w es|strong="H1697"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* comunidad \w de|strong="H1697"\w* \w Israel|strong="H3478"\w* \w la|strong="H3605"\w* \w que|strong="H3808"\w* peca \w por|strong="H1697"\w* error, \w sin|strong="H3808"\w* darse \w cuenta|strong="H1697"\w* \w de|strong="H1697"\w* \w que|strong="H3808"\w* han \w hecho|strong="H6213"\w* \w algo|strong="H1697"\w* \w que|strong="H3808"\w* Yahvé prohibió, \w son|strong="H3808"\w* culpables.  
\v 14 Cuando \w se|strong="H3045"\w* den cuenta \w del|strong="H5921"\w* \w pecado|strong="H2403"\w* \w que|strong="H5921"\w* \w cometieron|strong="H2398"\w*, \w la|strong="H5921"\w* comunidad \w ofrecerá|strong="H7126"\w* un \w becerro|strong="H6499"\w* \w como|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* llevará \w ante|strong="H6440"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro.  
\v 15 \w Los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* comunidad \w pondrán|strong="H5564"\w* sus \w manos|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w del|strong="H5921"\w* \w becerro|strong="H6499"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w el|strong="H5921"\w* animal será degollado \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé.  
\v 16 El \w sacerdote|strong="H3548"\w* \w ungido|strong="H4899"\w* llevará un poco \w de|strong="H1818"\w* la \w sangre|strong="H1818"\w* del \w becerro|strong="H6499"\w* \w a|strong="H3068"\w* la Tienda del Encuentro.  
\v 17 Mojará su dedo \w en|strong="H4480"\w* la \w sangre|strong="H1818"\w* y la \w rociará|strong="H5137"\w* \w siete|strong="H7651"\w* \w veces|strong="H6471"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* Yahvé, frente \w al|strong="H4480"\w* velo.  
\v 18 \w Pondrá|strong="H5414"\w* un poco \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w cuernos|strong="H7161"\w* \w del|strong="H4480"\w* \w altar|strong="H4196"\w* \w que|strong="H4480"\w* \w está|strong="H5921"\w* \w ante|strong="H6440"\w* Yahvé, \w en|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H4480"\w* Encuentro, \w y|strong="H5921"\w* \w derramará|strong="H8210"\w* \w el|strong="H5921"\w* resto \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w al|strong="H5921"\w* \w pie|strong="H3247"\w* \w del|strong="H4480"\w* \w altar|strong="H4196"\w* \w del|strong="H4480"\w* \w holocausto|strong="H5930"\w*, \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H4480"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H4480"\w* Encuentro.  
\v 19 Luego le quitará \w toda|strong="H3605"\w* \w la|strong="H3605"\w* grasa y \w la|strong="H3605"\w* \w quemará|strong="H6999"\w* \w en|strong="H4480"\w* \w el|strong="H3605"\w* \w altar|strong="H4196"\w*.  
\v 20 \w Hará|strong="H6213"\w* \w con|strong="H5921"\w* este \w becerro|strong="H6499"\w* \w lo|strong="H5921"\w* mismo \w que|strong="H5921"\w* \w hizo|strong="H6213"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w becerro|strong="H6499"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w*. \w Así|strong="H3651"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w hará|strong="H6213"\w* \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w ellos|strong="H1992"\w*, \w y|strong="H5921"\w* \w serán|strong="H1992"\w* perdonados.  
\v 21 Después \w sacará|strong="H3318"\w* \w el|strong="H1931"\w* \w becerro|strong="H6499"\w* \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w* y \w lo|strong="H1931"\w* \w quemará|strong="H8313"\w* \w como|strong="H1931"\w* \w quemó|strong="H8313"\w* \w el|strong="H1931"\w* \w primer|strong="H7223"\w* \w becerro|strong="H6499"\w*. \w Es|strong="H1931"\w* \w la|strong="H1931"\w* ofrenda por \w el|strong="H1931"\w* \w pecado|strong="H2403"\w* de \w la|strong="H1931"\w* comunidad.   
\p
\v 22 “‘Cuando un \w jefe|strong="H5387"\w* \w peque|strong="H2398"\w* y por error \w haga|strong="H6213"\w* algo \w que|strong="H3808"\w* Yahvé su \w Dios|strong="H3068"\w* \w ha|strong="H3808"\w* prohibido, \w será|strong="H3808"\w* culpable.  
\v 23 \w En|strong="H8549"\w* cuanto \w se|strong="H3045"\w* le haga \w saber|strong="H3045"\w* el \w pecado|strong="H2403"\w* \w que|strong="H3045"\w* \w cometió|strong="H2398"\w*, presentará como \w ofrenda|strong="H7133"\w* un \w macho|strong="H2145"\w* \w cabrío|strong="H5795"\w* sin defecto.  
