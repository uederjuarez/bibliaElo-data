\v 28 Luego \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w pondrá|strong="H5414"\w* \w del|strong="H4480"\w* \w aceite|strong="H8081"\w* \w que|strong="H4480"\w* tiene \w en|strong="H5921"\w* su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* lóbulo \w de|strong="H4480"\w* \w la|strong="H5921"\w* oreja \w derecha|strong="H3233"\w* \w del|strong="H4480"\w* \w que|strong="H4480"\w* \w se|strong="H5921"\w* purifica, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* pulgar \w de|strong="H4480"\w* su \w mano|strong="H3027"\w* \w derecha|strong="H3233"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* dedo gordo \w de|strong="H4480"\w* su \w pie|strong="H7272"\w* \w derecho|strong="H3233"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* mismo \w lugar|strong="H4725"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w del|strong="H4480"\w* sacrificio \w por|strong="H5921"\w* \w la|strong="H5921"\w* culpa.  
\v 29 \w El|strong="H5921"\w* resto \w del|strong="H4480"\w* \w aceite|strong="H8081"\w* \w que|strong="H4480"\w* quede \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3709"\w* \w del|strong="H4480"\w* \w sacerdote|strong="H3548"\w* \w lo|strong="H5921"\w* \w pondrá|strong="H5414"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w del|strong="H4480"\w* \w que|strong="H4480"\w* \w se|strong="H5921"\w* purifica, \w para|strong="H5921"\w* hacer \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w* \w ante|strong="H6440"\w* Yahvé.  
\v 30 \w Ofrecerá|strong="H6213"\w* una \w de|strong="H4480"\w* las \w tórtolas|strong="H8449"\w* \w o|strong="H3068"\w* uno \w de|strong="H4480"\w* \w los|strong="H1121"\w* pichones, según \w lo|strong="H6213"\w* \w que|strong="H4480"\w* haya podido conseguir,  
\v 31 \w de|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* haya podido adquirir, uno \w como|strong="H5921"\w* sacrificio \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* otro \w como|strong="H5921"\w* \w holocausto|strong="H5930"\w*, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* cereal. Así \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* hará \w expiación|strong="H3722"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* purifica».   
\p
\v 32 \w Esta|strong="H2063"\w* \w es|strong="H3027"\w* \w la|strong="H2063"\w* \w ley|strong="H8451"\w* para aquel \w que|strong="H3808"\w* tiene una infección de \w lepra|strong="H6883"\w* y \w no|strong="H3808"\w* dispone de medios suficientes para su purificación.   
\p
\v 33 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón, \w diciendo|strong="H1696"\w*:  
\v 34 “\w Cuando|strong="H3588"\w* hayáis entrado \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w*, \w que|strong="H3588"\w* \w yo|strong="H3588"\w* os \w doy|strong="H5414"\w* \w en|strong="H3588"\w* posesión, \w y|strong="H3588"\w* \w yo|strong="H3588"\w* ponga una \w plaga|strong="H5061"\w* \w de|strong="H3588"\w* moho \w en|strong="H3588"\w* una \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* vuestra posesión,  
\v 35 el dueño de la \w casa|strong="H1004"\w* irá y se lo comunicará al \w sacerdote|strong="H3548"\w*, diciendo: ‘Me parece \w ver|strong="H7200"\w* como una \w plaga|strong="H5061"\w* en mi \w casa|strong="H1004"\w*’.  
\v 36 \w El|strong="H3605"\w* \w sacerdote|strong="H3548"\w* ordenará \w que|strong="H3808"\w* vacíen \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w antes|strong="H2962"\w* de \w que|strong="H3808"\w* \w él|strong="H3605"\w* \w entre|strong="H3808"\w* \w a|strong="H3068"\w* examinar \w la|strong="H3605"\w* \w plaga|strong="H5061"\w*, para \w que|strong="H3808"\w* \w no|strong="H3808"\w* sea declarado impuro \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* hay en \w ella|strong="H3605"\w*. Después \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* entrará para examinar \w la|strong="H3605"\w* \w casa|strong="H1004"\w*.  
\v 37 Examinará la mancha. \w Si|strong="H2009"\w* la mancha está \w en|strong="H4480"\w* las paredes \w de|strong="H4480"\w* la \w casa|strong="H1004"\w* \w con|strong="H4480"\w* cavidades verdosas \w o|strong="H3068"\w* rojizas, y su \w aspecto|strong="H4758"\w* es \w más|strong="H4480"\w* profundo \w que|strong="H4480"\w* la superficie \w de|strong="H4480"\w* la \w pared|strong="H7023"\w*,  
\v 38 \w entonces|strong="H3117"\w* el \w sacerdote|strong="H3548"\w* \w saldrá|strong="H3318"\w* \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* \w de|strong="H4480"\w* la \w casa|strong="H1004"\w* y la mantendrá \w cerrada|strong="H5462"\w* durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.  
\v 39 El \w sacerdote|strong="H3548"\w* \w volverá|strong="H7725"\w* al \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* y la examinará. \w Si|strong="H2009"\w* la mancha se ha extendido por las paredes de la \w casa|strong="H1004"\w*,  
\v 40 el \w sacerdote|strong="H3548"\w* ordenará que arranquen las piedras en las que está la mancha, y que las arrojen en un \w lugar|strong="H4725"\w* impuro \w fuera|strong="H2351"\w* de la \w ciudad|strong="H5892"\w*.  
\v 41 Hará raspar \w todo|strong="H5439"\w* el interior de la \w casa|strong="H1004"\w*, y echarán el \w polvo|strong="H6083"\w* que hayan raspado \w fuera|strong="H2351"\w* de la \w ciudad|strong="H5892"\w*, en un \w lugar|strong="H4725"\w* impuro.  
\v 42 \w Tomarán|strong="H3947"\w* otras piedras y las pondrán \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* las primeras; \w tomarán|strong="H3947"\w* otra mezcla y revocarán la \w casa|strong="H1004"\w*.   
\p
\v 43 “Si la mancha \w vuelve|strong="H7725"\w* \w a|strong="H3068"\w* brotar en la \w casa|strong="H1004"\w* después de haber arrancado las piedras, de haber raspado la \w casa|strong="H1004"\w* y de haberla revocado de nuevo,  
\v 44 entonces \w el|strong="H1931"\w* \w sacerdote|strong="H3548"\w* entrará y \w la|strong="H1931"\w* examinará. \w Si|strong="H1931"\w* \w la|strong="H1931"\w* mancha \w se|strong="H1931"\w* ha extendido en \w la|strong="H1931"\w* \w casa|strong="H1004"\w*, \w es|strong="H1931"\w* un moho maligno en \w la|strong="H1931"\w* \w casa|strong="H1004"\w*; \w es|strong="H1931"\w* impura.  
\v 45 \w Derribará|strong="H5422"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w*, sus piedras, su \w madera|strong="H6086"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* estuco de \w la|strong="H3605"\w* \w casa|strong="H1004"\w*, y \w lo|strong="H3605"\w* \w sacará|strong="H3318"\w* \w fuera|strong="H2351"\w* de \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w a|strong="H3068"\w* un \w lugar|strong="H4725"\w* impuro.   
\p
\v 46 “\w Cualquiera|strong="H3605"\w* \w que|strong="H5704"\w* entre \w en|strong="H5704"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* durante \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w que|strong="H5704"\w* esté \w cerrada|strong="H5462"\w* quedará impuro \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* \w tarde|strong="H6153"\w*.  
\v 47 El que duerma en la \w casa|strong="H1004"\w* \w lavará|strong="H3526"\w* sus vestidos, y el que coma en la \w casa|strong="H1004"\w* \w lavará|strong="H3526"\w* sus vestidos.   
\p
\v 48 «\w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w* entra \w y|strong="H3588"\w* \w la|strong="H3588"\w* examina, \w y|strong="H3588"\w* \w ve|strong="H7200"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* mancha \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* extendido \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* después \w de|strong="H3588"\w* \w haber|strong="H3808"\w* sido revocada, \w entonces|strong="H3588"\w* \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w* declarará \w la|strong="H3588"\w* \w casa|strong="H1004"\w* pura, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w plaga|strong="H5061"\w* \w ha|strong="H3808"\w* sanado.  
\v 49 Para purificar la \w casa|strong="H1004"\w* \w tomará|strong="H3947"\w* \w dos|strong="H8147"\w* aves, \w madera|strong="H6086"\w* de cedro, hilo escarlata \w e|strong="H3068"\w* hisopo.  
\v 50 Degollará una \w de|strong="H5921"\w* \w las|strong="H5921"\w* aves \w en|strong="H5921"\w* una \w vasija|strong="H3627"\w* \w de|strong="H5921"\w* barro \w sobre|strong="H5921"\w* \w agua|strong="H4325"\w* \w de|strong="H5921"\w* manantial.  
\v 51 \w Tomará|strong="H3947"\w* la \w madera|strong="H6086"\w* \w de|strong="H1818"\w* cedro, el hisopo, el hilo escarlata y el \w ave|strong="H6833"\w* \w viva|strong="H2416"\w*, los mojará en la \w sangre|strong="H1818"\w* del \w ave|strong="H6833"\w* degollada y en el \w agua|strong="H4325"\w* \w de|strong="H1818"\w* manantial, y \w rociará|strong="H5137"\w* la \w casa|strong="H1004"\w* \w siete|strong="H7651"\w* \w veces|strong="H6471"\w*.  
\v 52 Purificará la \w casa|strong="H1004"\w* con la \w sangre|strong="H1818"\w* del \w ave|strong="H6833"\w*, con el \w agua|strong="H4325"\w* \w de|strong="H1818"\w* manantial, con el \w ave|strong="H6833"\w* \w viva|strong="H2416"\w*, con la \w madera|strong="H6086"\w* \w de|strong="H1818"\w* cedro, con el hisopo y con el hilo escarlata.  
\v 53 \w Después|strong="H5921"\w* soltará \w el|strong="H5921"\w* \w ave|strong="H6833"\w* \w viva|strong="H2416"\w* \w fuera|strong="H2351"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w en|strong="H5921"\w* \w campo|strong="H7704"\w* abierto. Así hará \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, \w y|strong="H5921"\w* quedará pura».   
\p
\v 54 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H3605"\w* \w ley|strong="H8451"\w* para \w cualquier|strong="H3605"\w* infección de \w lepra|strong="H6883"\w*, para \w la|strong="H3605"\w* \w tiña|strong="H5424"\w*,  
\v 55 para la plaga en un vestido \w o|strong="H3068"\w* en una \w casa|strong="H1004"\w*,  
\v 56 para la \w hinchazón|strong="H7613"\w*, para la erupción y para la mancha brillante;  
\v 57 para \w enseñar|strong="H3384"\w* \w cuándo|strong="H3117"\w* \w es|strong="H2063"\w* impuro y \w cuándo|strong="H3117"\w* \w es|strong="H2063"\w* \w puro|strong="H2889"\w*.  
\p \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w ley|strong="H8451"\w* sobre \w la|strong="H2063"\w* \w lepra|strong="H6883"\w*.   
\c 15
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Hablad|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* decidles: ‘\w Cuando|strong="H3588"\w* un \w hombre|strong="H1121"\w* \w tenga|strong="H1961"\w* un \w flujo|strong="H2101"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* cuerpo, \w será|strong="H1961"\w* impuro \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w flujo|strong="H2101"\w*.  
\v 3 \w Esta|strong="H2063"\w* \w será|strong="H1961"\w* \w su|strong="H1931"\w* impureza por causa de \w su|strong="H1931"\w* \w flujo|strong="H2101"\w*: ya \w sea|strong="H1961"\w* \w que|strong="H1931"\w* \w su|strong="H1931"\w* cuerpo destile \w el|strong="H1931"\w* \w flujo|strong="H2101"\w* \w o|strong="H3068"\w* \w que|strong="H1931"\w* \w su|strong="H1931"\w* cuerpo retenga \w el|strong="H1931"\w* \w flujo|strong="H2101"\w*, \w es|strong="H1931"\w* \w su|strong="H1931"\w* impureza.   
\p
\v 4 “‘\w Toda|strong="H3605"\w* \w cama|strong="H4904"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* acueste \w el|strong="H5921"\w* \w que|strong="H5921"\w* tiene \w el|strong="H5921"\w* flujo \w será|strong="H2930"\w* impura, \w y|strong="H5921"\w* \w cualquier|strong="H3605"\w* \w mueble|strong="H3627"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* siente \w será|strong="H2930"\w* impuro.  
\v 5 Cualquiera \w que|strong="H5704"\w* toque su \w cama|strong="H4904"\w* \w lavará|strong="H3526"\w* sus vestidos, se bañará \w en|strong="H5704"\w* \w agua|strong="H4325"\w* \w y|strong="H5704"\w* quedará impuro \w hasta|strong="H5704"\w* la \w tarde|strong="H6153"\w*.  
\v 6 \w El|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* siente \w sobre|strong="H5921"\w* cualquier \w mueble|strong="H3627"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* haya \w sentado|strong="H3427"\w* \w el|strong="H5921"\w* hombre \w que|strong="H5921"\w* tiene \w el|strong="H5921"\w* flujo, \w lavará|strong="H3526"\w* sus vestidos, \w se|strong="H5921"\w* bañará \w en|strong="H5921"\w* \w agua|strong="H4325"\w* \w y|strong="H5921"\w* quedará impuro \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* \w tarde|strong="H6153"\w*.   
\p
\v 7 “‘El \w que|strong="H5704"\w* toque el cuerpo del \w que|strong="H5704"\w* tiene el flujo \w lavará|strong="H3526"\w* sus vestidos, se bañará \w en|strong="H5704"\w* \w agua|strong="H4325"\w* \w y|strong="H5704"\w* quedará impuro \w hasta|strong="H5704"\w* la \w tarde|strong="H6153"\w*.   
\p
\v 8 “‘\w Si|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* tiene \w el|strong="H3588"\w* flujo escupe sobre alguien \w que|strong="H3588"\w* está \w puro|strong="H2889"\w*, este \w lavará|strong="H3526"\w* sus vestidos, se bañará \w en|strong="H5704"\w* \w agua|strong="H4325"\w* \w y|strong="H3588"\w* quedará impuro \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* \w tarde|strong="H6153"\w*.   
\p
\v 9 “‘\w Cualquier|strong="H3605"\w* montura \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H5921"\w* cabalgue \w el|strong="H5921"\w* \w que|strong="H5921"\w* tiene \w el|strong="H5921"\w* flujo \w será|strong="H2930"\w* impura.  
\v 10 \w Cualquiera|strong="H3605"\w* \w que|strong="H5704"\w* toque algo \w que|strong="H5704"\w* \w haya|strong="H1961"\w* \w estado|strong="H1961"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w él|strong="H3605"\w* \w quedará|strong="H1961"\w* impuro \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* \w tarde|strong="H6153"\w*. \w El|strong="H3605"\w* \w que|strong="H5704"\w* transporte esas cosas \w lavará|strong="H3526"\w* sus vestidos, \w se|strong="H1961"\w* bañará \w en|strong="H5704"\w* \w agua|strong="H4325"\w* \w y|strong="H5704"\w* \w quedará|strong="H1961"\w* impuro \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* \w tarde|strong="H6153"\w*.   
\p
\v 11 “‘\w Cualquiera|strong="H3605"\w* \w a|strong="H3068"\w* \w quien|strong="H3605"\w* toque \w el|strong="H3605"\w* \w que|strong="H3808"\w* tiene \w el|strong="H3605"\w* flujo \w sin|strong="H3808"\w* haberse lavado las \w manos|strong="H3027"\w* \w con|strong="H5060"\w* \w agua|strong="H4325"\w*, \w lavará|strong="H3526"\w* sus vestidos, \w se|strong="H3808"\w* bañará \w en|strong="H5704"\w* \w agua|strong="H4325"\w* \w y|strong="H5704"\w* quedará impuro \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* \w tarde|strong="H6153"\w*.   
\p
\v 12 “‘\w La|strong="H3605"\w* \w vasija|strong="H3627"\w* \w de|strong="H4325"\w* barro \w que|strong="H4325"\w* toque \w el|strong="H3605"\w* \w que|strong="H4325"\w* tiene \w el|strong="H3605"\w* flujo \w será|strong="H7665"\w* quebrada, y \w toda|strong="H3605"\w* \w vasija|strong="H3627"\w* \w de|strong="H4325"\w* \w madera|strong="H6086"\w* \w será|strong="H7665"\w* enjuagada \w con|strong="H5060"\w* \w agua|strong="H4325"\w*.   
\p
\v 13 “‘\w Cuando|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* tiene \w el|strong="H3588"\w* \w flujo|strong="H2101"\w* sane \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w flujo|strong="H2101"\w*, \w contará|strong="H5608"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w para|strong="H3588"\w* \w su|strong="H3588"\w* purificación, \w lavará|strong="H3526"\w* sus vestidos, bañará \w su|strong="H3588"\w* cuerpo \w en|strong="H3588"\w* \w agua|strong="H4325"\w* \w de|strong="H3588"\w* manantial \w y|strong="H3588"\w* quedará puro.   
\p
\v 14 “‘Al \w octavo|strong="H8066"\w* \w día|strong="H3117"\w* \w tomará|strong="H3947"\w* \w dos|strong="H8147"\w* \w tórtolas|strong="H8449"\w* \w o|strong="H3068"\w* \w dos|strong="H8147"\w* pichones, vendrá \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* \w de|strong="H6440"\w* la Tienda del Encuentro, y se \w los|strong="H1121"\w* \w dará|strong="H5414"\w* al \w sacerdote|strong="H3548"\w*.  
\v 15 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w los|strong="H5921"\w* \w ofrecerá|strong="H6213"\w*, uno \w como|strong="H5921"\w* sacrificio \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* otro \w como|strong="H5921"\w* \w holocausto|strong="H5930"\w*. Así \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w hará|strong="H6213"\w* \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* su \w flujo|strong="H2101"\w*.   
\p
\v 16 “‘\w Si|strong="H3588"\w* un hombre tiene una emisión \w de|strong="H4480"\w* \w semen|strong="H7902"\w*, bañará \w todo|strong="H3605"\w* \w su|strong="H3588"\w* cuerpo \w en|strong="H4480"\w* \w agua|strong="H4325"\w* \w y|strong="H3588"\w* quedará impuro \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* \w tarde|strong="H6153"\w*.  
