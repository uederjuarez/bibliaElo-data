\v 46 \w Todo|strong="H3605"\w* \w el|strong="H1931"\w* \w tiempo|strong="H3117"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* \w llaga|strong="H5061"\w* \w esté|strong="H1931"\w* en \w él|strong="H1931"\w*, \w será|strong="H1931"\w* impuro. \w Es|strong="H1931"\w* impuro, por \w lo|strong="H1931"\w* \w que|strong="H1931"\w* vivirá aislado. \w Su|strong="H1931"\w* \w morada|strong="H3427"\w* \w estará|strong="H3427"\w* \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w*.   
\p
\v 47 “\w En|strong="H3588"\w* \w cuanto|strong="H3588"\w* al vestido \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w haya|strong="H1961"\w* una infección \w de|strong="H3588"\w* \w lepra|strong="H6883"\w*, \w sea|strong="H1961"\w* un vestido \w de|strong="H3588"\w* \w lana|strong="H6785"\w* \w o|strong="H3068"\w* \w de|strong="H3588"\w* \w lino|strong="H6593"\w*;  
\v 48 sea en \w la|strong="H3605"\w* urdimbre \w o|strong="H3068"\w* en \w la|strong="H3605"\w* \w trama|strong="H6154"\w* de \w lino|strong="H6593"\w* \w o|strong="H3068"\w* de \w lana|strong="H6785"\w*, sea en \w el|strong="H3605"\w* cuero \w o|strong="H3068"\w* en \w cualquier|strong="H3605"\w* objeto de cuero;  
\v 49 \w si|strong="H1931"\w* \w la|strong="H1931"\w* mancha \w es|strong="H1931"\w* verdosa \w o|strong="H3068"\w* rojiza en \w el|strong="H1931"\w* vestido, en \w el|strong="H1931"\w* cuero, en \w la|strong="H1931"\w* urdimbre, en \w la|strong="H1931"\w* \w trama|strong="H6154"\w* \w o|strong="H3068"\w* en \w cualquier|strong="H3605"\w* objeto de cuero, \w es|strong="H1931"\w* una infección de \w lepra|strong="H6883"\w* y \w será|strong="H1961"\w* mostrada al \w sacerdote|strong="H3548"\w*.  
\v 50 El \w sacerdote|strong="H3548"\w* examinará la infección y aislará el objeto infectado durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.  
\v 51 Al \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* examinará \w la|strong="H1931"\w* infección. \w Si|strong="H3588"\w* \w se|strong="H1931"\w* ha extendido \w en|strong="H3588"\w* \w el|strong="H1931"\w* vestido, \w en|strong="H3588"\w* \w la|strong="H1931"\w* urdimbre, \w en|strong="H3588"\w* \w la|strong="H1931"\w* \w trama|strong="H6154"\w*, \w o|strong="H3068"\w* \w en|strong="H3588"\w* \w el|strong="H1931"\w* cuero, \w cualquiera|strong="H3605"\w* \w que|strong="H3588"\w* sea \w el|strong="H1931"\w* uso \w que|strong="H3588"\w* \w se|strong="H1931"\w* \w le|strong="H1931"\w* \w dé|strong="H3588"\w*, \w la|strong="H1931"\w* infección \w es|strong="H1931"\w* un moho maligno. \w Es|strong="H1931"\w* impuro.  
\v 52 \w Quemará|strong="H8313"\w* \w el|strong="H1931"\w* vestido, \w la|strong="H1931"\w* urdimbre \w o|strong="H3068"\w* \w la|strong="H1931"\w* \w trama|strong="H6154"\w* \w en|strong="H3588"\w* \w lana|strong="H6785"\w* \w o|strong="H3068"\w* \w en|strong="H3588"\w* \w lino|strong="H6593"\w*, \w o|strong="H3068"\w* \w cualquier|strong="H3605"\w* objeto \w de|strong="H3588"\w* cuero \w en|strong="H3588"\w* \w el|strong="H1931"\w* \w que|strong="H3588"\w* \w esté|strong="H1931"\w* \w la|strong="H1931"\w* infección, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* un moho maligno. \w Será|strong="H1961"\w* quemado al fuego.   
\p
\v 53 «Pero \w si|strong="H3808"\w* \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* \w lo|strong="H3808"\w* examina, y \w ve|strong="H7200"\w* \w que|strong="H3808"\w* \w la|strong="H3605"\w* mancha \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* extendido en \w el|strong="H3605"\w* vestido, \w ni|strong="H3808"\w* en \w la|strong="H3605"\w* urdimbre, \w ni|strong="H3808"\w* en \w la|strong="H3605"\w* \w trama|strong="H6154"\w*, \w ni|strong="H3808"\w* en \w ningún|strong="H3605"\w* objeto de cuero,  
\v 54 \w entonces|strong="H3117"\w* el \w sacerdote|strong="H3548"\w* ordenará \w que|strong="H3117"\w* laven el objeto en \w que|strong="H3117"\w* está la mancha, y lo aislará \w siete|strong="H7651"\w* \w días|strong="H3117"\w* más.  
\v 55 Después \w el|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w lo|strong="H1931"\w* examinará, una vez lavada \w la|strong="H1931"\w* mancha. \w Si|strong="H3808"\w* \w la|strong="H1931"\w* mancha \w no|strong="H3808"\w* \w ha|strong="H3808"\w* cambiado \w de|strong="H5869"\w* aspecto, \w aunque|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* haya extendido, \w el|strong="H1931"\w* objeto \w es|strong="H1931"\w* impuro; \w lo|strong="H1931"\w* \w quemarás|strong="H8313"\w* al fuego. \w Es|strong="H1931"\w* una \w corrosión|strong="H6356"\w*, ya sea \w que|strong="H1931"\w* \w el|strong="H1931"\w* desgaste \w esté|strong="H1931"\w* por \w el|strong="H1931"\w* derecho \w o|strong="H3068"\w* por \w el|strong="H1931"\w* revés.  
\v 56 \w Si|strong="H2009"\w* el \w sacerdote|strong="H3548"\w* lo examina, y \w ve|strong="H7200"\w* \w que|strong="H4480"\w* la mancha \w se|strong="H4480"\w* ha desvanecido después \w de|strong="H4480"\w* haberla lavado, entonces la arrancará \w del|strong="H4480"\w* vestido, \w del|strong="H4480"\w* cuero, \w de|strong="H4480"\w* la urdimbre \w o|strong="H3068"\w* \w de|strong="H4480"\w* la \w trama|strong="H6154"\w*.  
\v 57 \w Y|strong="H3068"\w* \w si|strong="H1931"\w* aparece \w de|strong="H5750"\w* nuevo \w en|strong="H5750"\w* \w el|strong="H1931"\w* vestido, \w en|strong="H5750"\w* \w la|strong="H1931"\w* urdimbre, \w en|strong="H5750"\w* \w la|strong="H1931"\w* \w trama|strong="H6154"\w* \w o|strong="H3068"\w* \w en|strong="H5750"\w* \w cualquier|strong="H3605"\w* objeto \w de|strong="H5750"\w* cuero, \w es|strong="H1931"\w* una erupción \w que|strong="H1931"\w* \w se|strong="H1931"\w* extiende. \w Quemarás|strong="H8313"\w* al fuego \w aquello|strong="H1931"\w* \w en|strong="H5750"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w esté|strong="H1931"\w* \w la|strong="H1931"\w* mancha.  
\v 58 Pero \w el|strong="H3605"\w* vestido, \w la|strong="H3605"\w* urdimbre, \w la|strong="H3605"\w* \w trama|strong="H6154"\w* \w o|strong="H3068"\w* \w cualquier|strong="H3605"\w* objeto de cuero \w que|strong="H1992"\w* laves, si \w la|strong="H3605"\w* mancha desaparece de \w ellos|strong="H1992"\w*, \w se|strong="H1992"\w* \w lavará|strong="H3526"\w* por \w segunda|strong="H8145"\w* vez y quedará puro».   
\p
\v 59 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w ley|strong="H8451"\w* sobre \w la|strong="H2063"\w* \w plaga|strong="H5061"\w* del moho en un vestido de \w lana|strong="H6785"\w* \w o|strong="H3068"\w* de \w lino|strong="H6593"\w*, en \w la|strong="H2063"\w* urdimbre \w o|strong="H3068"\w* en \w la|strong="H2063"\w* \w trama|strong="H6154"\w*, \w o|strong="H3068"\w* en \w cualquier|strong="H3605"\w* objeto de cuero, para declararlo puro \w o|strong="H3068"\w* impuro.   
\c 14
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:   
\p
\v 2 “\w Esta|strong="H2063"\w* \w será|strong="H1961"\w* \w la|strong="H2063"\w* \w ley|strong="H8451"\w* \w para|strong="H1961"\w* el \w leproso|strong="H6879"\w* en el \w día|strong="H3117"\w* de su purificación: \w será|strong="H1961"\w* llevado al \w sacerdote|strong="H3548"\w*,  
\v 3 y \w el|strong="H4264"\w* \w sacerdote|strong="H3548"\w* \w saldrá|strong="H3318"\w* \w fuera|strong="H2351"\w* \w del|strong="H4480"\w* \w campamento|strong="H4264"\w*. \w El|strong="H4264"\w* \w sacerdote|strong="H3548"\w* lo examinará, y \w si|strong="H2009"\w* la infección \w de|strong="H4480"\w* la \w lepra|strong="H6883"\w* ha sanado \w en|strong="H4480"\w* \w el|strong="H4264"\w* \w leproso|strong="H6879"\w*,  
