\v 31 “‘Así mantendréis \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* separados \w de|strong="H1121"\w* sus impurezas, para \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w mueran|strong="H4191"\w* \w en|strong="H8432"\w* su impureza por \w haber|strong="H3808"\w* \w contaminado|strong="H2930"\w* mi Morada \w que|strong="H3808"\w* está \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* ellos’”.   
\p
\v 32 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w ley|strong="H8451"\w* \w para|strong="H4480"\w* el \w que|strong="H4480"\w* tiene un flujo y \w para|strong="H4480"\w* el \w que|strong="H4480"\w* tiene una emisión \w de|strong="H4480"\w* \w semen|strong="H7902"\w* \w por|strong="H4480"\w* \w la|strong="H2063"\w* cual queda impuro;  
\v 33 \w para|strong="H5973"\w* la mujer que está indispuesta por su menstruación, \w para|strong="H5973"\w* \w el|strong="H5973"\w* hombre \w o|strong="H3068"\w* la mujer que tenga un \w flujo|strong="H2101"\w*, y \w para|strong="H5973"\w* \w el|strong="H5973"\w* hombre que se acueste \w con|strong="H5973"\w* una mujer impura.   
\c 16
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* después \w de|strong="H6440"\w* la \w muerte|strong="H4194"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* Aarón, \w que|strong="H1121"\w* \w murieron|strong="H4191"\w* al acercarse \w a|strong="H3068"\w* la \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.  
\v 2 Yahvé \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “Dile \w a|strong="H3068"\w* tu hermano Aarón \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w entre|strong="H5921"\w* \w en|strong="H5921"\w* \w cualquier|strong="H3605"\w* momento \w en|strong="H5921"\w* \w el|strong="H5921"\w* Lugar \w Santísimo|strong="H6944"\w*, detrás \w del|strong="H5921"\w* velo, \w delante|strong="H6440"\w* \w del|strong="H5921"\w* propiciatorio \w que|strong="H3588"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* arca, \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w muera|strong="H4191"\w*; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w me|strong="H5921"\w* apareceré \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w nube|strong="H6051"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* propiciatorio.   
\p
\v 3 “Con \w esto|strong="H2063"\w* entrará Aarón en \w el|strong="H1121"\w* \w santuario|strong="H6944"\w*: con un \w novillo|strong="H1241"\w* para \w el|strong="H1121"\w* sacrificio por \w el|strong="H1121"\w* \w pecado|strong="H2403"\w* \w y|strong="H1241"\w* un carnero para \w el|strong="H1121"\w* \w holocausto|strong="H5930"\w*.  
\v 4 \w Se|strong="H1961"\w* \w vestirá|strong="H1961"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* túnica sagrada \w de|strong="H5921"\w* lino, llevará calzoncillos \w de|strong="H5921"\w* lino \w sobre|strong="H5921"\w* \w su|strong="H1992"\w* cuerpo, \w se|strong="H1961"\w* ceñirá \w el|strong="H5921"\w* fajín \w de|strong="H5921"\w* lino \w y|strong="H5921"\w* \w se|strong="H1961"\w* cubrirá \w con|strong="H5921"\w* \w el|strong="H5921"\w* turbante \w de|strong="H5921"\w* lino. \w Estas|strong="H1992"\w* \w son|strong="H1961"\w* \w vestiduras|strong="H3801"\w* \w sagradas|strong="H6944"\w*. Bañará \w su|strong="H1992"\w* cuerpo \w en|strong="H5921"\w* \w agua|strong="H4325"\w* \w y|strong="H5921"\w* \w se|strong="H1961"\w* \w las|strong="H1992"\w* pondrá.  
\v 5 \w De|strong="H1121"\w* la asamblea \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w tomará|strong="H3947"\w* \w dos|strong="H8147"\w* \w machos|strong="H8163"\w* cabríos para sacrificio por \w el|strong="H1121"\w* \w pecado|strong="H2403"\w* y un carnero para \w holocausto|strong="H5930"\w*.   
\p
\v 6 “Aarón \w ofrecerá|strong="H7126"\w* el \w novillo|strong="H6499"\w* como su propio sacrificio \w por|strong="H1157"\w* el \w pecado|strong="H2403"\w*, y hará \w expiación|strong="H3722"\w* \w por|strong="H1157"\w* \w sí|strong="H1157"\w* mismo y \w por|strong="H1157"\w* su \w casa|strong="H1004"\w*.  
\v 7 \w Tomará|strong="H3947"\w* los \w dos|strong="H8147"\w* \w machos|strong="H8163"\w* cabríos y los \w presentará|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* \w de|strong="H6440"\w* la Tienda del Encuentro.  
\v 8 Aarón echará \w suertes|strong="H1486"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w machos|strong="H8163"\w* cabríos: una \w suerte|strong="H1486"\w* \w para|strong="H5921"\w* Yahvé \w y|strong="H5921"\w* \w la|strong="H5921"\w* otra \w para|strong="H5921"\w* Azazel.  
