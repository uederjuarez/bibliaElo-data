\v 12 \w Tomará|strong="H3947"\w* un incensario \w lleno|strong="H4393"\w* \w de|strong="H5921"\w* \w brasas|strong="H1513"\w* \w de|strong="H5921"\w* fuego \w del|strong="H5921"\w* \w altar|strong="H4196"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w dos|strong="H6440"\w* \w puñados|strong="H2651"\w* \w de|strong="H5921"\w* incienso \w aromático|strong="H5561"\w* \w molido|strong="H1851"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w llevará|strong="H3947"\w* detrás \w del|strong="H5921"\w* velo.  
\v 13 \w Pondrá|strong="H5414"\w* \w el|strong="H5921"\w* incienso \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* fuego \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w la|strong="H5921"\w* \w nube|strong="H6051"\w* \w del|strong="H5921"\w* incienso cubra \w el|strong="H5921"\w* propiciatorio \w que|strong="H3808"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w Testimonio|strong="H5715"\w*, \w y|strong="H5921"\w* así \w no|strong="H3808"\w* \w morirá|strong="H4191"\w*.  
\v 14 \w Tomará|strong="H3947"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w del|strong="H4480"\w* \w novillo|strong="H6499"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w rociará|strong="H5137"\w* \w con|strong="H5921"\w* su dedo \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* lado \w oriental|strong="H6924"\w* \w del|strong="H4480"\w* propiciatorio; \w y|strong="H5921"\w* \w delante|strong="H6440"\w* \w del|strong="H4480"\w* propiciatorio \w rociará|strong="H5137"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w con|strong="H5921"\w* su dedo \w siete|strong="H7651"\w* \w veces|strong="H6471"\w*.   
