\v 34 «\w Esto|strong="H2063"\w* \w será|strong="H1961"\w* \w para|strong="H5921"\w* vosotros un \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w*, \w para|strong="H5921"\w* \w hacer|strong="H6213"\w* \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* sus \w pecados|strong="H2403"\w* una vez \w al|strong="H5921"\w* \w año|strong="H8141"\w*».  
\p \w Y|strong="H3068"\w* Aarón \w hizo|strong="H6213"\w* \w tal|strong="H2063"\w* \w como|strong="H1961"\w* Yahvé \w se|strong="H1961"\w* \w lo|strong="H5921"\w* \w había|strong="H1961"\w* \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\c 17
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* Aarón, \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w diles|strong="H1697"\w*: ‘\w Esto|strong="H2088"\w* \w es|strong="H2088"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* Yahvé ha \w ordenado|strong="H6680"\w*:  
\v 3 Todo hombre de la \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w* que degüelle un becerro, un \w cordero|strong="H3775"\w* \w o|strong="H3068"\w* una \w cabra|strong="H5795"\w* en \w el|strong="H4264"\w* \w campamento|strong="H4264"\w*, \w o|strong="H3068"\w* que lo degüelle \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w*,  
\v 4 y \w no|strong="H3808"\w* \w lo|strong="H1931"\w* haya traído \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w puerta|strong="H6607"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* Tienda del Encuentro \w para|strong="H5971"\w* presentarlo \w como|strong="H1931"\w* \w ofrenda|strong="H7133"\w* \w a|strong="H3068"\w* Yahvé \w ante|strong="H6440"\w* \w el|strong="H1931"\w* \w tabernáculo|strong="H4908"\w* \w de|strong="H6440"\w* Yahvé, \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* \w se|strong="H1931"\w* \w le|strong="H1931"\w* imputará \w a|strong="H3068"\w* \w ese|strong="H1931"\w* hombre. \w Ha|strong="H3808"\w* \w derramado|strong="H8210"\w* \w sangre|strong="H1818"\w*. \w Ese|strong="H1931"\w* hombre \w será|strong="H1931"\w* \w cortado|strong="H3772"\w* \w de|strong="H6440"\w* \w entre|strong="H7130"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*.  
\v 5 Esto es \w para|strong="H4616"\w* \w que|strong="H5921"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* traigan \w sus|strong="H1992"\w* \w sacrificios|strong="H2077"\w*, \w los|strong="H1992"\w* \w que|strong="H5921"\w* \w sacrifican|strong="H2077"\w* \w en|strong="H5921"\w* \w campo|strong="H7704"\w* abierto, \w y|strong="H5921"\w* \w los|strong="H1992"\w* traigan \w a|strong="H3068"\w* Yahvé, \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w*, \w y|strong="H5921"\w* \w los|strong="H1992"\w* sacrifiquen \w como|strong="H5921"\w* \w sacrificios|strong="H2077"\w* \w de|strong="H5921"\w* comunión \w a|strong="H3068"\w* Yahvé.  
\v 6 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* rociará \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* Yahvé \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w y|strong="H5921"\w* \w quemará|strong="H6999"\w* \w la|strong="H5921"\w* grasa \w como|strong="H5921"\w* aroma agradable \w para|strong="H5921"\w* Yahvé.  
\v 7 \w Nunca|strong="H3808"\w* \w más|strong="H5750"\w* ofrecerán \w sus|strong="H1992"\w* \w sacrificios|strong="H2077"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* ídolos \w en|strong="H5750"\w* forma \w de|strong="H5750"\w* \w macho|strong="H8163"\w* cabrío, tras \w los|strong="H1992"\w* cuales \w se|strong="H1961"\w* han prostituido. \w Esto|strong="H2063"\w* \w les|strong="H1992"\w* \w será|strong="H1961"\w* \w por|strong="H5750"\w* \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w* \w a|strong="H3068"\w* \w lo|strong="H3808"\w* largo \w de|strong="H5750"\w* \w sus|strong="H1992"\w* \w generaciones|strong="H1755"\w*’.   
\p
\v 8 “También les dirás: ‘Cualquier hombre \w de|strong="H4480"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w o|strong="H3068"\w* \w de|strong="H4480"\w* los forasteros \w que|strong="H4480"\w* residen \w entre|strong="H8432"\w* \w ellos|strong="H4480"\w*, \w que|strong="H4480"\w* ofrezca un \w holocausto|strong="H5930"\w* \w o|strong="H3068"\w* un \w sacrificio|strong="H2077"\w*,  
\v 9 y \w no|strong="H3808"\w* \w lo|strong="H1931"\w* traiga \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w puerta|strong="H6607"\w* \w de|strong="H5971"\w* \w la|strong="H1931"\w* Tienda del Encuentro \w para|strong="H5971"\w* ofrecerlo \w a|strong="H3068"\w* Yahvé, \w ese|strong="H1931"\w* hombre \w será|strong="H1931"\w* \w cortado|strong="H3772"\w* \w de|strong="H5971"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 10 “‘\w Cualquier|strong="H3605"\w* hombre \w de|strong="H4480"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w o|strong="H3068"\w* \w de|strong="H4480"\w* \w los|strong="H3605"\w* forasteros \w que|strong="H4480"\w* residen \w entre|strong="H8432"\w* \w ellos|strong="H4480"\w*, \w que|strong="H4480"\w* coma \w cualquier|strong="H3605"\w* clase \w de|strong="H4480"\w* \w sangre|strong="H1818"\w*, \w yo|strong="H4480"\w* \w pondré|strong="H5414"\w* \w mi|strong="H5315"\w* \w rostro|strong="H6440"\w* \w contra|strong="H6440"\w* esa \w persona|strong="H5315"\w* \w que|strong="H4480"\w* coma \w sangre|strong="H1818"\w* y \w la|strong="H3605"\w* \w cortaré|strong="H3772"\w* \w de|strong="H4480"\w* \w entre|strong="H8432"\w* su \w pueblo|strong="H5971"\w*.  
\v 11 \w Porque|strong="H3588"\w* \w la|strong="H1931"\w* \w vida|strong="H5315"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w carne|strong="H1320"\w* \w está|strong="H1931"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w*. \w Yo|strong="H3588"\w* \w os|strong="H5921"\w* \w la|strong="H1931"\w* he \w dado|strong="H5414"\w* \w sobre|strong="H5921"\w* \w el|strong="H1931"\w* \w altar|strong="H4196"\w* \w para|strong="H5921"\w* hacer \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* vuestras \w almas|strong="H5315"\w*; \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w*, \w en|strong="H5921"\w* razón \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w vida|strong="H5315"\w*, \w la|strong="H1931"\w* \w que|strong="H3588"\w* hace \w expiación|strong="H3722"\w*.  
\v 12 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* he dicho \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*: \w Ninguna|strong="H3605"\w* \w persona|strong="H5315"\w* \w entre|strong="H8432"\w* vosotros comerá \w sangre|strong="H1818"\w*, \w ni|strong="H3808"\w* \w el|strong="H5921"\w* forastero \w que|strong="H4480"\w* reside \w entre|strong="H8432"\w* vosotros comerá \w sangre|strong="H1818"\w*.   
\p
\v 13 “‘Cualquier \w hombre|strong="H1121"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w o|strong="H3068"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* forasteros \w que|strong="H4480"\w* residen \w entre|strong="H8432"\w* \w ellos|strong="H4480"\w*, \w que|strong="H4480"\w* cace algún \w animal|strong="H2416"\w* \w o|strong="H3068"\w* \w ave|strong="H5775"\w* \w que|strong="H4480"\w* sea lícito comer, \w derramará|strong="H8210"\w* su \w sangre|strong="H1818"\w* y la \w cubrirá|strong="H3680"\w* \w con|strong="H4480"\w* \w tierra|strong="H6083"\w*.  
\v 14 \w Porque|strong="H3588"\w* \w la|strong="H1931"\w* \w vida|strong="H5315"\w* \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w sangre|strong="H1818"\w*, \w su|strong="H1931"\w* \w sangre|strong="H1818"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w vida|strong="H5315"\w*. \w Por|strong="H3588"\w* \w eso|strong="H1931"\w* dije \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: \w No|strong="H3808"\w* comeréis \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* \w de|strong="H3588"\w* \w ninguna|strong="H3605"\w* \w carne|strong="H1320"\w*, \w porque|strong="H3588"\w* \w la|strong="H1931"\w* \w vida|strong="H5315"\w* \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w sangre|strong="H1818"\w*. \w Todo|strong="H3605"\w* \w el|strong="H1931"\w* \w que|strong="H3588"\w* \w la|strong="H1931"\w* coma \w será|strong="H1931"\w* \w cortado|strong="H3772"\w*.   
\p
\v 15 “‘\w Toda|strong="H3605"\w* \w persona|strong="H5315"\w*, sea nativo \w o|strong="H3068"\w* forastero, \w que|strong="H5704"\w* coma \w de|strong="H5704"\w* un \w animal|strong="H5315"\w* muerto \w por|strong="H5704"\w* \w sí|strong="H5315"\w* solo \w o|strong="H3068"\w* despedazado \w por|strong="H5704"\w* las fieras, \w lavará|strong="H3526"\w* sus vestidos, se bañará \w en|strong="H5704"\w* \w agua|strong="H4325"\w* \w y|strong="H5704"\w* quedará impuro \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* \w tarde|strong="H6153"\w*. Entonces quedará puro.  
\v 16 Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w lava|strong="H3526"\w* sus vestidos \w ni|strong="H3808"\w* baña su cuerpo, cargará con su \w iniquidad|strong="H5771"\w*’”.   
\c 18
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w diles|strong="H1696"\w*: ‘Yo soy Yahvé, vuestro \w Dios|strong="H3068"\w*.  
\v 3 \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* como \w hacen|strong="H6213"\w* \w en|strong="H3212"\w* la tierra de \w Egipto|strong="H4714"\w*, \w donde|strong="H8033"\w* habitasteis. \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* como \w hacen|strong="H6213"\w* \w en|strong="H3212"\w* la tierra de \w Canaán|strong="H3667"\w*, \w a|strong="H3068"\w* \w donde|strong="H8033"\w* \w yo|strong="H6213"\w* os llevo. \w No|strong="H3808"\w* \w andaréis|strong="H3212"\w* \w en|strong="H3212"\w* sus \w estatutos|strong="H2708"\w*.  
\v 4 Cumpliréis mis \w ordenanzas|strong="H4941"\w* y \w guardaréis|strong="H8104"\w* mis \w estatutos|strong="H2708"\w* para \w andar|strong="H3212"\w* \w en|strong="H3212"\w* \w ellos|strong="H2708"\w*. \w Yo|strong="H6213"\w* soy Yahvé, vuestro \w Dios|strong="H3068"\w*.  
\v 5 \w Guardaréis|strong="H8104"\w*, pues, mis \w estatutos|strong="H2708"\w* y mis \w ordenanzas|strong="H4941"\w*, por los cuales \w el|strong="H6213"\w* hombre que los cumpla, \w vivirá|strong="H2425"\w*. \w Yo|strong="H6213"\w* soy Yahvé.   
\p
\v 6 “‘\w Ninguno|strong="H3808"\w* de vosotros \w se|strong="H3808"\w* acercará \w a|strong="H3068"\w* \w ningún|strong="H3605"\w* pariente cercano para descubrir su \w desnudez|strong="H6172"\w*. Yo soy Yahvé.   
\p
\v 7 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* de tu padre, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* de tu madre; \w ella|strong="H1931"\w* \w es|strong="H1931"\w* tu madre, \w no|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w su|strong="H1931"\w* \w desnudez|strong="H6172"\w*.   
\p
\v 8 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* de \w la|strong="H1931"\w* mujer de tu padre; \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* de tu padre.   
\p
\v 9 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* la \w desnudez|strong="H6172"\w* de tu hermana, \w hija|strong="H1323"\w* de tu padre \w o|strong="H3068"\w* \w hija|strong="H1323"\w* de tu madre, ya sea \w nacida|strong="H4138"\w* en \w casa|strong="H1004"\w* \w o|strong="H3068"\w* \w nacida|strong="H4138"\w* \w fuera|strong="H2351"\w*; \w no|strong="H3808"\w* \w descubrirás|strong="H1540"\w* su \w desnudez|strong="H6172"\w*.   
\p
\v 10 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H3588"\w* \w desnudez|strong="H6172"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* tu \w hijo|strong="H1121"\w* \w o|strong="H3068"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* tu \w hija|strong="H1323"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w desnudez|strong="H6172"\w* \w de|strong="H3588"\w* \w ellas|strong="H2007"\w* \w es|strong="H3588"\w* tu propia \w desnudez|strong="H6172"\w*.   
\p
\v 11 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* de \w la|strong="H1931"\w* \w hija|strong="H1323"\w* de \w la|strong="H1931"\w* mujer de tu padre, \w engendrada|strong="H4138"\w* por tu padre, \w pues|strong="H1931"\w* \w ella|strong="H1931"\w* \w es|strong="H1931"\w* tu hermana.   
\p
\v 12 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* de \w la|strong="H1931"\w* hermana de tu padre; \w ella|strong="H1931"\w* \w es|strong="H1931"\w* pariente \w cercana|strong="H7607"\w* de tu padre.   
\p
\v 13 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* hermana \w de|strong="H3588"\w* tu madre, \w porque|strong="H3588"\w* \w ella|strong="H1931"\w* \w es|strong="H1931"\w* pariente \w cercana|strong="H7607"\w* \w de|strong="H3588"\w* tu madre.   
\p
\v 14 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* del hermano de tu padre; \w no|strong="H3808"\w* te acercarás \w a|strong="H3068"\w* \w su|strong="H1931"\w* mujer, \w ella|strong="H1931"\w* \w es|strong="H1931"\w* tu tía.   
\p
\v 15 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* \w de|strong="H1121"\w* tu \w nuera|strong="H3618"\w*; \w es|strong="H1931"\w* \w la|strong="H1931"\w* mujer \w de|strong="H1121"\w* tu \w hijo|strong="H1121"\w*, \w no|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w su|strong="H1931"\w* \w desnudez|strong="H6172"\w*.   
\p
\v 16 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* de \w la|strong="H1931"\w* mujer de tu hermano; \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* de tu hermano.   
\p
\v 17 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* \w de|strong="H1121"\w* una mujer y \w la|strong="H1931"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* \w hija|strong="H1323"\w*. \w No|strong="H3808"\w* \w tomarás|strong="H3947"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* \w hijo|strong="H1121"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* \w hija|strong="H1323"\w*, para descubrir \w su|strong="H1931"\w* \w desnudez|strong="H6172"\w*; \w son|strong="H3808"\w* parientes cercanas. \w Es|strong="H1931"\w* una infamia.   
\p
\v 18 “‘\w No|strong="H3808"\w* \w tomarás|strong="H3947"\w* \w a|strong="H3068"\w* una mujer juntamente \w con|strong="H5921"\w* su hermana, \w para|strong="H5921"\w* hacerla su rival, \w descubriendo|strong="H1540"\w* \w la|strong="H5921"\w* \w desnudez|strong="H6172"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* una \w en|strong="H5921"\w* presencia \w de|strong="H5921"\w* \w la|strong="H5921"\w* otra, mientras \w viva|strong="H2416"\w* \w la|strong="H5921"\w* primera.   
\p
\v 19 “‘\w No|strong="H3808"\w* te acercarás \w a|strong="H3068"\w* una mujer para descubrir su \w desnudez|strong="H6172"\w* mientras esté apartada por su impureza menstrual.   
\p
\v 20 “‘\w No|strong="H3808"\w* te acostarás carnalmente con la mujer \w de|strong="H5414"\w* tu prójimo, \w contaminándote|strong="H2930"\w* con ella.   
\p
\v 21 “‘\w No|strong="H3808"\w* entregarás \w a|strong="H3068"\w* \w ninguno|strong="H3808"\w* \w de|strong="H5414"\w* tus \w hijos|strong="H2233"\w* \w para|strong="H5414"\w* ofrecerlo \w por|strong="H5414"\w* \w el|strong="H5674"\w* fuego \w a|strong="H3068"\w* Moloc, \w profanando|strong="H2490"\w* así \w el|strong="H5674"\w* \w nombre|strong="H8034"\w* \w de|strong="H5414"\w* tu \w Dios|strong="H3068"\w*. Yo soy Yahvé.   
\p
\v 22 “‘\w No|strong="H3808"\w* te acostarás \w con|strong="H4904"\w* un hombre \w como|strong="H1931"\w* \w quien|strong="H1931"\w* \w se|strong="H1931"\w* acuesta \w con|strong="H4904"\w* una mujer; \w es|strong="H1931"\w* una \w abominación|strong="H8441"\w*.   
\p
\v 23 “‘\w No|strong="H3808"\w* te ayuntarás con \w ningún|strong="H3605"\w* animal \w para|strong="H5414"\w* contaminarte con \w él|strong="H1931"\w*. \w Tampoco|strong="H3808"\w* mujer \w alguna|strong="H3605"\w* \w se|strong="H1931"\w* \w pondrá|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* un animal \w para|strong="H5414"\w* ayuntarse con \w él|strong="H1931"\w*; \w es|strong="H1931"\w* una perversión.   
\p
\v 24 “‘\w No|strong="H3588"\w* os \w contaminéis|strong="H2930"\w* \w con|strong="H3588"\w* \w ninguna|strong="H3605"\w* \w de|strong="H3588"\w* estas cosas, \w porque|strong="H3588"\w* \w con|strong="H3588"\w* \w todas|strong="H3605"\w* ellas se \w contaminaron|strong="H2930"\w* las \w naciones|strong="H1471"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* voy \w a|strong="H3068"\w* expulsar \w de|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* vosotros.  
\v 25 \w La|strong="H5921"\w* tierra \w se|strong="H5921"\w* \w contaminó|strong="H2930"\w*, \w y|strong="H5921"\w* \w por|strong="H5921"\w* ello castigué su \w iniquidad|strong="H5771"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* tierra vomitó \w a|strong="H3068"\w* sus \w habitantes|strong="H3427"\w*.  
\v 26 \w Guardad|strong="H8104"\w*, pues, vosotros mis \w estatutos|strong="H2708"\w* y mis \w ordenanzas|strong="H4941"\w*, y \w no|strong="H3808"\w* cometáis \w ninguna|strong="H3605"\w* de \w estas|strong="H6213"\w* \w abominaciones|strong="H8441"\w*, \w ni|strong="H3808"\w* \w el|strong="H3605"\w* nativo \w ni|strong="H3808"\w* \w el|strong="H3605"\w* forastero \w que|strong="H3808"\w* reside \w entre|strong="H8432"\w* vosotros.  
\v 27 \w Porque|strong="H3588"\w* \w los|strong="H3605"\w* hombres \w de|strong="H3588"\w* aquella tierra \w que|strong="H3588"\w* os precedieron \w cometieron|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H6213"\w* \w abominaciones|strong="H8441"\w*, \w y|strong="H3588"\w* \w la|strong="H3605"\w* tierra se \w contaminó|strong="H2930"\w*.  
\v 28 \w No|strong="H3808"\w* sea \w que|strong="H3808"\w* la tierra os vomite también \w a|strong="H3068"\w* vosotros \w por|strong="H6440"\w* haberla \w contaminado|strong="H2930"\w*, como vomitó \w a|strong="H3068"\w* la \w nación|strong="H1471"\w* \w que|strong="H3808"\w* la habitó \w antes|strong="H6440"\w* \w de|strong="H6440"\w* vosotros.   
\p
\v 29 “‘\w Cualquiera|strong="H3605"\w* \w que|strong="H3588"\w* cometa \w alguna|strong="H3605"\w* \w de|strong="H3588"\w* \w estas|strong="H6213"\w* \w abominaciones|strong="H8441"\w*, las \w personas|strong="H5315"\w* \w que|strong="H3588"\w* las cometan serán \w cortadas|strong="H3772"\w* \w de|strong="H3588"\w* \w entre|strong="H7130"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*.  
\v 30 \w Guardad|strong="H8104"\w*, pues, \w mi|strong="H1115"\w* mandato, \w no|strong="H3808"\w* practicando \w ninguna|strong="H3808"\w* \w de|strong="H6440"\w* las costumbres abominables \w que|strong="H3808"\w* \w se|strong="H3808"\w* practicaron \w antes|strong="H6440"\w* \w de|strong="H6440"\w* vosotros, para \w que|strong="H3808"\w* \w no|strong="H3808"\w* os \w contaminéis|strong="H2930"\w* con ellas. \w Yo|strong="H6213"\w* soy Yahvé, vuestro \w Dios|strong="H3068"\w*’”.   
\c 19
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* congregación \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Seréis|strong="H1961"\w* \w santos|strong="H6918"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, vuestro \w Dios|strong="H3068"\w*, \w soy|strong="H1961"\w* \w santo|strong="H6918"\w*.   
\p
\v 3 “‘Cada uno \w de|strong="H3372"\w* vosotros reverenciará \w a|strong="H3068"\w* su madre y \w a|strong="H3068"\w* su padre, y \w guardaréis|strong="H8104"\w* mis días \w de|strong="H3372"\w* reposo. Yo soy Yahvé, vuestro \w Dios|strong="H3068"\w*.   
\p
\v 4 “‘\w No|strong="H3808"\w* os volváis \w a|strong="H3068"\w* los ídolos, \w ni|strong="H3808"\w* os \w hagáis|strong="H6213"\w* dioses de \w fundición|strong="H4541"\w*. \w Yo|strong="H6213"\w* soy Yahvé, vuestro \w Dios|strong="H3068"\w*.   
\p
\v 5 “‘\w Cuando|strong="H3588"\w* ofrezcáis un \w sacrificio|strong="H2077"\w* \w de|strong="H3588"\w* comunión \w a|strong="H3068"\w* Yahvé, ofrecedlo \w de|strong="H3588"\w* manera \w que|strong="H3588"\w* seáis aceptados.  
\v 6 Se comerá el mismo \w día|strong="H3117"\w* \w que|strong="H5704"\w* \w lo|strong="H5704"\w* ofrezcáis, \w y|strong="H5704"\w* \w al|strong="H5704"\w* \w día|strong="H3117"\w* \w siguiente|strong="H4283"\w*. Si \w queda|strong="H3498"\w* algo \w hasta|strong="H5704"\w* el tercer \w día|strong="H3117"\w*, será quemado \w al|strong="H5704"\w* fuego.  
\v 7 \w Si|strong="H3808"\w* \w se|strong="H1931"\w* come al tercer \w día|strong="H3117"\w*, \w es|strong="H1931"\w* una \w abominación|strong="H6292"\w*; \w no|strong="H3808"\w* \w será|strong="H1931"\w* aceptado.  
\v 8 Cualquiera \w que|strong="H3588"\w* \w lo|strong="H1931"\w* coma cargará \w con|strong="H3588"\w* \w su|strong="H1931"\w* \w iniquidad|strong="H5771"\w*, \w porque|strong="H3588"\w* ha \w profanado|strong="H2490"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* \w es|strong="H1931"\w* \w santo|strong="H6944"\w* \w para|strong="H3588"\w* Yahvé, \w y|strong="H3588"\w* \w esa|strong="H1931"\w* \w persona|strong="H5315"\w* \w será|strong="H1931"\w* cortada \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 9 “‘Cuando seguéis la \w mies|strong="H7105"\w* de vuestra tierra, \w no|strong="H3808"\w* \w segaréis|strong="H7114"\w* hasta el último rincón de tu \w campo|strong="H7704"\w*, \w ni|strong="H3808"\w* \w espigarás|strong="H3951"\w* el sobrante de tu \w mies|strong="H7105"\w*.  
\v 10 \w No|strong="H3808"\w* \w rebuscarás|strong="H5953"\w* tu \w viña|strong="H3754"\w*, \w ni|strong="H3808"\w* \w recogerás|strong="H3950"\w* el fruto caído de tu \w viña|strong="H3754"\w*; \w lo|strong="H3808"\w* \w dejarás|strong="H5800"\w* para el \w pobre|strong="H6041"\w* y para el forastero. Yo soy Yahvé, vuestro \w Dios|strong="H3068"\w*.   
\p
\v 11 “‘\w No|strong="H3808"\w* \w hurtaréis|strong="H1589"\w*.  
\p “‘\w No|strong="H3808"\w* \w engañaréis|strong="H3584"\w*.  
\p “‘\w No|strong="H3808"\w* os \w mentiréis|strong="H8266"\w* unos \w a|strong="H3068"\w* otros.   
\p
\v 12 “‘\w No|strong="H3808"\w* \w juraréis|strong="H7650"\w* en \w falso|strong="H8267"\w* por \w mi|strong="H2490"\w* \w nombre|strong="H8034"\w*, \w profanando|strong="H2490"\w* así el \w nombre|strong="H8034"\w* de tu \w Dios|strong="H3068"\w*. Yo soy Yahvé.   
\p
\v 13 “‘\w No|strong="H3808"\w* \w oprimirás|strong="H6231"\w* \w a|strong="H3068"\w* tu \w prójimo|strong="H7453"\w* \w ni|strong="H3808"\w* \w le|strong="H1242"\w* \w robarás|strong="H1497"\w*.  
\p “‘\w El|strong="H3885"\w* salario del jornalero \w no|strong="H3808"\w* retendrás contigo toda la noche \w hasta|strong="H5704"\w* la \w mañana|strong="H1242"\w*.   
\p
\v 14 “‘\w No|strong="H3808"\w* maldecirás al \w sordo|strong="H2795"\w*, \w ni|strong="H3808"\w* \w pondrás|strong="H5414"\w* \w tropiezo|strong="H4383"\w* \w delante|strong="H6440"\w* del \w ciego|strong="H5787"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w temerás|strong="H3372"\w* \w a|strong="H3068"\w* tu \w Dios|strong="H3068"\w*. Yo soy Yahvé.   
\p
\v 15 “‘\w No|strong="H3808"\w* \w haréis|strong="H6213"\w* injusticia en \w el|strong="H6213"\w* \w juicio|strong="H4941"\w*. \w No|strong="H3808"\w* favorecerás al \w pobre|strong="H1800"\w* \w ni|strong="H3808"\w* complacerás al poderoso, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* con \w justicia|strong="H6664"\w* \w juzgarás|strong="H8199"\w* \w a|strong="H3068"\w* \w tu|strong="H8199"\w* prójimo.   
\p
\v 16 “‘\w No|strong="H3808"\w* \w andarás|strong="H3212"\w* \w como|strong="H5921"\w* chismoso \w entre|strong="H5921"\w* tu \w pueblo|strong="H5971"\w*.  
\p “‘\w No|strong="H3808"\w* atentarás \w contra|strong="H5921"\w* \w la|strong="H5921"\w* vida \w de|strong="H5921"\w* tu \w prójimo|strong="H7453"\w*. Yo soy Yahvé.   
\p
\v 17 “‘\w No|strong="H3808"\w* \w aborrecerás|strong="H8130"\w* \w a|strong="H3068"\w* tu hermano \w en|strong="H5921"\w* tu \w corazón|strong="H3824"\w*. \w Reprenderás|strong="H3198"\w* francamente \w a|strong="H3068"\w* tu prójimo, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* cargues \w con|strong="H5921"\w* \w pecado|strong="H2399"\w* \w por|strong="H5921"\w* su causa.   
\p
\v 18 “‘\w No|strong="H3808"\w* te vengarás, \w ni|strong="H3808"\w* guardarás \w rencor|strong="H5201"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* tu \w pueblo|strong="H5971"\w*, \w sino|strong="H3808"\w* amarás \w a|strong="H3068"\w* tu \w prójimo|strong="H7453"\w* \w como|strong="H3644"\w* \w a|strong="H3068"\w* ti mismo. Yo soy Yahvé.   
\p
\v 19 “‘Mis \w estatutos|strong="H2708"\w* \w guardaréis|strong="H8104"\w*.  
\p “‘\w No|strong="H3808"\w* harás \w que|strong="H3808"\w* tu ganado \w se|strong="H5921"\w* cruze \w con|strong="H5921"\w* animales \w de|strong="H5921"\w* otra especie.  
\p “‘\w No|strong="H3808"\w* \w sembrarás|strong="H2232"\w* tu \w campo|strong="H7704"\w* \w con|strong="H5921"\w* semilla mezclada.  
\p “‘\w No|strong="H3808"\w* \w te|strong="H5921"\w* pondrás un vestido tejido \w con|strong="H5921"\w* dos clases \w de|strong="H5921"\w* hilo.   
\p
\v 20 “‘\w Si|strong="H3588"\w* un hombre \w se|strong="H1961"\w* acuesta carnalmente \w con|strong="H3588"\w* una mujer \w que|strong="H3588"\w* \w es|strong="H1931"\w* \w sierva|strong="H8198"\w* \w desposada|strong="H2778"\w* \w con|strong="H3588"\w* otro hombre, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w sido|strong="H1961"\w* rescatada \w ni|strong="H3808"\w* \w se|strong="H1961"\w* \w le|strong="H1931"\w* \w ha|strong="H3808"\w* \w dado|strong="H5414"\w* \w la|strong="H1931"\w* \w libertad|strong="H2668"\w*, \w habrá|strong="H1961"\w* castigo. \w No|strong="H3808"\w* \w serán|strong="H1961"\w* condenados \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*, \w porque|strong="H3588"\w* \w ella|strong="H1931"\w* \w no|strong="H3808"\w* \w era|strong="H1961"\w* libre.  
\v 21 Él traerá \w a|strong="H3068"\w* Yahvé su ofrenda por la culpa, \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* de la Tienda del Encuentro; un carnero como ofrenda por la culpa.  
\v 22 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* hará \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé \w con|strong="H5921"\w* \w el|strong="H5921"\w* carnero \w de|strong="H5921"\w* \w la|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* \w la|strong="H5921"\w* culpa, \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w que|strong="H5921"\w* \w cometió|strong="H2398"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w le|strong="H5921"\w* será perdonado.   
\p
\v 23 “‘\w Cuando|strong="H3588"\w* entréis \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w y|strong="H3588"\w* plantéis \w toda|strong="H3605"\w* clase \w de|strong="H3588"\w* \w árboles|strong="H6086"\w* frutales, consideraréis \w su|strong="H3588"\w* \w fruto|strong="H6529"\w* \w como|strong="H3588"\w* \w incircunciso|strong="H6189"\w* \w y|strong="H3588"\w* prohibido. Durante \w tres|strong="H7969"\w* \w años|strong="H8141"\w* os \w será|strong="H1961"\w* prohibido; \w no|strong="H3808"\w* \w se|strong="H1961"\w* comerá.  
\v 24 Al \w cuarto|strong="H7243"\w* \w año|strong="H8141"\w* \w todo|strong="H3605"\w* su \w fruto|strong="H6529"\w* \w será|strong="H1961"\w* \w consagrado|strong="H6944"\w* en alabanza \w a|strong="H3068"\w* Yahvé.  
\v 25 En el \w quinto|strong="H2549"\w* \w año|strong="H8141"\w* comeréis su \w fruto|strong="H6529"\w*, para que su rendimiento os aumente. Yo soy Yahvé, \w vuestro|strong="H6529"\w* \w Dios|strong="H3068"\w*.   
\p
\v 26 “‘\w No|strong="H3808"\w* comeréis carne \w con|strong="H5921"\w* su \w sangre|strong="H1818"\w*. \w No|strong="H3808"\w* practicaréis \w la|strong="H5921"\w* adivinación \w ni|strong="H3808"\w* \w la|strong="H5921"\w* hechicería.   
\p
\v 27 “‘\w No|strong="H3808"\w* os \w cortaréis|strong="H5362"\w* el cabello en redondo en las sienes, \w ni|strong="H3808"\w* os recortaréis los bordes de la \w barba|strong="H2206"\w*.   
\p
\v 28 “‘\w No|strong="H3808"\w* \w haréis|strong="H5414"\w* sajaduras en vuestro cuerpo \w por|strong="H5414"\w* un muerto, \w ni|strong="H3808"\w* os \w haréis|strong="H5414"\w* tatuajes. \w Yo|strong="H5315"\w* soy Yahvé.   
\p
\v 29 “‘\w No|strong="H3808"\w* profanarás \w a|strong="H3068"\w* tu \w hija|strong="H1323"\w* haciéndola prostituta, para \w que|strong="H3808"\w* la tierra \w no|strong="H3808"\w* \w se|strong="H3808"\w* prostituya y \w se|strong="H3808"\w* llene de perversidad.   
\p
\v 30 “‘\w Guardaréis|strong="H8104"\w* mis días \w de|strong="H3372"\w* reposo y reverenciaréis mi \w santuario|strong="H4720"\w*. Yo soy Yahvé.   
\p
\v 31 “‘No os volváis \w a|strong="H3068"\w* los encantadores ni \w a|strong="H3068"\w* los \w adivinos|strong="H3049"\w*; no los consultéis, contaminándoos con ellos. Yo soy Yahvé, vuestro \w Dios|strong="H3068"\w*.   
\p
\v 32 “‘\w Delante|strong="H6440"\w* \w de|strong="H6440"\w* las canas te \w levantarás|strong="H6965"\w*, y honrarás el \w rostro|strong="H6440"\w* del \w anciano|strong="H2205"\w*, y \w de|strong="H6440"\w* tu \w Dios|strong="H3068"\w* tendrás \w temor|strong="H3372"\w*. Yo soy Yahvé.   
\p
\v 33 “‘\w Cuando|strong="H3588"\w* un forastero resida \w con|strong="H3588"\w* vosotros \w en|strong="H3588"\w* vuestra tierra, \w no|strong="H3808"\w* le oprimiréis.  
\v 34 \w El|strong="H3588"\w* forastero \w que|strong="H3588"\w* resida \w con|strong="H4480"\w* vosotros \w os|strong="H4480"\w* \w será|strong="H1961"\w* \w como|strong="H3588"\w* uno nacido \w entre|strong="H3588"\w* vosotros, \w y|strong="H3588"\w* lo amarás \w como|strong="H3588"\w* \w a|strong="H3068"\w* \w ti|strong="H4480"\w* mismo, \w porque|strong="H3588"\w* forasteros \w fuisteis|strong="H1961"\w* \w en|strong="H4480"\w* \w la|strong="H3588"\w* tierra \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*. \w Yo|strong="H4480"\w* \w soy|strong="H1961"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*.   
\p
\v 35 “‘\w No|strong="H3808"\w* cometeréis injusticia en los \w juicios|strong="H4941"\w*, \w ni|strong="H3808"\w* en las medidas de longitud, de \w peso|strong="H4948"\w* \w o|strong="H3068"\w* de capacidad.  
\v 36 \w Tendréis|strong="H1961"\w* \w balanzas|strong="H3976"\w* \w justas|strong="H6664"\w*, pesas \w justas|strong="H6664"\w*, un efa justo y un \w hin|strong="H1969"\w* justo. Yo \w soy|strong="H1961"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*, \w que|strong="H1961"\w* os \w saqué|strong="H3318"\w* de la tierra de \w Egipto|strong="H4714"\w*.   
\p
\v 37 “‘\w Guardaréis|strong="H8104"\w*, pues, \w todos|strong="H3605"\w* mis \w estatutos|strong="H2708"\w* y \w todas|strong="H3605"\w* mis \w ordenanzas|strong="H4941"\w*, y \w los|strong="H3605"\w* pondréis por \w obra|strong="H6213"\w*. \w Yo|strong="H6213"\w* soy Yahvé’”.   
\c 20
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “Dirás asimismo \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*: ‘Cualquier \w hombre|strong="H1121"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w o|strong="H3068"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* forasteros \w que|strong="H4480"\w* residen \w en|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w que|strong="H4480"\w* ofrezca alguno \w de|strong="H4480"\w* sus descendientes \w a|strong="H3068"\w* Moloc, \w morirá|strong="H4191"\w* \w irremisiblemente|strong="H4191"\w*. \w El|strong="H1121"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* la tierra lo apedreará.  
\v 3 \w Yo|strong="H3588"\w* \w pondré|strong="H5414"\w* \w mi|strong="H2490"\w* \w rostro|strong="H6440"\w* \w contra|strong="H6440"\w* \w ese|strong="H1931"\w* hombre \w y|strong="H3588"\w* \w lo|strong="H1931"\w* \w cortaré|strong="H3772"\w* \w de|strong="H3588"\w* \w entre|strong="H7130"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*, \w por|strong="H3588"\w* haber \w entregado|strong="H5414"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w descendencia|strong="H2233"\w* \w a|strong="H3068"\w* Moloc, \w profanando|strong="H2490"\w* \w mi|strong="H2490"\w* \w santuario|strong="H4720"\w* \w y|strong="H3588"\w* mancillando \w mi|strong="H2490"\w* \w santo|strong="H6944"\w* \w nombre|strong="H8034"\w*.  
\v 4 \w Y|strong="H3068"\w* \w si|strong="H1931"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* tierra cierra \w los|strong="H1931"\w* \w ojos|strong="H5869"\w* ante \w ese|strong="H1931"\w* hombre, cuando ofrece \w de|strong="H4480"\w* \w su|strong="H1931"\w* \w descendencia|strong="H2233"\w* \w a|strong="H3068"\w* Moloc, y \w no|strong="H1115"\w* \w le|strong="H1931"\w* \w da|strong="H5414"\w* \w muerte|strong="H4191"\w*,  
\v 5 entonces yo \w pondré|strong="H7760"\w* mi \w rostro|strong="H6440"\w* \w contra|strong="H6440"\w* \w ese|strong="H1931"\w* hombre y \w contra|strong="H6440"\w* \w su|strong="H1931"\w* \w familia|strong="H4940"\w*. \w Lo|strong="H1931"\w* \w cortaré|strong="H3772"\w* \w de|strong="H6440"\w* \w entre|strong="H7130"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*, \w a|strong="H3068"\w* \w él|strong="H1931"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* prostituyan tras \w él|strong="H1931"\w* \w para|strong="H5971"\w* adorar \w a|strong="H3068"\w* Moloc.   
\p
\v 6 “‘\w La|strong="H1931"\w* \w persona|strong="H5315"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* vuelva \w a|strong="H3068"\w* \w los|strong="H1931"\w* encantadores \w o|strong="H3068"\w* \w adivinos|strong="H3049"\w*, \w para|strong="H5414"\w* prostituirse yendo en pos \w de|strong="H6440"\w* \w ellos|strong="H1931"\w*, \w yo|strong="H5315"\w* \w pondré|strong="H5414"\w* \w mi|strong="H5315"\w* \w rostro|strong="H6440"\w* \w contra|strong="H6440"\w* \w esa|strong="H1931"\w* \w persona|strong="H5315"\w* y \w la|strong="H1931"\w* \w cortaré|strong="H3772"\w* \w de|strong="H6440"\w* \w entre|strong="H7130"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 7 “‘\w Santificaos|strong="H6942"\w*, \w pues|strong="H3588"\w*, \w y|strong="H3588"\w* \w sed|strong="H1961"\w* \w santos|strong="H6918"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*.  
\v 8 \w Guardad|strong="H8104"\w* mis \w estatutos|strong="H2708"\w* y ponedlos por \w obra|strong="H6213"\w*. \w Yo|strong="H6213"\w* soy Yahvé, \w el|strong="H6213"\w* que os \w santifica|strong="H6942"\w*.   
\p
\v 9 “‘Todo hombre \w que|strong="H3588"\w* maldiga \w a|strong="H3068"\w* \w su|strong="H3588"\w* padre \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* madre será condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*. Ha maldecido \w a|strong="H3068"\w* \w su|strong="H3588"\w* padre \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* madre; \w su|strong="H3588"\w* \w sangre|strong="H1818"\w* caerá sobre \w él|strong="H3588"\w*.   
\p
\v 10 “‘El hombre que cometa adulterio con la mujer de \w otro|strong="H7453"\w*, el que cometa adulterio con la mujer de su \w prójimo|strong="H7453"\w*, el adúltero y la \w adúltera|strong="H5003"\w* serán condenados \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*.   
\p
\v 11 “‘Cualquiera que se acueste con la mujer \w de|strong="H1818"\w* su padre, ha descubierto la \w desnudez|strong="H6172"\w* \w de|strong="H1818"\w* su padre; \w ambos|strong="H8147"\w* serán condenados \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*. Su \w sangre|strong="H1818"\w* caerá sobre ellos.   
\p
\v 12 “‘Si un hombre se acuesta con su \w nuera|strong="H3618"\w*, \w ambos|strong="H8147"\w* serán condenados \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*. \w Han|strong="H4191"\w* cometido una perversión; su \w sangre|strong="H1818"\w* caerá sobre ellos.   
\p
\v 13 “‘Si un hombre se acuesta \w con|strong="H4904"\w* otro hombre como \w quien|strong="H6213"\w* se acuesta \w con|strong="H4904"\w* una mujer, \w ambos|strong="H8147"\w* \w han|strong="H4191"\w* cometido una \w abominación|strong="H8441"\w*. Serán condenados \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*; su \w sangre|strong="H1818"\w* caerá sobre ellos.   
\p
\v 14 “‘\w Si|strong="H3808"\w* un hombre \w toma|strong="H3947"\w* por esposas \w a|strong="H3068"\w* una mujer y \w a|strong="H3068"\w* \w la|strong="H1931"\w* madre de \w ella|strong="H1931"\w*, \w es|strong="H1931"\w* una infamia. \w Serán|strong="H1961"\w* quemados al fuego \w él|strong="H1931"\w* y \w ellas|strong="H1931"\w*, \w para|strong="H1961"\w* \w que|strong="H1931"\w* \w no|strong="H3808"\w* \w haya|strong="H1961"\w* infamia \w entre|strong="H8432"\w* vosotros.   
\p
\v 15 “‘Cualquiera que tenga \w cópula|strong="H7903"\w* con un animal \w será|strong="H5414"\w* condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*, y mataréis al animal.   
\p
\v 16 “‘Si una mujer se acerca \w a|strong="H3068"\w* algún animal para ayuntarse con \w él|strong="H3605"\w*, \w matarás|strong="H2026"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* mujer y al animal. Serán condenados \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*; su \w sangre|strong="H1818"\w* caerá sobre \w ellos|strong="H3605"\w*.   
\p
\v 17 “‘\w Si|strong="H1931"\w* un \w hombre|strong="H1121"\w* \w toma|strong="H3947"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* hermana, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* padre \w o|strong="H3068"\w* \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* madre, y \w ve|strong="H7200"\w* \w su|strong="H1931"\w* \w desnudez|strong="H6172"\w* y \w ella|strong="H1931"\w* \w ve|strong="H7200"\w* \w la|strong="H1931"\w* \w suya|strong="H1931"\w*, \w es|strong="H1931"\w* una deshonra. \w Serán|strong="H1931"\w* cortados \w a|strong="H3068"\w* \w la|strong="H1931"\w* vista \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*. Ha descubierto \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* hermana; cargará con \w su|strong="H1931"\w* \w iniquidad|strong="H5771"\w*.   
\p
\v 18 “‘\w Si|strong="H1931"\w* un hombre \w se|strong="H1931"\w* acuesta con una mujer durante \w su|strong="H1931"\w* menstruación y \w descubre|strong="H1540"\w* \w su|strong="H1931"\w* \w desnudez|strong="H6172"\w*, ha puesto \w al|strong="H7130"\w* descubierto \w la|strong="H1931"\w* \w fuente|strong="H4726"\w* \w de|strong="H5971"\w* \w ella|strong="H1931"\w*, y \w ella|strong="H1931"\w* ha descubierto \w la|strong="H1931"\w* \w fuente|strong="H4726"\w* \w de|strong="H5971"\w* \w su|strong="H1931"\w* \w sangre|strong="H1818"\w*. \w Ambos|strong="H8147"\w* \w serán|strong="H1931"\w* cortados \w de|strong="H5971"\w* \w entre|strong="H7130"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 19 “‘\w No|strong="H3808"\w* \w descubrirás|strong="H1540"\w* \w la|strong="H3588"\w* \w desnudez|strong="H6172"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* hermana \w de|strong="H3588"\w* tu madre, \w ni|strong="H3808"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* hermana \w de|strong="H3588"\w* tu padre, \w porque|strong="H3588"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* desnudado \w a|strong="H3068"\w* un pariente cercano. Ellos cargarán \w con|strong="H3588"\w* \w su|strong="H3588"\w* \w iniquidad|strong="H5771"\w*.  
\v 20 Si un hombre se acuesta con la mujer de su \w tío|strong="H1730"\w*, la \w desnudez|strong="H6172"\w* de su \w tío|strong="H1730"\w* ha descubierto. Cargarán con su \w pecado|strong="H2399"\w* y \w morirán|strong="H4191"\w* \w sin|strong="H6185"\w* hijos.   
\p
\v 21 “‘\w Si|strong="H1931"\w* un hombre \w toma|strong="H3947"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* mujer de \w su|strong="H1931"\w* hermano, \w es|strong="H1931"\w* una impureza. Ha descubierto \w la|strong="H1931"\w* \w desnudez|strong="H6172"\w* de \w su|strong="H1931"\w* hermano; \w no|strong="H1961"\w* \w tendrán|strong="H1961"\w* hijos.   
\p
\v 22 “‘\w Guardaréis|strong="H8104"\w*, pues, \w todos|strong="H3605"\w* mis \w estatutos|strong="H2708"\w* y \w todas|strong="H3605"\w* mis \w ordenanzas|strong="H4941"\w*, y \w los|strong="H3427"\w* pondréis por \w obra|strong="H6213"\w*, para \w que|strong="H3808"\w* \w no|strong="H3808"\w* os vomite \w la|strong="H8104"\w* tierra \w a|strong="H3068"\w* \w donde|strong="H8033"\w* \w yo|strong="H6213"\w* os llevo para \w habitar|strong="H3427"\w*.  
\v 23 \w No|strong="H3808"\w* \w andaréis|strong="H3212"\w* \w en|strong="H3588"\w* las costumbres \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* expulso \w de|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* vosotros, \w porque|strong="H3588"\w* \w ellos|strong="H2708"\w* \w hicieron|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H6213"\w* cosas \w y|strong="H3588"\w* \w por|strong="H3588"\w* eso \w los|strong="H3605"\w* abominé.  
\v 24 Pero \w a|strong="H3068"\w* vosotros \w os|strong="H4480"\w* he dicho: Vosotros heredaréis su tierra, y \w yo|strong="H4480"\w* \w os|strong="H4480"\w* la \w daré|strong="H5414"\w* \w para|strong="H4480"\w* \w que|strong="H4480"\w* la poseáis; tierra \w que|strong="H4480"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* y \w miel|strong="H1706"\w*. \w Yo|strong="H4480"\w* soy Yahvé, vuestro \w Dios|strong="H3068"\w*, \w que|strong="H4480"\w* \w os|strong="H4480"\w* he separado \w de|strong="H4480"\w* los demás \w pueblos|strong="H5971"\w*.   
\p
\v 25 “‘Haréis, pues, distinción \w entre|strong="H3808"\w* \w el|strong="H3605"\w* \w animal|strong="H5315"\w* \w puro|strong="H2889"\w* y \w el|strong="H3605"\w* impuro, y \w entre|strong="H3808"\w* \w el|strong="H3605"\w* \w ave|strong="H5775"\w* impura y \w la|strong="H3605"\w* \w pura|strong="H2889"\w*. \w No|strong="H3808"\w* os hagáis abominables por causa de \w animal|strong="H5315"\w*, de \w ave|strong="H5775"\w* \w o|strong="H3068"\w* de \w cualquier|strong="H3605"\w* \w cosa|strong="H3605"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* arrastra sobre \w la|strong="H3605"\w* tierra, \w los|strong="H3605"\w* cuales \w yo|strong="H5315"\w* he separado para \w que|strong="H3808"\w* \w los|strong="H3605"\w* consideréis impuros.  
\v 26 Habéis \w de|strong="H4480"\w* \w serme|strong="H1961"\w* \w santos|strong="H6918"\w*, \w porque|strong="H3588"\w* \w yo|strong="H4480"\w*, Yahvé, \w soy|strong="H1961"\w* \w santo|strong="H6918"\w*, \w y|strong="H3588"\w* \w os|strong="H4480"\w* he separado \w de|strong="H4480"\w* \w los|strong="H1961"\w* \w pueblos|strong="H5971"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w seáis|strong="H1961"\w* míos.   
\p
\v 27 “‘\w El|strong="H3588"\w* hombre \w o|strong="H3068"\w* \w la|strong="H3588"\w* mujer \w en|strong="H3588"\w* quienes \w haya|strong="H1961"\w* espíritu \w de|strong="H3588"\w* nigromancia \w o|strong="H3068"\w* \w de|strong="H3588"\w* adivinación, \w han|strong="H4191"\w* \w de|strong="H3588"\w* \w morir|strong="H4191"\w* \w irremisiblemente|strong="H4191"\w*. \w Serán|strong="H1961"\w* apedreados; \w su|strong="H3588"\w* \w sangre|strong="H1818"\w* caerá \w sobre|strong="H1961"\w* ellos’”.   
\c 21
\p
\v 1 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “Habla \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, y diles: ‘\w Ningún|strong="H3808"\w* \w sacerdote|strong="H3548"\w* \w se|strong="H3808"\w* profanará por \w los|strong="H1121"\w* muertos \w de|strong="H1121"\w* su \w pueblo|strong="H5971"\w*,  
\v 2 excepto \w por|strong="H3588"\w* sus parientes \w más|strong="H3588"\w* \w cercanos|strong="H7138"\w*: \w por|strong="H3588"\w* \w su|strong="H3588"\w* madre, \w por|strong="H3588"\w* \w su|strong="H3588"\w* padre, \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*, \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w hija|strong="H1323"\w*, \w por|strong="H3588"\w* \w su|strong="H3588"\w* hermano,  
\v 3 y por su hermana \w virgen|strong="H1330"\w* \w que|strong="H3808"\w* dependa de él y \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w haya|strong="H1961"\w* tenido marido; por ella \w sí|strong="H3808"\w* puede profanarse.  
\v 4 \w No|strong="H3808"\w* \w se|strong="H3808"\w* \w contaminará|strong="H2490"\w*, siendo jefe \w entre|strong="H3808"\w* su \w pueblo|strong="H5971"\w*, haciéndose impuro.   
\p
\v 5 “‘\w No|strong="H3808"\w* \w se|strong="H3808"\w* \w raparán|strong="H1548"\w* la \w cabeza|strong="H7218"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* recortarán los bordes de la \w barba|strong="H2206"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* \w harán|strong="H8296"\w* sajaduras en su \w carne|strong="H1320"\w*.  
\v 6 \w Serán|strong="H1961"\w* \w santos|strong="H6918"\w* \w para|strong="H3588"\w* \w su|strong="H1992"\w* \w Dios|strong="H3068"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w profanarán|strong="H2490"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* \w Dios|strong="H3068"\w*, \w porque|strong="H3588"\w* \w ellos|strong="H1992"\w* \w ofrecen|strong="H7126"\w* \w las|strong="H1992"\w* ofrendas hechas \w por|strong="H3588"\w* fuego \w a|strong="H3068"\w* Yahvé, \w el|strong="H3588"\w* \w pan|strong="H3899"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* \w Dios|strong="H3068"\w*. \w Por|strong="H3588"\w* \w lo|strong="H3808"\w* tanto, \w serán|strong="H1961"\w* \w santos|strong="H6918"\w*.   
\p
\v 7 “‘\w No|strong="H3808"\w* \w tomarán|strong="H3947"\w* \w por|strong="H3588"\w* esposa \w a|strong="H3068"\w* una mujer prostituta \w o|strong="H3068"\w* profanada. \w El|strong="H1931"\w* sacerdote \w tampoco|strong="H3808"\w* \w se|strong="H1931"\w* casará \w con|strong="H3588"\w* una mujer divorciada \w de|strong="H3588"\w* \w su|strong="H1931"\w* marido, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w es|strong="H1931"\w* \w santo|strong="H6918"\w* \w para|strong="H3588"\w* \w su|strong="H1931"\w* Dios.  
\v 8 \w Por|strong="H3588"\w* \w eso|strong="H1931"\w* \w lo|strong="H1931"\w* \w santificarás|strong="H6942"\w*, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w ofrece|strong="H7126"\w* \w el|strong="H1931"\w* \w pan|strong="H3899"\w* \w de|strong="H3588"\w* tu \w Dios|strong="H3068"\w*. \w Será|strong="H1961"\w* \w santo|strong="H6918"\w* \w para|strong="H3588"\w* ti, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, \w que|strong="H3588"\w* os \w santifico|strong="H6942"\w*, \w soy|strong="H1961"\w* \w santo|strong="H6918"\w*.   
\p
\v 9 “‘\w Si|strong="H3588"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* un \w sacerdote|strong="H3548"\w* \w se|strong="H1931"\w* profana entregándose \w a|strong="H3068"\w* \w la|strong="H1931"\w* prostitución, profana \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre; \w será|strong="H1931"\w* \w quemada|strong="H8313"\w* al fuego.   
\p
\v 10 “‘\w El|strong="H5921"\w* \w sumo|strong="H7218"\w* \w sacerdote|strong="H3548"\w* \w entre|strong="H5921"\w* sus hermanos, \w sobre|strong="H5921"\w* cuya \w cabeza|strong="H7218"\w* \w se|strong="H5921"\w* haya \w derramado|strong="H3332"\w* \w el|strong="H5921"\w* \w aceite|strong="H8081"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w unción|strong="H4888"\w*, \w y|strong="H5921"\w* \w que|strong="H3808"\w* haya sido consagrado \w para|strong="H5921"\w* llevar \w las|strong="H5921"\w* vestiduras sagradas, \w no|strong="H3808"\w* llevará \w el|strong="H5921"\w* cabello suelto \w ni|strong="H3808"\w* rasgará sus \w vestidos|strong="H3847"\w*.  
\v 11 \w No|strong="H3808"\w* \w se|strong="H3808"\w* acercará \w a|strong="H3068"\w* \w ningún|strong="H3605"\w* cadáver, \w ni|strong="H3808"\w* siquiera \w por|strong="H5921"\w* su padre \w o|strong="H3068"\w* \w por|strong="H5921"\w* su madre \w se|strong="H3808"\w* \w contaminará|strong="H2930"\w*.  
\v 12 \w No|strong="H3808"\w* \w saldrá|strong="H3318"\w* \w del|strong="H4480"\w* \w santuario|strong="H4720"\w* \w ni|strong="H3808"\w* \w profanará|strong="H2490"\w* \w el|strong="H5921"\w* \w santuario|strong="H4720"\w* \w de|strong="H4480"\w* \w su|strong="H3588"\w* \w Dios|strong="H3068"\w*, \w porque|strong="H3588"\w* \w la|strong="H5921"\w* \w consagración|strong="H5145"\w* \w del|strong="H4480"\w* \w aceite|strong="H8081"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w unción|strong="H4888"\w* \w de|strong="H4480"\w* \w su|strong="H3588"\w* \w Dios|strong="H3068"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*. \w Yo|strong="H4480"\w* soy Yahvé.   
\p
\v 13 “‘\w Tomará|strong="H3947"\w* por esposa \w a|strong="H3068"\w* una mujer en \w su|strong="H1931"\w* virginidad.  
\v 14 \w No|strong="H3808"\w* \w se|strong="H3808"\w* casará \w con|strong="H3588"\w* una viuda, \w ni|strong="H3808"\w* \w con|strong="H3588"\w* una divorciada, \w ni|strong="H3808"\w* \w con|strong="H3588"\w* una mujer profanada, \w ni|strong="H3808"\w* \w con|strong="H3588"\w* una prostituta. \w Tomará|strong="H3947"\w* \w como|strong="H3588"\w* esposa \w a|strong="H3068"\w* una \w virgen|strong="H1330"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* propio \w pueblo|strong="H5971"\w*.  
\v 15 \w Así|strong="H3588"\w* \w no|strong="H3808"\w* \w profanará|strong="H2490"\w* \w su|strong="H3588"\w* \w descendencia|strong="H2233"\w* \w entre|strong="H3588"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w que|strong="H3588"\w* \w lo|strong="H3808"\w* \w santifico|strong="H6942"\w*’”.   
\p
\v 16 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 17 “\w Di|strong="H1696"\w* \w a|strong="H3068"\w* Aarón: ‘\w Ninguno|strong="H3808"\w* de tus descendientes, \w a|strong="H3068"\w* \w lo|strong="H3808"\w* largo de sus \w generaciones|strong="H1755"\w*, \w que|strong="H3808"\w* \w tenga|strong="H1961"\w* algún defecto físico \w podrá|strong="H3808"\w* acercarse \w a|strong="H3068"\w* ofrecer el \w pan|strong="H3899"\w* de su Dios.  
\v 18 \w Porque|strong="H3588"\w* \w ningún|strong="H3605"\w* hombre \w que|strong="H3588"\w* tenga un defecto \w se|strong="H3808"\w* acercará: \w ni|strong="H3808"\w* \w el|strong="H3588"\w* \w ciego|strong="H5787"\w*, \w ni|strong="H3808"\w* \w el|strong="H3588"\w* \w cojo|strong="H6455"\w*, \w ni|strong="H3808"\w* \w el|strong="H3588"\w* mutilado del rostro, \w ni|strong="H3808"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* tenga \w alguna|strong="H3605"\w* deformidad,  
\v 19 ni el hombre \w que|strong="H1961"\w* \w tenga|strong="H1961"\w* fracturado un \w pie|strong="H7272"\w* \w o|strong="H3068"\w* una \w mano|strong="H3027"\w*,  
\v 20 ni el jorobado, ni el enano, ni el que tenga un defecto en el \w ojo|strong="H5869"\w*, ni el que tenga sarna \w o|strong="H3068"\w* tiña, ni el que tenga los testículos magullados.  
\v 21 \w Ningún|strong="H3605"\w* hombre de \w la|strong="H3605"\w* \w descendencia|strong="H2233"\w* del \w sacerdote|strong="H3548"\w* Aarón \w que|strong="H3808"\w* tenga algún defecto \w se|strong="H3808"\w* acercará \w a|strong="H3068"\w* presentar las ofrendas hechas por fuego \w a|strong="H3068"\w* Yahvé. Puesto \w que|strong="H3808"\w* tiene un defecto, \w no|strong="H3808"\w* \w se|strong="H3808"\w* acercará \w a|strong="H3068"\w* ofrecer \w el|strong="H3605"\w* \w pan|strong="H3899"\w* de su \w Dios|strong="H3068"\w*.  
\v 22 Podrá comer \w del|strong="H4480"\w* \w pan|strong="H3899"\w* \w de|strong="H4480"\w* su Dios, tanto \w de|strong="H4480"\w* las ofrendas santísimas como \w de|strong="H4480"\w* las \w santas|strong="H6944"\w*.  
\v 23 \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* acercará al velo, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* acercará al \w altar|strong="H4196"\w*, \w porque|strong="H3588"\w* tiene un defecto; \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w profane|strong="H2490"\w* mis santuarios, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w que|strong="H3588"\w* \w los|strong="H3588"\w* \w santifico|strong="H6942"\w*’”.   
\p
\v 24 \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* comunicó esto \w a|strong="H3068"\w* Aarón, \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.   
\c 22
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Di|strong="H1696"\w* \w a|strong="H3068"\w* Aarón y \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w* \w que|strong="H3808"\w* traten con reverencia \w las|strong="H1992"\w* ofrendas \w sagradas|strong="H6944"\w* \w de|strong="H1121"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w las|strong="H1992"\w* cuales \w ellos|strong="H1992"\w* me \w consagran|strong="H6942"\w*, para \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w profanen|strong="H2490"\w* \w mi|strong="H2490"\w* \w santo|strong="H6944"\w* \w nombre|strong="H8034"\w*. Yo soy Yahvé.   
\p
\v 3 “Diles: ‘\w Si|strong="H1931"\w* \w alguno|strong="H3605"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* vuestros descendientes, \w a|strong="H3068"\w* \w lo|strong="H1931"\w* largo \w de|strong="H5921"\w* vuestras \w generaciones|strong="H1755"\w*, \w se|strong="H1931"\w* \w acerca|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* cosas \w sagradas|strong="H6944"\w* \w que|strong="H1931"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w consagran|strong="H6942"\w* \w a|strong="H3068"\w* Yahvé, estando \w en|strong="H5921"\w* estado \w de|strong="H5921"\w* impureza, \w esa|strong="H1931"\w* \w persona|strong="H5315"\w* \w será|strong="H1931"\w* cortada \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w presencia|strong="H6440"\w*. \w Yo|strong="H5315"\w* \w soy|strong="H1931"\w* Yahvé.   
\p
\v 4 “‘\w Ningún|strong="H3605"\w* descendiente \w de|strong="H4480"\w* Aarón \w que|strong="H4480"\w* sea \w leproso|strong="H6879"\w* \w o|strong="H3068"\w* \w que|strong="H4480"\w* tenga un flujo comerá \w de|strong="H4480"\w* las cosas \w sagradas|strong="H6944"\w* \w hasta|strong="H5704"\w* \w que|strong="H4480"\w* \w esté|strong="H1931"\w* puro. \w El|strong="H1931"\w* \w que|strong="H4480"\w* toque algo \w que|strong="H4480"\w* \w ha|strong="H3808"\w* quedado impuro \w por|strong="H4480"\w* causa \w de|strong="H4480"\w* un muerto, \w o|strong="H3068"\w* \w el|strong="H1931"\w* hombre \w que|strong="H4480"\w* tenga una emisión seminal,  
\v 5 \w o|strong="H3068"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* toque \w cualquier|strong="H3605"\w* animal \w que|strong="H3605"\w* se arrastra por \w el|strong="H3605"\w* cual pueda quedar impuro, \w o|strong="H3068"\w* \w a|strong="H3068"\w* un hombre \w que|strong="H3605"\w* \w lo|strong="H3605"\w* haga impuro, sea cual sea \w la|strong="H3605"\w* impureza \w que|strong="H3605"\w* tenga,  
\v 6 \w la|strong="H3588"\w* \w persona|strong="H5315"\w* \w que|strong="H3588"\w* toque \w a|strong="H3068"\w* cualquiera \w de|strong="H4480"\w* \w ellos|strong="H4480"\w* quedará impura \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* \w tarde|strong="H6153"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* comerá \w de|strong="H4480"\w* las cosas \w sagradas|strong="H6944"\w* \w a|strong="H3068"\w* \w menos|strong="H3588"\w* \w que|strong="H3588"\w* bañe \w su|strong="H3588"\w* cuerpo \w en|strong="H4480"\w* \w agua|strong="H4325"\w*.  
\v 7 \w Cuando|strong="H3588"\w* \w se|strong="H1931"\w* ponga \w el|strong="H1931"\w* \w sol|strong="H8121"\w*, quedará puro, \w y|strong="H3588"\w* después podrá comer \w de|strong="H4480"\w* las cosas \w sagradas|strong="H6944"\w*, \w porque|strong="H3588"\w* \w son|strong="H3588"\w* \w su|strong="H1931"\w* alimento.  
\v 8 \w No|strong="H3808"\w* comerá de un animal \w que|strong="H3808"\w* muera por \w sí|strong="H3808"\w* solo \w o|strong="H3068"\w* \w que|strong="H3808"\w* sea despedazado por las fieras, contaminándose con ello. Yo soy Yahvé.   
\p
\v 9 “‘\w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w guardarán|strong="H8104"\w* \w mi|strong="H5921"\w* \w ordenanza|strong="H4931"\w*, \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* carguen \w con|strong="H5921"\w* \w pecado|strong="H2399"\w* \w por|strong="H5921"\w* ello \w y|strong="H3588"\w* \w mueran|strong="H4191"\w* \w por|strong="H5921"\w* haberla \w profanado|strong="H2490"\w*. \w Yo|strong="H3588"\w* soy Yahvé, \w que|strong="H3588"\w* \w los|strong="H5921"\w* \w santifico|strong="H6942"\w*.   
\p
\v 10 “‘\w Ningún|strong="H3605"\w* \w extraño|strong="H2114"\w* comerá de las cosas \w sagradas|strong="H6944"\w*; \w ni|strong="H3808"\w* \w el|strong="H3605"\w* huésped del \w sacerdote|strong="H3548"\w* \w ni|strong="H3808"\w* su jornalero comerán de las cosas \w sagradas|strong="H6944"\w*.  
\v 11 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* un \w sacerdote|strong="H3548"\w* \w compra|strong="H7069"\w* \w a|strong="H3068"\w* un esclavo \w con|strong="H3588"\w* \w su|strong="H1931"\w* propio \w dinero|strong="H3701"\w*, \w este|strong="H1931"\w* podrá \w comer|strong="H5315"\w* \w de|strong="H3588"\w* \w ellas|strong="H1992"\w*; \w y|strong="H3588"\w* \w los|strong="H1992"\w* \w nacidos|strong="H3211"\w* \w en|strong="H3588"\w* \w su|strong="H1931"\w* \w casa|strong="H1004"\w* también podrán \w comer|strong="H5315"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w pan|strong="H3899"\w*.  
\v 12 \w Si|strong="H3588"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* un \w sacerdote|strong="H3548"\w* \w se|strong="H1961"\w* casa \w con|strong="H3588"\w* un \w extraño|strong="H2114"\w*, \w no|strong="H3808"\w* \w podrá|strong="H3808"\w* comer \w de|strong="H3588"\w* las \w ofrendas|strong="H8641"\w* elevadas \w de|strong="H3588"\w* las cosas \w sagradas|strong="H6944"\w*.  
\v 13 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* un \w sacerdote|strong="H3548"\w* queda viuda \w o|strong="H3068"\w* \w se|strong="H1961"\w* divorcia, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w tiene|strong="H1961"\w* \w hijos|strong="H2233"\w*, \w y|strong="H3588"\w* \w vuelve|strong="H7725"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* padre \w como|strong="H3588"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w juventud|strong="H5271"\w*, \w podrá|strong="H3808"\w* comer del \w pan|strong="H3899"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* padre; \w pero|strong="H3588"\w* \w ningún|strong="H3605"\w* \w extraño|strong="H2114"\w* comerá \w de|strong="H3588"\w* \w él|strong="H3588"\w*.   
\p
\v 14 “‘\w Si|strong="H3588"\w* un hombre come inadvertidamente \w de|strong="H5921"\w* una ofrenda sagrada, \w le|strong="H5921"\w* \w añadirá|strong="H3254"\w* \w la|strong="H5921"\w* quinta parte \w de|strong="H5921"\w* \w su|strong="H3588"\w* valor \w y|strong="H3588"\w* \w se|strong="H5921"\w* \w la|strong="H5921"\w* \w dará|strong="H5414"\w* \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* ofrenda sagrada.  
\v 15 \w Los|strong="H1121"\w* sacerdotes \w no|strong="H3808"\w* \w profanarán|strong="H2490"\w* las ofrendas \w sagradas|strong="H6944"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, las cuales elevan \w a|strong="H3068"\w* Yahvé,  
\v 16 haciendo \w que|strong="H3588"\w* \w el|strong="H3588"\w* pueblo cargue \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w iniquidad|strong="H5771"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* culpa al comer sus ofrendas \w sagradas|strong="H6944"\w*; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w que|strong="H3588"\w* \w los|strong="H3588"\w* \w santifico|strong="H6942"\w*’”.   
\p
\v 17 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 18 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* Aarón, \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, y \w diles|strong="H1696"\w*: ‘\w Cualquiera|strong="H3605"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w o|strong="H3068"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* forasteros \w en|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w que|strong="H4480"\w* \w presente|strong="H7133"\w* su \w ofrenda|strong="H7133"\w*, ya sea \w para|strong="H4480"\w* cumplir un \w voto|strong="H5088"\w* \w o|strong="H3068"\w* como \w ofrenda|strong="H7133"\w* \w voluntaria|strong="H5071"\w* \w que|strong="H4480"\w* \w se|strong="H4480"\w* ofrezca \w a|strong="H3068"\w* Yahvé como \w holocausto|strong="H5930"\w*,  
\v 19 para que os sea aceptada, ofreceréis un \w macho|strong="H2145"\w* sin defecto, de entre los toros, las ovejas \w o|strong="H3068"\w* las \w cabras|strong="H5795"\w*.  
\v 20 \w No|strong="H3808"\w* \w ofreceréis|strong="H7126"\w* \w nada|strong="H3808"\w* \w que|strong="H3588"\w* \w tenga|strong="H1961"\w* defecto, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* os \w será|strong="H1961"\w* aceptado.  
\v 21 \w Cuando|strong="H3588"\w* alguien ofrezca un \w sacrificio|strong="H2077"\w* \w de|strong="H3588"\w* comunión \w a|strong="H3068"\w* Yahvé \w para|strong="H3588"\w* cumplir un \w voto|strong="H5088"\w*, \w o|strong="H3068"\w* \w como|strong="H3588"\w* ofrenda \w voluntaria|strong="H5071"\w*, ya \w sea|strong="H1961"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* vacada \w o|strong="H3068"\w* del \w rebaño|strong="H6629"\w*, \w el|strong="H3588"\w* animal deberá ser \w perfecto|strong="H8549"\w* \w para|strong="H3588"\w* ser aceptado; \w no|strong="H3808"\w* \w tendrá|strong="H1961"\w* \w ningún|strong="H3605"\w* defecto.  
\v 22 \w No|strong="H3808"\w* \w ofreceréis|strong="H7126"\w* \w a|strong="H3068"\w* Yahvé un animal \w ciego|strong="H5788"\w*, herido, mutilado, \w con|strong="H5921"\w* verrugas, \w con|strong="H5921"\w* sarna \w o|strong="H3068"\w* \w con|strong="H5921"\w* tiña, \w ni|strong="H3808"\w* \w haréis|strong="H5414"\w* \w de|strong="H5921"\w* \w ellos|strong="H1992"\w* una ofrenda hecha \w por|strong="H5921"\w* fuego \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* Yahvé.  
\v 23 \w Podrás|strong="H3808"\w* ofrecer como ofrenda \w voluntaria|strong="H5071"\w* un toro \w o|strong="H3068"\w* un \w cordero|strong="H7716"\w* \w que|strong="H3808"\w* tenga algún miembro deforme \w o|strong="H3068"\w* atrofiado; pero \w no|strong="H3808"\w* \w será|strong="H3808"\w* aceptado para cumplir un \w voto|strong="H5088"\w*.  
\v 24 \w No|strong="H3808"\w* \w ofreceréis|strong="H7126"\w* \w a|strong="H3068"\w* Yahvé un animal \w que|strong="H3808"\w* tenga los testículos magullados, aplastados, arrancados \w o|strong="H3068"\w* cortados. \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w esto|strong="H6213"\w* en vuestra tierra.  
\v 25 \w Tampoco|strong="H3808"\w* aceptaréis \w de|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* un \w extranjero|strong="H5236"\w* \w ninguno|strong="H3808"\w* \w de|strong="H3588"\w* \w estos|strong="H3605"\w* \w animales|strong="H1121"\w* \w para|strong="H3588"\w* ofrecerlos \w como|strong="H3588"\w* \w pan|strong="H3899"\w* \w de|strong="H3588"\w* vuestro Dios, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* corrupción está \w en|strong="H3588"\w* \w ellos|strong="H3027"\w*. Tienen defecto \w y|strong="H3588"\w* \w no|strong="H3808"\w* os serán aceptados’”.   
\p
\v 26 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 27 “\w Cuando|strong="H3588"\w* nazca un ternero, un \w cordero|strong="H3775"\w* \w o|strong="H3068"\w* un cabrito, \w permanecerá|strong="H1961"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w con|strong="H3588"\w* \w su|strong="H3588"\w* madre. \w A|strong="H3068"\w* partir del \w octavo|strong="H8066"\w* \w día|strong="H3117"\w* \w será|strong="H1961"\w* aceptable \w como|strong="H3588"\w* \w ofrenda|strong="H7133"\w* hecha \w por|strong="H3588"\w* fuego \w a|strong="H3068"\w* Yahvé.  
\v 28 \w Ya|strong="H3068"\w* sea vaca u \w oveja|strong="H7716"\w*, \w no|strong="H3808"\w* la \w degollaréis|strong="H7819"\w* \w a|strong="H3068"\w* ella \w y|strong="H7794"\w* \w a|strong="H3068"\w* su cría en \w el|strong="H1121"\w* mismo \w día|strong="H3117"\w*.   
\p
\v 29 “\w Cuando|strong="H3588"\w* ofrezcáis \w a|strong="H3068"\w* Yahvé un \w sacrificio|strong="H2077"\w* \w de|strong="H3588"\w* acción \w de|strong="H3588"\w* gracias, lo \w sacrificaréis|strong="H2076"\w* \w de|strong="H3588"\w* tal manera \w que|strong="H3588"\w* seáis aceptados.  
\v 30 \w Se|strong="H1931"\w* comerá \w en|strong="H4480"\w* \w el|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*; \w no|strong="H3808"\w* \w dejaréis|strong="H3498"\w* \w nada|strong="H3808"\w* \w de|strong="H4480"\w* \w él|strong="H1931"\w* \w para|strong="H5704"\w* \w la|strong="H1931"\w* \w mañana|strong="H1242"\w* siguiente. \w Yo|strong="H4480"\w* \w soy|strong="H1931"\w* Yahvé.   
\p
\v 31 «Por \w lo|strong="H6213"\w* tanto, \w guardaréis|strong="H8104"\w* mis \w mandamientos|strong="H4687"\w* y los pondréis por \w obra|strong="H6213"\w*. \w Yo|strong="H6213"\w* soy Yahvé.  
\v 32 \w No|strong="H3808"\w* profanaréis \w mi|strong="H2490"\w* \w santo|strong="H6944"\w* \w nombre|strong="H8034"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w seré|strong="H3808"\w* \w santificado|strong="H6944"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. Yo soy Yahvé, \w que|strong="H3808"\w* os \w santifico|strong="H6942"\w*,  
\v 33 \w que|strong="H1961"\w* os \w saqué|strong="H3318"\w* de la tierra de \w Egipto|strong="H4714"\w* \w para|strong="H1961"\w* ser vuestro \w Dios|strong="H3068"\w*. Yo \w soy|strong="H1961"\w* Yahvé».   
\c 23
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w diles|strong="H1696"\w*: ‘\w Las|strong="H1992"\w* fiestas solemnes \w de|strong="H1121"\w* Yahvé, \w las|strong="H1992"\w* cuales \w proclamaréis|strong="H7121"\w* como \w asambleas|strong="H4744"\w* \w santas|strong="H6944"\w*, \w serán|strong="H1992"\w* mis fiestas señaladas.   
\p
\v 3 “‘\w Seis|strong="H8337"\w* \w días|strong="H3117"\w* \w se|strong="H1931"\w* trabajará, pero \w el|strong="H1931"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w será|strong="H1931"\w* un \w día|strong="H3117"\w* de descanso solemne, una asamblea \w santa|strong="H6944"\w*; \w no|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo. \w Es|strong="H1931"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* de reposo \w dedicado|strong="H6944"\w* \w a|strong="H3068"\w* Yahvé en \w todas|strong="H3605"\w* vuestras moradas.   
\p
\v 4 “‘Estas son las fiestas solemnes de Yahvé, \w asambleas|strong="H4744"\w* \w santas|strong="H6944"\w* que \w proclamaréis|strong="H7121"\w* en sus fechas señaladas:  
\v 5 El \w primer|strong="H7223"\w* \w mes|strong="H2320"\w*, el día catorce del \w mes|strong="H2320"\w* al atardecer, es la \w Pascua|strong="H6453"\w* de Yahvé.  
\v 6 El \w día|strong="H3117"\w* \w quince|strong="H2568"\w* \w de|strong="H2568"\w* \w este|strong="H2088"\w* mismo \w mes|strong="H2320"\w* \w es|strong="H2088"\w* la \w fiesta|strong="H2282"\w* \w de|strong="H2568"\w* los Panes sin Levadura dedicada \w a|strong="H3068"\w* Yahvé. Durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w* comeréis pan sin levadura.  
\v 7 \w El|strong="H3605"\w* \w primer|strong="H7223"\w* \w día|strong="H3117"\w* \w tendréis|strong="H1961"\w* una asamblea \w santa|strong="H6944"\w*; \w no|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo ordinario.  
\v 8 Durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w* presentaréis \w a|strong="H3068"\w* Yahvé ofrendas hechas por fuego. \w El|strong="H3605"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w habrá|strong="H3117"\w* una asamblea \w santa|strong="H6944"\w*; \w no|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo ordinario’”.   
\p
\v 9 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 10 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Cuando|strong="H3588"\w* hayáis entrado \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* \w yo|strong="H3588"\w* os \w doy|strong="H5414"\w*, \w y|strong="H3588"\w* seguéis \w su|strong="H3588"\w* \w mies|strong="H7105"\w*, traeréis al \w sacerdote|strong="H3548"\w* una gavilla \w como|strong="H3588"\w* primicia \w de|strong="H3588"\w* vuestra cosecha.  
\v 11 El \w sacerdote|strong="H3548"\w* \w mecerá|strong="H5130"\w* la gavilla \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé para que seáis aceptados. La \w mecerá|strong="H5130"\w* el día \w siguiente|strong="H4283"\w* al día \w de|strong="H6440"\w* reposo.  
\v 12 \w El|strong="H1121"\w* mismo \w día|strong="H3117"\w* \w que|strong="H3117"\w* mezáis la gavilla, \w ofreceréis|strong="H6213"\w* \w a|strong="H3068"\w* Yahvé un \w cordero|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto, como \w holocausto|strong="H5930"\w*.  
\v 13 Su \w ofrenda|strong="H4503"\w* de cereal será de \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* de efa\f + \fr 23:13 \ft 1 efa equivale a unos 22 litros o a 2/3 de una fanega\f* de flor de harina \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w*, como \w ofrenda|strong="H4503"\w* hecha por fuego \w a|strong="H3068"\w* Yahvé en aroma agradable; y su \w libación|strong="H5262"\w* será de \w vino|strong="H3196"\w*, la cuarta \w parte|strong="H6241"\w* de un \w hin|strong="H1969"\w*. \f + \fr 23:13 \ft Un hin es de unos 6,5 litros.\f*  
\v 14 \w No|strong="H3808"\w* comeréis \w pan|strong="H3899"\w*, \w ni|strong="H3808"\w* grano \w tostado|strong="H7039"\w*, \w ni|strong="H3808"\w* grano fresco, \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w mismo|strong="H6106"\w* \w día|strong="H3117"\w* \w en|strong="H5704"\w* \w que|strong="H3808"\w* hayáis traído \w la|strong="H3605"\w* \w ofrenda|strong="H7133"\w* \w a|strong="H3068"\w* vuestro Dios. \w Este|strong="H2088"\w* \w será|strong="H3808"\w* un \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w* \w a|strong="H3068"\w* \w lo|strong="H2088"\w* largo \w de|strong="H5704"\w* vuestras \w generaciones|strong="H1755"\w*, \w en|strong="H5704"\w* \w todas|strong="H3605"\w* vuestras moradas.   
\p
\v 15 “‘\w Contaréis|strong="H5608"\w* desde el \w día|strong="H3117"\w* \w siguiente|strong="H4283"\w* al \w día|strong="H3117"\w* de reposo, desde el \w día|strong="H3117"\w* \w en|strong="H8549"\w* \w que|strong="H3117"\w* trajisteis la gavilla de la \w ofrenda|strong="H8573"\w* mecida: \w contaréis|strong="H5608"\w* \w siete|strong="H7651"\w* \w semanas|strong="H7676"\w* completas.  
\v 16 \w Hasta|strong="H5704"\w* el \w día|strong="H3117"\w* \w siguiente|strong="H4283"\w* \w al|strong="H5704"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w de|strong="H5704"\w* reposo \w contaréis|strong="H5608"\w* \w cincuenta|strong="H2572"\w* \w días|strong="H3117"\w*; \w entonces|strong="H3117"\w* presentaréis \w a|strong="H3068"\w* Yahvé una \w ofrenda|strong="H4503"\w* \w de|strong="H5704"\w* grano \w nuevo|strong="H2319"\w*.  
\v 17 Traeréis de vuestras moradas \w dos|strong="H8147"\w* \w panes|strong="H3899"\w* \w para|strong="H1961"\w* ser mecidos, hechos de \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* de efa\f + \fr 23:17 \ft 1 efa equivale a unos 22 litros o a 2/3 de una fanega\f* de flor de harina. \w Serán|strong="H1961"\w* cocidos con levadura, \w como|strong="H1961"\w* primicias \w para|strong="H1961"\w* Yahvé.  
\v 18 \w Junto|strong="H5921"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w pan|strong="H3899"\w*, presentaréis \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w* \w de|strong="H5921"\w* un \w año|strong="H8141"\w* sin defecto, un \w novillo|strong="H1121"\w* \w y|strong="H5921"\w* \w dos|strong="H8147"\w* carneros. \w Serán|strong="H1961"\w* un \w holocausto|strong="H5930"\w* \w para|strong="H5921"\w* Yahvé, \w con|strong="H5921"\w* su \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* cereal \w y|strong="H5921"\w* sus \w libaciones|strong="H5262"\w*, una \w ofrenda|strong="H4503"\w* hecha \w por|strong="H5921"\w* fuego, \w de|strong="H5921"\w* aroma agradable \w para|strong="H5921"\w* Yahvé.  
\v 19 \w Ofreceréis|strong="H6213"\w* también un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w* como \w sacrificio|strong="H2077"\w* por \w el|strong="H1121"\w* \w pecado|strong="H2403"\w*, y \w dos|strong="H8147"\w* \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* como \w sacrificio|strong="H2077"\w* \w de|strong="H1121"\w* comunión.  
\v 20 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w los|strong="H5921"\w* \w mecerá|strong="H5130"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w pan|strong="H3899"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* primicias \w como|strong="H1961"\w* \w ofrenda|strong="H8573"\w* mecida \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w corderos|strong="H3532"\w*. \w Serán|strong="H1961"\w* \w cosas|strong="H8147"\w* consagradas \w a|strong="H3068"\w* Yahvé \w y|strong="H5921"\w* pertenecerán \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w*.  
\v 21 \w Ese|strong="H2088"\w* \w mismo|strong="H6106"\w* \w día|strong="H3117"\w* \w haréis|strong="H6213"\w* una proclamación; \w tendréis|strong="H1961"\w* una asamblea \w santa|strong="H6944"\w*. \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo ordinario. \w Será|strong="H1961"\w* un \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w* en \w todas|strong="H3605"\w* vuestras moradas, \w a|strong="H3068"\w* \w lo|strong="H2088"\w* largo de vuestras \w generaciones|strong="H1755"\w*.   
\p
\v 22 “‘Cuando seguéis la \w mies|strong="H7105"\w* de vuestra tierra, \w no|strong="H3808"\w* \w segaréis|strong="H7114"\w* hasta el último rincón de vuestro \w campo|strong="H7704"\w*, \w ni|strong="H3808"\w* espigaréis los restos de vuestra cosecha. Los \w dejaréis|strong="H5800"\w* para el \w pobre|strong="H6041"\w* y para el forastero. Yo soy Yahvé, vuestro \w Dios|strong="H3068"\w*’”.   
\p
\v 23 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 24 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w diles|strong="H1696"\w*: ‘En \w el|strong="H1121"\w* \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w*, \w el|strong="H1121"\w* primer \w día|strong="H1121"\w* del \w mes|strong="H2320"\w*, \w tendréis|strong="H1961"\w* un \w día|strong="H1121"\w* \w de|strong="H1121"\w* descanso solemne, una conmemoración anunciada con toque \w de|strong="H1121"\w* trompetas, una asamblea \w santa|strong="H6944"\w*.  
\v 25 \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo ordinario, y presentaréis \w a|strong="H3068"\w* Yahvé una ofrenda hecha por fuego’”.   
\p
\v 26 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 27 «\w El|strong="H1931"\w* décimo \w día|strong="H3117"\w* de \w este|strong="H2088"\w* \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w* \w será|strong="H1961"\w* \w el|strong="H1931"\w* \w Día|strong="H3117"\w* de \w la|strong="H1931"\w* Expiación. \w Tendréis|strong="H1961"\w* una asamblea \w santa|strong="H6944"\w*, os \w afligiréis|strong="H6031"\w* y presentaréis \w a|strong="H3068"\w* Yahvé una ofrenda hecha \w por|strong="H2088"\w* fuego.  
\v 28 \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo \w en|strong="H5921"\w* \w ese|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w Día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w Expiación|strong="H3722"\w*, \w para|strong="H5921"\w* \w hacer|strong="H6213"\w* \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* vosotros \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*.  
\v 29 \w Porque|strong="H3588"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w aflija|strong="H6031"\w* \w en|strong="H3588"\w* \w ese|strong="H2088"\w* \w mismo|strong="H6106"\w* \w día|strong="H3117"\w*, \w será|strong="H3808"\w* \w cortado|strong="H3772"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*.  
\v 30 \w A|strong="H3068"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H1931"\w* \w haga|strong="H6213"\w* algún trabajo en \w ese|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*, \w yo|strong="H5315"\w* \w lo|strong="H1931"\w* destruiré \w de|strong="H5971"\w* \w entre|strong="H7130"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*.  
\v 31 \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* trabajo \w alguno|strong="H3605"\w*; \w será|strong="H6213"\w* un \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w* \w a|strong="H3068"\w* \w lo|strong="H3808"\w* largo de vuestras \w generaciones|strong="H1755"\w*, en \w todas|strong="H3605"\w* vuestras moradas.  
\v 32 \w Será|strong="H1931"\w* \w para|strong="H5704"\w* vosotros un día \w de|strong="H5704"\w* descanso solemne, \w y|strong="H5704"\w* \w os|strong="H5704"\w* \w afligiréis|strong="H6031"\w*. \w Desde|strong="H5704"\w* \w el|strong="H1931"\w* atardecer del noveno día del \w mes|strong="H2320"\w* \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* atardecer siguiente, guardaréis vuestro día \w de|strong="H5704"\w* \w reposo|strong="H7673"\w*».   
\p
\v 33 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 34 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Israel|strong="H3478"\w* y \w diles|strong="H1696"\w*: ‘\w El|strong="H1121"\w* \w día|strong="H3117"\w* \w quince|strong="H2568"\w* \w de|strong="H2568"\w* \w este|strong="H2088"\w* \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w* celebréis la \w fiesta|strong="H2282"\w* \w de|strong="H2568"\w* \w los|strong="H1121"\w* Tabernáculos\f + \fr 23:34 \ft o, fiesta de las Cabañas, o Sucot\f* \w a|strong="H3068"\w* Yahvé durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.  
\v 35 \w El|strong="H3605"\w* \w primer|strong="H7223"\w* \w día|strong="H3117"\w* \w habrá|strong="H3117"\w* una asamblea \w santa|strong="H6944"\w*; \w no|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo ordinario.  
\v 36 Durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w* presentaréis ofrendas hechas por fuego \w a|strong="H3068"\w* Yahvé. \w El|strong="H1931"\w* \w octavo|strong="H8066"\w* \w día|strong="H3117"\w* \w tendréis|strong="H1961"\w* una asamblea \w santa|strong="H6944"\w*, y presentaréis \w a|strong="H3068"\w* Yahvé una ofrenda hecha por fuego. \w Es|strong="H1931"\w* una asamblea solemne; \w no|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo ordinario.   
\p
\v 37 “‘Estas son las fiestas solemnes \w de|strong="H1697"\w* Yahvé, \w que|strong="H1697"\w* \w proclamaréis|strong="H7121"\w* como \w asambleas|strong="H4744"\w* \w santas|strong="H6944"\w* para presentar ofrendas hechas \w por|strong="H1697"\w* fuego \w a|strong="H3068"\w* Yahvé: \w holocaustos|strong="H5930"\w* y ofrendas \w de|strong="H1697"\w* cereal, \w sacrificios|strong="H2077"\w* y \w libaciones|strong="H5262"\w*, \w cada|strong="H3117"\w* \w cosa|strong="H1697"\w* en su \w día|strong="H3117"\w* prescrito,  
\v 38 además \w de|strong="H5414"\w* \w los|strong="H3605"\w* días \w de|strong="H5414"\w* reposo \w de|strong="H5414"\w* Yahvé, además \w de|strong="H5414"\w* vuestros \w dones|strong="H4979"\w*, además \w de|strong="H5414"\w* \w todos|strong="H3605"\w* vuestros \w votos|strong="H5088"\w* y además \w de|strong="H5414"\w* \w todas|strong="H3605"\w* vuestras \w ofrendas|strong="H4979"\w* \w voluntarias|strong="H5071"\w* \w que|strong="H5071"\w* deis \w a|strong="H3068"\w* Yahvé.   
\p
\v 39 “‘Así pues, el \w día|strong="H3117"\w* \w quince|strong="H2568"\w* del \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w*, \w cuando|strong="H3117"\w* hayáis recogido los \w frutos|strong="H8393"\w* \w de|strong="H2568"\w* la tierra, celebraréis la \w fiesta|strong="H2282"\w* \w a|strong="H3068"\w* Yahvé durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*. El \w primer|strong="H7223"\w* \w día|strong="H3117"\w* será \w de|strong="H2568"\w* descanso solemne, y el \w octavo|strong="H8066"\w* \w día|strong="H3117"\w* será \w de|strong="H2568"\w* descanso solemne.  
\v 40 El \w primer|strong="H7223"\w* \w día|strong="H3117"\w* \w tomaréis|strong="H3947"\w* \w frutos|strong="H6529"\w* \w de|strong="H6440"\w* \w árboles|strong="H6086"\w* hermosos, ramas \w de|strong="H6440"\w* \w palmeras|strong="H8558"\w*, ramas \w de|strong="H6440"\w* \w árboles|strong="H6086"\w* frondosos y sauces \w de|strong="H6440"\w* los \w arroyos|strong="H5158"\w*, y os alegraréis \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, \w vuestro|strong="H6529"\w* \w Dios|strong="H3068"\w*, durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.  
\v 41 La celebraréis como una \w fiesta|strong="H2282"\w* \w a|strong="H3068"\w* Yahvé durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w cada|strong="H3117"\w* \w año|strong="H8141"\w*. Será un \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w* \w a|strong="H3068"\w* lo largo de vuestras \w generaciones|strong="H1755"\w*; la celebraréis en el \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w*.  
\v 42 \w Habitaréis|strong="H3427"\w* en tabernáculos\f + \fr 23:42 \ft o, cabañas\f* durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*. \w Todos|strong="H3605"\w* \w los|strong="H3427"\w* nativos de \w Israel|strong="H3478"\w* \w habitarán|strong="H3427"\w* en tabernáculos,\f + \fr 23:42 \ft o, cabañas\f*  
\v 43 \w para|strong="H4616"\w* \w que|strong="H3588"\w* vuestras \w generaciones|strong="H1755"\w* \w sepan|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* hice \w habitar|strong="H3427"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w en|strong="H3588"\w* tabernáculos\f + \fr 23:43 \ft o, cabañas\f* \w cuando|strong="H3588"\w* \w los|strong="H3427"\w* \w saqué|strong="H3318"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*. \w Yo|strong="H3588"\w* soy Yahvé, vuestro \w Dios|strong="H3068"\w*’”.   
\p
\v 44 \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* anunció \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* las fiestas solemnes \w de|strong="H1121"\w* Yahvé.   
\c 24
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Manda|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* te \w traigan|strong="H3947"\w* \w aceite|strong="H8081"\w* \w puro|strong="H2134"\w* \w de|strong="H1121"\w* \w olivas|strong="H2132"\w* machacadas para \w el|strong="H1121"\w* alumbrado, \w a|strong="H3068"\w* fin \w de|strong="H1121"\w* hacer arder las \w lámparas|strong="H5216"\w* \w continuamente|strong="H8548"\w*.  
\v 3 \w Fuera|strong="H2351"\w* del velo del \w Testimonio|strong="H5715"\w*, \w en|strong="H5704"\w* la Tienda del Encuentro, Aarón las mantendrá \w en|strong="H5704"\w* orden \w desde|strong="H5704"\w* la \w tarde|strong="H6153"\w* \w hasta|strong="H5704"\w* la \w mañana|strong="H1242"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w de|strong="H6440"\w* forma \w continua|strong="H8548"\w*. Será un \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w* \w a|strong="H3068"\w* \w lo|strong="H5704"\w* largo \w de|strong="H6440"\w* vuestras \w generaciones|strong="H1755"\w*.  
\v 4 \w Él|strong="H5921"\w* mantendrá \w siempre|strong="H8548"\w* \w en|strong="H5921"\w* orden \w las|strong="H5921"\w* \w lámparas|strong="H5216"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* candelabro \w de|strong="H5921"\w* oro \w puro|strong="H2889"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé.   
\p
\v 5 «\w Tomarás|strong="H3947"\w* flor de harina y cocerás con ella \w doce|strong="H8147"\w* \w tortas|strong="H2471"\w*; cada \w torta|strong="H2471"\w* \w será|strong="H1961"\w* de \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* de efa.\f + \fr 24:5 \ft 1 efa son unos 22 litros o unos 2/3 de una fanega\f*  
\v 6 \w Las|strong="H5921"\w* colocarás \w en|strong="H5921"\w* \w dos|strong="H8147"\w* hileras, \w seis|strong="H8337"\w* \w en|strong="H5921"\w* cada hilera, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w mesa|strong="H7979"\w* \w de|strong="H5921"\w* oro \w puro|strong="H2889"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé.  
\v 7 \w Pondrás|strong="H5414"\w* \w incienso|strong="H3828"\w* \w puro|strong="H2134"\w* \w sobre|strong="H5921"\w* cada hilera, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w sea|strong="H1961"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w pan|strong="H3899"\w* \w como|strong="H1961"\w* porción memorial, una ofrenda hecha \w por|strong="H5921"\w* fuego \w a|strong="H3068"\w* Yahvé.  
\v 8 \w Cada|strong="H3117"\w* \w día|strong="H3117"\w* \w de|strong="H6440"\w* reposo \w el|strong="H1121"\w* sacerdote lo pondrá en orden \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w de|strong="H6440"\w* forma \w continua|strong="H8548"\w*. Es un \w pacto|strong="H1285"\w* \w perpetuo|strong="H5769"\w* \w de|strong="H6440"\w* parte \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.  
\v 9 \w El|strong="H1931"\w* pan \w será|strong="H1961"\w* \w para|strong="H3588"\w* Aarón \w y|strong="H3588"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*, quienes \w lo|strong="H1931"\w* comerán \w en|strong="H3588"\w* un \w lugar|strong="H4725"\w* \w sagrado|strong="H6944"\w*, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w para|strong="H3588"\w* \w él|strong="H1931"\w* una porción santísima \w de|strong="H3588"\w* las ofrendas hechas \w por|strong="H3588"\w* fuego \w a|strong="H3068"\w* Yahvé, \w por|strong="H3588"\w* \w estatuto|strong="H2706"\w* \w perpetuo|strong="H5769"\w*».   
\p
\v 10 \w El|strong="H1931"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* una mujer \w israelita|strong="H3482"\w*, \w cuyo|strong="H1931"\w* padre \w era|strong="H1931"\w* \w egipcio|strong="H4713"\w*, \w salió|strong="H3318"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*; y \w el|strong="H1931"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w la|strong="H1931"\w* \w israelita|strong="H3482"\w* y un \w hombre|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w riñeron|strong="H5327"\w* \w en|strong="H8432"\w* \w el|strong="H1931"\w* \w campamento|strong="H4264"\w*.  
\v 11 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* la mujer \w israelita|strong="H3482"\w* blasfemó \w el|strong="H1121"\w* \w Nombre|strong="H8034"\w* y lo \w maldijo|strong="H7043"\w*, por lo \w que|strong="H1121"\w* lo llevaron \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*. Su madre se \w llamaba|strong="H8034"\w* Selomit, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Dibri, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w*.  
\v 12 \w Lo|strong="H5921"\w* \w pusieron|strong="H3240"\w* bajo custodia \w hasta|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w les|strong="H1992"\w* declarara \w la|strong="H5921"\w* voluntad \w de|strong="H5921"\w* Yahvé.  
\v 13 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 14 “\w Saca|strong="H3318"\w* \w fuera|strong="H2351"\w* \w del|strong="H5921"\w* \w campamento|strong="H4264"\w* \w al|strong="H5921"\w* \w que|strong="H5921"\w* ha maldecido. \w Que|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w lo|strong="H5921"\w* \w oyeron|strong="H8085"\w* \w pongan|strong="H5564"\w* sus \w manos|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* asamblea \w lo|strong="H5921"\w* apedree.  
\v 15 \w Hablarás|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w diciendo|strong="H1696"\w*: ‘Cualquiera \w que|strong="H3588"\w* maldiga \w a|strong="H3068"\w* \w su|strong="H3588"\w* Dios cargará \w con|strong="H3588"\w* \w su|strong="H3588"\w* \w pecado|strong="H2399"\w*.  
\v 16 \w El|strong="H3605"\w* \w que|strong="H1616"\w* blasfeme \w el|strong="H3605"\w* \w nombre|strong="H8034"\w* de Yahvé, \w morirá|strong="H4191"\w* \w irremisiblemente|strong="H4191"\w*; \w toda|strong="H3605"\w* \w la|strong="H3605"\w* asamblea \w lo|strong="H3605"\w* apedreará. \w Ya|strong="H3068"\w* sea forastero \w o|strong="H3068"\w* nativo, si blasfema \w el|strong="H3605"\w* \w Nombre|strong="H8034"\w*, \w morirá|strong="H4191"\w*.   
\p
\v 17 “‘\w El|strong="H3588"\w* \w que|strong="H3588"\w* \w hiera|strong="H5221"\w* mortalmente \w a|strong="H3068"\w* \w cualquier|strong="H3605"\w* \w ser|strong="H5315"\w* humano, \w morirá|strong="H4191"\w* \w irremisiblemente|strong="H4191"\w*.  
\v 18 El que \w hiera|strong="H5221"\w* mortalmente \w a|strong="H3068"\w* un \w animal|strong="H5315"\w* \w de|strong="H8478"\w* otro, lo restituirá: \w vida|strong="H5315"\w* \w por|strong="H8478"\w* \w vida|strong="H5315"\w*.  
\v 19 \w Si|strong="H3588"\w* alguien causa una \w lesión|strong="H3971"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* prójimo, según \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w hizo|strong="H6213"\w*, \w así|strong="H3651"\w* \w se|strong="H3651"\w* le \w hará|strong="H6213"\w* \w a|strong="H3068"\w* \w él|strong="H3588"\w*:  
\v 20 fractura \w por|strong="H8478"\w* fractura, \w ojo|strong="H5869"\w* \w por|strong="H8478"\w* \w ojo|strong="H5869"\w*, \w diente|strong="H8127"\w* \w por|strong="H8478"\w* \w diente|strong="H8127"\w*. Según la \w lesión|strong="H3971"\w* que \w haya|strong="H3971"\w* causado \w a|strong="H3068"\w* otro, \w así|strong="H3651"\w* \w se|strong="H3651"\w* \w le|strong="H5869"\w* \w hará|strong="H5414"\w* \w a|strong="H3068"\w* él.  
\v 21 El que \w mate|strong="H4191"\w* \w a|strong="H3068"\w* un animal, lo restituirá; pero el que \w mate|strong="H4191"\w* \w a|strong="H3068"\w* un hombre, \w morirá|strong="H4191"\w*.  
\v 22 \w Tendréis|strong="H1961"\w* un solo \w derecho|strong="H4941"\w*, tanto \w para|strong="H3588"\w* \w el|strong="H3588"\w* forastero \w como|strong="H3588"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* nativo, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*’”.   
\p
\v 23 \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w así|strong="H7043"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w sacaron|strong="H3318"\w* \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w* al \w que|strong="H1121"\w* \w había|strong="H6213"\w* maldecido y \w lo|strong="H6213"\w* apedrearon. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w hicieron|strong="H6213"\w* tal como Yahvé se \w lo|strong="H6213"\w* \w había|strong="H6213"\w* \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\c 25
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* en el \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Cuando|strong="H3588"\w* entréis \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* os \w doy|strong="H5414"\w*, \w la|strong="H3588"\w* tierra guardará un \w sábado|strong="H7676"\w* \w de|strong="H3588"\w* \w reposo|strong="H7673"\w* \w para|strong="H3588"\w* Yahvé.  
\v 3 \w Sembrarás|strong="H2232"\w* tu \w campo|strong="H7704"\w* durante \w seis|strong="H8337"\w* \w años|strong="H8141"\w*, y \w podarás|strong="H2168"\w* tu \w viña|strong="H3754"\w* durante \w seis|strong="H8337"\w* \w años|strong="H8141"\w*, y recogerás sus \w frutos|strong="H8393"\w*;  
\v 4 pero el \w séptimo|strong="H7637"\w* \w año|strong="H8141"\w* \w será|strong="H1961"\w* un \w sábado|strong="H7676"\w* de descanso solemne \w para|strong="H1961"\w* la tierra, un \w sábado|strong="H7676"\w* consagrado \w a|strong="H3068"\w* Yahvé. \w No|strong="H3808"\w* \w sembrarás|strong="H2232"\w* tu \w campo|strong="H7704"\w* \w ni|strong="H3808"\w* \w podarás|strong="H2168"\w* tu \w viña|strong="H3754"\w*.  
\v 5 \w Lo|strong="H3808"\w* \w que|strong="H3808"\w* crezca por \w sí|strong="H3808"\w* mismo de tu cosecha \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w segarás|strong="H7114"\w*, y \w no|strong="H3808"\w* \w vendimiarás|strong="H1219"\w* las \w uvas|strong="H6025"\w* de tu viña \w no|strong="H3808"\w* podada. \w Será|strong="H1961"\w* un \w año|strong="H8141"\w* de descanso solemne \w para|strong="H1961"\w* la tierra.  
\v 6 \w El|strong="H5973"\w* descanso \w de|strong="H5973"\w* la tierra \w os|strong="H5973"\w* \w servirá|strong="H1961"\w* \w de|strong="H5973"\w* alimento: \w a|strong="H3068"\w* \w ti|strong="H5973"\w*, \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w*, \w a|strong="H3068"\w* tu sierva, \w a|strong="H3068"\w* tu jornalero y al forastero \w que|strong="H1961"\w* reside \w contigo|strong="H5973"\w*.  
\v 7 También \w para|strong="H1961"\w* tu ganado y \w para|strong="H1961"\w* \w los|strong="H3605"\w* \w animales|strong="H2416"\w* silvestres \w que|strong="H1961"\w* \w estén|strong="H1961"\w* en tu tierra, \w todo|strong="H3605"\w* su producto \w servirá|strong="H1961"\w* de alimento.   
\p
\v 8 “‘Contarás \w siete|strong="H7651"\w* \w semanas|strong="H7676"\w* de \w años|strong="H8141"\w*, \w siete|strong="H7651"\w* \w veces|strong="H6471"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w*; de modo \w que|strong="H3117"\w* el \w tiempo|strong="H3117"\w* de las \w siete|strong="H7651"\w* \w semanas|strong="H7676"\w* de \w años|strong="H8141"\w* te sumará cuarenta y \w nueve|strong="H8672"\w* \w años|strong="H8141"\w*.  
\v 9 \w Entonces|strong="H3117"\w* harás resonar \w la|strong="H3605"\w* \w trompeta|strong="H7782"\w* \w el|strong="H3605"\w* décimo \w día|strong="H3117"\w* del \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w*. En \w el|strong="H3605"\w* \w Día|strong="H3117"\w* de \w la|strong="H3605"\w* Expiación haréis tocar \w la|strong="H3605"\w* \w trompeta|strong="H7782"\w* por \w toda|strong="H3605"\w* vuestra tierra.  
\v 10 Santificaréis \w el|strong="H1931"\w* \w año|strong="H8141"\w* quincuagésimo y \w proclamaréis|strong="H7121"\w* \w la|strong="H1931"\w* \w libertad|strong="H1865"\w* en \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra \w para|strong="H1961"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w habitantes|strong="H3427"\w*. \w Será|strong="H1961"\w* un \w jubileo|strong="H3104"\w* \w para|strong="H1961"\w* vosotros; \w cada|strong="H3605"\w* uno de vosotros recobrará \w su|strong="H1931"\w* propiedad, y \w cada|strong="H3605"\w* uno de vosotros regresará \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w familia|strong="H4940"\w*.  
\v 11 \w Ese|strong="H1931"\w* \w año|strong="H8141"\w* quincuagésimo \w será|strong="H1961"\w* un \w jubileo|strong="H3104"\w* \w para|strong="H1961"\w* vosotros. En \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w sembraréis|strong="H2232"\w*, \w ni|strong="H3808"\w* \w segaréis|strong="H7114"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* crezca por \w sí|strong="H3808"\w* \w mismo|strong="H1931"\w*, \w ni|strong="H3808"\w* \w vendimiaréis|strong="H1219"\w* las viñas \w no|strong="H3808"\w* podadas.  
\v 12 \w Porque|strong="H3588"\w* \w es|strong="H1931"\w* un \w jubileo|strong="H3104"\w*, \w será|strong="H1961"\w* \w sagrado|strong="H6944"\w* \w para|strong="H3588"\w* vosotros. Comeréis directamente \w del|strong="H4480"\w* \w campo|strong="H7704"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* \w la|strong="H1931"\w* tierra produzca.   
\p
\v 13 “‘En \w este|strong="H2063"\w* \w Año|strong="H8141"\w* del \w Jubileo|strong="H3104"\w*, \w cada|strong="H8141"\w* uno de vosotros \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* su propiedad.   
\p
\v 14 “‘\w Si|strong="H3588"\w* vendes \w algo|strong="H4465"\w* \w a|strong="H3068"\w* tu prójimo, \w o|strong="H3068"\w* compras \w algo|strong="H4465"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* tu prójimo, \w no|strong="H3588"\w* os \w engañéis|strong="H3238"\w* unos \w a|strong="H3068"\w* otros.  
\v 15 \w Comprarás|strong="H7069"\w* \w a|strong="H3068"\w* tu prójimo conforme al \w número|strong="H4557"\w* de \w años|strong="H8141"\w* transcurridos desde el \w jubileo|strong="H3104"\w*. Él te \w venderá|strong="H4376"\w* conforme al \w número|strong="H4557"\w* de \w años|strong="H8141"\w* de cosecha que queden.  
\v 16 \w Si|strong="H3588"\w* \w los|strong="H1931"\w* \w años|strong="H8141"\w* \w son|strong="H3588"\w* \w muchos|strong="H7235"\w*, \w aumentarás|strong="H7235"\w* \w su|strong="H1931"\w* precio, \w y|strong="H3588"\w* \w si|strong="H3588"\w* \w los|strong="H1931"\w* \w años|strong="H8141"\w* \w son|strong="H3588"\w* \w pocos|strong="H4557"\w*, \w disminuirás|strong="H8141"\w* \w su|strong="H1931"\w* precio, \w porque|strong="H3588"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* \w él|strong="H1931"\w* \w te|strong="H3588"\w* \w vende|strong="H4376"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w número|strong="H4557"\w* \w de|strong="H3588"\w* las cosechas.  
\v 17 \w No|strong="H3808"\w* os oprimiréis unos \w a|strong="H3068"\w* otros, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w temeréis|strong="H3372"\w* \w a|strong="H3068"\w* vuestro \w Dios|strong="H3068"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, vuestro \w Dios|strong="H3068"\w*.   
\p
\v 18 “‘\w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, pondréis \w por|strong="H5921"\w* \w obra|strong="H6213"\w* mis \w estatutos|strong="H2708"\w*, \w y|strong="H5921"\w* \w guardaréis|strong="H8104"\w* mis \w ordenanzas|strong="H4941"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* cumpliréis, \w para|strong="H5921"\w* \w que|strong="H5921"\w* habitéis \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w con|strong="H5921"\w* seguridad.  
\v 19 \w La|strong="H5921"\w* tierra \w dará|strong="H5414"\w* su \w fruto|strong="H6529"\w*, comeréis \w hasta|strong="H5921"\w* saciaros \w y|strong="H5921"\w* \w habitaréis|strong="H3427"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w con|strong="H5921"\w* seguridad.  
\v 20 \w Si|strong="H3588"\w* decís: «¿\w Qué|strong="H3588"\w* comeremos \w el|strong="H3588"\w* \w séptimo|strong="H7637"\w* \w año|strong="H8141"\w*, \w si|strong="H3588"\w* \w no|strong="H3808"\w* sembramos \w ni|strong="H3808"\w* recogemos nuestras cosechas?»,  
\v 21 entonces \w yo|strong="H6680"\w* os enviaré mi \w bendición|strong="H1293"\w* en \w el|strong="H6213"\w* \w sexto|strong="H8345"\w* \w año|strong="H8141"\w*, de modo que producirá \w fruto|strong="H8393"\w* para \w tres|strong="H7969"\w* \w años|strong="H8141"\w*.  
\v 22 \w En|strong="H4480"\w* el \w octavo|strong="H8066"\w* \w año|strong="H8141"\w* \w sembraréis|strong="H2232"\w* \w y|strong="H5704"\w* comeréis \w de|strong="H4480"\w* la cosecha añeja; \w hasta|strong="H5704"\w* el \w noveno|strong="H8671"\w* \w año|strong="H8141"\w*, \w hasta|strong="H5704"\w* \w que|strong="H4480"\w* llegue su nueva cosecha, seguiréis comiendo \w de|strong="H4480"\w* la añeja.   
\p
\v 23 “‘\w La|strong="H3588"\w* tierra \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w venderá|strong="H4376"\w* \w a|strong="H3068"\w* perpetuidad, \w pues|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w es|strong="H3588"\w* mía, \w porque|strong="H3588"\w* vosotros sois \w para|strong="H3588"\w* mí forasteros \w y|strong="H3588"\w* huéspedes.  
\v 24 \w Por|strong="H5414"\w* tanto, en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5414"\w* vuestra posesión concederéis \w el|strong="H3605"\w* derecho \w de|strong="H5414"\w* rescate \w por|strong="H5414"\w* \w la|strong="H3605"\w* tierra.   
\p
\v 25 “‘\w Si|strong="H3588"\w* tu hermano se empobrece \w y|strong="H3588"\w* \w vende|strong="H4376"\w* parte \w de|strong="H3588"\w* \w su|strong="H3588"\w* posesión, \w entonces|strong="H3588"\w* \w su|strong="H3588"\w* \w pariente|strong="H1350"\w* \w más|strong="H3588"\w* \w cercano|strong="H7138"\w* vendrá \w y|strong="H3588"\w* rescatará lo \w que|strong="H3588"\w* \w su|strong="H3588"\w* hermano haya vendido.  
\v 26 \w Si|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w no|strong="H3808"\w* \w tiene|strong="H1961"\w* \w a|strong="H3068"\w* \w nadie|strong="H3808"\w* \w que|strong="H3588"\w* \w lo|strong="H3808"\w* rescate, \w pero|strong="H3588"\w* prospera \w y|strong="H3588"\w* \w halla|strong="H4672"\w* \w lo|strong="H3808"\w* suficiente \w para|strong="H3588"\w* \w su|strong="H3588"\w* rescate,  
\v 27 \w entonces|strong="H7725"\w* \w calculará|strong="H2803"\w* los \w años|strong="H8141"\w* transcurridos desde su venta y devolverá el excedente al hombre \w a|strong="H3068"\w* quien se la \w vendió|strong="H4376"\w*; y así \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* su posesión.  
\v 28 Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* consigue \w lo|strong="H3808"\w* suficiente \w para|strong="H5704"\w* recuperarla, \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w haya|strong="H1961"\w* vendido \w quedará|strong="H1961"\w* \w en|strong="H5704"\w* \w poder|strong="H3027"\w* del comprador \w hasta|strong="H5704"\w* el \w Año|strong="H8141"\w* del \w Jubileo|strong="H3104"\w*. \w En|strong="H5704"\w* el \w jubileo|strong="H3104"\w* la propiedad \w quedará|strong="H1961"\w* libre, \w y|strong="H5704"\w* él \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* su posesión.   
\p
\v 29 “‘\w Si|strong="H3588"\w* un hombre \w vende|strong="H4376"\w* una \w casa|strong="H1004"\w* \w de|strong="H3588"\w* vivienda \w en|strong="H5704"\w* una \w ciudad|strong="H5892"\w* amurallada, \w tendrá|strong="H1961"\w* derecho \w a|strong="H3068"\w* rescatarla durante un \w año|strong="H8141"\w* entero \w después|strong="H1961"\w* \w de|strong="H3588"\w* haberla vendido. Durante un \w año|strong="H8141"\w* completo \w tendrá|strong="H1961"\w* \w el|strong="H3588"\w* derecho \w de|strong="H3588"\w* rescate.  
\v 30 \w Si|strong="H3808"\w* \w no|strong="H3808"\w* es rescatada \w en|strong="H5704"\w* el plazo \w de|strong="H5704"\w* un \w año|strong="H8141"\w* completo, la \w casa|strong="H1004"\w* \w que|strong="H3808"\w* \w está|strong="H6965"\w* \w en|strong="H5704"\w* la \w ciudad|strong="H5892"\w* amurallada \w quedará|strong="H6965"\w* asegurada \w a|strong="H3068"\w* perpetuidad \w para|strong="H5704"\w* el \w que|strong="H3808"\w* la \w compró|strong="H7069"\w*, \w por|strong="H5704"\w* \w todas|strong="H1755"\w* sus \w generaciones|strong="H1755"\w*. \w No|strong="H3808"\w* \w quedará|strong="H6965"\w* libre \w en|strong="H5704"\w* el \w jubileo|strong="H3104"\w*.  
\v 31 Pero \w las|strong="H1992"\w* \w casas|strong="H1004"\w* \w de|strong="H5921"\w* \w las|strong="H1992"\w* \w aldeas|strong="H2691"\w* \w que|strong="H5921"\w* \w no|strong="H1961"\w* \w tienen|strong="H1992"\w* \w muro|strong="H2346"\w* \w alrededor|strong="H5439"\w* \w serán|strong="H1961"\w* consideradas \w como|strong="H1961"\w* \w los|strong="H1992"\w* \w campos|strong="H7704"\w* \w del|strong="H5921"\w* país; podrán ser rescatadas, \w y|strong="H5921"\w* quedarán libres \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w jubileo|strong="H3104"\w*.   
\p
\v 32 “‘En cuanto \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w* de \w los|strong="H1961"\w* \w levitas|strong="H3881"\w*, \w los|strong="H1961"\w* \w levitas|strong="H3881"\w* \w tendrán|strong="H1961"\w* derecho \w perpetuo|strong="H5769"\w* \w para|strong="H1961"\w* rescatar las \w casas|strong="H1004"\w* de las \w ciudades|strong="H5892"\w* de su posesión.  
\v 33 \w Lo|strong="H1931"\w* \w que|strong="H3588"\w* sea rescatado \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, \w es|strong="H1931"\w* decir, \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w vendida|strong="H4465"\w* \w en|strong="H4480"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w de|strong="H4480"\w* \w su|strong="H1931"\w* posesión, quedará libre \w en|strong="H4480"\w* \w el|strong="H1931"\w* \w jubileo|strong="H3104"\w*, \w porque|strong="H3588"\w* las \w casas|strong="H1004"\w* \w de|strong="H4480"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w son|strong="H3588"\w* \w su|strong="H1931"\w* posesión \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*.  
\v 34 \w Pero|strong="H3588"\w* \w el|strong="H1931"\w* \w campo|strong="H7704"\w* \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w ejidos|strong="H4054"\w* \w de|strong="H3588"\w* \w sus|strong="H1931"\w* \w ciudades|strong="H5892"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* \w venderá|strong="H4376"\w*, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* posesión \w perpetua|strong="H5769"\w*.   
\p
\v 35 “‘\w Si|strong="H3588"\w* tu hermano se empobrece \w y|strong="H3588"\w* \w no|strong="H3588"\w* puede sostenerse \w entre|strong="H5973"\w* \w vosotros|strong="H5973"\w*, tú lo mantendrás. \w Vivirá|strong="H2421"\w* \w contigo|strong="H5973"\w* \w como|strong="H3588"\w* un forastero \w y|strong="H3588"\w* un residente temporal.  
\v 36 No \w le|strong="H5973"\w* cobrarás intereses \w ni|strong="H5973"\w* \w le|strong="H5973"\w* exigirás ganancias, sino que \w temerás|strong="H3372"\w* \w a|strong="H3068"\w* tu Dios, \w para|strong="H5973"\w* que tu hermano pueda \w vivir|strong="H2421"\w* \w junto|strong="H5973"\w* \w a|strong="H3068"\w* \w ti|strong="H5973"\w*.  
\v 37 \w No|strong="H3808"\w* le prestarás tu \w dinero|strong="H3701"\w* con intereses, \w ni|strong="H3808"\w* le \w darás|strong="H5414"\w* tus alimentos \w para|strong="H5414"\w* obtener lucro.  
\v 38 Yo \w soy|strong="H1961"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*, \w que|strong="H1961"\w* os \w saqué|strong="H3318"\w* \w de|strong="H5414"\w* la tierra \w de|strong="H5414"\w* \w Egipto|strong="H4714"\w* \w para|strong="H5414"\w* daros la tierra \w de|strong="H5414"\w* \w Canaán|strong="H3667"\w* y \w para|strong="H5414"\w* ser vuestro \w Dios|strong="H3068"\w*.   
\p
\v 39 “‘\w Si|strong="H3588"\w* tu hermano \w se|strong="H3808"\w* empobrece estando \w contigo|strong="H5973"\w* \w y|strong="H3588"\w* \w se|strong="H3808"\w* \w vende|strong="H4376"\w* \w a|strong="H3068"\w* \w ti|strong="H5973"\w*, \w no|strong="H3808"\w* \w le|strong="H5973"\w* \w harás|strong="H5647"\w* \w servir|strong="H5647"\w* \w como|strong="H3588"\w* esclavo.  
\v 40 \w Estará|strong="H1961"\w* \w contigo|strong="H5973"\w* \w como|strong="H5973"\w* un jornalero \w o|strong="H3068"\w* \w como|strong="H5973"\w* un residente temporal; \w te|strong="H5973"\w* \w servirá|strong="H5647"\w* \w hasta|strong="H5704"\w* \w el|strong="H5973"\w* \w Año|strong="H8141"\w* \w del|strong="H5973"\w* \w Jubileo|strong="H3104"\w*.  
\v 41 \w Entonces|strong="H7725"\w* \w saldrá|strong="H3318"\w* libre \w de|strong="H5973"\w* tu casa, \w él|strong="H1931"\w* y \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w*, y \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w familia|strong="H4940"\w* y \w a|strong="H3068"\w* \w la|strong="H1931"\w* posesión \w de|strong="H5973"\w* \w sus|strong="H1931"\w* padres.  
\v 42 \w Porque|strong="H3588"\w* \w son|strong="H3588"\w* mis \w siervos|strong="H5650"\w*, \w a|strong="H3068"\w* quienes \w yo|strong="H3588"\w* \w saqué|strong="H3318"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*. \w No|strong="H3808"\w* \w serán|strong="H1992"\w* \w vendidos|strong="H4376"\w* \w a|strong="H3068"\w* manera \w de|strong="H3588"\w* esclavos.  
\v 43 \w No|strong="H3808"\w* te enseñorearás \w de|strong="H3372"\w* él con dureza, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w temerás|strong="H3372"\w* \w a|strong="H3068"\w* tu Dios.   
\p
\v 44 “‘En cuanto \w a|strong="H3068"\w* \w los|strong="H1992"\w* esclavos y esclavas \w que|strong="H1961"\w* puedas \w tener|strong="H1961"\w* de \w las|strong="H1992"\w* \w naciones|strong="H1471"\w* \w que|strong="H1961"\w* te \w rodean|strong="H5439"\w*, de \w ellos|strong="H1992"\w* \w podréis|strong="H1961"\w* comprar esclavos y esclavas.  
\v 45 \w También|strong="H1571"\w* \w podréis|strong="H1961"\w* comprar \w de|strong="H5973"\w* \w entre|strong="H5973"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w los|strong="H1992"\w* forasteros \w que|strong="H1571"\w* residen \w entre|strong="H5973"\w* \w vosotros|strong="H5973"\w*, \w y|strong="H1571"\w* \w de|strong="H5973"\w* \w sus|strong="H1992"\w* \w familias|strong="H4940"\w* \w que|strong="H1571"\w* \w están|strong="H1961"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*, \w los|strong="H1992"\w* \w que|strong="H1571"\w* hayan \w nacido|strong="H3205"\w* \w en|strong="H5973"\w* \w vuestra|strong="H1961"\w* tierra; \w y|strong="H1571"\w* \w serán|strong="H1961"\w* \w vuestra|strong="H1961"\w* propiedad.  
\v 46 \w Los|strong="H1121"\w* podréis dejar en herencia \w a|strong="H3068"\w* \w vuestros|strong="H5647"\w* \w hijos|strong="H1121"\w* después \w de|strong="H1121"\w* vosotros, para \w que|strong="H3808"\w* \w los|strong="H1121"\w* \w posean|strong="H3423"\w* como herencia. \w De|strong="H1121"\w* ellos os \w serviréis|strong="H5647"\w* \w siempre|strong="H5769"\w* como esclavos, pero sobre \w vuestros|strong="H5647"\w* hermanos, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w no|strong="H3808"\w* os enseñorearéis con dureza unos sobre otros.   
\p
\v 47 “‘\w Si|strong="H3588"\w* un forastero \w o|strong="H3068"\w* residente temporal \w que|strong="H3588"\w* vive \w contigo|strong="H5973"\w* se enriquece, \w y|strong="H3588"\w* tu hermano \w que|strong="H3588"\w* está \w junto|strong="H5973"\w* \w a|strong="H3068"\w* \w él|strong="H5973"\w* se empobrece \w y|strong="H3588"\w* se \w vende|strong="H4376"\w* al forastero \w o|strong="H3068"\w* residente temporal \w que|strong="H3588"\w* vive \w contigo|strong="H5973"\w*, \w o|strong="H3068"\w* \w a|strong="H3068"\w* un miembro \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w familia|strong="H4940"\w* \w del|strong="H5973"\w* forastero,  
\v 48 \w después|strong="H1961"\w* de haberse vendido conservará el derecho de ser rescatado. Uno de sus hermanos \w podrá|strong="H4376"\w* rescatarlo;  
\v 49 \w o|strong="H3068"\w* su \w tío|strong="H1730"\w*, \w o|strong="H3068"\w* \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* su \w tío|strong="H1730"\w*, podrá rescatarlo, \w o|strong="H3068"\w* cualquier \w pariente|strong="H1350"\w* cercano \w de|strong="H1121"\w* su \w familia|strong="H4940"\w* podrá rescatarlo; \w o|strong="H3068"\w* si \w él|strong="H1121"\w* mismo consigue \w los|strong="H1121"\w* medios, podrá rescatarse \w a|strong="H3068"\w* sí mismo.  
\v 50 \w Hará|strong="H1961"\w* \w el|strong="H5973"\w* cálculo \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w que|strong="H5704"\w* \w lo|strong="H5704"\w* \w compró|strong="H7069"\w*, \w desde|strong="H5704"\w* \w el|strong="H5973"\w* \w año|strong="H8141"\w* \w en|strong="H5973"\w* \w que|strong="H5704"\w* \w se|strong="H1961"\w* \w vendió|strong="H4376"\w* \w a|strong="H3068"\w* \w él|strong="H5973"\w* \w hasta|strong="H5704"\w* \w el|strong="H5973"\w* \w Año|strong="H8141"\w* \w del|strong="H5973"\w* \w Jubileo|strong="H3104"\w*. \w El|strong="H5973"\w* \w precio|strong="H3701"\w* \w de|strong="H5973"\w* su venta \w se|strong="H1961"\w* \w calculará|strong="H2803"\w* según \w el|strong="H5973"\w* \w número|strong="H4557"\w* \w de|strong="H5973"\w* \w años|strong="H8141"\w*, \w y|strong="H5704"\w* \w el|strong="H5973"\w* \w tiempo|strong="H3117"\w* \w que|strong="H5704"\w* \w haya|strong="H1961"\w* \w estado|strong="H1961"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w se|strong="H1961"\w* contará \w como|strong="H5973"\w* \w el|strong="H5973"\w* \w tiempo|strong="H3117"\w* \w de|strong="H5973"\w* un jornalero.  
\v 51 Si \w aún|strong="H5750"\w* faltan \w muchos|strong="H7227"\w* \w años|strong="H8141"\w*, \w en|strong="H5750"\w* proporción \w a|strong="H3068"\w* ellos devolverá para su rescate parte del \w dinero|strong="H3701"\w* \w por|strong="H5750"\w* el \w que|strong="H6310"\w* fue \w comprado|strong="H4736"\w*.  
\v 52 Si faltan \w pocos|strong="H4592"\w* \w años|strong="H8141"\w* \w para|strong="H5704"\w* el \w Año|strong="H8141"\w* del \w Jubileo|strong="H3104"\w*, \w hará|strong="H6310"\w* el cálculo \w con|strong="H5704"\w* él \w y|strong="H5704"\w* le devolverá el precio \w de|strong="H5704"\w* su rescate \w en|strong="H5704"\w* proporción \w a|strong="H3068"\w* sus \w años|strong="H8141"\w* \w de|strong="H5704"\w* servicio.  
\v 53 \w Estará|strong="H1961"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w como|strong="H5973"\w* un trabajador contratado \w año|strong="H8141"\w* por \w año|strong="H8141"\w*. \w El|strong="H5973"\w* amo \w no|strong="H3808"\w* \w se|strong="H1961"\w* enseñoreará \w de|strong="H5973"\w* \w él|strong="H5973"\w* \w con|strong="H5973"\w* dureza ante tus propios \w ojos|strong="H5869"\w*.  
\v 54 \w Si|strong="H3808"\w* \w no|strong="H3808"\w* \w es|strong="H1931"\w* rescatado por \w estos|strong="H1931"\w* medios, quedará libre \w en|strong="H5973"\w* \w el|strong="H1931"\w* \w Año|strong="H8141"\w* \w del|strong="H5973"\w* \w Jubileo|strong="H3104"\w*, \w él|strong="H1931"\w* y \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w*.  
\v 55 \w Porque|strong="H3588"\w* \w para|strong="H3588"\w* mí \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w son|strong="H3588"\w* \w siervos|strong="H5650"\w*; \w son|strong="H3588"\w* mis \w siervos|strong="H5650"\w*, \w a|strong="H3068"\w* quienes \w saqué|strong="H3318"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*. \w Yo|strong="H3588"\w* soy Yahvé, vuestro \w Dios|strong="H3068"\w*.   
\c 26
\p
\v 1 “‘\w No|strong="H3808"\w* \w os|strong="H5921"\w* \w haréis|strong="H6213"\w* ídolos, \w ni|strong="H3808"\w* \w os|strong="H5921"\w* \w levantaréis|strong="H6965"\w* \w imagen|strong="H6459"\w* tallada \w ni|strong="H3808"\w* pilares sagrados, \w ni|strong="H3808"\w* \w pondréis|strong="H5414"\w* \w en|strong="H5921"\w* vuestra tierra piedra grabada \w para|strong="H5921"\w* inclinaros ante \w ella|strong="H5921"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, vuestro \w Dios|strong="H3068"\w*.   
\p
\v 2 “‘\w Guardaréis|strong="H8104"\w* mis días \w de|strong="H3372"\w* reposo y \w tendréis|strong="H8104"\w* reverencia por mi \w santuario|strong="H4720"\w*. Yo soy Yahvé.   
\p
\v 3 “‘Si andáis \w en|strong="H3212"\w* mis \w estatutos|strong="H2708"\w*, guardáis mis \w mandamientos|strong="H4687"\w* y los ponéis por \w obra|strong="H6213"\w*,  
\v 4 \w entonces|strong="H6256"\w* os \w daré|strong="H5414"\w* las \w lluvias|strong="H1653"\w* \w a|strong="H3068"\w* su \w tiempo|strong="H6256"\w*, la tierra \w dará|strong="H5414"\w* sus productos y los \w árboles|strong="H6086"\w* del \w campo|strong="H7704"\w* \w darán|strong="H5414"\w* su \w fruto|strong="H6529"\w*.  
\v 5 Vuestra trilla durará hasta la vendimia, y la vendimia durará hasta \w el|strong="H3427"\w* tiempo de la \w siembra|strong="H2233"\w*. Comeréis vuestro \w pan|strong="H3899"\w* hasta saciaros y \w habitaréis|strong="H3427"\w* en vuestra tierra con seguridad.   
\p
\v 6 “‘\w Yo|strong="H4480"\w* \w daré|strong="H5414"\w* \w paz|strong="H7965"\w* \w en|strong="H4480"\w* la tierra, y \w os|strong="H4480"\w* acostaréis \w sin|strong="H3808"\w* \w que|strong="H4480"\w* \w nadie|strong="H3808"\w* \w os|strong="H4480"\w* infunda temor. Quitaré \w de|strong="H4480"\w* la tierra las \w bestias|strong="H2416"\w* feroces, y la \w espada|strong="H2719"\w* \w no|strong="H3808"\w* \w pasará|strong="H5674"\w* \w por|strong="H4480"\w* vuestra tierra.  
\v 7 Perseguiréis \w a|strong="H3068"\w* vuestros enemigos, y \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros.  
\v 8 \w Cinco|strong="H2568"\w* \w de|strong="H4480"\w* vosotros \w perseguirán|strong="H7291"\w* \w a|strong="H3068"\w* \w cien|strong="H3967"\w*, y \w cien|strong="H3967"\w* \w de|strong="H4480"\w* vosotros \w perseguirán|strong="H7291"\w* \w a|strong="H3068"\w* diez \w mil|strong="H7233"\w*, y vuestros enemigos \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* vosotros.   
\p
\v 9 “‘Me volveré hacia vosotros, os haré fecundos, os \w multiplicaré|strong="H7235"\w* y \w confirmaré|strong="H6965"\w* mi \w pacto|strong="H1285"\w* con vosotros.  
\v 10 Comeréis \w de|strong="H6440"\w* las provisiones \w añejas|strong="H3465"\w* guardadas durante mucho tiempo, y tendréis que sacar lo \w añejo|strong="H3465"\w* para hacer lugar \w a|strong="H3068"\w* lo \w nuevo|strong="H2319"\w*.  
\v 11 Estableceré \w mi|strong="H5315"\w* morada \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5414"\w* vosotros, y \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w no|strong="H3808"\w* os abominará.  
\v 12 \w Andaré|strong="H1980"\w* \w entre|strong="H8432"\w* vosotros y \w seré|strong="H1961"\w* vuestro Dios, y vosotros \w seréis|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*.  
\v 13 Yo \w soy|strong="H1961"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*, \w que|strong="H1961"\w* os \w saqué|strong="H3318"\w* de la tierra de \w Egipto|strong="H4714"\w* \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w no|strong="H1961"\w* fuerais sus esclavos. Rompí las coyundas de vuestro \w yugo|strong="H5923"\w* y os he \w hecho|strong="H1961"\w* caminar con la cabeza erguida.   
\p
\v 14 “‘Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* me escucháis y \w no|strong="H3808"\w* ponéis por \w obra|strong="H6213"\w* \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* \w mandamientos|strong="H4687"\w*,  
\v 15 \w si|strong="H5315"\w* rechazáis mis \w estatutos|strong="H2708"\w* y vuestra \w alma|strong="H5315"\w* \w aborrece|strong="H3988"\w* mis \w ordenanzas|strong="H4941"\w*, de modo \w que|strong="H1115"\w* \w no|strong="H6213"\w* cumpláis \w todos|strong="H3605"\w* mis \w mandamientos|strong="H4687"\w* y quebrantéis \w mi|strong="H5315"\w* \w pacto|strong="H1285"\w*,  
\v 16 entonces \w yo|strong="H5315"\w* \w haré|strong="H6213"\w* \w esto|strong="H2063"\w* \w con|strong="H5921"\w* vosotros: \w Enviaré|strong="H6485"\w* \w sobre|strong="H5921"\w* vosotros un terror repentino, tisis \w y|strong="H5921"\w* fiebre, \w que|strong="H5921"\w* consumirán \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w y|strong="H5921"\w* marchitarán \w el|strong="H5921"\w* \w alma|strong="H5315"\w*. \w Sembraréis|strong="H2232"\w* \w vuestra|strong="H2063"\w* semilla \w en|strong="H5921"\w* vano, \w porque|strong="H5921"\w* vuestros enemigos \w se|strong="H5921"\w* \w la|strong="H5921"\w* comerán.  
\v 17 \w Pondré|strong="H5414"\w* mi \w rostro|strong="H6440"\w* \w contra|strong="H6440"\w* vosotros y seréis derrotados \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vuestros \w enemigos|strong="H8130"\w*. \w Los|strong="H7291"\w* que os odian dominarán sobre vosotros, y huiréis sin que nadie os \w persiga|strong="H7291"\w*.   
\p
\v 18 “‘\w Si|strong="H3808"\w* \w aun|strong="H5704"\w* \w con|strong="H5921"\w* estas cosas \w no|strong="H3808"\w* \w me|strong="H5921"\w* escucháis, \w volveré|strong="H3254"\w* \w a|strong="H3068"\w* castigaros \w siete|strong="H7651"\w* \w veces|strong="H7651"\w* \w más|strong="H3254"\w* \w por|strong="H5921"\w* vuestros \w pecados|strong="H2403"\w*.  
\v 19 \w Quebrantaré|strong="H7665"\w* la \w soberbia|strong="H1347"\w* \w de|strong="H5414"\w* vuestro poder, \w y|strong="H5797"\w* \w haré|strong="H5414"\w* que vuestros \w cielos|strong="H8064"\w* sean como \w hierro|strong="H1270"\w* \w y|strong="H5797"\w* vuestra tierra como bronce.  
\v 20 Vuestra \w fuerza|strong="H3581"\w* \w se|strong="H3808"\w* consumirá en vano, \w porque|strong="H3808"\w* vuestra tierra \w no|strong="H3808"\w* \w dará|strong="H5414"\w* sus productos \w ni|strong="H3808"\w* los \w árboles|strong="H6086"\w* \w de|strong="H5414"\w* la tierra \w darán|strong="H5414"\w* su \w fruto|strong="H6529"\w*.   
\p
\v 21 “‘\w Si|strong="H3808"\w* seguís oponiéndoos \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w os|strong="H5921"\w* negáis \w a|strong="H3068"\w* escucharme, multiplicaré mis \w plagas|strong="H4347"\w* \w sobre|strong="H5921"\w* \w vosotros|strong="H8085"\w* \w siete|strong="H7651"\w* \w veces|strong="H7651"\w* \w más|strong="H3254"\w*, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* vuestros \w pecados|strong="H2403"\w*.  
\v 22 \w Enviaré|strong="H7971"\w* contra vosotros las fieras del \w campo|strong="H7704"\w*, que os arrebatarán \w a|strong="H3068"\w* vuestros hijos, destruirán vuestro ganado y os reducirán en número, de modo que vuestros \w caminos|strong="H1870"\w* quedarán desolados.   
\p
\v 23 “‘\w Si|strong="H3808"\w* \w a|strong="H3068"\w* pesar \w de|strong="H5973"\w* estas cosas \w no|strong="H3808"\w* \w os|strong="H5973"\w* corregís ante mí, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* seguís oponiéndoos \w a|strong="H3068"\w* mí,  
\v 24 yo \w también|strong="H1571"\w* \w me|strong="H5921"\w* opondré \w a|strong="H3068"\w* \w vosotros|strong="H5973"\w* \w y|strong="H1571"\w* \w os|strong="H5921"\w* castigaré, yo \w mismo|strong="H1571"\w*, \w siete|strong="H7651"\w* \w veces|strong="H7651"\w* \w más|strong="H1571"\w* \w por|strong="H5921"\w* vuestros \w pecados|strong="H2403"\w*.  
\v 25 Traeré \w sobre|strong="H5921"\w* vosotros una \w espada|strong="H2719"\w* \w que|strong="H5921"\w* ejecutará \w la|strong="H5921"\w* \w venganza|strong="H5359"\w* \w del|strong="H5921"\w* \w pacto|strong="H1285"\w*. \w Os|strong="H5921"\w* refugiaréis \w en|strong="H5921"\w* vuestras \w ciudades|strong="H5892"\w*, pero yo \w enviaré|strong="H7971"\w* \w la|strong="H5921"\w* peste \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* vosotros, \w y|strong="H5921"\w* seréis entregados \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w del|strong="H5921"\w* enemigo.  
\v 26 Cuando yo os quite el sustento del \w pan|strong="H3899"\w*, \w diez|strong="H6235"\w* mujeres cocerán vuestro \w pan|strong="H3899"\w* en un solo \w horno|strong="H8574"\w* y os devolverán el \w pan|strong="H3899"\w* por \w peso|strong="H4948"\w*. Comeréis, pero \w no|strong="H3808"\w* os saciaréis.   
\p
\v 27 “‘\w Si|strong="H3808"\w* \w a|strong="H3068"\w* pesar \w de|strong="H5973"\w* \w esto|strong="H2063"\w* \w no|strong="H3808"\w* \w me|strong="H5973"\w* escucháis, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* seguís oponiéndoos \w a|strong="H3068"\w* mí,  
\v 28 entonces yo \w me|strong="H5921"\w* opondré \w a|strong="H3068"\w* \w vosotros|strong="H5973"\w* \w con|strong="H5973"\w* \w furor|strong="H2534"\w*, \w y|strong="H5921"\w* \w os|strong="H5921"\w* \w castigaré|strong="H3256"\w* \w siete|strong="H7651"\w* \w veces|strong="H7651"\w* \w más|strong="H5921"\w* \w por|strong="H5921"\w* vuestros \w pecados|strong="H2403"\w*.  
\v 29 Comeréis la \w carne|strong="H1320"\w* \w de|strong="H1121"\w* vuestros \w hijos|strong="H1121"\w*, y comeréis la \w carne|strong="H1320"\w* \w de|strong="H1121"\w* vuestras \w hijas|strong="H1323"\w*.  
\v 30 \w Destruiré|strong="H8045"\w* vuestros lugares \w altos|strong="H1116"\w*, derribaré vuestros \w altares|strong="H1116"\w* \w de|strong="H5921"\w* incienso \w y|strong="H5921"\w* arrojaré vuestros cadáveres \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w cuerpos|strong="H6297"\w* inermes \w de|strong="H5921"\w* vuestros \w ídolos|strong="H1544"\w*; \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w os|strong="H5921"\w* abominará.  
\v 31 Reduciré \w a|strong="H3068"\w* ruinas vuestras \w ciudades|strong="H5892"\w* y asolaré vuestros santuarios. \w No|strong="H3808"\w* me deleitaré en el aroma agradable \w de|strong="H5414"\w* vuestras ofrendas.  
\v 32 Yo mismo asolaré \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* vuestros enemigos \w que|strong="H5921"\w* \w habiten|strong="H3427"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w se|strong="H5921"\w* \w quedarán|strong="H3427"\w* pasmados.  
\v 33 \w A|strong="H3068"\w* vosotros os \w esparciré|strong="H2219"\w* entre las \w naciones|strong="H1471"\w* y desenvainaré la \w espada|strong="H2719"\w* tras vosotros. \w Vuestra|strong="H1961"\w* tierra \w quedará|strong="H1961"\w* \w asolada|strong="H8077"\w* y vuestras \w ciudades|strong="H5892"\w* en ruinas.  
\v 34 \w Entonces|strong="H3117"\w* \w la|strong="H3605"\w* tierra disfrutará de sus \w años|strong="H3117"\w* de \w reposo|strong="H7673"\w* durante \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* de su desolación, \w mientras|strong="H3605"\w* vosotros estéis en \w la|strong="H3605"\w* tierra de vuestros enemigos. \w La|strong="H3605"\w* tierra \w descansará|strong="H7676"\w* \w entonces|strong="H3117"\w* y disfrutará de sus \w años|strong="H3117"\w* de \w reposo|strong="H7673"\w*.  
\v 35 \w Todo|strong="H3605"\w* \w el|strong="H5921"\w* \w tiempo|strong="H3117"\w* \w que|strong="H3808"\w* esté desolada tendrá \w el|strong="H5921"\w* descanso \w que|strong="H3808"\w* \w no|strong="H3808"\w* tuvo \w en|strong="H5921"\w* vuestros \w años|strong="H3117"\w* \w de|strong="H5921"\w* \w reposo|strong="H7673"\w* \w cuando|strong="H3117"\w* habitabais \w en|strong="H5921"\w* \w ella|strong="H5921"\w*.   
\p
\v 36 “‘En cuanto \w a|strong="H3068"\w* \w los|strong="H7291"\w* que de vosotros queden con vida, infundiré tal cobardía en sus \w corazones|strong="H3824"\w* en las tierras de sus enemigos, que \w el|strong="H5307"\w* \w sonido|strong="H6963"\w* de una hoja llevada \w por|strong="H5127"\w* \w el|strong="H5307"\w* viento \w los|strong="H7291"\w* pondrá en fuga. Huirán como quien \w huye|strong="H5127"\w* de la \w espada|strong="H2719"\w*, y \w caerán|strong="H5307"\w* sin que nadie \w los|strong="H7291"\w* \w persiga|strong="H7291"\w*.  
\v 37 \w Tropezarán|strong="H3782"\w* unos con otros \w como|strong="H1961"\w* \w si|strong="H3808"\w* huyeran \w de|strong="H6440"\w* la \w espada|strong="H2719"\w*, \w aunque|strong="H3808"\w* \w nadie|strong="H3808"\w* \w los|strong="H7291"\w* \w persiga|strong="H7291"\w*. \w No|strong="H3808"\w* \w tendréis|strong="H1961"\w* fuerza \w para|strong="H1961"\w* manteneros en pie \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vuestros enemigos.  
\v 38 Pereceréis entre las \w naciones|strong="H1471"\w*, y la tierra de vuestros enemigos os devorará.  
\v 39 Los que queden de vosotros se consumirán por su \w iniquidad|strong="H5771"\w* en las tierras de vuestros enemigos, y también se consumirán por las \w iniquidades|strong="H5771"\w* de sus padres junto con ellos.   
\p
\v 40 “‘Pero si confiesan su \w iniquidad|strong="H5771"\w* y la \w iniquidad|strong="H5771"\w* \w de|strong="H5973"\w* sus padres, la \w transgresión|strong="H4604"\w* que \w cometieron|strong="H4604"\w* \w contra|strong="H5973"\w* mí, y reconocen que por haberse opuesto \w a|strong="H3068"\w* mí  
\v 41 yo también \w me|strong="H5973"\w* opuse \w a|strong="H3068"\w* ellos y \w los|strong="H5973"\w* llevé \w a|strong="H3068"\w* la tierra \w de|strong="H5973"\w* sus enemigos; si entonces su \w corazón|strong="H3824"\w* \w incircunciso|strong="H6189"\w* se humilla y aceptan \w el|strong="H5973"\w* castigo \w de|strong="H5973"\w* su \w iniquidad|strong="H5771"\w*,  
\v 42 yo me acordaré de mi \w pacto|strong="H1285"\w* con \w Jacob|strong="H3290"\w*, me acordaré también de mi \w pacto|strong="H1285"\w* con \w Isaac|strong="H3327"\w* y de mi \w pacto|strong="H1285"\w* con Abraham, y me acordaré de la tierra.  
\v 43 La tierra será \w abandonada|strong="H5800"\w* \w por|strong="H3282"\w* \w ellos|strong="H1992"\w* y disfrutará de \w sus|strong="H1992"\w* años de reposo mientras quede desolada sin \w ellos|strong="H1992"\w*; y \w ellos|strong="H1992"\w* aceptarán \w el|strong="H1992"\w* castigo de \w su|strong="H1992"\w* \w iniquidad|strong="H5771"\w*, \w porque|strong="H3282"\w* rechazaron mis \w ordenanzas|strong="H4941"\w* y \w su|strong="H1992"\w* \w alma|strong="H5315"\w* \w aborreció|strong="H3988"\w* mis \w estatutos|strong="H2708"\w*.  
\v 44 \w A|strong="H3068"\w* pesar \w de|strong="H3588"\w* todo \w esto|strong="H2063"\w*, \w cuando|strong="H3588"\w* \w estén|strong="H1961"\w* \w en|strong="H3588"\w* \w la|strong="H1571"\w* tierra \w de|strong="H3588"\w* sus enemigos, \w no|strong="H3808"\w* \w los|strong="H1961"\w* \w desecharé|strong="H3988"\w* \w ni|strong="H3808"\w* \w los|strong="H1961"\w* abominaré hasta \w destruirlos|strong="H3615"\w* \w por|strong="H3588"\w* completo \w y|strong="H1571"\w* anular \w mi|strong="H1961"\w* \w pacto|strong="H1285"\w* \w con|strong="H3588"\w* \w ellos|strong="H1571"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé, \w su|strong="H3588"\w* \w Dios|strong="H3068"\w*.  
\v 45 \w A|strong="H3068"\w* favor \w de|strong="H5869"\w* ellos me acordaré del \w pacto|strong="H1285"\w* con sus antepasados, \w a|strong="H3068"\w* quienes \w saqué|strong="H3318"\w* \w de|strong="H5869"\w* la tierra \w de|strong="H5869"\w* \w Egipto|strong="H4714"\w* \w a|strong="H3068"\w* la vista \w de|strong="H5869"\w* las \w naciones|strong="H1471"\w*, \w para|strong="H1961"\w* ser su \w Dios|strong="H3068"\w*. Yo \w soy|strong="H1961"\w* Yahvé’”.   
\p
\v 46 Estos son \w los|strong="H1121"\w* \w estatutos|strong="H2706"\w*, \w ordenanzas|strong="H2706"\w* y \w leyes|strong="H8451"\w* \w que|strong="H1121"\w* Yahvé \w estableció|strong="H5414"\w* entre \w él|strong="H1121"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* en \w el|strong="H1121"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w* \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*.   
\c 27
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Cuando|strong="H3588"\w* alguien haga un \w voto|strong="H5088"\w* especial \w para|strong="H3588"\w* consagrar una \w persona|strong="H5315"\w* \w a|strong="H3068"\w* Yahvé, lo harás conforme \w a|strong="H3068"\w* \w la|strong="H3588"\w* siguiente valoración:  
\v 3 Tu valoración \w de|strong="H5704"\w* un \w varón|strong="H2145"\w* \w de|strong="H5704"\w* \w veinte|strong="H6242"\w* \w a|strong="H3068"\w* \w sesenta|strong="H8346"\w* \w años|strong="H8141"\w* \w será|strong="H1961"\w* \w de|strong="H5704"\w* \w cincuenta|strong="H2572"\w* \w siclos|strong="H8255"\w* \w de|strong="H5704"\w* \w plata|strong="H3701"\w*, según \w el|strong="H1121"\w* \w siclo|strong="H8255"\w*\f + \fr 27:3 \ft Un siclo equivale a unos 10 gramos.\f* del \w santuario|strong="H6944"\w*.  
\v 4 \w Si|strong="H1931"\w* \w se|strong="H1961"\w* trata de una mujer, tu valoración \w será|strong="H1961"\w* de \w treinta|strong="H7970"\w* \w siclos|strong="H8255"\w*.  
\v 5 \w Si|strong="H1961"\w* la persona \w tiene|strong="H1961"\w* \w de|strong="H5704"\w* \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w*, tu valoración \w será|strong="H1961"\w* \w de|strong="H5704"\w* \w veinte|strong="H6242"\w* \w siclos|strong="H8255"\w* \w para|strong="H5704"\w* \w el|strong="H1121"\w* \w varón|strong="H2145"\w* \w y|strong="H5704"\w* \w de|strong="H5704"\w* \w diez|strong="H6235"\w* \w siclos|strong="H8255"\w* \w para|strong="H5704"\w* la mujer.  
\v 6 \w Si|strong="H1961"\w* la persona \w tiene|strong="H1961"\w* \w de|strong="H5704"\w* un \w mes|strong="H2320"\w* \w a|strong="H3068"\w* \w cinco|strong="H2568"\w* \w años|strong="H8141"\w*, tu valoración \w será|strong="H1961"\w* \w de|strong="H5704"\w* \w cinco|strong="H2568"\w* \w siclos|strong="H8255"\w* \w de|strong="H5704"\w* \w plata|strong="H3701"\w* \w para|strong="H5704"\w* \w el|strong="H1121"\w* \w varón|strong="H2145"\w* \w y|strong="H5704"\w* \w de|strong="H5704"\w* \w tres|strong="H7969"\w* \w siclos|strong="H8255"\w* \w de|strong="H5704"\w* \w plata|strong="H3701"\w* \w para|strong="H5704"\w* la mujer.  
\v 7 \w Si|strong="H1961"\w* la persona \w tiene|strong="H1961"\w* \w sesenta|strong="H8346"\w* \w años|strong="H8141"\w* \w o|strong="H3068"\w* más, \w si|strong="H1961"\w* \w es|strong="H1961"\w* \w varón|strong="H2145"\w*, tu valoración \w será|strong="H1961"\w* \w de|strong="H2568"\w* \w quince|strong="H2568"\w* \w siclos|strong="H8255"\w*, y \w para|strong="H1961"\w* la mujer, \w de|strong="H2568"\w* \w diez|strong="H6235"\w* \w siclos|strong="H8255"\w*.  
\v 8 Pero \w si|strong="H1931"\w* \w es|strong="H1931"\w* demasiado pobre \w para|strong="H5921"\w* pagar tu valoración, \w será|strong="H1931"\w* presentado \w ante|strong="H6440"\w* \w el|strong="H1931"\w* \w sacerdote|strong="H3548"\w*, \w y|strong="H5921"\w* \w este|strong="H1931"\w* \w le|strong="H1931"\w* fijará un valor. \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w lo|strong="H1931"\w* valorará \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* capacidad \w de|strong="H5921"\w* pago \w del|strong="H5921"\w* \w que|strong="H1931"\w* hizo \w el|strong="H1931"\w* \w voto|strong="H5087"\w*.   
\p
\v 9 “‘\w Si|strong="H1961"\w* \w se|strong="H1961"\w* trata \w de|strong="H4480"\w* un animal \w de|strong="H4480"\w* \w los|strong="H3605"\w* \w que|strong="H4480"\w* \w se|strong="H1961"\w* pueden ofrecer \w como|strong="H1961"\w* \w ofrenda|strong="H7133"\w* \w a|strong="H3068"\w* Yahvé, \w cualquier|strong="H3605"\w* animal \w de|strong="H4480"\w* \w estos|strong="H3605"\w* \w que|strong="H4480"\w* \w se|strong="H1961"\w* \w dé|strong="H4480"\w* \w a|strong="H3068"\w* Yahvé \w será|strong="H1961"\w* considerado \w santo|strong="H6944"\w*.  
\v 10 \w No|strong="H3808"\w* \w lo|strong="H1931"\w* sustituirá \w ni|strong="H3808"\w* \w lo|strong="H1931"\w* cambiará, \w ni|strong="H3808"\w* uno \w bueno|strong="H2896"\w* por uno \w malo|strong="H7451"\w*, \w ni|strong="H3808"\w* uno \w malo|strong="H7451"\w* por uno \w bueno|strong="H2896"\w*. \w Si|strong="H3808"\w* llegara \w a|strong="H3068"\w* cambiar un animal por otro, tanto \w el|strong="H1931"\w* primero \w como|strong="H1961"\w* \w el|strong="H1931"\w* sustituto \w serán|strong="H1961"\w* \w santos|strong="H6944"\w*.  
\v 11 \w Si|strong="H3808"\w* \w se|strong="H4480"\w* trata \w de|strong="H4480"\w* un animal impuro, \w de|strong="H4480"\w* \w los|strong="H3605"\w* \w que|strong="H4480"\w* \w no|strong="H3808"\w* \w se|strong="H4480"\w* \w ofrecen|strong="H7126"\w* como \w ofrenda|strong="H7133"\w* \w a|strong="H3068"\w* Yahvé, entonces \w presentará|strong="H7126"\w* \w el|strong="H3605"\w* animal \w ante|strong="H6440"\w* \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w*;  
\v 12 y el \w sacerdote|strong="H3548"\w* lo valorará, \w sea|strong="H1961"\w* \w bueno|strong="H2896"\w* \w o|strong="H3068"\w* \w malo|strong="H7451"\w*. El valor \w será|strong="H1961"\w* el \w que|strong="H1961"\w* fije el \w sacerdote|strong="H3548"\w*.  
\v 13 Pero \w si|strong="H5921"\w* \w el|strong="H5921"\w* dueño quiere rescatarlo, \w añadirá|strong="H3254"\w* \w la|strong="H5921"\w* quinta parte \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* valor fijado.   
\p
\v 14 “‘\w Cuando|strong="H3588"\w* alguien consagre \w su|strong="H3588"\w* \w casa|strong="H1004"\w* \w como|strong="H3588"\w* cosa sagrada \w a|strong="H3068"\w* Yahvé, \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w* \w la|strong="H3588"\w* valorará, sea \w buena|strong="H2896"\w* \w o|strong="H3068"\w* \w mala|strong="H7451"\w*. \w El|strong="H3588"\w* valor \w quedará|strong="H6965"\w* \w tal|strong="H3651"\w* \w como|strong="H3588"\w* lo fije \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w*.  
\v 15 \w Si|strong="H1961"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* consagró su \w casa|strong="H1004"\w* desea rescatarla, \w añadirá|strong="H3254"\w* \w la|strong="H5921"\w* quinta parte \w del|strong="H5921"\w* \w dinero|strong="H3701"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* valoración fijada, \w y|strong="H5921"\w* \w volverá|strong="H3254"\w* \w a|strong="H3068"\w* ser suya.   
\p
\v 16 “‘\w Si|strong="H1961"\w* un hombre consagra \w a|strong="H3068"\w* Yahvé una parte del \w campo|strong="H7704"\w* de su propiedad, su valoración \w se|strong="H1961"\w* \w hará|strong="H6310"\w* de acuerdo con la cantidad de semilla \w que|strong="H1961"\w* \w se|strong="H1961"\w* necesite \w para|strong="H1961"\w* sembrarlo. La \w siembra|strong="H2233"\w* de un homer\f + \fr 27:16 \ft 1 homer equivale a unos 220 litros.\f* de \w cebada|strong="H8184"\w* \w se|strong="H1961"\w* valorará en \w cincuenta|strong="H2572"\w* \w siclos|strong="H8255"\w*\f + \fr 27:16 \ft Un siclo equivale a unos 10 gramos.\f* de \w plata|strong="H3701"\w*.  
\v 17 Si consagra su \w campo|strong="H7704"\w* desde el \w Año|strong="H8141"\w* del \w Jubileo|strong="H3104"\w*, el \w campo|strong="H7704"\w* se mantendrá según tu valoración.  
\v 18 Pero \w si|strong="H5921"\w* consagra su \w campo|strong="H7704"\w* \w después|strong="H5921"\w* \w del|strong="H5921"\w* \w jubileo|strong="H3104"\w*, \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w le|strong="H5921"\w* \w calculará|strong="H2803"\w* \w el|strong="H5921"\w* \w precio|strong="H3701"\w* \w según|strong="H5921"\w* \w los|strong="H5921"\w* \w años|strong="H8141"\w* \w que|strong="H5921"\w* falten \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w Año|strong="H8141"\w* \w del|strong="H5921"\w* \w Jubileo|strong="H3104"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w hará|strong="H6310"\w* \w la|strong="H5921"\w* rebaja correspondiente \w a|strong="H3068"\w* tu valoración.  
\v 19 \w Si|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* consagró \w el|strong="H5921"\w* \w campo|strong="H7704"\w* desea rescatarlo, \w añadirá|strong="H3254"\w* \w la|strong="H5921"\w* quinta parte \w del|strong="H5921"\w* \w dinero|strong="H3701"\w* \w sobre|strong="H5921"\w* tu valoración, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w campo|strong="H7704"\w* seguirá siendo suyo.  
\v 20 \w Si|strong="H3808"\w* \w no|strong="H3808"\w* rescata el \w campo|strong="H7704"\w*, \w o|strong="H3068"\w* \w si|strong="H3808"\w* ya \w lo|strong="H3808"\w* \w ha|strong="H3808"\w* vendido \w a|strong="H3068"\w* \w otro|strong="H5750"\w* hombre, el \w campo|strong="H7704"\w* \w no|strong="H3808"\w* \w podrá|strong="H4376"\w* ser rescatado \w jamás|strong="H3808"\w*.  
\v 21 \w Cuando|strong="H1961"\w* el \w campo|strong="H7704"\w* \w quede|strong="H1961"\w* libre \w en|strong="H3318"\w* el \w jubileo|strong="H3104"\w*, \w será|strong="H1961"\w* \w santo|strong="H6944"\w* \w para|strong="H1961"\w* Yahvé, \w como|strong="H1961"\w* \w campo|strong="H7704"\w* \w consagrado|strong="H6944"\w* \w a|strong="H3068"\w* él. \w Será|strong="H1961"\w* propiedad de \w los|strong="H1961"\w* \w sacerdotes|strong="H3548"\w*.   
\p
\v 22 “‘\w Si|strong="H3808"\w* alguien consagra \w a|strong="H3068"\w* Yahvé un \w campo|strong="H7704"\w* \w que|strong="H3808"\w* \w ha|strong="H3808"\w* \w comprado|strong="H4736"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* forma parte de su propiedad familiar,  
\v 23 \w el|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w calculará|strong="H2803"\w* \w el|strong="H1931"\w* monto \w de|strong="H5704"\w* \w la|strong="H1931"\w* valoración \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w Año|strong="H8141"\w* del \w Jubileo|strong="H3104"\w*, \w y|strong="H5704"\w* \w ese|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* hombre \w pagará|strong="H5414"\w* \w la|strong="H1931"\w* valoración \w como|strong="H5704"\w* cosa \w consagrada|strong="H6944"\w* \w a|strong="H3068"\w* Yahvé.  
\v 24 En el \w Año|strong="H8141"\w* del \w Jubileo|strong="H3104"\w*, el \w campo|strong="H7704"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* aquel \w a|strong="H3068"\w* quien se lo \w compró|strong="H7069"\w*, es decir, al dueño original de la tierra.  
\v 25 \w Todas|strong="H3605"\w* tus valoraciones \w se|strong="H1961"\w* harán según \w el|strong="H3605"\w* \w siclo|strong="H8255"\w* del \w santuario|strong="H6944"\w*, \w el|strong="H3605"\w* cual equivale \w a|strong="H3068"\w* \w veinte|strong="H6242"\w* \w geras|strong="H1626"\w*.\f + \fr 27:25 \ft Un siclo equivale a veinte geras.\f*   
\p
\v 26 “‘\w Sin|strong="H3808"\w* embargo, \w nadie|strong="H3808"\w* \w podrá|strong="H3808"\w* consagrar \w el|strong="H1931"\w* \w primogénito|strong="H1060"\w* de un animal, ya \w que|strong="H1931"\w* por ser \w primogénito|strong="H1060"\w* \w le|strong="H1931"\w* pertenece \w a|strong="H3068"\w* Yahvé, sea \w buey|strong="H7794"\w* u \w oveja|strong="H7716"\w*. \w Es|strong="H1931"\w* de Yahvé.  
\v 27 \w Si|strong="H3808"\w* \w se|strong="H3808"\w* trata \w de|strong="H5921"\w* un animal impuro, \w podrá|strong="H4376"\w* rescatarlo \w según|strong="H5921"\w* tu valoración, \w añadiendo|strong="H3254"\w* \w la|strong="H5921"\w* quinta parte \w de|strong="H5921"\w* su valor. \w Si|strong="H3808"\w* \w no|strong="H3808"\w* es rescatado, \w será|strong="H3808"\w* vendido \w según|strong="H5921"\w* tu valoración.   
\p
\v 28 “‘\w Sin|strong="H3808"\w* embargo, \w ninguna|strong="H3605"\w* \w cosa|strong="H3605"\w* \w consagrada|strong="H2764"\w* por completo \w a|strong="H3068"\w* Yahvé, de \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* un hombre posee, sea persona, animal \w o|strong="H3068"\w* \w el|strong="H1931"\w* \w campo|strong="H7704"\w* de \w su|strong="H1931"\w* propiedad, \w podrá|strong="H4376"\w* ser vendida \w ni|strong="H3808"\w* rescatada. \w Todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w consagrado|strong="H6944"\w* por completo \w es|strong="H1931"\w* \w santísimo|strong="H6944"\w* para Yahvé.   
\p
\v 29 “‘\w Ninguna|strong="H3605"\w* persona \w que|strong="H4480"\w* haya sido \w consagrada|strong="H2764"\w* \w por|strong="H4480"\w* completo \w para|strong="H4480"\w* destrucción \w podrá|strong="H3808"\w* ser rescatada. Deberá ser condenada \w a|strong="H3068"\w* \w muerte|strong="H4191"\w* \w irremisiblemente|strong="H4191"\w*.   
\p
\v 30 “‘\w Todo|strong="H3605"\w* \w el|strong="H1931"\w* diezmo de \w la|strong="H1931"\w* tierra, ya sea de \w la|strong="H1931"\w* semilla de \w la|strong="H1931"\w* tierra \w o|strong="H3068"\w* del \w fruto|strong="H6529"\w* de \w los|strong="H3605"\w* \w árboles|strong="H6086"\w*, \w le|strong="H1931"\w* pertenece \w a|strong="H3068"\w* Yahvé. \w Es|strong="H1931"\w* \w consagrado|strong="H6944"\w* \w a|strong="H3068"\w* Yahvé.  
\v 31 \w Si|strong="H5921"\w* alguien desea rescatar algo \w de|strong="H5921"\w* su diezmo, deberá añadir \w la|strong="H5921"\w* quinta parte \w de|strong="H5921"\w* su valor.  
\v 32 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* diezmo \w de|strong="H8478"\w* las \w vacas|strong="H1241"\w* \w o|strong="H3068"\w* \w de|strong="H8478"\w* \w los|strong="H3605"\w* rebaños, \w es|strong="H1961"\w* decir, \w de|strong="H8478"\w* \w cada|strong="H3605"\w* diez animales \w que|strong="H1961"\w* pasen \w bajo|strong="H8478"\w* \w la|strong="H3605"\w* \w vara|strong="H7626"\w* del pastor, \w el|strong="H3605"\w* \w décimo|strong="H6224"\w* \w será|strong="H1961"\w* \w consagrado|strong="H6944"\w* \w a|strong="H3068"\w* Yahvé.  
\v 33 \w No|strong="H3808"\w* \w se|strong="H1961"\w* examinará \w si|strong="H3808"\w* \w es|strong="H1931"\w* \w bueno|strong="H2896"\w* \w o|strong="H3068"\w* \w malo|strong="H7451"\w*, \w ni|strong="H3808"\w* \w se|strong="H1961"\w* \w podrá|strong="H3808"\w* cambiar. \w Si|strong="H3808"\w* \w se|strong="H1961"\w* cambia, tanto \w el|strong="H1931"\w* primero \w como|strong="H1961"\w* \w el|strong="H1931"\w* sustituto \w serán|strong="H1961"\w* \w cosas|strong="H7451"\w* \w sagradas|strong="H6944"\w* y \w no|strong="H3808"\w* podrán ser rescatados’”.   
\p
\v 34 Estos son \w los|strong="H1121"\w* \w mandamientos|strong="H4687"\w* \w que|strong="H1121"\w* Yahvé \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* para \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* en \w el|strong="H1121"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*.   