\id LEV
\ide  UTF-8
\h LEVÍTICO 
\toc3 Levítico 
\toc1 LIBRO TERCERO DE MOISÉS COMÚNMENTE LLAMADO LEVÍTICO 
\toc2 LEVÍTICO 
\mt2 Libro tercero de Moisés,  
\mt3 comúnmente llamado  
\mt1 Levítico  
\c 1
\p
\v 1 Yahvé \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y le \w habló|strong="H1696"\w* desde la Tienda del Encuentro, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Cuando|strong="H3588"\w* alguno \w de|strong="H4480"\w* ustedes \w presente|strong="H7133"\w* una \w ofrenda|strong="H7133"\w* \w a|strong="H3068"\w* Yahvé, podrá ofrecer \w animales|strong="H1121"\w* \w de|strong="H4480"\w* sus \w ganados|strong="H6629"\w*, ya sea \w de|strong="H4480"\w* las \w vacas|strong="H1241"\w* \w o|strong="H3068"\w* \w de|strong="H4480"\w* las \w ovejas|strong="H6629"\w*.   
\p
\v 3 “‘\w Si|strong="H6440"\w* su \w ofrenda|strong="H7133"\w* es un \w holocausto|strong="H5930"\w* \w de|strong="H4480"\w* las \w vacas|strong="H1241"\w*, \w ofrecerá|strong="H7126"\w* un \w macho|strong="H2145"\w* sin defecto. Lo \w presentará|strong="H7126"\w* \w a|strong="H3068"\w* la entrada \w de|strong="H4480"\w* la Tienda \w del|strong="H4480"\w* Encuentro, \w para|strong="H4480"\w* \w que|strong="H4480"\w* sea aceptado \w ante|strong="H6440"\w* Yahvé.  
\v 4 Pondrá su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* víctima, \w y|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* \w la|strong="H5921"\w* aceptará \w para|strong="H5921"\w* hacer \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 5 Entonces degollará \w el|strong="H5921"\w* becerro \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Aarón, \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, presentarán \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w rociarán|strong="H2236"\w* \w por|strong="H5921"\w* todos \w los|strong="H1121"\w* \w lados|strong="H5439"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro.  
\v 6 Después desollará el animal y lo cortará en pedazos.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Aarón encenderán \w el|strong="H5921"\w* fuego \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w y|strong="H5921"\w* \w acomodarán|strong="H6186"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* fuego.  
\v 8 Luego \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Aarón, \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, \w acomodarán|strong="H6186"\w* \w los|strong="H1121"\w* pedazos, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* grasa, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w* \w que|strong="H5921"\w* arde \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 9 \w El|strong="H3605"\w* \w que|strong="H4325"\w* ofrece \w la|strong="H3605"\w* víctima \w lavará|strong="H7364"\w* con \w agua|strong="H4325"\w* las entrañas y las patas, y \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* \w lo|strong="H3605"\w* \w quemará|strong="H6999"\w* \w todo|strong="H3605"\w* en \w el|strong="H3605"\w* \w altar|strong="H4196"\w*. Es un \w holocausto|strong="H5930"\w*, una ofrenda \w quemada|strong="H6999"\w* \w de|strong="H4325"\w* aroma agradable para Yahvé.   
\p
\v 10 “‘Si su \w ofrenda|strong="H7133"\w* \w para|strong="H4480"\w* el \w holocausto|strong="H5930"\w* es \w del|strong="H4480"\w* \w rebaño|strong="H6629"\w*, \w de|strong="H4480"\w* las \w ovejas|strong="H6629"\w* \w o|strong="H3068"\w* \w de|strong="H4480"\w* las \w cabras|strong="H5795"\w*, \w ofrecerá|strong="H7126"\w* un \w macho|strong="H2145"\w* sin defecto.  
\v 11 \w Lo|strong="H5921"\w* degollará \w al|strong="H5921"\w* \w lado|strong="H3409"\w* \w norte|strong="H6828"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*, \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Aarón, \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, \w rociarán|strong="H2236"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w por|strong="H5921"\w* todos \w los|strong="H1121"\w* \w lados|strong="H5439"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 12 Luego \w lo|strong="H5921"\w* cortará \w en|strong="H5921"\w* pedazos, \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* grasa, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w los|strong="H5921"\w* acomodará \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w* \w que|strong="H5921"\w* arde \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 13 Pero \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w ofrece|strong="H7126"\w* \w la|strong="H1931"\w* víctima \w lavará|strong="H7364"\w* las entrañas y las patas con \w agua|strong="H4325"\w*. \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w presentará|strong="H7126"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* animal y \w lo|strong="H1931"\w* \w quemará|strong="H6999"\w* en \w el|strong="H1931"\w* \w altar|strong="H4196"\w*. \w Es|strong="H1931"\w* un \w holocausto|strong="H5930"\w*, una ofrenda \w quemada|strong="H6999"\w* \w de|strong="H4325"\w* aroma agradable para Yahvé.   
\p
\v 14 “‘Si su \w ofrenda|strong="H7133"\w* \w para|strong="H4480"\w* Yahvé es un \w holocausto|strong="H5930"\w* \w de|strong="H4480"\w* \w aves|strong="H5775"\w*, \w ofrecerá|strong="H7126"\w* \w tórtolas|strong="H8449"\w* \w o|strong="H3068"\w* pichones.  
\v 15 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* llevará \w el|strong="H5921"\w* ave \w al|strong="H5921"\w* \w altar|strong="H4196"\w*, \w le|strong="H5921"\w* cortará \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w quemará|strong="H6999"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*. \w La|strong="H5921"\w* \w sangre|strong="H1818"\w* será exprimida \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w pared|strong="H7023"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 16 Le \w quitará|strong="H5493"\w* el buche y las \w plumas|strong="H5133"\w*, y los echará al lado \w oriental|strong="H6924"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*, \w en|strong="H5493"\w* el \w lugar|strong="H4725"\w* de las cenizas.  
\v 17 \w La|strong="H1931"\w* abrirá \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w alas|strong="H3671"\w*, pero \w sin|strong="H3808"\w* llegar \w a|strong="H3068"\w* dividirla. \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w la|strong="H1931"\w* \w quemará|strong="H6999"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w altar|strong="H4196"\w*, \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* \w leña|strong="H6086"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* fuego. \w Es|strong="H1931"\w* un \w holocausto|strong="H5930"\w*, una ofrenda \w quemada|strong="H6999"\w* \w de|strong="H5921"\w* aroma agradable \w para|strong="H5921"\w* Yahvé.   
\c 2
\p
\v 1 “‘\w Cuando|strong="H3588"\w* alguien \w presente|strong="H4503"\w* una \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* cereal \w a|strong="H3068"\w* Yahvé, \w su|strong="H3588"\w* \w ofrenda|strong="H4503"\w* \w será|strong="H1961"\w* \w de|strong="H5921"\w* harina fina. Derramará \w aceite|strong="H8081"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* \w y|strong="H3588"\w* \w le|strong="H5921"\w* \w pondrá|strong="H5414"\w* \w incienso|strong="H3828"\w*.  
\v 2 \w La|strong="H5921"\w* llevará \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Aarón, \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*. \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w tomará|strong="H7062"\w* un puñado \w de|strong="H5921"\w* \w la|strong="H5921"\w* harina fina \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w aceite|strong="H8081"\w* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w incienso|strong="H3828"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w quemará|strong="H6999"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w como|strong="H5921"\w* un memorial. Es una ofrenda \w quemada|strong="H6999"\w* \w de|strong="H5921"\w* aroma agradable \w para|strong="H5921"\w* Yahvé.  
\v 3 \w El|strong="H1121"\w* resto \w de|strong="H4480"\w* la \w ofrenda|strong="H4503"\w* será \w para|strong="H4480"\w* Aarón y sus \w hijos|strong="H1121"\w*. Es una parte muy \w santa|strong="H6944"\w* \w de|strong="H4480"\w* las ofrendas quemadas \w para|strong="H4480"\w* Yahvé.   
\p
\v 4 “‘\w Cuando|strong="H3588"\w* \w presentes|strong="H4503"\w* una \w ofrenda|strong="H4503"\w* \w de|strong="H3588"\w* cereal cocida al \w horno|strong="H8574"\w*, será \w de|strong="H3588"\w* harina fina: \w tortas|strong="H2471"\w* sin levadura \w amasadas|strong="H1101"\w* \w con|strong="H3588"\w* \w aceite|strong="H8081"\w*, u hojuelas sin levadura \w untadas|strong="H4886"\w* \w con|strong="H3588"\w* \w aceite|strong="H8081"\w*.  
\v 5 \w Si|strong="H1961"\w* tu \w ofrenda|strong="H4503"\w* \w es|strong="H1961"\w* \w de|strong="H5921"\w* cereal cocido \w a|strong="H3068"\w* \w la|strong="H5921"\w* plancha, \w será|strong="H1961"\w* \w de|strong="H5921"\w* harina fina sin levadura, \w amasada|strong="H1101"\w* \w con|strong="H5921"\w* \w aceite|strong="H8081"\w*.  
\v 6 \w La|strong="H1931"\w* partirás \w en|strong="H5921"\w* pedazos \w y|strong="H5921"\w* derramarás \w aceite|strong="H8081"\w* \w sobre|strong="H5921"\w* \w ella|strong="H1931"\w*. \w Es|strong="H1931"\w* una \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* cereal.  
\v 7 Si \w tu|strong="H6213"\w* \w ofrenda|strong="H4503"\w* es de cereal cocido en sartén, \w será|strong="H6213"\w* de harina fina con \w aceite|strong="H8081"\w*.  
\v 8 Llevarás \w a|strong="H3068"\w* Yahvé la \w ofrenda|strong="H4503"\w* que se prepare con estos ingredientes. Se la entregarás al \w sacerdote|strong="H3548"\w*, y \w él|strong="H6213"\w* la llevará al \w altar|strong="H4196"\w*.  
\v 9 El \w sacerdote|strong="H3548"\w* tomará \w de|strong="H4480"\w* la \w ofrenda|strong="H4503"\w* la porción memorial y la \w quemará|strong="H6999"\w* \w en|strong="H4480"\w* el \w altar|strong="H4196"\w*. Es una \w ofrenda|strong="H4503"\w* \w quemada|strong="H6999"\w* \w de|strong="H4480"\w* aroma agradable \w para|strong="H4480"\w* Yahvé.  
\v 10 \w El|strong="H1121"\w* resto \w de|strong="H4480"\w* la \w ofrenda|strong="H4503"\w* \w de|strong="H4480"\w* cereal será \w para|strong="H4480"\w* Aarón y sus \w hijos|strong="H1121"\w*. Es una parte muy \w santa|strong="H6944"\w* \w de|strong="H4480"\w* las ofrendas quemadas \w para|strong="H4480"\w* Yahvé.   
\p
\v 11 “‘\w Ninguna|strong="H3605"\w* \w ofrenda|strong="H4503"\w* \w de|strong="H4480"\w* cereal \w que|strong="H3588"\w* presenten \w a|strong="H3068"\w* Yahvé \w se|strong="H4480"\w* preparará \w con|strong="H4480"\w* \w levadura|strong="H7603"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* deben quemar \w levadura|strong="H7603"\w* \w ni|strong="H3808"\w* \w miel|strong="H1706"\w* \w como|strong="H3588"\w* \w ofrenda|strong="H4503"\w* \w para|strong="H3588"\w* Yahvé.  
\v 12 Podrán presentarlas \w a|strong="H3068"\w* Yahvé como \w ofrenda|strong="H7133"\w* de \w primicias|strong="H7225"\w*, pero \w no|strong="H3808"\w* \w se|strong="H3808"\w* quemarán en el \w altar|strong="H4196"\w* como aroma agradable.  
\v 13 Sazonarás \w con|strong="H5921"\w* \w sal|strong="H4417"\w* \w todas|strong="H3605"\w* tus \w ofrendas|strong="H7133"\w* \w de|strong="H5921"\w* cereal. \w No|strong="H3808"\w* permitas \w que|strong="H3808"\w* falte \w en|strong="H5921"\w* tu \w ofrenda|strong="H4503"\w* \w la|strong="H5921"\w* \w sal|strong="H4417"\w* \w del|strong="H5921"\w* \w pacto|strong="H1285"\w* \w de|strong="H5921"\w* tu Dios. \w En|strong="H5921"\w* \w todas|strong="H3605"\w* tus \w ofrendas|strong="H7133"\w* debes presentar \w sal|strong="H4417"\w*.   
\p
\v 14 “‘Si presentas \w a|strong="H3068"\w* Yahvé una \w ofrenda|strong="H4503"\w* de primicias, \w ofrecerás|strong="H7126"\w* grano tierno tostado al fuego \w o|strong="H3068"\w* grano desmenuzado de espigas frescas.  
\v 15 \w Le|strong="H1931"\w* añadirás \w aceite|strong="H8081"\w* \w y|strong="H5921"\w* \w le|strong="H1931"\w* \w pondrás|strong="H5414"\w* \w incienso|strong="H3828"\w*. \w Es|strong="H1931"\w* una \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* cereal.  
\v 16 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w quemará|strong="H6999"\w*, \w como|strong="H5921"\w* memorial, parte \w del|strong="H5921"\w* grano desmenuzado \w y|strong="H5921"\w* \w del|strong="H5921"\w* \w aceite|strong="H8081"\w*, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w incienso|strong="H3828"\w*. Es una ofrenda \w quemada|strong="H6999"\w* \w para|strong="H5921"\w* Yahvé.   
\c 3
\p
\v 1 “‘\w Si|strong="H1931"\w* \w su|strong="H1931"\w* \w ofrenda|strong="H7133"\w* \w es|strong="H1931"\w* un \w sacrificio|strong="H2077"\w* \w de|strong="H4480"\w* paz, \w y|strong="H1241"\w* \w la|strong="H1931"\w* toma \w del|strong="H4480"\w* ganado \w vacuno|strong="H1241"\w*, ya sea \w macho|strong="H2145"\w* \w o|strong="H3068"\w* \w hembra|strong="H5347"\w*, \w la|strong="H1931"\w* \w presentará|strong="H7126"\w* sin defecto \w delante|strong="H6440"\w* \w de|strong="H4480"\w* Yahvé.  
\v 2 Pondrá su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ofrenda|strong="H7133"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* degollará \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Aarón, \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, \w rociarán|strong="H2236"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w por|strong="H5921"\w* todos \w los|strong="H1121"\w* \w lados|strong="H5439"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 3 \w Del|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w de|strong="H5921"\w* paz, \w presentará|strong="H7126"\w* \w como|strong="H5921"\w* ofrenda quemada \w a|strong="H3068"\w* Yahvé \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w cubre|strong="H3680"\w* \w las|strong="H5921"\w* entrañas \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w*,  
\v 4 \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w riñones|strong="H3629"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w los|strong="H5921"\w* cubre \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* lomos, \w y|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w del|strong="H5921"\w* \w hígado|strong="H3516"\w*, \w que|strong="H5921"\w* \w quitará|strong="H5493"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w riñones|strong="H3629"\w*.  
\v 5 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Aarón quemarán esto \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* fuego. Es una ofrenda \w quemada|strong="H6999"\w* \w de|strong="H5921"\w* aroma agradable \w para|strong="H5921"\w* Yahvé.   
\p
\v 6 “‘Si su \w ofrenda|strong="H7133"\w* \w para|strong="H4480"\w* un \w sacrificio|strong="H2077"\w* \w de|strong="H4480"\w* paz \w a|strong="H3068"\w* Yahvé es \w del|strong="H4480"\w* \w rebaño|strong="H6629"\w* \w de|strong="H4480"\w* \w ovejas|strong="H6629"\w* \w o|strong="H3068"\w* cabras, ya sea \w macho|strong="H2145"\w* \w o|strong="H3068"\w* \w hembra|strong="H5347"\w*, la \w presentará|strong="H7126"\w* sin defecto.  
\v 7 \w Si|strong="H1931"\w* \w ofrece|strong="H7126"\w* un \w cordero|strong="H3775"\w*, \w lo|strong="H1931"\w* \w presentará|strong="H7126"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.  
\v 8 Pondrá su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* su \w ofrenda|strong="H7133"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* degollará \w ante|strong="H6440"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Aarón \w rociarán|strong="H2236"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w por|strong="H5921"\w* todos \w los|strong="H1121"\w* \w lados|strong="H5439"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 9 \w Del|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w de|strong="H5921"\w* paz \w presentará|strong="H7126"\w* \w como|strong="H5921"\w* ofrenda quemada \w a|strong="H3068"\w* Yahvé \w la|strong="H5921"\w* grasa: \w la|strong="H5921"\w* cola \w entera|strong="H8549"\w*, \w la|strong="H5921"\w* cual cortará \w cerca|strong="H5921"\w* \w del|strong="H5921"\w* espinazo; \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w cubre|strong="H3680"\w* \w las|strong="H5921"\w* entrañas \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w*,  
\v 10 \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w riñones|strong="H3629"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w los|strong="H5921"\w* cubre \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* lomos, \w y|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w del|strong="H5921"\w* \w hígado|strong="H3516"\w*, \w que|strong="H5921"\w* \w quitará|strong="H5493"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w riñones|strong="H3629"\w*.  
\v 11 El \w sacerdote|strong="H3548"\w* \w quemará|strong="H6999"\w* esto en el \w altar|strong="H4196"\w* como alimento, una ofrenda \w quemada|strong="H6999"\w* para Yahvé.   
\p
\v 12 “‘\w Si|strong="H6440"\w* su \w ofrenda|strong="H7133"\w* es una \w cabra|strong="H5795"\w*, la \w presentará|strong="H7126"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.  
