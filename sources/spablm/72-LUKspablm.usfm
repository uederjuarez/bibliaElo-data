\c 18
\p
\v 1 \w También|strong="G2532"\w* \w les|strong="G4314"\w* refirió \w una|strong="G3588"\w* \w parábola|strong="G3850"\w* \w sobre|strong="G4314"\w* \w la|strong="G3588"\w* necesidad \w de|strong="G4314"\w* \w orar|strong="G4336"\w* \w siempre|strong="G3842"\w* \w y|strong="G2532"\w* \w no|strong="G3361"\w* \w desmayar|strong="G1573"\w*,  
