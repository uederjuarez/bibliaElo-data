\c 1
\p
\v 1 \w Puesto|strong="G1722"\w* \w que|strong="G3588"\w* \w muchos|strong="G4183"\w* han emprendido \w la|strong="G3588"\w* tarea \w de|strong="G4012"\w* poner \w en|strong="G1722"\w* orden \w una|strong="G3588"\w* narración relativa \w a|strong="G1722"\w* \w los|strong="G3588"\w* asuntos \w que|strong="G3588"\w* se han cumplido \w entre|strong="G1722"\w* \w nosotros|strong="G2249"\w*,  
\v 2 tal \w como|strong="G2531"\w* nos \w lo|strong="G3588"\w* transmitieron \w los|strong="G3588"\w* \w que|strong="G3588"\w* desde \w el|strong="G3588"\w* principio \w fueron|strong="G1096"\w* testigos oculares \w y|strong="G2532"\w* \w servidores|strong="G5257"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w palabra|strong="G3056"\w*,  
\v 3 \w también|strong="G2504"\w* me \w pareció|strong="G1380"\w* bien, habiendo entendido el curso de \w todas|strong="G3956"\w* las cosas con exactitud desde el principio, \w escribirte|strong="G1125"\w* en orden, \w excelentísimo|strong="G2903"\w* \w Teófilo|strong="G2321"\w*;  
\v 4 \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w conozcas|strong="G1921"\w* \w la|strong="G3588"\w* certeza relativa \w a|strong="G2443"\w* \w las|strong="G3588"\w* \w cosas|strong="G3739"\w* \w en|strong="G4012"\w* \w las|strong="G3588"\w* \w que|strong="G3588"\w* fuiste \w instruido|strong="G2727"\w*.   
\p
\v 5 \w Había|strong="G1096"\w* \w en|strong="G1722"\w* \w los|strong="G3588"\w* \w días|strong="G2250"\w* \w de|strong="G1537"\w* \w Herodes|strong="G2264"\w*, rey \w de|strong="G1537"\w* \w Judea|strong="G2449"\w*, \w un|strong="G5100"\w* \w sacerdote|strong="G2409"\w* \w llamado|strong="G3686"\w* \w Zacarías|strong="G2197"\w*, \w de|strong="G1537"\w* \w la|strong="G3588"\w* división sacerdotal \w de|strong="G1537"\w* Abías. Tenía \w una|strong="G5100"\w* \w esposa|strong="G1135"\w* \w de|strong="G1537"\w* \w las|strong="G3588"\w* \w hijas|strong="G2364"\w* \w de|strong="G1537"\w* Aarón, \w que|strong="G3588"\w* \w se|strong="G1096"\w* llamaba \w Elisabet|strong="G1665"\w*.  
\v 6 Ambos eran \w justos|strong="G1342"\w* ante \w Dios|strong="G2316"\w*, \w y|strong="G2532"\w* andaban irreprochablemente \w en|strong="G1722"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w mandamientos|strong="G1785"\w* \w y|strong="G2532"\w* \w ordenanzas|strong="G1345"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*.  
\v 7 \w Pero|strong="G2532"\w* \w no|strong="G3756"\w* tuvieron \w hijos|strong="G5043"\w*, \w porque|strong="G2532"\w* \w Elisabet|strong="G1665"\w* \w era|strong="G1510"\w* \w estéril|strong="G4723"\w*, \w y|strong="G2532"\w* ambos eran \w de|strong="G1722"\w* \w edad|strong="G2250"\w* \w avanzada|strong="G4260"\w*.   
\p
\v 8 Mientras ejercía \w el|strong="G3588"\w* oficio sacerdotal ante \w Dios|strong="G2316"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w orden|strong="G5010"\w* \w de|strong="G1722"\w* \w su|strong="G3588"\w* división  
\v 9 \w según|strong="G2596"\w* \w la|strong="G3588"\w* \w costumbre|strong="G1485"\w* \w del|strong="G3588"\w* oficio sacerdotal, \w le|strong="G2596"\w* tocaba \w entrar|strong="G1525"\w* \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w templo|strong="G3485"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* y quemar incienso.  
\v 10 \w Toda|strong="G3956"\w* \w la|strong="G3588"\w* \w multitud|strong="G4128"\w* \w del|strong="G3588"\w* \w pueblo|strong="G2992"\w* \w oraba|strong="G4336"\w* \w fuera|strong="G1854"\w* a \w la|strong="G3588"\w* \w hora|strong="G5610"\w* \w del|strong="G3588"\w* \w incienso|strong="G2368"\w*.   
\p
\v 11 Se le apareció \w un|strong="G3588"\w* ángel \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*, \w de|strong="G1537"\w* \w pie|strong="G2476"\w* \w a|strong="G1537"\w* \w la|strong="G3588"\w* \w derecha|strong="G1188"\w* \w del|strong="G3588"\w* \w altar|strong="G2379"\w* \w del|strong="G3588"\w* \w incienso|strong="G2368"\w*.  
\v 12 \w Zacarías|strong="G2197"\w* \w se|strong="G2532"\w* turbó \w al|strong="G1909"\w* verlo \w y|strong="G2532"\w* \w le|strong="G1909"\w* entró \w miedo|strong="G5401"\w*.  
\v 13 \w Pero|strong="G1161"\w* \w el|strong="G3588"\w* ángel \w le|strong="G4314"\w* \w dijo|strong="G3004"\w*: “\w No|strong="G3361"\w* \w temas|strong="G5399"\w*, \w Zacarías|strong="G2197"\w*, \w porque|strong="G1161"\w* \w tu|strong="G4771"\w* petición ha sido escuchada. \w Tu|strong="G4771"\w* \w mujer|strong="G1135"\w*, \w Elisabet|strong="G1665"\w*, \w te|strong="G4771"\w* dará \w a|strong="G4314"\w* luz \w un|strong="G3588"\w* \w hijo|strong="G5207"\w*, \w y|strong="G2532"\w* \w le|strong="G4314"\w* pondrás \w por|strong="G4314"\w* \w nombre|strong="G3686"\w* \w Juan|strong="G2491"\w*.  
\v 14 Tendrás \w alegría|strong="G5479"\w* \w y|strong="G2532"\w* \w gozo|strong="G5479"\w*, \w y|strong="G2532"\w* \w muchos|strong="G4183"\w* \w se|strong="G2532"\w* alegrarán \w de|strong="G1909"\w* \w su|strong="G3588"\w* nacimiento.  
\v 15 \w Porque|strong="G1063"\w* será \w grande|strong="G3173"\w* \w a|strong="G1537"\w* \w los|strong="G2532"\w* ojos \w del|strong="G1537"\w* \w Señor|strong="G2962"\w*, \w y|strong="G2532"\w* \w no|strong="G3756"\w* \w beberá|strong="G4095"\w* \w vino|strong="G3631"\w* \w ni|strong="G2532"\w* bebida fuerte. Estará \w lleno|strong="G4130"\w* \w del|strong="G1537"\w* \w Espíritu|strong="G4151"\w* Santo, incluso \w desde|strong="G1537"\w* \w el|strong="G1537"\w* \w vientre|strong="G2836"\w* \w de|strong="G1537"\w* su \w madre|strong="G3384"\w*.  
\v 16 Hará \w que|strong="G3588"\w* \w muchos|strong="G4183"\w* \w de|strong="G1909"\w* \w los|strong="G3588"\w* \w hijos|strong="G5207"\w* \w de|strong="G1909"\w* \w Israel|strong="G2474"\w* \w se|strong="G2532"\w* conviertan \w al|strong="G3588"\w* \w Señor|strong="G2962"\w*, \w su|strong="G3588"\w* \w Dios|strong="G2316"\w*.  
\v 17 \w Irá|strong="G4281"\w* \w delante|strong="G1799"\w* \w de|strong="G1722"\w* \w él|strong="G1722"\w* \w con|strong="G1722"\w* \w el|strong="G1722"\w* \w espíritu|strong="G4151"\w* \w y|strong="G2532"\w* \w el|strong="G1722"\w* \w poder|strong="G1411"\w* \w de|strong="G1722"\w* \w Elías|strong="G2243"\w*, ‘\w para|strong="G1909"\w* hacer volver \w el|strong="G1722"\w* \w corazón|strong="G2588"\w* \w de|strong="G1722"\w* \w los|strong="G2532"\w* \w padres|strong="G3962"\w* \w a|strong="G1909"\w* \w los|strong="G2532"\w* \w hijos|strong="G5043"\w*’\f + \fr 1:17 \ft Malaquías 4:6\f*, \w y|strong="G2532"\w* \w a|strong="G1909"\w* \w los|strong="G2532"\w* desobedientes \w a|strong="G1909"\w* la sabiduría \w de|strong="G1722"\w* \w los|strong="G2532"\w* \w justos|strong="G1342"\w*; \w para|strong="G1909"\w* preparar \w un|strong="G1722"\w* \w pueblo|strong="G2992"\w* \w preparado|strong="G2090"\w* \w para|strong="G1909"\w* \w el|strong="G1722"\w* \w Señor|strong="G2962"\w*.”   
\p
\v 18 \w Zacarías|strong="G2197"\w* \w dijo|strong="G3004"\w* \w al|strong="G3588"\w* ángel: «¿\w Cómo|strong="G2532"\w* puedo estar seguro \w de|strong="G1722"\w* \w esto|strong="G3778"\w*? \w Porque|strong="G1063"\w* \w soy|strong="G1510"\w* \w un|strong="G3588"\w* anciano, \w y|strong="G2532"\w* \w mi|strong="G3588"\w* \w mujer|strong="G1135"\w* \w está|strong="G3778"\w* muy \w avanzada|strong="G4260"\w* \w en|strong="G1722"\w* años».   
\p
\v 19 \w El|strong="G3588"\w* ángel \w le|strong="G4314"\w* respondió: “\w Soy|strong="G1510"\w* \w Gabriel|strong="G1043"\w*, \w que|strong="G3588"\w* \w está|strong="G3778"\w* \w en|strong="G4314"\w* \w la|strong="G3588"\w* \w presencia|strong="G1799"\w* \w de|strong="G4314"\w* \w Dios|strong="G2316"\w*. He sido enviado \w para|strong="G4314"\w* \w hablarte|strong="G2980"\w* \w y|strong="G2532"\w* traerte \w esta|strong="G3778"\w* buena noticia.  
\v 20 He aquí \w que|strong="G3588"\w*\f + \fr 1:20 \ft «Contemplar», de «ἰδοὺ», significa mirar, fijarse, observar, ver o contemplar. Se utiliza a menudo como interjección.\f* te quedarás callado \w y|strong="G2532"\w* \w no|strong="G3756"\w* \w podrás|strong="G1410"\w* \w hablar|strong="G2980"\w* \w hasta|strong="G1519"\w* \w el|strong="G3588"\w* \w día|strong="G2250"\w* \w en|strong="G1519"\w* \w que|strong="G3588"\w* sucedan \w estas|strong="G3778"\w* \w cosas|strong="G3739"\w*, \w porque|strong="G2532"\w* \w no|strong="G3756"\w* \w creíste|strong="G4100"\w* \w en|strong="G1519"\w* mis \w palabras|strong="G3056"\w*, \w que|strong="G3588"\w* \w se|strong="G1096"\w* cumplirán \w a|strong="G1519"\w* \w su|strong="G3588"\w* debido \w tiempo|strong="G2540"\w*.”   
\p
\v 21 \w La|strong="G3588"\w* gente esperaba \w a|strong="G1722"\w* \w Zacarías|strong="G2197"\w* \w y|strong="G2532"\w* \w se|strong="G2532"\w* maravillaba \w de|strong="G1722"\w* \w que|strong="G3588"\w* \w se|strong="G2532"\w* demorara \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w templo|strong="G3485"\w*.  
\v 22 \w Cuando|strong="G1722"\w* \w salió|strong="G1831"\w*, \w no|strong="G3756"\w* \w pudo|strong="G1410"\w* hablarles. \w Se|strong="G2532"\w* dieron cuenta \w de|strong="G1722"\w* \w que|strong="G3754"\w* había tenido \w una|strong="G3588"\w* \w visión|strong="G3701"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w templo|strong="G3485"\w*. Siguió haciéndoles señales, \w y|strong="G2532"\w* permaneció \w mudo|strong="G2974"\w*.  
\v 23 \w Cuando|strong="G5613"\w* \w se|strong="G1096"\w* cumplieron \w los|strong="G3588"\w* \w días|strong="G2250"\w* \w de|strong="G1519"\w* \w su|strong="G3588"\w* \w servicio|strong="G3009"\w*, \w se|strong="G1096"\w* \w fue|strong="G1096"\w* \w a|strong="G1519"\w* \w su|strong="G3588"\w* \w casa|strong="G3624"\w*.  
\v 24 \w Después|strong="G3326"\w* \w de|strong="G3588"\w* \w estos|strong="G3778"\w* \w días|strong="G2250"\w*, \w concibió|strong="G4815"\w* \w Elisabet|strong="G1665"\w*, \w su|strong="G3588"\w* \w mujer|strong="G1135"\w*, \w y|strong="G2532"\w* \w se|strong="G1438"\w* escondió \w cinco|strong="G4002"\w* \w meses|strong="G3376"\w*, \w diciendo|strong="G3004"\w*:  
\v 25 «\w Así|strong="G3779"\w* \w me|strong="G1473"\w* ha \w hecho|strong="G4160"\w* \w el|strong="G3739"\w* \w Señor|strong="G2962"\w* \w en|strong="G1722"\w* \w los|strong="G3748"\w* \w días|strong="G2250"\w* \w en|strong="G1722"\w* \w que|strong="G3754"\w* \w me|strong="G1473"\w* ha mirado, \w para|strong="G1722"\w* quitar mi oprobio \w entre|strong="G1722"\w* \w los|strong="G3748"\w* hombres.»   
\p
\v 26 \w En|strong="G1722"\w* \w el|strong="G3588"\w* \w sexto|strong="G1623"\w* \w mes|strong="G3376"\w*, \w el|strong="G3588"\w* ángel \w Gabriel|strong="G1043"\w* fue enviado \w por|strong="G1722"\w* \w Dios|strong="G2316"\w* \w a|strong="G1519"\w* \w una|strong="G3588"\w* \w ciudad|strong="G4172"\w* \w de|strong="G1722"\w* \w Galilea|strong="G1056"\w* \w llamada|strong="G3686"\w* \w Nazaret|strong="G3478"\w*,  
\v 27 \w a|strong="G4314"\w* \w una|strong="G3588"\w* \w virgen|strong="G3933"\w* comprometida \w a|strong="G4314"\w* casarse \w con|strong="G4314"\w* \w un|strong="G3588"\w* hombre \w que|strong="G3588"\w* \w se|strong="G4314"\w* llamaba \w José|strong="G2501"\w*, \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w casa|strong="G3624"\w* \w de|strong="G1537"\w* \w David|strong="G1138"\w*. \w La|strong="G3588"\w* \w virgen|strong="G3933"\w* \w se|strong="G4314"\w* llamaba \w María|strong="G3137"\w*.  
\v 28 \w Al|strong="G3588"\w* \w entrar|strong="G1525"\w*, \w el|strong="G3588"\w* ángel \w le|strong="G4314"\w* \w dijo|strong="G3004"\w*: «¡Alégrate, muy favorecida! \w El|strong="G3588"\w* \w Señor|strong="G2962"\w* \w está|strong="G3588"\w* \w contigo|strong="G3326"\w*. Bendita eres \w entre|strong="G4314"\w* \w las|strong="G3588"\w* mujeres».   
\p
\v 29 \w Pero|strong="G1161"\w* \w cuando|strong="G1909"\w* \w lo|strong="G3588"\w* vio, \w se|strong="G2532"\w* preocupó \w mucho|strong="G1909"\w* \w por|strong="G1909"\w* \w el|strong="G3588"\w* \w dicho|strong="G3056"\w*, \w y|strong="G2532"\w* pensó \w qué|strong="G3588"\w* clase \w de|strong="G1909"\w* saludo sería \w éste|strong="G3778"\w*.  
\v 30 \w El|strong="G3588"\w* ángel le \w dijo|strong="G3004"\w*: “\w No|strong="G3361"\w* \w temas|strong="G5399"\w*, \w María|strong="G3137"\w*, \w porque|strong="G1063"\w* has encontrado \w el|strong="G3588"\w* favor \w de|strong="G3844"\w* \w Dios|strong="G2316"\w*.  
\v 31 He aquí \w que|strong="G3588"\w* \w concebirás|strong="G4815"\w* \w en|strong="G1722"\w* \w tu|strong="G3588"\w* seno \w y|strong="G2532"\w* darás \w a|strong="G1722"\w* luz \w un|strong="G3588"\w* \w hijo|strong="G5207"\w*, \w al|strong="G3588"\w* \w que|strong="G3588"\w* pondrás \w por|strong="G1722"\w* \w nombre|strong="G3686"\w* «\w Jesús|strong="G2424"\w*».  
\v 32 Será \w grande|strong="G3173"\w* \w y|strong="G2532"\w* \w se|strong="G2532"\w* llamará \w Hijo|strong="G5207"\w* \w del|strong="G3588"\w* \w Altísimo|strong="G5310"\w*. \w El|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Dios|strong="G2316"\w* le \w dará|strong="G1325"\w* \w el|strong="G3588"\w* \w trono|strong="G2362"\w* \w de|strong="G1325"\w* \w su|strong="G3588"\w* \w padre|strong="G3962"\w* \w David|strong="G1138"\w*,  
\v 33 \w y|strong="G2532"\w* reinará \w sobre|strong="G1909"\w* \w la|strong="G3588"\w* \w casa|strong="G3624"\w* \w de|strong="G1909"\w* \w Jacob|strong="G2384"\w* \w para|strong="G1519"\w* \w siempre|strong="G3588"\w*. \w Su|strong="G3588"\w* Reino \w no|strong="G3756"\w* tendrá \w fin|strong="G5056"\w*”.   
\p
\v 34 \w María|strong="G3137"\w* \w dijo|strong="G3004"\w* \w al|strong="G3588"\w* ángel: «¿\w Cómo|strong="G4459"\w* puede ser \w esto|strong="G3778"\w*, \w siendo|strong="G1161"\w* yo virgen?».   
\p
\v 35 \w El|strong="G3588"\w* ángel \w le|strong="G1909"\w* respondió: «\w El|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo \w vendrá|strong="G1904"\w* \w sobre|strong="G1909"\w* ti, \w y|strong="G2532"\w* \w el|strong="G3588"\w* \w poder|strong="G1411"\w* \w del|strong="G3588"\w* \w Altísimo|strong="G5310"\w* \w te|strong="G4771"\w* cubrirá \w con|strong="G1909"\w* \w su|strong="G3588"\w* sombra. \w Por|strong="G1909"\w* eso \w también|strong="G2532"\w* \w el|strong="G3588"\w* santo \w que|strong="G3588"\w* nazca \w de|strong="G1909"\w* ti será \w llamado|strong="G2564"\w* \w Hijo|strong="G5207"\w* \w de|strong="G1909"\w* \w Dios|strong="G2316"\w*.  
\v 36 He aquí \w que|strong="G3588"\w* \w también|strong="G2532"\w* \w Elisabet|strong="G1665"\w*, \w tu|strong="G4771"\w* \w pariente|strong="G4773"\w*, ha concebido \w un|strong="G3588"\w* \w hijo|strong="G5207"\w* \w en|strong="G1722"\w* \w su|strong="G3588"\w* \w vejez|strong="G1094"\w*; \w y|strong="G2532"\w* \w éste|strong="G3778"\w* \w es|strong="G3778"\w* \w el|strong="G3588"\w* \w sexto|strong="G1623"\w* \w mes|strong="G3376"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w que|strong="G3588"\w* \w se|strong="G2532"\w* llamaba \w estéril|strong="G4723"\w*.  
\v 37 \w Porque|strong="G3754"\w* \w nada|strong="G3756"\w* \w de|strong="G3844"\w* \w lo|strong="G3588"\w* \w dicho|strong="G3588"\w* \w por|strong="G3754"\w* \w Dios|strong="G2316"\w* \w es|strong="G3756"\w* \w imposible|strong="G3756"\w*.»\f + \fr 1:37 \ft o «Porque todo lo que Dios dice es posible».\f*   
\p
\v 38 \w María|strong="G3137"\w* \w dijo|strong="G3004"\w*: «He aquí \w la|strong="G3588"\w* \w sierva|strong="G1399"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*; \w hágase|strong="G1096"\w* \w en|strong="G2596"\w* \w mí|strong="G3588"\w* \w según|strong="G2596"\w* \w tu|strong="G4771"\w* \w palabra|strong="G4487"\w*».  
\p \w Entonces|strong="G1161"\w* \w el|strong="G3588"\w* ángel \w se|strong="G1096"\w* alejó \w de|strong="G2596"\w* \w ella|strong="G3588"\w*.   
\p
\v 39 \w En|strong="G1722"\w* \w aquellos|strong="G3588"\w* \w días|strong="G2250"\w*, \w María|strong="G3137"\w* se levantó \w y|strong="G1161"\w* se \w fue|strong="G4198"\w* \w de|strong="G1722"\w* prisa \w a|strong="G1519"\w* \w la|strong="G3588"\w* región montañosa, \w a|strong="G1519"\w* \w una|strong="G3588"\w* \w ciudad|strong="G4172"\w* \w de|strong="G1722"\w* \w Judá|strong="G2448"\w*,  
