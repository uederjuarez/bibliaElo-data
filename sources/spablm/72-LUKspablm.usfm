\c 6
\p
\v 1 \w Y|strong="G2532"\w* \w aconteció|strong="G1096"\w*, \w que|strong="G3588"\w* \w un|strong="G3588"\w* \w día|strong="G1722"\w* \w de|strong="G1722"\w* reposo iba \w por|strong="G1223"\w* \w los|strong="G3588"\w* campos \w de|strong="G1722"\w* trigo. \w Sus|strong="G3588"\w* \w discípulos|strong="G3101"\w* \w arrancaban|strong="G5089"\w* \w las|strong="G3588"\w* \w espigas|strong="G4719"\w* \w y|strong="G2532"\w* \w comían|strong="G2068"\w*, frotándolas \w en|strong="G1722"\w* \w sus|strong="G3588"\w* \w manos|strong="G5495"\w*.  
