\v 12 \wj \+w ayuno|strong="G3522"\+w* \+w dos|strong="G1364"\+w* veces a \+w la|strong="G3588"\+w* \+w semana|strong="G4521"\+w*, y doy \+w el|strong="G3588"\+w* diezmo \+w de|strong="G3588"\+w* \+w todo|strong="G3956"\+w* \+w lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* gano’. \wj*  
\v 13 \wj \+w Mas|strong="G1161"\+w* \+w el|strong="G3588"\+w* \+w publicano|strong="G5057"\+w*, \+w estando|strong="G2476"\+w* \+w lejos|strong="G3113"\+w*, \+w no|strong="G3756"\+w* \+w quería|strong="G2309"\+w* \+w ni|strong="G3761"\+w* \+w aun|strong="G1161"\+w* alzar \+w los|strong="G3588"\+w* \+w ojos|strong="G3788"\+w* \+w al|strong="G3588"\+w* \+w cielo|strong="G3772"\+w*, \+w sino|strong="G1161"\+w* \+w que|strong="G3588"\+w* se golpeaba \+w el|strong="G3588"\+w* \+w pecho|strong="G4738"\+w* \+w diciendo|strong="G3004"\+w*: ‘¡\+w Dios|strong="G2316"\+w*, sé propicio \+w a|strong="G1519"\+w* \+w mí|strong="G3588"\+w*, pecador!’. \wj*  
