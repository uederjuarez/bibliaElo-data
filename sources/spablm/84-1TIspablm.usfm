\c 2
\p
\v 1 \w Exhorto|strong="G3870"\w* \w ante|strong="G4412"\w* \w todo|strong="G3956"\w*, a \w que|strong="G3767"\w* se \w hagan|strong="G4160"\w* \w rogativas|strong="G1162"\w*, \w oraciones|strong="G4335"\w*, \w peticiones|strong="G1783"\w* \w y|strong="G3767"\w* acciones \w de|strong="G5228"\w* gracias, \w por|strong="G5228"\w* \w todos|strong="G3956"\w* los hombres;  
\v 2 \w por|strong="G1722"\w* \w los|strong="G3588"\w* reyes \w y|strong="G2532"\w* \w por|strong="G1722"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* están \w en|strong="G1722"\w* \w eminencia|strong="G5247"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* vivamos \w quieta|strong="G2263"\w* \w y|strong="G2532"\w* \w reposadamente|strong="G2272"\w* \w en|strong="G1722"\w* \w toda|strong="G3956"\w* \w piedad|strong="G2150"\w* \w y|strong="G2532"\w* \w honestidad|strong="G4587"\w*.  
