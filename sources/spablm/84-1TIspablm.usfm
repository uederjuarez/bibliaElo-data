\v 9 \w Asimismo|strong="G2532"\w* \w que|strong="G2228"\w* las \w mujeres|strong="G1135"\w* \w se|strong="G1438"\w* atavíen \w de|strong="G1722"\w* \w ropa|strong="G2441"\w* decorosa, \w con|strong="G3326"\w* pudor \w y|strong="G2532"\w* \w modestia|strong="G4997"\w*; \w no|strong="G3361"\w* \w con|strong="G3326"\w* peinado ostentoso, \w ni|strong="G2532"\w* \w oro|strong="G5557"\w*, \w ni|strong="G2532"\w* \w perlas|strong="G3135"\w*, \w ni|strong="G2532"\w* \w vestidos|strong="G2441"\w* \w costosos|strong="G4185"\w*,  
