\v 5 \w Porque|strong="G1063"\w* hay \w un|strong="G1520"\w* \w solo|strong="G1520"\w* \w Dios|strong="G2316"\w*, \w y|strong="G2532"\w* \w un|strong="G1520"\w* \w solo|strong="G1520"\w* \w mediador|strong="G3316"\w* entre \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w los|strong="G2532"\w* hombres, \w Jesucristo|strong="G2424"\w* hombre,  
