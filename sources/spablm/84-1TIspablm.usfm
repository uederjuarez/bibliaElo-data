\v 15 \w Pero|strong="G1161"\w* \w se|strong="G2532"\w* \w salvará|strong="G4982"\w* engendrando hijos, \w si|strong="G1437"\w* \w permaneciere|strong="G3306"\w* \w en|strong="G1722"\w* \w fe|strong="G4102"\w*, amor \w y|strong="G2532"\w* santificación, \w con|strong="G3326"\w* \w modestia|strong="G4997"\w*.   
\c 3
\p
\v 1 \w Palabra|strong="G3056"\w* \w fiel|strong="G4103"\w*: \w Si|strong="G1487"\w* \w alguno|strong="G5100"\w* anhela \w obispado|strong="G1984"\w*, \w buena|strong="G2570"\w* \w obra|strong="G2041"\w* \w desea|strong="G1937"\w*.  
