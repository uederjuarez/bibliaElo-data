\v 7 \w Para|strong="G1519"\w* \w esto|strong="G3739"\w* \w yo|strong="G1473"\w* fui constituido \w predicador|strong="G2783"\w* \w y|strong="G2532"\w* apóstol (\w digo|strong="G3004"\w* \w verdad|strong="G4102"\w* \w en|strong="G1722"\w* Cristo, \w no|strong="G3756"\w* \w miento|strong="G5574"\w*), \w y|strong="G2532"\w* \w maestro|strong="G1320"\w* \w de|strong="G1722"\w* \w los|strong="G2532"\w* gentiles \w en|strong="G1722"\w* \w fe|strong="G4102"\w* \w y|strong="G2532"\w* \w verdad|strong="G4102"\w*.   
