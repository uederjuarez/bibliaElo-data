\v 3 \w no|strong="G3361"\w* dado al vino, \w no|strong="G3361"\w* pendenciero, \w no|strong="G3361"\w* codicioso de ganancias deshonestas, \w sino|strong="G3361"\w* amable, apacible, \w no|strong="G3361"\w* avaro;  
\v 4 \w que|strong="G3588"\w* gobierne \w bien|strong="G2573"\w* \w su|strong="G3588"\w* \w casa|strong="G3624"\w*, \w que|strong="G3588"\w* \w tenga|strong="G2192"\w* \w a|strong="G1722"\w* \w sus|strong="G3588"\w* \w hijos|strong="G5043"\w* \w en|strong="G1722"\w* \w sujeción|strong="G5292"\w* \w con|strong="G3326"\w* \w toda|strong="G3956"\w* \w honestidad|strong="G4587"\w*  
\v 5 (\w pues|strong="G1161"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w no|strong="G3756"\w* \w sabe|strong="G1492"\w* \w gobernar|strong="G4291"\w* \w su|strong="G3588"\w* \w propia|strong="G2398"\w* \w casa|strong="G3624"\w*, ¿\w cómo|strong="G4459"\w* \w cuidará|strong="G1959"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w*?);  
\v 6 \w no|strong="G3361"\w* \w un|strong="G3588"\w* neófito, \w no|strong="G3361"\w* \w sea|strong="G3588"\w* \w que|strong="G3588"\w* envaneciéndose \w caiga|strong="G1706"\w* \w en|strong="G1519"\w* \w la|strong="G3588"\w* \w condenación|strong="G2917"\w* \w del|strong="G3588"\w* \w diablo|strong="G1228"\w*.  
