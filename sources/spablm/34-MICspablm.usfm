\q1
\v 6 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w deshonra|strong="H5034"\w* al padre,  
\q2 \w la|strong="H3588"\w* \w hija|strong="H1323"\w* se levanta contra \w su|strong="H3588"\w* madre,  
\q2 \w la|strong="H3588"\w* \w nuera|strong="H3618"\w* contra \w su|strong="H3588"\w* \w suegra|strong="H2545"\w*,  
\q2 \w y|strong="H3588"\w* \w los|strong="H1121"\w* enemigos del \w hombre|strong="H1121"\w* \w son|strong="H3588"\w* \w los|strong="H1121"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* propia \w casa|strong="H1004"\w*.   
\q1
\v 7 Mas yo miraré hacia Yahvé;  
\q2 \w esperaré|strong="H3176"\w* al \w Dios|strong="H3068"\w* de mi salvación.  
\q2 El \w Dios|strong="H3068"\w* mío me \w oirá|strong="H8085"\w*.   
\q1
\v 8 \w No|strong="H3588"\w* \w te|strong="H3588"\w* alegres \w de|strong="H3588"\w* mí, enemiga mía.  
