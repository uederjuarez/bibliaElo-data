\toc1 MIQUEAS 
\toc2 MIQUEAS 
\mt1 Miqueas  
\c 1
\p
\v 1 \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w que|strong="H5921"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* Miqueas \w de|strong="H5921"\w* Moreset \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Jotam, Acaz \w y|strong="H5921"\w* Ezequías, \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*; \w lo|strong="H1697"\w* \w que|strong="H5921"\w* \w vio|strong="H2372"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w Samaria|strong="H8111"\w* \w y|strong="H5921"\w* Jerusalén.   
\q1
\v 2 ¡\w Oíd|strong="H8085"\w*, \w pueblos|strong="H5971"\w* \w todos|strong="H3605"\w*!  
\q2 \w Escucha|strong="H8085"\w*, tierra, y cuanto \w hay|strong="H1961"\w* en ti.  
\q1 \w Que|strong="H5971"\w* \w el|strong="H3605"\w* Señor Yahvé \w sea|strong="H1961"\w* \w testigo|strong="H5707"\w* \w contra|strong="H1961"\w* \w vosotros|strong="H8085"\w*,  
\q2 \w el|strong="H3605"\w* Señor desde su \w santo|strong="H6944"\w* \w templo|strong="H1964"\w*.   
\q1
\v 3 \w Porque|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* Yahvé \w sale|strong="H3318"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* morada,  
\q2 \w y|strong="H3588"\w* \w descenderá|strong="H3381"\w* \w y|strong="H3588"\w* hollará \w los|strong="H5921"\w* \w lugares|strong="H4725"\w* \w altos|strong="H1116"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.   
\q1
\v 4 Las montañas se derriten \w bajo|strong="H8478"\w* él  
\q2 y los \w valles|strong="H6010"\w* se hienden \w como|strong="H8478"\w* la cera \w ante|strong="H6440"\w* el fuego,  
\q2 \w como|strong="H8478"\w* las \w aguas|strong="H4325"\w* \w que|strong="H4325"\w* se vierten \w por|strong="H8478"\w* una pendiente.   
\b  
\q1
\v 5 \w Todo|strong="H3605"\w* \w esto|strong="H2063"\w* \w es|strong="H2063"\w* por \w la|strong="H2063"\w* \w rebelión|strong="H6588"\w* de \w Jacob|strong="H3290"\w*  
\q2 y por \w los|strong="H3605"\w* \w pecados|strong="H2403"\w* de \w la|strong="H2063"\w* \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*.  
\q1 ¿\w Cuál|strong="H4310"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w rebelión|strong="H6588"\w* de \w Jacob|strong="H3290"\w*?  
\q2 ¿\w No|strong="H3808"\w* \w es|strong="H2063"\w* \w Samaria|strong="H8111"\w*?  
\q1 ¿\w Y|strong="H3068"\w* cuáles \w son|strong="H3808"\w* \w los|strong="H3605"\w* lugares \w altos|strong="H1116"\w* de \w Judá|strong="H3063"\w*?  
\q2 ¿\w No|strong="H3808"\w* \w es|strong="H2063"\w* Jerusalén?   
\q1
\v 6 Por tanto, \w haré|strong="H7760"\w* de \w Samaria|strong="H8111"\w* un montón de ruinas en el \w campo|strong="H7704"\w*,  
\q2 tierra para plantar viñedos;  
\q1 despeñaré sus piedras en el \w valle|strong="H1516"\w*  
\q2 y \w descubriré|strong="H1540"\w* sus cimientos.   
\q1
\v 7 \w Todas|strong="H3605"\w* sus estatuas serán despedazadas,  
\q2 \w todas|strong="H3605"\w* sus ganancias \w de|strong="H3588"\w* \w ramera|strong="H2181"\w* serán quemadas \w en|strong="H5704"\w* \w el|strong="H3588"\w* fuego  
\q2 \w y|strong="H3588"\w* \w asolaré|strong="H7760"\w* \w todas|strong="H3605"\w* sus imágenes;  
\q1 \w porque|strong="H3588"\w* \w de|strong="H3588"\w* paga \w de|strong="H3588"\w* \w ramera|strong="H2181"\w* las reunió,  
\q2 \w y|strong="H3588"\w* \w a|strong="H3068"\w* paga \w de|strong="H3588"\w* \w ramera|strong="H2181"\w* \w volverán|strong="H7725"\w*.   
\b  
\q1
\v 8 \w Por|strong="H5921"\w* \w esto|strong="H2063"\w* \w me|strong="H5921"\w* lamentaré \w y|strong="H5921"\w* aullaré;  
\q2 \w andaré|strong="H3212"\w* despojado \w y|strong="H5921"\w* \w desnudo|strong="H6174"\w*.  
\q2 Daré alaridos \w como|strong="H5921"\w* \w los|strong="H5921"\w* chacales  
\q2 \w y|strong="H5921"\w* lamentos \w como|strong="H5921"\w* \w los|strong="H5921"\w* avestruces.   
\q1
\v 9 \w Porque|strong="H3588"\w* \w su|strong="H3588"\w* \w llaga|strong="H4347"\w* \w es|strong="H3588"\w* incurable  
\q2 \w y|strong="H3588"\w* ha \w llegado|strong="H5060"\w* \w hasta|strong="H5704"\w* \w Judá|strong="H3063"\w*;  
\q1 \w se|strong="H5971"\w* ha extendido \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* \w de|strong="H3588"\w* \w mi|strong="H3389"\w* \w pueblo|strong="H5971"\w*,  
\q2 \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* misma Jerusalén.   
\q1
\v 10 No lo anunciéis en Gat,  
\q2 ni \w lloréis|strong="H1058"\w* \w amargamente|strong="H1058"\w*.  
\q2 En Bet-le-afrá me he revolcado en el \w polvo|strong="H6083"\w*.   
\q1
\v 11 \w Pasa|strong="H5674"\w*, \w morador|strong="H3427"\w* \w de|strong="H4480"\w* Safir, \w en|strong="H4480"\w* desnudez y vergüenza.  
\q2 \w El|strong="H5674"\w* \w morador|strong="H3427"\w* \w de|strong="H4480"\w* Zaánan \w no|strong="H3808"\w* \w se|strong="H4480"\w* atrevió \w a|strong="H3068"\w* \w salir|strong="H3318"\w*.  
\q2 \w El|strong="H5674"\w* llanto \w de|strong="H4480"\w* Bet-ezel \w os|strong="H4480"\w* \w quitará|strong="H3947"\w* su apoyo.   
\q1
\v 12 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w morador|strong="H3427"\w* \w de|strong="H3588"\w* Marot anhelaba \w el|strong="H3588"\w* \w bien|strong="H2896"\w*,  
\q2 \w pero|strong="H3588"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w* ha descendido \w de|strong="H3588"\w* parte \w de|strong="H3588"\w* Yahvé hasta \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* \w de|strong="H3588"\w* Jerusalén.   
\q1
\v 13 Uncid al \w carro|strong="H4818"\w* \w los|strong="H3427"\w* corceles, \w moradores|strong="H3427"\w* \w de|strong="H3588"\w* Laquis;  
\q2 vosotros fuisteis \w principio|strong="H7225"\w* \w de|strong="H3588"\w* \w pecado|strong="H2403"\w* \w para|strong="H3588"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* \w Sión|strong="H6726"\w*,  
\q2 \w porque|strong="H3588"\w* \w en|strong="H3588"\w* vosotros \w se|strong="H1931"\w* \w hallaron|strong="H4672"\w* las \w rebeliones|strong="H6588"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.   
\q1
\v 14 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w daréis|strong="H5414"\w* \w dones|strong="H7964"\w* \w de|strong="H5921"\w* despedida \w a|strong="H3068"\w* Moreset-gat.  
\q2 \w Las|strong="H5921"\w* \w casas|strong="H1004"\w* \w de|strong="H5921"\w* Aczib serán un engaño \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\q1
\v 15 \w Aún|strong="H5750"\w* \w os|strong="H5704"\w* traeré un conquistador, \w moradores|strong="H3427"\w* \w de|strong="H5750"\w* \w Maresá|strong="H4762"\w*;  
\q2 la \w gloria|strong="H3519"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w* llegará \w hasta|strong="H5704"\w* Adulam.   
\q1
\v 16 Ráate \w la|strong="H5921"\w* cabeza  
\q2 \w y|strong="H3588"\w* córtate \w el|strong="H5921"\w* cabello \w por|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* tus delicias;  
\q1 hazte una calva tan \w ancha|strong="H7337"\w* \w como|strong="H3588"\w* \w la|strong="H5921"\w* \w del|strong="H4480"\w* buitre,  
\q2 \w porque|strong="H3588"\w* han sido llevados \w al|strong="H5921"\w* destierro lejos \w de|strong="H4480"\w* \w ti|strong="H4480"\w*.   
\c 2
\p
\v 1 ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* traman \w la|strong="H5921"\w* iniquidad  
\q2 \w y|strong="H3588"\w* \w maquinan|strong="H2803"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w en|strong="H5921"\w* sus lechos!  
\q1 \w Al|strong="H5921"\w* clarear \w el|strong="H5921"\w* día \w lo|strong="H5921"\w* ejecutan,  
\q2 \w porque|strong="H3588"\w* \w está|strong="H3426"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w poder|strong="H3027"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*.   
\q1
\v 2 Codician \w campos|strong="H7704"\w* y se apoderan de ellos;  
\q2 codician \w casas|strong="H1004"\w* y las \w quitan|strong="H1497"\w*.  
\q1 Oprimen al \w hombre|strong="H1397"\w* y \w a|strong="H3068"\w* su \w familia|strong="H1004"\w*,  
\q2 al \w hombre|strong="H1397"\w* y \w a|strong="H3068"\w* su \w heredad|strong="H5159"\w*.   
\q1
\v 3 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice Yahvé:  
\q1 “He \w aquí|strong="H8033"\w*, \w yo|strong="H3588"\w* preparo \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* estirpe un \w mal|strong="H7451"\w*  
\q2 \w del|strong="H5921"\w* \w cual|strong="H1931"\w* \w no|strong="H3808"\w* podréis librar \w el|strong="H1931"\w* \w cuello|strong="H6677"\w*,  
\q2 \w ni|strong="H3808"\w* caminaréis \w con|strong="H5921"\w* altivez,  
\q2 \w porque|strong="H3588"\w* \w será|strong="H1931"\w* un \w tiempo|strong="H6256"\w* aciago.   
\q1
\v 4 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* entonará \w contra|strong="H5921"\w* vosotros un refrán,  
\q2 \w y|strong="H5921"\w* \w se|strong="H1931"\w* hará un lamento lúgubre, diciendo:  
\q2 ‘¡Estamos totalmente arruinados!  
\q2 \w La|strong="H1931"\w* \w heredad|strong="H7704"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* ha sido repartida.  
\q2 ¡\w Cómo|strong="H5921"\w* \w nos|strong="H5921"\w* \w la|strong="H1931"\w* \w quita|strong="H5375"\w*! Asigna nuestros \w campos|strong="H7704"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* traidores’”.   
\q1
\v 5 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w no|strong="H3808"\w* \w tendrás|strong="H1961"\w* \w a|strong="H3068"\w* \w nadie|strong="H3808"\w* \w que|strong="H3808"\w* reparta la tierra \w a|strong="H3068"\w* cordel  
\q2 en la asamblea de Yahvé.   
\q1
\v 6 «¡\w No|strong="H3808"\w* \w profeticéis|strong="H5197"\w*!» —dicen ellos.  
\q2 «\w No|strong="H3808"\w* \w se|strong="H3808"\w* debe profetizar sobre estas cosas;  
\q2 la \w vergüenza|strong="H3639"\w* \w no|strong="H3808"\w* nos alcanzará».   
\q1
\v 7 Tú, \w que|strong="H3808"\w* \w te|strong="H5973"\w* llamas \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Jacob|strong="H3290"\w*,  
\q2 ¿acaso \w se|strong="H3808"\w* \w ha|strong="H3808"\w* agotado la paciencia \w del|strong="H5973"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5973"\w* Yahvé?  
\q2 ¿\w Son|strong="H3808"\w* estas sus \w obras|strong="H4611"\w*?  
\q2 ¿\w No|strong="H3808"\w* hacen \w bien|strong="H3190"\w* mis \w palabras|strong="H1697"\w* al \w que|strong="H3808"\w* \w camina|strong="H1980"\w* rectamente?   
\q1
\v 8 Pero hace poco mi \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* ha levantado \w como|strong="H8008"\w* enemigo;  
\q2 \w a|strong="H3068"\w* los \w que|strong="H5971"\w* \w pasan|strong="H5674"\w* confiados, \w como|strong="H8008"\w* los \w que|strong="H5971"\w* \w vuelven|strong="H7725"\w* \w de|strong="H5971"\w* la \w guerra|strong="H4421"\w*,  
\q2 les quitáis la túnica y \w el|strong="H5674"\w* manto.   
\q1
\v 9 \w A|strong="H3068"\w* \w las|strong="H5921"\w* mujeres \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* expulsáis \w de|strong="H5921"\w* sus hogares queridos;  
\q2 \w a|strong="H3068"\w* sus \w niños|strong="H5768"\w* pequeños \w les|strong="H5921"\w* arrebatáis \w mi|strong="H5921"\w* \w gloria|strong="H1926"\w* \w para|strong="H5921"\w* \w siempre|strong="H5769"\w*.   
\q1
\v 10 ¡\w Levantaos|strong="H6965"\w* \w y|strong="H3588"\w* \w marchaos|strong="H3212"\w*!  
\q2 \w Porque|strong="H3588"\w* \w este|strong="H2063"\w* \w no|strong="H3808"\w* \w es|strong="H3588"\w* vuestro lugar \w de|strong="H3588"\w* \w descanso|strong="H4496"\w*,  
\q2 \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w la|strong="H2063"\w* impureza \w que|strong="H3588"\w* destruye  
\q2 \w con|strong="H3588"\w* una destrucción atroz.   
\q1
\v 11 \w Si|strong="H3863"\w* un hombre \w que|strong="H5971"\w* \w camina|strong="H1980"\w* con \w espíritu|strong="H7307"\w* \w de|strong="H5971"\w* falsedad mintiese diciendo:  
\q2 «\w Yo|strong="H5197"\w* os profetizaré \w sobre|strong="H1961"\w* el \w vino|strong="H3196"\w* y la \w sidra|strong="H7941"\w*»,  
\q2 \w ese|strong="H2088"\w* \w sería|strong="H1961"\w* el \w profeta|strong="H5197"\w* \w para|strong="H1961"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*.   
\q1
\v 12 «\w Ciertamente|strong="H6908"\w* os reuniré \w a|strong="H3068"\w* \w todos|strong="H3605"\w*, oh \w Jacob|strong="H3290"\w*;  
\q2 \w recogeré|strong="H6908"\w* \w el|strong="H3605"\w* remanente de \w Israel|strong="H3478"\w*.  
\q1 \w Los|strong="H3605"\w* \w juntaré|strong="H6908"\w* como \w ovejas|strong="H6629"\w* \w en|strong="H8432"\w* \w el|strong="H3605"\w* aprisco,  
\q2 como \w rebaño|strong="H6629"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de su pastizal;  
\q2 habrá estrépito de multitud de gente».   
\q1
\v 13 \w El|strong="H5674"\w* que abre camino \w subirá|strong="H5927"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos;  
\q2 \w romperán|strong="H6555"\w* la brecha, \w pasarán|strong="H5674"\w* la \w puerta|strong="H8179"\w* y \w saldrán|strong="H3318"\w* \w por|strong="H6440"\w* ella.  
\q2 Su \w rey|strong="H4428"\w* \w pasará|strong="H5674"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos,  
\q2 con Yahvé \w a|strong="H3068"\w* su \w cabeza|strong="H7218"\w*.   
\c 3
\p
\v 1 Dije:  
\q1 «\w Oíd|strong="H8085"\w*, os \w ruego|strong="H4994"\w*, \w cabezas|strong="H7218"\w* de \w Jacob|strong="H3290"\w*,  
\q2 y \w jefes|strong="H7218"\w* de la \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*:  
\q2 ¿\w No|strong="H3808"\w* os corresponde \w a|strong="H3068"\w* \w vosotros|strong="H8085"\w* conocer el \w derecho|strong="H4941"\w*?   
\q1
\v 2 Vosotros, \w que|strong="H5921"\w* odiáis \w el|strong="H5921"\w* \w bien|strong="H2896"\w*  
\q2 \w y|strong="H5921"\w* amáis \w el|strong="H5921"\w* \w mal|strong="H7451"\w*;  
\q2 \w que|strong="H5921"\w* \w les|strong="H5921"\w* arrancáis \w la|strong="H5921"\w* \w piel|strong="H5785"\w*  
\q2 \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w carne|strong="H7607"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* sus \w huesos|strong="H6106"\w*;   
\q2
\v 3 \w que|strong="H5921"\w* coméis también \w la|strong="H5921"\w* \w carne|strong="H1320"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*,  
\q2 \w les|strong="H5921"\w* desolláis \w la|strong="H5921"\w* \w piel|strong="H5785"\w*,  
\q2 \w les|strong="H5921"\w* quebráis \w los|strong="H5921"\w* \w huesos|strong="H6106"\w*  
\q2 \w y|strong="H5921"\w* \w los|strong="H5921"\w* picáis \w como|strong="H5921"\w* \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w olla|strong="H5518"\w*,  
\q2 \w como|strong="H5921"\w* \w carne|strong="H1320"\w* \w dentro|strong="H8432"\w* \w del|strong="H5921"\w* caldero».   
\q1
\v 4 \w Entonces|strong="H6256"\w* \w clamarán|strong="H2199"\w* \w a|strong="H3068"\w* Yahvé,  
\q2 pero \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w les|strong="H1992"\w* \w responderá|strong="H6030"\w*.  
\q1 \w Antes|strong="H6440"\w* bien, esconderá \w de|strong="H6440"\w* \w ellos|strong="H1992"\w* \w su|strong="H1931"\w* \w rostro|strong="H6440"\w* en \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w*,  
\q2 \w por|strong="H6440"\w* cuanto cometieron malvadas \w obras|strong="H4611"\w*.   
\p
\v 5 \w Así|strong="H3541"\w* dice Yahvé \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w* \w que|strong="H3808"\w* extravían \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*: “\w Si|strong="H3808"\w* tienen algo \w que|strong="H3808"\w* morder \w con|strong="H5921"\w* sus \w dientes|strong="H8127"\w*, proclaman: ‘¡\w Paz|strong="H7965"\w*!’, pero \w a|strong="H3068"\w* quien \w no|strong="H3808"\w* \w les|strong="H5921"\w* pone \w nada|strong="H3808"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w*, \w le|strong="H5921"\w* declaran \w la|strong="H5921"\w* \w guerra|strong="H4421"\w*”:   
\q1
\v 6 «\w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w se|strong="H5921"\w* \w os|strong="H5921"\w* hará \w noche|strong="H3915"\w* sin \w visión|strong="H2377"\w*,  
\q2 \w y|strong="H5921"\w* tendréis tinieblas sin revelación;  
\q2 \w el|strong="H5921"\w* \w sol|strong="H8121"\w* \w se|strong="H5921"\w* pondrá \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w*,  
