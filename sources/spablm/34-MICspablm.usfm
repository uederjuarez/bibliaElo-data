\q2 y el efa escaso que es detestable?   
\q1
\v 11 ¿Daré por inocente al que tiene balanza falsa,  
\q2 y \w bolsa|strong="H3599"\w* de pesas \w engañosas|strong="H4820"\w*?   
\q1
\v 12 Pues sus ricos \w están|strong="H3427"\w* \w llenos|strong="H4390"\w* de \w violencia|strong="H2555"\w*,  
\q2 y sus \w moradores|strong="H3427"\w* \w hablan|strong="H1696"\w* \w mentira|strong="H8267"\w*,  
\q2 y su \w lengua|strong="H3956"\w* es \w engañosa|strong="H7423"\w* en su \w boca|strong="H6310"\w*.   
\q1
\v 13 \w Por|strong="H5921"\w* eso yo \w también|strong="H1571"\w* \w te|strong="H5921"\w* \w heriré|strong="H5221"\w* gravemente,  
\q2 \w asolándote|strong="H8074"\w* \w por|strong="H5921"\w* tus \w pecados|strong="H2403"\w*.   
\q1
\v 14 Comerás, pero \w no|strong="H3808"\w* te saciarás,  
\q2 y el vacío estará en tus entrañas.  
\q2 Recogerás, pero \w no|strong="H3808"\w* \w salvarás|strong="H6403"\w*,  
\q2 y \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w salvaras|strong="H6403"\w*, \w lo|strong="H3808"\w* \w entregaré|strong="H5414"\w* yo \w a|strong="H3068"\w* \w la|strong="H7646"\w* \w espada|strong="H2719"\w*.   
\q1
\v 15 \w Sembrarás|strong="H2232"\w*, \w mas|strong="H3808"\w* \w no|strong="H3808"\w* \w segarás|strong="H7114"\w*.  
\q2 \w Pisarás|strong="H1869"\w* \w aceitunas|strong="H2132"\w*, \w mas|strong="H3808"\w* \w no|strong="H3808"\w* te ungirás con el \w aceite|strong="H8081"\w*;  
\q2 y \w pisarás|strong="H1869"\w* uvas, \w mas|strong="H3808"\w* \w no|strong="H3808"\w* \w beberás|strong="H8354"\w* el \w vino|strong="H3196"\w*.   
\q1
\v 16 \w Porque|strong="H4616"\w* \w se|strong="H5971"\w* han \w guardado|strong="H8104"\w* \w los|strong="H3427"\w* \w estatutos|strong="H2708"\w* \w de|strong="H5971"\w* \w Omrí|strong="H6018"\w*,  
\q2 y \w todas|strong="H3605"\w* las \w obras|strong="H4639"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Acab.  
\q2 Habéis caminado según sus \w consejos|strong="H4156"\w*,  
\q2 \w para|strong="H4616"\w* \w que|strong="H5971"\w* yo te \w entregue|strong="H5414"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* desolación,  
\q2 y \w a|strong="H3068"\w* vuestros \w moradores|strong="H3427"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* burla.  
\q2 \w Llevaréis|strong="H5375"\w*, pues, \w el|strong="H3605"\w* reproche \w de|strong="H5971"\w* \w mi|strong="H5375"\w* \w pueblo|strong="H5971"\w*».   
\b  
\c 7
\q1
\v 1 ¡Ay \w de|strong="H3588"\w* \w mí|strong="H1961"\w*! \w Porque|strong="H3588"\w* \w soy|strong="H1961"\w* \w como|strong="H3588"\w* \w cuando|strong="H3588"\w* han recogido \w los|strong="H1961"\w* \w frutos|strong="H7019"\w* del \w verano|strong="H7019"\w*, \w como|strong="H3588"\w* \w los|strong="H1961"\w* rebuscos \w de|strong="H3588"\w* \w la|strong="H3588"\w* vendimia.  
\q2 \w No|strong="H3588"\w* queda ni un racimo \w de|strong="H3588"\w* uvas \w para|strong="H3588"\w* \w comer|strong="H5315"\w*; \w mi|strong="H1961"\w* \w alma|strong="H5315"\w* desea \w la|strong="H3588"\w* breva.   
\q1
\v 2 Ha perecido \w el|strong="H3605"\w* hombre piadoso \w de|strong="H4480"\w* \w la|strong="H3605"\w* tierra,  
\q2 y no queda \w nadie|strong="H3605"\w* \w recto|strong="H3477"\w* \w entre|strong="H4480"\w* \w los|strong="H3605"\w* hombres.  
\q2 \w Todos|strong="H3605"\w* acechan \w para|strong="H4480"\w* derramar \w sangre|strong="H1818"\w*;  
\q2 \w cada|strong="H3605"\w* cual \w caza|strong="H6679"\w* \w a|strong="H3068"\w* su hermano \w con|strong="H4480"\w* una red.   
\q1
\v 3 \w Sus|strong="H1931"\w* \w manos|strong="H3709"\w* son diestras \w para|strong="H5921"\w* hacer \w el|strong="H1931"\w* \w mal|strong="H7451"\w*;  
\q2 \w el|strong="H1931"\w* \w príncipe|strong="H8269"\w* \w y|strong="H5921"\w* \w el|strong="H1931"\w* \w juez|strong="H8199"\w* exigen soborno.  
\q1 \w El|strong="H1931"\w* poderoso manifiesta \w el|strong="H1931"\w* \w deseo|strong="H7592"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w alma|strong="H5315"\w*,  
\q2 \w y|strong="H5921"\w* \w así|strong="H1931"\w* traman todos juntos \w la|strong="H1931"\w* conspiración.   
\q1
\v 4 El \w mejor|strong="H2896"\w* de ellos \w es|strong="H1961"\w* \w como|strong="H1961"\w* una zarza;  
\q2 el \w más|strong="H6258"\w* \w recto|strong="H3477"\w* \w es|strong="H1961"\w* peor \w que|strong="H6258"\w* un seto de espinos.  
\q1 El \w día|strong="H3117"\w* de tus atalayas,  
\q2 el \w día|strong="H3117"\w* de tu castigo ha llegado;  
\q2 \w ahora|strong="H6258"\w* \w será|strong="H1961"\w* su confusión.   
\q1
\v 5 No confiéis en el \w prójimo|strong="H7453"\w*,  
\q2 ni tengáis fe en el \w amigo|strong="H7453"\w*;  
\q2 de \w la|strong="H8104"\w* \w que|strong="H6310"\w* \w duerme|strong="H7901"\w* \w a|strong="H3068"\w* tu lado,  
