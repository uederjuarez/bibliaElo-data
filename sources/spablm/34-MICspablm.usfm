\q1
\v 12 \w En|strong="H4480"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* vendrán \w a|strong="H3068"\w* \w ti|strong="H4480"\w* \w desde|strong="H4480"\w* Asiria \w y|strong="H5704"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H4480"\w* Egipto,  
\q2 \w desde|strong="H4480"\w* Egipto \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* Gran \w Río|strong="H5104"\w*,  
\q2 \w de|strong="H4480"\w* \w mar|strong="H3220"\w* \w a|strong="H3068"\w* \w mar|strong="H3220"\w*  
\q2 \w y|strong="H5704"\w* \w de|strong="H4480"\w* montaña \w a|strong="H3068"\w* montaña.   
\q1
\v 13 Pero \w la|strong="H5921"\w* tierra \w será|strong="H1961"\w* \w asolada|strong="H8077"\w* \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* sus \w moradores|strong="H3427"\w*,  
\q2 \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w fruto|strong="H6529"\w* \w de|strong="H5921"\w* sus \w obras|strong="H4611"\w*.   
\q1
\v 14 Pastorea \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* con tu cayado,  
\q2 al \w rebaño|strong="H6629"\w* \w de|strong="H5971"\w* tu \w heredad|strong="H5159"\w*,  
\q2 \w que|strong="H5971"\w* \w mora|strong="H7931"\w* solo \w en|strong="H8432"\w* la selva,  
\q1 \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del Carmelo. \w Que|strong="H5971"\w* \w se|strong="H5971"\w* alimenten  
\q2 \w en|strong="H8432"\w* \w Basán|strong="H1316"\w* y \w Galaad|strong="H1568"\w*, \w como|strong="H7931"\w* \w en|strong="H8432"\w* los \w tiempos|strong="H3117"\w* \w de|strong="H5971"\w* antaño.   
\q1
\v 15 «Como \w en|strong="H3318"\w* los \w días|strong="H3117"\w* de tu \w salida|strong="H3318"\w* de la tierra de \w Egipto|strong="H4714"\w*,  
\q2 yo les \w mostraré|strong="H7200"\w* \w maravillas|strong="H6381"\w*».   
\q1
\v 16 \w Las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w lo|strong="H5921"\w* \w verán|strong="H7200"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* avergonzarán \w de|strong="H5921"\w* \w todo|strong="H3605"\w* su poderío;  
\q2 \w se|strong="H5921"\w* \w pondrán|strong="H7760"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w*  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w les|strong="H5921"\w* \w ensordecerán|strong="H2790"\w* \w los|strong="H5921"\w* oídos.   
\q1
\v 17 \w Lamerán|strong="H3897"\w* el \w polvo|strong="H6083"\w* como la \w serpiente|strong="H5175"\w*;  
\q2 como los reptiles \w de|strong="H4480"\w* la \w tierra|strong="H6083"\w*, saldrán temblando \w de|strong="H4480"\w* sus agujeros.  
\q2 \w Se|strong="H4480"\w* volverán \w con|strong="H4480"\w* \w temor|strong="H3372"\w* \w a|strong="H3068"\w* Yahvé, nuestro \w Dios|strong="H3068"\w*,  
\q2 y tendrán \w miedo|strong="H3372"\w* ante \w ti|strong="H4480"\w*.   
\q1
\v 18 ¿\w Qué|strong="H3588"\w* Dios \w hay|strong="H4310"\w* \w como|strong="H3588"\w* tú, \w que|strong="H3588"\w* \w perdona|strong="H5375"\w* \w la|strong="H1931"\w* \w iniquidad|strong="H5771"\w*  
\q2 \w y|strong="H3588"\w* \w pasa|strong="H5674"\w* \w por|strong="H5921"\w* alto \w la|strong="H1931"\w* rebeldía \w del|strong="H5921"\w* remanente \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w heredad|strong="H5159"\w*?  
\q1 \w No|strong="H3808"\w* retiene \w para|strong="H5921"\w* \w siempre|strong="H5703"\w* \w su|strong="H1931"\w* enojo,  
\q2 \w porque|strong="H3588"\w* \w se|strong="H1931"\w* deleita \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w misericordia|strong="H2617"\w*.   
\q1
\v 19 \w Él|strong="H3605"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* tener compasión de \w nosotros|strong="H3605"\w*;  
\q2 sepultará nuestras \w iniquidades|strong="H5771"\w*.  
\q2 Tú arrojarás \w todos|strong="H3605"\w* nuestros \w pecados|strong="H2403"\w* \w a|strong="H3068"\w* \w lo|strong="H3605"\w* \w profundo|strong="H4688"\w* del \w mar|strong="H3220"\w*.   
\q1
\v 20 Mostrarás tu fidelidad \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*,  
\q2 y tu \w misericordia|strong="H2617"\w* \w a|strong="H3068"\w* Abraham,  
\q2 como \w juraste|strong="H7650"\w* \w a|strong="H3068"\w* nuestros padres desde los \w tiempos|strong="H3117"\w* \w de|strong="H5414"\w* antaño.   