\v 7 Sus hermanos por sus \w familias|strong="H4940"\w*, cuando se enumeró la genealogía de sus generaciones: el \w jefe|strong="H7218"\w*, \w Jeiel|strong="H3273"\w*, y \w Zacarías|strong="H2148"\w*,  
\v 8 \w y|strong="H5704"\w* \w Bela|strong="H1106"\w* \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Azaz, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Sema, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Joel|strong="H3100"\w*, \w que|strong="H1931"\w* \w habitaba|strong="H3427"\w* \w en|strong="H5704"\w* \w Aroer|strong="H6177"\w*, \w hasta|strong="H5704"\w* \w Nebo|strong="H5015"\w* \w y|strong="H5704"\w* Baal Meón;  
\v 9 \w y|strong="H3588"\w* \w habitaba|strong="H3427"\w* \w hacia|strong="H4480"\w* \w el|strong="H3588"\w* \w este|strong="H4217"\w* \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* entrada \w del|strong="H4480"\w* \w desierto|strong="H4057"\w* \w desde|strong="H4480"\w* \w el|strong="H3588"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*, \w porque|strong="H3588"\w* sus \w ganados|strong="H4735"\w* \w se|strong="H4480"\w* multiplicaban \w en|strong="H4480"\w* \w la|strong="H3588"\w* tierra \w de|strong="H4480"\w* \w Galaad|strong="H1568"\w*.   
\p
\v 10 \w En|strong="H5921"\w* \w los|strong="H3427"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w*, \w hicieron|strong="H6213"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* agarenos, \w que|strong="H5921"\w* \w cayeron|strong="H5307"\w* \w por|strong="H5921"\w* su \w mano|strong="H3027"\w*, \w y|strong="H5921"\w* \w habitaron|strong="H3427"\w* \w en|strong="H5921"\w* sus tiendas \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w al|strong="H5921"\w* \w este|strong="H4217"\w* \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*.   
