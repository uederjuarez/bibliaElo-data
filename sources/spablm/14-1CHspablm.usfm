\v 32 Jonatán, \w tío|strong="H1730"\w* \w de|strong="H5973"\w* \w David|strong="H1732"\w*, \w era|strong="H1931"\w* \w consejero|strong="H3289"\w*, \w hombre|strong="H1121"\w* \w de|strong="H5973"\w* gran entendimiento y \w escriba|strong="H5608"\w*. \w Jehiel|strong="H3171"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Hacmoni, instruía \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*.  
\v 33 Ahitófel era \w consejero|strong="H3289"\w* del \w rey|strong="H4428"\w*. \w Husai|strong="H2365"\w* el arquita era \w amigo|strong="H7453"\w* del \w rey|strong="H4428"\w*.  
\v 34 Después \w de|strong="H1121"\w* Ahitófel, fueron consejeros \w Joiada|strong="H3077"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Benaía|strong="H1141"\w*, y Abiatar. \w Joab|strong="H3097"\w* \w era|strong="H1121"\w* \w el|strong="H1121"\w* \w comandante|strong="H8269"\w* del \w ejército|strong="H6635"\w* del \w rey|strong="H4428"\w*.   
\c 28
\p
\v 1 \w David|strong="H1732"\w* reunió \w en|strong="H5973"\w* Jerusalén \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w principales|strong="H8269"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*: \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H5973"\w* las \w tribus|strong="H7626"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* comandantes \w de|strong="H5973"\w* las divisiones \w que|strong="H1121"\w* servían \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w capitanes|strong="H8269"\w* \w de|strong="H5973"\w* millares, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w capitanes|strong="H8269"\w* \w de|strong="H5973"\w* centenas, y \w a|strong="H3068"\w* \w los|strong="H1121"\w* administradores \w de|strong="H5973"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w hacienda|strong="H7399"\w* y posesiones \w del|strong="H5973"\w* \w rey|strong="H4428"\w* y \w de|strong="H5973"\w* sus \w hijos|strong="H1121"\w*, \w junto|strong="H5973"\w* \w con|strong="H5973"\w* \w los|strong="H1121"\w* oficiales \w del|strong="H5973"\w* palacio, \w los|strong="H1121"\w* héroes y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*.  
\v 2 Entonces \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w se|strong="H5921"\w* puso \w en|strong="H5921"\w* \w pie|strong="H7272"\w* \w y|strong="H5921"\w* dijo: “¡\w Oídme|strong="H8085"\w*, hermanos míos \w y|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w mío|strong="H5921"\w*! Yo tenía \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3824"\w* \w edificar|strong="H1129"\w* una \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w reposo|strong="H4496"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* arca \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w alianza|strong="H1285"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w como|strong="H5973"\w* \w estrado|strong="H1916"\w* \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w pies|strong="H7272"\w* \w de|strong="H5921"\w* nuestro \w Dios|strong="H3068"\w*; \w y|strong="H5921"\w* había hecho \w los|strong="H5921"\w* preparativos \w para|strong="H5921"\w* \w la|strong="H5921"\w* construcción.  
\v 3 \w Pero|strong="H3588"\w* Dios \w me|strong="H3588"\w* dijo: ‘\w No|strong="H3808"\w* \w edificarás|strong="H1129"\w* una \w casa|strong="H1004"\w* \w a|strong="H3068"\w* mi \w nombre|strong="H8034"\w*, \w porque|strong="H3588"\w* eres un hombre \w de|strong="H3588"\w* \w guerra|strong="H4421"\w* \w y|strong="H3588"\w* has \w derramado|strong="H8210"\w* mucha \w sangre|strong="H1818"\w*.’  
\v 4 Sin embargo, Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w me|strong="H5921"\w* eligió \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre \w para|strong="H5921"\w* ser \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w para|strong="H5921"\w* \w siempre|strong="H5769"\w*. \w Porque|strong="H3588"\w* \w él|strong="H5921"\w* ha elegido \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w como|strong="H3588"\w* líder; \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, eligió \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w familia|strong="H1004"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre; \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre, \w se|strong="H1961"\w* agradó \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w para|strong="H5921"\w* hacerme \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*.  
\v 5 \w Y|strong="H3068"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w mis|strong="H5414"\w* \w hijos|strong="H1121"\w* (\w pues|strong="H3588"\w* Yahvé \w me|strong="H5921"\w* ha \w dado|strong="H5414"\w* \w muchos|strong="H7227"\w*), ha elegido \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* siente \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w del|strong="H5921"\w* \w reino|strong="H4438"\w* \w de|strong="H5921"\w* Yahvé \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 6 \w Me|strong="H3588"\w* dijo: ‘Tu \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w es|strong="H1931"\w* \w quien|strong="H1931"\w* \w edificará|strong="H1129"\w* \w mi|strong="H1961"\w* \w casa|strong="H1004"\w* \w y|strong="H3588"\w* mis \w atrios|strong="H2691"\w*; \w porque|strong="H3588"\w* \w lo|strong="H1931"\w* he escogido \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w sea|strong="H1961"\w* \w mi|strong="H1961"\w* \w hijo|strong="H1121"\w*, \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w seré|strong="H1961"\w* \w su|strong="H1931"\w* padre.  
\v 7 Estableceré su \w reino|strong="H4438"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*, si \w él|strong="H6213"\w* se mantiene \w firme|strong="H3559"\w* \w en|strong="H5704"\w* cumplir mis \w mandamientos|strong="H4687"\w* \w y|strong="H5704"\w* mis \w ordenanzas|strong="H4941"\w*, \w como|strong="H5704"\w* \w lo|strong="H2088"\w* \w hace|strong="H6213"\w* \w hoy|strong="H3117"\w*.’   
\p
\v 8 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w a|strong="H3068"\w* \w la|strong="H8104"\w* vista \w de|strong="H5704"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w la|strong="H8104"\w* asamblea \w de|strong="H5704"\w* Yahvé, \w y|strong="H5704"\w* \w a|strong="H3068"\w* oídos \w de|strong="H5704"\w* nuestro \w Dios|strong="H3068"\w*: observad \w y|strong="H5704"\w* \w buscad|strong="H1875"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w mandamientos|strong="H4687"\w* \w de|strong="H5704"\w* Yahvé vuestro \w Dios|strong="H3068"\w*, \w para|strong="H5704"\w* \w que|strong="H6258"\w* poseáis esta \w buena|strong="H2896"\w* tierra \w y|strong="H5704"\w* \w la|strong="H8104"\w* dejéis \w en|strong="H5704"\w* herencia \w a|strong="H3068"\w* vuestros \w hijos|strong="H1121"\w* \w después|strong="H5704"\w* \w de|strong="H5704"\w* vosotros, \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.   
\p
\v 9 \w Y|strong="H3068"\w* tú, \w Salomón|strong="H8010"\w*, \w hijo|strong="H1121"\w* mío, \w reconoce|strong="H3045"\w* al \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* tu padre, \w y|strong="H3588"\w* sírvele \w con|strong="H3588"\w* un \w corazón|strong="H3820"\w* \w perfecto|strong="H8003"\w* \w y|strong="H3588"\w* un \w ánimo|strong="H5315"\w* dispuesto; \w porque|strong="H3588"\w* Yahvé \w escudriña|strong="H1875"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w corazones|strong="H3824"\w*, \w y|strong="H3588"\w* \w entiende|strong="H3045"\w* \w toda|strong="H3605"\w* intención \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w pensamientos|strong="H4284"\w*. \w Si|strong="H3588"\w* \w lo|strong="H3605"\w* buscas, \w lo|strong="H3605"\w* \w hallarás|strong="H4672"\w*; \w pero|strong="H3588"\w* \w si|strong="H3588"\w* \w lo|strong="H3605"\w* abandonas, \w él|strong="H3588"\w* \w te|strong="H3588"\w* \w desechará|strong="H2186"\w* \w para|strong="H3588"\w* \w siempre|strong="H3605"\w*.  
\v 10 Presta atención \w ahora|strong="H6258"\w*, \w porque|strong="H3588"\w* Yahvé \w te|strong="H3588"\w* ha elegido \w para|strong="H3588"\w* \w edificar|strong="H1129"\w* una \w casa|strong="H1004"\w* \w como|strong="H3588"\w* \w santuario|strong="H4720"\w*. \w Esfuérzate|strong="H2388"\w* \w y|strong="H3588"\w* hazla.”   
\p
\v 11 Entonces \w David|strong="H1732"\w* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w los|strong="H1121"\w* planos del pórtico del \w templo|strong="H1004"\w*, \w de|strong="H1121"\w* sus edificios, \w de|strong="H1121"\w* sus tesorerías, \w de|strong="H1121"\w* sus aposentos altos, \w de|strong="H1121"\w* sus cámaras \w interiores|strong="H6442"\w* y del lugar del propiciatorio;  
\v 12 y \w los|strong="H3605"\w* planos \w de|strong="H5973"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1961"\w* \w el|strong="H5973"\w* \w Espíritu|strong="H7307"\w* \w le|strong="H5973"\w* \w había|strong="H1961"\w* revelado \w para|strong="H1961"\w* \w los|strong="H3605"\w* \w atrios|strong="H2691"\w* \w de|strong="H5973"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Yahvé, \w para|strong="H1961"\w* \w todas|strong="H3605"\w* las \w cámaras|strong="H3957"\w* \w alrededor|strong="H5439"\w*, \w para|strong="H1961"\w* \w los|strong="H3605"\w* tesoros \w de|strong="H5973"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Dios|strong="H3068"\w* y \w para|strong="H1961"\w* \w los|strong="H3605"\w* tesoros \w de|strong="H5973"\w* las cosas \w sagradas|strong="H6944"\w*;  
\v 13 también para las divisiones de \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y de \w los|strong="H3605"\w* \w levitas|strong="H3881"\w*, para \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* del servicio de \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de Yahvé, y para \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios del servicio de \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de Yahvé:  
\v 14 \w el|strong="H3605"\w* \w peso|strong="H4948"\w* del \w oro|strong="H2091"\w* \w para|strong="H4948"\w* \w los|strong="H3605"\w* utensilios de \w oro|strong="H2091"\w* de \w toda|strong="H3605"\w* clase de servicio, y \w el|strong="H3605"\w* \w peso|strong="H4948"\w* de \w la|strong="H3605"\w* \w plata|strong="H3701"\w* \w para|strong="H4948"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios de \w plata|strong="H3701"\w* de \w toda|strong="H3605"\w* clase de servicio;  
\v 15 el \w peso|strong="H4948"\w* \w para|strong="H4948"\w* los candelabros de \w oro|strong="H2091"\w* y sus \w lámparas|strong="H5216"\w* de \w oro|strong="H2091"\w*, especificando el \w peso|strong="H4948"\w* de cada candelabro y de sus \w lámparas|strong="H5216"\w*; y \w para|strong="H4948"\w* los candelabros de \w plata|strong="H3701"\w*, el \w peso|strong="H4948"\w* \w para|strong="H4948"\w* cada candelabro y sus \w lámparas|strong="H5216"\w*, según el uso de cada candelabro;  
\v 16 el \w oro|strong="H2091"\w* por \w peso|strong="H4948"\w* \w para|strong="H4948"\w* las \w mesas|strong="H7979"\w* de los panes de la proposición, \w para|strong="H4948"\w* cada \w mesa|strong="H7979"\w*; y la \w plata|strong="H3701"\w* \w para|strong="H4948"\w* las \w mesas|strong="H7979"\w* de \w plata|strong="H3701"\w*;  
\v 17 y los tenedores, los \w tazones|strong="H4219"\w* y las copas de \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*; y \w para|strong="H4948"\w* los \w tazones|strong="H4219"\w* de \w oro|strong="H2091"\w*, el \w peso|strong="H4948"\w* de cada tazón; y \w para|strong="H4948"\w* los \w tazones|strong="H4219"\w* de \w plata|strong="H3701"\w*, el \w peso|strong="H4948"\w* de cada tazón;  
\v 18 \w y|strong="H5921"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w del|strong="H5921"\w* incienso, \w oro|strong="H2091"\w* refinado \w por|strong="H5921"\w* \w peso|strong="H4948"\w*; \w y|strong="H5921"\w* \w el|strong="H5921"\w* modelo \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w carro|strong="H4818"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w que|strong="H5921"\w* extienden sus alas \w y|strong="H5921"\w* cubren \w el|strong="H5921"\w* arca \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w alianza|strong="H1285"\w* \w de|strong="H5921"\w* Yahvé.  
\v 19 «\w Todo|strong="H3605"\w* esto», dijo David, «Yahvé \w me|strong="H5921"\w* \w lo|strong="H5921"\w* ha hecho \w entender|strong="H7919"\w* \w por|strong="H5921"\w* escrito \w de|strong="H5921"\w* su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*, dándome \w a|strong="H3068"\w* conocer \w todos|strong="H3605"\w* \w los|strong="H5921"\w* detalles \w de|strong="H5921"\w* este diseño.»   
\p
\v 20 \w David|strong="H1732"\w* \w le|strong="H5973"\w* dijo también \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w*: «\w Esfuérzate|strong="H2388"\w* \w y|strong="H3588"\w* \w sé|strong="H3808"\w* valiente, \w y|strong="H3588"\w* pon manos \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w obra|strong="H4399"\w*. \w No|strong="H3808"\w* \w temas|strong="H3372"\w* \w ni|strong="H3808"\w* \w te|strong="H3588"\w* desanimes, \w porque|strong="H3588"\w* Yahvé \w Dios|strong="H3068"\w*, mi \w Dios|strong="H3068"\w*, \w estará|strong="H3605"\w* \w contigo|strong="H5973"\w*. \w Él|strong="H5973"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* fallará \w ni|strong="H3808"\w* \w te|strong="H3588"\w* abandonará, \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* hayas terminado \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w obra|strong="H4399"\w* \w para|strong="H5704"\w* \w el|strong="H5973"\w* servicio \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé.  
\v 21 He \w aquí|strong="H2009"\w*, tienes las divisiones \w de|strong="H5973"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w de|strong="H5973"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* \w para|strong="H5973"\w* \w todo|strong="H3605"\w* \w el|strong="H5973"\w* servicio \w de|strong="H5973"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Dios. \w Todo|strong="H3605"\w* \w voluntario|strong="H5081"\w* experto \w en|strong="H5973"\w* \w cualquier|strong="H3605"\w* \w oficio|strong="H4399"\w* \w estará|strong="H3605"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w* \w en|strong="H5973"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w*. También \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* y \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w* estarán enteramente \w a|strong="H3068"\w* tus órdenes.»   
\c 29
\p
\v 1 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* asamblea: «Mi \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w*, \w el|strong="H3588"\w* único \w a|strong="H3068"\w* \w quien|strong="H3605"\w* \w Dios|strong="H3068"\w* \w ha|strong="H3808"\w* elegido, \w es|strong="H3588"\w* todavía joven \w e|strong="H3068"\w* inexperto, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w obra|strong="H4399"\w* \w es|strong="H3588"\w* muy \w grande|strong="H1419"\w*; \w porque|strong="H3588"\w* este palacio \w no|strong="H3808"\w* \w es|strong="H3588"\w* \w para|strong="H3588"\w* \w hombres|strong="H1121"\w*, \w sino|strong="H3588"\w* \w para|strong="H3588"\w* Yahvé \w Dios|strong="H3068"\w*.  
\v 2 Yo he preparado con \w todas|strong="H3605"\w* mis \w fuerzas|strong="H3581"\w* para \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de mi Dios \w el|strong="H3605"\w* \w oro|strong="H2091"\w* para las cosas de \w oro|strong="H2091"\w*, \w la|strong="H3605"\w* \w plata|strong="H3701"\w* para las cosas de \w plata|strong="H3701"\w*, \w el|strong="H3605"\w* bronce para las cosas de bronce, \w el|strong="H3605"\w* \w hierro|strong="H1270"\w* para las cosas de \w hierro|strong="H1270"\w*, y \w la|strong="H3605"\w* \w madera|strong="H6086"\w* para las cosas de \w madera|strong="H6086"\w*; además de piedras de ónice, piedras de engaste, piedras de antimonio y de diversos colores, \w toda|strong="H3605"\w* clase de piedras \w preciosas|strong="H3368"\w*, y mármol en \w abundancia|strong="H7230"\w*.  
