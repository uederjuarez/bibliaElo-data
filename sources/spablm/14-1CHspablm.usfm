\v 9 la quinta en Malquías, la sexta en Mijamín,  
\v 10 la séptima en \w Cos|strong="H6976"\w*, la octava en Abías,  
\v 11 la novena en \w Jesúa|strong="H3442"\w*, la décima en Secanías,  
\v 12 la undécima en Eliasib, la duodécima en Jaquim,  
\v 13 la decimotercera en Hupa, la decimocuarta en Jesebeab,  
\v 14 la decimoquinta en \w Bilga|strong="H1083"\w*, la decimosexta en Imer,  
\v 15 la decimoséptima en \w Hezir|strong="H2387"\w*, la decimoctava en Afses,  
\v 16 la decimonovena en Petaías, la vigésima en Hezequiel,  
\v 17 la vigesimoprimera en Jaquín, la vigesimosegunda en Gamul,  
\v 18 la vigesimotercera en Delaías, y la vigesimocuarta en \w Maazías|strong="H4590"\w*.  
\v 19 Este fue el \w orden|strong="H6680"\w* de su servicio para entrar en la \w casa|strong="H1004"\w* de Yahvé, según la norma \w que|strong="H3027"\w* \w les|strong="H6680"\w* dio su antepasado Aarón, tal como Yahvé, el \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*, se lo había \w mandado|strong="H6680"\w*.   
\p
\v 20 \w De|strong="H1121"\w* \w los|strong="H1121"\w* demás \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w*: \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Amram|strong="H6019"\w*, \w Subael|strong="H7619"\w*; \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Subael|strong="H7619"\w*, Jehdeías.  
\v 21 \w De|strong="H1121"\w* Rehabías: \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Rehabías, \w el|strong="H1121"\w* \w jefe|strong="H7218"\w* fue \w Isías|strong="H3449"\w*.  
\v 22 \w De|strong="H1121"\w* \w los|strong="H1121"\w* izharitas, Selomot; \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Selomot, Jahat.  
\v 23 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hebrón: \w Jerías|strong="H3404"\w* \w el|strong="H1121"\w* jefe, Amarías \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*, \w Jahaziel|strong="H3166"\w* \w el|strong="H1121"\w* \w tercero|strong="H7992"\w* y \w Jecamán|strong="H3360"\w* \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w*.  
\v 24 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uziel: Miqueas; \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Miqueas, \w Samir|strong="H8053"\w*.  
\v 25 \w El|strong="H1121"\w* hermano \w de|strong="H1121"\w* Miqueas: \w Isías|strong="H3449"\w*; \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Isías|strong="H3449"\w*, \w Zacarías|strong="H2148"\w*.  
\v 26 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w*: Mahli y Musi. \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jaazías: Beno.  
\v 27 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w* por parte \w de|strong="H1121"\w* Jaazías: Beno, Soham, Zacur \w e|strong="H3068"\w* Ibri.  
\v 28 \w De|strong="H1121"\w* Mahli: Eleazar, \w el|strong="H1121"\w* cual \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w*.  
\v 29 \w De|strong="H1121"\w* \w Cis|strong="H7027"\w*: \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Cis|strong="H7027"\w*, \w Jerameel|strong="H3396"\w*.  
\v 30 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Musi: Mahli, \w Eder|strong="H5740"\w* y Jerimot. Estos fueron \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* según sus \w casas|strong="H1004"\w* paternas.  
\v 31 \w Ellos|strong="H1992"\w* \w también|strong="H1571"\w* \w echaron|strong="H5307"\w* \w suertes|strong="H1486"\w*, \w al|strong="H4428"\w* igual \w que|strong="H1571"\w* \w sus|strong="H1992"\w* hermanos \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* Aarón, en \w presencia|strong="H6440"\w* del \w rey|strong="H4428"\w* \w David|strong="H1732"\w*, \w de|strong="H6440"\w* \w Sadoc|strong="H6659"\w*, \w de|strong="H6440"\w* Ahimelec \w y|strong="H1571"\w* \w de|strong="H6440"\w* \w los|strong="H1992"\w* \w jefes|strong="H7218"\w* \w de|strong="H6440"\w* \w las|strong="H1992"\w* casas paternas \w de|strong="H6440"\w* \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H1571"\w* \w de|strong="H6440"\w* \w los|strong="H1992"\w* \w levitas|strong="H3881"\w*. \w Las|strong="H1992"\w* casas \w de|strong="H6440"\w* \w los|strong="H1992"\w* hermanos mayores \w fueron|strong="H1732"\w* tratadas \w de|strong="H6440"\w* \w la|strong="H1571"\w* misma manera \w que|strong="H1571"\w* \w las|strong="H1992"\w* \w de|strong="H6440"\w* \w sus|strong="H1992"\w* hermanos \w menores|strong="H6996"\w*.   
\c 25
\p
\v 1 Además, \w David|strong="H1732"\w* y \w los|strong="H1121"\w* \w capitanes|strong="H8269"\w* del \w ejército|strong="H6635"\w* apartaron \w para|strong="H1961"\w* \w el|strong="H1121"\w* servicio \w a|strong="H3068"\w* algunos \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Asaf, \w de|strong="H1121"\w* \w Hemán|strong="H1968"\w* y \w de|strong="H1121"\w* Jedutún, \w que|strong="H1121"\w* debían profetizar con \w arpas|strong="H3658"\w*, con liras y con \w címbalos|strong="H4700"\w*. \w El|strong="H1121"\w* \w número|strong="H4557"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* hicieron la \w obra|strong="H4399"\w* según su servicio \w fue|strong="H1961"\w*:  
\v 2 \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Asaf: Zacur, \w José|strong="H3130"\w*, Netanías \w y|strong="H5921"\w* Asarela. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Asaf estaban bajo \w la|strong="H5921"\w* dirección \w de|strong="H5921"\w* Asaf, quien profetizaba \w por|strong="H5921"\w* orden \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.  
\v 3 \w De|strong="H5921"\w* Jedutún, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Jedutún: \w Gedalías|strong="H1436"\w*, Zeri, \w Jesaías|strong="H3470"\w*, Simei, \w Hasabías|strong="H2811"\w* \w y|strong="H5921"\w* Matatías, \w seis|strong="H8337"\w*, bajo \w la|strong="H5921"\w* dirección \w de|strong="H5921"\w* su padre Jedutún, \w que|strong="H5921"\w* \w profetizaban|strong="H5012"\w* dando gracias \w y|strong="H5921"\w* \w alabando|strong="H1984"\w* \w a|strong="H3068"\w* Yahvé \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w arpa|strong="H3658"\w*.  
\v 4 \w De|strong="H1121"\w* \w Hemán|strong="H1968"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hemán|strong="H1968"\w*: Buquías, Matanías, Uziel, \w Sebuel|strong="H7619"\w*, Jerimot, \w Hananías|strong="H2608"\w*, \w Hanani|strong="H2607"\w*, Eliata, Gidalti, \w Romamti-Ezer|strong="H7320"\w*, \w Josbecasa|strong="H3436"\w*, Maloti, Hotir y Mahaziot.  
\v 5 \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hemán|strong="H1968"\w*, \w el|strong="H3605"\w* \w vidente|strong="H2374"\w* del \w rey|strong="H4428"\w*, en las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* Dios, \w para|strong="H5414"\w* exaltar su poder. Dios le \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Hemán|strong="H1968"\w* catorce \w hijos|strong="H1121"\w* y \w tres|strong="H7969"\w* \w hijas|strong="H1323"\w*.  
