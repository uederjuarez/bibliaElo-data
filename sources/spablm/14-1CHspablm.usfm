\h 1 CRÓNICAS 
\toc3 1 Crónicas 
\toc1 PRIMER LIBRO DE LAS CRÓNICAS 
\toc2 1 CRÓNICAS 
\mt2 Primer libro de las  
\mt1 Crónicas  
\c 1
\p
\v 1 Adán, Set, Enós,  
\v 2 \w Cainán|strong="H7018"\w*, \w Mahalaleel|strong="H4111"\w*, \w Jared|strong="H3382"\w*,  
\v 3 Enoc, Matusalén, Lamec,  
\v 4 \w Noé|strong="H5146"\w*, \w Sem|strong="H8035"\w*, Cam y Jafet.   
\p
\v 5 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jafet: \w Gomer|strong="H1586"\w*, \w Magog|strong="H4031"\w*, Madai, \w Javán|strong="H3120"\w*, \w Tubal|strong="H8422"\w*, \w Mesec|strong="H4902"\w* y Tiras.  
\v 6 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gomer|strong="H1586"\w*: Asquenaz, Rifat y Togarma.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Javán|strong="H3120"\w*: Elisá, \w Tarsis|strong="H8659"\w*, Quitim y Rodanim.   
\p
\v 8 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cam: Cus, Mizraim, Fut y \w Canaán|strong="H3667"\w*.  
\v 9 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cus: \w Seba|strong="H7614"\w*, \w Havila|strong="H2341"\w*, Sabta, Raama y Sabteca. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Raama: Sabá y \w Dedán|strong="H1719"\w*.  
\v 10 Cus \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Nimrod, \w quien|strong="H1931"\w* llegó \w a|strong="H3068"\w* ser \w el|strong="H1931"\w* primer \w hombre|strong="H1368"\w* \w poderoso|strong="H1368"\w* en \w la|strong="H1931"\w* tierra.  
\v 11 Mizraim \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* los luditas, los anamitas, los lehabitas, los naftuhitas,  
\v 12 los patrusitas, los casluhitas (de \w donde|strong="H8033"\w* proceden los \w filisteos|strong="H6430"\w*) y los caftoritas.  
\v 13 \w Canaán|strong="H3667"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sidón|strong="H6721"\w*, su \w primogénito|strong="H1060"\w*, \w a|strong="H3068"\w* Het,  
\v 14 al \w jebuseo|strong="H2983"\w*, al amorreo, al gergeseo,  
\v 15 al \w heveo|strong="H2340"\w*, al arquita, al sinita,  
\v 16 al arvadita, al zemarita y al hamateo.   
\p
\v 17 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sem|strong="H8035"\w*: \w Elam|strong="H5867"\w*, Asur, Arfaxad, \w Lud|strong="H3865"\w*, Aram, \w Uz|strong="H5780"\w*, \w Hul|strong="H2343"\w*, Geter y \w Mesec|strong="H4902"\w*.  
\v 18 Arfaxad \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sala|strong="H7974"\w*, y \w Sala|strong="H7974"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w*.  
\v 19 \w A|strong="H3068"\w* \w Heber|strong="H5677"\w* le \w nacieron|strong="H3205"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*: \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* del uno fue \w Peleg|strong="H6389"\w*, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* sus \w días|strong="H3117"\w* \w la|strong="H3588"\w* tierra fue dividida; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermano fue \w Joctán|strong="H3355"\w*.  
\v 20 \w Joctán|strong="H3355"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Almodad, Selef, Hazar-mavet, Jera,  
\v 21 Hadoram, Uzal, \w Dicla|strong="H1853"\w*,  
\v 22 \w Ebal|strong="H5858"\w*, Abimael, Sabá,  
\v 23 Ofir, \w Havila|strong="H2341"\w* y \w Jobab|strong="H3103"\w*. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Joctán|strong="H3355"\w*.  
\v 24 \w Sem|strong="H8035"\w*, Arfaxad, \w Sala|strong="H7974"\w*,  
\v 25 \w Heber|strong="H5677"\w*, \w Peleg|strong="H6389"\w*, \w Reu|strong="H7466"\w*,  
\v 26 \w Serug|strong="H8286"\w*, Nacor, Taré,  
\v 27 Abram (\w es|strong="H1931"\w* decir, Abraham).   
\p
\v 28 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Abraham: \w Isaac|strong="H3327"\w* \w e|strong="H3068"\w* \w Ismael|strong="H3458"\w*.  
\v 29 Estas son sus generaciones: el \w primogénito|strong="H1060"\w* de \w Ismael|strong="H3458"\w*, Nebaiot; luego \w Cedar|strong="H6938"\w*, Adbeel, \w Mibsam|strong="H4017"\w*,  
\v 30 \w Misma|strong="H4927"\w*, \w Duma|strong="H1746"\w*, Massa, \w Hadad|strong="H2301"\w*, Tema,  
\v 31 \w Jetur|strong="H3195"\w*, Nafis y Cedema. \w Estos|strong="H1992"\w* son \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w*.   
\p
\v 32 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cetura, \w concubina|strong="H6370"\w* \w de|strong="H1121"\w* Abraham: dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Zimrán, \w Jocsán|strong="H3370"\w*, \w Medán|strong="H4091"\w*, \w Madián|strong="H4080"\w*, \w Isbac|strong="H3435"\w* y Súa. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jocsán|strong="H3370"\w*: Sabá y \w Dedán|strong="H1719"\w*.  
\v 33 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Madián|strong="H4080"\w*: Efa, Efer, Hanoc, Abida y Eldaá. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cetura.   
\p
\v 34 Abraham \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Isaac|strong="H3327"\w*: \w Esaú|strong="H6215"\w* \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*.  
\v 35 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: Elifaz, \w Reuel|strong="H7467"\w*, \w Jeús|strong="H3266"\w*, \w Jalam|strong="H3281"\w* y \w Coré|strong="H7141"\w*.  
\v 36 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elifaz: \w Temán|strong="H8487"\w*, Omar, Zefo, \w Gatam|strong="H1609"\w*, Cenaz, \w Timna|strong="H8555"\w* y \w Amalec|strong="H6002"\w*.  
\v 37 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w*: Nahat, \w Zera|strong="H2226"\w*, Sama y Miza.   
\p
\v 38 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Seir|strong="H8165"\w*: \w Lotán|strong="H3877"\w*, \w Sobal|strong="H7732"\w*, \w Zibeón|strong="H6649"\w*, \w Aná|strong="H6034"\w*, \w Disón|strong="H1789"\w*, Ezer y Disán.  
\v 39 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Lotán|strong="H3877"\w*: \w Hori|strong="H2753"\w* y Homam; y \w Timna|strong="H8555"\w* \w era|strong="H1121"\w* hermana \w de|strong="H1121"\w* \w Lotán|strong="H3877"\w*.  
\v 40 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sobal|strong="H7732"\w*: \w Alian|strong="H5935"\w*, Manahat, \w Ebal|strong="H5858"\w*, Sefi y Onam. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zibeón|strong="H6649"\w*: Aja y \w Aná|strong="H6034"\w*.  
\v 41 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Aná|strong="H6034"\w*: \w Disón|strong="H1787"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Disón|strong="H1787"\w*: \w Hamrán|strong="H2566"\w*, Esbán, Itrán y Querán.  
\v 42 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ezer: \w Bilhán|strong="H1092"\w*, \w Zaaván|strong="H2190"\w* y Jaacán. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Disán: \w Uz|strong="H5780"\w* y Arán.   
\p
\v 43 Estos son \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w que|strong="H1121"\w* \w reinaron|strong="H4428"\w* en la tierra \w de|strong="H6440"\w* Edom, \w antes|strong="H6440"\w* \w de|strong="H6440"\w* \w que|strong="H1121"\w* \w reinase|strong="H4427"\w* \w rey|strong="H4428"\w* alguno sobre \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*: \w Bela|strong="H1106"\w* \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Beor, y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H6440"\w* su \w ciudad|strong="H5892"\w* fue Dinhaba.  
\v 44 \w Murió|strong="H4191"\w* \w Bela|strong="H1106"\w*, y \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w reinó|strong="H4427"\w* \w Jobab|strong="H3103"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* \w Zera|strong="H2226"\w*, \w de|strong="H8478"\w* \w Bosra|strong="H1224"\w*.  
\v 45 \w Murió|strong="H4191"\w* \w Jobab|strong="H3103"\w*, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Husam|strong="H2367"\w*, \w de|strong="H8478"\w* la tierra \w de|strong="H8478"\w* los temanitas.  
\v 46 \w Murió|strong="H4191"\w* \w Husam|strong="H2367"\w*, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* Hadad, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Bedad, \w que|strong="H1121"\w* derrotó \w a|strong="H3068"\w* \w Madián|strong="H4080"\w* \w en|strong="H8478"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w* \w de|strong="H8478"\w* \w Moab|strong="H4124"\w*, y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su \w ciudad|strong="H5892"\w* fue Avit.  
\v 47 \w Murió|strong="H4191"\w* Hadad, y \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w reinó|strong="H4427"\w* Samá \w de|strong="H8478"\w* Masreca.  
\v 48 \w Murió|strong="H4191"\w* Samá, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Saúl|strong="H7586"\w*, \w de|strong="H8478"\w* Rehobot, junto \w al|strong="H8478"\w* \w río|strong="H5104"\w*.  
\v 49 \w Murió|strong="H4191"\w* \w Saúl|strong="H7586"\w*, y \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w reinó|strong="H4427"\w* Baal Hanán, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Acbor.  
\v 50 \w Murió|strong="H4191"\w* Baal Hanán, y \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w reinó|strong="H4427"\w* Hadad; el \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su \w ciudad|strong="H5892"\w* fue Pai. Su mujer se \w llamaba|strong="H8034"\w* Mehetabel, \w hija|strong="H1323"\w* \w de|strong="H8478"\w* Matred, \w hija|strong="H1323"\w* \w de|strong="H8478"\w* Mezahab.  
\v 51 Luego \w murió|strong="H4191"\w* Hadad. \w Los|strong="H1961"\w* jefes de Edom \w fueron|strong="H1961"\w*: el jefe \w Timna|strong="H8555"\w*, el jefe Aliah, el jefe Jetet,  
\v 52 el jefe Aholibama, el jefe Ela, el jefe Pinón,  
\v 53 el jefe Cenaz, el jefe \w Temán|strong="H8487"\w*, el jefe Mibzar,  
\v 54 el jefe \w Magdiel|strong="H4025"\w* y el jefe Iram. Estos son los jefes de Edom.   
\c 2
\p
\v 1 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: \w Rubén|strong="H7205"\w*, \w Simeón|strong="H8095"\w*, \w Leví|strong="H3878"\w*, \w Judá|strong="H3063"\w*, Isacar, \w Zabulón|strong="H2074"\w*,  
\v 2 \w Dan|strong="H1835"\w*, \w José|strong="H3130"\w*, \w Benjamín|strong="H1144"\w*, Neftalí, \w Gad|strong="H1410"\w* y Aser.   
\p
\v 3 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*: \w Er|strong="H6147"\w*, Onán y \w Sela|strong="H7956"\w*, \w los|strong="H1121"\w* \w tres|strong="H7969"\w* \w que|strong="H1121"\w* \w le|strong="H5869"\w* \w nacieron|strong="H3205"\w* \w de|strong="H1121"\w* la \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Súa, la \w cananea|strong="H3669"\w*. \w Er|strong="H6147"\w*, \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w fue|strong="H1961"\w* \w malo|strong="H7451"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H1121"\w* Yahvé\f + \fr 2:3 \ft «Yahvé» es el nombre propio de Dios, a veces traducido como «SEÑOR» (en mayúsculas) en otras traducciones.\f*, y \w este|strong="H1961"\w* \w le|strong="H5869"\w* \w quitó|strong="H4191"\w* la vida.  
\v 4 Tamar, su \w nuera|strong="H3618"\w*, le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Fares y \w a|strong="H3068"\w* \w Zera|strong="H2226"\w*. \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Judá|strong="H3063"\w* fueron \w cinco|strong="H2568"\w*.   
\p
\v 5 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Fares: Esrom y Hamul.  
\v 6 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Zera|strong="H2226"\w*: \w Zimri|strong="H2174"\w*, Etán, \w Hemán|strong="H1968"\w*, Calcol y Dara: \w cinco|strong="H2568"\w* en total.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Carmi|strong="H3756"\w*: Acar, \w el|strong="H1121"\w* perturbador \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w que|strong="H1121"\w* \w prevaricó|strong="H4603"\w* en \w el|strong="H1121"\w* \w anatema|strong="H2764"\w*.  
\v 8 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Etán: \w Azarías|strong="H5838"\w*.   
\p
\v 9 También \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Esrom, \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w*: \w Jerameel|strong="H3396"\w*, \w Ram|strong="H7410"\w* y Quelubai.  
\v 10 \w Ram|strong="H7410"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Aminadab|strong="H5992"\w*, y \w Aminadab|strong="H5992"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Naasón|strong="H5177"\w*, \w príncipe|strong="H5387"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*;  
\v 11 y \w Naasón|strong="H5177"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Salma|strong="H8007"\w*, y \w Salma|strong="H8007"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Booz|strong="H1162"\w*,  
\v 12 y \w Booz|strong="H1162"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Obed|strong="H5744"\w*, y \w Obed|strong="H5744"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jesé,  
\v 13 y Jesé \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* su \w primogénito|strong="H1060"\w* Eliab, Abinadab el \w segundo|strong="H8145"\w*, Simea el \w tercero|strong="H7992"\w*,  
\v 14 Natanael el \w cuarto|strong="H7243"\w*, \w Radai|strong="H7288"\w* el \w quinto|strong="H2549"\w*,  
\v 15 Ozem el \w sexto|strong="H8345"\w* y \w David|strong="H1732"\w* el \w séptimo|strong="H7637"\w*;  
\v 16 y sus hermanas fueron Sarvia y Abigail. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia: \w Abisai|strong="H7969"\w*, \w Joab|strong="H3097"\w* y \w Asael|strong="H6214"\w*, \w tres|strong="H7969"\w*.  
\v 17 Abigail dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Amasa|strong="H6021"\w*, y el padre de \w Amasa|strong="H6021"\w* fue \w Jeter|strong="H3500"\w*, el \w ismaelita|strong="H3459"\w*.   
\p
\v 18 \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Esrom, tuvo \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Azuba|strong="H5806"\w*, su mujer, y \w de|strong="H1121"\w* Jeriot; y estos fueron sus \w hijos|strong="H1121"\w*: Jeser, \w Sobab|strong="H7727"\w* y Ardón.  
\v 19 \w Murió|strong="H4191"\w* \w Azuba|strong="H5806"\w*, y \w Caleb|strong="H3612"\w* \w tomó|strong="H3947"\w* por mujer \w a|strong="H3068"\w* Efrata, que le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Hur|strong="H2354"\w*.  
\v 20 \w Hur|strong="H2354"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Uri, y Uri \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Bezalel.   
\p
\v 21 Después, Esrom \w se|strong="H1931"\w* unió \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Maquir, padre \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w que|strong="H1931"\w* \w tomó|strong="H3947"\w* por mujer cuando \w tenía|strong="H1931"\w* \w sesenta|strong="H8346"\w* \w años|strong="H8141"\w*, y \w ella|strong="H1931"\w* \w le|strong="H1931"\w* dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Segub.  
\v 22 Segub \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Jair|strong="H2971"\w*, quien \w tuvo|strong="H1961"\w* \w veintitrés|strong="H6242"\w* \w ciudades|strong="H5892"\w* en la tierra de \w Galaad|strong="H1568"\w*.  
\v 23 Gesur y Aram les arrebataron las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* \w Jair|strong="H2971"\w*, con Kenat y sus \w aldeas|strong="H1323"\w*, hasta \w sesenta|strong="H8346"\w* \w ciudades|strong="H5892"\w*. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Maquir, padre \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*.  
\v 24 Después de la \w muerte|strong="H4194"\w* de Esrom en Caleb Efrata, Abías, mujer de Esrom, le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Asur, padre de Tecoa.   
\p
\v 25 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jerameel|strong="H3396"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* Esrom, \w fueron|strong="H1961"\w* \w Ram|strong="H7410"\w* \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, Buna, Orén, Ozem y Ahías.  
\v 26 \w Jerameel|strong="H3396"\w* \w tuvo|strong="H1961"\w* otra mujer \w que|strong="H1931"\w* \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* \w Atará|strong="H5851"\w*. \w Ella|strong="H1931"\w* \w fue|strong="H1961"\w* \w la|strong="H1931"\w* madre de Onam.  
\v 27 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ram|strong="H7410"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Jerameel|strong="H3396"\w*, \w fueron|strong="H1961"\w* Maaz, \w Jamín|strong="H3226"\w* y Eker.  
\v 28 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Onam \w fueron|strong="H1961"\w* Samai y Jada. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Samai: \w Nadab|strong="H5070"\w* y Abisur.  
\v 29 La mujer de Abisur se \w llamaba|strong="H8034"\w* Abihail, y dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Ahbán y \w a|strong="H3068"\w* Molid.  
\v 30 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Nadab|strong="H5070"\w*: \w Seled|strong="H5540"\w* y Apaim; pero \w Seled|strong="H5540"\w* \w murió|strong="H4191"\w* \w sin|strong="H3808"\w* \w hijos|strong="H1121"\w*.  
\v 31 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Apaim: \w Isi|strong="H3469"\w*. \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Isi|strong="H3469"\w*: \w Sesán|strong="H8348"\w*. \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Sesán|strong="H8348"\w*: Ahlai.  
\v 32 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jada, hermano \w de|strong="H1121"\w* Samai: \w Jeter|strong="H3500"\w* y Jonatán; pero \w Jeter|strong="H3500"\w* \w murió|strong="H4191"\w* \w sin|strong="H3808"\w* \w hijos|strong="H1121"\w*.  
\v 33 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jonatán: Pelet y Zaza. Estos \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jerameel|strong="H3396"\w*.  
\v 34 \w Sesán|strong="H8348"\w* \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w* \w varones|strong="H3588"\w*, \w sino|strong="H3588"\w* solo \w hijas|strong="H1323"\w*. \w Sesán|strong="H8348"\w* \w tenía|strong="H1961"\w* un \w siervo|strong="H5650"\w*, un \w egipcio|strong="H4713"\w*, \w que|strong="H3588"\w* \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* Jarha.  
\v 35 \w Sesán|strong="H8348"\w* \w dio|strong="H5414"\w* su \w hija|strong="H1323"\w* \w a|strong="H3068"\w* Jarha, su \w siervo|strong="H5650"\w*, \w por|strong="H5414"\w* mujer, y ella le \w dio|strong="H5414"\w* \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Atai.  
\v 36 Atai \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Natán, y Natán \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Zabad|strong="H2066"\w*,  
\v 37 y \w Zabad|strong="H2066"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Eflal, y Eflal \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Obed|strong="H5744"\w*,  
\v 38 y \w Obed|strong="H5744"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Jehú|strong="H3058"\w*, y \w Jehú|strong="H3058"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Azarías|strong="H5838"\w*,  
\v 39 y \w Azarías|strong="H5838"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Heles|strong="H2503"\w*, y \w Heles|strong="H2503"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Elasa,  
\v 40 y Elasa \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Sismai, y Sismai \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Salum,  
\v 41 y Salum \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jecamías, y Jecamías \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Elisama.   
\p
\v 42 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Caleb|strong="H3612"\w*, hermano \w de|strong="H1121"\w* \w Jerameel|strong="H3396"\w*, fueron Mesá, \w su|strong="H1931"\w* \w primogénito|strong="H1060"\w*, \w que|strong="H1931"\w* \w fue|strong="H1931"\w* padre \w de|strong="H1121"\w* Zif, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Maresa|strong="H4762"\w*, padre \w de|strong="H1121"\w* \w Hebrón|strong="H2275"\w*.  
\v 43 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hebrón|strong="H2275"\w*: \w Coré|strong="H7141"\w*, Tapú, Requem y Sema.  
\v 44 Sema \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Raham, padre de Jorkeam; y Requem \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Samai.  
\v 45 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Samai fue \w Maón|strong="H4584"\w*; y \w Maón|strong="H4584"\w* fue \w el|strong="H1121"\w* padre \w de|strong="H1121"\w* Bet Zur.  
\v 46 Efa, \w concubina|strong="H6370"\w* de \w Caleb|strong="H3612"\w*, dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Harán|strong="H2771"\w*, Moza y Gazez; y \w Harán|strong="H2771"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Gazez.  
\v 47 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jahdai: \w Regem|strong="H7276"\w*, Jotam, \w Gesán|strong="H1529"\w*, \w Pelet|strong="H6404"\w*, Efa y Saaf.  
\v 48 Maaca, \w concubina|strong="H6370"\w* de \w Caleb|strong="H3612"\w*, dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Seber y \w a|strong="H3068"\w* Tirana.  
\v 49 También dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Saaf, padre de Madmaná, \w a|strong="H3068"\w* Seva, padre de Macbena, y al padre de Gibea; y la \w hija|strong="H1323"\w* de \w Caleb|strong="H3612"\w* fue Acsa.   
\p
\v 50 Estos \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hur|strong="H2354"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* Efrata: \w Sobal|strong="H7732"\w*, padre \w de|strong="H1121"\w* Quiriat Jearim,  
\v 51 \w Salma|strong="H8007"\w*, padre de Belén, y Haref, padre de Bet Gader.  
\v 52 \w Sobal|strong="H7732"\w*, padre \w de|strong="H1121"\w* Quiriat Jearim, \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w*: \w Haroeh|strong="H7204"\w*, la mitad \w de|strong="H1121"\w* \w los|strong="H1121"\w* menuhot.  
\v 53 Las \w familias|strong="H4940"\w* de Quiriat Jearim: los itritas, los putitas, los sumatitas y los misraítas; de ellos \w salieron|strong="H3318"\w* los zoratitas y los estaolitas.  
\v 54 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Salma|strong="H8007"\w*: Belén, \w los|strong="H1121"\w* netofatitas, Atrot Bet Joab, y la mitad \w de|strong="H1121"\w* \w los|strong="H1121"\w* manaítas, \w los|strong="H1121"\w* zoritas.  
\v 55 \w Las|strong="H1992"\w* \w familias|strong="H4940"\w* de \w escribas|strong="H5608"\w* \w que|strong="H1992"\w* \w vivían|strong="H3427"\w* en \w Jabes|strong="H3258"\w*: \w los|strong="H1992"\w* tirateos, \w los|strong="H1992"\w* simeateos y \w los|strong="H1992"\w* sucateos. \w Estos|strong="H1992"\w* son \w los|strong="H1992"\w* ceneos \w que|strong="H1992"\w* vinieron de Hamat, padre de la \w casa|strong="H1004"\w* de Recab.   
\c 3
\p
\v 1 Estos \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w* \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* en \w Hebrón|strong="H2275"\w*: \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, Amnón, \w de|strong="H1121"\w* Ahinoam \w jezreelita|strong="H3159"\w*; \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*, \w Daniel|strong="H1840"\w*, \w de|strong="H1121"\w* Abigail carmelita;  
\v 2 \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*, Absalón, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maaca, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Talmai, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Gesur; \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w*, Adonías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Haguit;  
\v 3 el \w quinto|strong="H2549"\w*, Sefatías, de Abital; el \w sexto|strong="H8345"\w*, \w Itream|strong="H3507"\w*, de Egla, su mujer:  
\v 4 \w seis|strong="H8337"\w* le \w nacieron|strong="H3205"\w* en \w Hebrón|strong="H2275"\w*; y \w reinó|strong="H4427"\w* \w allí|strong="H8033"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* y \w seis|strong="H8337"\w* \w meses|strong="H2320"\w*. \w Reinó|strong="H4427"\w* \w treinta|strong="H7970"\w* y \w tres|strong="H7969"\w* \w años|strong="H8141"\w* en Jerusalén;  
\v 5 y estos le \w nacieron|strong="H3205"\w* en Jerusalén: Simea, \w Sobab|strong="H7727"\w*, Natán y \w Salomón|strong="H8010"\w*, cuatro, de Betsúa, \w hija|strong="H1323"\w* de Amiel;  
\v 6 \w e|strong="H3068"\w* \w Ibhar|strong="H2984"\w*, Elisama, Elifelet,  
\v 7 \w Noga|strong="H5052"\w*, Néfeg, Jafía,  
\v 8 Elisama, Eliada y Elifelet, \w nueve|strong="H8672"\w*.  
\v 9 \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* eran \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, además \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* las \w concubinas|strong="H6370"\w*; y Tamar \w era|strong="H1121"\w* su hermana.   
\p
\v 10 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w* fue \w Roboam|strong="H7346"\w*, su \w hijo|strong="H1121"\w* Abías, su \w hijo|strong="H1121"\w* Asa, su \w hijo|strong="H1121"\w* Josafat,  
\v 11 Su \w hijo|strong="H1121"\w* \w Joram|strong="H3141"\w*, su \w hijo|strong="H1121"\w* Ocozías, su \w hijo|strong="H1121"\w* \w Joás|strong="H3101"\w*,  
\v 12 Su \w hijo|strong="H1121"\w* Amasías, su \w hijo|strong="H1121"\w* \w Azarías|strong="H5838"\w*, su \w hijo|strong="H1121"\w* Jotam,  
\v 13 Su \w hijo|strong="H1121"\w* Acaz, su \w hijo|strong="H1121"\w* Ezequías, su \w hijo|strong="H1121"\w* \w Manasés|strong="H4519"\w*,  
\v 14 Su \w hijo|strong="H1121"\w* Amón, su \w hijo|strong="H1121"\w* \w Josías|strong="H2977"\w*.  
\v 15 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w*: \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w Johanán|strong="H3110"\w*, \w el|strong="H1121"\w* \w segundo|strong="H8145"\w* \w Joacim|strong="H3079"\w*, \w el|strong="H1121"\w* \w tercero|strong="H7992"\w* Sedequías y \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w* Salum.  
\v 16 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Joacim|strong="H3079"\w*: Jeconías, su \w hijo|strong="H1121"\w*, y Sedequías, su \w hijo|strong="H1121"\w*.  
\v 17 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jeconías, \w el|strong="H1121"\w* cautivo: Salatiel su \w hijo|strong="H1121"\w*,  
\v 18 Malquiram, Pedaías, Senazar, Jecamías, \w Hosama|strong="H1953"\w* y Nedabías.  
\v 19 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Pedaías: \w Zorobabel|strong="H2216"\w* y Simei. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zorobabel|strong="H2216"\w*: Mesulam y \w Hananías|strong="H2608"\w*; y Selomit fue su hermana;  
\v 20 y \w Hasubá|strong="H2807"\w*, Ohel, Berequías, Hasadías y Jusab Hesed, \w cinco|strong="H2568"\w*.  
\v 21 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hananías|strong="H2608"\w*: \w Pelatías|strong="H6410"\w* y \w Jesaías|strong="H3470"\w*; \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Refaías, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Arnán, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Abdías|strong="H5662"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Secanías.  
\v 22 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Secanías: \w Semaías|strong="H8098"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Semaías|strong="H8098"\w*: Hatús, \w Igal|strong="H3008"\w*, \w Barías|strong="H1282"\w*, \w Nearías|strong="H5294"\w* y Safat, \w seis|strong="H8337"\w*.  
\v 23 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Nearías|strong="H5294"\w*: Elioenai, Ezequías y \w Azricam|strong="H5840"\w*, \w tres|strong="H7969"\w*.  
\v 24 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elioenai: Hodavías, Eliasib, \w Pelaías|strong="H6411"\w*, Acub, \w Johanán|strong="H3110"\w*, \w Dalaías|strong="H1806"\w*, y Ananí, \w siete|strong="H7651"\w*.   
\c 4
\p
\v 1 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*: Fares, Esrom, \w Carmi|strong="H3756"\w*, \w Hur|strong="H2354"\w* y \w Sobal|strong="H7732"\w*.  
\v 2 Reaías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Sobal|strong="H7732"\w*, \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jahat, y Jahat \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Ahumai y Lahad. Estas son las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* zoratitas.  
\v 3 Estos fueron los hijos del padre de Etam: \w Jezreel|strong="H3157"\w*, \w Isma|strong="H3457"\w* \w e|strong="H3068"\w* Idbas. El \w nombre|strong="H8034"\w* de su hermana era Hazezelelponi.  
\v 4 Penuel fue \w el|strong="H1121"\w* padre \w de|strong="H1121"\w* \w Gedor|strong="H1446"\w* y \w Ezer|strong="H5829"\w* \w el|strong="H1121"\w* padre \w de|strong="H1121"\w* Husa. Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hur|strong="H2354"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* Efrata, padre \w de|strong="H1121"\w* Belén.  
\v 5 Asur, padre de Tecoa, \w tuvo|strong="H1961"\w* \w dos|strong="H8147"\w* mujeres, Hela y Naara.  
\v 6 Naara le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Ahuzam, Hefer, Temeni y Ahasari. Estos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Naara.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hela fueron Zeret, Izhar y Etnán.  
\v 8 \w Cos|strong="H6976"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Anub, \w a|strong="H3068"\w* Zobeba y \w a|strong="H3068"\w* las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* Aharhel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Harum.   
\p
\v 9 \w Jabes|strong="H3258"\w* \w fue|strong="H1961"\w* \w más|strong="H3588"\w* ilustre \w que|strong="H3588"\w* sus hermanos. \w Su|strong="H3588"\w* madre le \w puso|strong="H3205"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w Jabes|strong="H3258"\w*,\f + \fr 4:9 \ft «Jabes» suena similar a la palabra hebrea para «dolor».\f* diciendo: «\w Porque|strong="H3588"\w* lo di \w a|strong="H3068"\w* luz \w con|strong="H3588"\w* dolor».   
\p
\v 10 \w Jabes|strong="H3258"\w* invocó al Dios\f + \fr 4:10 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*, diciendo: “¡Oh, \w si|strong="H1961"\w* \w en|strong="H5973"\w* verdad \w me|strong="H5973"\w* bendijeras y ensancharas \w mi|strong="H1961"\w* territorio! \w Que|strong="H1115"\w* \w tu|strong="H6213"\w* \w mano|strong="H3027"\w* \w esté|strong="H1961"\w* \w conmigo|strong="H5973"\w*, y \w que|strong="H1115"\w* \w me|strong="H5973"\w* \w guardes|strong="H6213"\w* \w del|strong="H5973"\w* \w mal|strong="H7451"\w*, \w para|strong="H1961"\w* \w que|strong="H1115"\w* \w no|strong="H6213"\w* \w me|strong="H5973"\w* cause dolor”.  
\p Dios \w le|strong="H5973"\w* otorgó \w lo|strong="H6213"\w* \w que|strong="H1115"\w* \w pidió|strong="H7592"\w*.   
\p
\v 11 Quelub, hermano de Súa, \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Mehir, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Estón.  
