\v 13 Sus hermanos de las \w casas|strong="H1004"\w* paternas: \w Miguel|strong="H4317"\w*, Mesulam, \w Seba|strong="H7652"\w*, \w Jorai|strong="H3140"\w*, Jacán, \w Zía|strong="H2127"\w* y \w Heber|strong="H5677"\w*, \w siete|strong="H7651"\w*.  
\v 14 Estos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Abihail, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Huri, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jaroa, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Micael, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jesisai, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jahdo, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Buz;  
\v 15 Ahí \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abdiel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Guni, \w jefe|strong="H7218"\w* \w de|strong="H1121"\w* las \w casas|strong="H1004"\w* \w de|strong="H1121"\w* sus padres.  
\v 16 \w Habitaban|strong="H3427"\w* \w en|strong="H5921"\w* \w Galaad|strong="H1568"\w*, \w en|strong="H5921"\w* \w Basán|strong="H1316"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* sus ciudades, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* tierras \w de|strong="H5921"\w* pastoreo \w de|strong="H5921"\w* \w Sarón|strong="H8289"\w* \w hasta|strong="H5921"\w* sus fronteras.  
\v 17 \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron enumerados \w por|strong="H4428"\w* genealogías en \w los|strong="H3605"\w* \w días|strong="H3117"\w* de Jotam, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*, y en \w los|strong="H3605"\w* \w días|strong="H3117"\w* de \w Jeroboam|strong="H3379"\w*, \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*.   
\p
\v 18 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Rubén|strong="H7205"\w*, \w los|strong="H1121"\w* \w gaditas|strong="H1425"\w* y la media \w tribu|strong="H7626"\w* \w de|strong="H4480"\w* \w Manasés|strong="H4519"\w*, \w de|strong="H4480"\w* \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w*, capaces \w de|strong="H4480"\w* llevar broquel y \w espada|strong="H2719"\w*, \w de|strong="H4480"\w* disparar \w con|strong="H4480"\w* \w arco|strong="H7198"\w* y hábiles \w en|strong="H4480"\w* la \w guerra|strong="H4421"\w*, eran cuarenta y cuatro \w mil|strong="H3967"\w* \w setecientos|strong="H7651"\w* \w sesenta|strong="H8346"\w* \w que|strong="H4480"\w* podían \w salir|strong="H3318"\w* \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w*.  
\v 19 \w Hicieron|strong="H6213"\w* la \w guerra|strong="H4421"\w* \w a|strong="H3068"\w* \w los|strong="H5973"\w* agarenos, \w a|strong="H3068"\w* \w Jetur|strong="H3195"\w*, \w a|strong="H3068"\w* Nafis y \w a|strong="H3068"\w* Nodab.  
\v 20 Fueron ayudados \w contra|strong="H5921"\w* \w ellos|strong="H3027"\w*, \w y|strong="H3588"\w* \w los|strong="H5921"\w* agarenos fueron entregados \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*, \w y|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* estaban \w con|strong="H5973"\w* \w ellos|strong="H3027"\w*; \w porque|strong="H3588"\w* \w clamaron|strong="H2199"\w* \w a|strong="H3068"\w* Dios \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w*, \w y|strong="H3588"\w* \w él|strong="H5921"\w* \w les|strong="H5973"\w* respondió \w porque|strong="H3588"\w* \w pusieron|strong="H5414"\w* \w su|strong="H3588"\w* confianza \w en|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 21 Les quitaron el \w ganado|strong="H4735"\w*: de sus \w camellos|strong="H1581"\w* \w cincuenta|strong="H2572"\w* \w mil|strong="H3967"\w*, de las \w ovejas|strong="H6629"\w* \w doscientas|strong="H3967"\w* \w cincuenta|strong="H2572"\w* \w mil|strong="H3967"\w*, de los \w asnos|strong="H2543"\w* dos \w mil|strong="H3967"\w* y de los hombres \w cien|strong="H3967"\w* \w mil|strong="H3967"\w*.  
\v 22 \w Porque|strong="H3588"\w* \w muchos|strong="H7227"\w* \w cayeron|strong="H5307"\w* \w muertos|strong="H2491"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w guerra|strong="H4421"\w* era \w de|strong="H3588"\w* Dios. \w Habitaron|strong="H3427"\w* \w en|strong="H5704"\w* \w su|strong="H3588"\w* \w lugar|strong="H8478"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w cautiverio|strong="H1473"\w*.   
\p
\v 23 \w Los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* la media \w tribu|strong="H7626"\w* \w de|strong="H5704"\w* \w Manasés|strong="H4519"\w* \w habitaron|strong="H3427"\w* \w en|strong="H5704"\w* la tierra. \w Se|strong="H1992"\w* \w multiplicaron|strong="H7235"\w* \w desde|strong="H5704"\w* \w Basán|strong="H1316"\w* \w hasta|strong="H5704"\w* Baal \w Hermón|strong="H2768"\w*, \w Senir|strong="H8149"\w* \w y|strong="H5704"\w* \w el|strong="H1121"\w* \w monte|strong="H2022"\w* \w Hermón|strong="H2768"\w*.  
\v 24 Estos eran los \w jefes|strong="H7218"\w* de las \w casas|strong="H1004"\w* de sus padres: Efer, \w Isi|strong="H3469"\w*, Eliel, \w Azriel|strong="H5837"\w*, \w Jeremías|strong="H3414"\w*, Hodavías y Jahdiel: \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* y famosos, \w jefes|strong="H7218"\w* de sus \w casas|strong="H1004"\w* paternas.  
\v 25 \w Se|strong="H5971"\w* rebelaron \w contra|strong="H6440"\w* el Dios \w de|strong="H6440"\w* sus padres y \w se|strong="H5971"\w* prostituyeron en pos \w de|strong="H6440"\w* los dioses \w de|strong="H6440"\w* los \w pueblos|strong="H5971"\w* \w de|strong="H6440"\w* la tierra \w que|strong="H5971"\w* Dios había destruido \w antes|strong="H6440"\w* \w que|strong="H5971"\w* ellos.  
\v 26 \w Entonces|strong="H3117"\w* el Dios \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* \w despertó|strong="H5782"\w* el \w espíritu|strong="H7307"\w* \w de|strong="H5704"\w* Pul, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* Asiria, \w y|strong="H5704"\w* el \w espíritu|strong="H7307"\w* \w de|strong="H5704"\w* Tiglat Pileser, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* Asiria, \w y|strong="H5704"\w* se llevó \w a|strong="H3068"\w* los rubenitas, \w a|strong="H3068"\w* los \w gaditas|strong="H1425"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* la media \w tribu|strong="H7626"\w* \w de|strong="H5704"\w* \w Manasés|strong="H4519"\w*, \w y|strong="H5704"\w* los llevó \w a|strong="H3068"\w* Halah, Habor, Hara \w y|strong="H5704"\w* \w al|strong="H5704"\w* \w río|strong="H5104"\w* \w de|strong="H5704"\w* \w Gozán|strong="H1470"\w*, \w hasta|strong="H5704"\w* el \w día|strong="H3117"\w* \w de|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\c 6
\p
\v 1 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w*: Gersón, Coat y \w Merari|strong="H4847"\w*.  
\v 2 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat: Amram, Izhar, Hebrón y Uziel.  
\v 3 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Amram|strong="H6019"\w*: Aarón, Moisés y Miriam. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón: Nadab, Abiú, Eleazar \w e|strong="H3068"\w* Itamar.  
\v 4 Eleazar engendró \w a|strong="H3068"\w* Finees, Finees engendró \w a|strong="H3068"\w* Abisúa,  
\v 5 Abisúa engendró \w a|strong="H3068"\w* Buqui, Buqui engendró \w a|strong="H3068"\w* Uzi,  
\v 6 Uzi engendró \w a|strong="H3068"\w* Zeraías, Zeraías engendró \w a|strong="H3068"\w* Meraiot,  
\v 7 Meraiot engendró \w a|strong="H3068"\w* Amarías, Amarías engendró \w a|strong="H3068"\w* Ahitob,  
\v 8 Ahitob engendró \w a|strong="H3068"\w* Sadoc, Sadoc engendró \w a|strong="H3068"\w* Ahimaas,  
\v 9 Ahimaas engendró \w a|strong="H3068"\w* Azarías, Azarías engendró \w a|strong="H3068"\w* Johanán,  
\v 10 Johanán engendró \w a|strong="H3068"\w* Azarías, quien ejerció \w el|strong="H1121"\w* oficio \w de|strong="H1121"\w* sacerdote en la casa \w que|strong="H1121"\w* Salomón construyó en Jerusalén.  
\v 11 Azarías engendró \w a|strong="H3068"\w* Amarías, Amarías engendró \w a|strong="H3068"\w* Ahitob,  
\v 12 Ahitob engendró \w a|strong="H3068"\w* Sadoc, Sadoc engendró \w a|strong="H3068"\w* Salum,  
\v 13 Salum engendró \w a|strong="H3068"\w* Hilcías, Hilcías engendró \w a|strong="H3068"\w* Azarías,  
\v 14 Azarías engendró \w a|strong="H3068"\w* Seraías, Seraías engendró \w a|strong="H3068"\w* Josadac.  
\v 15 Josadac fue al cautiverio cuando Yahvé se llevó \w a|strong="H3068"\w* Judá y \w a|strong="H3068"\w* Jerusalén por mano \w de|strong="H1121"\w* Nabucodonosor.   
\p
\v 16 \w Los|strong="H5921"\w* hijos \w de|strong="H5921"\w* Leví: Gersón, Coat \w y|strong="H5921"\w* Merari.  
\v 17 Estos \w son|strong="H1961"\w* \w los|strong="H5921"\w* nombres \w de|strong="H5921"\w* \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* Gersón: Libni \w y|strong="H5921"\w* Simei.  
\v 18 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat fueron Amram, Izhar, Hebrón y Uziel.  
\v 19 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Merari: Mahli y Musi. Estas son las familias \w de|strong="H1121"\w* \w los|strong="H1121"\w* levitas según las familias \w de|strong="H1121"\w* sus padres.  
\v 20 \w De|strong="H1121"\w* Gersón: Libni su \w hijo|strong="H1121"\w*, Jahat su \w hijo|strong="H1121"\w*, Zima su \w hijo|strong="H1121"\w*,  
\v 21 Joah su \w hijo|strong="H1121"\w*, Iddo su \w hijo|strong="H1121"\w*, Zera su \w hijo|strong="H1121"\w* y Jeaterai su \w hijo|strong="H1121"\w*.  
\v 22 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat: Aminadab su \w hijo|strong="H1121"\w*, \w Coré|strong="H7141"\w* su \w hijo|strong="H1121"\w*, Asir su \w hijo|strong="H1121"\w*,  
\v 23 Elcaná su \w hijo|strong="H1121"\w*, Ebiasaf su \w hijo|strong="H1121"\w*, Asir su \w hijo|strong="H1121"\w*,  
\v 24 Tahat su \w hijo|strong="H1121"\w*, Uriel su \w hijo|strong="H1121"\w*, Uzías su \w hijo|strong="H1121"\w* \w y|strong="H5921"\w* Saúl su \w hijo|strong="H1121"\w*.  
\v 25 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elcaná: Amasai y Ahimot.  
\v 26 En cuanto \w a|strong="H3068"\w* Elcaná, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elcaná: Zofai su \w hijo|strong="H1121"\w*, Nahat su \w hijo|strong="H1121"\w*,  
\v 27 Eliab su \w hijo|strong="H1121"\w*, Jeroham su \w hijo|strong="H1121"\w*, y Elcaná su \w hijo|strong="H1121"\w*.  
\v 28 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Samuel: \w el|strong="H1121"\w* primogénito, Joel, y \w el|strong="H1121"\w* segundo, Abías.  
\v 29 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Merari|strong="H4847"\w*: Mahli, Libni su \w hijo|strong="H1121"\w*, Simei su \w hijo|strong="H1121"\w*, Uza su \w hijo|strong="H1121"\w*,  
\v 30 Simea su \w hijo|strong="H1121"\w*, Haguía su \w hijo|strong="H1121"\w*, Asaías su \w hijo|strong="H1121"\w*.   
\p
\v 31 Estos son \w los|strong="H1121"\w* \w que|strong="H1121"\w* David puso al frente del servicio del canto en la casa \w de|strong="H1121"\w* Yahvé, después \w de|strong="H1121"\w* \w que|strong="H1121"\w* \w el|strong="H1121"\w* arca vino \w a|strong="H3068"\w* descansar allí.  
\v 32 Ellos ministraron con \w el|strong="H1121"\w* canto ante \w el|strong="H1121"\w* tabernáculo \w de|strong="H1121"\w* la Tienda \w de|strong="H1121"\w* Reunión hasta \w que|strong="H1121"\w* Salomón edificó la casa \w de|strong="H1121"\w* Yahvé en Jerusalén. Desempeñaron \w los|strong="H1121"\w* deberes \w de|strong="H1121"\w* su cargo según su orden.  
\v 33 \w Estos|strong="H3605"\w* son \w los|strong="H3605"\w* \w que|strong="H3605"\w* servían, y sus hijos. \w De|strong="H5414"\w* \w los|strong="H3605"\w* hijos \w de|strong="H5414"\w* \w los|strong="H3605"\w* coatitas: Hemán \w el|strong="H3605"\w* cantor, hijo \w de|strong="H5414"\w* Joel, hijo \w de|strong="H5414"\w* Samuel,  
\v 34 \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Elcaná, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Jeroham, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Eliel, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Toah,  
\v 35 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zuf, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Elcaná, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Mahat, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amasai,  
\v 36 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Elcaná, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Joel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Azarías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sofonías,  
\v 37 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Tahat, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Asir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ebiasaf, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Coré,  
\v 38 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Izhar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Coat, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Leví, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Israel.  
\v 39 \w Su|strong="H1992"\w* hermano Asaf, \w que|strong="H3588"\w* \w estaba|strong="H1961"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* derecha, Asaf \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Simea,  
\v 40 hijo \w de|strong="H5414"\w* Micael, hijo \w de|strong="H5414"\w* Baasías, hijo \w de|strong="H5414"\w* Malquías,  
\v 41 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Etni, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zera, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Adaías,  
\v 42 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Etán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zima, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Simei,  
\v 43 hijo de Jahat, hijo de Gersón, hijo de Leví.  
\v 44 \w A|strong="H3068"\w* la izquierda sus hermanos los hijos de Merari: Etán hijo de Quisi, hijo de Abdi, hijo de Maluc,  
\v 45 hijo de Hasabías, hijo de Amasías, hijo de Hilcías,  
\v 46 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amsi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Bani, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Semer,  
\v 47 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Mahli, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Musi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Merari, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Leví.  
\v 48 Sus hermanos \w los|strong="H1121"\w* levitas fueron designados para todo \w el|strong="H1121"\w* servicio del tabernáculo \w de|strong="H1121"\w* la casa \w de|strong="H1121"\w* Dios.  
\v 49 Pero Aarón y sus \w hijos|strong="H1121"\w* ofrecían en \w el|strong="H1121"\w* altar \w de|strong="H1121"\w* \w los|strong="H1121"\w* holocaustos y en \w el|strong="H1121"\w* altar del incienso, \w para|strong="H5414"\w* toda la obra del lugar santísimo y \w para|strong="H5414"\w* hacer la expiación \w por|strong="H5414"\w* \w Israel|strong="H3478"\w*, conforme \w a|strong="H3068"\w* todo lo \w que|strong="H1121"\w* había mandado Moisés, siervo \w de|strong="H1121"\w* Dios.   
\p
\v 50 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón: Eleazar su \w hijo|strong="H1121"\w*, Finees su \w hijo|strong="H1121"\w*, Abisúa su \w hijo|strong="H1121"\w*,  
\v 51 Buqui su \w hijo|strong="H1121"\w*, Uzi su \w hijo|strong="H1121"\w*, Zeraías su \w hijo|strong="H1121"\w*,  
\v 52 Meraiot su hijo, Amarías su hijo, Ahitob su hijo,  
\v 53 Sadoc su hijo, y Ahimaas su hijo.  
\v 54 Estos son sus lugares de residencia según sus campamentos en sus fronteras: \w a|strong="H3068"\w* los hijos de Aarón, de las familias de los coatitas (porque la suya fue la primera suerte),  
\v 55 les dieron Hebrón en la tierra \w de|strong="H1121"\w* Judá, y sus tierras \w de|strong="H1121"\w* pastoreo alrededor \w de|strong="H1121"\w* ella;  
\v 56 pero \w los|strong="H1121"\w* campos \w de|strong="H1121"\w* la ciudad y sus aldeas, se \w los|strong="H1121"\w* dieron \w a|strong="H3068"\w* Caleb \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jefone.  
\v 57 \w A|strong="H3068"\w* los hijos de Aarón les dieron las ciudades de refugio, Hebrón, Libna con sus tierras de pastoreo, Jatir, Estemoa con sus tierras de pastoreo,  
\v 58 Hilén con sus tierras de pastoreo, Debir con sus tierras de pastoreo,  
\v 59 Asán con sus tierras de pastoreo y Bet Semes con sus tierras de pastoreo;  
\v 60 y de la tribu de Benjamín, Geba con sus tierras de pastoreo, Alemet con sus tierras de pastoreo y Anatot con sus tierras de pastoreo. Todas las ciudades de sus familias eran trece ciudades.   
\p
\v 61 \w A|strong="H3068"\w* los demás hijos de Coat se les dio por sorteo, de la familia de la \w tribu|strong="H4294"\w*, de la media \w tribu|strong="H4294"\w*, la mitad de Manasés, diez ciudades.  
\v 62 \w A|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Gersón, según sus familias, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Isacar, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Aser, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Neftalí y \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Manasés en Basán, trece ciudades.  
\v 63 \w A|strong="H3068"\w* los hijos de Merari se les dio por sorteo, según sus familias, de la \w tribu|strong="H4294"\w* de \w Rubén|strong="H7205"\w*, de la \w tribu|strong="H4294"\w* de Gad y de la \w tribu|strong="H4294"\w* de Zabulón, doce ciudades.  
\v 64 Los hijos de Israel dieron \w a|strong="H3068"\w* los levitas las ciudades con sus tierras de pastoreo.  
\v 65 De la \w tribu|strong="H4294"\w* de los hijos de Judá, de la \w tribu|strong="H4294"\w* de los hijos de Simeón y de la \w tribu|strong="H4294"\w* de los hijos de Benjamín, dieron por sorteo estas ciudades que se mencionan por su nombre.   
\p
\v 66 Algunas de las familias de los hijos de Coat tenían ciudades de sus fronteras fuera de la tribu de Efraín.  
\v 67 Les dieron las ciudades de refugio, Siquem en la región montañosa de Efraín con sus tierras de pastoreo y Gezer con sus tierras de pastoreo,  
\v 68 Jocmeam con sus tierras de pastoreo, Bet Horón con sus tierras de pastoreo,  
\v 69 Ajalón con sus tierras de pastoreo, Gat Rimón con sus tierras de pastoreo;  
\v 70 y de la media tribu de Manasés, Aner con sus tierras de pastoreo y Bileam con sus tierras de pastoreo, para el resto de la familia de los hijos de Coat.   
\p
\v 71 \w A|strong="H3068"\w* los hijos de Gersón se les dio, de la familia de la media tribu de Manasés, Golán en Basán con sus tierras de pastoreo, y Astarot con sus tierras de pastoreo;  
\v 72 y de la tribu de Isacar, Cedes con sus tierras de pastoreo, Daberat con sus tierras de pastoreo,  
\v 73 Ramot con sus tierras de pastoreo, y Anem con sus tierras de pastoreo;  
\v 74 y de la tribu de Aser, Masal con sus tierras de pastoreo, Abdón con sus tierras de pastoreo,  
\v 75 Hucoc con sus tierras de pastoreo, y Rehob con sus tierras de pastoreo;  
\v 76 y de la tribu de Neftalí, Cedes en Galilea con sus tierras de pastoreo, Hamón con sus tierras de pastoreo, y Quiriatáim con sus tierras de pastoreo.   
\p
\v 77 Al resto de los levitas, hijos de Merari, se les dio, de la tribu de Zabulón, Rimón con sus tierras de pastoreo, y Tabor con sus tierras de pastoreo;  
\v 78 y al otro lado del Jordán, en Jericó, al lado oriental del Jordán, se les dio de la tribu de Rubén: Beser en el desierto con sus tierras de pastoreo, Jahaza con sus tierras de pastoreo,  
\v 79 Cedemot con sus tierras de pastoreo y Mefaat con sus tierras de pastoreo;  
\v 80 y de la tribu de Gad, Ramot en Galaad con sus tierras de pastoreo, Mahanaim con sus tierras de pastoreo,  
\v 81 Hesbón con sus tierras de pastoreo y Jazer con sus tierras de pastoreo.   
\c 7
\p
\v 1 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Isacar: \w Tola|strong="H8439"\w*, Fúa, \w Jasub|strong="H3437"\w* y Simrón, cuatro.  
\v 2 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Tola|strong="H8439"\w*: Uzi, Refaías, \w Jeriel|strong="H3400"\w*, Jahmai, Ibsam y Semuel, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las \w casas|strong="H1004"\w* paternas \w de|strong="H1121"\w* \w Tola|strong="H8439"\w*; \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* en sus generaciones. Su \w número|strong="H4557"\w* en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w* \w era|strong="H1121"\w* \w de|strong="H1121"\w* \w veintidós|strong="H6242"\w* \w mil|strong="H3967"\w* \w seiscientos|strong="H8337"\w*.  
\v 3 \w El|strong="H3605"\w* \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* Uzi: Izrahías. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* Izrahías: \w Miguel|strong="H4317"\w*, \w Obadías|strong="H5662"\w*, \w Joel|strong="H3100"\w* \w e|strong="H3068"\w* \w Isías|strong="H3449"\w*, \w cinco|strong="H2568"\w*; \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w hombres|strong="H1121"\w* \w principales|strong="H7218"\w*.  
\v 4 \w Con|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w por|strong="H5921"\w* sus generaciones, \w según|strong="H5921"\w* \w las|strong="H5921"\w* \w casas|strong="H1004"\w* \w de|strong="H5921"\w* sus padres, \w había|strong="H3588"\w* grupos \w del|strong="H5921"\w* \w ejército|strong="H6635"\w* \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w*, \w treinta|strong="H7970"\w* \w y|strong="H3588"\w* \w seis|strong="H8337"\w* mil; \w porque|strong="H3588"\w* tenían \w muchas|strong="H7235"\w* mujeres \w e|strong="H3068"\w* \w hijos|strong="H1121"\w*.  
\v 5 Sus hermanos de \w todas|strong="H3605"\w* las \w familias|strong="H4940"\w* de Isacar, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, enumerados en su totalidad por genealogía, eran \w ochenta|strong="H8084"\w* y \w siete|strong="H7651"\w* mil.   
\p
\v 6 Los hijos de \w Benjamín|strong="H1144"\w*: \w Bela|strong="H1106"\w*, Bequer y \w Jediael|strong="H3043"\w*, \w tres|strong="H7969"\w*.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Bela|strong="H1106"\w*: Ezbón, Uzi, Uziel, Jerimot \w e|strong="H3068"\w* Iri, \w cinco|strong="H2568"\w*; \w jefes|strong="H7218"\w* \w de|strong="H2568"\w* \w familia|strong="H1004"\w*, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*; y fueron enumerados por genealogía \w veintidós|strong="H6242"\w* mil \w treinta|strong="H7970"\w* y cuatro.  
\v 8 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Bequer: \w Zemira|strong="H2160"\w*, \w Joás|strong="H3135"\w*, Eliezer, Elioenai, \w Omri|strong="H6018"\w*, Jeremot, Abías, Anatot y Alemet. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Bequer.  
\v 9 Fueron listados por genealogía, según sus generaciones, \w jefes|strong="H7218"\w* de las \w casas|strong="H1004"\w* de sus padres, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, \w veinte|strong="H6242"\w* \w mil|strong="H3967"\w* \w doscientos|strong="H3967"\w*.  
\v 10 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jediael|strong="H3043"\w*: \w Bilhán|strong="H1092"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bilhán|strong="H1092"\w*: \w Jeús|strong="H3266"\w*, \w Benjamín|strong="H1144"\w*, Aod, Quenaaná, Zetán, \w Tarsis|strong="H8659"\w* y Ahisahar.  
\v 11 \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jediael|strong="H3043"\w*, según \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* familia \w de|strong="H1121"\w* sus padres, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, \w diecisiete|strong="H7651"\w* \w mil|strong="H3967"\w* \w doscientos|strong="H3967"\w*, capaces \w de|strong="H1121"\w* \w salir|strong="H3318"\w* \w en|strong="H3318"\w* \w el|strong="H3605"\w* \w ejército|strong="H2428"\w* para \w la|strong="H3605"\w* \w guerra|strong="H4421"\w*.  
\v 12 También estaban Supim, Hupim, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ir, \w Husim|strong="H2366"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aher.   
\p
\v 13 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Neftalí: \w Jahzeel|strong="H3185"\w*, \w Guni|strong="H3337"\w*, \w Jezer|strong="H7967"\w*, Salum y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bilhá|strong="H1090"\w*.   
\p
\v 14 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*: Asriel, \w a|strong="H3068"\w* quien dio \w a|strong="H3068"\w* luz su \w concubina|strong="H6370"\w* la aramea. Ella dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Maquir, padre \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*.  
\v 15 Maquir \w tomó|strong="H3947"\w* una mujer de Hupim y Supim, cuya hermana \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* Maaca. El \w nombre|strong="H8034"\w* de la \w segunda|strong="H8145"\w* \w era|strong="H1961"\w* Zelofehad; y Zelofehad \w tuvo|strong="H1961"\w* \w hijas|strong="H1323"\w*.  
\v 16 Maaca, la mujer \w de|strong="H1121"\w* Maquir, dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, al \w que|strong="H1121"\w* \w llamó|strong="H7121"\w* \w Peres|strong="H6570"\w*. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su hermano fue Seres, y sus \w hijos|strong="H1121"\w* fueron Ulam y Requem.  
\v 17 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ulam: Bedán. Estos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*.  
\v 18 Su hermana Hamolequet dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Isod, Abiezer y Mahala.  
\v 19 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Semida \w fueron|strong="H1961"\w* Ahián, Siquem, Likhi y Aniam.   
\p
\v 20 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Efraín: Sutela, \w Bered|strong="H1260"\w* su \w hijo|strong="H1121"\w*, Tahat su \w hijo|strong="H1121"\w*, Eleada su \w hijo|strong="H1121"\w*, Tahat su \w hijo|strong="H1121"\w*,  
\v 21 \w Zabad|strong="H2066"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*, Sutela \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*, \w Ezer|strong="H5827"\w* \w y|strong="H3588"\w* Elead, \w a|strong="H3068"\w* quienes \w mataron|strong="H2026"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* Gat \w que|strong="H3588"\w* habían \w nacido|strong="H3205"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* país, \w porque|strong="H3588"\w* \w bajaron|strong="H3381"\w* \w a|strong="H3068"\w* quitarles \w el|strong="H3588"\w* \w ganado|strong="H4735"\w*.  
\v 22 Efraín, su padre, estuvo de luto \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*, y sus hermanos fueron \w a|strong="H3068"\w* consolarlo.  
\v 23 \w Se|strong="H1961"\w* acercó \w a|strong="H3068"\w* \w su|strong="H3588"\w* mujer, \w y|strong="H3588"\w* ella \w concibió|strong="H2029"\w* \w y|strong="H3588"\w* dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, al \w que|strong="H3588"\w* \w puso|strong="H3205"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w Beriá|strong="H1283"\w*,\f + \fr 7:23 \ft «Beriá» es similar a la palabra hebrea para «desgracia».\f* \w porque|strong="H3588"\w* \w había|strong="H1961"\w* problemas \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*.  
\v 24 Su \w hija|strong="H1323"\w* fue Seera, \w que|strong="H1323"\w* construyó Bet Horón la de abajo y la de arriba, y Uzen Seera.  
\v 25 Su \w hijo|strong="H1121"\w* fue Refa, su \w hijo|strong="H1121"\w* Resef, su \w hijo|strong="H1121"\w* Tela, su \w hijo|strong="H1121"\w* Tahán,  
\v 26 Su \w hijo|strong="H1121"\w* \w Ladán|strong="H3936"\w*, su \w hijo|strong="H1121"\w* Amiud, su \w hijo|strong="H1121"\w* Elisama,  
\v 27 Su \w hijo|strong="H1121"\w* \w Nun|strong="H5126"\w*, y su \w hijo|strong="H1121"\w* \w Josué|strong="H3091"\w*.  
\v 28 Sus posesiones \w y|strong="H5704"\w* asentamientos fueron Betel \w y|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*, \w al|strong="H5704"\w* \w este|strong="H4217"\w* \w Naarán|strong="H5295"\w*, \w y|strong="H5704"\w* \w al|strong="H5704"\w* oeste \w Gezer|strong="H1507"\w* \w con|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*; también Siquem \w y|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*, \w hasta|strong="H5704"\w* \w Gaza|strong="H5804"\w* \w y|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*;  
\v 29 \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w los|strong="H3427"\w* límites \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w*, Bet Seán \w y|strong="H5921"\w* sus \w aldeas|strong="H1323"\w*, Taanac \w y|strong="H5921"\w* sus \w aldeas|strong="H1323"\w*, Meguido \w y|strong="H5921"\w* sus \w aldeas|strong="H1323"\w*, \w y|strong="H5921"\w* \w Dor|strong="H1756"\w* \w y|strong="H5921"\w* sus \w aldeas|strong="H1323"\w*. \w En|strong="H5921"\w* \w ellas|strong="H5921"\w* \w habitaron|strong="H3427"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 30 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aser: \w Imna|strong="H3232"\w*, \w Isúa|strong="H3438"\w*, \w Isúi|strong="H3440"\w* y \w Beriá|strong="H1283"\w*. \w Sera|strong="H8294"\w* \w era|strong="H1121"\w* su hermana.  
\v 31 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Beriá|strong="H1283"\w*: \w Heber|strong="H2268"\w* y Malquiel, \w que|strong="H1931"\w* \w fue|strong="H1931"\w* \w el|strong="H1931"\w* padre \w de|strong="H1121"\w* Birzait.  
\v 32 \w Heber|strong="H2268"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jaflet, \w a|strong="H3068"\w* Somer, \w a|strong="H3068"\w* Hotam y \w a|strong="H3068"\w* su hermana Súa.  
\v 33 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jaflet: \w Pasac|strong="H6457"\w*, \w Bimhal|strong="H1118"\w* y Asvat. Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jaflet.  
\v 34 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Semer: Ahí, Rohga, Jehubá y Aram.  
\v 35 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Helem, su hermano: Zofa, \w Imna|strong="H3234"\w*, Seles y Amal.  
\v 36 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Zofa: \w Súa|strong="H5477"\w*, Harnefer, \w Sual|strong="H7777"\w*, \w Beri|strong="H1275"\w*, \w Imra|strong="H3236"\w*,  
\v 37 \w Beser|strong="H1221"\w*, \w Hod|strong="H1936"\w*, Sama, \w Silsa|strong="H8030"\w*, Itrán y Beera.  
\v 38 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeter|strong="H3500"\w*: Jefone, \w Pispa|strong="H6462"\w* y Ara.  
\v 39 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ula: Ara, \w Haniel|strong="H2592"\w* y Rizia.  
\v 40 \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aser, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las \w casas|strong="H1004"\w* paternas, \w hombres|strong="H1368"\w* selectos y \w valientes|strong="H1368"\w*, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w príncipes|strong="H5387"\w*. \w El|strong="H3605"\w* \w número|strong="H4557"\w* \w de|strong="H1121"\w* \w ellos|strong="H3605"\w* inscritos por genealogía para \w el|strong="H3605"\w* servicio en \w la|strong="H3605"\w* \w guerra|strong="H4421"\w* \w era|strong="H1121"\w* \w de|strong="H1121"\w* \w veintiséis|strong="H6242"\w* mil \w hombres|strong="H1368"\w*.   
\c 8
\p
\v 1 \w Benjamín|strong="H1144"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Bela|strong="H1106"\w*, su \w primogénito|strong="H1060"\w*; Asbel, el \w segundo|strong="H8145"\w*; Ahara, el \w tercero|strong="H7992"\w*;  
\v 2 \w Noha|strong="H5119"\w*, el \w cuarto|strong="H7243"\w*, y Rafa, el \w quinto|strong="H2549"\w*.  
\v 3 \w Bela|strong="H1106"\w* \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w*: Adar, \w Gera|strong="H1617"\w*, Abiud,  
\v 4 Abisúa, \w Naamán|strong="H5283"\w*, Ahoá,  
\v 5 \w Gera|strong="H1617"\w*, Sefufán y Huram.  
\v 6 \w Estos|strong="H1992"\w* son \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aod. \w Estos|strong="H1992"\w* son \w los|strong="H1992"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* familia \w de|strong="H1121"\w* \w los|strong="H1992"\w* \w habitantes|strong="H3427"\w* \w de|strong="H1121"\w* Geba, \w que|strong="H1121"\w* fueron llevados \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* Manahat:  
\v 7 \w Naamán|strong="H5283"\w*, Ahías y \w Gera|strong="H1617"\w*, \w que|strong="H1931"\w* \w los|strong="H1931"\w* llevó \w cautivos|strong="H1540"\w*; y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Uza y \w a|strong="H3068"\w* Ahiud.   
\p
\v 8 Saharaim \w engendró|strong="H3205"\w* hijos \w en|strong="H4480"\w* el \w campo|strong="H7704"\w* \w de|strong="H4480"\w* \w Moab|strong="H4124"\w*, después \w de|strong="H4480"\w* haber despedido \w a|strong="H3068"\w* sus mujeres. \w Husim|strong="H2366"\w* y Baara fueron sus mujeres.  
\v 9 \w De|strong="H4480"\w* Hodes, su mujer, \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Jobab|strong="H3103"\w*, Zibia, \w Mesa|strong="H4331"\w*, Malcam,  
\v 10 Jeúz, Saquía y Mirma. Estos fueron sus \w hijos|strong="H1121"\w*, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* familia \w de|strong="H1121"\w* sus padres.  
\v 11 Por \w Husim|strong="H2366"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Abitub y \w a|strong="H3068"\w* Elpaal.  
\v 12 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elpaal: \w Heber|strong="H5677"\w*, \w Misam|strong="H4936"\w* y Semed, \w que|strong="H1931"\w* \w edificaron|strong="H1129"\w* Ono y \w Lod|strong="H3850"\w*, con \w sus|strong="H1931"\w* ciudades;  
\v 13 y \w Beriá|strong="H1283"\w* y Sema, \w que|strong="H1992"\w* fueron \w jefes|strong="H7218"\w* de familia de \w los|strong="H1992"\w* \w habitantes|strong="H3427"\w* de Ajalón, \w que|strong="H1992"\w* pusieron en fuga \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w habitantes|strong="H3427"\w* de Gat;  
\v 14 y Ahío, \w Sasac|strong="H8349"\w*, Jeremot,  
\v 15 \w Zebadías|strong="H2069"\w*, \w Arad|strong="H6166"\w*, Eder,  
\v 16 \w Miguel|strong="H4317"\w*, Ispa, Joha, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Beriá|strong="H1283"\w*,  
\v 17 \w Zebadías|strong="H2069"\w*, Mesulam, Hizqui, \w Heber|strong="H2268"\w*,  
\v 18 Ismerai, \w Izlía|strong="H3152"\w*, \w Jobab|strong="H3103"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elpaal,  
\v 19 Jaquim, Zicri, \w Zabdi|strong="H2067"\w*,  
\v 20 Elienai, Ziletai, Eliel,  
\v 21 \w Adaías|strong="H5718"\w*, Beraías, Simrat, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Simei,  
\v 22 Ispán, \w Heber|strong="H5677"\w*, Eliel,  
\v 23 \w Abdón|strong="H5658"\w*, Zicri, \w Hanán|strong="H2605"\w*,  
\v 24 \w Hananías|strong="H2608"\w*, \w Elam|strong="H5867"\w*, Anatotías,  
\v 25 Ifdeías, Penuel, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sasac|strong="H8349"\w*,  
\v 26 Samserai, Searías, Atalías,  
\v 27 Jaresías, Elías, Zicri, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeroham|strong="H3395"\w*.  
\v 28 Estos eran \w jefes|strong="H7218"\w* de familia por sus generaciones, hombres \w principales|strong="H7218"\w*. Estos \w habitaban|strong="H3427"\w* en Jerusalén.   
\p
\v 29 \w El|strong="H3427"\w* padre de \w Gabaón|strong="H1391"\w*, cuya mujer se \w llamaba|strong="H8034"\w* Maaca, \w habitaba|strong="H3427"\w* en \w Gabaón|strong="H1391"\w*  
\v 30 con su \w hijo|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w Abdón|strong="H5658"\w*, Zur, \w Cis|strong="H7027"\w*, \w Baal|strong="H1168"\w*, \w Nadab|strong="H5070"\w*,  
\v 31 \w Gedor|strong="H1446"\w*, Ahío, Zequer,  
\v 32 y Miclot, \w que|strong="H1992"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Simea. También \w habitaban|strong="H3427"\w* \w con|strong="H5973"\w* \w sus|strong="H1992"\w* familias \w en|strong="H5973"\w* Jerusalén, \w cerca|strong="H5973"\w* \w de|strong="H5048"\w* \w sus|strong="H1992"\w* parientes.  
\v 33 \w Ner|strong="H5369"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Cis|strong="H7027"\w*. \w Cis|strong="H7027"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*. \w Saúl|strong="H7586"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jonatán, Malquisúa, Abinadab y Esbaal.  
\v 34 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jonatán fue Merib-baal. Merib-baal \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Miqueas.  
\v 35 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Miqueas: Pitón, Melec, Tarea y Acaz.  
\v 36 Acaz \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Joada. \w Y|strong="H3068"\w* Joada \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Alemet, Azmavet y \w Zimri|strong="H2174"\w*. \w Zimri|strong="H2174"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Moza.  
\v 37 Moza \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Binea. Rafa fue su \w hijo|strong="H1121"\w*, Elasa su \w hijo|strong="H1121"\w*, y Azel su \w hijo|strong="H1121"\w*.  
\v 38 Azel tuvo \w seis|strong="H8337"\w* \w hijos|strong="H1121"\w*, cuyos \w nombres|strong="H8034"\w* son \w estos|strong="H3605"\w*: \w Azricam|strong="H5840"\w*, Bocru, \w Ismael|strong="H3458"\w*, \w Searías|strong="H8187"\w*, \w Abdías|strong="H5662"\w* y \w Hanán|strong="H2605"\w*. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Azel.  
\v 39 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* su hermano Esec: Ulam su \w primogénito|strong="H1060"\w*, \w Jeús|strong="H3266"\w* \w el|strong="H1121"\w* \w segundo|strong="H8145"\w* y Elifelet \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*.  
\v 40 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ulam \w fueron|strong="H1961"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, arqueros, y \w tuvieron|strong="H1961"\w* \w muchos|strong="H7235"\w* \w hijos|strong="H1121"\w* y \w nietos|strong="H1121"\w*, \w ciento|strong="H3967"\w* \w cincuenta|strong="H2572"\w*. \w Todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w eran|strong="H1961"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w*.   
\c 9
\p
\v 1 Así \w que|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w fue|strong="H3063"\w* enumerado \w por|strong="H5921"\w* genealogías; \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w*\f + \fr 9:1 \ft «He aquí», de «הִנֵּה», significa mirar, fijarse, observar, ver o contemplar. Se utiliza a menudo como interjección.\f* \w están|strong="H2009"\w* \w escritas|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w libro|strong="H5612"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Judá|strong="H3063"\w* \w fue|strong="H3063"\w* llevado cautivo \w a|strong="H3068"\w* Babilonia \w por|strong="H5921"\w* su desobediencia.  
\v 2 \w Los|strong="H3427"\w* \w primeros|strong="H7223"\w* \w habitantes|strong="H3427"\w* que \w vivían|strong="H3427"\w* en sus posesiones, en sus \w ciudades|strong="H5892"\w*, eran \w los|strong="H3427"\w* israelitas, \w los|strong="H3427"\w* \w sacerdotes|strong="H3548"\w*, \w los|strong="H3427"\w* \w levitas|strong="H3881"\w* y \w los|strong="H3427"\w* sirvientes del templo.  
\v 3 \w En|strong="H4480"\w* Jerusalén \w vivían|strong="H3427"\w* \w de|strong="H4480"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w de|strong="H4480"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Benjamín|strong="H1144"\w* y \w de|strong="H4480"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Efraín y \w Manasés|strong="H4519"\w*:  
\v 4 \w Utai|strong="H5793"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amiud, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Omri|strong="H6018"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Imri, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Bani|strong="H1137"\w*, \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Fares \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 5 \w De|strong="H4480"\w* \w los|strong="H1121"\w* silonitas: \w Asaías|strong="H6222"\w* \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w* y sus \w hijos|strong="H1121"\w*.  
\v 6 \w De|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Zera|strong="H2226"\w*: Jeuel y sus hermanos, \w seiscientos|strong="H8337"\w* \w noventa|strong="H8673"\w*.  
\v 7 \w De|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Benjamín|strong="H1144"\w*: \w Salú|strong="H5543"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Hodavías, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Hasenúa;  
\v 8 \w e|strong="H3068"\w* Ibneías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeroham|strong="H3395"\w*, y Ela, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uzi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Micri; y Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sefatías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ibnía;  
\v 9 y sus hermanos, según sus generaciones, \w novecientos|strong="H8672"\w* \w cincuenta|strong="H2572"\w* y \w seis|strong="H8337"\w*. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* hombres eran \w jefes|strong="H7218"\w* de \w familia|strong="H1004"\w* por las \w casas|strong="H1004"\w* de sus padres.   
\p
\v 10 \w De|strong="H4480"\w* los \w sacerdotes|strong="H3548"\w*: \w Jedaías|strong="H3048"\w*, \w Joiarib|strong="H3080"\w*, Jacín,  
