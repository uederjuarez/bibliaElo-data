\v 9 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Gad|strong="H1410"\w*, el \w vidente|strong="H2374"\w* de \w David|strong="H1732"\w*, \w diciendo|strong="H1696"\w*:  
\v 10 “\w Ve|strong="H3212"\w* \w y|strong="H5921"\w* \w habla|strong="H1696"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w diciendo|strong="H1696"\w*: ‘\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* Yahvé: \w Tres|strong="H7969"\w* \w cosas|strong="H2007"\w* \w te|strong="H5921"\w* ofrezco. Escoge una \w de|strong="H5921"\w* \w ellas|strong="H2007"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w yo|strong="H6213"\w* \w te|strong="H5921"\w* \w la|strong="H5921"\w* \w haga|strong="H6213"\w*.’”   
