\p
\v 3 \w David|strong="H1732"\w* reunió \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* en Jerusalén, para llevar \w el|strong="H3605"\w* arca de Yahvé \w a|strong="H3068"\w* su \w lugar|strong="H4725"\w*, \w el|strong="H3605"\w* cual \w él|strong="H3605"\w* había preparado para \w ella|strong="H3605"\w*.  
\v 4 \w David|strong="H1732"\w* reunió \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*:  
\v 5 \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat, Uriel \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y sus hermanos, \w ciento|strong="H3967"\w* \w veinte|strong="H6242"\w*;  
\v 6 \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w*, \w Asaías|strong="H6222"\w* \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y sus hermanos, \w doscientos|strong="H3967"\w* \w veinte|strong="H6242"\w*;  
\v 7 \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gersón|strong="H1648"\w*, \w Joel|strong="H3100"\w* \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y sus hermanos, \w ciento|strong="H3967"\w* \w treinta|strong="H7970"\w*;  
\v 8 \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elizafán, \w Semaías|strong="H8098"\w* \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y sus hermanos, \w doscientos|strong="H3967"\w*;  
\v 9 \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hebrón|strong="H2275"\w*, Eliel \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y sus hermanos, \w ochenta|strong="H8084"\w*;  
\v 10 \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Uziel, \w Aminadab|strong="H5992"\w* \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y sus hermanos, \w ciento|strong="H3967"\w* \w doce|strong="H8147"\w*.   
\p
\v 11 \w David|strong="H1732"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* \w Sadoc|strong="H6659"\w* y Abiatar, y \w a|strong="H3068"\w* los \w levitas|strong="H3881"\w*: Uriel, \w Asaías|strong="H6222"\w*, \w Joel|strong="H3100"\w*, \w Semaías|strong="H8098"\w*, Eliel y \w Aminadab|strong="H5992"\w*,  
\v 12 y les dijo: «Vosotros sois los \w jefes|strong="H7218"\w* de familia de los \w levitas|strong="H3881"\w*. \w Santificaos|strong="H6942"\w*, vosotros y vuestros hermanos, para que podáis \w subir|strong="H5927"\w* el arca de Yahvé, el \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*, al lugar que le he preparado.  
\v 13 \w Porque|strong="H3588"\w* \w como|strong="H3588"\w* \w no|strong="H3808"\w* \w la|strong="H3588"\w* llevasteis \w la|strong="H3588"\w* \w primera|strong="H7223"\w* vez, Yahvé nuestro \w Dios|strong="H3068"\w* irrumpió contra nosotros, \w por|strong="H3588"\w* \w no|strong="H3808"\w* haberlo buscado según \w la|strong="H3588"\w* \w ordenanza|strong="H4941"\w*.»   
\p
\v 14 Los \w sacerdotes|strong="H3548"\w* y los \w levitas|strong="H3881"\w* se santificaron para \w subir|strong="H5927"\w* el arca de Yahvé, el \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*.  
\v 15 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w llevaron|strong="H5375"\w* \w el|strong="H5921"\w* arca \w de|strong="H5921"\w* \w Dios|strong="H3068"\w* \w sobre|strong="H5921"\w* sus \w hombros|strong="H3802"\w* \w con|strong="H5921"\w* \w las|strong="H5921"\w* varas, \w tal|strong="H1697"\w* \w como|strong="H5921"\w* \w lo|strong="H1697"\w* había \w ordenado|strong="H6680"\w* \w Moisés|strong="H4872"\w* \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé.   
\p
\v 16 \w David|strong="H1732"\w* \w ordenó|strong="H5975"\w* \w a|strong="H3068"\w* los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* los \w levitas|strong="H3881"\w* que designaran \w a|strong="H3068"\w* sus hermanos como \w cantores|strong="H7891"\w* con \w instrumentos|strong="H3627"\w* musicales, liras, \w arpas|strong="H3658"\w* y \w címbalos|strong="H4700"\w*, para que tocaran y alzaran la \w voz|strong="H6963"\w* con \w alegría|strong="H8057"\w*.  
\v 17 \w Los|strong="H1121"\w* \w levitas|strong="H3881"\w* nombraron \w a|strong="H3068"\w* \w Hemán|strong="H1968"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Joel|strong="H3100"\w*, y \w de|strong="H4480"\w* sus hermanos \w a|strong="H3068"\w* Asaf \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Berequías, y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Merari|strong="H4847"\w*, sus hermanos, \w a|strong="H3068"\w* Etán \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Cusaías|strong="H6984"\w*;  
\v 18 y \w con|strong="H5973"\w* ellos \w a|strong="H3068"\w* sus hermanos \w de|strong="H5973"\w* \w segundo|strong="H4932"\w* grado: \w Zacarías|strong="H2148"\w*, Ben, Jaaziel, Semiramot, \w Jehiel|strong="H3171"\w*, Uni, Eliab, \w Benaía|strong="H1141"\w*, \w Maasías|strong="H4641"\w*, Matatías, Elifelehu, Micneías, \w Obed-Edom|strong="H5654"\w* y \w Jeiel|strong="H3273"\w*, \w los|strong="H5973"\w* \w porteros|strong="H7778"\w*.  
\v 19 \w A|strong="H3068"\w* los \w cantores|strong="H7891"\w*, \w Hemán|strong="H1968"\w*, Asaf y Etán, se les dieron \w címbalos|strong="H4700"\w* de bronce para que los hicieran sonar;  
\v 20 \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w*, Aziel, Semiramot, \w Jehiel|strong="H3171"\w*, Uni, Eliab, \w Maasías|strong="H4641"\w* \w y|strong="H5921"\w* \w Benaía|strong="H1141"\w*, liras afinadas \w a|strong="H3068"\w* tono \w de|strong="H5921"\w* Alamot;  
\v 21 \w y|strong="H5921"\w* \w a|strong="H3068"\w* Matatías, Elifelehu, Micneías, \w Obed-Edom|strong="H5654"\w*, \w Jeiel|strong="H3273"\w* \w y|strong="H5921"\w* \w Azazías|strong="H5812"\w*, \w arpas|strong="H3658"\w* afinadas \w a|strong="H3068"\w* tono \w de|strong="H5921"\w* Seminit, \w para|strong="H5921"\w* dirigir.  
\v 22 Quenanías, \w jefe|strong="H8269"\w* \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w levitas|strong="H3881"\w*, estaba \w a|strong="H3068"\w* cargo del canto. \w Él|strong="H1931"\w* instruía \w en|strong="H3588"\w* \w el|strong="H1931"\w* canto, \w porque|strong="H3588"\w* \w era|strong="H1931"\w* experto.  
\v 23 Berequías y Elcaná eran \w porteros|strong="H7778"\w* del arca.  
\v 24 \w Sebanías|strong="H7645"\w*, Josafat, Natanael, \w Amasai|strong="H6022"\w*, \w Zacarías|strong="H2148"\w*, \w Benaía|strong="H1141"\w* y Eliezer, los \w sacerdotes|strong="H3548"\w*, \w tocaban|strong="H2690"\w* las \w trompetas|strong="H2689"\w* \w delante|strong="H6440"\w* del arca \w de|strong="H6440"\w* Dios; y \w Obed-Edom|strong="H5654"\w* y Jehías eran \w porteros|strong="H7778"\w* del arca.   
\p
\v 25 Entonces \w David|strong="H1732"\w*, \w los|strong="H1961"\w* \w ancianos|strong="H2205"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* y \w los|strong="H1961"\w* \w capitanes|strong="H8269"\w* \w de|strong="H4480"\w* millares \w fueron|strong="H1961"\w* \w con|strong="H4480"\w* \w alegría|strong="H8057"\w* \w a|strong="H3068"\w* sacar el arca \w de|strong="H4480"\w* la \w alianza|strong="H1285"\w* \w de|strong="H4480"\w* Yahvé \w de|strong="H4480"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w Obed-Edom|strong="H5654"\w*.  
\v 26 \w Como|strong="H1961"\w* \w Dios|strong="H3068"\w* \w ayudó|strong="H5826"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w levitas|strong="H3881"\w* \w que|strong="H1961"\w* \w llevaban|strong="H5375"\w* el arca de la \w alianza|strong="H1285"\w* de Yahvé, \w sacrificaron|strong="H2076"\w* \w siete|strong="H7651"\w* \w novillos|strong="H6499"\w* y \w siete|strong="H7651"\w* carneros.  
\v 27 \w David|strong="H1732"\w* estaba vestido \w con|strong="H5921"\w* un \w manto|strong="H4598"\w* \w de|strong="H5921"\w* lino fino, \w al|strong="H5921"\w* igual \w que|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w que|strong="H5921"\w* \w llevaban|strong="H5375"\w* \w el|strong="H5921"\w* arca, \w los|strong="H5921"\w* \w cantores|strong="H7891"\w* \w y|strong="H5921"\w* Quenanías, \w el|strong="H5921"\w* director \w del|strong="H5921"\w* \w canto|strong="H7891"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w cantores|strong="H7891"\w*; \w David|strong="H1732"\w* también \w llevaba|strong="H5375"\w* puesto un efod \w de|strong="H5921"\w* lino.  
\v 28 Así \w subió|strong="H5927"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w el|strong="H3605"\w* arca \w de|strong="H5035"\w* \w la|strong="H3605"\w* \w alianza|strong="H1285"\w* \w de|strong="H5035"\w* Yahvé con \w júbilo|strong="H8643"\w*, con \w sonido|strong="H6963"\w* \w de|strong="H5035"\w* cuernos, \w de|strong="H5035"\w* \w trompetas|strong="H2689"\w* y \w de|strong="H5035"\w* \w címbalos|strong="H4700"\w*, tocando liras y \w arpas|strong="H3658"\w*.  
\v 29 \w Cuando|strong="H5704"\w* el arca \w de|strong="H5704"\w* \w la|strong="H4324"\w* \w alianza|strong="H1285"\w* \w de|strong="H5704"\w* Yahvé \w llegó|strong="H5704"\w* \w a|strong="H3068"\w* \w la|strong="H4324"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* \w David|strong="H1732"\w*, Mical, \w hija|strong="H1323"\w* \w de|strong="H5704"\w* \w Saúl|strong="H7586"\w*, \w se|strong="H1961"\w* asomó \w a|strong="H3068"\w* \w la|strong="H4324"\w* ventana; \w y|strong="H5704"\w* \w al|strong="H5704"\w* \w ver|strong="H7200"\w* \w al|strong="H5704"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* saltando \w y|strong="H5704"\w* bailando, \w lo|strong="H5704"\w* menospreció \w en|strong="H5704"\w* su \w corazón|strong="H3820"\w*.   
\c 16
\p
\v 1 \w Trajeron|strong="H7126"\w* el arca \w de|strong="H6440"\w* Dios y la pusieron \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H6440"\w* la tienda que \w David|strong="H1732"\w* había levantado para ella; y ofrecieron \w holocaustos|strong="H5930"\w* y ofrendas \w de|strong="H6440"\w* paz \w ante|strong="H6440"\w* Dios.  
\v 2 Cuando \w David|strong="H1732"\w* terminó \w de|strong="H5971"\w* ofrecer el \w holocausto|strong="H5930"\w* y las ofrendas \w de|strong="H5971"\w* paz, \w bendijo|strong="H1288"\w* \w al|strong="H5930"\w* \w pueblo|strong="H5971"\w* en el \w nombre|strong="H8034"\w* \w de|strong="H5971"\w* Yahvé.  
\v 3 Dio \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* israelitas, tanto hombres \w como|strong="H5704"\w* \w mujeres|strong="H5704"\w*, \w a|strong="H3068"\w* \w cada|strong="H3605"\w* uno una hogaza \w de|strong="H5704"\w* \w pan|strong="H3899"\w*, una porción \w de|strong="H5704"\w* carne \w y|strong="H5704"\w* una \w torta|strong="H3603"\w* \w de|strong="H5704"\w* pasas.   
\p
\v 4 Nombró \w a|strong="H3068"\w* algunos \w de|strong="H4480"\w* los \w levitas|strong="H3881"\w* \w para|strong="H4480"\w* \w que|strong="H4480"\w* sirvieran \w ante|strong="H6440"\w* el arca \w de|strong="H4480"\w* Yahvé, y \w para|strong="H4480"\w* \w que|strong="H4480"\w* recordaran, dieran gracias y \w alabaran|strong="H1984"\w* \w a|strong="H3068"\w* Yahvé, el \w Dios|strong="H3068"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*:  
\v 5 Asaf era el \w jefe|strong="H7218"\w*, y su \w segundo|strong="H4932"\w* era \w Zacarías|strong="H2148"\w*; luego \w Jeiel|strong="H3273"\w*, Semiramot, \w Jehiel|strong="H3171"\w*, Matatías, Eliab, \w Benaía|strong="H1141"\w*, \w Obed-Edom|strong="H5654"\w* y \w Jeiel|strong="H3273"\w*, con liras y \w arpas|strong="H3658"\w*; y Asaf hacía sonar los \w címbalos|strong="H4700"\w*;  
