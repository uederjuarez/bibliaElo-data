\p
\v 38 \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* eran hombres \w de|strong="H4480"\w* \w guerra|strong="H4421"\w* \w que|strong="H4480"\w* sabían mantener \w la|strong="H3605"\w* formación \w de|strong="H4480"\w* \w la|strong="H3605"\w* \w batalla|strong="H4421"\w*, y vinieron \w con|strong="H4480"\w* un corazón perfecto \w a|strong="H3068"\w* Hebrón \w para|strong="H4480"\w* hacer \w a|strong="H3068"\w* David rey \w de|strong="H4480"\w* \w todo|strong="H3605"\w* Israel; y también \w todos|strong="H3605"\w* \w los|strong="H3605"\w* demás \w de|strong="H4480"\w* Israel tenían un \w mismo|strong="H3605"\w* corazón \w para|strong="H4480"\w* hacer \w a|strong="H3068"\w* David rey.  
\v 39 Estuvieron allí \w con|strong="H5921"\w* \w David|strong="H1732"\w* tres días, comiendo \w y|strong="H1571"\w* bebiendo, \w pues|strong="H1571"\w* sus hermanos \w les|strong="H5921"\w* habían preparado provisiones.  
\v 40 \w Además|strong="H3588"\w*, \w los|strong="H5973"\w* \w que|strong="H3588"\w* \w estaban|strong="H1961"\w* \w cerca|strong="H5973"\w* \w de|strong="H3588"\w* ellos, \w y|strong="H3588"\w* \w hasta|strong="H3117"\w* Isacar, Zabulón \w y|strong="H3588"\w* Neftalí, trajeron pan \w en|strong="H5973"\w* asnos, \w en|strong="H5973"\w* camellos, \w en|strong="H5973"\w* mulos \w y|strong="H3588"\w* \w en|strong="H5973"\w* bueyes: provisiones \w de|strong="H3588"\w* harina, tortas \w de|strong="H3588"\w* higos, racimos \w de|strong="H3588"\w* pasas, \w vino|strong="H1961"\w*, aceite, ganado \w mayor|strong="H3588"\w* \w y|strong="H3588"\w* menor \w en|strong="H5973"\w* abundancia; \w porque|strong="H3588"\w* \w había|strong="H1961"\w* alegría \w en|strong="H5973"\w* Israel.   
\c 13
\p
\v 1 \w David|strong="H1732"\w* consultó \w con|strong="H5973"\w* \w los|strong="H3605"\w* \w capitanes|strong="H8269"\w* \w de|strong="H5973"\w* millares y \w de|strong="H5973"\w* centenas, y \w con|strong="H5973"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w*.  
\v 2 \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* asamblea \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*: «\w Si|strong="H5921"\w* \w os|strong="H4480"\w* parece \w bien|strong="H2895"\w*, \w y|strong="H5921"\w* \w si|strong="H5921"\w* es \w la|strong="H5921"\w* voluntad \w de|strong="H4480"\w* Yahvé nuestro \w Dios|strong="H3068"\w*, mandemos \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* nuestros hermanos \w que|strong="H4480"\w* han quedado \w en|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w levitas|strong="H3881"\w* \w que|strong="H4480"\w* están \w en|strong="H5921"\w* sus \w ciudades|strong="H5892"\w* \w con|strong="H5973"\w* tierras \w de|strong="H4480"\w* pastoreo, \w que|strong="H4480"\w* \w se|strong="H5921"\w* reúnan \w con|strong="H5973"\w* \w nosotros|strong="H3605"\w*.  
\v 3 \w Además|strong="H3588"\w*, traigamos \w de|strong="H3588"\w* nuevo \w el|strong="H3588"\w* arca \w de|strong="H3588"\w* nuestro Dios, \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w la|strong="H3588"\w* buscamos \w en|strong="H3588"\w* \w los|strong="H3588"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* \w Saúl|strong="H7586"\w*.»   
\p
\v 4 \w Toda|strong="H3605"\w* \w la|strong="H3588"\w* asamblea dijo \w que|strong="H3588"\w* \w lo|strong="H1697"\w* harían, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* propuesta era justa \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*.  
\v 5 Entonces \w David|strong="H1732"\w* reunió \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w desde|strong="H4480"\w* \w el|strong="H3605"\w* río \w Sihor|strong="H7883"\w* \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w* \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* entrada \w de|strong="H4480"\w* Hamat, \w para|strong="H5704"\w* traer \w el|strong="H3605"\w* arca \w de|strong="H4480"\w* Dios \w desde|strong="H4480"\w* Quiriat Jearim.   
\p
\v 6 \w David|strong="H1732"\w* \w subió|strong="H5927"\w* con \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w Baalá|strong="H1173"\w*, es \w decir|strong="H7121"\w*, \w a|strong="H3068"\w* Quiriat Jearim, \w que|strong="H3605"\w* pertenecía \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*, para hacer \w subir|strong="H5927"\w* desde \w allí|strong="H8033"\w* \w el|strong="H3605"\w* arca de \w Dios|strong="H3068"\w* \w que|strong="H3605"\w* se asienta sobre \w los|strong="H3427"\w* \w querubines|strong="H3742"\w*, \w donde|strong="H8033"\w* se invoca su \w Nombre|strong="H8034"\w*.  
\v 7 Llevaron \w el|strong="H5921"\w* arca \w de|strong="H5921"\w* Dios \w en|strong="H5921"\w* un \w carro|strong="H5699"\w* \w nuevo|strong="H2319"\w*, sacándola \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Abinadab; Uza \w y|strong="H5921"\w* Ahío conducían \w el|strong="H5921"\w* \w carro|strong="H5699"\w*.  
\v 8 \w David|strong="H1732"\w* \w y|strong="H5797"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* celebraban \w ante|strong="H6440"\w* Dios con \w toda|strong="H3605"\w* su fuerza, con cantos, con \w arpas|strong="H3658"\w*, con liras, con panderetas, con \w címbalos|strong="H4700"\w* \w y|strong="H5797"\w* con \w trompetas|strong="H2689"\w*.   
\p
\v 9 \w Cuando|strong="H3588"\w* llegaron \w a|strong="H3068"\w* \w la|strong="H3588"\w* era \w de|strong="H3588"\w* Quidón, Uza \w extendió|strong="H7971"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w para|strong="H5704"\w* sostener \w el|strong="H3588"\w* arca, \w pues|strong="H3588"\w* \w los|strong="H3588"\w* \w bueyes|strong="H1241"\w* tropezaron.  
\v 10 \w La|strong="H5921"\w* ira \w de|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* encendió \w contra|strong="H5921"\w* Uza, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w hirió|strong="H5221"\w* \w porque|strong="H5921"\w* había puesto su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* arca; \w y|strong="H5921"\w* \w allí|strong="H8033"\w* \w murió|strong="H4191"\w* \w ante|strong="H6440"\w* \w Dios|strong="H3068"\w*.  
\v 11 \w David|strong="H1732"\w* \w se|strong="H1931"\w* disgustó \w porque|strong="H3588"\w* Yahvé \w había|strong="H3588"\w* irrumpido contra Uza. \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w ese|strong="H1931"\w* \w lugar|strong="H4725"\w* Pérez Uza, \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w hoy|strong="H3117"\w*.  
\v 12 \w Ese|strong="H1931"\w* \w día|strong="H3117"\w* \w David|strong="H1732"\w* \w tuvo|strong="H3372"\w* \w miedo|strong="H3372"\w* \w de|strong="H3372"\w* Dios, diciendo: «¿\w Cómo|strong="H1963"\w* voy \w a|strong="H3068"\w* llevar \w el|strong="H1931"\w* arca \w de|strong="H3372"\w* Dios \w a|strong="H3068"\w* mi casa?»  
\v 13 Así \w que|strong="H3808"\w* \w David|strong="H1732"\w* \w no|strong="H3808"\w* trasladó el arca con él \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w* de \w David|strong="H1732"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* la desvió \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de \w Obed-Edom|strong="H5654"\w* el geteo.  
\v 14 \w El|strong="H5973"\w* arca \w de|strong="H5973"\w* \w Dios|strong="H3068"\w* permaneció \w con|strong="H5973"\w* \w la|strong="H3605"\w* \w familia|strong="H1004"\w* \w de|strong="H5973"\w* \w Obed-Edom|strong="H5654"\w* \w en|strong="H5973"\w* su \w casa|strong="H1004"\w* durante \w tres|strong="H7969"\w* \w meses|strong="H2320"\w*; y \w el|strong="H5973"\w* \w Señor|strong="H3068"\w* \w bendijo|strong="H1288"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Obed-Edom|strong="H5654"\w* y \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tenía.   
\c 14
\p
\v 1 \w Hiram|strong="H2438"\w*, \w rey|strong="H4428"\w* de \w Tiro|strong="H6865"\w*, \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* con cedros, canteros y \w carpinteros|strong="H2796"\w* para que le construyeran una \w casa|strong="H1004"\w*.  
\v 2 \w David|strong="H1732"\w* \w reconoció|strong="H3045"\w* \w que|strong="H3588"\w* Yahvé \w lo|strong="H5921"\w* \w había|strong="H3588"\w* \w establecido|strong="H3559"\w* \w como|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w pues|strong="H3588"\w* \w su|strong="H3588"\w* \w reino|strong="H4438"\w* era \w muy|strong="H4605"\w* exaltado, \w por|strong="H5921"\w* amor \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.   
\p
\v 3 \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* \w más|strong="H5750"\w* \w mujeres|strong="H1323"\w* \w en|strong="H5750"\w* Jerusalén, y \w engendró|strong="H3205"\w* \w más|strong="H5750"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.  
\v 4 Estos \w son|strong="H1961"\w* \w los|strong="H1961"\w* \w nombres|strong="H8034"\w* de \w los|strong="H1961"\w* hijos \w que|strong="H1961"\w* \w tuvo|strong="H1961"\w* en Jerusalén: \w Samúa|strong="H8051"\w*, \w Sobab|strong="H7727"\w*, Natán, \w Salomón|strong="H8010"\w*,  
\v 5 \w Ibhar|strong="H2984"\w*, Elisúa, Elfelet,  
\v 6 \w Noga|strong="H5052"\w*, Néfeg, Jafía,  
\v 7 Elisama, Beeliada y Elifelet.   
\p
\v 8 \w Cuando|strong="H3588"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w David|strong="H1732"\w* \w había|strong="H3588"\w* sido \w ungido|strong="H4886"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w subieron|strong="H5927"\w* \w en|strong="H5921"\w* \w busca|strong="H1245"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*; \w pero|strong="H3588"\w* \w David|strong="H1732"\w* \w lo|strong="H5921"\w* \w supo|strong="H8085"\w* \w y|strong="H3588"\w* \w salió|strong="H3318"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 9 Los \w filisteos|strong="H6430"\w* habían llegado y hecho una incursión en el \w valle|strong="H6010"\w* de Refaim.  
\v 10 \w David|strong="H1732"\w* \w consultó|strong="H7592"\w* \w a|strong="H3068"\w* \w Dios|strong="H3068"\w*, diciendo: «¿\w Subiré|strong="H5927"\w* \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w*? ¿\w Los|strong="H5921"\w* entregarás \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*?»  
\p Yahvé \w le|strong="H5921"\w* respondió: «\w Sube|strong="H5927"\w*, \w porque|strong="H5921"\w* \w los|strong="H5921"\w* \w entregaré|strong="H5414"\w* \w en|strong="H5921"\w* tu \w mano|strong="H3027"\w*.»   
\p
\v 11 \w Así|strong="H3651"\w* \w que|strong="H1931"\w* \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* Baal Perazim, \w y|strong="H5921"\w* \w David|strong="H1732"\w* \w los|strong="H5921"\w* derrotó \w allí|strong="H8033"\w*. \w David|strong="H1732"\w* dijo: «Dios ha roto \w a|strong="H3068"\w* mis enemigos \w por|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*, \w como|strong="H5921"\w* \w aguas|strong="H4325"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* desbordan.» \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w llamaron|strong="H7121"\w* \w a|strong="H3068"\w* \w ese|strong="H1931"\w* \w lugar|strong="H4725"\w* Baal Perazim. \f + \fr 14:11 \ft «Baal Perazim» significa «El Señor que irrumpe».\f*  
\v 12 \w Dejaron|strong="H5800"\w* \w allí|strong="H8033"\w* sus dioses, y \w David|strong="H1732"\w* dio la orden, y \w fueron|strong="H1732"\w* quemados en el fuego.   
\p
\v 13 Los \w filisteos|strong="H6430"\w* hicieron \w otra|strong="H5750"\w* incursión \w en|strong="H5750"\w* el \w valle|strong="H6010"\w*.  
\v 14 \w David|strong="H1732"\w* \w volvió|strong="H5750"\w* \w a|strong="H3068"\w* consultar \w a|strong="H3068"\w* Dios, \w y|strong="H5921"\w* Dios \w le|strong="H5921"\w* dijo: «\w No|strong="H3808"\w* \w subas|strong="H5927"\w* tras \w ellos|strong="H1992"\w*. Rodéalos, \w y|strong="H5921"\w* acércate \w a|strong="H3068"\w* \w ellos|strong="H1992"\w* frente \w a|strong="H3068"\w* \w las|strong="H1992"\w* balsameras.  
\v 15 \w Cuando|strong="H3588"\w* \w oigas|strong="H8085"\w* \w el|strong="H3588"\w* \w ruido|strong="H6963"\w* \w de|strong="H3588"\w* marcha \w en|strong="H3588"\w* las copas \w de|strong="H3588"\w* las balsameras, \w sal|strong="H3318"\w* \w a|strong="H3068"\w* \w combatir|strong="H4421"\w*, \w porque|strong="H3588"\w* Dios \w habrá|strong="H1961"\w* \w salido|strong="H3318"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti \w para|strong="H3588"\w* atacar al \w ejército|strong="H4264"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*.»   
\p
\v 16 \w David|strong="H1732"\w* \w hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H5704"\w* Dios le \w ordenó|strong="H6680"\w*, \w y|strong="H5704"\w* derrotaron \w al|strong="H5704"\w* \w ejército|strong="H4264"\w* \w de|strong="H5704"\w* los \w filisteos|strong="H6430"\w* \w desde|strong="H5704"\w* \w Gabaón|strong="H1391"\w* \w hasta|strong="H5704"\w* \w Gezer|strong="H1507"\w*.  
\v 17 \w La|strong="H5921"\w* \w fama|strong="H8034"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w se|strong="H5921"\w* extendió \w por|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* tierras, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* \w hizo|strong="H5414"\w* \w que|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w lo|strong="H5921"\w* temieran.   
\c 15
\p
\v 1 \w David|strong="H1732"\w* se \w edificó|strong="H6213"\w* \w casas|strong="H1004"\w* en la \w ciudad|strong="H5892"\w* de \w David|strong="H1732"\w*, y \w preparó|strong="H3559"\w* un \w lugar|strong="H4725"\w* para \w el|strong="H6213"\w* arca de Dios, y le levantó una tienda.  
