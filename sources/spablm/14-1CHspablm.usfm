\p
\v 1 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Rubén|strong="H7205"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* (\w pues|strong="H3588"\w* \w él|strong="H1931"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* \w primogénito|strong="H1060"\w*, \w pero|strong="H3588"\w* \w por|strong="H3588"\w* \w haber|strong="H3808"\w* \w profanado|strong="H2490"\w* \w el|strong="H1931"\w* lecho \w de|strong="H3588"\w* \w su|strong="H1931"\w* padre, \w su|strong="H1931"\w* primogenitura \w fue|strong="H1931"\w* \w entregada|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w José|strong="H3130"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*; \w y|strong="H3588"\w* \w la|strong="H1931"\w* genealogía \w no|strong="H3808"\w* debe enumerarse según \w la|strong="H1931"\w* primogenitura.  
\v 2 \w Porque|strong="H3588"\w* \w Judá|strong="H3063"\w* prevaleció \w sobre|strong="H4480"\w* sus hermanos, \w y|strong="H3588"\w* \w de|strong="H4480"\w* \w él|strong="H3588"\w* salió \w el|strong="H3588"\w* \w príncipe|strong="H5057"\w*; \w pero|strong="H3588"\w* \w la|strong="H3588"\w* primogenitura \w fue|strong="H3063"\w* \w de|strong="H4480"\w* \w José|strong="H3130"\w*):  
