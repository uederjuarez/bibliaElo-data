\v 42 Algunos \w de|strong="H4480"\w* \w ellos|strong="H1992"\w*, \w de|strong="H4480"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Simeón|strong="H8095"\w*, \w quinientos|strong="H2568"\w* \w hombres|strong="H1121"\w*, \w fueron|strong="H1980"\w* \w al|strong="H4480"\w* \w monte|strong="H2022"\w* \w de|strong="H4480"\w* \w Seir|strong="H8165"\w*, teniendo \w por|strong="H4480"\w* \w capitanes|strong="H7218"\w* \w a|strong="H3068"\w* \w Pelatías|strong="H6410"\w*, \w Nearías|strong="H5294"\w*, Refaías y Uziel, \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Isi|strong="H3469"\w*.  
\v 43 Destruyeron \w al|strong="H5704"\w* \w resto|strong="H7611"\w* \w de|strong="H5704"\w* \w los|strong="H3427"\w* amalecitas \w que|strong="H5704"\w* escaparon, \w y|strong="H5704"\w* han habitado \w allí|strong="H8033"\w* \w hasta|strong="H5704"\w* \w el|strong="H3427"\w* \w día|strong="H3117"\w* \w de|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
