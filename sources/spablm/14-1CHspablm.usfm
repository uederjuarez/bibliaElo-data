\p
\v 7 “\w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w así|strong="H3541"\w* dirás \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* \w David|strong="H1732"\w*: ‘\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*: \w Yo|strong="H4480"\w* \w te|strong="H5921"\w* \w tomé|strong="H3947"\w* \w del|strong="H4480"\w* redil, \w de|strong="H4480"\w* seguir \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w*, \w para|strong="H5921"\w* \w que|strong="H4480"\w* fueras \w príncipe|strong="H5057"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.  
\v 8 He \w estado|strong="H1961"\w* \w contigo|strong="H5973"\w* \w por|strong="H6440"\w* dondequiera \w que|strong="H1961"\w* has \w andado|strong="H1980"\w*, y he exterminado \w a|strong="H3068"\w* \w todos|strong="H3605"\w* tus enemigos \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ti|strong="H5973"\w*. \w Te|strong="H5973"\w* \w haré|strong="H6213"\w* un \w nombre|strong="H8034"\w* \w como|strong="H5973"\w* \w el|strong="H5973"\w* \w nombre|strong="H8034"\w* \w de|strong="H6440"\w* \w los|strong="H3605"\w* \w grandes|strong="H1419"\w* \w que|strong="H1961"\w* \w hay|strong="H1961"\w* \w en|strong="H5973"\w* \w la|strong="H3605"\w* tierra.  
\v 9 Yo designaré un \w lugar|strong="H4725"\w* \w para|strong="H5971"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, y \w lo|strong="H3808"\w* \w plantaré|strong="H5193"\w*, \w para|strong="H5971"\w* \w que|strong="H3808"\w* habite \w en|strong="H5750"\w* su propio \w lugar|strong="H4725"\w* y \w no|strong="H3808"\w* sea removido \w más|strong="H5750"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* \w iniquidad|strong="H5766"\w* \w no|strong="H3808"\w* \w los|strong="H1121"\w* oprimirán \w más|strong="H5750"\w*, \w como|strong="H8478"\w* \w al|strong="H8478"\w* principio,  
\v 10 \w y|strong="H5921"\w* \w como|strong="H5921"\w* \w desde|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w en|strong="H5921"\w* \w que|strong="H5921"\w* \w puse|strong="H6680"\w* \w jueces|strong="H8199"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*. Someteré \w a|strong="H3068"\w* \w todos|strong="H3605"\w* tus enemigos. \w Además|strong="H5921"\w*, \w te|strong="H5921"\w* \w declaro|strong="H5046"\w* \w que|strong="H5921"\w* Yahvé \w te|strong="H5921"\w* \w edificará|strong="H1129"\w* una \w casa|strong="H1004"\w*.  
\v 11 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w se|strong="H1961"\w* cumplan tus \w días|strong="H3117"\w* \w para|strong="H3588"\w* \w ir|strong="H3212"\w* \w a|strong="H3068"\w* estar \w con|strong="H5973"\w* tus padres, \w yo|strong="H3588"\w* \w levantaré|strong="H6965"\w* \w a|strong="H3068"\w* tu \w descendencia|strong="H2233"\w* \w después|strong="H1961"\w* \w de|strong="H3588"\w* \w ti|strong="H5973"\w*, \w a|strong="H3068"\w* uno \w de|strong="H3588"\w* tus \w hijos|strong="H1121"\w*, \w y|strong="H3588"\w* afirmaré \w su|strong="H3588"\w* \w reino|strong="H4438"\w*.  
\v 12 \w Él|strong="H1931"\w* me \w edificará|strong="H1129"\w* una \w casa|strong="H1004"\w*, \w y|strong="H5704"\w* yo estableceré \w su|strong="H1931"\w* \w trono|strong="H3678"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.  
\v 13 Yo \w seré|strong="H1961"\w* \w para|strong="H1961"\w* \w él|strong="H1931"\w* padre, y \w él|strong="H1931"\w* \w será|strong="H1961"\w* \w para|strong="H1961"\w* \w mí|strong="H1961"\w* \w hijo|strong="H1121"\w*. \w No|strong="H3808"\w* apartaré \w de|strong="H6440"\w* \w él|strong="H1931"\w* \w mi|strong="H1961"\w* \w misericordia|strong="H2617"\w*, \w como|strong="H5973"\w* \w la|strong="H1931"\w* \w aparté|strong="H5973"\w* \w del|strong="H5973"\w* \w que|strong="H1931"\w* \w fue|strong="H1961"\w* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* \w ti|strong="H5973"\w*;  
\v 14 sino \w que|strong="H5704"\w* \w lo|strong="H5704"\w* \w confirmaré|strong="H3559"\w* \w en|strong="H5704"\w* \w mi|strong="H1961"\w* \w casa|strong="H1004"\w* \w y|strong="H5704"\w* \w en|strong="H5704"\w* \w mi|strong="H1961"\w* \w reino|strong="H4438"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*. Su \w trono|strong="H3678"\w* \w quedará|strong="H1961"\w* \w establecido|strong="H3559"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.’”  
\v 15 Conforme \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w estas|strong="H2088"\w* \w palabras|strong="H1697"\w* y conforme \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w esta|strong="H2088"\w* \w visión|strong="H2377"\w*, \w así|strong="H3651"\w* \w habló|strong="H1696"\w* Natán \w a|strong="H3068"\w* \w David|strong="H1732"\w*.   
\p
\v 16 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* entró \w y|strong="H3588"\w* se sentó \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Yahvé, \w y|strong="H3588"\w* dijo: “¿\w Quién|strong="H4310"\w* soy \w yo|strong="H3588"\w*, Yahvé \w Dios|strong="H3068"\w*, \w y|strong="H3588"\w* \w qué|strong="H3588"\w* \w es|strong="H3588"\w* mi \w casa|strong="H1004"\w*, \w para|strong="H5704"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* hayas traído \w hasta|strong="H5704"\w* \w aquí|strong="H1988"\w*?  
\v 17 \w Y|strong="H3068"\w* aun \w esto|strong="H2063"\w* \w te|strong="H5869"\w* ha parecido \w poco|strong="H6994"\w*, oh \w Dios|strong="H3068"\w*, \w pues|strong="H7200"\w* has \w hablado|strong="H1696"\w* \w del|strong="H5921"\w* porvenir \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* tu \w siervo|strong="H5650"\w*, \w y|strong="H5921"\w* \w me|strong="H5921"\w* has mirado \w como|strong="H5921"\w* \w a|strong="H3068"\w* un hombre \w de|strong="H5921"\w* \w alto|strong="H4609"\w* rango, Yahvé \w Dios|strong="H3068"\w*.  
\v 18 ¿\w Qué|strong="H4100"\w* \w más|strong="H5750"\w* puede añadir \w David|strong="H1732"\w* ante ti sobre el honor concedido \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w*? \w Porque|strong="H4100"\w* tú \w conoces|strong="H3045"\w* \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w*.  
\v 19 Yahvé, \w por|strong="H5668"\w* amor \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w siervo|strong="H5650"\w* y según \w tu|strong="H6213"\w* propio \w corazón|strong="H3820"\w*, has realizado \w toda|strong="H3605"\w* \w esta|strong="H2063"\w* grandeza, para dar \w a|strong="H3068"\w* conocer \w todas|strong="H3605"\w* \w estas|strong="H2063"\w* \w maravillas|strong="H6213"\w*.  
\v 20 Yahvé, no hay \w nadie|strong="H3605"\w* \w como|strong="H3644"\w* tú, ni hay \w Dios|strong="H3068"\w* \w fuera|strong="H2108"\w* \w de|strong="H2108"\w* ti, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* hemos \w oído|strong="H8085"\w* con nuestros \w oídos|strong="H8085"\w*.  
\v 21 ¿\w Y|strong="H3068"\w* \w qué|strong="H4310"\w* otra \w nación|strong="H1471"\w* en la tierra es como tu \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, al \w cual|strong="H4310"\w* Dios \w fue|strong="H1980"\w* \w a|strong="H3068"\w* \w redimir|strong="H6299"\w* \w para|strong="H5971"\w* \w que|strong="H4310"\w* fuera su propio \w pueblo|strong="H5971"\w*, \w para|strong="H5971"\w* hacerte un \w nombre|strong="H8034"\w* con hazañas \w grandes|strong="H1420"\w* y asombrosas, al expulsar \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* tu \w pueblo|strong="H5971"\w* \w que|strong="H4310"\w* \w redimiste|strong="H6299"\w* \w de|strong="H6440"\w* \w Egipto|strong="H4714"\w*?  
\v 22 Porque constituiste \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w* \w para|strong="H5704"\w* \w que|strong="H5704"\w* \w fuera|strong="H1961"\w* tu \w pueblo|strong="H5971"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*; \w y|strong="H5704"\w* tú, Yahvé, \w has|strong="H5414"\w* llegado \w a|strong="H3068"\w* ser su \w Dios|strong="H3068"\w*.  
\v 23 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, Yahvé, \w que|strong="H6258"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w que|strong="H6258"\w* has pronunciado \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w tu|strong="H6213"\w* \w siervo|strong="H5650"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* su \w casa|strong="H1004"\w* sea firme \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*, \w y|strong="H5921"\w* \w haz|strong="H6213"\w* \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w lo|strong="H1697"\w* \w que|strong="H6258"\w* has \w dicho|strong="H1696"\w*.  
\v 24 \w Que|strong="H5704"\w* tu \w nombre|strong="H8034"\w* sea \w establecido|strong="H3559"\w* \w y|strong="H5704"\w* \w engrandecido|strong="H1431"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*, \w y|strong="H5704"\w* \w que|strong="H5704"\w* se diga: ‘El \w Señor|strong="H3068"\w* \w de|strong="H6440"\w* los \w Ejércitos|strong="H6635"\w*, el \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, es \w Dios|strong="H3068"\w* \w para|strong="H5704"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w David|strong="H1732"\w*, tu \w siervo|strong="H5650"\w*, permanezca \w firme|strong="H3559"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti.’  
\v 25 \w Porque|strong="H3588"\w* tú, Dios \w mío|strong="H5921"\w*, has revelado \w al|strong="H5921"\w* oído \w de|strong="H5921"\w* tu \w siervo|strong="H5650"\w* \w que|strong="H3588"\w* \w le|strong="H5921"\w* \w edificarás|strong="H1129"\w* \w una|strong="H4672"\w* \w casa|strong="H1004"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* tu \w siervo|strong="H5650"\w* ha \w hallado|strong="H4672"\w* valor \w para|strong="H5921"\w* orar \w en|strong="H5921"\w* tu \w presencia|strong="H6440"\w*.  
\v 26 \w Ahora|strong="H6258"\w* \w bien|strong="H2896"\w*, Yahvé, tú \w eres|strong="H1931"\w* \w Dios|strong="H3068"\w*, \w y|strong="H5921"\w* has prometido \w este|strong="H1931"\w* \w bien|strong="H2896"\w* \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w*.  
\v 27 \w Ahora|strong="H6258"\w* \w te|strong="H3588"\w* ha placido bendecir \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* tu \w siervo|strong="H5650"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* permanezca \w para|strong="H3588"\w* \w siempre|strong="H5769"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti; \w porque|strong="H3588"\w* lo \w que|strong="H3588"\w* tú \w bendices|strong="H1288"\w*, Yahvé, queda \w bendito|strong="H1288"\w* \w para|strong="H3588"\w* \w siempre|strong="H5769"\w*.”   
\c 18
\p
\v 1 \w Después|strong="H1961"\w* de \w esto|strong="H3651"\w*, \w David|strong="H1732"\w* derrotó \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w* y \w los|strong="H1961"\w* sometió, y arrebató Gat y sus \w aldeas|strong="H1323"\w* de \w manos|strong="H3027"\w* de \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*.  
\v 2 Derrotó también \w a|strong="H3068"\w* \w Moab|strong="H4124"\w*, y \w los|strong="H1961"\w* moabitas \w se|strong="H1961"\w* convirtieron \w en|strong="H5221"\w* \w siervos|strong="H5650"\w* de \w David|strong="H1732"\w*, pagándole \w tributo|strong="H4503"\w*.   
\p
\v 3 \w David|strong="H1732"\w* derrotó \w a|strong="H3068"\w* Hadadézer, \w rey|strong="H4428"\w* de Soba, \w en|strong="H3212"\w* Hamat, cuando este \w iba|strong="H3212"\w* \w a|strong="H3068"\w* establecer su dominio \w junto|strong="H3027"\w* \w al|strong="H4428"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*.  
\v 4 \w David|strong="H1732"\w* le capturó \w mil|strong="H3967"\w* \w carros|strong="H7393"\w*, \w siete|strong="H7651"\w* \w mil|strong="H3967"\w* \w jinetes|strong="H6571"\w* y \w veinte|strong="H6242"\w* \w mil|strong="H3967"\w* soldados \w de|strong="H4480"\w* \w a|strong="H3068"\w* pie; y \w desjarretó|strong="H6131"\w* \w David|strong="H1732"\w* \w los|strong="H3605"\w* caballos \w de|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w carros|strong="H7393"\w*, pero reservó \w los|strong="H3605"\w* suficientes \w para|strong="H4480"\w* \w cien|strong="H3967"\w* \w carros|strong="H7393"\w*.  
\v 5 Cuando los sirios de \w Damasco|strong="H1834"\w* vinieron \w a|strong="H3068"\w* socorrer \w a|strong="H3068"\w* Hadadézer, \w rey|strong="H4428"\w* de Soba, \w David|strong="H1732"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w veintidós|strong="H6242"\w* mil \w hombres|strong="H8147"\w* de los sirios.  
\v 6 Luego \w David|strong="H1732"\w* \w puso|strong="H7760"\w* guarniciones en \w la|strong="H3605"\w* Siria de \w Damasco|strong="H1834"\w*, y \w los|strong="H3605"\w* sirios \w se|strong="H1961"\w* convirtieron en \w siervos|strong="H5650"\w* de \w David|strong="H1732"\w*, pagándole \w tributo|strong="H4503"\w*. \w El|strong="H3605"\w* \w Señor|strong="H3068"\w* daba \w la|strong="H3605"\w* victoria \w a|strong="H3068"\w* \w David|strong="H1732"\w* por dondequiera \w que|strong="H1961"\w* \w iba|strong="H1980"\w*.  
\v 7 \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* \w los|strong="H5921"\w* \w escudos|strong="H7982"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w que|strong="H5921"\w* \w llevaban|strong="H1961"\w* \w los|strong="H5921"\w* \w siervos|strong="H5650"\w* \w de|strong="H5921"\w* Hadadézer \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w llevó|strong="H3947"\w* \w a|strong="H3068"\w* Jerusalén.  
\v 8 Asimismo, de Tibhat y de Cun, \w ciudades|strong="H5892"\w* de Hadadézer, \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* muchísimo bronce, con \w el|strong="H6213"\w* cual \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w mar|strong="H3220"\w* de bronce, las \w columnas|strong="H5982"\w* y los utensilios de bronce.   
\p
\v 9 \w Cuando|strong="H3588"\w* \w Tou|strong="H8583"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Hamat, se enteró \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w David|strong="H1732"\w* \w había|strong="H3588"\w* derrotado \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w ejército|strong="H2426"\w* \w de|strong="H3588"\w* Hadadézer, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Soba,  
\v 10 \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* Hadoram \w para|strong="H5921"\w* saludar \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w y|strong="H3588"\w* felicitarle, \w porque|strong="H3588"\w* \w había|strong="H1961"\w* peleado \w contra|strong="H5921"\w* Hadadézer \w y|strong="H3588"\w* \w lo|strong="H5921"\w* \w había|strong="H1961"\w* vencido (\w pues|strong="H3588"\w* Hadadézer \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w guerra|strong="H4421"\w* \w con|strong="H5921"\w* \w Tou|strong="H8583"\w*); \w y|strong="H3588"\w* \w le|strong="H5921"\w* llevó \w toda|strong="H3605"\w* clase \w de|strong="H5921"\w* objetos \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* bronce.  
\v 11 \w El|strong="H5973"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w también|strong="H1571"\w* \w los|strong="H1121"\w* \w dedicó|strong="H6942"\w* \w a|strong="H3068"\w* Yahvé, \w junto|strong="H5973"\w* \w con|strong="H5973"\w* \w la|strong="H1571"\w* \w plata|strong="H3701"\w* \w y|strong="H1571"\w* \w el|strong="H5973"\w* \w oro|strong="H2091"\w* \w que|strong="H1571"\w* \w había|strong="H6942"\w* tomado \w de|strong="H5973"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w*: \w de|strong="H5973"\w* Edom, \w de|strong="H5973"\w* \w Moab|strong="H4124"\w*, \w de|strong="H5973"\w* \w los|strong="H1121"\w* amonitas, \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w y|strong="H1571"\w* \w de|strong="H5973"\w* \w Amalec|strong="H6002"\w*.   
\p
\v 12 Además, Abisai, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia, derrotó \w a|strong="H3068"\w* \w dieciocho|strong="H8083"\w* mil edomitas \w en|strong="H5221"\w* \w el|strong="H1121"\w* \w Valle|strong="H1516"\w* \w de|strong="H1121"\w* la \w Sal|strong="H4417"\w*.  
\v 13 \w Puso|strong="H7760"\w* guarniciones en Edom, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* edomitas \w se|strong="H1961"\w* convirtieron en \w siervos|strong="H5650"\w* de \w David|strong="H1732"\w*. \w El|strong="H3605"\w* \w Señor|strong="H3068"\w* daba \w la|strong="H3605"\w* victoria \w a|strong="H3068"\w* \w David|strong="H1732"\w* por dondequiera \w que|strong="H1961"\w* \w iba|strong="H1980"\w*.   
\p
\v 14 \w David|strong="H1732"\w* \w reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* administraba \w el|strong="H5921"\w* \w derecho|strong="H4941"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w justicia|strong="H6666"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* su \w pueblo|strong="H5971"\w*.  
\v 15 \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Sarvia, \w era|strong="H1121"\w* \w el|strong="H5921"\w* jefe \w del|strong="H5921"\w* \w ejército|strong="H6635"\w*; Josafat, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ahilud, \w era|strong="H1121"\w* \w el|strong="H5921"\w* cronista;  
\v 16 \w Sadoc|strong="H6659"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahitob, y Ahimelec, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abiatar, eran \w sacerdotes|strong="H3548"\w*; Savsa \w era|strong="H1121"\w* \w el|strong="H1121"\w* \w escriba|strong="H5608"\w*;  
\v 17 \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Joiada|strong="H3077"\w*, estaba \w al|strong="H5921"\w* mando \w de|strong="H5921"\w* \w los|strong="H1121"\w* cereteos \w y|strong="H5921"\w* peleteos; \w y|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* eran \w los|strong="H1121"\w* funcionarios principales \w al|strong="H5921"\w* \w lado|strong="H3027"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.   
\c 19
\p
\v 1 \w Después|strong="H1961"\w* \w de|strong="H8478"\w* \w esto|strong="H3651"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w murió|strong="H4191"\w* Nahas, \w rey|strong="H4428"\w* \w de|strong="H8478"\w* \w los|strong="H1121"\w* amonitas, y su \w hijo|strong="H1121"\w* \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w*.  
\v 2 \w Y|strong="H3068"\w* dijo \w David|strong="H1732"\w*: «Mostraré bondad \w a|strong="H3068"\w* \w Hanún|strong="H2586"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nahas, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* padre mostró bondad \w conmigo|strong="H5973"\w*.» \w Entonces|strong="H3588"\w* \w David|strong="H1732"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w para|strong="H5921"\w* consolarle \w por|strong="H5921"\w* \w la|strong="H5921"\w* muerte \w de|strong="H5921"\w* \w su|strong="H3588"\w* padre. \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* \w los|strong="H1121"\w* \w siervos|strong="H5650"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* llegaron \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w los|strong="H1121"\w* amonitas \w para|strong="H5921"\w* consolar \w a|strong="H3068"\w* \w Hanún|strong="H2586"\w*,  
\v 3 \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* amonitas \w le|strong="H5869"\w* dijeron \w a|strong="H3068"\w* \w Hanún|strong="H2586"\w*: «¿Acaso crees \w que|strong="H3588"\w* \w David|strong="H1732"\w* \w honra|strong="H3513"\w* \w a|strong="H3068"\w* tu padre al enviarte \w consoladores|strong="H5162"\w*? ¿\w No|strong="H3808"\w* han venido \w a|strong="H3068"\w* ti sus \w siervos|strong="H5650"\w* \w más|strong="H3588"\w* \w bien|strong="H3588"\w* \w para|strong="H3588"\w* explorar, destruir \w y|strong="H3588"\w* espiar \w la|strong="H3588"\w* tierra?»  
\v 4 Entonces \w Hanún|strong="H2586"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* los \w siervos|strong="H5650"\w* \w de|strong="H5704"\w* \w David|strong="H1732"\w*, los rapó, les \w cortó|strong="H3772"\w* las vestiduras \w por|strong="H5704"\w* la mitad, \w hasta|strong="H5704"\w* las nalgas, \w y|strong="H5704"\w* los \w despidió|strong="H7971"\w*.  
\v 5 \w Cuando|strong="H3588"\w* algunos \w fueron|strong="H1961"\w* \w y|strong="H3588"\w* \w le|strong="H5921"\w* \w contaron|strong="H5046"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w les|strong="H5921"\w* \w había|strong="H1961"\w* sucedido \w a|strong="H3068"\w* aquellos hombres, \w él|strong="H5921"\w* \w envió|strong="H7971"\w* emisarios \w a|strong="H3068"\w* recibirlos, \w porque|strong="H3588"\w* \w estaban|strong="H1961"\w* \w sumamente|strong="H3966"\w* \w avergonzados|strong="H3637"\w*. \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w les|strong="H5921"\w* \w dijo|strong="H5046"\w*: «Quedaos \w en|strong="H5921"\w* \w Jericó|strong="H3405"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w os|strong="H5921"\w* crezca \w la|strong="H5921"\w* \w barba|strong="H2206"\w*, \w y|strong="H3588"\w* \w entonces|strong="H3588"\w* regresad.»   
\p
\v 6 \w Al|strong="H4480"\w* \w ver|strong="H7200"\w* \w los|strong="H1121"\w* amonitas \w que|strong="H3588"\w* \w se|strong="H4480"\w* habían hecho odiosos \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w Hanún|strong="H2586"\w* \w y|strong="H3588"\w* \w los|strong="H1121"\w* amonitas \w enviaron|strong="H7971"\w* mil \w talentos|strong="H3603"\w*\f + \fr 19:6 \ft Un talento equivale a unos 30 kilogramos o 66 libras, por lo que 1000 talentos son unas 30 toneladas métricas\f* \w de|strong="H4480"\w* \w plata|strong="H3701"\w* \w para|strong="H3588"\w* alquilar \w carros|strong="H7393"\w* \w y|strong="H3588"\w* \w jinetes|strong="H6571"\w* \w de|strong="H4480"\w* Mesopotamia, \w de|strong="H4480"\w* Aram-maacá \w y|strong="H3588"\w* \w de|strong="H4480"\w* Soba.  
\v 7 Contrataron \w treinta|strong="H7970"\w* y \w dos|strong="H8147"\w* mil \w carros|strong="H7393"\w*, y \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Maaca con su \w gente|strong="H5971"\w*, \w los|strong="H1121"\w* cuales vinieron y acamparon \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Medeba|strong="H4311"\w*. \w Los|strong="H1121"\w* amonitas también \w se|strong="H5971"\w* reunieron \w de|strong="H6440"\w* sus \w ciudades|strong="H5892"\w* y acudieron \w a|strong="H3068"\w* la \w batalla|strong="H4421"\w*.  
\v 8 Cuando \w David|strong="H1732"\w* \w lo|strong="H3605"\w* \w oyó|strong="H8085"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Joab|strong="H3097"\w* con \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ejército|strong="H6635"\w* de \w los|strong="H3605"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*.  
\v 9 \w Los|strong="H1121"\w* amonitas \w salieron|strong="H3318"\w* y se pusieron \w en|strong="H3318"\w* orden \w de|strong="H1121"\w* \w batalla|strong="H4421"\w* \w a|strong="H3068"\w* la entrada \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w*, mientras \w que|strong="H1121"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w que|strong="H1121"\w* habían venido estaban aparte \w en|strong="H3318"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w*.   
\p
\v 10 Al \w ver|strong="H7200"\w* \w Joab|strong="H3097"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w frente|strong="H7125"\w* \w de|strong="H3588"\w* \w batalla|strong="H4421"\w* \w estaba|strong="H1961"\w* \w contra|strong="H7125"\w* \w él|strong="H3588"\w* \w por|strong="H3588"\w* \w delante|strong="H6440"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* detrás, escogió \w a|strong="H3068"\w* \w los|strong="H3605"\w* mejores hombres \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w los|strong="H3605"\w* \w puso|strong="H6186"\w* \w en|strong="H3588"\w* orden \w de|strong="H3588"\w* \w batalla|strong="H4421"\w* \w contra|strong="H7125"\w* \w los|strong="H3605"\w* sirios.  
\v 11 \w Entregó|strong="H5414"\w* \w el|strong="H1121"\w* \w resto|strong="H3499"\w* del ejército al mando \w de|strong="H1121"\w* su hermano Abisai, y \w se|strong="H5971"\w* alinearon \w contra|strong="H7125"\w* \w los|strong="H1121"\w* amonitas.  
\v 12 \w Y|strong="H3068"\w* dijo Joab: «\w Si|strong="H1961"\w* \w los|strong="H1121"\w* sirios \w son|strong="H1961"\w* \w más|strong="H4480"\w* \w fuertes|strong="H1121"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w*, tú \w me|strong="H4480"\w* ayudarás; y \w si|strong="H1961"\w* \w los|strong="H1121"\w* amonitas \w son|strong="H1961"\w* \w más|strong="H4480"\w* \w fuertes|strong="H1121"\w* \w que|strong="H4480"\w* tú, \w yo|strong="H4480"\w* \w te|strong="H4480"\w* ayudaré.  
\v 13 \w Esfuérzate|strong="H2388"\w*, y luchemos con valor \w por|strong="H1157"\w* nuestro \w pueblo|strong="H5971"\w* y \w por|strong="H1157"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5971"\w* nuestro \w Dios|strong="H3068"\w*. \w Y|strong="H3068"\w* \w que|strong="H5971"\w* Yahvé \w haga|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H5971"\w* \w le|strong="H5869"\w* parezca \w bien|strong="H2896"\w*.»   
\p
\v 14 Entonces \w Joab|strong="H3097"\w* y \w el|strong="H5973"\w* ejército \w que|strong="H5971"\w* estaba \w con|strong="H5973"\w* \w él|strong="H5973"\w* avanzaron \w para|strong="H5973"\w* enfrentarse \w a|strong="H3068"\w* \w los|strong="H5973"\w* sirios, y estos \w huyeron|strong="H5127"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H5973"\w*.  
\v 15 \w Cuando|strong="H3588"\w* \w los|strong="H1992"\w* amonitas \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* \w los|strong="H1992"\w* sirios huían, \w ellos|strong="H1992"\w* \w también|strong="H1571"\w* \w huyeron|strong="H5127"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* hermano Abisai, \w y|strong="H1571"\w* \w se|strong="H1992"\w* refugiaron \w en|strong="H3588"\w* \w la|strong="H1571"\w* \w ciudad|strong="H5892"\w*. \w Entonces|strong="H3588"\w* \w Joab|strong="H3097"\w* regresó \w a|strong="H3068"\w* Jerusalén.   
\p
\v 16 Al \w ver|strong="H7200"\w* \w los|strong="H3588"\w* sirios \w que|strong="H3588"\w* habían sido derrotados \w por|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w enviaron|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w y|strong="H3588"\w* \w sacaron|strong="H3318"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* sirios \w que|strong="H3588"\w* estaban al otro \w lado|strong="H5676"\w* del \w río|strong="H5104"\w*,\f + \fr 19:16 \ft o, el río Éufrates\f* comandados \w por|strong="H3588"\w* Sofac, \w jefe|strong="H8269"\w* del \w ejército|strong="H6635"\w* \w de|strong="H3588"\w* Hadadézer.  
\v 17 Cuando se \w lo|strong="H3605"\w* informaron \w a|strong="H3068"\w* \w David|strong="H1732"\w*, reunió \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, cruzó \w el|strong="H5973"\w* \w Jordán|strong="H3383"\w*, llegó \w a|strong="H3068"\w* donde estaban y se \w puso|strong="H6186"\w* \w en|strong="H5973"\w* orden \w de|strong="H5973"\w* \w batalla|strong="H4421"\w* \w contra|strong="H5973"\w* \w ellos|strong="H3605"\w*. Al formarse \w David|strong="H1732"\w* \w contra|strong="H5973"\w* \w los|strong="H3605"\w* sirios, \w estos|strong="H3605"\w* \w pelearon|strong="H3898"\w* \w contra|strong="H5973"\w* \w él|strong="H5973"\w*.  
\v 18 Pero los sirios \w huyeron|strong="H5127"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, y \w David|strong="H1732"\w* \w mató|strong="H2026"\w* \w de|strong="H6440"\w* los sirios \w a|strong="H3068"\w* los hombres \w de|strong="H6440"\w* \w siete|strong="H7651"\w* mil \w carros|strong="H7393"\w* y \w a|strong="H3068"\w* cuarenta mil hombres \w de|strong="H6440"\w* \w a|strong="H3068"\w* pie; \w mató|strong="H2026"\w* también \w a|strong="H3068"\w* Sofac, \w jefe|strong="H8269"\w* del \w ejército|strong="H6635"\w*.  
\v 19 Al \w ver|strong="H7200"\w* \w los|strong="H1121"\w* \w siervos|strong="H5650"\w* \w de|strong="H3588"\w* Hadadézer \w que|strong="H3588"\w* habían sido derrotados \w por|strong="H3588"\w* \w Israel|strong="H3478"\w*, hicieron \w la|strong="H3588"\w* \w paz|strong="H7999"\w* \w con|strong="H5973"\w* \w David|strong="H1732"\w* \w y|strong="H3588"\w* \w se|strong="H3808"\w* sometieron \w a|strong="H3068"\w* \w él|strong="H5973"\w*. \w Y|strong="H3068"\w* \w los|strong="H1121"\w* sirios \w no|strong="H3808"\w* quisieron ayudar \w más|strong="H5750"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* amonitas.   
\c 20
\p
\v 1 \w A|strong="H3068"\w* la vuelta del \w año|strong="H8141"\w*, \w en|strong="H3318"\w* \w el|strong="H1121"\w* \w tiempo|strong="H6256"\w* \w en|strong="H3318"\w* \w que|strong="H1121"\w* \w los|strong="H3427"\w* \w reyes|strong="H4428"\w* \w salen|strong="H3318"\w* \w a|strong="H3068"\w* la \w guerra|strong="H6635"\w*, \w Joab|strong="H3097"\w* condujo \w al|strong="H6256"\w* \w ejército|strong="H6635"\w* y devastó la tierra \w de|strong="H1121"\w* \w los|strong="H3427"\w* amonitas, y \w fue|strong="H1961"\w* y puso sitio \w a|strong="H3068"\w* Rabá. Pero \w David|strong="H1732"\w* \w se|strong="H1961"\w* \w quedó|strong="H1961"\w* \w en|strong="H3318"\w* Jerusalén. \w Joab|strong="H3097"\w* atacó \w a|strong="H3068"\w* Rabá y la \w destruyó|strong="H2040"\w*.  
\v 2 \w David|strong="H1732"\w* \w le|strong="H5921"\w* \w quitó|strong="H3947"\w* \w la|strong="H5921"\w* \w corona|strong="H5850"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w a|strong="H3068"\w* su \w rey|strong="H4428"\w*, \w y|strong="H5921"\w* comprobó \w que|strong="H5921"\w* pesaba un talento \w de|strong="H5921"\w* \w oro|strong="H2091"\w*,\f + \fr 20:2 \ft Un talento es de unos 30 kilogramos o 66 libras, por lo que un talento de oro es sumamente pesado.\f* \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w tenía|strong="H1961"\w* piedras \w preciosas|strong="H3368"\w*; \w y|strong="H5921"\w* \w fue|strong="H1961"\w* puesta \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*. \w Además|strong="H5921"\w*, \w sacó|strong="H3318"\w* un inmenso botín \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.  
\v 3 \w Sacó|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w gente|strong="H5971"\w* \w que|strong="H5971"\w* estaba \w en|strong="H3318"\w* \w ella|strong="H3605"\w* y \w los|strong="H1121"\w* puso \w a|strong="H3068"\w* \w trabajar|strong="H6213"\w* con sierras, con picos \w de|strong="H1121"\w* \w hierro|strong="H1270"\w* y con hachas. \w Lo|strong="H6213"\w* \w mismo|strong="H3605"\w* \w hizo|strong="H6213"\w* \w David|strong="H1732"\w* con \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* amonitas. \w Luego|strong="H3318"\w*, \w David|strong="H1732"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* regresaron \w a|strong="H3068"\w* Jerusalén.   
\p
\v 4 \w Después|strong="H1961"\w* \w de|strong="H5973"\w* esto, \w se|strong="H1961"\w* desató una \w guerra|strong="H4421"\w* \w en|strong="H5973"\w* \w Gezer|strong="H1507"\w* \w contra|strong="H5973"\w* \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w*. \w Fue|strong="H1961"\w* entonces \w cuando|strong="H1961"\w* Sibecai \w el|strong="H5973"\w* \w husatita|strong="H2843"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* Sipai, uno \w de|strong="H5973"\w* \w los|strong="H5973"\w* descendientes \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w gigantes|strong="H7497"\w*, y \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w* \w fueron|strong="H1961"\w* sometidos.   
\p
\v 5 \w Hubo|strong="H1961"\w* \w otra|strong="H5750"\w* \w guerra|strong="H4421"\w* \w contra|strong="H1961"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*, y Elhanán, \w hijo|strong="H1121"\w* \w de|strong="H5750"\w* Jair, \w mató|strong="H5221"\w* \w a|strong="H3068"\w* Lahmi, hermano \w de|strong="H5750"\w* Goliat \w el|strong="H1121"\w* geteo, \w el|strong="H1121"\w* asta \w de|strong="H5750"\w* cuya \w lanza|strong="H2595"\w* \w era|strong="H1961"\w* \w como|strong="H1961"\w* \w el|strong="H1121"\w* rodillo \w de|strong="H5750"\w* un telar.  
\v 6 \w Volvió|strong="H5750"\w* \w a|strong="H3068"\w* \w haber|strong="H1961"\w* \w guerra|strong="H4421"\w* \w en|strong="H5750"\w* Gat, \w donde|strong="H1931"\w* \w había|strong="H1961"\w* un hombre \w de|strong="H5750"\w* gran estatura \w que|strong="H1931"\w* \w tenía|strong="H1961"\w* \w veinticuatro|strong="H6242"\w* dedos, \w seis|strong="H8337"\w* \w en|strong="H5750"\w* cada \w mano|strong="H1931"\w* \w y|strong="H1571"\w* \w seis|strong="H8337"\w* \w en|strong="H5750"\w* cada pie, \w quien|strong="H1931"\w* \w también|strong="H1571"\w* \w era|strong="H1961"\w* descendiente \w de|strong="H5750"\w* \w los|strong="H1931"\w* \w gigantes|strong="H7497"\w*.  
\v 7 Este \w hombre|strong="H1121"\w* desafió \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, pero Jonatán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Simea, hermano \w de|strong="H1121"\w* \w David|strong="H1732"\w*, lo \w mató|strong="H5221"\w*.  
\v 8 Estos \w nacieron|strong="H3205"\w* al gigante en Gat, y \w cayeron|strong="H5307"\w* \w a|strong="H3068"\w* \w manos|strong="H3027"\w* de \w David|strong="H1732"\w* y de sus \w siervos|strong="H5650"\w*.   
\c 21
\p
\v 1 Satanás \w se|strong="H5921"\w* levantó \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w* \w e|strong="H3068"\w* incitó \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w a|strong="H3068"\w* hacer un censo \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 2 \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* \w Joab|strong="H3097"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* los \w jefes|strong="H8269"\w* del \w pueblo|strong="H5971"\w*: «\w Id|strong="H3212"\w* \w a|strong="H3068"\w* \w contar|strong="H5608"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w desde|strong="H5704"\w* Beerseba \w hasta|strong="H5704"\w* \w Dan|strong="H1835"\w*, \w y|strong="H5704"\w* traedme la noticia \w para|strong="H5704"\w* \w que|strong="H5704"\w* yo \w sepa|strong="H3045"\w* cuántos son.»   
\p
\v 3 \w Joab|strong="H3097"\w* dijo: «\w Que|strong="H4100"\w* Yahvé haga \w que|strong="H4100"\w* \w su|strong="H1992"\w* \w pueblo|strong="H5971"\w* \w sea|strong="H1961"\w* \w cien|strong="H3967"\w* \w veces|strong="H6471"\w* mayor \w de|strong="H5921"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w es|strong="H1961"\w*. Pero, \w mi|strong="H5921"\w* \w señor|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*, ¿\w no|strong="H3808"\w* \w son|strong="H1961"\w* \w todos|strong="H3605"\w* \w ellos|strong="H1992"\w* \w siervos|strong="H5650"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w señor|strong="H3068"\w*? ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w mi|strong="H5921"\w* \w señor|strong="H3068"\w* exige \w esto|strong="H2063"\w*? ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w ha|strong="H3808"\w* \w de|strong="H5921"\w* ser causa \w de|strong="H5921"\w* culpa \w para|strong="H5921"\w* \w Israel|strong="H3478"\w*?»   
\p
\v 4 Sin embargo, \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w prevaleció|strong="H2388"\w* \w contra|strong="H5921"\w* \w Joab|strong="H3097"\w*. \w Por|strong="H5921"\w* eso \w Joab|strong="H3097"\w* partió \w y|strong="H5921"\w* recorrió \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w luego|strong="H3318"\w* regresó \w a|strong="H3068"\w* Jerusalén.  
\v 5 \w Joab|strong="H3097"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w la|strong="H3605"\w* suma del censo del \w pueblo|strong="H5971"\w*. \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w* \w eran|strong="H1961"\w* un millón \w cien|strong="H3967"\w* \w mil|strong="H3967"\w* hombres \w que|strong="H5971"\w* \w sacaban|strong="H8025"\w* \w espada|strong="H2719"\w*; y en \w Judá|strong="H3063"\w* \w había|strong="H1961"\w* cuatrocientos \w setenta|strong="H7657"\w* \w mil|strong="H3967"\w* hombres \w que|strong="H5971"\w* \w sacaban|strong="H8025"\w* \w espada|strong="H2719"\w*.  
\v 6 \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* \w contó|strong="H6485"\w* \w a|strong="H3068"\w* \w Leví|strong="H3878"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w* \w entre|strong="H8432"\w* ellos, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* orden del \w rey|strong="H4428"\w* le resultaba \w abominable|strong="H8581"\w* \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*.   
