\v 12 y \w Adaías|strong="H5718"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeroham|strong="H3395"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Pasur, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Malquías y Masai \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Adiel|strong="H5717"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jazera, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Mesilemit, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Imer;  
\v 13 y sus hermanos, \w jefes|strong="H7218"\w* de las \w casas|strong="H1004"\w* de sus padres, \w mil|strong="H3967"\w* \w setecientos|strong="H7651"\w* \w sesenta|strong="H8346"\w*; eran \w hombres|strong="H1368"\w* muy capaces para la \w obra|strong="H4399"\w* del servicio de la \w casa|strong="H1004"\w* de Dios.   
\p
\v 14 \w De|strong="H4480"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*: \w Semaías|strong="H8098"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Hasub, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Azricam|strong="H5840"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Hasabías|strong="H2811"\w*, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Merari|strong="H4847"\w*;  
\v 15 y Bacbacar, \w Heres|strong="H2792"\w*, Galal y Matanías \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Mica, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zicri, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Asaf,  
\v 16 y \w Abdías|strong="H5662"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Semaías|strong="H8098"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Galal, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jedutún; y Berequías \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Asa, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Elcaná, \w que|strong="H1121"\w* \w vivían|strong="H3427"\w* en las \w aldeas|strong="H2691"\w* \w de|strong="H1121"\w* \w los|strong="H3427"\w* netofatitas.   
\p
\v 17 Los \w porteros|strong="H7778"\w*: Salum, Acub, \w Talmón|strong="H2929"\w*, Ahimán y sus hermanos (Salum era el \w jefe|strong="H7218"\w*),  
\v 18 \w que|strong="H5704"\w* \w antes|strong="H5704"\w* servían \w en|strong="H5704"\w* la \w puerta|strong="H8179"\w* del \w rey|strong="H4428"\w* \w hacia|strong="H2008"\w* \w el|strong="H1121"\w* \w este|strong="H4217"\w*. Eran \w los|strong="H1992"\w* \w porteros|strong="H7778"\w* del \w campamento|strong="H4264"\w* \w de|strong="H5704"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Leví|strong="H3878"\w*.  
\v 19 Salum \w era|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Coré|strong="H7141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ebiasaf, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Coré|strong="H7141"\w*, \w y|strong="H5921"\w* sus hermanos, \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su padre, \w los|strong="H1121"\w* coreítas, estaban \w a|strong="H3068"\w* cargo \w del|strong="H5921"\w* trabajo \w del|strong="H5921"\w* servicio, guardianes \w de|strong="H5921"\w* \w los|strong="H1121"\w* umbrales \w de|strong="H5921"\w* \w la|strong="H5921"\w* tienda. Sus padres habían estado \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w campamento|strong="H4264"\w* \w de|strong="H5921"\w* Yahvé, guardianes \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w entrada|strong="H3996"\w*.  
\v 20 Finees, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Eleazar, \w era|strong="H1961"\w* \w el|strong="H5921"\w* jefe \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* pasado, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* \w estaba|strong="H1961"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w*.  
\v 21 \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Meselemías, \w era|strong="H1121"\w* \w el|strong="H1121"\w* guardián \w de|strong="H1121"\w* la \w puerta|strong="H6607"\w* \w de|strong="H1121"\w* la Tienda \w de|strong="H1121"\w* Reunión.  
\v 22 \w Todos|strong="H3605"\w* \w estos|strong="H1992"\w* \w que|strong="H2691"\w* \w fueron|strong="H1732"\w* elegidos para ser \w porteros|strong="H7778"\w* en \w los|strong="H1992"\w* umbrales \w fueron|strong="H1732"\w* \w doscientos|strong="H3967"\w* \w doce|strong="H8147"\w*. \w Estos|strong="H1992"\w* \w fueron|strong="H1732"\w* listados por genealogía en \w sus|strong="H1992"\w* pueblos, \w a|strong="H3068"\w* quienes \w David|strong="H1732"\w* y \w Samuel|strong="H8050"\w* \w el|strong="H3605"\w* \w vidente|strong="H7200"\w* ordenaron en \w su|strong="H1992"\w* cargo de confianza.  
\v 23 \w Ellos|strong="H1992"\w* \w y|strong="H5921"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w* tenían \w la|strong="H5921"\w* vigilancia \w de|strong="H5921"\w* \w las|strong="H1992"\w* \w puertas|strong="H8179"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé, \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tienda, \w como|strong="H5921"\w* guardianes.  
\v 24 En \w los|strong="H1961"\w* cuatro \w lados|strong="H7307"\w* \w estaban|strong="H1961"\w* \w los|strong="H1961"\w* guardianes de las puertas, \w hacia|strong="H5045"\w* el \w este|strong="H1961"\w*, el oeste, el \w norte|strong="H6828"\w* y el sur.  
\v 25 Sus hermanos, \w en|strong="H5973"\w* sus \w aldeas|strong="H2691"\w*, debían entrar \w cada|strong="H3117"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w para|strong="H5973"\w* estar \w con|strong="H5973"\w* ellos,  
\v 26 \w porque|strong="H3588"\w* \w los|strong="H1992"\w* cuatro \w principales|strong="H1368"\w* \w porteros|strong="H7778"\w*, \w que|strong="H3588"\w* \w eran|strong="H1961"\w* \w levitas|strong="H3881"\w*, \w tenían|strong="H1961"\w* un cargo \w de|strong="H5921"\w* confianza \w y|strong="H3588"\w* \w estaban|strong="H1961"\w* \w a|strong="H3068"\w* cargo \w de|strong="H5921"\w* \w las|strong="H1992"\w* habitaciones \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w los|strong="H1992"\w* tesoros \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Dios.  
\v 27 \w Ellos|strong="H1992"\w* permanecían \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Dios, \w porque|strong="H3588"\w* ese era \w su|strong="H1992"\w* deber; \w y|strong="H3588"\w* era \w su|strong="H1992"\w* deber abrirla \w de|strong="H5921"\w* \w mañana|strong="H1242"\w* \w en|strong="H5921"\w* \w mañana|strong="H1242"\w*.   
\p
\v 28 Algunos \w de|strong="H5921"\w* \w ellos|strong="H1992"\w* estaban \w a|strong="H3068"\w* cargo \w de|strong="H5921"\w* \w los|strong="H1992"\w* utensilios \w del|strong="H5921"\w* servicio, \w pues|strong="H3588"\w* \w estos|strong="H1992"\w* \w se|strong="H5921"\w* \w traían|strong="H5921"\w* \w por|strong="H5921"\w* \w cuenta|strong="H4557"\w*, \w y|strong="H3588"\w* \w estos|strong="H1992"\w* \w se|strong="H5921"\w* \w sacaban|strong="H3318"\w* \w por|strong="H5921"\w* \w cuenta|strong="H4557"\w*.  
\v 29 Algunos \w de|strong="H5921"\w* \w ellos|strong="H1992"\w* también estaban encargados \w de|strong="H5921"\w* \w los|strong="H1992"\w* muebles \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* utensilios \w del|strong="H5921"\w* \w santuario|strong="H6944"\w*, \w de|strong="H5921"\w* \w la|strong="H5921"\w* harina fina, \w del|strong="H5921"\w* \w vino|strong="H3196"\w*, \w del|strong="H5921"\w* \w aceite|strong="H8081"\w*, \w del|strong="H5921"\w* \w incienso|strong="H3828"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w las|strong="H1992"\w* \w especias|strong="H1314"\w*.   
\p
\v 30 Algunos \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* preparaban la mezcla \w de|strong="H4480"\w* las \w especias|strong="H1314"\w*.  
\v 31 Matatías, uno \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w*, \w que|strong="H4480"\w* \w era|strong="H1931"\w* \w primogénito|strong="H1060"\w* \w de|strong="H4480"\w* Salum \w el|strong="H1931"\w* coreíta, \w tenía|strong="H1931"\w* \w el|strong="H1931"\w* cargo \w de|strong="H4480"\w* confianza \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* cosas \w que|strong="H4480"\w* \w se|strong="H1931"\w* cocían \w en|strong="H5921"\w* \w las|strong="H5921"\w* sartenes.  
\v 32 Algunos \w de|strong="H4480"\w* sus hermanos, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* coatitas, estaban \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w panes|strong="H3899"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* proposición, \w para|strong="H5921"\w* prepararlos cada \w sábado|strong="H7676"\w*.   
\p
\v 33 Estos \w son|strong="H3588"\w* \w los|strong="H5921"\w* \w cantores|strong="H7891"\w*, \w jefes|strong="H7218"\w* \w de|strong="H5921"\w* familia \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w*, \w que|strong="H3588"\w* vivían \w en|strong="H5921"\w* \w las|strong="H5921"\w* habitaciones \w y|strong="H3588"\w* \w estaban|strong="H7218"\w* libres \w de|strong="H5921"\w* cualquier otro servicio, \w pues|strong="H3588"\w* \w se|strong="H5921"\w* empleaban \w en|strong="H5921"\w* \w su|strong="H3588"\w* trabajo \w de|strong="H5921"\w* \w día|strong="H3119"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w*.  
\v 34 Estos eran \w jefes|strong="H7218"\w* de familia de \w los|strong="H3427"\w* \w levitas|strong="H3881"\w*, \w por|strong="H3881"\w* sus generaciones, hombres \w principales|strong="H7218"\w*. \w Vivían|strong="H3427"\w* en Jerusalén.   
\p
\v 35 \w Jeiel|strong="H3273"\w*, padre de \w Gabaón|strong="H1391"\w*, cuya mujer se \w llamaba|strong="H8034"\w* Maaca, \w vivía|strong="H3427"\w* en \w Gabaón|strong="H1391"\w*.  
\v 36 Su \w hijo|strong="H1121"\w* \w primogénito|strong="H1060"\w* fue \w Abdón|strong="H5658"\w*, luego Zur, \w Cis|strong="H7027"\w*, \w Baal|strong="H1168"\w*, \w Ner|strong="H5369"\w*, \w Nadab|strong="H5070"\w*,  
\v 37 \w Gedor|strong="H1446"\w*, Ahío, \w Zacarías|strong="H2148"\w* y Miclot.  
\v 38 Miclot \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Simeam. \w Ellos|strong="H1992"\w* también vivieron \w con|strong="H5973"\w* \w sus|strong="H1992"\w* parientes \w en|strong="H5973"\w* Jerusalén, \w cerca|strong="H5973"\w* \w de|strong="H5048"\w* \w sus|strong="H1992"\w* parientes.  
\v 39 \w Ner|strong="H5369"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Cis|strong="H7027"\w*. \w Cis|strong="H7027"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*. \w Saúl|strong="H7586"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jonatán, Malquisúa, Abinadab y Esbaal.  
\v 40 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jonatán fue Merib-baal. Merib-baal \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Miqueas.  
\v 41 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Miqueas: Pitón, Melec, Tarea y Acaz.  
\v 42 Acaz \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jara. Jara \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Alemet, Azmavet y \w Zimri|strong="H2174"\w*. \w Zimri|strong="H2174"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Moza.  
\v 43 Moza \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Binea, \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* Refaías, \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* Eleasá y \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* Azel.  
\v 44 Azel tuvo \w seis|strong="H8337"\w* \w hijos|strong="H1121"\w*, cuyos \w nombres|strong="H8034"\w* son \w Azricam|strong="H5840"\w*, Bocru, \w Ismael|strong="H3458"\w*, \w Searías|strong="H8187"\w*, \w Abdías|strong="H5662"\w* y \w Hanán|strong="H2605"\w*. Estos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Azel.   
\c 10
\p
\v 1 Los \w filisteos|strong="H6430"\w* lucharon \w contra|strong="H6440"\w* \w Israel|strong="H3478"\w*, y los hombres \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w huyeron|strong="H5127"\w* \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* los \w filisteos|strong="H6430"\w* y \w cayeron|strong="H5307"\w* \w muertos|strong="H2491"\w* en \w el|strong="H5307"\w* \w monte|strong="H2022"\w* Gilboa.  
\v 2 \w Los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w siguieron|strong="H5221"\w* con fuerza \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*, y \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w mataron|strong="H5221"\w* \w a|strong="H3068"\w* Jonatán, \w a|strong="H3068"\w* Abinadab y \w a|strong="H3068"\w* Malquisúa, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*.  
\v 3 \w La|strong="H5921"\w* \w batalla|strong="H4421"\w* fue dura \w contra|strong="H5921"\w* \w Saúl|strong="H7586"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* arqueros \w lo|strong="H5921"\w* alcanzaron; \w y|strong="H5921"\w* \w él|strong="H5921"\w* estaba angustiado \w a|strong="H3068"\w* causa \w de|strong="H4480"\w* \w los|strong="H5921"\w* arqueros.  
\v 4 \w Entonces|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w le|strong="H5921"\w* dijo \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w escudero|strong="H5375"\w*: «\w Saca|strong="H8025"\w* tu \w espada|strong="H2719"\w* \w y|strong="H3588"\w* traspásame \w con|strong="H5921"\w* \w ella|strong="H5921"\w*, \w no|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* estos \w incircuncisos|strong="H6189"\w* vengan \w a|strong="H3068"\w* abusar \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.»  
\p \w Pero|strong="H3588"\w* \w su|strong="H3588"\w* \w escudero|strong="H5375"\w* \w no|strong="H3808"\w* quiso, \w porque|strong="H3588"\w* estaba aterrorizado. \w Entonces|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w tomó|strong="H3947"\w* \w su|strong="H3588"\w* \w espada|strong="H2719"\w* \w y|strong="H3588"\w* \w se|strong="H5921"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*.  
\v 5 \w Cuando|strong="H3588"\w* \w su|strong="H1931"\w* \w escudero|strong="H5375"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* estaba \w muerto|strong="H4191"\w*, \w él|strong="H1931"\w* \w también|strong="H1571"\w* \w se|strong="H1931"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* \w espada|strong="H2719"\w* \w y|strong="H1571"\w* \w murió|strong="H4191"\w*.  
\v 6 Así \w murió|strong="H4191"\w* \w Saúl|strong="H7586"\w* con sus \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w*, y \w toda|strong="H3605"\w* su \w casa|strong="H1004"\w* \w murió|strong="H4191"\w* junta.  
\v 7 \w Cuando|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w que|strong="H3588"\w* \w estaban|strong="H3427"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w valle|strong="H6010"\w* \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* huían, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w y|strong="H3588"\w* sus \w hijos|strong="H1121"\w* \w estaban|strong="H3427"\w* \w muertos|strong="H4191"\w*, abandonaron sus \w ciudades|strong="H5892"\w* \w y|strong="H3588"\w* \w huyeron|strong="H5127"\w*, \w y|strong="H3588"\w* \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w* vinieron \w y|strong="H3588"\w* \w habitaron|strong="H3427"\w* \w en|strong="H3588"\w* ellas.   
\p
\v 8 Al \w día|strong="H1121"\w* \w siguiente|strong="H4283"\w*, \w cuando|strong="H1961"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w fueron|strong="H1961"\w* \w a|strong="H3068"\w* despojar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w muertos|strong="H2491"\w*, encontraron \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w caídos|strong="H5307"\w* en \w el|strong="H5307"\w* \w monte|strong="H2022"\w* Gilboa.  
\v 9 Lo despojaron y \w tomaron|strong="H5375"\w* su \w cabeza|strong="H7218"\w* y su armadura, y luego \w enviaron|strong="H7971"\w* mensajeros por toda la tierra \w de|strong="H5971"\w* los \w filisteos|strong="H6430"\w* \w para|strong="H5971"\w* llevar la noticia \w a|strong="H3068"\w* sus \w ídolos|strong="H6091"\w* y al \w pueblo|strong="H5971"\w*.  
\v 10 \w Pusieron|strong="H7760"\w* su armadura en la \w casa|strong="H1004"\w* de sus dioses, y fijaron su cabeza en la \w casa|strong="H1004"\w* de \w Dagón|strong="H1712"\w*.  
\v 11 Cuando \w todo|strong="H3605"\w* \w Jabes|strong="H3003"\w* de \w Galaad|strong="H1568"\w* se enteró de \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* le habían \w hecho|strong="H6213"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*,  
\v 12 \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w* se \w levantaron|strong="H6965"\w* y se \w llevaron|strong="H5375"\w* \w el|strong="H3605"\w* cuerpo \w de|strong="H8478"\w* \w Saúl|strong="H7586"\w* y \w los|strong="H1121"\w* cuerpos \w de|strong="H8478"\w* sus \w hijos|strong="H1121"\w*, y \w los|strong="H1121"\w* \w llevaron|strong="H5375"\w* \w a|strong="H3068"\w* \w Jabes|strong="H3003"\w*, y enterraron sus \w huesos|strong="H6106"\w* \w bajo|strong="H8478"\w* \w la|strong="H3605"\w* encina \w en|strong="H6912"\w* \w Jabes|strong="H3003"\w*, y ayunaron \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.   
\p
\v 13 \w Así|strong="H1571"\w* \w pues|strong="H1571"\w*, \w Saúl|strong="H7586"\w* \w murió|strong="H4191"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w prevaricación|strong="H4603"\w* \w que|strong="H3808"\w* \w cometió|strong="H4604"\w* \w contra|strong="H5921"\w* Yahvé, \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w guardó|strong="H8104"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w porque|strong="H5921"\w* \w consultó|strong="H7592"\w* \w a|strong="H3068"\w* una pitonisa \w para|strong="H5921"\w* pedir \w consejo|strong="H1697"\w*,  
\v 14 y \w no|strong="H3808"\w* \w consultó|strong="H1875"\w* \w a|strong="H3068"\w* Yahvé. Por eso \w lo|strong="H3808"\w* \w mató|strong="H4191"\w*, y entregó \w el|strong="H1121"\w* \w reino|strong="H4410"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jesé.   
\c 11
\p
\v 1 Entonces \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* se reunió con \w David|strong="H1732"\w* en \w Hebrón|strong="H2275"\w*, diciendo: “He \w aquí|strong="H2009"\w* \w que|strong="H3605"\w* somos tu \w hueso|strong="H6106"\w* y tu \w carne|strong="H1320"\w*.  
\v 2 \w En|strong="H5921"\w* tiempos \w pasados|strong="H1961"\w*, \w cuando|strong="H1571"\w* \w Saúl|strong="H7586"\w* \w era|strong="H1961"\w* \w rey|strong="H4428"\w*, \w fuiste|strong="H1961"\w* tú quien dirigía \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* batalla. \w El|strong="H5921"\w* \w Señor|strong="H3068"\w*, tu \w Dios|strong="H3068"\w*, \w te|strong="H5921"\w* dijo: ‘Tú \w serás|strong="H1961"\w* \w el|strong="H5921"\w* \w pastor|strong="H7462"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w y|strong="H1571"\w* tú \w serás|strong="H1961"\w* \w el|strong="H5921"\w* \w príncipe|strong="H5057"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*’.”   
\p
\v 3 Así \w que|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* vinieron \w a|strong="H3068"\w* ver \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w a|strong="H3068"\w* \w Hebrón|strong="H2275"\w*, \w y|strong="H5921"\w* \w David|strong="H1732"\w* \w hizo|strong="H3772"\w* un \w pacto|strong="H1285"\w* \w con|strong="H5921"\w* \w ellos|strong="H3027"\w* \w en|strong="H5921"\w* \w Hebrón|strong="H2275"\w* \w ante|strong="H6440"\w* Yahvé. \w Ungieron|strong="H4886"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w Samuel|strong="H8050"\w*.   
\p
\v 4 \w David|strong="H1732"\w* y \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w se|strong="H1931"\w* dirigieron \w a|strong="H3068"\w* Jerusalén (también llamada \w Jebús|strong="H2983"\w*), y \w los|strong="H3427"\w* \w jebuseos|strong="H2983"\w*, \w habitantes|strong="H3427"\w* de \w la|strong="H1931"\w* tierra, \w estaban|strong="H3427"\w* \w allí|strong="H8033"\w*.  
\v 5 \w Los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Jebús dijeron \w a|strong="H3068"\w* \w David|strong="H1732"\w*: «¡\w No|strong="H3808"\w* entrarás \w aquí|strong="H2008"\w*!» \w Sin|strong="H3808"\w* embargo, \w David|strong="H1732"\w* \w tomó|strong="H3920"\w* \w la|strong="H1931"\w* fortaleza de \w Sión|strong="H6726"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* de \w David|strong="H1732"\w*.  
\v 6 \w David|strong="H1732"\w* \w había|strong="H1961"\w* dicho: «\w El|strong="H3605"\w* \w que|strong="H1121"\w* ataque \w primero|strong="H7223"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w jebuseos|strong="H2983"\w* \w será|strong="H1961"\w* \w jefe|strong="H7218"\w* y \w capitán|strong="H8269"\w*.» \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia, \w subió|strong="H5927"\w* \w primero|strong="H7223"\w* y \w fue|strong="H1961"\w* nombrado \w jefe|strong="H7218"\w*.  
\v 7 \w David|strong="H1732"\w* \w vivía|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* fortaleza; \w por|strong="H5921"\w* \w eso|strong="H3651"\w* \w la|strong="H5921"\w* \w llamaban|strong="H7121"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*.  
\v 8 Él \w edificó|strong="H1129"\w* la \w ciudad|strong="H5892"\w* \w por|strong="H4480"\w* \w todas|strong="H5439"\w* \w partes|strong="H5439"\w*, \w desde|strong="H4480"\w* Milo \w hasta|strong="H5704"\w* los \w alrededores|strong="H5439"\w*; \w y|strong="H5704"\w* \w Joab|strong="H3097"\w* \w reparó|strong="H2421"\w* el resto \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w*.  
\v 9 \w David|strong="H1732"\w* se hacía cada vez más \w grande|strong="H1419"\w*, \w porque|strong="H1732"\w* \w el|strong="H5973"\w* \w Señor|strong="H3068"\w* \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w Ejércitos|strong="H6635"\w* estaba \w con|strong="H5973"\w* \w él|strong="H5973"\w*.   
\p
\v 10 \w Estos|strong="H3605"\w* son \w los|strong="H5921"\w* \w principales|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w valientes|strong="H1368"\w* \w que|strong="H5921"\w* tenía \w David|strong="H1732"\w*, \w que|strong="H5921"\w* \w se|strong="H5921"\w* mostraron \w fuertes|strong="H1368"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* su \w reino|strong="H4427"\w*, \w junto|strong="H5921"\w* \w con|strong="H5973"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w para|strong="H5921"\w* hacerlo \w rey|strong="H4427"\w*, \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 11 \w Este|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w número|strong="H4557"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w valientes|strong="H1368"\w* \w que|strong="H1931"\w* \w tenía|strong="H1931"\w* \w David|strong="H1732"\w*: Jasobeam, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* un hacmonita, \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w treinta|strong="H7970"\w*; alzó \w su|strong="H1931"\w* \w lanza|strong="H2595"\w* \w contra|strong="H5921"\w* \w trescientos|strong="H7969"\w* \w y|strong="H5921"\w* \w los|strong="H1121"\w* mató \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w vez|strong="H6471"\w*.  
\v 12 Después \w de|strong="H1121"\w* \w él|strong="H1931"\w* estaba Eleazar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Dodo, ahohíta, \w que|strong="H1931"\w* \w era|strong="H1931"\w* uno \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w tres|strong="H7969"\w* \w valientes|strong="H1368"\w*.  
\v 13 \w Estaba|strong="H1961"\w* \w con|strong="H5973"\w* \w David|strong="H1732"\w* \w en|strong="H5973"\w* Pasdamim, y \w allí|strong="H8033"\w* \w se|strong="H1961"\w* reunieron \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w* \w para|strong="H1961"\w* \w combatir|strong="H4421"\w*, \w donde|strong="H8033"\w* \w había|strong="H1961"\w* un terreno \w lleno|strong="H4392"\w* \w de|strong="H6440"\w* \w cebada|strong="H8184"\w*; y \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w huyó|strong="H5127"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w*.  
\v 14 Se pusieron \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de la parcela, la defendieron y \w mataron|strong="H5221"\w* \w a|strong="H3068"\w* los \w filisteos|strong="H6430"\w*; y el \w Señor|strong="H3068"\w* los \w salvó|strong="H3467"\w* con una \w gran|strong="H1419"\w* victoria.   
\p
\v 15 \w Tres|strong="H7969"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w treinta|strong="H7970"\w* \w jefes|strong="H7218"\w* \w bajaron|strong="H3381"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* peña \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w cueva|strong="H4631"\w* \w de|strong="H4480"\w* Adulam; \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w ejército|strong="H4264"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* estaba acampado \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w valle|strong="H6010"\w* \w de|strong="H4480"\w* Refaim.  
\v 16 \w David|strong="H1732"\w* estaba entonces en la fortaleza, y la \w guarnición|strong="H5333"\w* de los \w filisteos|strong="H6430"\w* estaba en Belén en ese momento.  
\v 17 \w David|strong="H1732"\w* anheló y dijo: «¡\w Oh|strong="H4310"\w*, \w quién|strong="H4310"\w* \w me|strong="H4310"\w* diera \w de|strong="H4325"\w* \w beber|strong="H8248"\w* \w agua|strong="H4325"\w* del pozo \w de|strong="H4325"\w* Belén, \w que|strong="H4310"\w* está junto \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w*!»   
\p
\v 18 Los \w tres|strong="H7969"\w* atravesaron \w el|strong="H4264"\w* \w campamento|strong="H4264"\w* \w de|strong="H4325"\w* los \w filisteos|strong="H6430"\w* y \w sacaron|strong="H7579"\w* \w agua|strong="H4325"\w* \w del|strong="H8354"\w* pozo \w de|strong="H4325"\w* Belén \w que|strong="H3808"\w* estaba junto \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w*, la \w tomaron|strong="H5375"\w* y \w se|strong="H3808"\w* la \w llevaron|strong="H5375"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*; pero este \w no|strong="H3808"\w* quiso \w beberla|strong="H8354"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* la derramó como libación \w a|strong="H3068"\w* Yahvé,  
\v 19 \w y|strong="H3588"\w* dijo: «¡\w Mi|strong="H5315"\w* Dios \w me|strong="H3588"\w* guarde \w de|strong="H3588"\w* \w hacer|strong="H6213"\w* \w tal|strong="H2063"\w* \w cosa|strong="H5315"\w*! ¿He \w de|strong="H3588"\w* \w beber|strong="H8354"\w* \w la|strong="H3588"\w* \w sangre|strong="H1818"\w* \w de|strong="H3588"\w* \w estos|strong="H2063"\w* \w hombres|strong="H1368"\w* \w que|strong="H3588"\w* han \w puesto|strong="H3588"\w* \w su|strong="H3588"\w* \w vida|strong="H5315"\w* \w en|strong="H3588"\w* peligro?» \w Pues|strong="H3588"\w* arriesgaron sus \w vidas|strong="H5315"\w* \w para|strong="H3588"\w* traerla. \w Por|strong="H3588"\w* \w eso|strong="H2063"\w* \w no|strong="H3808"\w* quiso \w beberla|strong="H8354"\w*. \w Los|strong="H3588"\w* \w tres|strong="H7969"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* \w hicieron|strong="H6213"\w* \w estas|strong="H2063"\w* cosas.   
\p
\v 20 \w Abisai|strong="H7969"\w*, hermano \w de|strong="H5921"\w* \w Joab|strong="H3097"\w*, \w era|strong="H1961"\w* \w el|strong="H1931"\w* \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w tres|strong="H7969"\w*, \w pues|strong="H1931"\w* levantó \w su|strong="H1931"\w* \w lanza|strong="H2595"\w* \w contra|strong="H5921"\w* \w trescientos|strong="H7969"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* mató, \w y|strong="H5921"\w* ganó renombre \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w tres|strong="H7969"\w*.  
\v 21 \w De|strong="H4480"\w* \w los|strong="H1961"\w* \w tres|strong="H7969"\w*, él \w era|strong="H1961"\w* el \w más|strong="H4480"\w* ilustre \w de|strong="H4480"\w* \w los|strong="H1961"\w* \w dos|strong="H8147"\w*, \w y|strong="H5704"\w* \w fue|strong="H1961"\w* nombrado su \w capitán|strong="H8269"\w*; \w sin|strong="H3808"\w* embargo, \w no|strong="H3808"\w* \w fue|strong="H1961"\w* incluido \w entre|strong="H3808"\w* \w los|strong="H1961"\w* \w tres|strong="H7969"\w* primeros.   
\p
\v 22 \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Joiada|strong="H3077"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* un \w valiente|strong="H2428"\w* \w de|strong="H4480"\w* \w Cabseel|strong="H6909"\w*, \w de|strong="H4480"\w* \w grandes|strong="H7227"\w* hazañas, \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Ariel \w de|strong="H4480"\w* \w Moab|strong="H4124"\w*. También bajó y \w mató|strong="H5221"\w* \w a|strong="H3068"\w* un león \w en|strong="H4480"\w* \w medio|strong="H8432"\w* \w de|strong="H4480"\w* un foso \w en|strong="H4480"\w* un \w día|strong="H3117"\w* \w de|strong="H4480"\w* nieve.  
\v 23 \w Mató|strong="H2026"\w* \w a|strong="H3068"\w* un \w egipcio|strong="H4713"\w*, un hombre \w de|strong="H2568"\w* gran estatura, \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* codos\f + \fr 11:23 \ft Un codo es la longitud desde la punta del dedo corazón hasta el codo del brazo de un hombre, o sea, unas 18 pulgadas o 46 centímetros. Por lo tanto, este egipcio medía alrededor de 7 pies y 6 pulgadas o 2,28 metros de altura.\f* \w de|strong="H2568"\w* altura. \w En|strong="H5221"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* del \w egipcio|strong="H4713"\w* había una \w lanza|strong="H2595"\w* \w como|strong="H1931"\w* \w el|strong="H1931"\w* rodillo \w de|strong="H2568"\w* un telar; y \w él|strong="H1931"\w* bajó hacia \w él|strong="H1931"\w* con un bastón, arrancó \w la|strong="H1931"\w* \w lanza|strong="H2595"\w* \w de|strong="H2568"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* del \w egipcio|strong="H4713"\w* y \w lo|strong="H1931"\w* \w mató|strong="H2026"\w* con \w su|strong="H1931"\w* propia \w lanza|strong="H2595"\w*.  
\v 24 \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joiada|strong="H3077"\w*, \w hizo|strong="H6213"\w* \w estas|strong="H6213"\w* cosas y ganó renombre entre \w los|strong="H1121"\w* \w tres|strong="H7969"\w* \w valientes|strong="H1368"\w*.  
\v 25 \w Era|strong="H1931"\w* \w más|strong="H4480"\w* ilustre \w que|strong="H4480"\w* \w los|strong="H5921"\w* \w treinta|strong="H7970"\w*, pero \w no|strong="H3808"\w* igualó \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w tres|strong="H7969"\w* primeros; \w y|strong="H5921"\w* \w David|strong="H1732"\w* \w lo|strong="H1931"\w* \w puso|strong="H7760"\w* \w al|strong="H5921"\w* frente \w de|strong="H4480"\w* \w su|strong="H1931"\w* guardia personal.   
\p
\v 26 Entre \w los|strong="H1121"\w* \w valientes|strong="H1368"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w ejércitos|strong="H2428"\w* se encuentran también \w Asael|strong="H6214"\w* hermano \w de|strong="H1121"\w* \w Joab|strong="H3097"\w*, Elhanán \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Dodo \w de|strong="H1121"\w* Belén,  
\v 27 Samot harorita, \w Heles|strong="H2503"\w* pelonita,  
\v 28 \w Ira|strong="H5896"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Iques \w tecoíta|strong="H8621"\w*, Abiezer anatotita,  
\v 29 Sibecai \w husatita|strong="H2843"\w*, \w Ilai|strong="H5866"\w* ahohíta,  
\v 30 \w Maharai|strong="H4121"\w* \w netofatita|strong="H5200"\w*, \w Heled|strong="H2466"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Baana|strong="H1196"\w* \w netofatita|strong="H5200"\w*,  
\v 31 Itai \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ribai \w de|strong="H1121"\w* \w Gabaa|strong="H1390"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w*, \w Benaía|strong="H1141"\w* \w el|strong="H1121"\w* \w piratonita|strong="H6553"\w*,  
\v 32 \w Hurai|strong="H2360"\w* de los \w arroyos|strong="H5158"\w* de \w Gaas|strong="H1608"\w*, Abiel el arbateo,  
\v 33 Azmavet el baharumita, Eliaba el \w saalbonita|strong="H8170"\w*,  
\v 34 \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hasem \w el|strong="H1121"\w* \w gizonita|strong="H1493"\w*, Jonatán \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sage \w el|strong="H1121"\w* \w ararita|strong="H2043"\w*,  
\v 35 Ahíam \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sacar \w el|strong="H1121"\w* \w ararita|strong="H2043"\w*, Elifal \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ur,  
\v 36 Hefer el mequeratita, Ahías el pelonita,  
\v 37 Hezro \w el|strong="H1121"\w* \w carmelita|strong="H3761"\w*, Naarai \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ezbai,  
\v 38 \w Joel|strong="H3100"\w* \w el|strong="H1121"\w* hermano \w de|strong="H1121"\w* Natán, \w Mibhar|strong="H4006"\w* \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hagri,  
\v 39 \w Selec|strong="H6768"\w* \w el|strong="H1121"\w* amonita, \w Naharai|strong="H5171"\w* \w el|strong="H1121"\w* berotita (\w el|strong="H1121"\w* \w escudero|strong="H5375"\w* \w de|strong="H1121"\w* \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia),  
\v 40 \w Ira|strong="H5896"\w* el itrita, \w Gareb|strong="H1619"\w* el itrita,  
\v 41 Urías \w el|strong="H1121"\w* hitita, \w Zabad|strong="H2066"\w* \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahlai,  
\v 42 \w Adina|strong="H5721"\w* \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Siza \w el|strong="H5921"\w* \w rubenita|strong="H7206"\w* (un \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* rubenitas), \w y|strong="H5921"\w* \w treinta|strong="H7970"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w*,  
\v 43 \w Hanán|strong="H2605"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maaca, Josafat mitnita,  
\v 44 Uzías asterita, Sama y \w Jeiel|strong="H3273"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hotam aroerita,  
\v 45 \w Jediael|strong="H3043"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Simri|strong="H8113"\w*, y Joha su hermano tizita,  
\v 46 Eliel mahavita, \w Jeribai|strong="H3403"\w* y Josavías, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elnaam, \w e|strong="H3068"\w* Itma \w moabita|strong="H4125"\w*,  
\v 47 Eliel, \w Obed|strong="H5744"\w* y Jaasiel mezobaíta.   
\c 12
\p
\v 1 \w Estos|strong="H1992"\w* son \w los|strong="H1992"\w* \w que|strong="H1121"\w* vinieron \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w a|strong="H3068"\w* \w Siclag|strong="H6860"\w* cuando estaba fugitivo \w de|strong="H6440"\w* \w Saúl|strong="H7586"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Cis|strong="H7027"\w*. Estaban entre \w los|strong="H1992"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, \w sus|strong="H1992"\w* ayudantes \w en|strong="H5750"\w* la \w guerra|strong="H4421"\w*.  
\v 2 Estaban \w armados|strong="H5401"\w* con \w arcos|strong="H7198"\w*, y podían usar tanto la mano derecha como la izquierda para lanzar piedras y tirar flechas con el \w arco|strong="H7198"\w*. Eran de los parientes de \w Saúl|strong="H7586"\w* de la tribu de \w Benjamín|strong="H1144"\w*.  
\v 3 \w El|strong="H1121"\w* \w jefe|strong="H7218"\w* \w era|strong="H1121"\w* Ahiezer, luego \w Joás|strong="H3101"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Semaá \w el|strong="H1121"\w* gabaatita; Jeziel y \w Pelet|strong="H6404"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Azmavet; Beraca; \w Jehú|strong="H3058"\w* \w el|strong="H1121"\w* anatotita;  
\v 4 \w Ismaías|strong="H3460"\w* \w el|strong="H5921"\w* \w gabaonita|strong="H1393"\w*, \w hombre|strong="H1368"\w* \w poderoso|strong="H1368"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w treinta|strong="H7970"\w* \w y|strong="H5921"\w* jefe \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w treinta|strong="H7970"\w*; Jeremías; Jahaziel; Johanán; Jozabad \w el|strong="H5921"\w* gederatita;  
\v 5 Eluzai; Jerimot; Bealías; Semarías; Sefatías el harufita;  
\v 6 Elcaná, Isías, Azarel, Joezer y Jasobeam, los coreítas;  
\v 7 y Joela y Zebadías, hijos de Jeroham de Gedor.   
\p
\v 8 Algunos gaditas \w se|strong="H4480"\w* unieron \w a|strong="H3068"\w* David \w en|strong="H4480"\w* la fortaleza \w del|strong="H4480"\w* desierto, \w hombres|strong="H1121"\w* \w valientes|strong="H1121"\w* y entrenados \w para|strong="H4480"\w* la guerra, \w que|strong="H4480"\w* sabían manejar \w el|strong="H1121"\w* escudo y la lanza; sus rostros eran como \w los|strong="H1121"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* leones, y eran tan veloces como las gacelas \w de|strong="H4480"\w* \w los|strong="H1121"\w* montes:  
\v 9 Ezer, \w el|strong="H5921"\w* principal; Abdías, \w el|strong="H5921"\w* segundo; Eliab, \w el|strong="H5921"\w* tercero;  
\v 10 Mismana, el cuarto; Jeremías, el quinto;  
\v 11 Atai, el sexto; Eliel, el séptimo;  
\v 12 Johanán, el octavo; Elzabad, el noveno;  
\v 13 Jeremías, el décimo; y Macbanai, el undécimo.  
\v 14 Estos de los hijos de Gad eran capitanes del ejército. El menor era igual \w a|strong="H3068"\w* cien, y el mayor \w a|strong="H3068"\w* mil.  
\v 15 Estos son \w los|strong="H1121"\w* \w que|strong="H1121"\w* pasaron \w el|strong="H1121"\w* Jordán en \w el|strong="H1121"\w* \w primer|strong="H7218"\w* mes, cuando se desbordó por todas sus orillas; y pusieron en fuga \w a|strong="H3068"\w* todos \w los|strong="H1121"\w* \w que|strong="H1121"\w* vivían en \w los|strong="H1121"\w* valles, tanto hacia \w el|strong="H1121"\w* oriente como hacia \w el|strong="H1121"\w* occidente.   
\p
\v 16 Algunos \w de|strong="H5921"\w* \w los|strong="H1992"\w* hijos \w de|strong="H5921"\w* Benjamín \w y|strong="H5921"\w* \w de|strong="H5921"\w* Judá vinieron \w a|strong="H3068"\w* \w la|strong="H1931"\w* fortaleza \w a|strong="H3068"\w* David.  
\v 17 \w David|strong="H1732"\w* salió \w a|strong="H3068"\w* recibirlos \w y|strong="H5704"\w* les respondió: «Si habéis venido pacíficamente \w a|strong="H3068"\w* ayudarme, mi corazón \w se|strong="H4480"\w* unirá \w a|strong="H3068"\w* vosotros; pero si habéis venido \w a|strong="H3068"\w* entregarme \w a|strong="H3068"\w* mis adversarios, ya \w que|strong="H4480"\w* no hay mal \w en|strong="H4480"\w* mis manos, \w que|strong="H4480"\w* \w el|strong="H1121"\w* Dios \w de|strong="H4480"\w* nuestros padres \w lo|strong="H5704"\w* vea \w y|strong="H5704"\w* \w lo|strong="H5704"\w* juzgue.»  
\v 18 Entonces \w el|strong="H5921"\w* Espíritu \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* Amasai, \w que|strong="H3808"\w* \w era|strong="H1961"\w* \w el|strong="H5921"\w* jefe \w de|strong="H5921"\w* \w los|strong="H5921"\w* treinta, \w y|strong="H5921"\w* dijo: «\w Somos|strong="H1961"\w* tuyos, \w David|strong="H1732"\w*, \w y|strong="H5921"\w* estamos \w contigo|strong="H5921"\w*, hijo \w de|strong="H5921"\w* Jesé. \w Paz|strong="H7965"\w*, \w paz|strong="H7965"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w paz|strong="H7965"\w* \w a|strong="H3068"\w* tus ayudantes, \w porque|strong="H5921"\w* tu Dios \w te|strong="H5921"\w* \w ayuda|strong="H5826"\w*.» Entonces \w David|strong="H1732"\w* \w los|strong="H5921"\w* recibió \w y|strong="H5921"\w* \w los|strong="H5921"\w* nombró capitanes \w de|strong="H5921"\w* \w la|strong="H5921"\w* tropa.   
\p
\v 19 Algunos \w de|strong="H3588"\w* Manasés también se unieron \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w cuando|strong="H3588"\w* vino \w con|strong="H5973"\w* \w los|strong="H1121"\w* filisteos \w contra|strong="H5973"\w* Saúl \w a|strong="H3068"\w* \w la|strong="H3588"\w* batalla, \w pero|strong="H3588"\w* \w no|strong="H3588"\w* \w los|strong="H1121"\w* \w ayudaron|strong="H5826"\w*, \w pues|strong="H3588"\w* \w los|strong="H1121"\w* \w príncipes|strong="H7218"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* filisteos lo despidieron después \w de|strong="H3588"\w* consultarlo, diciendo: «Desertará \w con|strong="H5973"\w* \w su|strong="H3588"\w* amo Saúl \w con|strong="H5973"\w* peligro \w de|strong="H3588"\w* nuestras \w cabezas|strong="H7218"\w*.»   
\p
\v 20 \w Cuando|strong="H3588"\w* \w se|strong="H5921"\w* dirigía \w a|strong="H3068"\w* Siclag, \w se|strong="H5921"\w* \w le|strong="H5921"\w* unieron \w algunos|strong="H5307"\w* \w de|strong="H4480"\w* \w Manasés|strong="H4519"\w*: Adnas, Jozabad, Jediael, Miguel, Jozabad, Eliú \w y|strong="H3588"\w* Ziletai, \w capitanes|strong="H7218"\w* \w de|strong="H4480"\w* millares \w que|strong="H3588"\w* eran \w de|strong="H4480"\w* \w Manasés|strong="H4519"\w*.  
