\v 17 \w David|strong="H1732"\w* también \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* ayudaran \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w*, diciendo:  
\v 18 «¿\w No|strong="H3808"\w* \w está|strong="H3427"\w* Yahvé vuestro \w Dios|strong="H3068"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*? ¿\w No|strong="H3808"\w* \w os|strong="H5973"\w* \w ha|strong="H3808"\w* \w dado|strong="H5414"\w* descanso \w por|strong="H3588"\w* todos \w lados|strong="H5439"\w*? \w Porque|strong="H3588"\w* \w él|strong="H5973"\w* \w ha|strong="H3808"\w* \w entregado|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w en|strong="H5973"\w* \w mis|strong="H5414"\w* \w manos|strong="H3027"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w está|strong="H3427"\w* sometida \w ante|strong="H6440"\w* Yahvé \w y|strong="H3588"\w* \w ante|strong="H6440"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*.  
\v 19 \w Ahora|strong="H6258"\w* disponed vuestro \w corazón|strong="H3824"\w* y vuestra \w alma|strong="H5315"\w* \w para|strong="H5414"\w* buscar \w a|strong="H3068"\w* Yahvé vuestro \w Dios|strong="H3068"\w*. \w Levantaos|strong="H6965"\w*, \w pues|strong="H6258"\w*, y \w edificad|strong="H1129"\w* el \w santuario|strong="H4720"\w* \w de|strong="H5414"\w* Yahvé \w Dios|strong="H3068"\w*, \w para|strong="H5414"\w* trasladar el arca \w de|strong="H5414"\w* la \w alianza|strong="H1285"\w* \w de|strong="H5414"\w* Yahvé y los utensilios \w sagrados|strong="H6944"\w* \w de|strong="H5414"\w* \w Dios|strong="H3068"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w que|strong="H6258"\w* se \w va|strong="H3068"\w* \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* al \w nombre|strong="H8034"\w* \w de|strong="H5414"\w* Yahvé.»   
\c 23
\p
\v 1 \w Cuando|strong="H3117"\w* \w David|strong="H1732"\w* \w era|strong="H1121"\w* ya anciano \w y|strong="H5921"\w* lleno \w de|strong="H5921"\w* \w días|strong="H3117"\w*, proclamó \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w rey|strong="H4427"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
