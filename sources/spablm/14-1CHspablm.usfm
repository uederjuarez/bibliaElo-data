\v 22 \w Porque|strong="H3588"\w* \w de|strong="H5921"\w* día \w en|strong="H5921"\w* día venían \w hombres|strong="H1368"\w* \w a|strong="H3068"\w* ayudar \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w hasta|strong="H5921"\w* \w que|strong="H3588"\w* \w hubo|strong="H1961"\w* un gran \w ejército|strong="H2428"\w*, \w como|strong="H3588"\w* \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* Dios.   
\p
\v 23 Estos \w son|strong="H3588"\w* \w los|strong="H5921"\w* números \w de|strong="H5921"\w* \w los|strong="H5921"\w* jefes \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* estaban armados \w para|strong="H5704"\w* \w la|strong="H5921"\w* guerra, \w que|strong="H3588"\w* vinieron \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w a|strong="H3068"\w* Hebrón \w para|strong="H5704"\w* entregarle \w el|strong="H5921"\w* reino \w de|strong="H5921"\w* Saúl, \w según|strong="H5921"\w* \w la|strong="H5921"\w* palabra \w de|strong="H5921"\w* Yahvé.  
