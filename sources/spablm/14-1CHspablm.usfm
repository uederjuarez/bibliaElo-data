\v 4 \w Obed-Edom|strong="H5654"\w* tuvo \w hijos|strong="H1121"\w*: \w Semaías|strong="H8098"\w* \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, \w Jozabad|strong="H3075"\w* \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*, Joa \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*, Sacar \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w*, Natanael \w el|strong="H1121"\w* \w quinto|strong="H2549"\w*,  
\v 5 Amiel \w el|strong="H3588"\w* \w sexto|strong="H8345"\w*, Isacar \w el|strong="H3588"\w* \w séptimo|strong="H7637"\w* \w y|strong="H3588"\w* Peuletai \w el|strong="H3588"\w* \w octavo|strong="H8066"\w*; \w porque|strong="H3588"\w* Dios lo \w bendijo|strong="H1288"\w*.  
\v 6 También le \w nacieron|strong="H3205"\w* \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* \w Semaías|strong="H8098"\w*, \w su|strong="H1992"\w* \w hijo|strong="H1121"\w*, \w que|strong="H3588"\w* gobernaban \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* padre, \w porque|strong="H3588"\w* eran \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Semaías|strong="H8098"\w*: Otni, Rafael, \w Obed|strong="H5744"\w* y Elzabad, cuyos hermanos eran \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w*, Eliú y Samaquías.  
\v 8 \w Todos|strong="H3605"\w* \w estos|strong="H1992"\w* fueron \w de|strong="H1121"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Obed-Edom|strong="H5654"\w*, con \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w* y \w sus|strong="H1992"\w* hermanos, \w hombres|strong="H8147"\w* sumamente capacitados para \w el|strong="H3605"\w* servicio: \w sesenta|strong="H8346"\w* y \w dos|strong="H8147"\w* \w de|strong="H1121"\w* \w Obed-Edom|strong="H5654"\w*.  
\v 9 Meselemías tenía \w hijos|strong="H1121"\w* y hermanos, \w dieciocho|strong="H8083"\w* \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w*.  
\v 10 También Hosa, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Merari|strong="H4847"\w*, \w tenía|strong="H1961"\w* \w hijos|strong="H1121"\w*: \w Simri|strong="H8113"\w*, \w el|strong="H3588"\w* \w jefe|strong="H7218"\w* (\w pues|strong="H3588"\w* \w aunque|strong="H3588"\w* \w no|strong="H3808"\w* \w era|strong="H1961"\w* \w el|strong="H3588"\w* \w primogénito|strong="H1060"\w*, \w su|strong="H3588"\w* padre \w lo|strong="H3808"\w* hizo \w jefe|strong="H7218"\w*),  
