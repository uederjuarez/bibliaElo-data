\p
\v 21 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w*: Mahli y Musi. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Mahli: Eleazar y \w Cis|strong="H7027"\w*.  
\v 22 Eleazar \w murió|strong="H4191"\w* \w sin|strong="H3808"\w* \w tener|strong="H1961"\w* \w hijos|strong="H1121"\w*, solo \w hijas|strong="H1323"\w*; \w y|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Cis|strong="H7027"\w*, sus parientes, las \w tomaron|strong="H5375"\w* \w por|strong="H3588"\w* \w mujeres|strong="H1323"\w*.  
\v 23 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Musi: Mahli, \w Eder|strong="H5740"\w* y Jeremot, \w tres|strong="H7969"\w*.   
\p
\v 24 Estos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w* según sus \w casas|strong="H1004"\w* paternas, \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* \w familia|strong="H1004"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* fueron censados contando \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* individualmente, \w los|strong="H1121"\w* cuales \w hacían|strong="H6213"\w* \w el|strong="H1121"\w* trabajo para \w el|strong="H1121"\w* servicio \w de|strong="H1121"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Yahvé, \w de|strong="H1121"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* para \w arriba|strong="H4605"\w*.  
\v 25 \w Porque|strong="H3588"\w* \w David|strong="H1732"\w* \w había|strong="H3588"\w* dicho: «Yahvé, \w el|strong="H3588"\w* \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, ha dado descanso \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H3588"\w* \w él|strong="H3588"\w* \w habitará|strong="H7931"\w* \w en|strong="H5704"\w* Jerusalén \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.  
\v 26 \w Así|strong="H1571"\w* \w que|strong="H1571"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* \w ya|strong="H1571"\w* no tendrán \w que|strong="H1571"\w* transportar \w el|strong="H3605"\w* \w tabernáculo|strong="H4908"\w* \w ni|strong="H1571"\w* \w ninguno|strong="H3605"\w* de \w los|strong="H3605"\w* utensilios para su servicio.»  
\v 27 \w Porque|strong="H3588"\w* según \w las|strong="H1992"\w* últimas disposiciones \w de|strong="H3588"\w* \w David|strong="H1732"\w*, \w se|strong="H1992"\w* hizo \w el|strong="H3588"\w* censo \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Leví|strong="H3881"\w* \w de|strong="H3588"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* \w para|strong="H3588"\w* \w arriba|strong="H4605"\w*.  
\v 28 \w Porque|strong="H3588"\w* \w su|strong="H3588"\w* deber \w era|strong="H1121"\w* asistir \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Aarón \w en|strong="H5921"\w* \w el|strong="H5921"\w* servicio \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé, \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w atrios|strong="H2691"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w cámaras|strong="H3957"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* purificación \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* cosas \w santas|strong="H6944"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w obra|strong="H4639"\w* \w del|strong="H5921"\w* servicio \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Dios|strong="H3068"\w*;  
\v 29 también para \w los|strong="H3605"\w* \w panes|strong="H3899"\w* de \w la|strong="H3605"\w* proposición, \w la|strong="H3605"\w* flor de harina para \w la|strong="H3605"\w* \w ofrenda|strong="H4503"\w*, las hojaldres sin levadura, \w lo|strong="H3605"\w* \w que|strong="H3605"\w* se cuece en \w sartén|strong="H4227"\w*, \w lo|strong="H3605"\w* \w que|strong="H3605"\w* se mezcla, y para \w todas|strong="H3605"\w* las medidas de capacidad y longitud;  
\v 30 y debían presentarse cada \w mañana|strong="H1242"\w* para dar gracias y \w alabar|strong="H1984"\w* \w a|strong="H3068"\w* Yahvé, y lo mismo al atardecer;  
\v 31 \w y|strong="H5921"\w* \w para|strong="H5921"\w* ofrecer \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w holocaustos|strong="H5930"\w* \w a|strong="H3068"\w* Yahvé \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w sábados|strong="H7676"\w*, \w en|strong="H5921"\w* \w las|strong="H5921"\w* lunas \w nuevas|strong="H2320"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* fiestas señaladas, \w según|strong="H5921"\w* \w el|strong="H5921"\w* \w número|strong="H4557"\w* fijado \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w ordenanza|strong="H4941"\w*, \w continuamente|strong="H8548"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé;  
\v 32 y \w tenían|strong="H8104"\w* \w a|strong="H3068"\w* su cargo \w el|strong="H1121"\w* cuidado \w de|strong="H1121"\w* \w la|strong="H8104"\w* Tienda \w de|strong="H1121"\w* Reunión, \w el|strong="H1121"\w* cuidado del \w santuario|strong="H6944"\w* y \w el|strong="H1121"\w* deber \w de|strong="H1121"\w* asistir \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, sus hermanos, en \w el|strong="H1121"\w* servicio \w de|strong="H1121"\w* \w la|strong="H8104"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Yahvé.   
\c 24
\p
\v 1 Estas fueron las divisiones \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón: \w Nadab|strong="H5070"\w*, Abiú, Eleazar \w e|strong="H3068"\w* Itamar.  
\v 2 Pero \w Nadab|strong="H5070"\w* y Abiú \w murieron|strong="H4191"\w* \w antes|strong="H6440"\w* \w que|strong="H3808"\w* \w su|strong="H1992"\w* padre y \w no|strong="H3808"\w* \w tuvieron|strong="H1961"\w* \w hijos|strong="H1121"\w*; \w por|strong="H6440"\w* \w lo|strong="H3808"\w* tanto, Eleazar \w e|strong="H3068"\w* Itamar sirvieron \w como|strong="H1961"\w* sacerdotes.  
\v 3 \w David|strong="H1732"\w*, junto \w con|strong="H4480"\w* \w Sadoc|strong="H6659"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Eleazar, y Ahimelec \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Itamar, \w los|strong="H1121"\w* distribuyó según su turno \w en|strong="H4480"\w* \w el|strong="H1121"\w* servicio.  
\v 4 \w Al|strong="H4480"\w* encontrarse \w que|strong="H4480"\w* \w había|strong="H4672"\w* \w más|strong="H4480"\w* \w varones|strong="H1397"\w* \w principales|strong="H7218"\w* \w entre|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Eleazar \w que|strong="H4480"\w* \w entre|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Itamar, \w los|strong="H1121"\w* dividieron así: \w dieciséis|strong="H8337"\w* \w jefes|strong="H7218"\w* \w de|strong="H4480"\w* \w casas|strong="H1004"\w* paternas \w para|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Eleazar, y \w ocho|strong="H8083"\w* \w para|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Itamar, según sus \w familias|strong="H1004"\w*.  
\v 5 \w Fueron|strong="H1961"\w* repartidos imparcialmente \w por|strong="H3588"\w* sorteo, unos \w y|strong="H3588"\w* otros, \w pues|strong="H3588"\w* \w había|strong="H1961"\w* oficiales \w del|strong="H5973"\w* \w santuario|strong="H6944"\w* \w y|strong="H3588"\w* oficiales \w de|strong="H3588"\w* Dios tanto \w entre|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Eleazar \w como|strong="H3588"\w* \w entre|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Itamar.  
\v 6 \w El|strong="H1121"\w* \w escriba|strong="H5608"\w* \w Semaías|strong="H8098"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Natanael, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, inscribió sus nombres \w en|strong="H4480"\w* \w presencia|strong="H6440"\w* \w del|strong="H4480"\w* \w rey|strong="H4428"\w*, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w*, \w del|strong="H4480"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w de|strong="H4480"\w* Ahimelec \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Abiatar, y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H4480"\w* las \w casas|strong="H1004"\w* paternas \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*; \w se|strong="H4480"\w* tomaba \w por|strong="H4480"\w* sorteo una \w casa|strong="H1004"\w* paterna \w para|strong="H4480"\w* Eleazar y otra \w para|strong="H4480"\w* Itamar.   
\p
\v 7 La \w primera|strong="H7223"\w* \w suerte|strong="H1486"\w* recayó \w en|strong="H3318"\w* \w Joiarib|strong="H3080"\w*, la \w segunda|strong="H8145"\w* \w en|strong="H3318"\w* \w Jedaías|strong="H3048"\w*,  
