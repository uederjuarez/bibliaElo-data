\v 17 \w Las|strong="H1992"\w* basas de \w las|strong="H1992"\w* \w columnas|strong="H5982"\w* eran de bronce, \w los|strong="H1992"\w* capiteles de \w las|strong="H1992"\w* \w columnas|strong="H5982"\w* y \w sus|strong="H1992"\w* \w molduras|strong="H2838"\w* eran de \w plata|strong="H3701"\w*, y \w el|strong="H3605"\w* revestimiento de \w sus|strong="H1992"\w* \w cabezas|strong="H7218"\w* era de \w plata|strong="H3701"\w*. \w Todas|strong="H3605"\w* \w las|strong="H1992"\w* \w columnas|strong="H5982"\w* del \w atrio|strong="H2691"\w* \w estaban|strong="H7218"\w* unidas con varillas de \w plata|strong="H3701"\w*.  
\v 18 La cortina \w de|strong="H2568"\w* la \w puerta|strong="H8179"\w* del \w atrio|strong="H2691"\w* era \w obra|strong="H4639"\w* \w de|strong="H2568"\w* recamador, \w de|strong="H2568"\w* hilo azul, púrpura, escarlata y lino fino \w torcido|strong="H7806"\w*. Su longitud era \w de|strong="H2568"\w* \w veinte|strong="H6242"\w* codos, y su \w altura|strong="H6967"\w* \w a|strong="H3068"\w* lo ancho era \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* codos, en proporción con las \w cortinas|strong="H7050"\w* del \w atrio|strong="H2691"\w*.  
\v 19 Sus \w columnas|strong="H5982"\w* eran cuatro, con sus cuatro basas de bronce; sus capiteles eran de \w plata|strong="H3701"\w*, y el revestimiento de sus \w cabezas|strong="H7218"\w* y sus \w molduras|strong="H2838"\w* eran de \w plata|strong="H3701"\w*.  
\v 20 \w Todas|strong="H3605"\w* las estacas del \w tabernáculo|strong="H4908"\w* y del \w atrio|strong="H2691"\w* en \w derredor|strong="H5439"\w* eran de bronce.   
\p
\v 21 Este \w es|strong="H3027"\w* \w el|strong="H5921"\w* inventario \w de|strong="H5921"\w* \w los|strong="H1121"\w* materiales \w del|strong="H5921"\w* \w tabernáculo|strong="H4908"\w*, \w el|strong="H5921"\w* \w Tabernáculo|strong="H4908"\w* \w del|strong="H5921"\w* \w Testimonio|strong="H5715"\w*, tal \w como|strong="H5921"\w* fueron contados \w por|strong="H5921"\w* \w mandato|strong="H6310"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*, \w para|strong="H5921"\w* \w el|strong="H5921"\w* servicio \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, bajo \w la|strong="H5921"\w* dirección \w de|strong="H5921"\w* Itamar, \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Aarón.  
\v 22 Bezalel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uri, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hur|strong="H2354"\w*, \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w hizo|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* Yahvé \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.  
