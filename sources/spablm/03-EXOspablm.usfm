\v 15 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H3588"\w*, \w cuando|strong="H3588"\w* \w el|strong="H5921"\w* \w faraón|strong="H6547"\w* \w se|strong="H1961"\w* obstinó \w en|strong="H5921"\w* \w no|strong="H3588"\w* dejarnos \w ir|strong="H7971"\w*, Yahvé \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w primogénitos|strong="H1060"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w tanto|strong="H3651"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w primogénitos|strong="H1060"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w como|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w primogénitos|strong="H1060"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w animales|strong="H1121"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w yo|strong="H3588"\w* \w sacrifico|strong="H2076"\w* \w a|strong="H3068"\w* Yahvé \w todo|strong="H3605"\w* \w macho|strong="H2145"\w* \w que|strong="H3588"\w* abre \w la|strong="H5921"\w* \w matriz|strong="H7358"\w*, \w pero|strong="H3588"\w* redimo \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w primogénitos|strong="H1060"\w* \w de|strong="H5921"\w* mis \w hijos|strong="H1121"\w*’.  
\v 16 \w Os|strong="H5921"\w* \w servirá|strong="H1961"\w* \w como|strong="H3588"\w* una señal \w en|strong="H5921"\w* \w vuestra|strong="H1961"\w* \w mano|strong="H3027"\w* \w y|strong="H3588"\w* \w como|strong="H3588"\w* unas filacterias \w entre|strong="H5921"\w* vuestros \w ojos|strong="H5869"\w*, \w porque|strong="H3588"\w* \w con|strong="H5921"\w* \w mano|strong="H3027"\w* \w fuerte|strong="H2392"\w* Yahvé \w nos|strong="H5921"\w* \w sacó|strong="H3318"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.”   
\p
\v 17 \w Cuando|strong="H3588"\w* \w el|strong="H1931"\w* \w faraón|strong="H6547"\w* \w dejó|strong="H7971"\w* \w ir|strong="H7971"\w* al \w pueblo|strong="H5971"\w*, Dios \w no|strong="H3808"\w* \w los|strong="H1931"\w* condujo \w por|strong="H3588"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w filisteos|strong="H6430"\w*, \w aunque|strong="H3588"\w* \w estaba|strong="H1961"\w* \w cerca|strong="H7138"\w*; \w porque|strong="H3588"\w* Dios dijo: «\w No|strong="H3808"\w* \w sea|strong="H1961"\w* \w que|strong="H3588"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* cambie \w de|strong="H3588"\w* opinión al \w ver|strong="H7200"\w* \w la|strong="H1931"\w* \w guerra|strong="H4421"\w*, \w y|strong="H3588"\w* \w vuelva|strong="H7725"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*»;  
\v 18 sino \w que|strong="H5971"\w* Dios \w hizo|strong="H5927"\w* \w que|strong="H5971"\w* \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w* diera un \w rodeo|strong="H5437"\w* \w por|strong="H1870"\w* \w el|strong="H1121"\w* \w camino|strong="H1870"\w* del \w desierto|strong="H4057"\w*, \w hacia|strong="H1870"\w* \w el|strong="H1121"\w* \w Mar|strong="H3220"\w* Rojo; y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w subieron|strong="H5927"\w* \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w* ordenados como un ejército.  
\v 19 \w Moisés|strong="H4872"\w* \w llevó|strong="H3947"\w* \w consigo|strong="H5973"\w* \w los|strong="H1121"\w* \w huesos|strong="H6106"\w* \w de|strong="H3588"\w* \w José|strong="H3130"\w*, \w porque|strong="H3588"\w* \w este|strong="H2088"\w* \w había|strong="H3588"\w* hecho jurar solemnemente \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, diciendo: “\w Ciertamente|strong="H3588"\w* Dios \w os|strong="H5973"\w* \w visitará|strong="H6485"\w*, \w y|strong="H3588"\w* \w entonces|strong="H3588"\w* llevaréis \w de|strong="H3588"\w* \w aquí|strong="H2088"\w* mis \w huesos|strong="H6106"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*.”  
\v 20 \w Partieron|strong="H5265"\w* de Sucot y acamparon en Etam, al borde del \w desierto|strong="H4057"\w*.  
\v 21 Yahvé \w iba|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos \w de|strong="H6440"\w* \w día|strong="H3119"\w* \w en|strong="H3212"\w* una \w columna|strong="H5982"\w* \w de|strong="H6440"\w* \w nube|strong="H6051"\w*, para guiarlos \w por|strong="H1870"\w* el \w camino|strong="H1870"\w*, y \w de|strong="H6440"\w* \w noche|strong="H3915"\w* \w en|strong="H3212"\w* una \w columna|strong="H5982"\w* \w de|strong="H6440"\w* fuego, para alumbrarles, \w a|strong="H3068"\w* fin \w de|strong="H6440"\w* que pudieran marchar \w de|strong="H6440"\w* \w día|strong="H3119"\w* y \w de|strong="H6440"\w* \w noche|strong="H3915"\w*.  
