\p
\v 24 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w oro|strong="H2091"\w* \w que|strong="H1961"\w* \w se|strong="H1961"\w* utilizó en \w la|strong="H3605"\w* \w obra|strong="H4399"\w*, en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* del \w santuario|strong="H6944"\w*, \w el|strong="H3605"\w* \w oro|strong="H2091"\w* de \w la|strong="H3605"\w* \w ofrenda|strong="H8573"\w*, \w fue|strong="H1961"\w* de \w veintinueve|strong="H6242"\w* \w talentos|strong="H3603"\w*\f + \fr 38:24 \ft Un talento equivale a unos 34 kilogramos.\f* y \w setecientos|strong="H7651"\w* \w treinta|strong="H7970"\w* \w siclos|strong="H8255"\w*, según \w el|strong="H3605"\w* \w siclo|strong="H8255"\w* del \w santuario|strong="H6944"\w*. \f + \fr 38:24 \ft Un siclo equivale a unos 11,4 gramos.\f*  
\v 25 La \w plata|strong="H3701"\w* \w de|strong="H2568"\w* los empadronados \w de|strong="H2568"\w* la congregación fue \w de|strong="H2568"\w* \w cien|strong="H3967"\w* \w talentos|strong="H3603"\w*\f + \fr 38:25 \ft Un talento equivale a unos 34 kilogramos.\f* y \w mil|strong="H3967"\w* \w setecientos|strong="H7651"\w* \w setenta|strong="H7657"\w* y \w cinco|strong="H2568"\w* \w siclos|strong="H8255"\w*, según el \w siclo|strong="H8255"\w* del \w santuario|strong="H6944"\w*:  
\v 26 un becá \w por|strong="H5921"\w* cabeza, es decir, \w medio|strong="H1235"\w* \w siclo|strong="H8255"\w*, \w según|strong="H5921"\w* \w el|strong="H5921"\w* \w siclo|strong="H8255"\w* \w del|strong="H5921"\w* \w santuario|strong="H6944"\w*, \w por|strong="H5921"\w* \w cada|strong="H3605"\w* uno \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* fueron censados \w de|strong="H5921"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* \w para|strong="H5921"\w* \w arriba|strong="H4605"\w*, \w que|strong="H5921"\w* fueron \w seiscientos|strong="H8337"\w* \w tres|strong="H7969"\w* \w mil|strong="H3967"\w* \w quinientos|strong="H2568"\w* \w cincuenta|strong="H2572"\w* \w hombres|strong="H1121"\w*.  
\v 27 \w Los|strong="H1961"\w* \w cien|strong="H3967"\w* \w talentos|strong="H3603"\w* de \w plata|strong="H3701"\w* \w se|strong="H1961"\w* emplearon \w para|strong="H1961"\w* fundir las basas del \w santuario|strong="H6944"\w* y las basas del velo: \w cien|strong="H3967"\w* basas por \w los|strong="H1961"\w* \w cien|strong="H3967"\w* \w talentos|strong="H3603"\w*, un talento por basa.  
\v 28 \w De|strong="H2568"\w* los \w mil|strong="H3967"\w* \w setecientos|strong="H7651"\w* \w setenta|strong="H7657"\w* y \w cinco|strong="H2568"\w* siclos \w de|strong="H2568"\w* plata, \w hizo|strong="H6213"\w* los ganchos para las \w columnas|strong="H5982"\w*, recubrió sus capiteles \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* sus molduras.  
