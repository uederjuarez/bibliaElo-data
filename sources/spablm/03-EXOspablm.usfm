\v 7 Aarón \w quemará|strong="H6999"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* incienso \w aromático|strong="H5561"\w*; \w lo|strong="H5921"\w* \w quemará|strong="H6999"\w* cada \w mañana|strong="H1242"\w* cuando prepare \w las|strong="H5921"\w* \w lámparas|strong="H5216"\w*.  
\v 8 \w Y|strong="H3068"\w* cuando Aarón encienda las \w lámparas|strong="H5216"\w* al atardecer, \w quemará|strong="H6999"\w* el incienso; será un incienso \w continuo|strong="H8548"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w por|strong="H6440"\w* vuestras \w generaciones|strong="H1755"\w*.  
\v 9 \w No|strong="H3808"\w* \w ofreceréis|strong="H5927"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* incienso \w extraño|strong="H2114"\w*, \w ni|strong="H3808"\w* \w holocausto|strong="H5930"\w*, \w ni|strong="H3808"\w* \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* cereal; \w ni|strong="H3808"\w* derramaréis \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w libación|strong="H5262"\w* alguna.  
\v 10 Una vez \w al|strong="H5921"\w* \w año|strong="H8141"\w*, Aarón hará \w expiación|strong="H3722"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w cuernos|strong="H7161"\w* \w de|strong="H5921"\w* \w este|strong="H1931"\w* altar. \w Con|strong="H5921"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* \w del|strong="H5921"\w* sacrificio \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w pecado|strong="H2403"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w expiaciones|strong="H2403"\w*, una vez \w al|strong="H5921"\w* \w año|strong="H8141"\w* hará \w expiación|strong="H3722"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* \w a|strong="H3068"\w* \w lo|strong="H1931"\w* largo \w de|strong="H5921"\w* vuestras \w generaciones|strong="H1755"\w*. \w Será|strong="H1931"\w* \w santísimo|strong="H6944"\w* \w para|strong="H5921"\w* Yahvé».   
\p
\v 11 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 12 “\w Cuando|strong="H3588"\w* hagas \w el|strong="H3588"\w* censo \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w para|strong="H3588"\w* empadronarlos, cada uno \w dará|strong="H5414"\w* \w a|strong="H3068"\w* Yahvé un \w rescate|strong="H3724"\w* \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w vida|strong="H5315"\w* al \w ser|strong="H5315"\w* empadronado, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w haya|strong="H1961"\w* \w plaga|strong="H5063"\w* \w entre|strong="H3808"\w* ellos al contarlos.  
\v 13 \w Esto|strong="H2088"\w* \w dará|strong="H5414"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* sea incluido \w en|strong="H5921"\w* \w el|strong="H5921"\w* censo: \w medio|strong="H4276"\w* \w siclo|strong="H8255"\w*, \w conforme|strong="H5921"\w* \w al|strong="H5921"\w* \w siclo|strong="H8255"\w*\f + \fr 30:13 \ft Un siclo equivale a unos 10 gramos o a unas 0,35 onzas.\f* \w del|strong="H5921"\w* \w santuario|strong="H6944"\w* (\w el|strong="H5921"\w* \w siclo|strong="H8255"\w* \w es|strong="H2088"\w* \w de|strong="H5921"\w* \w veinte|strong="H6242"\w* \w geras|strong="H1626"\w*\f + \fr 30:13 \ft Una gera equivale a unos 0,5 gramos.\f*). \w Este|strong="H2088"\w* \w medio|strong="H4276"\w* \w siclo|strong="H8255"\w* \w será|strong="H5414"\w* \w la|strong="H5921"\w* \w ofrenda|strong="H8641"\w* \w a|strong="H3068"\w* Yahvé.  
\v 14 \w Todo|strong="H3605"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* sea incluido \w en|strong="H5921"\w* \w el|strong="H5921"\w* censo, \w de|strong="H5921"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* \w en|strong="H5921"\w* adelante, \w dará|strong="H5414"\w* \w esta|strong="H5921"\w* \w ofrenda|strong="H8641"\w* \w a|strong="H3068"\w* Yahvé.  
\v 15 \w El|strong="H5921"\w* \w rico|strong="H6223"\w* \w no|strong="H3808"\w* \w dará|strong="H5414"\w* \w más|strong="H5921"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pobre|strong="H1800"\w* \w no|strong="H3808"\w* \w dará|strong="H5414"\w* menos \w del|strong="H5921"\w* \w medio|strong="H4276"\w* \w siclo|strong="H8255"\w*,\f + \fr 30:15 \ft Un siclo equivale a unos 10 gramos o a unas 0,35 onzas.\f* cuando deis \w la|strong="H5921"\w* \w ofrenda|strong="H8641"\w* \w a|strong="H3068"\w* Yahvé \w para|strong="H5921"\w* hacer \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* vuestras \w vidas|strong="H5315"\w*.  
\v 16 \w Tomarás|strong="H3947"\w* \w el|strong="H5921"\w* \w dinero|strong="H3701"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* expiaciones \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* destinarás \w al|strong="H5921"\w* servicio \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w sea|strong="H1961"\w* un memorial \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w para|strong="H5921"\w* hacer \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* vuestras \w vidas|strong="H5315"\w*.”   
\p
\v 17 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 18 “\w Harás|strong="H6213"\w* también una pila \w de|strong="H5414"\w* bronce, con su basa \w de|strong="H5414"\w* bronce, \w para|strong="H5414"\w* lavarse. La \w pondrás|strong="H5414"\w* \w entre|strong="H8033"\w* la Tienda \w del|strong="H4196"\w* Encuentro y \w el|strong="H6213"\w* \w altar|strong="H4196"\w*, y echarás \w agua|strong="H4325"\w* en \w ella|strong="H8033"\w*.  
\v 19 Aarón y sus \w hijos|strong="H1121"\w* \w se|strong="H4480"\w* \w lavarán|strong="H7364"\w* \w en|strong="H4480"\w* \w ella|strong="H4480"\w* las \w manos|strong="H3027"\w* y \w los|strong="H1121"\w* \w pies|strong="H7272"\w*.  
\v 20 Cuando entren en la Tienda \w del|strong="H4196"\w* Encuentro, \w se|strong="H3808"\w* \w lavarán|strong="H7364"\w* con \w agua|strong="H4325"\w*, para \w no|strong="H3808"\w* \w morir|strong="H4191"\w*; \w de|strong="H4325"\w* igual manera cuando \w se|strong="H3808"\w* acerquen al \w altar|strong="H4196"\w* para ministrar, para quemar una ofrenda encendida \w a|strong="H3068"\w* Yahvé.  
\v 21 \w Se|strong="H1961"\w* \w lavarán|strong="H7364"\w* las \w manos|strong="H3027"\w* y \w los|strong="H1961"\w* \w pies|strong="H7272"\w* \w para|strong="H1961"\w* \w no|strong="H3808"\w* \w morir|strong="H4191"\w*. Esto les \w será|strong="H1961"\w* \w por|strong="H3027"\w* \w estatuto|strong="H2706"\w* \w perpetuo|strong="H5769"\w*, \w a|strong="H3068"\w* él y \w a|strong="H3068"\w* su \w descendencia|strong="H2233"\w* \w por|strong="H3027"\w* sus \w generaciones|strong="H1755"\w*.”   
\p
\v 22 Además, Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 23 “\w Toma|strong="H3947"\w* también las mejores \w especias|strong="H1314"\w*: \w de|strong="H2568"\w* \w mirra|strong="H4753"\w* líquida, \w quinientos|strong="H2568"\w* siclos;\f + \fr 30:23 \ft Un siclo equivale a unos 10 gramos o a unas 0,35 onzas, por lo que 500 siclos equivalen a unos 5 kilogramos o a unas 11 libras.\f* \w de|strong="H2568"\w* canela \w aromática|strong="H1314"\w* la mitad, es decir, \w doscientos|strong="H3967"\w* \w cincuenta|strong="H2572"\w*; \w de|strong="H2568"\w* cálamo \w aromático|strong="H1314"\w*, \w doscientos|strong="H3967"\w* \w cincuenta|strong="H2572"\w*;  
\v 24 \w de|strong="H2568"\w* casia, \w quinientos|strong="H2568"\w*, según el \w siclo|strong="H8255"\w* del \w santuario|strong="H6944"\w*; y un \w hin|strong="H1969"\w*\f + \fr 30:24 \ft Un hin equivale a unos 3,8 litros o a 1 galón.\f* \w de|strong="H2568"\w* \w aceite|strong="H8081"\w* \w de|strong="H2568"\w* oliva.  
\v 25 Con ello \w harás|strong="H6213"\w* \w el|strong="H6213"\w* \w aceite|strong="H8081"\w* de la \w santa|strong="H6944"\w* \w unción|strong="H4888"\w*, un \w ungüento|strong="H8081"\w* compuesto según \w el|strong="H6213"\w* arte del perfumista. \w Este|strong="H1961"\w* \w será|strong="H1961"\w* \w el|strong="H6213"\w* \w aceite|strong="H8081"\w* de la \w santa|strong="H6944"\w* \w unción|strong="H4888"\w*.  
\v 26 Con él \w ungirás|strong="H4886"\w* la Tienda del Encuentro, el arca del \w Testimonio|strong="H5715"\w*,  
\v 27 \w la|strong="H3605"\w* \w mesa|strong="H7979"\w* y \w todos|strong="H3605"\w* sus utensilios, \w el|strong="H3605"\w* candelabro y sus utensilios, \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w del|strong="H4196"\w* incienso,  
\v 28 \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w del|strong="H4196"\w* \w holocausto|strong="H5930"\w* con \w todos|strong="H3605"\w* sus utensilios, y \w la|strong="H3605"\w* pila con su basa.  
\v 29 \w Los|strong="H3605"\w* consagrarás, y \w serán|strong="H1961"\w* santísimos. \w Todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1961"\w* \w los|strong="H3605"\w* toque \w será|strong="H1961"\w* \w santificado|strong="H6944"\w*.  
\v 30 \w Ungirás|strong="H4886"\w* \w a|strong="H3068"\w* Aarón y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*, y \w los|strong="H1121"\w* consagrarás para \w que|strong="H1121"\w* me sirvan como sacerdotes.  
\v 31 \w Y|strong="H3068"\w* \w hablarás|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w diciendo|strong="H1696"\w*: ‘\w Este|strong="H2088"\w* \w será|strong="H1961"\w* \w mi|strong="H1961"\w* \w aceite|strong="H8081"\w* \w de|strong="H1121"\w* la \w santa|strong="H6944"\w* \w unción|strong="H4888"\w* \w a|strong="H3068"\w* \w lo|strong="H2088"\w* largo \w de|strong="H1121"\w* vuestras \w generaciones|strong="H1755"\w*.  
\v 32 \w No|strong="H3808"\w* \w se|strong="H1961"\w* derramará \w sobre|strong="H5921"\w* \w el|strong="H1931"\w* cuerpo \w de|strong="H5921"\w* \w ningún|strong="H3808"\w* hombre, \w ni|strong="H3808"\w* \w haréis|strong="H6213"\w* otro igual \w con|strong="H5921"\w* \w la|strong="H1931"\w* \w misma|strong="H1931"\w* \w composición|strong="H4971"\w*. \w Es|strong="H1931"\w* \w santo|strong="H6944"\w*, \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w santo|strong="H6944"\w* \w lo|strong="H1931"\w* \w tendréis|strong="H1961"\w* vosotros.  
\v 33 Cualquiera \w que|strong="H4480"\w* componga un ungüento semejante, \w o|strong="H3068"\w* \w que|strong="H4480"\w* ponga \w de|strong="H4480"\w* \w él|strong="H5921"\w* \w sobre|strong="H5921"\w* un \w extraño|strong="H2114"\w*, \w será|strong="H5414"\w* excluido \w de|strong="H4480"\w* su \w pueblo|strong="H5971"\w*’”.   
\p
\v 34 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Toma|strong="H3947"\w* especias aromáticas: \w estacte|strong="H5198"\w*, uña aromática y gálbano \w aromático|strong="H5561"\w*, junto con \w incienso|strong="H3828"\w* \w puro|strong="H2134"\w*. \w Habrá|strong="H1961"\w* la misma cantidad de cada una.  
\v 35 \w Harás|strong="H6213"\w* con ello incienso, un \w perfume|strong="H7004"\w* según \w el|strong="H6213"\w* arte del perfumista, bien mezclado, \w puro|strong="H2889"\w* y \w santo|strong="H6944"\w*.  
\v 36 Molerás una parte \w de|strong="H4480"\w* él hasta hacerlo polvo muy fino, y lo \w pondrás|strong="H5414"\w* \w delante|strong="H6440"\w* \w del|strong="H4480"\w* \w Testimonio|strong="H5715"\w* \w en|strong="H4480"\w* la Tienda \w del|strong="H4480"\w* Encuentro, \w donde|strong="H8033"\w* \w me|strong="H4480"\w* encontraré \w contigo|strong="H6440"\w*. \w Será|strong="H1961"\w* \w para|strong="H4480"\w* vosotros \w santísimo|strong="H6944"\w*.  
\v 37 En cuanto al incienso \w que|strong="H3808"\w* \w haréis|strong="H6213"\w*, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w haréis|strong="H6213"\w* \w para|strong="H1961"\w* vosotros según su \w composición|strong="H4971"\w*; \w lo|strong="H3808"\w* \w tendréis|strong="H1961"\w* por cosa \w consagrada|strong="H6944"\w* \w a|strong="H3068"\w* Yahvé.  
\v 38 Cualquiera \w que|strong="H5971"\w* \w haga|strong="H6213"\w* otro semejante \w para|strong="H5971"\w* disfrutar \w de|strong="H5971"\w* su aroma, \w será|strong="H6213"\w* excluido \w de|strong="H5971"\w* su \w pueblo|strong="H5971"\w*.”   
\c 31
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Mira|strong="H7200"\w*, he \w llamado|strong="H8034"\w* por su \w nombre|strong="H8034"\w* \w a|strong="H3068"\w* Bezalel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uri, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hur|strong="H2354"\w*, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 3 \w Lo|strong="H3605"\w* he llenado del \w Espíritu|strong="H7307"\w* de Dios, de \w sabiduría|strong="H2451"\w*, de \w inteligencia|strong="H8394"\w*, de \w conocimiento|strong="H1847"\w* y de \w toda|strong="H3605"\w* clase de habilidad,  
\v 4 para concebir \w diseños|strong="H4284"\w* artísticos, para \w trabajar|strong="H6213"\w* en \w oro|strong="H2091"\w*, en \w plata|strong="H3701"\w* y en bronce,  
\v 5 y en \w el|strong="H3605"\w* tallado de piedras para engastar, y en \w el|strong="H3605"\w* tallado de \w madera|strong="H6086"\w*, para \w trabajar|strong="H6213"\w* en \w toda|strong="H3605"\w* clase de artesanía.  
\v 6 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H1121"\w* \w yo|strong="H2009"\w* \w mismo|strong="H3605"\w* he designado con \w él|strong="H3605"\w* \w a|strong="H3068"\w* Aholiab, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahisamac, \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w*; y he \w puesto|strong="H5414"\w* \w sabiduría|strong="H2451"\w* en \w el|strong="H3605"\w* \w corazón|strong="H3820"\w* \w de|strong="H1121"\w* \w todo|strong="H3605"\w* artesano experto, \w para|strong="H5414"\w* \w que|strong="H1121"\w* \w hagan|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* te he \w mandado|strong="H6680"\w*:  
\v 7 \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w el|strong="H5921"\w* arca \w del|strong="H5921"\w* \w Testimonio|strong="H5715"\w*, \w el|strong="H5921"\w* propiciatorio \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ella|strong="H3605"\w*, \w todo|strong="H3605"\w* \w el|strong="H5921"\w* mobiliario \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda,  
\v 8 \w la|strong="H3605"\w* \w mesa|strong="H7979"\w* y sus utensilios, \w el|strong="H3605"\w* candelabro de oro \w puro|strong="H2889"\w* con \w todos|strong="H3605"\w* sus utensilios, \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w del|strong="H4196"\w* incienso,  
\v 9 \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w del|strong="H3653"\w* \w holocausto|strong="H5930"\w* con \w todos|strong="H3605"\w* sus utensilios, \w la|strong="H3605"\w* pila y su basa,  
\v 10 las vestiduras finamente tejidas, las vestiduras \w sagradas|strong="H6944"\w* para \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Aarón y las vestiduras \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* para servir en \w el|strong="H1121"\w* oficio sacerdotal,  
\v 11 \w el|strong="H3605"\w* \w aceite|strong="H8081"\w* de \w la|strong="H3605"\w* \w unción|strong="H4888"\w* y \w el|strong="H3605"\w* incienso \w aromático|strong="H5561"\w* para \w el|strong="H3605"\w* Lugar \w Santo|strong="H6944"\w*. \w Lo|strong="H6213"\w* \w harán|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* te he \w mandado|strong="H6680"\w*.”   
\p
\v 12 Yahvé habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, diciendo:  
\v 13 “\w Habla|strong="H1696"\w* también \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Ciertamente|strong="H3588"\w* \w guardaréis|strong="H8104"\w* mis días \w de|strong="H3588"\w* reposo, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* una señal \w entre|strong="H3588"\w* vosotros \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w por|strong="H3588"\w* vuestras \w generaciones|strong="H1755"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w sepáis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1931"\w* Yahvé, \w el|strong="H1931"\w* \w que|strong="H3588"\w* os \w santifica|strong="H6942"\w*.  
\v 14 \w Por|strong="H3588"\w* \w lo|strong="H1931"\w* tanto, \w guardaréis|strong="H8104"\w* \w el|strong="H1931"\w* día \w de|strong="H3588"\w* reposo, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w santo|strong="H6944"\w* \w para|strong="H3588"\w* vosotros. \w El|strong="H1931"\w* \w que|strong="H3588"\w* \w lo|strong="H1931"\w* \w profane|strong="H2490"\w* \w será|strong="H1931"\w* condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*; \w pues|strong="H3588"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H3588"\w* \w haga|strong="H6213"\w* algún trabajo \w en|strong="H3588"\w* \w él|strong="H1931"\w*, \w esa|strong="H1931"\w* \w persona|strong="H5315"\w* \w será|strong="H1931"\w* excluida \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*.  
\v 15 \w Seis|strong="H8337"\w* \w días|strong="H3117"\w* se trabajará, pero \w el|strong="H3605"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* es \w día|strong="H3117"\w* de descanso solemne, \w consagrado|strong="H6944"\w* \w a|strong="H3068"\w* Yahvé. \w Cualquiera|strong="H3605"\w* \w que|strong="H3117"\w* \w haga|strong="H6213"\w* algún trabajo en \w el|strong="H3605"\w* \w día|strong="H3117"\w* de reposo \w será|strong="H6213"\w* condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*.  
\v 16 \w Por|strong="H5769"\w* \w lo|strong="H6213"\w* tanto, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w guardarán|strong="H8104"\w* \w el|strong="H1121"\w* \w día|strong="H1121"\w* \w de|strong="H1121"\w* reposo, \w celebrándolo|strong="H6213"\w* \w a|strong="H3068"\w* \w lo|strong="H6213"\w* largo \w de|strong="H1121"\w* sus \w generaciones|strong="H1755"\w* como un \w pacto|strong="H1285"\w* \w perpetuo|strong="H5769"\w*.  
\v 17 \w Es|strong="H1931"\w* una señal \w entre|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w para|strong="H3588"\w* \w siempre|strong="H5769"\w*; \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w seis|strong="H8337"\w* \w días|strong="H3117"\w* Yahvé \w hizo|strong="H6213"\w* \w los|strong="H1121"\w* \w cielos|strong="H8064"\w* \w y|strong="H3588"\w* \w la|strong="H1931"\w* tierra, \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H1931"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w cesó|strong="H7673"\w* \w de|strong="H3588"\w* \w trabajar|strong="H6213"\w* \w y|strong="H3588"\w* descansó’”.   
\p
\v 18 Cuando terminó \w de|strong="H5414"\w* \w hablar|strong="H1696"\w* con él en el \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*, \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* las \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* del \w Testimonio|strong="H5715"\w*, \w tablas|strong="H3871"\w* \w de|strong="H5414"\w* piedra \w escritas|strong="H3789"\w* \w por|strong="H3789"\w* el dedo \w de|strong="H5414"\w* Dios.   
\c 32
\p
\v 1 \w Cuando|strong="H3588"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w Moisés|strong="H4872"\w* tardaba \w en|strong="H5921"\w* bajar \w del|strong="H4480"\w* \w monte|strong="H2022"\w*, \w se|strong="H3045"\w* reunió \w alrededor|strong="H4480"\w* \w de|strong="H4480"\w* Aarón \w y|strong="H3588"\w* \w le|strong="H5921"\w* dijo: “\w Levántate|strong="H6965"\w*, \w haznos|strong="H6213"\w* dioses \w que|strong="H3588"\w* \w vayan|strong="H3212"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w nosotros|strong="H5921"\w*; \w porque|strong="H3588"\w* \w en|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w Moisés|strong="H4872"\w*, \w el|strong="H5921"\w* hombre \w que|strong="H3588"\w* \w nos|strong="H5921"\w* \w sacó|strong="H5927"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*, \w no|strong="H3808"\w* \w sabemos|strong="H3045"\w* \w qué|strong="H3588"\w* \w le|strong="H5921"\w* \w ha|strong="H3808"\w* pasado.”   
\p
\v 2 Aarón les respondió: «Quitad \w los|strong="H1121"\w* zarcillos \w de|strong="H1121"\w* \w oro|strong="H2091"\w* \w que|strong="H1121"\w* están en las orejas \w de|strong="H1121"\w* vuestras \w mujeres|strong="H1323"\w*, \w de|strong="H1121"\w* vuestros \w hijos|strong="H1121"\w* y \w de|strong="H1121"\w* vuestras \w hijas|strong="H1323"\w*, y traédmelos».   
\p
\v 3 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* quitó \w los|strong="H3605"\w* zarcillos \w de|strong="H5971"\w* \w oro|strong="H2091"\w* \w que|strong="H5971"\w* llevaban en las orejas y \w se|strong="H5971"\w* \w los|strong="H3605"\w* llevaron \w a|strong="H3068"\w* Aarón.  
\v 4 \w Él|strong="H6213"\w* los \w recibió|strong="H3947"\w* de sus \w manos|strong="H3027"\w*, les dio forma con un buril, y fundió un \w becerro|strong="H5695"\w*. Entonces \w el|strong="H6213"\w* pueblo exclamó: «¡Estos son tus dioses, \w Israel|strong="H3478"\w*, \w que|strong="H3027"\w* te sacaron de la tierra de \w Egipto|strong="H4714"\w*!».   
\p
\v 5 Al \w ver|strong="H7200"\w* esto, Aarón \w edificó|strong="H1129"\w* un \w altar|strong="H4196"\w* \w delante|strong="H6440"\w* \w del|strong="H4196"\w* becerro y \w proclamó|strong="H7121"\w*: «\w Mañana|strong="H4279"\w* será \w fiesta|strong="H2282"\w* para Yahvé».   
\p
\v 6 \w Al|strong="H5930"\w* día \w siguiente|strong="H4283"\w* \w se|strong="H5971"\w* \w levantaron|strong="H6965"\w* temprano, ofrecieron \w holocaustos|strong="H5930"\w* y \w trajeron|strong="H5066"\w* sacrificios \w de|strong="H5971"\w* paz; \w luego|strong="H5927"\w* \w el|strong="H3427"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* sentó \w a|strong="H3068"\w* comer y \w a|strong="H3068"\w* \w beber|strong="H8354"\w*, y \w se|strong="H5971"\w* \w levantó|strong="H6965"\w* \w a|strong="H3068"\w* regocijarse.   
\p
\v 7 Yahvé \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Desciende|strong="H3381"\w*, \w porque|strong="H3588"\w* tu \w pueblo|strong="H5971"\w*, \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w sacaste|strong="H5927"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w se|strong="H5971"\w* ha \w corrompido|strong="H7843"\w*.  
\v 8 \w Se|strong="H4480"\w* han apartado \w pronto|strong="H4118"\w* \w del|strong="H4480"\w* \w camino|strong="H1870"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* \w les|strong="H6680"\w* \w mandé|strong="H6680"\w*. \w Se|strong="H4480"\w* han \w hecho|strong="H6213"\w* un \w becerro|strong="H5695"\w* \w de|strong="H4480"\w* \w fundición|strong="H4541"\w*, \w se|strong="H4480"\w* han postrado ante \w él|strong="H6213"\w*, le han ofrecido \w sacrificios|strong="H2076"\w* y han dicho: ‘Estos son tus dioses, \w Israel|strong="H3478"\w*, \w que|strong="H4480"\w* \w te|strong="H4480"\w* sacaron \w de|strong="H4480"\w* la tierra \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*’”.   
\p
\v 9 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «He observado \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, y he \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w es|strong="H1931"\w* un \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w dura|strong="H7186"\w* \w cerviz|strong="H6203"\w*.  
\v 10 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, déjame actuar; mi ira se encenderá contra ellos y los consumiré. Pero de ti \w haré|strong="H6213"\w* una \w gran|strong="H1419"\w* \w nación|strong="H1471"\w*».   
\p
\v 11 \w Moisés|strong="H4872"\w* suplicó \w a|strong="H3068"\w* Yahvé su \w Dios|strong="H3068"\w*, diciendo: “\w Oh|strong="H4100"\w* Yahvé, ¿\w por|strong="H6440"\w* \w qué|strong="H4100"\w* ha \w de|strong="H6440"\w* encenderse tu furor \w contra|strong="H6440"\w* tu \w pueblo|strong="H5971"\w*, al \w que|strong="H4100"\w* tú \w sacaste|strong="H3318"\w* \w de|strong="H6440"\w* la tierra \w de|strong="H6440"\w* \w Egipto|strong="H4714"\w* con \w gran|strong="H1419"\w* \w poder|strong="H3027"\w* y con \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w*?  
\v 12 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* han \w de|strong="H5921"\w* hablar \w los|strong="H5921"\w* \w egipcios|strong="H4713"\w*, diciendo: ‘\w Para|strong="H5921"\w* \w mal|strong="H7451"\w* \w los|strong="H5921"\w* \w sacó|strong="H3318"\w*, \w para|strong="H5921"\w* matarlos \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w* \w y|strong="H5921"\w* \w para|strong="H5921"\w* raerlos \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra’? \w Vuélvete|strong="H7725"\w* \w del|strong="H5921"\w* ardor \w de|strong="H5921"\w* tu \w ira|strong="H2740"\w* \w y|strong="H5921"\w* desiste \w de|strong="H5921"\w* hacer este \w mal|strong="H7451"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*.  
\v 13 \w Acuérdate|strong="H2142"\w* \w de|strong="H5414"\w* Abraham, \w de|strong="H5414"\w* \w Isaac|strong="H3327"\w* y \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*, tus \w siervos|strong="H5650"\w*, \w a|strong="H3068"\w* quienes \w juraste|strong="H7650"\w* \w por|strong="H5769"\w* ti \w mismo|strong="H3605"\w*, diciéndoles: ‘\w Multiplicaré|strong="H7235"\w* \w vuestra|strong="H2063"\w* \w descendencia|strong="H2233"\w* como las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w*, y \w daré|strong="H5414"\w* \w a|strong="H3068"\w* \w vuestra|strong="H2063"\w* \w descendencia|strong="H2233"\w* \w toda|strong="H3605"\w* \w esta|strong="H2063"\w* tierra \w de|strong="H5414"\w* \w la|strong="H2063"\w* \w que|strong="H3605"\w* he \w hablado|strong="H1696"\w*, y \w la|strong="H2063"\w* \w heredarán|strong="H5157"\w* \w para|strong="H5414"\w* \w siempre|strong="H5769"\w*’”.   
\p
\v 14 Entonces Yahvé desistió \w del|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H5921"\w* \w había|strong="H6213"\w* \w dicho|strong="H1696"\w* \w que|strong="H5921"\w* \w haría|strong="H6213"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*.   
\p
\v 15 \w Moisés|strong="H4872"\w* \w se|strong="H4480"\w* \w volvió|strong="H6437"\w* y bajó \w del|strong="H4480"\w* \w monte|strong="H2022"\w* \w con|strong="H4480"\w* \w las|strong="H1992"\w* \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* \w del|strong="H4480"\w* \w Testimonio|strong="H5715"\w* \w en|strong="H4480"\w* \w su|strong="H1992"\w* \w mano|strong="H3027"\w*; \w tablas|strong="H3871"\w* \w escritas|strong="H3789"\w* \w por|strong="H4480"\w* \w ambos|strong="H8147"\w* \w lados|strong="H5676"\w*, \w por|strong="H4480"\w* un \w lado|strong="H5676"\w* y \w por|strong="H4480"\w* \w el|strong="H1992"\w* \w otro|strong="H2088"\w* \w estaban|strong="H6437"\w* \w escritas|strong="H3789"\w*.  
\v 16 \w Las|strong="H1992"\w* \w tablas|strong="H3871"\w* eran \w obra|strong="H4639"\w* \w de|strong="H5921"\w* Dios, \w y|strong="H5921"\w* \w la|strong="H1931"\w* \w escritura|strong="H4385"\w* \w era|strong="H1931"\w* \w la|strong="H1931"\w* \w escritura|strong="H4385"\w* \w de|strong="H5921"\w* Dios, \w grabada|strong="H2801"\w* \w sobre|strong="H5921"\w* \w las|strong="H1992"\w* \w tablas|strong="H3871"\w*.   
\p
\v 17 Cuando \w Josué|strong="H3091"\w* \w oyó|strong="H8085"\w* \w el|strong="H4264"\w* clamor del \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* gritaba, dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «\w Se|strong="H5971"\w* \w oye|strong="H8085"\w* \w alarido|strong="H6963"\w* \w de|strong="H5971"\w* \w guerra|strong="H4421"\w* en \w el|strong="H4264"\w* \w campamento|strong="H4264"\w*».   
\p
\v 18 \w Y|strong="H3068"\w* él \w respondió|strong="H6030"\w*: «No es clamor de victoria, ni tampoco es clamor de derrota; cantos de celebración es lo que \w oigo|strong="H8085"\w*».  
\v 19 \w Aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w Moisés|strong="H4872"\w* llegó \w al|strong="H8478"\w* \w campamento|strong="H4264"\w* y \w vio|strong="H7200"\w* \w el|strong="H4264"\w* \w becerro|strong="H5695"\w* y las danzas, ardió \w en|strong="H8478"\w* ira; arrojó las \w tablas|strong="H3871"\w* \w de|strong="H8478"\w* sus \w manos|strong="H3027"\w* y las \w quebró|strong="H7665"\w* \w al|strong="H8478"\w* \w pie|strong="H8478"\w* del \w monte|strong="H2022"\w*.  
\v 20 \w Tomó|strong="H3947"\w* \w el|strong="H5921"\w* \w becerro|strong="H5695"\w* \w que|strong="H5921"\w* habían \w hecho|strong="H6213"\w*, \w lo|strong="H5921"\w* \w quemó|strong="H8313"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* fuego \w y|strong="H5921"\w* \w lo|strong="H5921"\w* molió \w hasta|strong="H5704"\w* reducirlo \w a|strong="H3068"\w* polvo; \w luego|strong="H5704"\w* \w lo|strong="H5921"\w* \w esparció|strong="H2219"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w agua|strong="H4325"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w lo|strong="H5921"\w* \w hizo|strong="H6213"\w* \w beber|strong="H8248"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 21 \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* Aarón: «¿\w Qué|strong="H3588"\w* \w te|strong="H5921"\w* ha \w hecho|strong="H6213"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w que|strong="H3588"\w* has traído \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* un \w pecado|strong="H2401"\w* tan \w grande|strong="H1419"\w*?»   
\p
\v 22 Aarón respondió: “\w No|strong="H3588"\w* \w se|strong="H3045"\w* encienda \w la|strong="H1931"\w* ira \w de|strong="H3588"\w* mi señor. Tú \w bien|strong="H3588"\w* \w sabes|strong="H3045"\w* \w que|strong="H3588"\w* \w este|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w es|strong="H1931"\w* propenso al \w mal|strong="H7451"\w*.  
\v 23 \w Me|strong="H3588"\w* dijeron: ‘\w Haznos|strong="H6213"\w* dioses \w que|strong="H3588"\w* \w vayan|strong="H3212"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* nosotros, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w Moisés|strong="H4872"\w*, \w el|strong="H3588"\w* hombre \w que|strong="H3588"\w* \w nos|strong="H4100"\w* \w sacó|strong="H5927"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w no|strong="H3808"\w* \w sabemos|strong="H3045"\w* \w qué|strong="H3588"\w* le \w ha|strong="H3808"\w* pasado’.  
\v 24 \w Y|strong="H3068"\w* yo les dije: ‘\w El|strong="H4310"\w* \w que|strong="H4310"\w* tenga \w oro|strong="H2091"\w*, \w que|strong="H4310"\w* se \w lo|strong="H2088"\w* quite’. \w Me|strong="H4310"\w* \w lo|strong="H2088"\w* \w dieron|strong="H5414"\w*, \w lo|strong="H2088"\w* \w eché|strong="H7993"\w* al fuego, y \w salió|strong="H3318"\w* \w este|strong="H2088"\w* \w becerro|strong="H5695"\w*”.   
\p
\v 25 \w Viendo|strong="H7200"\w* \w Moisés|strong="H4872"\w* \w que|strong="H3588"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* estaba desenfrenado (\w pues|strong="H3588"\w* Aarón les \w había|strong="H3588"\w* permitido desenfrenarse, \w para|strong="H3588"\w* burla \w de|strong="H3588"\w* \w sus|strong="H1931"\w* enemigos),  
\v 26 se \w puso|strong="H5975"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* entrada del \w campamento|strong="H4264"\w* y gritó: «¡\w El|strong="H3605"\w* \w que|strong="H4310"\w* \w esté|strong="H5975"\w* \w de|strong="H1121"\w* parte \w de|strong="H1121"\w* Yahvé, únase \w a|strong="H3068"\w* mí!». \w Y|strong="H3068"\w* se unieron \w a|strong="H3068"\w* \w él|strong="H3605"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w*.  
\v 27 \w Él|strong="H5921"\w* \w les|strong="H5921"\w* dijo: “\w Así|strong="H3541"\w* dice Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: ‘Póngase cada uno \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w al|strong="H5921"\w* \w muslo|strong="H3409"\w*, \w y|strong="H5921"\w* \w pasad|strong="H5674"\w* \w y|strong="H5921"\w* repasad \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w campamento|strong="H4264"\w*, \w de|strong="H5921"\w* \w puerta|strong="H8179"\w* \w en|strong="H5921"\w* \w puerta|strong="H8179"\w*, \w y|strong="H5921"\w* \w mate|strong="H2026"\w* cada uno \w a|strong="H3068"\w* su hermano, \w a|strong="H3068"\w* su \w amigo|strong="H7453"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* su pariente’”.  
\v 28 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Leví|strong="H3878"\w* \w hicieron|strong="H6213"\w* \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w palabra|strong="H1697"\w* \w de|strong="H4480"\w* \w Moisés|strong="H4872"\w*; y \w cayeron|strong="H5307"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w en|strong="H4480"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w como|strong="H1931"\w* \w tres|strong="H7969"\w* mil \w hombres|strong="H1121"\w*.  
