\c 39
\p
\v 1 \w De|strong="H4480"\w* hilo azul, púrpura y escarlata \w hicieron|strong="H6213"\w* las vestiduras finamente tejidas \w para|strong="H4480"\w* ministrar \w en|strong="H4480"\w* \w el|strong="H6213"\w* Lugar \w Santo|strong="H6944"\w*. Así \w hicieron|strong="H6213"\w* las vestiduras \w sagradas|strong="H6944"\w* \w para|strong="H4480"\w* Aarón, como Yahvé \w se|strong="H4480"\w* \w lo|strong="H6213"\w* \w había|strong="H6213"\w* \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 2 \w Hizo|strong="H6213"\w* \w el|strong="H6213"\w* efod de \w oro|strong="H2091"\w*, hilo azul, púrpura, escarlata y lino fino \w torcido|strong="H7806"\w*.  
\v 3 Batieron \w el|strong="H6213"\w* \w oro|strong="H2091"\w* \w en|strong="H8432"\w* láminas finas y las cortaron \w en|strong="H8432"\w* \w hilos|strong="H6616"\w*, para entretejerlos con \w el|strong="H6213"\w* azul, la púrpura, la escarlata y \w el|strong="H6213"\w* lino fino, \w obra|strong="H4639"\w* de hábil artesano.  
\v 4 \w Le|strong="H5921"\w* \w hicieron|strong="H6213"\w* \w hombreras|strong="H3802"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* unían \w entre|strong="H5921"\w* \w sí|strong="H5921"\w*; \w se|strong="H5921"\w* unía \w por|strong="H5921"\w* sus \w dos|strong="H8147"\w* extremos.  
\v 5 \w El|strong="H1931"\w* cinto hábilmente tejido \w que|strong="H4480"\w* llevaba \w encima|strong="H5921"\w* formaba una sola pieza \w con|strong="H5921"\w* \w él|strong="H1931"\w* \w y|strong="H5921"\w* \w era|strong="H1931"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* \w misma|strong="H1931"\w* \w obra|strong="H4639"\w*: \w de|strong="H4480"\w* \w oro|strong="H2091"\w*, hilo azul, púrpura, escarlata \w y|strong="H5921"\w* lino fino \w torcido|strong="H7806"\w*, \w como|strong="H5921"\w* Yahvé \w se|strong="H1931"\w* \w lo|strong="H1931"\w* había \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 6 Prepararon \w las|strong="H5921"\w* piedras \w de|strong="H5921"\w* ónice montadas \w en|strong="H5921"\w* \w engastes|strong="H4865"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w grabadas|strong="H6605"\w* \w como|strong="H5921"\w* \w se|strong="H5921"\w* graba un sello, \w con|strong="H5921"\w* \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 7 \w Las|strong="H5921"\w* \w puso|strong="H7760"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w hombreras|strong="H3802"\w* \w del|strong="H5921"\w* efod, \w como|strong="H5921"\w* piedras \w de|strong="H5921"\w* \w memoria|strong="H2146"\w* \w para|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, tal \w como|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* \w lo|strong="H5921"\w* había \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 8 \w Hizo|strong="H6213"\w* \w el|strong="H6213"\w* pectoral, \w obra|strong="H4639"\w* de hábil artesano, igual que la \w obra|strong="H4639"\w* del efod: de \w oro|strong="H2091"\w*, hilo azul, púrpura, escarlata y lino fino \w torcido|strong="H7806"\w*.  
\v 9 \w Era|strong="H1961"\w* \w cuadrado|strong="H7251"\w* y \w doble|strong="H3717"\w*. Su longitud \w era|strong="H1961"\w* de un \w palmo|strong="H2239"\w*, y su \w anchura|strong="H7341"\w* de un \w palmo|strong="H2239"\w*, siendo \w doble|strong="H3717"\w*.  
\v 10 Engastaron en él cuatro hileras de piedras. La primera hilera era un rubí, un \w topacio|strong="H6357"\w* y un berilo;  
\v 11 la \w segunda|strong="H8145"\w* hilera, una turquesa, un zafiro y una esmeralda;  
\v 12 la \w tercera|strong="H7992"\w* hilera, un jacinto, una ágata y una amatista;  
\v 13 y la cuarta hilera, un \w crisólito|strong="H8658"\w*, un ónice y un jaspe. Todas estaban montadas en \w engastes|strong="H4865"\w* de \w oro|strong="H2091"\w*.  
\v 14 \w Las|strong="H5921"\w* piedras correspondían \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*; eran \w doce|strong="H8147"\w*, \w según|strong="H5921"\w* sus \w nombres|strong="H8034"\w*. \w Como|strong="H5921"\w* \w los|strong="H1121"\w* grabados \w de|strong="H5921"\w* un sello, cada una tenía \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* una \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w doce|strong="H8147"\w* \w tribus|strong="H7626"\w*.  
\v 15 \w Hicieron|strong="H6213"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* pectoral \w cadenillas|strong="H8333"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*, trenzadas \w a|strong="H3068"\w* manera \w de|strong="H5921"\w* cordón.  
\v 16 \w Hicieron|strong="H6213"\w* \w dos|strong="H8147"\w* \w engastes|strong="H4865"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w dos|strong="H8147"\w* argollas \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w y|strong="H5921"\w* \w pusieron|strong="H5414"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* argollas \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* extremos superiores \w del|strong="H5921"\w* pectoral.  
\v 17 Pasaron \w los|strong="H5921"\w* \w dos|strong="H8147"\w* cordones \w de|strong="H5921"\w* \w oro|strong="H2091"\w* trenzados \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* argollas \w en|strong="H5921"\w* \w los|strong="H5921"\w* extremos \w del|strong="H5921"\w* pectoral.  
\v 18 \w Los|strong="H5921"\w* otros \w dos|strong="H8147"\w* extremos \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* cordones \w los|strong="H5921"\w* fijaron \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w engastes|strong="H4865"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* unieron \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w hombreras|strong="H3802"\w* \w del|strong="H5921"\w* efod \w en|strong="H5921"\w* su parte delantera.  
\v 19 \w Hicieron|strong="H6213"\w* otras \w dos|strong="H8147"\w* argollas \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w pusieron|strong="H7760"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* extremos inferiores \w del|strong="H5921"\w* pectoral, \w en|strong="H5921"\w* \w el|strong="H5921"\w* borde interior \w que|strong="H5921"\w* \w da|strong="H7760"\w* \w hacia|strong="H6213"\w* \w el|strong="H5921"\w* efod.  
\v 20 \w Hicieron|strong="H6213"\w* \w dos|strong="H8147"\w* argollas \w más|strong="H5921"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* fijaron \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte inferior \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w hombreras|strong="H3802"\w* \w del|strong="H5921"\w* efod, \w por|strong="H5921"\w* \w la|strong="H5921"\w* parte delantera, \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* su unión, \w por|strong="H5921"\w* \w encima|strong="H4605"\w* \w del|strong="H5921"\w* cinto tejido \w del|strong="H5921"\w* efod.  
\v 21 Ataron \w el|strong="H5921"\w* pectoral \w por|strong="H5921"\w* sus argollas \w a|strong="H3068"\w* \w las|strong="H5921"\w* argollas \w del|strong="H5921"\w* efod \w con|strong="H5921"\w* un cordón azul, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w quedara|strong="H1961"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* cinto tejido \w del|strong="H5921"\w* efod \w y|strong="H5921"\w* \w el|strong="H5921"\w* pectoral \w no|strong="H3808"\w* \w se|strong="H1961"\w* separara \w del|strong="H5921"\w* efod, \w como|strong="H1961"\w* Yahvé \w se|strong="H1961"\w* \w lo|strong="H3808"\w* \w había|strong="H1961"\w* \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 22 \w Hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w manto|strong="H4598"\w* del efod tejido, \w todo|strong="H3632"\w* de hilo azul.  
\v 23 La abertura del \w manto|strong="H4598"\w* \w en|strong="H8432"\w* el centro era como el cuello de un coselete, con un borde tejido \w alrededor|strong="H5439"\w* de la abertura, para \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* rasgara.  
\v 24 \w En|strong="H5921"\w* \w el|strong="H5921"\w* borde inferior \w del|strong="H5921"\w* \w manto|strong="H4598"\w* \w hicieron|strong="H6213"\w* \w granadas|strong="H7416"\w* \w de|strong="H5921"\w* hilo azul, púrpura, escarlata \w y|strong="H5921"\w* lino \w torcido|strong="H7806"\w*.  
\v 25 \w Hicieron|strong="H6213"\w* también campanillas \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*, \w y|strong="H5921"\w* \w pusieron|strong="H5414"\w* \w las|strong="H5921"\w* campanillas \w entre|strong="H8432"\w* \w las|strong="H5921"\w* \w granadas|strong="H7416"\w* \w en|strong="H5921"\w* \w todo|strong="H5439"\w* \w el|strong="H5921"\w* borde inferior \w del|strong="H5921"\w* \w manto|strong="H4598"\w*;  
\v 26 una \w campanilla|strong="H6472"\w* \w y|strong="H5921"\w* una granada, otra \w campanilla|strong="H6472"\w* \w y|strong="H5921"\w* otra granada, \w en|strong="H5921"\w* \w todo|strong="H5439"\w* \w el|strong="H5921"\w* borde inferior \w del|strong="H5921"\w* \w manto|strong="H4598"\w*, \w para|strong="H5921"\w* ministrar, \w como|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* \w lo|strong="H5921"\w* había \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 27 \w Hicieron|strong="H6213"\w* asimismo las \w túnicas|strong="H3801"\w* \w de|strong="H1121"\w* lino fino tejido para Aarón y para sus \w hijos|strong="H1121"\w*;  
\v 28 la mitra de lino fino, los hermosos turbantes de lino fino, los calzoncillos de lino fino \w torcido|strong="H7806"\w*,  
\v 29 y el ceñidor de lino fino \w torcido|strong="H7806"\w*, de hilo azul, púrpura y escarlata, \w obra|strong="H4639"\w* de recamador, como Yahvé se lo había \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 30 \w Hicieron|strong="H6213"\w* \w la|strong="H5921"\w* lámina \w de|strong="H5921"\w* \w la|strong="H5921"\w* diadema \w santa|strong="H6944"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*, \w y|strong="H5921"\w* \w escribieron|strong="H3789"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* una inscripción \w como|strong="H5921"\w* \w los|strong="H5921"\w* grabados \w de|strong="H5921"\w* un sello: «\w SANTIDAD|strong="H6944"\w* \w A|strong="H3068"\w* YAHVÉ».  
\v 31 \w Le|strong="H5921"\w* ataron un cordón \w de|strong="H5921"\w* hilo azul \w para|strong="H5921"\w* sujetarla \w por|strong="H5921"\w* \w encima|strong="H4605"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* mitra, \w como|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* \w lo|strong="H5921"\w* había \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 32 \w Así|strong="H3651"\w* quedó terminada \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H6213"\w* del \w tabernáculo|strong="H4908"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* Tienda del Encuentro. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w hicieron|strong="H6213"\w* \w todo|strong="H3605"\w* exactamente \w como|strong="H3651"\w* Yahvé \w lo|strong="H6213"\w* \w había|strong="H6213"\w* \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*; \w así|strong="H3651"\w* \w lo|strong="H6213"\w* \w hicieron|strong="H6213"\w*.  
\v 33 \w Y|strong="H3068"\w* llevaron \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w el|strong="H3605"\w* \w tabernáculo|strong="H4908"\w*, \w la|strong="H3605"\w* tienda con \w todos|strong="H3605"\w* sus utensilios, sus \w corchetes|strong="H7165"\w*, sus \w tablas|strong="H7175"\w*, sus travesaños, sus \w columnas|strong="H5982"\w* y sus basas;  
\v 34 la cubierta de pieles de carnero teñidas de rojo, la cubierta de pieles de tejón, el velo de separación;  
\v 35 el arca del \w Testimonio|strong="H5715"\w* con sus varas y el propiciatorio;  
\v 36 \w la|strong="H3605"\w* \w mesa|strong="H7979"\w*, \w todos|strong="H3605"\w* sus utensilios y \w el|strong="H3605"\w* \w pan|strong="H3899"\w* \w de|strong="H6440"\w* \w la|strong="H3605"\w* \w Presencia|strong="H6440"\w*;  
\v 37 \w el|strong="H3605"\w* candelabro de oro \w puro|strong="H2889"\w*, sus \w lámparas|strong="H5216"\w* preparadas para ser encendidas, \w todos|strong="H3605"\w* sus utensilios y \w el|strong="H3605"\w* \w aceite|strong="H8081"\w* para \w el|strong="H3605"\w* alumbrado;  
\v 38 el \w altar|strong="H4196"\w* de \w oro|strong="H2091"\w*, el \w aceite|strong="H8081"\w* de la \w unción|strong="H4888"\w*, el incienso \w aromático|strong="H5561"\w* y la cortina para la entrada de la tienda;  
\v 39 \w el|strong="H3605"\w* \w altar|strong="H4196"\w* de bronce, su enrejado de bronce, sus varas y \w todos|strong="H3605"\w* sus utensilios, \w la|strong="H3605"\w* pila y su basa;  
\v 40 las \w cortinas|strong="H7050"\w* del \w atrio|strong="H2691"\w*, sus \w columnas|strong="H5982"\w*, sus basas, \w la|strong="H3605"\w* cortina para \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* del \w atrio|strong="H2691"\w*, sus cuerdas, sus estacas y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios del servicio del \w tabernáculo|strong="H4908"\w*, para \w la|strong="H3605"\w* Tienda del Encuentro;  
\v 41 las vestiduras finamente tejidas para ministrar en \w el|strong="H1121"\w* Lugar \w Santo|strong="H6944"\w*, las vestiduras \w sagradas|strong="H6944"\w* para \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Aarón, y las vestiduras \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w*, para servir en \w el|strong="H1121"\w* oficio sacerdotal.  
\v 42 Conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* Yahvé \w había|strong="H6213"\w* \w mandado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w así|strong="H3651"\w* \w hicieron|strong="H6213"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H6213"\w*.  
\v 43 \w Moisés|strong="H4872"\w* examinó \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w*, y he \w aquí|strong="H2009"\w* \w que|strong="H3605"\w* \w la|strong="H3605"\w* habían \w hecho|strong="H6213"\w* \w como|strong="H3651"\w* Yahvé \w había|strong="H6213"\w* \w ordenado|strong="H6680"\w*. \w Así|strong="H3651"\w* \w lo|strong="H6213"\w* habían \w hecho|strong="H6213"\w*; y \w Moisés|strong="H4872"\w* \w los|strong="H3605"\w* \w bendijo|strong="H1288"\w*.   
\c 40
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “El \w primer|strong="H7223"\w* \w día|strong="H3117"\w* del \w primer|strong="H7223"\w* \w mes|strong="H2320"\w* \w levantarás|strong="H6965"\w* el \w tabernáculo|strong="H4908"\w*, la Tienda del Encuentro.  
\v 3 \w Pondrás|strong="H7760"\w* \w en|strong="H5921"\w* \w él|strong="H5921"\w* \w el|strong="H5921"\w* arca \w del|strong="H5921"\w* \w Testimonio|strong="H5715"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* cubrirás \w con|strong="H5921"\w* \w el|strong="H5921"\w* velo.  
\v 4 Meterás la \w mesa|strong="H7979"\w* y pondrás en orden los utensilios que \w van|strong="H5927"\w* sobre ella. Meterás el candelabro y encenderás sus \w lámparas|strong="H5216"\w*.  
\v 5 \w Pondrás|strong="H5414"\w* el \w altar|strong="H4196"\w* \w de|strong="H6440"\w* \w oro|strong="H2091"\w* \w para|strong="H5414"\w* el incienso \w delante|strong="H6440"\w* \w del|strong="H4196"\w* arca \w del|strong="H4196"\w* \w Testimonio|strong="H5715"\w*, y colgarás la cortina \w a|strong="H3068"\w* la entrada \w del|strong="H4196"\w* \w tabernáculo|strong="H4908"\w*.   
\p
\v 6 “\w Pondrás|strong="H5414"\w* el \w altar|strong="H4196"\w* \w del|strong="H4196"\w* \w holocausto|strong="H5930"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* la entrada \w de|strong="H6440"\w* la Tienda \w del|strong="H4196"\w* Encuentro.  
\v 7 \w Pondrás|strong="H5414"\w* la pila \w entre|strong="H8033"\w* la Tienda \w del|strong="H4196"\w* Encuentro y el \w altar|strong="H4196"\w*, y \w pondrás|strong="H5414"\w* \w agua|strong="H4325"\w* en \w ella|strong="H8033"\w*.  
\v 8 Levantarás el \w atrio|strong="H2691"\w* en \w derredor|strong="H5439"\w*, y colgarás la cortina \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* del \w atrio|strong="H2691"\w*.   
\p
\v 9 “\w Tomarás|strong="H3947"\w* \w el|strong="H3605"\w* \w aceite|strong="H8081"\w* de \w la|strong="H3605"\w* \w unción|strong="H4888"\w* y \w ungirás|strong="H4886"\w* \w el|strong="H3605"\w* \w tabernáculo|strong="H4908"\w* y \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1961"\w* \w hay|strong="H1961"\w* en \w él|strong="H3605"\w*; \w lo|strong="H3605"\w* \w santificarás|strong="H6942"\w* con \w todos|strong="H3605"\w* sus utensilios, y \w será|strong="H1961"\w* \w santo|strong="H6944"\w*.  
