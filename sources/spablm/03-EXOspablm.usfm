\v 12 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Extiende|strong="H5186"\w* tu \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* suban \w las|strong="H5921"\w* langostas \w y|strong="H5921"\w* devoren \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w hierba|strong="H6212"\w* \w del|strong="H5921"\w* país, \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w dejó|strong="H7604"\w* \w el|strong="H5921"\w* \w granizo|strong="H1259"\w*.”  
\v 13 \w Moisés|strong="H4872"\w* \w extendió|strong="H5186"\w* \w su|strong="H1931"\w* \w vara|strong="H4294"\w* \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H5921"\w* Yahvé \w trajo|strong="H5375"\w* un \w viento|strong="H7307"\w* \w del|strong="H5921"\w* \w este|strong="H1931"\w* \w sobre|strong="H5921"\w* \w el|strong="H1931"\w* país durante \w todo|strong="H3605"\w* \w ese|strong="H1931"\w* \w día|strong="H3117"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* \w noche|strong="H3915"\w*; \w y|strong="H5921"\w* \w cuando|strong="H3117"\w* amaneció, \w el|strong="H1931"\w* \w viento|strong="H7307"\w* \w del|strong="H5921"\w* \w este|strong="H1931"\w* \w había|strong="H1961"\w* traído \w las|strong="H5921"\w* langostas.  
\v 14 \w Las|strong="H5921"\w* langostas \w subieron|strong="H5927"\w* \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w y|strong="H5921"\w* \w se|strong="H1961"\w* posaron \w en|strong="H5921"\w* \w todos|strong="H3605"\w* sus límites. \w Fue|strong="H1961"\w* una plaga \w gravísima|strong="H3966"\w*. \w Nunca|strong="H3808"\w* \w antes|strong="H6440"\w* \w hubo|strong="H1961"\w* langostas \w como|strong="H3644"\w* aquellas, \w ni|strong="H3808"\w* \w las|strong="H5921"\w* \w habrá|strong="H1961"\w* \w jamás|strong="H3808"\w*.  
\v 15 \w Porque|strong="H3808"\w* \w cubrieron|strong="H3680"\w* \w la|strong="H3605"\w* superficie \w de|strong="H5869"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra, oscureciéndola por completo; devoraron \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w hierba|strong="H6212"\w* \w de|strong="H5869"\w* \w la|strong="H3605"\w* tierra y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w fruto|strong="H6529"\w* \w de|strong="H5869"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* \w que|strong="H3808"\w* había dejado \w el|strong="H3605"\w* \w granizo|strong="H1259"\w*. \w No|strong="H3808"\w* \w quedó|strong="H3498"\w* \w nada|strong="H3808"\w* \w verde|strong="H3418"\w*, \w ni|strong="H3808"\w* en \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* \w ni|strong="H3808"\w* en \w la|strong="H3605"\w* \w hierba|strong="H6212"\w* del \w campo|strong="H7704"\w*, en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5869"\w* \w Egipto|strong="H4714"\w*.  
\v 16 Entonces el \w faraón|strong="H6547"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón \w a|strong="H3068"\w* toda prisa, y dijo: “He \w pecado|strong="H2398"\w* contra Yahvé, vuestro \w Dios|strong="H3068"\w*, y contra vosotros.  
\v 17 \w Ahora|strong="H6258"\w*, \w por|strong="H5921"\w* favor, perdonad \w mi|strong="H5921"\w* \w pecado|strong="H2403"\w* \w solo|strong="H7535"\w* \w esta|strong="H2088"\w* \w vez|strong="H6471"\w*, \w y|strong="H5921"\w* rogad \w a|strong="H3068"\w* Yahvé vuestro \w Dios|strong="H3068"\w*, \w para|strong="H5921"\w* \w que|strong="H6258"\w* \w aparte|strong="H5493"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w esta|strong="H2088"\w* \w muerte|strong="H4194"\w* mortal.”   
\p
\v 18 Moisés \w salió|strong="H3318"\w* \w de|strong="H5973"\w* la presencia \w del|strong="H5973"\w* \w faraón|strong="H6547"\w* y oró \w a|strong="H3068"\w* Yahvé.  
\v 19 Yahvé hizo soplar un \w viento|strong="H7307"\w* del oeste \w muy|strong="H3966"\w* \w fuerte|strong="H2389"\w*, \w que|strong="H3808"\w* \w se|strong="H3808"\w* \w llevó|strong="H5375"\w* las langostas y las arrojó al \w Mar|strong="H3220"\w* Rojo. \w No|strong="H3808"\w* \w quedó|strong="H7604"\w* \w ni|strong="H3808"\w* una sola langosta en \w todo|strong="H3605"\w* \w el|strong="H3605"\w* territorio de \w Egipto|strong="H4714"\w*.  
\v 20 Pero Yahvé \w endureció|strong="H2388"\w* \w el|strong="H1121"\w* \w corazón|strong="H3820"\w* del \w faraón|strong="H6547"\w*, y \w no|strong="H3808"\w* \w dejó|strong="H7971"\w* \w ir|strong="H7971"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.   
\p
\v 21 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Extiende|strong="H5186"\w* tu \w mano|strong="H3027"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w haya|strong="H1961"\w* \w tinieblas|strong="H2822"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, unas \w tinieblas|strong="H2822"\w* tan densas \w que|strong="H5921"\w* \w se|strong="H1961"\w* puedan palpar.”  
\v 22 \w Moisés|strong="H4872"\w* \w extendió|strong="H5186"\w* su \w mano|strong="H3027"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w y|strong="H5921"\w* \w hubo|strong="H1961"\w* una densa \w oscuridad|strong="H2822"\w* \w en|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* durante \w tres|strong="H7969"\w* \w días|strong="H3117"\w*.  
\v 23 \w Nadie|strong="H3808"\w* \w podía|strong="H3808"\w* \w ver|strong="H7200"\w* \w a|strong="H3068"\w* su prójimo, \w ni|strong="H3808"\w* \w nadie|strong="H3808"\w* \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* \w de|strong="H8478"\w* su \w lugar|strong="H8478"\w* durante \w tres|strong="H7969"\w* \w días|strong="H3117"\w*; pero \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w* \w tenían|strong="H1961"\w* luz \w en|strong="H8478"\w* sus moradas.   
\p
\v 24 \w El|strong="H5973"\w* \w faraón|strong="H6547"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w y|strong="H1571"\w* \w le|strong="H5973"\w* dijo: «\w Id|strong="H3212"\w* \w y|strong="H1571"\w* \w servid|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé. \w Que|strong="H1571"\w* se queden únicamente vuestras \w ovejas|strong="H6629"\w* \w y|strong="H1571"\w* vuestras \w vacas|strong="H1241"\w*. \w Que|strong="H1571"\w* \w vuestros|strong="H5647"\w* pequeños \w también|strong="H1571"\w* \w vayan|strong="H3212"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*».   
\p
\v 25 \w Moisés|strong="H4872"\w* dijo: “\w También|strong="H1571"\w* debes \w poner|strong="H5414"\w* en nuestras \w manos|strong="H3027"\w* \w sacrificios|strong="H2077"\w* \w y|strong="H1571"\w* \w holocaustos|strong="H5930"\w*, \w para|strong="H5414"\w* \w que|strong="H1571"\w* los ofrezcamos \w a|strong="H3068"\w* Yahvé, nuestro \w Dios|strong="H3068"\w*.  
\v 26 Nuestro \w ganado|strong="H4735"\w* \w también|strong="H1571"\w* \w irá|strong="H3212"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*. \w No|strong="H3808"\w* \w quedará|strong="H7604"\w* atrás \w ni|strong="H3808"\w* una sola pezuña, \w pues|strong="H3588"\w* \w de|strong="H4480"\w* \w él|strong="H5973"\w* debemos \w tomar|strong="H3947"\w* \w para|strong="H5704"\w* \w servir|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé nuestro \w Dios|strong="H3068"\w*; \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w sabemos|strong="H3045"\w* \w con|strong="H5973"\w* \w qué|strong="H3588"\w* hemos \w de|strong="H4480"\w* \w servir|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* lleguemos \w allí|strong="H8033"\w*.”   
\p
\v 27 Pero Yahvé \w endureció|strong="H2388"\w* el \w corazón|strong="H3820"\w* del \w faraón|strong="H6547"\w* y \w no|strong="H3808"\w* quiso dejarlos \w ir|strong="H7971"\w*.  
\v 28 \w El|strong="H5921"\w* \w faraón|strong="H6547"\w* \w le|strong="H5921"\w* dijo: “¡\w Apártate|strong="H3212"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*! Cuídate \w de|strong="H5921"\w* \w no|strong="H3588"\w* volver \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w*, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w en|strong="H5921"\w* \w que|strong="H3588"\w* \w veas|strong="H7200"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w*, \w morirás|strong="H4191"\w*”.   
\p
\v 29 \w Moisés|strong="H4872"\w* respondió: «Has \w hablado|strong="H1696"\w* \w bien|strong="H3651"\w*. \w No|strong="H3808"\w* \w volveré|strong="H3254"\w* \w a|strong="H3068"\w* \w ver|strong="H7200"\w* tu \w rostro|strong="H6440"\w*».   
\c 11
\p
\v 1 Yahvé \w le|strong="H5921"\w* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “Traeré una \w plaga|strong="H5061"\w* \w más|strong="H5750"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w faraón|strong="H6547"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w Egipto|strong="H4714"\w*; \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w eso|strong="H3651"\w*, \w os|strong="H5921"\w* dejará \w ir|strong="H7971"\w* \w de|strong="H5921"\w* \w aquí|strong="H2088"\w*. Cuando \w os|strong="H5921"\w* \w deje|strong="H7971"\w* \w ir|strong="H7971"\w*, ciertamente \w os|strong="H5921"\w* \w echará|strong="H7971"\w* \w de|strong="H5921"\w* \w aquí|strong="H2088"\w* \w por|strong="H5921"\w* completo.  
\v 2 \w Habla|strong="H1696"\w* \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* oídos del \w pueblo|strong="H5971"\w*, \w para|strong="H5971"\w* \w que|strong="H4994"\w* cada hombre pida \w a|strong="H3068"\w* su vecino, y cada mujer \w a|strong="H3068"\w* su vecina, objetos \w de|strong="H5971"\w* \w plata|strong="H3701"\w* y objetos \w de|strong="H5971"\w* \w oro|strong="H2091"\w*.”  
\v 3 Yahvé \w hizo|strong="H5414"\w* \w que|strong="H1571"\w* \w el|strong="H1571"\w* \w pueblo|strong="H5971"\w* hallara \w gracia|strong="H2580"\w* \w a|strong="H3068"\w* los \w ojos|strong="H5869"\w* \w de|strong="H5971"\w* los \w egipcios|strong="H4713"\w*. \w Además|strong="H1571"\w*, \w el|strong="H1571"\w* varón \w Moisés|strong="H4872"\w* era considerado \w muy|strong="H3966"\w* \w grande|strong="H1419"\w* en \w la|strong="H1571"\w* tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*, \w a|strong="H3068"\w* los \w ojos|strong="H5869"\w* \w de|strong="H5971"\w* los \w siervos|strong="H5650"\w* del \w faraón|strong="H6547"\w* \w y|strong="H1571"\w* del \w pueblo|strong="H5971"\w*.   
\p
\v 4 \w Moisés|strong="H4872"\w* dijo: “\w Esto|strong="H3541"\w* \w es|strong="H3541"\w* lo \w que|strong="H3541"\w* dice Yahvé: ‘Hacia la medianoche \w saldré|strong="H3318"\w* por \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w Egipto|strong="H4714"\w*,  
\v 5 \w y|strong="H5921"\w* \w morirán|strong="H4191"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w primogénitos|strong="H1060"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w desde|strong="H5704"\w* \w el|strong="H5921"\w* \w primogénito|strong="H1060"\w* \w del|strong="H5921"\w* \w faraón|strong="H6547"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* sienta \w en|strong="H5921"\w* su \w trono|strong="H3678"\w*, \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w primogénito|strong="H1060"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w sierva|strong="H8198"\w* \w que|strong="H5921"\w* \w está|strong="H3427"\w* detrás \w del|strong="H5921"\w* molino, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w primogénitos|strong="H1060"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* bestias.  
\v 6 \w Habrá|strong="H1961"\w* un \w gran|strong="H1419"\w* \w clamor|strong="H6818"\w* en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra de \w Egipto|strong="H4714"\w*, \w como|strong="H3644"\w* \w nunca|strong="H3808"\w* \w lo|strong="H3808"\w* \w ha|strong="H3808"\w* habido \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* \w habrá|strong="H1961"\w* \w jamás|strong="H3808"\w*.  
\v 7 Pero \w contra|strong="H3478"\w* \w ninguno|strong="H3808"\w* \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w ni|strong="H3808"\w* \w contra|strong="H3478"\w* \w hombre|strong="H1121"\w* \w ni|strong="H3808"\w* \w contra|strong="H3478"\w* animal, \w ni|strong="H3808"\w* siquiera un \w perro|strong="H3611"\w* ladrará; \w para|strong="H5704"\w* \w que|strong="H3808"\w* \w sepáis|strong="H3045"\w* \w que|strong="H3808"\w* Yahvé hace distinción \w entre|strong="H3808"\w* \w los|strong="H1121"\w* \w egipcios|strong="H4714"\w* \w y|strong="H5704"\w* \w los|strong="H1121"\w* israelitas’.  
\v 8 \w Entonces|strong="H3651"\w* \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* \w siervos|strong="H5650"\w* tuyos \w descenderán|strong="H3381"\w* \w a|strong="H3068"\w* mí y \w se|strong="H3651"\w* inclinarán ante mí, diciendo: ‘\w Sal|strong="H3318"\w* tú, \w con|strong="H5973"\w* \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w te|strong="H5973"\w* sigue’; y después \w de|strong="H5973"\w* \w eso|strong="H3651"\w* yo \w saldré|strong="H3318"\w*”. \w Y|strong="H3068"\w* Moisés \w salió|strong="H3318"\w* \w de|strong="H5973"\w* \w la|strong="H3605"\w* presencia \w del|strong="H5973"\w* \w faraón|strong="H6547"\w* ardiendo \w en|strong="H5973"\w* \w ira|strong="H3318"\w*.   
\p
\v 9 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «El \w faraón|strong="H6547"\w* \w no|strong="H3808"\w* os \w escuchará|strong="H8085"\w*, \w para|strong="H4616"\w* \w que|strong="H3808"\w* mis \w maravillas|strong="H4159"\w* \w se|strong="H3808"\w* multipliquen en la tierra de \w Egipto|strong="H4714"\w*».  
\v 10 \w Moisés|strong="H4872"\w* y Aarón \w hicieron|strong="H6213"\w* \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* \w prodigios|strong="H4159"\w* \w ante|strong="H6440"\w* \w el|strong="H3605"\w* \w faraón|strong="H6547"\w*, pero Yahvé \w endureció|strong="H2388"\w* \w el|strong="H3605"\w* \w corazón|strong="H3820"\w* del \w faraón|strong="H6547"\w*, y \w no|strong="H3808"\w* \w dejó|strong="H7971"\w* salir \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w de|strong="H6440"\w* su tierra.   
\c 12
\p
\v 1 Yahvé habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón en la tierra de \w Egipto|strong="H4714"\w*, diciendo:  
\v 2 “\w Este|strong="H2088"\w* \w mes|strong="H2320"\w* \w será|strong="H1931"\w* para vosotros \w el|strong="H1931"\w* principio de \w los|strong="H1931"\w* \w meses|strong="H2320"\w*. \w Será|strong="H1931"\w* para vosotros \w el|strong="H1931"\w* \w primer|strong="H7218"\w* \w mes|strong="H2320"\w* del \w año|strong="H8141"\w*.  
\v 3 \w Hablad|strong="H1696"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación de \w Israel|strong="H3478"\w*, \w diciendo|strong="H1696"\w*: ‘\w El|strong="H3605"\w* día diez de \w este|strong="H2088"\w* \w mes|strong="H2320"\w*, \w tome|strong="H3947"\w* \w cada|strong="H3605"\w* uno un \w cordero|strong="H7716"\w*, según las \w casas|strong="H1004"\w* de sus padres, un \w cordero|strong="H7716"\w* \w por|strong="H2088"\w* \w familia|strong="H1004"\w*;  
\v 4 \w y|strong="H5921"\w* \w si|strong="H1931"\w* \w la|strong="H1931"\w* \w familia|strong="H1004"\w* \w es|strong="H1931"\w* demasiado \w pequeña|strong="H4591"\w* \w para|strong="H5921"\w* un \w cordero|strong="H7716"\w*, entonces \w él|strong="H1931"\w* \w y|strong="H5921"\w* \w su|strong="H1931"\w* \w vecino|strong="H7934"\w* \w más|strong="H5921"\w* \w cercano|strong="H7138"\w* \w tomarán|strong="H3947"\w* uno \w según|strong="H5921"\w* \w el|strong="H1931"\w* número \w de|strong="H5921"\w* \w personas|strong="H5315"\w*. Haréis \w la|strong="H1931"\w* \w cuenta|strong="H3699"\w* \w para|strong="H5921"\w* \w el|strong="H1931"\w* \w cordero|strong="H7716"\w* \w según|strong="H5921"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* cada uno pueda \w comer|strong="H5315"\w*.  
\v 5 Vuestro \w cordero|strong="H3532"\w* \w será|strong="H1961"\w* sin defecto, un \w macho|strong="H2145"\w* \w de|strong="H4480"\w* un \w año|strong="H8141"\w*. Lo \w tomaréis|strong="H3947"\w* \w de|strong="H4480"\w* las ovejas \w o|strong="H3068"\w* \w de|strong="H4480"\w* las \w cabras|strong="H5795"\w*.  
