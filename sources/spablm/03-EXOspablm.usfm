\v 34 Pero \w cuando|strong="H5704"\w* \w Moisés|strong="H4872"\w* entraba \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w para|strong="H5704"\w* \w hablar|strong="H1696"\w* \w con|strong="H5704"\w* \w él|strong="H1121"\w*, se quitaba \w el|strong="H1121"\w* velo \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w salía|strong="H3318"\w*; \w y|strong="H5704"\w* \w al|strong="H5704"\w* \w salir|strong="H3318"\w*, decía \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w lo|strong="H5704"\w* \w que|strong="H5704"\w* se le había \w mandado|strong="H6680"\w*.  
\v 35 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w veían|strong="H7200"\w* \w que|strong="H3588"\w* \w la|strong="H5921"\w* \w piel|strong="H5785"\w* \w del|strong="H5921"\w* \w rostro|strong="H6440"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w resplandecía|strong="H7160"\w*; \w y|strong="H3588"\w* \w Moisés|strong="H4872"\w* \w volvía|strong="H7725"\w* \w a|strong="H3068"\w* poner \w el|strong="H5921"\w* velo \w sobre|strong="H5921"\w* \w su|strong="H3588"\w* \w rostro|strong="H6440"\w*, \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* entraba \w a|strong="H3068"\w* \w hablar|strong="H1696"\w* \w de|strong="H5921"\w* nuevo \w con|strong="H5921"\w* Dios.   
\c 35
\p
\v 1 \w Moisés|strong="H4872"\w* reunió \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w les|strong="H6680"\w* dijo: “\w Estas|strong="H6213"\w* son las \w cosas|strong="H1697"\w* \w que|strong="H1697"\w* Yahvé ha \w mandado|strong="H6680"\w* \w que|strong="H1697"\w* \w hagáis|strong="H6213"\w*:  
\v 2 ‘\w Seis|strong="H8337"\w* \w días|strong="H3117"\w* \w se|strong="H1961"\w* trabajará, pero \w el|strong="H3605"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* os \w será|strong="H1961"\w* \w santo|strong="H6944"\w*, \w día|strong="H3117"\w* de descanso solemne \w para|strong="H1961"\w* Yahvé; \w cualquiera|strong="H3605"\w* \w que|strong="H3117"\w* \w haga|strong="H6213"\w* \w alguna|strong="H3605"\w* \w obra|strong="H4399"\w* en \w él|strong="H3605"\w*, \w morirá|strong="H4191"\w*.  
\v 3 \w No|strong="H3808"\w* \w encenderéis|strong="H1197"\w* fuego en \w ninguna|strong="H3605"\w* de vuestras moradas en \w el|strong="H3605"\w* \w día|strong="H3117"\w* de reposo’”.   
\p
\v 4 \w Moisés|strong="H4872"\w* \w habló|strong="H1697"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, diciendo: “\w Esto|strong="H2088"\w* \w es|strong="H2088"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* ha \w mandado|strong="H6680"\w* Yahvé:  
\v 5 ‘\w Tomad|strong="H3947"\w* de entre vosotros una \w ofrenda|strong="H8641"\w* para Yahvé. \w Todo|strong="H3605"\w* \w aquel|strong="H3605"\w* de \w corazón|strong="H3820"\w* generoso \w la|strong="H3605"\w* \w traerá|strong="H3947"\w* como \w ofrenda|strong="H8641"\w* \w a|strong="H3068"\w* Yahvé: \w oro|strong="H2091"\w*, \w plata|strong="H3701"\w*, bronce,  
\v 6 tela azul, púrpura, escarlata, lino fino, pelo de \w cabra|strong="H5795"\w*,  
\v 7 pieles de carnero teñidas de rojo, pieles de tejón, \w madera|strong="H6086"\w* de acacia,  
\v 8 \w aceite|strong="H8081"\w* para el alumbrado, \w especias|strong="H1314"\w* aromáticas para el \w aceite|strong="H8081"\w* de la \w unción|strong="H4888"\w* y para el incienso \w aromático|strong="H5561"\w*,  
\v 9 piedras de ónice y piedras de engaste para el efod y para el pectoral.   
\p
\v 10 ‘\w Que|strong="H3605"\w* vengan \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w sabios|strong="H2450"\w* de \w corazón|strong="H3820"\w* de entre vosotros y \w hagan|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* Yahvé ha \w mandado|strong="H6680"\w*:  
\v 11 el \w tabernáculo|strong="H4908"\w*, su tienda, su cubierta, sus \w corchetes|strong="H7165"\w*, sus \w tablas|strong="H7175"\w*, sus travesaños, sus \w columnas|strong="H5982"\w* y sus basas;  
\v 12 el arca y sus varas, el propiciatorio y el velo de separación;  
\v 13 \w la|strong="H3605"\w* \w mesa|strong="H7979"\w* con sus varas y \w todos|strong="H3605"\w* sus utensilios, y \w el|strong="H3605"\w* \w pan|strong="H3899"\w* \w de|strong="H6440"\w* \w la|strong="H3605"\w* \w Presencia|strong="H6440"\w*;  
\v 14 el candelabro para el alumbrado, con sus utensilios, sus \w lámparas|strong="H5216"\w* y el \w aceite|strong="H8081"\w* para la luz;  
\v 15 el \w altar|strong="H4196"\w* \w del|strong="H4196"\w* incienso con sus varas, el \w aceite|strong="H8081"\w* de la \w unción|strong="H4888"\w*, el incienso \w aromático|strong="H5561"\w* y la cortina de la \w puerta|strong="H6607"\w* \w a|strong="H3068"\w* la entrada \w del|strong="H4196"\w* \w tabernáculo|strong="H4908"\w*;  
\v 16 \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w del|strong="H4196"\w* \w holocausto|strong="H5930"\w* con su enrejado de bronce, sus varas y \w todos|strong="H3605"\w* sus utensilios, \w la|strong="H3605"\w* pila y su basa;  
\v 17 las \w cortinas|strong="H7050"\w* del \w atrio|strong="H2691"\w*, sus \w columnas|strong="H5982"\w*, sus basas y la cortina para la \w puerta|strong="H8179"\w* del \w atrio|strong="H2691"\w*;  
\v 18 las estacas del \w tabernáculo|strong="H4908"\w*, las estacas del \w atrio|strong="H2691"\w* y sus cuerdas;  
\v 19 las vestiduras finamente tejidas para ministrar en \w el|strong="H1121"\w* Lugar \w Santo|strong="H6944"\w*, las vestiduras \w sagradas|strong="H6944"\w* para \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Aarón, y las vestiduras \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* para servir en \w el|strong="H1121"\w* \w sacerdocio|strong="H3547"\w*’”.   
\p
\v 20 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* se retiró \w de|strong="H6440"\w* \w la|strong="H3605"\w* \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \w Moisés|strong="H4872"\w*.  
\v 21 \w Y|strong="H3068"\w* vino \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w a|strong="H3068"\w* \w quien|strong="H3605"\w* su \w corazón|strong="H3820"\w* impulsó, y \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w a|strong="H3068"\w* \w quien|strong="H3605"\w* su \w espíritu|strong="H7307"\w* le dio voluntad, y \w trajeron|strong="H5375"\w* \w la|strong="H3605"\w* \w ofrenda|strong="H8641"\w* de Yahvé para \w la|strong="H3605"\w* \w obra|strong="H4399"\w* de \w la|strong="H3605"\w* Tienda del Encuentro, para \w todo|strong="H3605"\w* su servicio y para las vestiduras \w sagradas|strong="H6944"\w*.  
\v 22 Vinieron \w tanto|strong="H5921"\w* hombres \w como|strong="H5921"\w* mujeres, \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* \w corazón|strong="H3820"\w* generoso, \w y|strong="H5921"\w* trajeron broches, zarcillos, \w anillos|strong="H2885"\w* \w y|strong="H5921"\w* brazaletes, \w toda|strong="H3605"\w* clase \w de|strong="H5921"\w* \w joyas|strong="H5141"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w*; \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w que|strong="H5921"\w* ofreció una \w ofrenda|strong="H8573"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w a|strong="H3068"\w* Yahvé \w la|strong="H5921"\w* trajo.  
\v 23 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* tenía tela azul, púrpura, escarlata, lino fino, pelo de \w cabra|strong="H5795"\w*, pieles de carnero teñidas de rojo \w o|strong="H3068"\w* pieles de tejón, \w lo|strong="H3605"\w* trajo.  
\v 24 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* podía ofrecer \w una|strong="H4672"\w* \w ofrenda|strong="H8641"\w* de \w plata|strong="H3701"\w* \w o|strong="H3068"\w* de bronce trajo \w la|strong="H3605"\w* \w ofrenda|strong="H8641"\w* \w a|strong="H3068"\w* Yahvé; y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* tenía \w madera|strong="H6086"\w* de acacia para \w cualquier|strong="H3605"\w* \w obra|strong="H4399"\w* del servicio, \w la|strong="H3605"\w* trajo.  
\v 25 \w Todas|strong="H3605"\w* las mujeres \w sabias|strong="H2450"\w* de \w corazón|strong="H3820"\w* \w hilaron|strong="H2901"\w* con sus \w manos|strong="H3027"\w*, y trajeron \w lo|strong="H3605"\w* \w que|strong="H3605"\w* habían hilado: \w el|strong="H3605"\w* hilo azul, \w la|strong="H3605"\w* púrpura, \w la|strong="H3605"\w* escarlata y \w el|strong="H3605"\w* lino fino.  
\v 26 \w Y|strong="H3068"\w* \w todas|strong="H3605"\w* las mujeres cuyo \w corazón|strong="H3820"\w* las impulsó \w a|strong="H3068"\w* usar su habilidad \w hilaron|strong="H2901"\w* \w el|strong="H3605"\w* pelo de \w cabra|strong="H5795"\w*.  
\v 27 Los jefes trajeron las piedras de ónice y las piedras de engaste para el efod y para el pectoral,  
\v 28 junto con las \w especias|strong="H1314"\w* y el \w aceite|strong="H8081"\w* para el alumbrado, para el \w aceite|strong="H8081"\w* de la \w unción|strong="H4888"\w* y para el incienso \w aromático|strong="H5561"\w*.  
\v 29 \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, tanto \w hombres|strong="H1121"\w* como mujeres, cuyo \w corazón|strong="H3820"\w* \w los|strong="H1121"\w* movió \w a|strong="H3068"\w* traer algo para \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* \w que|strong="H1121"\w* Yahvé \w había|strong="H6213"\w* \w mandado|strong="H6680"\w* \w hacer|strong="H6213"\w* \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*, \w trajeron|strong="H6213"\w* una ofrenda \w voluntaria|strong="H5071"\w* \w a|strong="H3068"\w* Yahvé.   
\p
\v 30 \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: “\w Mirad|strong="H7200"\w*, Yahvé ha \w llamado|strong="H8034"\w* por su \w nombre|strong="H8034"\w* \w a|strong="H3068"\w* Bezalel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uri, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hur|strong="H2354"\w*, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*;  
\v 31 y \w lo|strong="H3605"\w* ha llenado del \w Espíritu|strong="H7307"\w* de Dios, en \w sabiduría|strong="H2451"\w*, \w inteligencia|strong="H8394"\w*, \w conocimiento|strong="H1847"\w* y en \w toda|strong="H3605"\w* clase de arte,  
\v 32 para concebir \w diseños|strong="H4284"\w* artísticos, para \w trabajar|strong="H6213"\w* en \w oro|strong="H2091"\w*, en \w plata|strong="H3701"\w* y en bronce,  
\v 33 en \w el|strong="H3605"\w* tallado de piedras para engastar, y en \w el|strong="H3605"\w* tallado de \w madera|strong="H6086"\w*, \w a|strong="H3068"\w* fin de realizar \w toda|strong="H3605"\w* clase de \w obra|strong="H4399"\w* ingeniosa.  
\v 34 Además, ha \w puesto|strong="H5414"\w* en \w su|strong="H1931"\w* \w corazón|strong="H3820"\w* \w el|strong="H1931"\w* don \w de|strong="H1121"\w* \w enseñar|strong="H3384"\w*, tanto \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w como|strong="H1931"\w* \w a|strong="H3068"\w* Aholiab, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahisamac, \w de|strong="H1121"\w* \w la|strong="H1931"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w*.  
\v 35 \w Los|strong="H3605"\w* ha llenado de \w sabiduría|strong="H2451"\w* de \w corazón|strong="H3820"\w* para \w hacer|strong="H6213"\w* \w toda|strong="H3605"\w* clase de \w obra|strong="H4399"\w* de grabador, de \w artífice|strong="H2796"\w* experto y de recamador en hilo azul, púrpura, escarlata y lino fino, así como de tejedor; para \w hacer|strong="H6213"\w* \w cualquier|strong="H3605"\w* \w labor|strong="H4399"\w* \w e|strong="H3068"\w* idear \w diseños|strong="H4284"\w* artísticos.   
\c 36
\p
\v 1 “Bezalel y Aholiab trabajarán, pues, con \w todo|strong="H3605"\w* hombre \w sabio|strong="H2450"\w* \w de|strong="H5414"\w* \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* \w quien|strong="H3605"\w* Yahvé haya \w dado|strong="H5414"\w* \w sabiduría|strong="H2451"\w* \w e|strong="H3068"\w* \w inteligencia|strong="H8394"\w* \w para|strong="H5414"\w* \w saber|strong="H3045"\w* cómo ejecutar \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* del servicio del \w santuario|strong="H6944"\w*, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3045"\w* Yahvé ha \w mandado|strong="H6680"\w*.”   
\p
\v 2 \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* Bezalel, \w a|strong="H3068"\w* Aholiab y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* hombre \w sabio|strong="H2450"\w* \w de|strong="H5414"\w* \w corazón|strong="H3820"\w*, en cuyo \w corazón|strong="H3820"\w* Yahvé \w había|strong="H6213"\w* \w puesto|strong="H5414"\w* \w sabiduría|strong="H2451"\w*; \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* cuyo \w corazón|strong="H3820"\w* le impulsó \w a|strong="H3068"\w* acercarse \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* \w para|strong="H5414"\w* realizarla.  
\v 3 \w Y|strong="H3068"\w* \w tomaron|strong="H3947"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Moisés|strong="H4872"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w ofrenda|strong="H8641"\w* \w que|strong="H1121"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* habían traído para \w la|strong="H3605"\w* \w obra|strong="H4399"\w* del servicio del \w santuario|strong="H6944"\w*, \w a|strong="H3068"\w* fin \w de|strong="H6440"\w* llevarla \w a|strong="H3068"\w* cabo. \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w pueblo|strong="H1992"\w* seguía trayéndole \w ofrendas|strong="H8641"\w* \w voluntarias|strong="H5071"\w* \w cada|strong="H3605"\w* \w mañana|strong="H1242"\w*.  
\v 4 Entonces \w todos|strong="H3605"\w* \w los|strong="H1992"\w* artesanos expertos \w que|strong="H1992"\w* \w hacían|strong="H6213"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* del \w santuario|strong="H6944"\w*, dejaron \w cada|strong="H3605"\w* cual \w el|strong="H3605"\w* trabajo \w que|strong="H1992"\w* estaban \w haciendo|strong="H6213"\w*,  
