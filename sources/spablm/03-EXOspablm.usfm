\p
\v 33 Yahvé respondió \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «Al \w que|strong="H4310"\w* haya \w pecado|strong="H2398"\w* contra mí, \w a|strong="H3068"\w* ese borraré de mi \w libro|strong="H5612"\w*.  
\v 34 \w Ve|strong="H3212"\w*, \w pues|strong="H6258"\w*, \w ahora|strong="H6258"\w*, \w y|strong="H5921"\w* conduce \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w al|strong="H5921"\w* lugar \w del|strong="H5921"\w* \w que|strong="H6258"\w* \w te|strong="H5921"\w* he \w hablado|strong="H1696"\w*; he \w aquí|strong="H2009"\w*, \w mi|strong="H5921"\w* \w ángel|strong="H4397"\w* \w irá|strong="H3212"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*. Pero \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w del|strong="H5921"\w* castigo, \w yo|strong="H2009"\w* \w los|strong="H5921"\w* castigaré \w por|strong="H5921"\w* su \w pecado|strong="H2403"\w*».  
\v 35 \w Y|strong="H3068"\w* Yahvé castigó \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w por|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w hicieron|strong="H6213"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w becerro|strong="H5695"\w* \w que|strong="H5921"\w* Aarón \w había|strong="H6213"\w* fabricado.   
\c 33
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Anda|strong="H3212"\w*, \w sube|strong="H5927"\w* \w de|strong="H5971"\w* \w aquí|strong="H2088"\w*, tú y el \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w has|strong="H5414"\w* sacado \w de|strong="H5971"\w* la tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*, \w a|strong="H3068"\w* la tierra \w de|strong="H5971"\w* la cual \w juré|strong="H7650"\w* \w a|strong="H3068"\w* Abraham, \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* y \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, \w diciendo|strong="H1696"\w*: ‘\w A|strong="H3068"\w* tu \w descendencia|strong="H2233"\w* la \w daré|strong="H5414"\w*’.  
\v 2 Yo \w enviaré|strong="H7971"\w* un \w ángel|strong="H4397"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, y expulsaré al \w cananeo|strong="H3669"\w*, al amorreo, al hitita, al ferezeo, al \w heveo|strong="H2340"\w* y al \w jebuseo|strong="H2983"\w*.  
\v 3 \w Subid|strong="H5927"\w* \w a|strong="H3068"\w* una tierra \w que|strong="H3588"\w* mana \w leche|strong="H2461"\w* \w y|strong="H3588"\w* \w miel|strong="H1706"\w*; \w pero|strong="H3588"\w* \w yo|strong="H3588"\w* \w no|strong="H3808"\w* \w subiré|strong="H5927"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* vosotros, \w porque|strong="H3588"\w* sois un \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* \w dura|strong="H7186"\w* \w cerviz|strong="H6203"\w*, \w no|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* os \w consuma|strong="H3615"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w*.”   
\p
\v 4 \w Al|strong="H5921"\w* \w oír|strong="H8085"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w esta|strong="H2088"\w* \w mala|strong="H7451"\w* noticia, hicieron luto, \w y|strong="H5921"\w* \w ninguno|strong="H3808"\w* \w se|strong="H5921"\w* \w puso|strong="H7896"\w* sus atavíos.   
\p
\v 5 \w Pues|strong="H6258"\w* Yahvé \w había|strong="H6213"\w* dicho \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “Di \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: ‘Vosotros sois un \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w dura|strong="H7186"\w* \w cerviz|strong="H6203"\w*. \w Si|strong="H5921"\w* \w yo|strong="H6213"\w* subiera \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* vosotros \w por|strong="H5921"\w* un solo \w momento|strong="H7281"\w*, \w os|strong="H5921"\w* consumiría. \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, quitaos \w ahora|strong="H6258"\w* vuestros atavíos, \w para|strong="H5921"\w* \w que|strong="H4100"\w* \w yo|strong="H6213"\w* \w sepa|strong="H3045"\w* \w qué|strong="H4100"\w* \w hacer|strong="H6213"\w* \w con|strong="H5921"\w* vosotros’”.   
\p
\v 6 Así \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* se despojaron \w de|strong="H1121"\w* sus atavíos desde \w el|strong="H1121"\w* \w monte|strong="H2022"\w* \w Horeb|strong="H2722"\w* en adelante.   
\p
\v 7 \w Moisés|strong="H4872"\w* acostumbraba \w tomar|strong="H3947"\w* \w la|strong="H3605"\w* tienda y levantarla \w fuera|strong="H2351"\w* \w del|strong="H4480"\w* \w campamento|strong="H4264"\w*, \w a|strong="H3068"\w* buena distancia \w de|strong="H4480"\w* \w él|strong="H3605"\w*, y \w la|strong="H3605"\w* \w llamaba|strong="H7121"\w* \w la|strong="H3605"\w* «Tienda \w del|strong="H4480"\w* Encuentro». \w Y|strong="H3068"\w* \w sucedía|strong="H1961"\w* \w que|strong="H4480"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H4480"\w* \w buscaba|strong="H1245"\w* \w a|strong="H3068"\w* Yahvé, \w salía|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* Tienda \w del|strong="H4480"\w* Encuentro \w que|strong="H4480"\w* \w estaba|strong="H1961"\w* \w fuera|strong="H2351"\w* \w del|strong="H4480"\w* \w campamento|strong="H4264"\w*.  
\v 8 \w Cuando|strong="H5704"\w* \w Moisés|strong="H4872"\w* \w salía|strong="H3318"\w* hacia \w la|strong="H3605"\w* Tienda, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H1961"\w* levantaba \w y|strong="H5704"\w* \w se|strong="H1961"\w* mantenía \w en|strong="H5704"\w* pie, \w cada|strong="H3605"\w* uno \w a|strong="H3068"\w* \w la|strong="H3605"\w* entrada \w de|strong="H5704"\w* su propia tienda, \w y|strong="H5704"\w* \w seguían|strong="H1961"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w con|strong="H5704"\w* \w la|strong="H3605"\w* mirada \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w él|strong="H3605"\w* entraba \w en|strong="H5704"\w* \w la|strong="H3605"\w* Tienda.  
\v 9 \w Cuando|strong="H1961"\w* \w Moisés|strong="H4872"\w* entraba \w en|strong="H5973"\w* la Tienda, la \w columna|strong="H5982"\w* \w de|strong="H5973"\w* \w nube|strong="H6051"\w* \w descendía|strong="H3381"\w* y \w se|strong="H1961"\w* posaba \w a|strong="H3068"\w* la entrada \w de|strong="H5973"\w* la Tienda, y Yahvé \w hablaba|strong="H1696"\w* \w con|strong="H5973"\w* \w Moisés|strong="H4872"\w*.  
\v 10 Al \w ver|strong="H7200"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w la|strong="H3605"\w* \w columna|strong="H5982"\w* \w de|strong="H5971"\w* \w nube|strong="H6051"\w* \w se|strong="H5971"\w* posaba \w a|strong="H3068"\w* \w la|strong="H3605"\w* entrada \w de|strong="H5971"\w* \w la|strong="H3605"\w* Tienda, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* levantaba y \w adoraba|strong="H7812"\w*, \w cada|strong="H3605"\w* cual \w a|strong="H3068"\w* \w la|strong="H3605"\w* entrada \w de|strong="H5971"\w* su tienda.  
\v 11 \w Y|strong="H3068"\w* Yahvé \w hablaba|strong="H1696"\w* con \w Moisés|strong="H4872"\w* \w cara|strong="H6440"\w* \w a|strong="H3068"\w* \w cara|strong="H6440"\w*, como \w habla|strong="H1696"\w* un \w hombre|strong="H1121"\w* con su \w amigo|strong="H7453"\w*. \w Luego|strong="H7725"\w* \w Moisés|strong="H4872"\w* \w volvía|strong="H7725"\w* al \w campamento|strong="H4264"\w*, pero su joven ayudante \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Nun|strong="H5126"\w*, \w no|strong="H3808"\w* \w se|strong="H3808"\w* apartaba \w de|strong="H6440"\w* la Tienda.   
\p
\v 12 \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* Yahvé: “\w Mira|strong="H7200"\w*, tú \w me|strong="H5973"\w* dices: ‘Haz \w subir|strong="H5927"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*’, pero \w no|strong="H3808"\w* \w me|strong="H5973"\w* has declarado \w a|strong="H3068"\w* quién \w enviarás|strong="H7971"\w* \w conmigo|strong="H5973"\w*. \w Sin|strong="H3808"\w* embargo, has dicho: ‘\w Te|strong="H5869"\w* \w conozco|strong="H3045"\w* \w por|strong="H2088"\w* tu \w nombre|strong="H8034"\w*, \w y|strong="H1571"\w* has \w hallado|strong="H4672"\w* \w gracia|strong="H2580"\w* \w a|strong="H3068"\w* mis \w ojos|strong="H5869"\w*’.  
\v 13 \w Ahora|strong="H6258"\w*, \w pues|strong="H3588"\w*, \w si|strong="H3588"\w* he \w hallado|strong="H4672"\w* \w gracia|strong="H2580"\w* \w a|strong="H3068"\w* tus \w ojos|strong="H5869"\w*, \w te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* muestres \w ahora|strong="H6258"\w* tu \w camino|strong="H1870"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w te|strong="H5869"\w* conozca \w y|strong="H3588"\w* \w halle|strong="H4672"\w* \w gracia|strong="H2580"\w* \w a|strong="H3068"\w* tus \w ojos|strong="H5869"\w*; \w y|strong="H3588"\w* \w considera|strong="H3045"\w* \w que|strong="H3588"\w* \w esta|strong="H2088"\w* \w nación|strong="H1471"\w* \w es|strong="H2088"\w* tu \w pueblo|strong="H5971"\w*.”   
\p
\v 14 \w Y|strong="H3068"\w* Yahvé le respondió: «Mi \w presencia|strong="H6440"\w* \w irá|strong="H3212"\w* \w contigo|strong="H6440"\w*, y te daré descanso».   
\p
\v 15 Moisés le dijo: “\w Si|strong="H6440"\w* tu \w presencia|strong="H6440"\w* \w no|strong="H6440"\w* ha \w de|strong="H6440"\w* \w ir|strong="H1980"\w* conmigo, \w no|strong="H6440"\w* nos hagas salir \w de|strong="H6440"\w* \w aquí|strong="H2088"\w*.  
\v 16 \w Pues|strong="H3588"\w*, ¿\w en|strong="H5921"\w* \w qué|strong="H3588"\w* \w se|strong="H3045"\w* \w conocerá|strong="H3045"\w* aquí \w que|strong="H3588"\w* he \w hallado|strong="H4672"\w* \w gracia|strong="H2580"\w* \w a|strong="H3068"\w* tus \w ojos|strong="H5869"\w*, \w yo|strong="H3588"\w* \w y|strong="H3588"\w* tu \w pueblo|strong="H5971"\w*? ¿\w No|strong="H3808"\w* \w es|strong="H3588"\w* acaso \w en|strong="H5921"\w* \w que|strong="H3588"\w* tú \w andes|strong="H3212"\w* \w con|strong="H5973"\w* \w nosotros|strong="H3605"\w*, \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w nosotros|strong="H3605"\w*, \w yo|strong="H3588"\w* \w y|strong="H3588"\w* tu \w pueblo|strong="H5971"\w*, seamos apartados \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w que|strong="H3588"\w* hay \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra?”   
\p
\v 17 Yahvé \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w También|strong="H1571"\w* \w haré|strong="H6213"\w* \w esto|strong="H2088"\w* \w que|strong="H3588"\w* has \w dicho|strong="H1696"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* has \w hallado|strong="H4672"\w* \w gracia|strong="H2580"\w* \w a|strong="H3068"\w* mis \w ojos|strong="H5869"\w* \w y|strong="H1571"\w* \w te|strong="H5869"\w* \w conozco|strong="H3045"\w* \w por|strong="H3588"\w* \w tu|strong="H6213"\w* \w nombre|strong="H8034"\w*.”   
\p
\v 18 Entonces Moisés dijo: «Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me muestres tu \w gloria|strong="H3519"\w*».   
\p
\v 19 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* \w le|strong="H5921"\w* respondió: «Yo haré \w pasar|strong="H5674"\w* \w toda|strong="H3605"\w* \w mi|strong="H5921"\w* \w bondad|strong="H2898"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* tu \w rostro|strong="H6440"\w*, \w y|strong="H5921"\w* proclamaré \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* Yahvé \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*. Tendré \w misericordia|strong="H7355"\w* \w del|strong="H5921"\w* \w que|strong="H5921"\w* tendré \w misericordia|strong="H7355"\w*, \w y|strong="H5921"\w* seré clemente \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* seré clemente».  
\v 20 \w Y|strong="H3068"\w* añadió: “\w No|strong="H3808"\w* \w podrás|strong="H3201"\w* \w ver|strong="H7200"\w* mi \w rostro|strong="H6440"\w*, \w porque|strong="H3588"\w* \w ningún|strong="H3808"\w* hombre \w podrá|strong="H3201"\w* verme \w y|strong="H3588"\w* seguir viviendo.”  
\v 21 Dijo \w además|strong="H5921"\w* Yahvé: “He \w aquí|strong="H2009"\w*, hay un \w lugar|strong="H4725"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* tú \w te|strong="H5921"\w* pondrás \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* peña.  
\v 22 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H5921"\w* \w cuando|strong="H5704"\w* \w pase|strong="H5674"\w* \w mi|strong="H5921"\w* \w gloria|strong="H3519"\w*, \w te|strong="H5921"\w* \w pondré|strong="H7760"\w* \w en|strong="H5921"\w* una hendidura \w de|strong="H5921"\w* \w la|strong="H5921"\w* peña \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w cubriré|strong="H5526"\w* \w con|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3709"\w* \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* yo \w haya|strong="H1961"\w* \w pasado|strong="H5674"\w*;  
\v 23 después apartaré mi \w mano|strong="H3709"\w*, y \w verás|strong="H7200"\w* mis espaldas; pero \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w verá|strong="H7200"\w* mi \w rostro|strong="H6440"\w*.”   
\c 34
\p
\v 1 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «\w Lábrate|strong="H6458"\w* \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* \w de|strong="H5921"\w* piedra \w como|strong="H1961"\w* \w las|strong="H5921"\w* \w primeras|strong="H7223"\w*, \w y|strong="H5921"\w* yo escribiré \w sobre|strong="H5921"\w* estas \w tablas|strong="H3871"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w que|strong="H5921"\w* \w estaban|strong="H1961"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w primeras|strong="H7223"\w* \w tablas|strong="H3871"\w* \w que|strong="H5921"\w* rompiste.  
\v 2 Prepárate, \w pues|strong="H1961"\w*, \w para|strong="H5921"\w* \w mañana|strong="H1242"\w*, \w y|strong="H5921"\w* \w sube|strong="H5927"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w* \w al|strong="H5921"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*, \w y|strong="H5921"\w* preséntate \w allí|strong="H8033"\w* ante \w mí|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w del|strong="H5921"\w* \w monte|strong="H2022"\w*.  
\v 3 \w Y|strong="H3068"\w* \w que|strong="H1931"\w* \w no|strong="H3808"\w* \w suba|strong="H5927"\w* \w nadie|strong="H3808"\w* \w contigo|strong="H5973"\w*, \w ni|strong="H3808"\w* \w se|strong="H1931"\w* \w vea|strong="H7200"\w* \w a|strong="H3068"\w* \w nadie|strong="H3808"\w* \w en|strong="H5973"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w monte|strong="H2022"\w*; \w ni|strong="H3808"\w* siquiera \w ovejas|strong="H6629"\w* \w ni|strong="H3808"\w* \w bueyes|strong="H1241"\w* pasten \w delante|strong="H4136"\w* \w de|strong="H5973"\w* \w ese|strong="H1931"\w* \w monte|strong="H2022"\w*».   
\p
\v 4 \w Moisés|strong="H4872"\w* labró \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* de piedra como las \w primeras|strong="H7223"\w*; se levantó de madrugada y \w subió|strong="H5927"\w* al \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*, como Yahvé \w le|strong="H1242"\w* había \w mandado|strong="H6680"\w*, \w llevando|strong="H3947"\w* en su \w mano|strong="H3027"\w* las \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* de piedra.  
\v 5 \w Y|strong="H3068"\w* Yahvé \w descendió|strong="H3381"\w* \w en|strong="H5973"\w* la \w nube|strong="H6051"\w*, y se detuvo \w allí|strong="H8033"\w* \w junto|strong="H5973"\w* \w a|strong="H3068"\w* \w él|strong="H5973"\w*, y \w proclamó|strong="H7121"\w* \w el|strong="H5973"\w* \w nombre|strong="H8034"\w* \w de|strong="H5973"\w* Yahvé.  
\v 6 \w Y|strong="H3068"\w* \w pasando|strong="H5674"\w* Yahvé \w por|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w proclamó|strong="H7121"\w*: «¡Yahvé! ¡Yahvé! \w Dios|strong="H3068"\w* \w misericordioso|strong="H7349"\w* \w y|strong="H5921"\w* \w clemente|strong="H2587"\w*, lento \w para|strong="H5921"\w* \w la|strong="H5921"\w* ira \w y|strong="H5921"\w* \w grande|strong="H7227"\w* \w en|strong="H5921"\w* \w misericordia|strong="H2617"\w* \w y|strong="H5921"\w* verdad,  
\v 7 \w que|strong="H3808"\w* \w guarda|strong="H5341"\w* \w la|strong="H5921"\w* \w misericordia|strong="H2617"\w* \w a|strong="H3068"\w* millares, \w que|strong="H3808"\w* \w perdona|strong="H5375"\w* \w la|strong="H5921"\w* \w iniquidad|strong="H5771"\w*, \w la|strong="H5921"\w* \w rebelión|strong="H6588"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w*, \w y|strong="H5921"\w* \w que|strong="H3808"\w* \w de|strong="H5921"\w* \w ningún|strong="H3808"\w* \w modo|strong="H5352"\w* \w tendrá|strong="H5352"\w* \w por|strong="H5921"\w* inocente \w al|strong="H5921"\w* culpable; \w que|strong="H3808"\w* castiga \w la|strong="H5921"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* padres \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w*, \w hasta|strong="H5921"\w* \w la|strong="H5921"\w* tercera \w y|strong="H5921"\w* cuarta generación.»   
\p
\v 8 Entonces \w Moisés|strong="H4872"\w* se apresuró \w a|strong="H3068"\w* inclinar la cabeza hacia la tierra y \w adoró|strong="H7812"\w*.  
\v 9 \w Y|strong="H3068"\w* dijo: “\w Si|strong="H3588"\w* \w ahora|strong="H4994"\w* he \w hallado|strong="H4672"\w* \w gracia|strong="H2580"\w* \w a|strong="H3068"\w* tus \w ojos|strong="H5869"\w*, oh Yahvé, \w te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* Yahvé \w vaya|strong="H3212"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* \w nosotros|strong="H1931"\w*, \w aunque|strong="H3588"\w* \w este|strong="H1931"\w* sea un \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* \w dura|strong="H7186"\w* \w cerviz|strong="H6203"\w*; \w perdona|strong="H5545"\w* nuestra \w iniquidad|strong="H5771"\w* \w y|strong="H3588"\w* nuestro \w pecado|strong="H2403"\w*, \w y|strong="H3588"\w* tómanos \w como|strong="H3588"\w* tu heredad.”   
\p
\v 10 \w Y|strong="H3068"\w* \w él|strong="H1931"\w* respondió: “He \w aquí|strong="H2009"\w*, \w yo|strong="H3588"\w* \w hago|strong="H6213"\w* un \w pacto|strong="H1285"\w*: \w delante|strong="H5048"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w* \w haré|strong="H6213"\w* \w maravillas|strong="H6381"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* han \w hecho|strong="H6213"\w* \w en|strong="H5973"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra, \w ni|strong="H3808"\w* \w en|strong="H5973"\w* \w ninguna|strong="H3605"\w* \w nación|strong="H1471"\w*; \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w en|strong="H5973"\w* \w medio|strong="H7130"\w* \w del|strong="H5973"\w* \w cual|strong="H1931"\w* habitas \w verá|strong="H7200"\w* \w la|strong="H1931"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* Yahvé, \w porque|strong="H3588"\w* \w será|strong="H1931"\w* \w cosa|strong="H3605"\w* temible \w la|strong="H1931"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w haré|strong="H6213"\w* \w contigo|strong="H5973"\w*.  
\v 11 \w Guarda|strong="H8104"\w* lo \w que|strong="H3117"\w* \w yo|strong="H6680"\w* te \w mando|strong="H6680"\w* \w hoy|strong="H3117"\w*. He \w aquí|strong="H2005"\w* \w que|strong="H3117"\w* \w yo|strong="H6680"\w* expulso \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti al amorreo, al \w cananeo|strong="H3669"\w*, al hitita, al ferezeo, al \w heveo|strong="H2340"\w* y al \w jebuseo|strong="H2983"\w*.  
\v 12 \w Guárdate|strong="H8104"\w* \w de|strong="H5921"\w* \w hacer|strong="H3772"\w* \w pacto|strong="H1285"\w* \w con|strong="H5921"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w a|strong="H3068"\w* \w la|strong="H5921"\w* cual has \w de|strong="H5921"\w* entrar, \w no|strong="H6435"\w* \w sea|strong="H1961"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* conviertan \w en|strong="H5921"\w* tropezadero \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*;  
\v 13 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w destruiréis|strong="H5422"\w* sus \w altares|strong="H4196"\w*, haréis pedazos sus \w estatuas|strong="H4676"\w* \w y|strong="H3588"\w* cortaréis sus imágenes \w de|strong="H3588"\w* Asera;  
\v 14 \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* postrarás ante \w ningún|strong="H3808"\w* otro \w dios|strong="H3068"\w*, \w pues|strong="H3588"\w* Yahvé, \w cuyo|strong="H1931"\w* \w nombre|strong="H8034"\w* \w es|strong="H1931"\w* \w Celoso|strong="H7067"\w*, \w es|strong="H1931"\w* un \w Dios|strong="H3068"\w* \w celoso|strong="H7067"\w*.   
\p
\v 15 “\w No|strong="H6435"\w* hagas \w pacto|strong="H1285"\w* con \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de la tierra, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* \w se|strong="H6435"\w* prostituyan tras sus dioses y ofrezcan \w sacrificios|strong="H2077"\w* \w a|strong="H3068"\w* sus dioses, y te inviten, y comas de sus \w sacrificios|strong="H2077"\w*;  
\v 16 y \w tomes|strong="H3947"\w* \w de|strong="H1121"\w* sus \w hijas|strong="H1323"\w* para tus \w hijos|strong="H1121"\w*, y al prostituirse sus \w hijas|strong="H1323"\w* tras sus dioses, hagan \w que|strong="H1121"\w* tus \w hijos|strong="H1121"\w* también se prostituyan tras \w los|strong="H1121"\w* dioses \w de|strong="H1121"\w* ellas.   
\p
\v 17 “\w No|strong="H3808"\w* te \w harás|strong="H6213"\w* dioses de \w fundición|strong="H4541"\w*.   
\p
\v 18 “\w Guardarás|strong="H8104"\w* \w la|strong="H3588"\w* \w fiesta|strong="H2282"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* panes sin levadura. \w Siete|strong="H7651"\w* \w días|strong="H3117"\w* comeréis panes sin levadura, \w como|strong="H3588"\w* \w te|strong="H3588"\w* he \w mandado|strong="H6680"\w*, \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w tiempo|strong="H3117"\w* \w señalado|strong="H4150"\w* del \w mes|strong="H2320"\w* \w de|strong="H3588"\w* Abib; \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w mes|strong="H2320"\w* \w de|strong="H3588"\w* Abib \w saliste|strong="H3318"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 19 “\w Todo|strong="H3605"\w* primer nacido \w que|strong="H3605"\w* abra \w la|strong="H3605"\w* \w matriz|strong="H7358"\w* \w es|strong="H4735"\w* mío; \w y|strong="H7794"\w* de \w todo|strong="H3605"\w* tu \w ganado|strong="H4735"\w*, \w todo|strong="H3605"\w* \w primerizo|strong="H6363"\w*, macho de vaca \w o|strong="H3068"\w* de \w oveja|strong="H7716"\w*.  
\v 20 Pero \w el|strong="H3605"\w* \w primerizo|strong="H6363"\w* \w de|strong="H6440"\w* \w asno|strong="H2543"\w* \w lo|strong="H3808"\w* \w redimirás|strong="H6299"\w* con un \w cordero|strong="H7716"\w*; y \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* redimes, le quebrarás \w el|strong="H3605"\w* cuello. \w Redimirás|strong="H6299"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w primogénito|strong="H1060"\w* \w de|strong="H6440"\w* tus \w hijos|strong="H1121"\w*. \w Y|strong="H3068"\w* \w nadie|strong="H3808"\w* \w se|strong="H3808"\w* presentará \w ante|strong="H6440"\w* mí con las manos \w vacías|strong="H7387"\w*.   
\p
\v 21 “\w Seis|strong="H8337"\w* \w días|strong="H3117"\w* \w trabajarás|strong="H5647"\w*, pero en el \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* descansarás; aun en el \w tiempo|strong="H3117"\w* de la siembra y de la siega, descansarás.   
\p
\v 22 “Celebrarás la \w fiesta|strong="H2282"\w* de las \w semanas|strong="H7620"\w*, la de las primicias de la siega del \w trigo|strong="H2406"\w*, y la \w fiesta|strong="H2282"\w* de la recolección al terminar \w el|strong="H6213"\w* \w año|strong="H8141"\w*.  
\v 23 \w Tres|strong="H7969"\w* \w veces|strong="H6471"\w* al \w año|strong="H8141"\w* se presentarán \w todos|strong="H3605"\w* vuestros varones \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w el|strong="H3605"\w* \w Señor|strong="H3068"\w*, \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.  
\v 24 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* expulsaré \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w* \w de|strong="H3588"\w* tu \w presencia|strong="H6440"\w*, \w y|strong="H3588"\w* \w ensancharé|strong="H7337"\w* tus fronteras; \w y|strong="H3588"\w* \w nadie|strong="H3808"\w* \w codiciará|strong="H2530"\w* tu tierra \w cuando|strong="H3588"\w* \w subas|strong="H5927"\w* \w para|strong="H3588"\w* presentarte \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Yahvé, tu \w Dios|strong="H3068"\w*, \w tres|strong="H7969"\w* \w veces|strong="H6471"\w* al \w año|strong="H8141"\w*.   
\p
\v 25 “\w No|strong="H3808"\w* \w ofrecerás|strong="H7819"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* pan \w leudado|strong="H2557"\w*, \w ni|strong="H3808"\w* \w se|strong="H5921"\w* dejará \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w* \w el|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w fiesta|strong="H2282"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Pascua|strong="H6453"\w*.   
\p
\v 26 “Llevarás las \w primicias|strong="H7225"\w* de los primeros frutos de tu tierra \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de Yahvé, tu \w Dios|strong="H3068"\w*.  
\p «\w No|strong="H3808"\w* \w cocerás|strong="H1310"\w* \w el|strong="H1310"\w* \w cabrito|strong="H1423"\w* en la \w leche|strong="H2461"\w* de su madre».   
\p
\v 27 \w Y|strong="H3068"\w* Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «\w Escribe|strong="H3789"\w* tú estas \w palabras|strong="H1697"\w*, \w porque|strong="H3588"\w* \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* estas \w palabras|strong="H1697"\w* he \w hecho|strong="H3772"\w* un \w pacto|strong="H1285"\w* \w contigo|strong="H5921"\w* \w y|strong="H3588"\w* \w con|strong="H5921"\w* \w Israel|strong="H3478"\w*».   
\p
\v 28 \w Y|strong="H3068"\w* \w estuvo|strong="H1961"\w* \w allí|strong="H8033"\w* \w con|strong="H5973"\w* Yahvé cuarenta \w días|strong="H3117"\w* \w y|strong="H5921"\w* cuarenta \w noches|strong="H3915"\w*; \w no|strong="H3808"\w* comió \w pan|strong="H3899"\w* \w ni|strong="H3808"\w* \w bebió|strong="H8354"\w* \w agua|strong="H4325"\w*. \w Y|strong="H3068"\w* \w escribió|strong="H3789"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w tablas|strong="H3871"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w del|strong="H5921"\w* \w pacto|strong="H1285"\w*, \w los|strong="H5921"\w* \w Diez|strong="H6235"\w* Mandamientos.   
\p
\v 29 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w Moisés|strong="H4872"\w* \w descendió|strong="H3381"\w* \w del|strong="H4480"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w* \w con|strong="H4480"\w* las \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* \w del|strong="H4480"\w* \w Testimonio|strong="H5715"\w* \w en|strong="H4480"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*, \w al|strong="H4480"\w* bajar \w del|strong="H4480"\w* \w monte|strong="H2022"\w*, \w Moisés|strong="H4872"\w* \w no|strong="H3808"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w piel|strong="H5785"\w* \w de|strong="H4480"\w* \w su|strong="H3588"\w* \w rostro|strong="H6440"\w* \w resplandecía|strong="H7160"\w* \w por|strong="H3588"\w* \w haber|strong="H1961"\w* \w hablado|strong="H1696"\w* \w con|strong="H4480"\w* Dios.  
\v 30 Cuando Aarón y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w miraron|strong="H7200"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H1121"\w* \w la|strong="H3605"\w* \w piel|strong="H5785"\w* \w de|strong="H6440"\w* su \w rostro|strong="H6440"\w* \w resplandecía|strong="H7160"\w*, y tuvieron \w miedo|strong="H3372"\w* \w de|strong="H6440"\w* acercarse \w a|strong="H3068"\w* \w él|strong="H3605"\w*.  
\v 31 \w Entonces|strong="H7725"\w* \w Moisés|strong="H4872"\w* \w los|strong="H3605"\w* \w llamó|strong="H7121"\w*, y Aarón y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* jefes de \w la|strong="H3605"\w* congregación \w volvieron|strong="H7725"\w* \w a|strong="H3068"\w* \w él|strong="H3605"\w*; y \w Moisés|strong="H4872"\w* les \w habló|strong="H1696"\w*.  
\v 32 Después \w se|strong="H3651"\w* acercaron \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w él|strong="H3605"\w* \w les|strong="H6680"\w* \w ordenó|strong="H6680"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H1121"\w* Yahvé había \w hablado|strong="H1696"\w* con \w él|strong="H3605"\w* en \w el|strong="H3605"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*.  
