\v 4 \w Moisés|strong="H4872"\w* \w clamó|strong="H6817"\w* \w a|strong="H3068"\w* Yahvé diciendo: “¿\w Qué|strong="H4100"\w* debo \w hacer|strong="H6213"\w* con \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*? \w Están|strong="H2088"\w* \w a|strong="H3068"\w* punto \w de|strong="H5750"\w* apedrearme”.   
\p
\v 5 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «\w Pasa|strong="H5674"\w* \w delante|strong="H6440"\w* del \w pueblo|strong="H5971"\w*, lleva \w contigo|strong="H5971"\w* \w a|strong="H3068"\w* algunos \w ancianos|strong="H2205"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w toma|strong="H3947"\w* \w en|strong="H5221"\w* tu \w mano|strong="H3027"\w* la \w vara|strong="H4294"\w* con la \w que|strong="H5971"\w* golpeaste \w el|strong="H2975"\w* Nilo, y \w ve|strong="H1980"\w*.  
\v 6 He \w aquí|strong="H8033"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* \w estaré|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w* \w allí|strong="H8033"\w*, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w roca|strong="H6697"\w* \w en|strong="H5921"\w* \w Horeb|strong="H2722"\w*. Golpearás \w la|strong="H5921"\w* \w roca|strong="H6697"\w* \w y|strong="H5921"\w* \w saldrá|strong="H3318"\w* \w agua|strong="H4325"\w* \w de|strong="H4480"\w* \w ella|strong="H8033"\w*, \w para|strong="H5921"\w* \w que|strong="H4480"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* beba». \w Y|strong="H3068"\w* \w así|strong="H3651"\w* \w lo|strong="H5921"\w* \w hizo|strong="H6213"\w* \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* vista \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*.  
\v 7 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w del|strong="H5921"\w* \w lugar|strong="H4725"\w* Masah,\f + \fr 17:7 \ft «Masah» significa prueba.\f* \w y|strong="H5921"\w* Meribá,\f + \fr 17:7 \ft «Meribá» significa riña o contienda.\f* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w contienda|strong="H7379"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w porque|strong="H5921"\w* \w tentaron|strong="H5254"\w* \w a|strong="H3068"\w* Yahvé, diciendo: «¿\w Está|strong="H3426"\w* Yahvé \w entre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w o|strong="H3068"\w* \w no|strong="H5921"\w*?»   
\p
\v 8 Entonces vino \w Amalec|strong="H6002"\w* y \w peleó|strong="H3898"\w* \w contra|strong="H5973"\w* \w Israel|strong="H3478"\w* \w en|strong="H5973"\w* Refidim.  
\v 9 \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: «Escoge hombres \w para|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w y|strong="H5921"\w* \w sal|strong="H3318"\w* \w a|strong="H3068"\w* pelear \w contra|strong="H5921"\w* \w Amalec|strong="H6002"\w*. \w Mañana|strong="H4279"\w* yo \w estaré|strong="H5324"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* cima \w del|strong="H5921"\w* \w collado|strong="H1389"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w vara|strong="H4294"\w* \w de|strong="H5921"\w* Dios \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*».  
\v 10 \w Josué|strong="H3091"\w* \w hizo|strong="H6213"\w* \w lo|strong="H6213"\w* que \w Moisés|strong="H4872"\w* le \w había|strong="H6213"\w* dicho, y luchó contra \w Amalec|strong="H6002"\w*; y \w Moisés|strong="H4872"\w*, Aarón y \w Hur|strong="H2354"\w* \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* la cima del \w collado|strong="H1389"\w*.  
\v 11 \w Y|strong="H3068"\w* \w sucedía|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w Moisés|strong="H4872"\w* levantaba su \w mano|strong="H3027"\w*, \w Israel|strong="H3478"\w* \w prevalecía|strong="H1396"\w*; pero \w cuando|strong="H1961"\w* bajaba su \w mano|strong="H3027"\w*, \w prevalecía|strong="H1396"\w* \w Amalec|strong="H6002"\w*.  
\v 12 Pero \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w se|strong="H1961"\w* cansaron, \w así|strong="H2088"\w* \w que|strong="H5921"\w* \w tomaron|strong="H3947"\w* una piedra \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w pusieron|strong="H7760"\w* \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w se|strong="H1961"\w* sentó \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*. Aarón \w y|strong="H5921"\w* \w Hur|strong="H2354"\w* \w le|strong="H5921"\w* sostenían \w las|strong="H5921"\w* \w manos|strong="H3027"\w*, \w el|strong="H5921"\w* uno \w de|strong="H5921"\w* un \w lado|strong="H3027"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w otro|strong="H2088"\w* \w del|strong="H5921"\w* \w otro|strong="H2088"\w*. \w Así|strong="H2088"\w* sus \w manos|strong="H3027"\w* \w se|strong="H1961"\w* mantuvieron firmes \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* puesta \w del|strong="H5921"\w* \w sol|strong="H8121"\w*.  
\v 13 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* derrotó \w a|strong="H3068"\w* \w Amalec|strong="H6002"\w* y \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* filo \w de|strong="H5971"\w* \w espada|strong="H2719"\w*.  
\v 14 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Escribe|strong="H3789"\w* \w esto|strong="H2063"\w* \w como|strong="H3588"\w* un memorial \w en|strong="H3588"\w* un \w libro|strong="H5612"\w*, \w y|strong="H3588"\w* hazlo saber \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: \w que|strong="H3588"\w* borraré \w por|strong="H3588"\w* completo \w la|strong="H3588"\w* \w memoria|strong="H2143"\w* \w de|strong="H3588"\w* \w Amalec|strong="H6002"\w* \w de|strong="H3588"\w* \w debajo|strong="H8478"\w* del \w cielo|strong="H8064"\w*.”  
\v 15 \w Moisés|strong="H4872"\w* construyó un \w altar|strong="H4196"\w* y lo \w llamó|strong="H7121"\w* «Yahvé, mi estandarte».\f + \fr 17:15 \ft En hebreo, Yahvé Nissi.\f*  
\v 16 \w Y|strong="H3068"\w* dijo: “\w Por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w Amalec|strong="H6002"\w* \w se|strong="H5921"\w* levantó \w contra|strong="H5921"\w* \w el|strong="H5921"\w* trono \w de|strong="H5921"\w* Yahvé, Yahvé tendrá \w guerra|strong="H4421"\w* \w contra|strong="H5921"\w* \w Amalec|strong="H6002"\w* \w de|strong="H5921"\w* \w generación|strong="H1755"\w* \w en|strong="H5921"\w* \w generación|strong="H1755"\w*.”   
\c 18
\p
\v 1 Jetro, \w el|strong="H3588"\w* \w sacerdote|strong="H3548"\w* \w de|strong="H3588"\w* \w Madián|strong="H4080"\w*, \w suegro|strong="H2859"\w* \w de|strong="H3588"\w* \w Moisés|strong="H4872"\w*, \w se|strong="H5971"\w* enteró \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w Dios|strong="H3068"\w* \w había|strong="H3588"\w* \w hecho|strong="H6213"\w* \w por|strong="H3588"\w* \w Moisés|strong="H4872"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w cómo|strong="H3588"\w* Yahvé \w había|strong="H3588"\w* \w sacado|strong="H3318"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.  
\v 2 \w Y|strong="H3068"\w* Jetro, \w suegro|strong="H2859"\w* de \w Moisés|strong="H4872"\w*, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* Séfora, la esposa de \w Moisés|strong="H4872"\w*, después de que este la había enviado de regreso,  
\v 3 \w y|strong="H3588"\w* \w a|strong="H3068"\w* sus \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*. \w El|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* uno \w era|strong="H1961"\w* Gersón,\f + \fr 18:3 \ft «Gersón» (Gershom) suena como el hebreo para «un extranjero allí».\f* \w porque|strong="H3588"\w* Moisés dijo: «He vivido \w como|strong="H3588"\w* \w extranjero|strong="H5237"\w* \w en|strong="H3588"\w* tierra extranjera».  
\v 4 \w El|strong="H3588"\w* \w nombre|strong="H8034"\w* del otro fue Eliezer,\f + \fr 18:4 \ft «Eliezer» significa «Dios es mi ayudador».\f* \w pues|strong="H3588"\w* dijo: «\w El|strong="H3588"\w* Dios \w de|strong="H3588"\w* mi padre fue mi \w ayuda|strong="H5828"\w* \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w libró|strong="H5337"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* del \w faraón|strong="H6547"\w*».  
\v 5 Jetro, \w el|strong="H1931"\w* \w suegro|strong="H2859"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*, vino con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* y \w la|strong="H1931"\w* esposa \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w* al \w desierto|strong="H4057"\w*, \w donde|strong="H8033"\w* \w él|strong="H1931"\w* estaba acampado, junto al \w monte|strong="H2022"\w* \w de|strong="H1121"\w* Dios.  
\v 6 \w Y|strong="H3068"\w* mandó \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “Yo, tu \w suegro|strong="H2859"\w* Jetro, he venido \w a|strong="H3068"\w* \w ti|strong="H5973"\w* \w con|strong="H5973"\w* tu mujer y sus \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w* \w con|strong="H5973"\w* ella.”   
\p
\v 7 \w Moisés|strong="H4872"\w* \w salió|strong="H3318"\w* al encuentro de su \w suegro|strong="H2859"\w*, se inclinó y lo \w besó|strong="H5401"\w*. Se \w preguntaron|strong="H7592"\w* mutuamente por su bienestar, y entraron \w en|strong="H3318"\w* la tienda.  
\v 8 \w Moisés|strong="H4872"\w* \w le|strong="H5921"\w* \w contó|strong="H5608"\w* \w a|strong="H3068"\w* su \w suegro|strong="H2859"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* Yahvé \w había|strong="H4672"\w* \w hecho|strong="H6213"\w* \w al|strong="H5921"\w* \w faraón|strong="H6547"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w* \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w todas|strong="H3605"\w* \w las|strong="H5921"\w* dificultades \w que|strong="H5921"\w* \w les|strong="H5921"\w* habían sobrevenido \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*, \w y|strong="H5921"\w* \w cómo|strong="H5921"\w* Yahvé \w los|strong="H5921"\w* \w había|strong="H4672"\w* \w librado|strong="H5337"\w*.  
\v 9 Jetro \w se|strong="H5921"\w* alegró \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w bien|strong="H2896"\w* \w que|strong="H5921"\w* Yahvé \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w al|strong="H5921"\w* librarlo \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w*.  
\v 10 \w Y|strong="H3068"\w* Jetro dijo: “\w Bendito|strong="H1288"\w* sea Yahvé, \w que|strong="H5971"\w* os ha \w librado|strong="H5337"\w* \w de|strong="H8478"\w* la \w mano|strong="H3027"\w* \w de|strong="H8478"\w* los \w egipcios|strong="H4714"\w* y \w de|strong="H8478"\w* la \w mano|strong="H3027"\w* del \w faraón|strong="H6547"\w*; \w que|strong="H5971"\w* ha \w librado|strong="H5337"\w* \w al|strong="H8478"\w* \w pueblo|strong="H5971"\w* del \w poder|strong="H3027"\w* \w de|strong="H8478"\w* los \w egipcios|strong="H4714"\w*.  
\v 11 \w Ahora|strong="H6258"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* Yahvé \w es|strong="H3588"\w* \w más|strong="H3588"\w* \w grande|strong="H1419"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* dioses, precisamente \w porque|strong="H3588"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w asunto|strong="H1697"\w* \w en|strong="H5921"\w* \w que|strong="H3588"\w* \w los|strong="H5921"\w* egipcios \w se|strong="H3045"\w* enorgullecieron, \w él|strong="H5921"\w* estuvo \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.”  
\v 12 Jetro, \w suegro|strong="H2859"\w* \w de|strong="H6440"\w* \w Moisés|strong="H4872"\w*, ofreció un \w holocausto|strong="H5930"\w* y \w sacrificios|strong="H2077"\w* \w para|strong="H5973"\w* Dios. Luego Aarón vino \w con|strong="H5973"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w para|strong="H5973"\w* comer \w pan|strong="H3899"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w suegro|strong="H2859"\w* \w de|strong="H6440"\w* \w Moisés|strong="H4872"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Dios.   
\p
\v 13 \w Al|strong="H5921"\w* día \w siguiente|strong="H4283"\w*, \w Moisés|strong="H4872"\w* \w se|strong="H1961"\w* sentó \w a|strong="H3068"\w* juzgar \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w estuvo|strong="H1961"\w* \w de|strong="H4480"\w* \w pie|strong="H5975"\w* \w alrededor|strong="H4480"\w* \w de|strong="H4480"\w* \w Moisés|strong="H4872"\w* \w desde|strong="H4480"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w* \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* noche.  
\v 14 \w Cuando|strong="H4100"\w* \w el|strong="H1931"\w* \w suegro|strong="H2859"\w* \w de|strong="H4480"\w* \w Moisés|strong="H4872"\w* \w vio|strong="H7200"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H4100"\w* \w él|strong="H1931"\w* \w hacía|strong="H6213"\w* \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w*, \w le|strong="H1931"\w* dijo: «¿\w Qué|strong="H4100"\w* \w es|strong="H1931"\w* \w esto|strong="H2088"\w* \w que|strong="H4100"\w* \w haces|strong="H6213"\w* \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w*? ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w te|strong="H5921"\w* sientas \w tú|strong="H6213"\w* \w solo|strong="H1931"\w*, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w se|strong="H1931"\w* queda \w de|strong="H4480"\w* pie \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w alrededor|strong="H4480"\w* \w desde|strong="H4480"\w* \w la|strong="H1931"\w* \w mañana|strong="H1242"\w* \w hasta|strong="H5704"\w* \w la|strong="H1931"\w* \w tarde|strong="H6153"\w*?»   
\p
\v 15 \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w suegro|strong="H2859"\w*: “\w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* viene \w a|strong="H3068"\w* mí \w para|strong="H3588"\w* consultar \w a|strong="H3068"\w* Dios.  
\v 16 \w Cuando|strong="H3588"\w* \w tienen|strong="H1961"\w* algún pleito, vienen \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w juzgo|strong="H8199"\w* \w entre|strong="H3588"\w* \w el|strong="H3588"\w* uno \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w otro|strong="H7453"\w*, \w y|strong="H3588"\w* les hago conocer \w los|strong="H1961"\w* \w estatutos|strong="H2706"\w* \w de|strong="H3588"\w* Dios \w y|strong="H3588"\w* sus \w leyes|strong="H8451"\w*.”  
\v 17 \w El|strong="H6213"\w* \w suegro|strong="H2859"\w* \w de|strong="H1697"\w* \w Moisés|strong="H4872"\w* le respondió: “\w Lo|strong="H1697"\w* \w que|strong="H3808"\w* \w haces|strong="H6213"\w* \w no|strong="H3808"\w* está \w bien|strong="H2896"\w*.  
\v 18 Seguramente \w te|strong="H4480"\w* agotarás, tanto \w tú|strong="H6213"\w* \w como|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* \w está|strong="H2088"\w* \w contigo|strong="H5973"\w*, \w porque|strong="H3588"\w* \w el|strong="H5973"\w* trabajo \w es|strong="H2088"\w* demasiado \w pesado|strong="H3515"\w* \w para|strong="H3588"\w* \w ti|strong="H4480"\w*. \w No|strong="H3808"\w* eres capaz \w de|strong="H4480"\w* \w hacerlo|strong="H3201"\w* \w tú|strong="H6213"\w* solo.  
\v 19 \w Escucha|strong="H8085"\w* \w ahora|strong="H6258"\w* \w mi|strong="H1961"\w* \w voz|strong="H6963"\w*; yo \w te|strong="H5973"\w* \w aconsejaré|strong="H3289"\w*, y Dios \w estará|strong="H1961"\w* \w contigo|strong="H5973"\w*. Tú debes representar al \w pueblo|strong="H5971"\w* ante Dios, y presentar \w los|strong="H5973"\w* casos ante Dios.  
\v 20 Les enseñarás los \w estatutos|strong="H2706"\w* y las \w leyes|strong="H8451"\w*, y les mostrarás \w el|strong="H6213"\w* \w camino|strong="H1870"\w* \w por|strong="H1870"\w* \w el|strong="H6213"\w* \w que|strong="H3045"\w* deben \w andar|strong="H3212"\w* y las \w obras|strong="H4639"\w* \w que|strong="H3045"\w* deben \w hacer|strong="H6213"\w*.  
\v 21 \w Además|strong="H5921"\w*, escogerás \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* hombres capaces \w y|strong="H5921"\w* \w temerosos|strong="H3373"\w* \w de|strong="H5921"\w* Dios; hombres veraces, \w que|strong="H5921"\w* aborrezcan \w las|strong="H5921"\w* ganancias deshonestas; \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w pondrás|strong="H7760"\w* \w al|strong="H5921"\w* frente \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w como|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w mil|strong="H6235"\w*, \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w cien|strong="H3967"\w*, \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w cincuenta|strong="H2572"\w* \w y|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w diez|strong="H6235"\w*.  
\v 22 \w Que|strong="H5921"\w* \w ellos|strong="H1992"\w* juzguen \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* momento. \w Todo|strong="H3605"\w* \w asunto|strong="H1697"\w* \w grave|strong="H1419"\w* \w te|strong="H5921"\w* \w lo|strong="H1697"\w* \w traerán|strong="H5375"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, pero \w todo|strong="H3605"\w* \w asunto|strong="H1697"\w* \w menor|strong="H6996"\w* \w lo|strong="H1697"\w* \w juzgarán|strong="H8199"\w* \w ellos|strong="H1992"\w* \w mismos|strong="H1992"\w*. \w Así|strong="H1992"\w* \w te|strong="H5921"\w* aliviarás \w la|strong="H5921"\w* carga, \w y|strong="H5921"\w* \w ellos|strong="H1992"\w* \w la|strong="H5921"\w* \w llevarán|strong="H5375"\w* \w contigo|strong="H5921"\w*.  
\v 23 \w Si|strong="H1571"\w* \w haces|strong="H6213"\w* \w esto|strong="H2088"\w*, \w y|strong="H1571"\w* Dios \w te|strong="H5921"\w* \w lo|strong="H1697"\w* \w manda|strong="H6680"\w*, \w entonces|strong="H1571"\w* \w podrás|strong="H3201"\w* resistir, \w y|strong="H1571"\w* \w toda|strong="H3605"\w* \w esta|strong="H2088"\w* \w gente|strong="H5971"\w* \w también|strong="H1571"\w* volverá \w a|strong="H3068"\w* sus hogares \w en|strong="H5921"\w* \w paz|strong="H7965"\w*.”   
\p
\v 24 \w Moisés|strong="H4872"\w* \w escuchó|strong="H8085"\w* \w la|strong="H3605"\w* \w voz|strong="H6963"\w* de su \w suegro|strong="H2859"\w*, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w él|strong="H3605"\w* le \w había|strong="H6213"\w* aconsejado.  
\v 25 \w Moisés|strong="H4872"\w* eligió \w a|strong="H3068"\w* hombres capaces \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* nombró líderes \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*: \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w mil|strong="H6235"\w*, \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w cien|strong="H3967"\w*, \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w cincuenta|strong="H2572"\w* \w y|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w diez|strong="H6235"\w*.  
\v 26 \w Ellos|strong="H1992"\w* \w juzgaban|strong="H8199"\w* \w al|strong="H6256"\w* \w pueblo|strong="H5971"\w* en \w todo|strong="H3605"\w* momento. \w Los|strong="H1992"\w* casos difíciles \w se|strong="H1992"\w* \w los|strong="H1992"\w* traían \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, pero \w todo|strong="H3605"\w* \w asunto|strong="H1697"\w* \w menor|strong="H6996"\w* \w lo|strong="H1697"\w* \w juzgaban|strong="H8199"\w* \w ellos|strong="H1992"\w* \w mismos|strong="H1992"\w*.  
\v 27 \w Moisés|strong="H4872"\w* \w despidió|strong="H7971"\w* \w a|strong="H3068"\w* su \w suegro|strong="H2859"\w*, y este se marchó \w a|strong="H3068"\w* su propia tierra.   
\c 19
\p
\v 1 \w En|strong="H3318"\w* \w el|strong="H1121"\w* tercer \w mes|strong="H2320"\w* después \w de|strong="H1121"\w* \w que|strong="H3117"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* salieran \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, \w en|strong="H3318"\w* \w ese|strong="H2088"\w* mismo \w día|strong="H3117"\w*, llegaron al \w desierto|strong="H4057"\w* \w de|strong="H1121"\w* \w Sinaí|strong="H5514"\w*.  
\v 2 Habían partido \w de|strong="H5048"\w* Refidim, y cuando llegaron al \w desierto|strong="H4057"\w* \w de|strong="H5048"\w* \w Sinaí|strong="H5514"\w*, acamparon en el \w desierto|strong="H4057"\w*; \w allí|strong="H8033"\w* acampó \w Israel|strong="H3478"\w* \w frente|strong="H5048"\w* al \w monte|strong="H2022"\w*.  
\v 3 \w Moisés|strong="H4872"\w* \w subió|strong="H5927"\w* \w hacia|strong="H4480"\w* \w Dios|strong="H3068"\w*, \w y|strong="H3541"\w* Yahvé lo \w llamó|strong="H7121"\w* \w desde|strong="H4480"\w* \w el|strong="H1121"\w* \w monte|strong="H2022"\w*, diciendo: “\w Esto|strong="H3541"\w* \w es|strong="H3541"\w* lo \w que|strong="H4480"\w* dirás \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w Jacob|strong="H3290"\w* \w y|strong="H3541"\w* anunciarás \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*:  
\v 4 ‘Vosotros habéis \w visto|strong="H7200"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w hice|strong="H6213"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w*, \w y|strong="H5921"\w* \w cómo|strong="H5921"\w* \w os|strong="H5921"\w* \w llevé|strong="H5375"\w* \w sobre|strong="H5921"\w* \w alas|strong="H3671"\w* \w de|strong="H5921"\w* águila \w y|strong="H5921"\w* \w os|strong="H5921"\w* traje \w a|strong="H3068"\w* \w mí|strong="H5921"\w*.  
\v 5 \w Ahora|strong="H6258"\w*, \w pues|strong="H3588"\w*, \w si|strong="H3588"\w* \w en|strong="H3588"\w* verdad escucháis \w mi|strong="H1961"\w* \w voz|strong="H6963"\w* \w y|strong="H3588"\w* guardáis \w mi|strong="H1961"\w* \w pacto|strong="H1285"\w*, \w seréis|strong="H1961"\w* \w mi|strong="H1961"\w* \w especial|strong="H5459"\w* tesoro \w de|strong="H3588"\w* \w entre|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*, \w porque|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra \w es|strong="H1961"\w* mía;  
\v 6 y \w seréis|strong="H1961"\w* \w para|strong="H1961"\w* \w mí|strong="H1961"\w* un \w reino|strong="H4467"\w* \w de|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* y una \w nación|strong="H1471"\w* \w santa|strong="H6918"\w*’. Estas \w son|strong="H1961"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w dirás|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*”.   
\p
\v 7 \w Moisés|strong="H4872"\w* fue y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* del \w pueblo|strong="H5971"\w*, y expuso \w ante|strong="H6440"\w* \w ellos|strong="H3605"\w* \w todas|strong="H3605"\w* estas \w palabras|strong="H1697"\w* \w que|strong="H5971"\w* Yahvé le había \w ordenado|strong="H6680"\w*.  
\v 8 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* una voz y \w dijo|strong="H1696"\w*: «\w Haremos|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H5971"\w* Yahvé ha \w dicho|strong="H1697"\w*». \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w refirió|strong="H7725"\w* \w a|strong="H3068"\w* Yahvé las \w palabras|strong="H1697"\w* del \w pueblo|strong="H5971"\w*.  
\v 9 Yahvé \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «He \w aquí|strong="H2009"\w* \w que|strong="H1571"\w* \w yo|strong="H2009"\w* vengo \w a|strong="H3068"\w* \w ti|strong="H5973"\w* \w en|strong="H5973"\w* una densa \w nube|strong="H6051"\w*, \w para|strong="H5973"\w* \w que|strong="H1571"\w* \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w* \w oiga|strong="H8085"\w* \w cuando|strong="H1571"\w* \w yo|strong="H2009"\w* \w hable|strong="H1696"\w* \w contigo|strong="H5973"\w* \w y|strong="H1571"\w* \w te|strong="H5973"\w* crean \w para|strong="H5973"\w* \w siempre|strong="H5769"\w*». \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w le|strong="H5973"\w* transmitió \w a|strong="H3068"\w* Yahvé las \w palabras|strong="H1697"\w* \w del|strong="H5973"\w* \w pueblo|strong="H5971"\w*.  
\v 10 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Ve|strong="H3212"\w* al \w pueblo|strong="H5971"\w* y santifícalos \w hoy|strong="H3117"\w* y \w mañana|strong="H4279"\w*, y \w que|strong="H5971"\w* laven sus \w vestidos|strong="H8071"\w*,  
\v 11 \w y|strong="H3588"\w* \w estén|strong="H1961"\w* preparados \w para|strong="H5921"\w* \w el|strong="H5921"\w* tercer \w día|strong="H3117"\w*; \w porque|strong="H3588"\w* \w al|strong="H5921"\w* tercer \w día|strong="H3117"\w* Yahvé \w descenderá|strong="H3381"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* vista \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*.  
\v 12 Pondrás límites al \w pueblo|strong="H5971"\w* en \w derredor|strong="H5439"\w*, diciendo: ‘\w Guardaos|strong="H8104"\w* \w de|strong="H5971"\w* no \w subir|strong="H5927"\w* al \w monte|strong="H2022"\w* ni \w tocar|strong="H5060"\w* sus límites. \w Cualquiera|strong="H3605"\w* \w que|strong="H5971"\w* toque \w el|strong="H3605"\w* \w monte|strong="H2022"\w* \w morirá|strong="H4191"\w* \w irremisiblemente|strong="H4191"\w*.  
\v 13 \w Ninguna|strong="H3808"\w* \w mano|strong="H3027"\w* \w lo|strong="H3808"\w* \w tocará|strong="H5060"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w será|strong="H5619"\w* \w apedreado|strong="H5619"\w* \w o|strong="H3068"\w* \w asaeteado|strong="H3384"\w*; sea animal u hombre, \w no|strong="H3808"\w* \w vivirá|strong="H2421"\w*’. Solo \w cuando|strong="H3588"\w* \w la|strong="H3588"\w* trompeta suene \w con|strong="H3588"\w* un toque prolongado, podrán \w ellos|strong="H1992"\w* \w subir|strong="H5927"\w* al \w monte|strong="H2022"\w*”.   
\p
\v 14 \w Moisés|strong="H4872"\w* bajó \w del|strong="H4480"\w* \w monte|strong="H2022"\w* \w hacia|strong="H4480"\w* el \w pueblo|strong="H5971"\w* y lo \w santificó|strong="H6942"\w*, y \w ellos|strong="H4480"\w* lavaron sus \w ropas|strong="H8071"\w*.  
\v 15 \w Y|strong="H3068"\w* dijo al \w pueblo|strong="H5971"\w*: «\w Estad|strong="H1961"\w* preparados \w para|strong="H1961"\w* \w el|strong="H5066"\w* tercer \w día|strong="H3117"\w*. \w No|strong="H1961"\w* os acerquéis \w a|strong="H3068"\w* mujer».   
\p
\v 16 \w Al|strong="H5921"\w* tercer \w día|strong="H3117"\w*, \w al|strong="H5921"\w* amanecer, \w hubo|strong="H1961"\w* \w truenos|strong="H6963"\w* \w y|strong="H5921"\w* \w relámpagos|strong="H1300"\w*, \w y|strong="H5921"\w* una espesa \w nube|strong="H6051"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w*, \w y|strong="H5921"\w* un \w sonido|strong="H6963"\w* \w de|strong="H5921"\w* \w trompeta|strong="H7782"\w* \w muy|strong="H3966"\w* \w fuerte|strong="H2389"\w*; \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campamento|strong="H4264"\w* \w se|strong="H1961"\w* estremeció.  
\v 17 \w Moisés|strong="H4872"\w* \w sacó|strong="H3318"\w* \w al|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w del|strong="H4480"\w* \w campamento|strong="H4264"\w* \w para|strong="H4480"\w* ir \w al|strong="H4480"\w* encuentro \w de|strong="H4480"\w* Dios, y \w se|strong="H4480"\w* detuvieron \w al|strong="H4480"\w* pie \w del|strong="H4480"\w* \w monte|strong="H2022"\w*.  
\v 18 \w Todo|strong="H3605"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w* \w humeaba|strong="H6227"\w*, \w porque|strong="H5921"\w* Yahvé había descendido \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* fuego; \w el|strong="H5921"\w* \w humo|strong="H6227"\w* \w subía|strong="H5927"\w* \w como|strong="H5921"\w* \w el|strong="H5921"\w* \w humo|strong="H6227"\w* \w de|strong="H5921"\w* un horno, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* temblaba violentamente.  
\v 19 El \w sonido|strong="H6963"\w* de la \w trompeta|strong="H7782"\w* \w se|strong="H1961"\w* \w iba|strong="H1980"\w* haciendo cada vez \w más|strong="H6030"\w* fuerte; \w Moisés|strong="H4872"\w* \w hablaba|strong="H1696"\w*, y Dios le respondía con \w voz|strong="H6963"\w* de trueno.  
\v 20 Yahvé \w descendió|strong="H3381"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w del|strong="H5921"\w* \w monte|strong="H2022"\w*. \w Llamó|strong="H7121"\w* Yahvé \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w del|strong="H5921"\w* \w monte|strong="H2022"\w*, \w y|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w subió|strong="H5927"\w*.   
\p
\v 21 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Desciende|strong="H3381"\w* y advierte \w al|strong="H4480"\w* \w pueblo|strong="H5971"\w*, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H4480"\w* \w traspasen|strong="H2040"\w* los límites \w para|strong="H4480"\w* \w ver|strong="H7200"\w* \w a|strong="H3068"\w* Yahvé, y perezcan \w muchos|strong="H7227"\w* \w de|strong="H4480"\w* \w ellos|strong="H4480"\w*.  
\v 22 \w Que|strong="H6435"\w* \w también|strong="H1571"\w* los \w sacerdotes|strong="H3548"\w* \w que|strong="H6435"\w* \w se|strong="H6435"\w* acercan \w a|strong="H3068"\w* Yahvé \w se|strong="H6435"\w* santifiquen, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* Yahvé irrumpa contra \w ellos|strong="H1571"\w*.”   
\p
\v 23 \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* Yahvé: “\w El|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* \w podrá|strong="H3201"\w* \w subir|strong="H5927"\w* al \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*, \w porque|strong="H3588"\w* tú nos has advertido, diciendo: ‘Pon límites alrededor del \w monte|strong="H2022"\w* \w y|strong="H3588"\w* santifícalo’”.   
\p
\v 24 Yahvé \w le|strong="H5973"\w* respondió: «¡\w Ve|strong="H3212"\w*, \w desciende|strong="H3381"\w*! \w Luego|strong="H5927"\w* \w subirás|strong="H5927"\w* tú, y Aarón \w contigo|strong="H5973"\w*; pero \w no|strong="H6435"\w* permitas \w que|strong="H6435"\w* \w los|strong="H5973"\w* \w sacerdotes|strong="H3548"\w* y \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w* \w traspasen|strong="H2040"\w* \w los|strong="H5973"\w* límites \w para|strong="H5973"\w* \w subir|strong="H5927"\w* \w a|strong="H3068"\w* Yahvé, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* \w él|strong="H5973"\w* irrumpa \w contra|strong="H5973"\w* ellos.»   
\p
\v 25 Entonces \w Moisés|strong="H4872"\w* bajó hacia el \w pueblo|strong="H5971"\w* y \w se|strong="H5971"\w* lo hizo saber.   
\c 20
\p
\v 1 Dios\f + \fr 20:1 \ft Después de «Dios», el hebreo tiene las dos letras «Alef Tav» (la primera y la última del alfabeto hebreo), no como una palabra, sino como un marcador gramatical.\f* \w pronunció|strong="H1696"\w* \w todas|strong="H3605"\w* estas \w palabras|strong="H1697"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “Yo soy Yahvé, tu \w Dios|strong="H3068"\w*, que te \w saqué|strong="H3318"\w* de la tierra de \w Egipto|strong="H4714"\w*, de la \w casa|strong="H1004"\w* de servidumbre.   
\p
\v 3 \w No|strong="H3808"\w* \w tendrás|strong="H1961"\w* dioses ajenos \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\p
\v 4 \w No|strong="H3808"\w* te \w harás|strong="H6213"\w* ídolo, \w ni|strong="H3808"\w* \w imagen|strong="H8544"\w* \w alguna|strong="H3605"\w* \w de|strong="H8478"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* está \w arriba|strong="H4605"\w* \w en|strong="H8478"\w* \w el|strong="H3605"\w* \w cielo|strong="H8064"\w*, \w ni|strong="H3808"\w* \w abajo|strong="H8478"\w* \w en|strong="H8478"\w* \w la|strong="H3605"\w* tierra, \w ni|strong="H3808"\w* \w en|strong="H8478"\w* las \w aguas|strong="H4325"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w la|strong="H3605"\w* tierra.  
\v 5 \w No|strong="H3808"\w* \w te|strong="H5921"\w* inclinarás ante \w ellas|strong="H5921"\w*, \w ni|strong="H3808"\w* \w las|strong="H5921"\w* honrarás, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, tu \w Dios|strong="H3068"\w*, soy un \w Dios|strong="H3068"\w* \w celoso|strong="H7067"\w*, \w que|strong="H3588"\w* castigo \w la|strong="H5921"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* padres \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w*, \w hasta|strong="H5921"\w* \w la|strong="H5921"\w* tercera \w y|strong="H3588"\w* cuarta generación \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* \w me|strong="H5921"\w* \w aborrecen|strong="H8130"\w*,  
\v 6 pero que muestro \w misericordia|strong="H2617"\w* \w a|strong="H3068"\w* millares de los que me aman y \w guardan|strong="H8104"\w* mis \w mandamientos|strong="H4687"\w*.   
\p
\v 7 \w No|strong="H3808"\w* \w tomarás|strong="H5375"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* Yahvé, tu \w Dios|strong="H3068"\w*, \w en|strong="H3588"\w* vano,\f + \fr 20:7 \ft O «No harás mal uso del nombre de Yahvé, tu Dios».\f* \w porque|strong="H3588"\w* Yahvé \w no|strong="H3808"\w* dará \w por|strong="H3588"\w* inocente \w al|strong="H5352"\w* \w que|strong="H3588"\w* \w tome|strong="H5375"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w* \w en|strong="H3588"\w* vano.   
\p
\v 8 \w Acuérdate|strong="H2142"\w* del \w día|strong="H3117"\w* de reposo para \w santificarlo|strong="H6942"\w*.  
\v 9 \w Seis|strong="H8337"\w* \w días|strong="H3117"\w* \w trabajarás|strong="H5647"\w* y \w harás|strong="H6213"\w* \w toda|strong="H3605"\w* \w tu|strong="H6213"\w* \w obra|strong="H4399"\w*,  
\v 10 pero \w el|strong="H3605"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* es \w día|strong="H3117"\w* \w de|strong="H1121"\w* reposo para Yahvé, \w tu|strong="H6213"\w* \w Dios|strong="H3068"\w*. \w No|strong="H3808"\w* \w harás|strong="H6213"\w* en \w él|strong="H3605"\w* \w obra|strong="H4399"\w* \w alguna|strong="H3605"\w*, \w ni|strong="H3808"\w* \w tú|strong="H6213"\w*, \w ni|strong="H3808"\w* \w tu|strong="H6213"\w* \w hijo|strong="H1121"\w*, \w ni|strong="H3808"\w* \w tu|strong="H6213"\w* \w hija|strong="H1323"\w*, \w ni|strong="H3808"\w* \w tu|strong="H6213"\w* \w siervo|strong="H5650"\w*, \w ni|strong="H3808"\w* \w tu|strong="H6213"\w* sierva, \w ni|strong="H3808"\w* \w tu|strong="H6213"\w* \w ganado|strong="H1121"\w*, \w ni|strong="H3808"\w* \w el|strong="H3605"\w* \w extranjero|strong="H1616"\w* \w que|strong="H3808"\w* reside dentro \w de|strong="H1121"\w* tus \w puertas|strong="H8179"\w*;  
\v 11 \w porque|strong="H3588"\w* \w en|strong="H5921"\w* \w seis|strong="H8337"\w* \w días|strong="H3117"\w* \w hizo|strong="H6213"\w* Yahvé \w los|strong="H5921"\w* \w cielos|strong="H8064"\w* \w y|strong="H3588"\w* \w la|strong="H5921"\w* tierra, \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* hay, \w y|strong="H3588"\w* \w reposó|strong="H5117"\w* \w el|strong="H5921"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* Yahvé \w bendijo|strong="H1288"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w reposo|strong="H5117"\w* \w y|strong="H3588"\w* \w lo|strong="H5921"\w* \w santificó|strong="H6942"\w*.   
\p
\v 12 \w Honra|strong="H3513"\w* \w a|strong="H3068"\w* tu padre \w y|strong="H5921"\w* \w a|strong="H3068"\w* tu madre, \w para|strong="H4616"\w* \w que|strong="H5921"\w* tus \w días|strong="H3117"\w* \w se|strong="H5921"\w* alarguen \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* Yahvé, tu \w Dios|strong="H3068"\w*, \w te|strong="H5921"\w* \w da|strong="H5414"\w*.   
\p
\v 13 \w No|strong="H3808"\w* \w matarás|strong="H7523"\w*.   
\p
\v 14 \w No|strong="H3808"\w* cometerás adulterio.   
\p
\v 15 \w No|strong="H3808"\w* robarás.   
\p
\v 16 \w No|strong="H3808"\w* darás \w falso|strong="H8267"\w* \w testimonio|strong="H5707"\w* contra tu \w prójimo|strong="H7453"\w*.   
\p
\v 17 \w No|strong="H3808"\w* \w codiciarás|strong="H2530"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de tu \w prójimo|strong="H7453"\w*. \w No|strong="H3808"\w* \w codiciarás|strong="H2530"\w* \w la|strong="H3605"\w* mujer de tu \w prójimo|strong="H7453"\w*, \w ni|strong="H3808"\w* su \w siervo|strong="H5650"\w*, \w ni|strong="H3808"\w* su sierva, \w ni|strong="H3808"\w* su \w buey|strong="H7794"\w*, \w ni|strong="H3808"\w* su \w asno|strong="H2543"\w*, \w ni|strong="H3808"\w* \w nada|strong="H3808"\w* \w que|strong="H3808"\w* sea de tu \w prójimo|strong="H7453"\w*”.   
\p
\v 18 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* percibía \w los|strong="H3605"\w* \w truenos|strong="H6963"\w*, \w los|strong="H3605"\w* relámpagos, \w el|strong="H3605"\w* \w sonido|strong="H6963"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* \w trompeta|strong="H7782"\w* y \w el|strong="H3605"\w* \w monte|strong="H2022"\w* humeante. Al verlo, \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* estremeció y \w se|strong="H5971"\w* mantuvo \w a|strong="H3068"\w* \w distancia|strong="H7350"\w*.  
\v 19 \w Y|strong="H3068"\w* \w dijeron|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Habla|strong="H1696"\w* tú \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*, y \w te|strong="H5973"\w* escucharemos; pero \w que|strong="H6435"\w* \w no|strong="H6435"\w* \w hable|strong="H1696"\w* Dios \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* \w muramos|strong="H4191"\w*.”   
\p
\v 20 \w Moisés|strong="H4872"\w* dijo \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w*: «\w No|strong="H3588"\w* \w temáis|strong="H3372"\w*, \w porque|strong="H3588"\w* Dios ha venido \w para|strong="H5921"\w* poneros \w a|strong="H3068"\w* \w prueba|strong="H5254"\w*, \w y|strong="H3588"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w temor|strong="H3372"\w* \w esté|strong="H1961"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* vosotros, \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w pequéis|strong="H2398"\w*».  
\v 21 \w El|strong="H5066"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* mantuvo \w a|strong="H3068"\w* \w distancia|strong="H7350"\w*, mientras \w Moisés|strong="H4872"\w* \w se|strong="H5971"\w* \w acercó|strong="H5066"\w* \w a|strong="H3068"\w* la densa \w oscuridad|strong="H6205"\w* \w donde|strong="H8033"\w* \w estaba|strong="H5975"\w* Dios.   
\p
\v 22 Yahvé \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Esto|strong="H3541"\w* \w es|strong="H3588"\w* lo \w que|strong="H3588"\w* \w dirás|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*: ‘\w Vosotros|strong="H5973"\w* mismos habéis \w visto|strong="H7200"\w* \w que|strong="H3588"\w* \w yo|strong="H4480"\w* he \w hablado|strong="H1696"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w* \w desde|strong="H4480"\w* \w el|strong="H5973"\w* \w cielo|strong="H8064"\w*.  
\v 23 \w No|strong="H3808"\w* os \w haréis|strong="H6213"\w* dioses de \w plata|strong="H3701"\w* \w ni|strong="H3808"\w* dioses de \w oro|strong="H2091"\w* para ponerlos junto \w a|strong="H3068"\w* mí.  
\v 24 \w Me|strong="H5921"\w* \w harás|strong="H6213"\w* un \w altar|strong="H4196"\w* \w de|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w sacrificarás|strong="H2076"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* tus \w holocaustos|strong="H5930"\w* \w y|strong="H5921"\w* tus ofrendas \w de|strong="H5921"\w* paz, tus \w ovejas|strong="H6629"\w* \w y|strong="H5921"\w* \w tu|strong="H6213"\w* \w ganado|strong="H6629"\w*. \w En|strong="H5921"\w* \w cualquier|strong="H3605"\w* \w lugar|strong="H4725"\w* \w donde|strong="H5921"\w* \w yo|strong="H6213"\w* \w haga|strong="H6213"\w* recordar \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w*, vendré \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w bendeciré|strong="H1288"\w*.  
\v 25 \w Si|strong="H3588"\w* \w me|strong="H5921"\w* \w haces|strong="H6213"\w* un \w altar|strong="H4196"\w* \w de|strong="H5921"\w* piedra, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* construirás \w con|strong="H5921"\w* piedras \w labradas|strong="H1496"\w*; \w porque|strong="H3588"\w* \w si|strong="H3588"\w* alzas \w tu|strong="H6213"\w* herramienta \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w lo|strong="H3808"\w* profanarás.  
\v 26 \w No|strong="H3808"\w* \w subirás|strong="H5927"\w* \w por|strong="H5921"\w* escaleras \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w altar|strong="H4196"\w*, \w para|strong="H5921"\w* \w que|strong="H3808"\w* tu \w desnudez|strong="H6172"\w* \w no|strong="H3808"\w* quede \w descubierta|strong="H1540"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*’”.   
\c 21
\p
\v 1 “Estas son las \w ordenanzas|strong="H4941"\w* que \w pondrás|strong="H7760"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos:   
\p
\v 2 “\w Si|strong="H3588"\w* compras un \w siervo|strong="H5650"\w* \w hebreo|strong="H5680"\w*, \w te|strong="H3588"\w* \w servirá|strong="H5647"\w* \w seis|strong="H8337"\w* \w años|strong="H8141"\w*, \w pero|strong="H3588"\w* al \w séptimo|strong="H7637"\w* \w saldrá|strong="H3318"\w* \w libre|strong="H2670"\w* sin pagar nada.  
\v 3 \w Si|strong="H1931"\w* entra \w solo|strong="H1931"\w*, \w saldrá|strong="H3318"\w* \w solo|strong="H1931"\w*. \w Si|strong="H1931"\w* \w está|strong="H1931"\w* casado, \w su|strong="H1931"\w* mujer \w saldrá|strong="H3318"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w*.  
\v 4 \w Si|strong="H1931"\w* \w su|strong="H1931"\w* amo \w le|strong="H1931"\w* \w da|strong="H5414"\w* una esposa y \w ella|strong="H1931"\w* \w le|strong="H1931"\w* \w da|strong="H5414"\w* \w hijos|strong="H1121"\w* \w o|strong="H3068"\w* \w hijas|strong="H1323"\w*, \w la|strong="H1931"\w* esposa y \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* \w serán|strong="H1961"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* amo, y \w él|strong="H1931"\w* \w saldrá|strong="H3318"\w* \w solo|strong="H1931"\w*.  
\v 5 Pero \w si|strong="H3808"\w* \w el|strong="H1121"\w* \w siervo|strong="H5650"\w* dice claramente: ‘Amo \w a|strong="H3068"\w* mi amo, \w a|strong="H3068"\w* mi mujer y \w a|strong="H3068"\w* mis \w hijos|strong="H1121"\w*; \w no|strong="H3808"\w* \w saldré|strong="H3318"\w* \w libre|strong="H2670"\w*’,  
\v 6 entonces su amo lo llevará ante Dios, y lo acercará \w a|strong="H3068"\w* la \w puerta|strong="H1817"\w* \w o|strong="H3068"\w* al \w poste|strong="H4201"\w* de la \w puerta|strong="H1817"\w*, y su amo le horadará la oreja con un punzón, y le \w servirá|strong="H5647"\w* para \w siempre|strong="H5769"\w*.   
\p
\v 7 “\w Si|strong="H3588"\w* un hombre \w vende|strong="H4376"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hija|strong="H1323"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* sea sierva, ella \w no|strong="H3808"\w* \w saldrá|strong="H3318"\w* libre \w como|strong="H3588"\w* \w salen|strong="H3318"\w* \w los|strong="H3588"\w* \w siervos|strong="H5650"\w* \w varones|strong="H3588"\w*.  
\v 8 \w Si|strong="H3808"\w* \w no|strong="H3808"\w* agrada \w a|strong="H3068"\w* su amo, quien la había tomado \w para|strong="H5971"\w* \w sí|strong="H3808"\w*, entonces él permitirá \w que|strong="H3808"\w* sea rescatada. \w No|strong="H3808"\w* tendrá derecho \w a|strong="H3068"\w* venderla \w a|strong="H3068"\w* un \w pueblo|strong="H5971"\w* \w extranjero|strong="H5237"\w*, ya \w que|strong="H3808"\w* la \w ha|strong="H3808"\w* tratado con engaño.  
\v 9 Si la desposa con su \w hijo|strong="H1121"\w*, la tratará según \w el|strong="H1121"\w* \w derecho|strong="H4941"\w* \w de|strong="H1121"\w* las \w hijas|strong="H1323"\w*.  
\v 10 \w Si|strong="H3808"\w* \w toma|strong="H3947"\w* otra esposa para \w sí|strong="H3808"\w*, \w no|strong="H3808"\w* \w disminuirá|strong="H1639"\w* \w a|strong="H3068"\w* la primera su alimento, su ropa \w ni|strong="H3808"\w* sus derechos conyugales.  
\v 11 \w Si|strong="H3808"\w* \w no|strong="H3808"\w* \w hace|strong="H6213"\w* \w estas|strong="H6213"\w* \w tres|strong="H7969"\w* cosas por ella, entonces ella \w podrá|strong="H3808"\w* \w salir|strong="H3318"\w* libre \w sin|strong="H3808"\w* pagar \w dinero|strong="H3701"\w*.   
\p
\v 12 “El que golpee \w a|strong="H3068"\w* un hombre de modo que \w muera|strong="H4191"\w*, será \w ciertamente|strong="H4191"\w* condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*;  
\v 13 pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w fue|strong="H3808"\w* premeditado, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* Dios permitió \w que|strong="H3808"\w* cayera en sus \w manos|strong="H3027"\w*, entonces te designaré un \w lugar|strong="H4725"\w* al cual \w podrá|strong="H3808"\w* huir.  
\v 14 \w Si|strong="H3588"\w* un hombre actúa \w con|strong="H5973"\w* presunción \w contra|strong="H5921"\w* \w su|strong="H3588"\w* \w prójimo|strong="H7453"\w* \w para|strong="H5921"\w* \w matarlo|strong="H4191"\w* \w con|strong="H5973"\w* alevosía, \w lo|strong="H5921"\w* sacarás incluso \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w altar|strong="H4196"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w muera|strong="H4191"\w*.   
\p
\v 15 “El que golpee \w a|strong="H3068"\w* su padre \w o|strong="H3068"\w* \w a|strong="H3068"\w* su madre será condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*.   
\p
\v 16 “El \w que|strong="H3027"\w* secuestre \w a|strong="H3068"\w* \w una|strong="H4672"\w* persona y la venda, \w o|strong="H3068"\w* si \w es|strong="H3027"\w* hallada en sus \w manos|strong="H3027"\w*, será condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*.   
\p
\v 17 “El que maldiga \w a|strong="H3068"\w* su padre \w o|strong="H3068"\w* \w a|strong="H3068"\w* su madre será condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*.   
\p
\v 18 “\w Si|strong="H3588"\w* unos hombres riñen \w y|strong="H3588"\w* uno golpea al \w otro|strong="H7453"\w* \w con|strong="H3588"\w* una piedra \w o|strong="H3068"\w* \w con|strong="H3588"\w* \w el|strong="H3588"\w* puño, \w y|strong="H3588"\w* este \w no|strong="H3808"\w* muere, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* queda confinado \w en|strong="H3588"\w* \w cama|strong="H4904"\w*;  
\v 19 \w si|strong="H5921"\w* \w se|strong="H5921"\w* levanta \w de|strong="H5921"\w* nuevo \w y|strong="H5921"\w* puede caminar apoyado \w en|strong="H5921"\w* su bastón, entonces \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w lo|strong="H5921"\w* golpeó \w quedará|strong="H6965"\w* \w libre|strong="H5352"\w* \w de|strong="H5921"\w* \w culpa|strong="H5352"\w*; \w solamente|strong="H7535"\w* \w le|strong="H5921"\w* \w pagará|strong="H5414"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* tiempo perdido \w y|strong="H5921"\w* \w se|strong="H5921"\w* encargará \w de|strong="H5921"\w* \w que|strong="H5921"\w* sea curado \w por|strong="H5921"\w* completo.   
\p
\v 20 “\w Si|strong="H3588"\w* un hombre golpea \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w siervo|strong="H5650"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* sierva \w con|strong="H3588"\w* una \w vara|strong="H7626"\w*, \w y|strong="H3588"\w* este muere \w bajo|strong="H8478"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*, \w el|strong="H3588"\w* amo será \w ciertamente|strong="H3588"\w* castigado.  
\v 21 \w Sin|strong="H3808"\w* embargo, \w si|strong="H3588"\w* \w el|strong="H1931"\w* siervo sobrevive uno \w o|strong="H3068"\w* \w dos|strong="H3117"\w* \w días|strong="H3117"\w*, \w no|strong="H3808"\w* \w será|strong="H1931"\w* castigado, \w porque|strong="H3588"\w* \w el|strong="H1931"\w* siervo \w es|strong="H1931"\w* propiedad \w suya|strong="H1931"\w*.   
\p
\v 22 “\w Si|strong="H3588"\w* unos hombres pelean \w y|strong="H3588"\w* golpean \w a|strong="H3068"\w* una mujer embarazada \w de|strong="H5921"\w* modo \w que|strong="H3588"\w* \w dé|strong="H5921"\w* \w a|strong="H3068"\w* luz prematuramente, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* \w produce|strong="H3318"\w* \w ninguna|strong="H3808"\w* desgracia \w mayor|strong="H3588"\w*, \w el|strong="H5921"\w* culpable \w será|strong="H1961"\w* multado \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w le|strong="H5921"\w* imponga \w el|strong="H5921"\w* \w marido|strong="H1167"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* mujer \w y|strong="H3588"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* determinen \w los|strong="H5921"\w* \w jueces|strong="H6414"\w*.  
\v 23 Pero \w si|strong="H1961"\w* \w se|strong="H1961"\w* produce una desgracia, entonces pagarás \w vida|strong="H5315"\w* \w por|strong="H8478"\w* \w vida|strong="H5315"\w*,  
\v 24 \w ojo|strong="H5869"\w* \w por|strong="H8478"\w* \w ojo|strong="H5869"\w*, \w diente|strong="H8127"\w* \w por|strong="H8478"\w* \w diente|strong="H8127"\w*, \w mano|strong="H3027"\w* \w por|strong="H8478"\w* \w mano|strong="H3027"\w*, \w pie|strong="H7272"\w* \w por|strong="H8478"\w* \w pie|strong="H7272"\w*,  
\v 25 \w quemadura|strong="H3555"\w* \w por|strong="H8478"\w* \w quemadura|strong="H3555"\w*, \w herida|strong="H6482"\w* \w por|strong="H8478"\w* \w herida|strong="H6482"\w*, contusión \w por|strong="H8478"\w* contusión.   
\p
\v 26 “\w Si|strong="H3588"\w* un hombre golpea \w el|strong="H3588"\w* \w ojo|strong="H5869"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w siervo|strong="H5650"\w* \w o|strong="H3068"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* sierva \w y|strong="H3588"\w* lo destruye, lo dejará \w ir|strong="H7971"\w* \w libre|strong="H2670"\w* \w a|strong="H3068"\w* cambio \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w ojo|strong="H5869"\w*.  
\v 27 \w Y|strong="H3068"\w* si le hace saltar un \w diente|strong="H8127"\w* \w a|strong="H3068"\w* su \w siervo|strong="H5650"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* su sierva, lo dejará \w ir|strong="H7971"\w* \w libre|strong="H2670"\w* \w a|strong="H3068"\w* cambio \w de|strong="H8478"\w* su \w diente|strong="H8127"\w*.   
\p
\v 28 “\w Si|strong="H3588"\w* un \w buey|strong="H7794"\w* acornea \w a|strong="H3068"\w* un hombre \w o|strong="H3068"\w* \w a|strong="H3068"\w* una mujer \w de|strong="H3588"\w* modo \w que|strong="H3588"\w* \w muera|strong="H4191"\w*, \w el|strong="H3588"\w* \w buey|strong="H7794"\w* \w será|strong="H5619"\w* \w apedreado|strong="H5619"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w carne|strong="H1320"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* comerá; \w pero|strong="H3588"\w* \w el|strong="H3588"\w* \w dueño|strong="H1167"\w* del \w buey|strong="H7794"\w* quedará \w libre|strong="H5355"\w* \w de|strong="H3588"\w* culpa.  
\v 29 Pero \w si|strong="H1571"\w* \w el|strong="H1931"\w* \w buey|strong="H7794"\w* \w tenía|strong="H1931"\w* \w la|strong="H1931"\w* costumbre de acornear en \w el|strong="H1931"\w* pasado, \w y|strong="H1571"\w* \w su|strong="H1931"\w* \w dueño|strong="H1167"\w* había sido advertido pero \w no|strong="H3808"\w* \w lo|strong="H1931"\w* mantuvo encerrado, \w y|strong="H1571"\w* \w el|strong="H1931"\w* \w buey|strong="H7794"\w* \w mata|strong="H4191"\w* \w a|strong="H3068"\w* un hombre \w o|strong="H3068"\w* \w a|strong="H3068"\w* una mujer, \w el|strong="H1931"\w* \w buey|strong="H7794"\w* \w será|strong="H1931"\w* \w apedreado|strong="H5619"\w* \w y|strong="H1571"\w* \w su|strong="H1931"\w* \w dueño|strong="H1167"\w* \w también|strong="H1571"\w* \w será|strong="H1931"\w* condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*.  
\v 30 \w Si|strong="H5921"\w* \w se|strong="H5921"\w* \w le|strong="H5921"\w* impone un \w rescate|strong="H3724"\w*, deberá \w dar|strong="H5414"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w redención|strong="H3724"\w* \w de|strong="H5921"\w* su \w vida|strong="H5315"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w le|strong="H5921"\w* imponga.  
\v 31 \w Ya|strong="H3068"\w* sea \w que|strong="H1121"\w* haya acorneado \w a|strong="H3068"\w* un \w hijo|strong="H1121"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* una \w hija|strong="H1323"\w*, se procederá con \w él|strong="H1121"\w* según \w esta|strong="H2088"\w* misma \w ordenanza|strong="H4941"\w*.  
\v 32 Si el \w buey|strong="H7794"\w* acornea \w a|strong="H3068"\w* un \w siervo|strong="H5650"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* una sierva, el dueño \w pagará|strong="H5414"\w* \w treinta|strong="H7970"\w* \w siclos|strong="H8255"\w*\f + \fr 21:32 \ft Un siclo equivale a unos 10 gramos o a unas 0,35 onzas, por lo que 30 siclos son unos 300 gramos o unas 10,6 onzas.\f* \w de|strong="H5414"\w* \w plata|strong="H3701"\w* al amo \w de|strong="H5414"\w* estos, \w y|strong="H7794"\w* el \w buey|strong="H7794"\w* \w será|strong="H5619"\w* \w apedreado|strong="H5619"\w*.   
\p
\v 33 “\w Si|strong="H3588"\w* un hombre destapa un pozo, \w o|strong="H3068"\w* \w si|strong="H3588"\w* \w cava|strong="H3738"\w* un pozo \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w cubre|strong="H3680"\w*, \w y|strong="H3588"\w* \w cae|strong="H5307"\w* \w en|strong="H3588"\w* \w él|strong="H3588"\w* un \w buey|strong="H7794"\w* \w o|strong="H3068"\w* un \w asno|strong="H2543"\w*,  
\v 34 el \w dueño|strong="H1167"\w* del pozo \w pagará|strong="H7999"\w* el daño. \w Dará|strong="H7999"\w* \w dinero|strong="H3701"\w* \w a|strong="H3068"\w* su \w dueño|strong="H1167"\w*, y el animal \w muerto|strong="H4191"\w* \w será|strong="H1961"\w* suyo.   
\p
\v 35 “\w Si|strong="H3588"\w* \w el|strong="H3588"\w* \w buey|strong="H7794"\w* \w de|strong="H3588"\w* un hombre hiere al \w buey|strong="H7794"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w prójimo|strong="H7453"\w* \w de|strong="H3588"\w* modo \w que|strong="H3588"\w* \w muera|strong="H4191"\w*, \w venderán|strong="H4376"\w* \w el|strong="H3588"\w* \w buey|strong="H7794"\w* \w vivo|strong="H2416"\w* \w y|strong="H1571"\w* se repartirán \w el|strong="H3588"\w* \w dinero|strong="H3701"\w*; \w y|strong="H1571"\w* \w también|strong="H1571"\w* se repartirán \w el|strong="H3588"\w* \w animal|strong="H2416"\w* \w muerto|strong="H4191"\w*.  
\v 36 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w era|strong="H1961"\w* notorio \w que|strong="H3588"\w* \w el|strong="H1931"\w* \w buey|strong="H7794"\w* \w tenía|strong="H1961"\w* \w la|strong="H1931"\w* costumbre \w de|strong="H3588"\w* acornear \w en|strong="H3588"\w* \w el|strong="H1931"\w* pasado \w y|strong="H3588"\w* \w su|strong="H1931"\w* \w dueño|strong="H1167"\w* \w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w había|strong="H1961"\w* mantenido encerrado, \w ciertamente|strong="H3588"\w* \w pagará|strong="H7999"\w* \w buey|strong="H7794"\w* \w por|strong="H3588"\w* \w buey|strong="H7794"\w*, \w y|strong="H3588"\w* \w el|strong="H1931"\w* animal \w muerto|strong="H4191"\w* \w será|strong="H1961"\w* \w suyo|strong="H1931"\w*.   
\c 22
\p
\v 1 “Si un hombre roba un buey \w o|strong="H3068"\w* \w una|strong="H4672"\w* oveja, y lo \w mata|strong="H4191"\w* \w o|strong="H3068"\w* lo vende, restituirá cinco bueyes por el buey, y cuatro ovejas por la oveja.  
\v 2 \w Si|strong="H5921"\w* \w el|strong="H5921"\w* ladrón es sorprendido forzando una casa \w y|strong="H5921"\w* es golpeado \w de|strong="H5921"\w* tal manera \w que|strong="H5921"\w* muere, \w no|strong="H5921"\w* habrá culpa \w de|strong="H5921"\w* \w sangre|strong="H1818"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 3 Pero si el sol ya ha salido sobre él, el \w que|strong="H5704"\w* \w lo|strong="H5704"\w* mató será culpable \w de|strong="H5704"\w* derramamiento \w de|strong="H5704"\w* sangre. El ladrón debe restituir \w por|strong="H5704"\w* completo. Si no tiene \w con|strong="H5704"\w* \w qué|strong="H5704"\w*, será vendido \w por|strong="H5704"\w* su robo.  
\v 4 \w Si|strong="H3588"\w* lo robado, ya sea buey, asno u oveja, \w es|strong="H3588"\w* hallado vivo \w en|strong="H3588"\w* \w su|strong="H3588"\w* poder, \w pagará|strong="H7999"\w* \w el|strong="H3588"\w* doble.   
\p
\v 5 “\w Si|strong="H3588"\w* un hombre hace pastar \w su|strong="H3588"\w* ganado \w en|strong="H3588"\w* un \w campo|strong="H7704"\w* \w o|strong="H3068"\w* \w en|strong="H3588"\w* \w una|strong="H4672"\w* viña \w y|strong="H3588"\w* deja suelto \w a|strong="H3068"\w* \w su|strong="H3588"\w* animal \w para|strong="H3588"\w* \w que|strong="H3588"\w* paste \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w* \w de|strong="H3588"\w* otro, hará restitución \w con|strong="H3588"\w* lo mejor \w de|strong="H3588"\w* \w su|strong="H3588"\w* propio \w campo|strong="H7704"\w* \w y|strong="H3588"\w* \w con|strong="H3588"\w* lo mejor \w de|strong="H3588"\w* \w su|strong="H3588"\w* propia viña.   
\p
\v 6 “\w Si|strong="H3588"\w* se desata un incendio \w y|strong="H3588"\w* se extiende \w a|strong="H3068"\w* \w los|strong="H3588"\w* espinos, \w de|strong="H3588"\w* modo \w que|strong="H3588"\w* consuma \w los|strong="H3588"\w* haces \w de|strong="H3588"\w* trigo, \w el|strong="H3588"\w* grano \w en|strong="H3588"\w* pie \w o|strong="H3068"\w* \w el|strong="H3588"\w* campo, \w el|strong="H3588"\w* \w que|strong="H3588"\w* encendió \w el|strong="H3588"\w* fuego \w hará|strong="H8104"\w* restitución completa.   
\p
\v 7 “\w Si|strong="H3808"\w* un hombre entrega \w a|strong="H3068"\w* su \w prójimo|strong="H7453"\w* dinero \w o|strong="H3068"\w* bienes para \w que|strong="H3808"\w* \w los|strong="H1167"\w* guarde, y \w son|strong="H3808"\w* robados de la \w casa|strong="H1004"\w* de ese hombre, \w si|strong="H3808"\w* el \w ladrón|strong="H1590"\w* \w es|strong="H3027"\w* \w hallado|strong="H4672"\w*, este pagará el doble.  
\v 8 \w Si|strong="H3588"\w* \w no|strong="H3588"\w* \w se|strong="H1931"\w* halla \w al|strong="H5921"\w* ladrón, \w el|strong="H1931"\w* dueño \w de|strong="H5921"\w* \w la|strong="H1931"\w* casa \w será|strong="H1931"\w* llevado ante Dios \w para|strong="H5704"\w* averiguar \w si|strong="H3588"\w* ha \w puesto|strong="H3588"\w* \w su|strong="H1931"\w* \w mano|strong="H1931"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* bienes \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w prójimo|strong="H7453"\w*.  
\v 9 \w En|strong="H3588"\w* \w todo|strong="H3605"\w* caso \w de|strong="H3588"\w* fraude, ya sea \w por|strong="H3588"\w* un \w buey|strong="H7794"\w*, un \w asno|strong="H2543"\w*, una \w oveja|strong="H7716"\w*, ropa, \w o|strong="H3068"\w* \w cualquier|strong="H3605"\w* \w cosa|strong="H3605"\w* perdida \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* alguien diga: ‘Esto \w es|strong="H3588"\w* mío’, \w la|strong="H3588"\w* causa \w de|strong="H3588"\w* ambas partes se llevará ante Dios. \w Aquel|strong="H3605"\w* \w a|strong="H3068"\w* \w quien|strong="H3605"\w* Dios condene, \w pagará|strong="H5414"\w* \w el|strong="H3588"\w* doble \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w prójimo|strong="H7453"\w*.   
\p
\v 10 “\w Si|strong="H3808"\w* un hombre entrega \w a|strong="H3068"\w* su \w prójimo|strong="H7453"\w* un asno, un buey, una oveja \w o|strong="H3068"\w* cualquier \w otro|strong="H7453"\w* animal \w para|strong="H1961"\w* \w que|strong="H3808"\w* \w lo|strong="H3808"\w* guarde, y \w este|strong="H1961"\w* muere, sufre daño \w o|strong="H3068"\w* \w es|strong="H1961"\w* llevado cautivo \w sin|strong="H3808"\w* \w que|strong="H3808"\w* \w nadie|strong="H3808"\w* \w lo|strong="H3808"\w* vea,  
\v 11 \w el|strong="H5973"\w* juramento \w de|strong="H5973"\w* Yahvé estará \w entre|strong="H5973"\w* \w los|strong="H1167"\w* dos, \w de|strong="H5973"\w* que no ha puesto su mano \w en|strong="H5973"\w* \w los|strong="H1167"\w* bienes \w de|strong="H5973"\w* su prójimo; \w el|strong="H5973"\w* \w dueño|strong="H1167"\w* lo aceptará y \w el|strong="H5973"\w* otro no hará restitución.  
\v 12 Pero \w si|strong="H3808"\w* le \w fue|strong="H3808"\w* robado, \w deberá|strong="H7999"\w* hacer restitución \w a|strong="H3068"\w* su dueño.  
\v 13 \w Si|strong="H3588"\w* fue despedazado \w por|strong="H3588"\w* una fiera, \w que|strong="H3588"\w* lo traiga \w como|strong="H3588"\w* prueba, \w y|strong="H3588"\w* \w no|strong="H3588"\w* tendrá \w que|strong="H3588"\w* \w pagar|strong="H7999"\w* \w por|strong="H3588"\w* lo despedazado.   
\p
\v 14 “\w Si|strong="H3808"\w* un hombre pide prestado un animal \w a|strong="H3068"\w* \w su|strong="H1931"\w* prójimo, y sufre daño \w o|strong="H3068"\w* muere \w no|strong="H3808"\w* estando \w su|strong="H1931"\w* \w dueño|strong="H1167"\w* presente, ciertamente \w deberá|strong="H7999"\w* restituirlo.  
\v 15 \w Si|strong="H3588"\w* \w su|strong="H3588"\w* dueño \w estaba|strong="H7901"\w* presente, \w no|strong="H3808"\w* hará restitución. \w Si|strong="H3588"\w* era alquilado, \w el|strong="H5973"\w* precio \w del|strong="H5973"\w* alquiler cubre \w la|strong="H3588"\w* pérdida.   
\p
\v 16 “Si un hombre seduce \w a|strong="H3068"\w* una \w virgen|strong="H1330"\w* que \w no|strong="H3985"\w* está comprometida y se acuesta con ella, \w ciertamente|strong="H5414"\w* \w pagará|strong="H5414"\w* la dote y la tomará \w por|strong="H5414"\w* mujer.  
\v 17 \w Si|strong="H3808"\w* el padre de ella \w se|strong="H3808"\w* niega rotundamente \w a|strong="H3068"\w* dársela, el seductor pagará una cantidad de dinero equivalente \w a|strong="H3068"\w* la dote de las vírgenes.   
\p
\v 18 “No dejarás \w con|strong="H5973"\w* vida \w a|strong="H3068"\w* \w ninguna|strong="H3605"\w* hechicera.   
\p
\v 19 “Cualquiera \w que|strong="H1115"\w* tenga relaciones con un animal, será condenado \w a|strong="H3068"\w* muerte.   
\p
\v 20 “\w El|strong="H3588"\w* \w que|strong="H3588"\w* ofrezca sacrificios \w a|strong="H3068"\w* cualquier dios \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w sea|strong="H1961"\w* solo Yahvé, \w será|strong="H1961"\w* destruido \w por|strong="H3588"\w* completo.   
\p
\v 21 “\w No|strong="H3808"\w* maltratarás al extranjero \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* oprimirás, \w porque|strong="H3808"\w* vosotros fuisteis extranjeros en \w la|strong="H3605"\w* tierra de Egipto.   
\p
\v 22 “\w No|strong="H3588"\w* \w afligiréis|strong="H6031"\w* \w a|strong="H3068"\w* ninguna viuda ni al huérfano.  
\v 23 \w Si|strong="H1961"\w* llegáis \w a|strong="H3068"\w* afligirlos, y ellos claman \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, ciertamente escucharé su clamor;  
\v 24 \w y|strong="H5921"\w* \w mi|strong="H5921"\w* ira \w se|strong="H1961"\w* encenderá, \w y|strong="H5921"\w* \w os|strong="H5921"\w* mataré \w a|strong="H3068"\w* espada; vuestras mujeres quedarán viudas, \w y|strong="H5921"\w* vuestros hijos huérfanos.   
\p
\v 25 “Si prestas dinero \w a|strong="H3068"\w* alguno \w de|strong="H5704"\w* mi pueblo, \w al|strong="H5704"\w* pobre \w que|strong="H5704"\w* está contigo, no te portarás \w con|strong="H5704"\w* él \w como|strong="H5704"\w* un usurero, \w ni|strong="H5704"\w* le cobrarás intereses.  
\v 26 \w Si|strong="H3588"\w* tomas \w en|strong="H3588"\w* prenda \w el|strong="H1931"\w* manto \w de|strong="H3588"\w* tu prójimo, \w se|strong="H1961"\w* \w lo|strong="H1931"\w* devolverás \w antes|strong="H3588"\w* \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* ponga \w el|strong="H1931"\w* sol,  
\v 27 \w porque|strong="H3808"\w* es su única cobertura; es el vestido \w para|strong="H5971"\w* su cuerpo. ¿Con \w qué|strong="H3808"\w*, \w si|strong="H3808"\w* \w no|strong="H3808"\w*, \w va|strong="H3068"\w* \w a|strong="H3068"\w* dormir? \w Y|strong="H3068"\w* sucederá \w que|strong="H3808"\w* cuando clame \w a|strong="H3068"\w* mí, yo \w lo|strong="H3808"\w* escucharé, \w porque|strong="H3808"\w* soy misericordioso.   
\p
\v 28 “\w No|strong="H3808"\w* injuriarás \w a|strong="H3068"\w* Dios, \w ni|strong="H3808"\w* maldecirás al gobernante \w de|strong="H1121"\w* tu pueblo.   
\p
\v 29 “\w No|strong="H6213"\w* demorarás \w en|strong="H5973"\w* ofrecer \w de|strong="H5973"\w* la abundancia \w de|strong="H5973"\w* \w tu|strong="H6213"\w* cosecha \w y|strong="H7794"\w* \w de|strong="H5973"\w* tus lagares.  
\p “\w Me|strong="H5973"\w* \w darás|strong="H5414"\w* \w el|strong="H5973"\w* primogénito \w de|strong="H5973"\w* tus hijos.  
\v 30 \w Lo|strong="H3808"\w* mismo harás con el de tus vacas y tus ovejas. Siete días \w estará|strong="H1961"\w* con su madre, y al octavo día me \w lo|strong="H3808"\w* darás.   
\p
\v 31 “Seréis hombres santos para mí. Por tanto, no comeréis ninguna carne de animal despedazado por las fieras en el campo; se la echaréis \w a|strong="H3068"\w* los perros.   
\c 23
\p
\v 1 “\w No|strong="H3808"\w* propagarás \w falsos|strong="H2555"\w* rumores. \w No|strong="H3808"\w* unas tu \w mano|strong="H3027"\w* \w con|strong="H5973"\w* la \w del|strong="H5973"\w* \w impío|strong="H7563"\w* \w para|strong="H1961"\w* ser \w testigo|strong="H5707"\w* \w falso|strong="H2555"\w*.   
\p
\v 2 “\w No|strong="H3808"\w* \w seguirás|strong="H1961"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* mayoría \w para|strong="H5921"\w* hacer \w el|strong="H5921"\w* \w mal|strong="H7451"\w*; \w ni|strong="H3808"\w* testificarás \w en|strong="H5921"\w* un \w pleito|strong="H7379"\w* inclinándote \w a|strong="H3068"\w* \w la|strong="H5921"\w* mayoría \w para|strong="H5921"\w* pervertir \w la|strong="H5921"\w* justicia.  
\v 3 \w Tampoco|strong="H3808"\w* favorecerás al \w pobre|strong="H1800"\w* en su \w pleito|strong="H7379"\w*.   
\p
\v 4 “\w Si|strong="H3588"\w* encuentras \w el|strong="H3588"\w* \w buey|strong="H7794"\w* \w de|strong="H3588"\w* tu enemigo \w o|strong="H3068"\w* \w su|strong="H3588"\w* \w asno|strong="H2543"\w* \w extraviado|strong="H8582"\w*, \w ciertamente|strong="H3588"\w* se lo devolverás.  
\v 5 \w Si|strong="H3588"\w* \w ves|strong="H7200"\w* \w caído|strong="H7257"\w* \w bajo|strong="H8478"\w* \w su|strong="H3588"\w* \w carga|strong="H4853"\w* \w el|strong="H5973"\w* \w asno|strong="H2543"\w* \w del|strong="H5973"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* \w aborrece|strong="H8130"\w*, \w no|strong="H3588"\w* lo \w dejarás|strong="H5800"\w* abandonado; sin \w falta|strong="H2308"\w* \w le|strong="H5973"\w* \w ayudarás|strong="H5800"\w* \w a|strong="H3068"\w* levantarlo.   
\p
\v 6 “\w No|strong="H3808"\w* \w pervertirás|strong="H5186"\w* el \w derecho|strong="H4941"\w* de tu pobre en su \w pleito|strong="H7379"\w*.   
\p
\v 7 “\w Te|strong="H3588"\w* \w alejarás|strong="H7368"\w* \w de|strong="H3588"\w* toda acusación \w falsa|strong="H8267"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w matarás|strong="H2026"\w* al \w inocente|strong="H5355"\w* \w ni|strong="H3808"\w* al \w justo|strong="H6662"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w no|strong="H3808"\w* \w justificaré|strong="H6663"\w* al malvado.   
\p
\v 8 “\w No|strong="H3808"\w* aceptarás \w soborno|strong="H7810"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w soborno|strong="H7810"\w* \w ciega|strong="H5786"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* ven \w con|strong="H3588"\w* claridad \w y|strong="H3588"\w* pervierte las \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w justos|strong="H6662"\w*.   
\p
\v 9 “\w No|strong="H3808"\w* oprimirás al \w extranjero|strong="H1616"\w*, \w pues|strong="H3588"\w* vosotros \w conocéis|strong="H3045"\w* \w los|strong="H1961"\w* sentimientos del \w extranjero|strong="H1616"\w*, ya \w que|strong="H3588"\w* \w fuisteis|strong="H1961"\w* \w extranjeros|strong="H1616"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 10 “Durante \w seis|strong="H8337"\w* \w años|strong="H8141"\w* \w sembrarás|strong="H2232"\w* tu tierra y recogerás sus \w frutos|strong="H8393"\w*,  
\v 11 pero \w el|strong="H6213"\w* \w séptimo|strong="H7637"\w* año la dejarás descansar y en barbecho, \w para|strong="H5971"\w* \w que|strong="H5971"\w* coman los pobres \w de|strong="H5971"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w*; y \w lo|strong="H6213"\w* \w que|strong="H5971"\w* ellos dejen, \w lo|strong="H6213"\w* comerán las \w bestias|strong="H2416"\w* del \w campo|strong="H7704"\w*. \w Lo|strong="H6213"\w* mismo \w harás|strong="H6213"\w* con \w tu|strong="H6213"\w* \w viña|strong="H3754"\w* y con \w tu|strong="H6213"\w* olivar.   
\p
\v 12 “\w Seis|strong="H8337"\w* \w días|strong="H3117"\w* \w harás|strong="H6213"\w* \w tu|strong="H6213"\w* trabajo, \w y|strong="H7794"\w* \w el|strong="H1121"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* descansarás, \w para|strong="H4616"\w* \w que|strong="H3117"\w* descansen \w tu|strong="H6213"\w* \w buey|strong="H7794"\w* \w y|strong="H7794"\w* \w tu|strong="H6213"\w* \w asno|strong="H2543"\w*, \w y|strong="H7794"\w* \w para|strong="H4616"\w* \w que|strong="H3117"\w* se repongan \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w tu|strong="H6213"\w* sierva \w y|strong="H7794"\w* \w el|strong="H1121"\w* \w extranjero|strong="H1616"\w*.   
\p
\v 13 “Poned atención \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w os|strong="H5921"\w* he \w dicho|strong="H6310"\w*. \w No|strong="H3808"\w* invocaréis \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* otros dioses, \w ni|strong="H3808"\w* \w se|strong="H5921"\w* \w oirá|strong="H8085"\w* \w de|strong="H5921"\w* vuestra \w boca|strong="H6310"\w*.   
\p
\v 14 “\w Tres|strong="H7969"\w* \w veces|strong="H7272"\w* al \w año|strong="H8141"\w* me celebraréis fiesta.  
\v 15 Celebrarás \w la|strong="H3588"\w* \w fiesta|strong="H2282"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* panes \w sin|strong="H3808"\w* levadura. \w Siete|strong="H7651"\w* \w días|strong="H3117"\w* comeréis panes \w sin|strong="H3808"\w* levadura, \w como|strong="H3588"\w* \w te|strong="H3588"\w* he \w mandado|strong="H6680"\w*, \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w tiempo|strong="H3117"\w* \w señalado|strong="H4150"\w* del \w mes|strong="H2320"\w* \w de|strong="H3588"\w* Abib, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w él|strong="H3588"\w* \w salisteis|strong="H3318"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*; \w y|strong="H3588"\w* \w nadie|strong="H3808"\w* \w se|strong="H3808"\w* presentará \w ante|strong="H6440"\w* mí \w con|strong="H3588"\w* las manos \w vacías|strong="H7387"\w*.  
\v 16 \w También|strong="H3318"\w* la \w fiesta|strong="H2282"\w* \w de|strong="H4480"\w* la siega, \w de|strong="H4480"\w* las primicias \w de|strong="H4480"\w* tus labores, \w de|strong="H4480"\w* lo \w que|strong="H4480"\w* hayas \w sembrado|strong="H2232"\w* \w en|strong="H4480"\w* el \w campo|strong="H7704"\w*; y la \w fiesta|strong="H2282"\w* \w de|strong="H4480"\w* la recolección \w al|strong="H4480"\w* final \w del|strong="H4480"\w* \w año|strong="H8141"\w*, cuando recojas \w del|strong="H4480"\w* \w campo|strong="H7704"\w* el fruto \w de|strong="H4480"\w* tu trabajo.  
\v 17 \w Tres|strong="H7969"\w* \w veces|strong="H6471"\w* al \w año|strong="H8141"\w* se presentarán \w todos|strong="H3605"\w* tus varones \w ante|strong="H6440"\w* Yahvé, \w el|strong="H3605"\w* \w Señor|strong="H3068"\w*.   
\p
\v 18 “\w No|strong="H3808"\w* \w ofrecerás|strong="H2076"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w con|strong="H5921"\w* pan \w leudado|strong="H2557"\w*, \w ni|strong="H3808"\w* \w la|strong="H5921"\w* grasa \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w fiesta|strong="H2282"\w* quedará \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w*.   
\p
\v 19 “Llevarás las \w primicias|strong="H7225"\w* de los primeros frutos de tu tierra \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de Yahvé, tu \w Dios|strong="H3068"\w*.  
\p “\w No|strong="H3808"\w* \w cocerás|strong="H1310"\w* \w el|strong="H1310"\w* \w cabrito|strong="H1423"\w* en la \w leche|strong="H2461"\w* de su madre.   
\p
\v 20 “He \w aquí|strong="H2009"\w*, \w yo|strong="H2009"\w* \w envío|strong="H7971"\w* un \w ángel|strong="H4397"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti para que te \w guarde|strong="H8104"\w* en el \w camino|strong="H1870"\w* y te lleve al \w lugar|strong="H4725"\w* que he preparado.  
\v 21 Presta atención \w a|strong="H3068"\w* \w él|strong="H3588"\w* \w y|strong="H3588"\w* \w escucha|strong="H8085"\w* \w su|strong="H3588"\w* \w voz|strong="H6963"\w*. \w No|strong="H3808"\w* seas rebelde \w contra|strong="H6440"\w* \w él|strong="H3588"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w perdonará|strong="H5375"\w* vuestra transgresión, \w pues|strong="H3588"\w* \w mi|strong="H5375"\w* \w nombre|strong="H8034"\w* está \w en|strong="H3588"\w* \w él|strong="H3588"\w*.  
\v 22 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w en|strong="H3588"\w* verdad escuchas \w su|strong="H3588"\w* \w voz|strong="H6963"\w* \w y|strong="H3588"\w* \w haces|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* digo, seré \w enemigo|strong="H6887"\w* \w de|strong="H3588"\w* tus enemigos \w y|strong="H3588"\w* adversario \w de|strong="H3588"\w* tus adversarios.  
\v 23 \w Porque|strong="H3588"\w* mi \w ángel|strong="H4397"\w* \w irá|strong="H3212"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti \w y|strong="H3588"\w* \w te|strong="H3588"\w* introducirá \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra del amorreo, del hitita, del ferezeo, del \w cananeo|strong="H3669"\w*, del \w heveo|strong="H2340"\w* \w y|strong="H3588"\w* del \w jebuseo|strong="H2983"\w*; \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w los|strong="H3588"\w* destruiré.  
\v 24 \w No|strong="H3808"\w* \w te|strong="H3588"\w* inclinarás ante sus dioses, \w ni|strong="H3808"\w* \w los|strong="H3588"\w* \w servirás|strong="H5647"\w*, \w ni|strong="H3808"\w* \w harás|strong="H6213"\w* conforme \w a|strong="H3068"\w* sus \w obras|strong="H4639"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w los|strong="H3588"\w* destruirás \w por|strong="H3588"\w* completo \w y|strong="H3588"\w* \w harás|strong="H6213"\w* pedazos sus pilares sagrados.  
\v 25 \w Serviréis|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*, y él \w bendecirá|strong="H1288"\w* vuestro \w pan|strong="H3899"\w* y vuestra \w agua|strong="H4325"\w*; y yo \w quitaré|strong="H5493"\w* la \w enfermedad|strong="H4245"\w* \w de|strong="H4325"\w* \w en|strong="H5493"\w* \w medio|strong="H7130"\w* \w de|strong="H4325"\w* vosotros.  
\v 26 \w No|strong="H3808"\w* \w habrá|strong="H1961"\w* mujer \w que|strong="H3808"\w* aborte \w ni|strong="H3808"\w* \w que|strong="H3808"\w* \w sea|strong="H1961"\w* estéril en tu tierra. Yo completaré el \w número|strong="H4557"\w* de tus \w días|strong="H3117"\w*.  
\v 27 \w Enviaré|strong="H7971"\w* mi terror \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti y llenaré \w de|strong="H6440"\w* confusión \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* adonde llegues, y \w haré|strong="H5414"\w* \w que|strong="H5971"\w* \w todos|strong="H3605"\w* tus enemigos huyan \w ante|strong="H6440"\w* ti.  
\v 28 \w Enviaré|strong="H7971"\w* avispas \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, \w que|strong="H2340"\w* expulsarán al \w heveo|strong="H2340"\w*, al \w cananeo|strong="H3669"\w* y al hitita \w de|strong="H6440"\w* tu \w presencia|strong="H6440"\w*.  
\v 29 \w No|strong="H3808"\w* \w los|strong="H5921"\w* expulsaré \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w en|strong="H5921"\w* un solo \w año|strong="H8141"\w*, \w no|strong="H3808"\w* \w sea|strong="H1961"\w* \w que|strong="H3808"\w* \w la|strong="H5921"\w* tierra \w quede|strong="H1961"\w* \w desolada|strong="H8077"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* fieras \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w se|strong="H1961"\w* multipliquen \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*.  
\v 30 \w Poco|strong="H4592"\w* \w a|strong="H3068"\w* \w poco|strong="H4592"\w* los expulsaré \w de|strong="H6440"\w* tu \w presencia|strong="H6440"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* te hayas multiplicado \w y|strong="H5704"\w* tomes posesión \w de|strong="H6440"\w* la tierra.  
\v 31 Fijaré tus fronteras \w desde|strong="H5704"\w* \w el|strong="H3588"\w* \w Mar|strong="H3220"\w* Rojo \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w mar|strong="H3220"\w* \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w*, \w y|strong="H3588"\w* \w desde|strong="H5704"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w* \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w río|strong="H5104"\w* Éufrates; \w porque|strong="H3588"\w* \w entregaré|strong="H5414"\w* \w en|strong="H5704"\w* vuestras \w manos|strong="H3027"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w y|strong="H3588"\w* tú \w los|strong="H3427"\w* echarás \w de|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti.  
\v 32 \w No|strong="H3808"\w* \w harás|strong="H3772"\w* \w pacto|strong="H1285"\w* alguno con ellos \w ni|strong="H3808"\w* con sus dioses.  
\v 33 \w No|strong="H3808"\w* \w habitarán|strong="H3427"\w* \w en|strong="H3588"\w* tu tierra, \w no|strong="H3808"\w* \w sea|strong="H1961"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* hagan \w pecar|strong="H2398"\w* \w contra|strong="H1961"\w* \w mí|strong="H1961"\w*; \w porque|strong="H3588"\w* \w si|strong="H3588"\w* sirves \w a|strong="H3068"\w* sus dioses, \w ciertamente|strong="H3588"\w* esto \w será|strong="H1961"\w* un \w lazo|strong="H4170"\w* \w para|strong="H3588"\w* ti.”   
\c 24
\p
\v 1 \w Y|strong="H3068"\w* dijo \w Dios|strong="H3068"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «\w Sube|strong="H5927"\w* ante Yahvé, tú, junto con Aarón, \w Nadab|strong="H5070"\w*, Abiú y \w setenta|strong="H7657"\w* de los \w ancianos|strong="H2205"\w* de \w Israel|strong="H3478"\w*; y \w adoraréis|strong="H7812"\w* desde \w lejos|strong="H7350"\w*.  
\v 2 Solo \w Moisés|strong="H4872"\w* \w se|strong="H3808"\w* acercará \w a|strong="H3068"\w* Yahvé; \w los|strong="H1992"\w* demás \w no|strong="H3808"\w* \w se|strong="H3808"\w* acercarán, \w ni|strong="H3808"\w* \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w* \w subirá|strong="H5927"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*».   
\p
\v 3 \w Moisés|strong="H4872"\w* vino y refirió al \w pueblo|strong="H5971"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w de|strong="H5971"\w* Yahvé y \w todas|strong="H3605"\w* las \w ordenanzas|strong="H4941"\w*. \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* una sola \w voz|strong="H6963"\w*, \w diciendo|strong="H1696"\w*: «Pondremos en práctica \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w que|strong="H5971"\w* Yahvé ha \w dicho|strong="H1697"\w*».   
\p
\v 4 \w Moisés|strong="H4872"\w* \w escribió|strong="H3789"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w de|strong="H8478"\w* Yahvé. Se levantó muy \w de|strong="H8478"\w* \w mañana|strong="H1242"\w* y construyó un \w altar|strong="H4196"\w* \w al|strong="H8478"\w* \w pie|strong="H8478"\w* \w del|strong="H4196"\w* \w monte|strong="H2022"\w*, y levantó \w doce|strong="H8147"\w* pilares \w por|strong="H8478"\w* las \w doce|strong="H8147"\w* \w tribus|strong="H7626"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w*.  
\v 5 \w Luego|strong="H5927"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* unos jóvenes \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w los|strong="H1121"\w* cuales ofrecieron \w holocaustos|strong="H5930"\w* y \w sacrificaron|strong="H2076"\w* \w novillos|strong="H6499"\w* como ofrendas \w de|strong="H1121"\w* paz \w a|strong="H3068"\w* Yahvé.  
\v 6 \w Moisés|strong="H4872"\w* \w tomó|strong="H3947"\w* \w la|strong="H5921"\w* mitad \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* echó \w en|strong="H5921"\w* vasijas, \w y|strong="H5921"\w* \w la|strong="H5921"\w* otra mitad \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w la|strong="H5921"\w* roció \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 7 \w Tomó|strong="H3947"\w* \w el|strong="H3605"\w* \w libro|strong="H5612"\w* del \w pacto|strong="H1285"\w* y \w lo|strong="H5612"\w* \w leyó|strong="H7121"\w* \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* del \w pueblo|strong="H5971"\w*, y \w ellos|strong="H3605"\w* \w dijeron|strong="H1696"\w*: «\w Haremos|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H5612"\w* \w que|strong="H5971"\w* Yahvé ha \w dicho|strong="H1696"\w* y seremos \w obedientes|strong="H8085"\w*».   
\p
\v 8 Entonces \w Moisés|strong="H4872"\w* \w tomó|strong="H3947"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w*, \w la|strong="H5921"\w* roció \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w y|strong="H5921"\w* dijo: “\w Mirad|strong="H2009"\w*, \w esta|strong="H5921"\w* \w es|strong="H1697"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w del|strong="H5921"\w* \w pacto|strong="H1285"\w* \w que|strong="H5921"\w* Yahvé ha \w hecho|strong="H3772"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w* \w según|strong="H5921"\w* \w todas|strong="H3605"\w* estas \w palabras|strong="H1697"\w*.”   
\p
\v 9 \w Luego|strong="H5927"\w* \w subieron|strong="H5927"\w* \w Moisés|strong="H4872"\w*, Aarón, \w Nadab|strong="H5070"\w*, Abiú y \w setenta|strong="H7657"\w* de los \w ancianos|strong="H2205"\w* de \w Israel|strong="H3478"\w*.  
\v 10 \w Y|strong="H3068"\w* \w vieron|strong="H7200"\w* \w al|strong="H8478"\w* Dios \w de|strong="H8478"\w* \w Israel|strong="H3478"\w*. \w Bajo|strong="H8478"\w* sus \w pies|strong="H7272"\w* había \w como|strong="H7272"\w* un pavimento \w de|strong="H8478"\w* piedra \w de|strong="H8478"\w* zafiro,\f + \fr 24:10 \ft O lapislázuli.\f* tan claro \w como|strong="H7272"\w* el \w mismo|strong="H6106"\w* \w cielo|strong="H8064"\w*.  
\v 11 Pero \w él|strong="H1121"\w* \w no|strong="H3808"\w* \w extendió|strong="H7971"\w* su \w mano|strong="H3027"\w* \w contra|strong="H3478"\w* \w los|strong="H1121"\w* líderes \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*; \w ellos|strong="H3027"\w* \w vieron|strong="H2372"\w* \w a|strong="H3068"\w* Dios, y comieron y \w bebieron|strong="H8354"\w*.   
\p
\v 12 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “\w Sube|strong="H5927"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* al \w monte|strong="H2022"\w* y quédate \w allí|strong="H8033"\w*, y te \w daré|strong="H5414"\w* las \w tablas|strong="H3871"\w* \w de|strong="H5414"\w* piedra con la \w ley|strong="H8451"\w* y \w los|strong="H1961"\w* \w mandamientos|strong="H4687"\w* \w que|strong="H1961"\w* he \w escrito|strong="H3789"\w*, \w para|strong="H5414"\w* \w que|strong="H1961"\w* les enseñes.”   
\p
\v 13 \w Moisés|strong="H4872"\w* se \w levantó|strong="H6965"\w* junto con \w Josué|strong="H3091"\w*, su ayudante, y \w Moisés|strong="H4872"\w* \w subió|strong="H5927"\w* al \w monte|strong="H2022"\w* de Dios.  
\v 14 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w*: «\w Esperadnos|strong="H3427"\w* \w aquí|strong="H2009"\w*, \w hasta|strong="H5704"\w* \w que|strong="H4310"\w* \w volvamos|strong="H7725"\w* \w a|strong="H3068"\w* \w vosotros|strong="H5973"\w*. He \w aquí|strong="H2009"\w*, Aarón \w y|strong="H5704"\w* \w Hur|strong="H2354"\w* \w están|strong="H3427"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*. \w El|strong="H5973"\w* \w que|strong="H4310"\w* tenga algún pleito, \w que|strong="H4310"\w* acuda \w a|strong="H3068"\w* ellos».   
\p
\v 15 \w Moisés|strong="H4872"\w* \w subió|strong="H5927"\w* al \w monte|strong="H2022"\w*, y la \w nube|strong="H6051"\w* \w cubrió|strong="H3680"\w* el \w monte|strong="H2022"\w*.  
\v 16 \w La|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* Yahvé \w reposó|strong="H7931"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w nube|strong="H6051"\w* \w lo|strong="H5921"\w* \w cubrió|strong="H3680"\w* durante \w seis|strong="H8337"\w* \w días|strong="H3117"\w*. \w Al|strong="H5921"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w él|strong="H5921"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w desde|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w nube|strong="H6051"\w*.  
\v 17 \w A|strong="H3068"\w* \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, la \w apariencia|strong="H5869"\w* \w de|strong="H1121"\w* la \w gloria|strong="H3519"\w* \w de|strong="H1121"\w* Yahvé \w era|strong="H1121"\w* como un fuego consumidor en la \w cumbre|strong="H7218"\w* del \w monte|strong="H2022"\w*.  
\v 18 \w Moisés|strong="H4872"\w* entró \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de la \w nube|strong="H6051"\w* y \w subió|strong="H5927"\w* al \w monte|strong="H2022"\w*; y \w Moisés|strong="H4872"\w* \w estuvo|strong="H1961"\w* \w en|strong="H8432"\w* el \w monte|strong="H2022"\w* cuarenta \w días|strong="H3117"\w* y cuarenta \w noches|strong="H3915"\w*.   
\c 25
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Di|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* recojan una \w ofrenda|strong="H8641"\w* para mí. \w De|strong="H1121"\w* \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* cuyo \w corazón|strong="H3820"\w* le mueva \w a|strong="H3068"\w* darla, \w tomaréis|strong="H3947"\w* mi \w ofrenda|strong="H8641"\w*.  
\v 3 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w ofrenda|strong="H8641"\w* que \w tomaréis|strong="H3947"\w* de ellos: \w oro|strong="H2091"\w*, \w plata|strong="H3701"\w*, bronce,  
\v 4 hilo azul, púrpura, escarlata, lino fino, pelo de \w cabra|strong="H5795"\w*,  
\v 5 pieles de carnero teñidas de rojo, pieles de tejón,\f + \fr 25:5 \ft Un codo es la longitud desde la punta del dedo medio hasta el codo del brazo de un hombre, es decir, unos 46 centímetros o 18 pulgadas.\f* \w madera|strong="H6086"\w* de acacia,  
\v 6 \w aceite|strong="H8081"\w* para el alumbrado, \w especias|strong="H1314"\w* para el \w aceite|strong="H8081"\w* de la \w unción|strong="H4888"\w* y para el incienso \w aromático|strong="H5561"\w*,  
\v 7 piedras de ónice, y piedras de engaste para el efod y para el pectoral.  
\v 8 Que me \w hagan|strong="H6213"\w* un \w santuario|strong="H4720"\w*, para que \w yo|strong="H6213"\w* habite \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ellos.  
\v 9 \w Lo|strong="H6213"\w* \w haréis|strong="H6213"\w* exactamente conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w yo|strong="H6213"\w* te muestre: \w el|strong="H3605"\w* diseño del \w tabernáculo|strong="H4908"\w* y \w el|strong="H3605"\w* diseño de \w todo|strong="H3605"\w* su mobiliario.   
\p
\v 10 “\w Harán|strong="H6213"\w* un arca de \w madera|strong="H6086"\w* de acacia. Su longitud \w será|strong="H6213"\w* de dos codos y \w medio|strong="H2677"\w*, su \w anchura|strong="H7341"\w* de un codo y \w medio|strong="H2677"\w*, y su \w altura|strong="H6967"\w* de un codo y \w medio|strong="H2677"\w*.  
\v 11 \w La|strong="H5921"\w* recubrirás \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*; \w por|strong="H5921"\w* \w dentro|strong="H5921"\w* \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w fuera|strong="H2351"\w* \w la|strong="H5921"\w* recubrirás, \w y|strong="H5921"\w* \w harás|strong="H6213"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* una moldura \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w alrededor|strong="H5439"\w*.  
\v 12 Fundirás \w para|strong="H5921"\w* \w ella|strong="H5921"\w* cuatro argollas \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w pondrás|strong="H5414"\w* \w en|strong="H5921"\w* sus cuatro patas: \w dos|strong="H8147"\w* argollas \w a|strong="H3068"\w* un \w lado|strong="H6763"\w*, \w y|strong="H5921"\w* \w dos|strong="H8147"\w* argollas \w al|strong="H5921"\w* \w otro|strong="H8145"\w* \w lado|strong="H6763"\w*.  
\v 13 \w Harás|strong="H6213"\w* unas varas de \w madera|strong="H6086"\w* de acacia y las recubrirás de \w oro|strong="H2091"\w*.  
\v 14 Pasarás \w las|strong="H5921"\w* varas \w por|strong="H5921"\w* \w las|strong="H5921"\w* argollas \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w lados|strong="H6763"\w* \w del|strong="H5921"\w* arca, \w para|strong="H5921"\w* transportarla \w con|strong="H5921"\w* \w ellas|strong="H5921"\w*.  
\v 15 Las varas permanecerán \w en|strong="H4480"\w* las argollas \w del|strong="H4480"\w* arca; \w no|strong="H3808"\w* \w se|strong="H1961"\w* quitarán \w de|strong="H4480"\w* \w ella|strong="H4480"\w*.  
\v 16 \w Y|strong="H3068"\w* \w pondrás|strong="H5414"\w* en el arca el \w Testimonio|strong="H5715"\w* que yo te \w daré|strong="H5414"\w*.  
\v 17 \w Harás|strong="H6213"\w* un propiciatorio de \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*. Su longitud \w será|strong="H6213"\w* de dos codos y \w medio|strong="H2677"\w*, y su \w anchura|strong="H7341"\w* de un codo y \w medio|strong="H2677"\w*.  
\v 18 \w Harás|strong="H6213"\w* \w dos|strong="H8147"\w* \w querubines|strong="H3742"\w* de \w oro|strong="H2091"\w* \w labrado|strong="H4749"\w* \w a|strong="H3068"\w* martillo; los \w harás|strong="H6213"\w* en los \w dos|strong="H8147"\w* extremos del propiciatorio.  
\v 19 \w Haz|strong="H6213"\w* un \w querubín|strong="H3742"\w* \w en|strong="H5921"\w* un extremo \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w otro|strong="H2088"\w* \w querubín|strong="H3742"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w otro|strong="H2088"\w* extremo. \w Harás|strong="H6213"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w* \w de|strong="H4480"\w* una sola pieza \w con|strong="H5921"\w* \w el|strong="H5921"\w* propiciatorio, \w en|strong="H5921"\w* sus \w dos|strong="H8147"\w* extremos.  
\v 20 \w Los|strong="H5921"\w* \w querubines|strong="H3742"\w* \w extenderán|strong="H6566"\w* sus \w alas|strong="H3671"\w* \w hacia|strong="H5921"\w* \w arriba|strong="H4605"\w*, \w cubriendo|strong="H5526"\w* \w el|strong="H5921"\w* propiciatorio \w con|strong="H5921"\w* sus \w alas|strong="H3671"\w*, \w con|strong="H5921"\w* sus \w rostros|strong="H6440"\w* \w el|strong="H5921"\w* uno frente \w al|strong="H5921"\w* otro. \w Los|strong="H5921"\w* \w rostros|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w* \w estarán|strong="H1961"\w* inclinados \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* propiciatorio.  
\v 21 \w Pondrás|strong="H5414"\w* \w el|strong="H5921"\w* propiciatorio \w encima|strong="H4605"\w* \w del|strong="H5921"\w* arca, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* arca \w pondrás|strong="H5414"\w* \w el|strong="H5921"\w* \w Testimonio|strong="H5715"\w* \w que|strong="H5921"\w* yo \w te|strong="H5921"\w* \w daré|strong="H5414"\w*.  
\v 22 \w Allí|strong="H8033"\w* \w me|strong="H5921"\w* encontraré \w contigo|strong="H5921"\w*, \w y|strong="H5921"\w* \w desde|strong="H5921"\w* \w encima|strong="H5921"\w* \w del|strong="H5921"\w* propiciatorio, \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w los|strong="H1121"\w* \w dos|strong="H8147"\w* \w querubines|strong="H3742"\w* \w que|strong="H5921"\w* están \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* arca \w del|strong="H5921"\w* \w Testimonio|strong="H5715"\w*, \w te|strong="H5921"\w* comunicaré \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* \w mande|strong="H6680"\w* \w para|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 23 “\w Harás|strong="H6213"\w* \w también|strong="H7979"\w* una \w mesa|strong="H7979"\w* de \w madera|strong="H6086"\w* de acacia. Su longitud \w será|strong="H6213"\w* de dos codos, su \w anchura|strong="H7341"\w* de un codo y su \w altura|strong="H6967"\w* de un codo y \w medio|strong="H2677"\w*.  
\v 24 La recubrirás de \w oro|strong="H2091"\w* \w puro|strong="H2889"\w* y le \w harás|strong="H6213"\w* una moldura de \w oro|strong="H2091"\w* \w alrededor|strong="H5439"\w*.  
\v 25 Le \w harás|strong="H6213"\w* un reborde de un \w palmo|strong="H2948"\w* de ancho en su \w derredor|strong="H5439"\w*, y \w harás|strong="H6213"\w* una moldura de \w oro|strong="H2091"\w* \w alrededor|strong="H5439"\w* de su reborde.  
\v 26 \w Le|strong="H5921"\w* \w harás|strong="H6213"\w* cuatro argollas \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w pondrás|strong="H5414"\w* \w las|strong="H5921"\w* argollas \w en|strong="H5921"\w* \w las|strong="H5921"\w* cuatro \w esquinas|strong="H6285"\w* \w que|strong="H5921"\w* corresponden \w a|strong="H3068"\w* sus cuatro patas.  
\v 27 Las argollas \w estarán|strong="H1961"\w* cerca del reborde, \w como|strong="H1961"\w* lugares \w para|strong="H1961"\w* pasar las varas con el fin de transportar la \w mesa|strong="H7979"\w*.  
\v 28 \w Harás|strong="H6213"\w* las varas de \w madera|strong="H6086"\w* de acacia y las recubrirás de \w oro|strong="H2091"\w*, para que la \w mesa|strong="H7979"\w* pueda ser transportada con ellas.  
\v 29 \w Harás|strong="H6213"\w* sus \w platos|strong="H7086"\w*, sus \w cucharas|strong="H3709"\w*, sus jarros y sus tazones con los que se derramarán las \w libaciones|strong="H5258"\w*. Los \w harás|strong="H6213"\w* de \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*.  
\v 30 \w Y|strong="H3068"\w* \w pondrás|strong="H5414"\w* \w continuamente|strong="H8548"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w mesa|strong="H7979"\w* \w el|strong="H5921"\w* \w pan|strong="H3899"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Presencia|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\p
\v 31 “\w Harás|strong="H6213"\w* un candelabro \w de|strong="H4480"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*. \w El|strong="H6213"\w* candelabro \w se|strong="H1961"\w* \w hará|strong="H6213"\w* \w de|strong="H4480"\w* \w obra|strong="H6213"\w* labrada \w a|strong="H3068"\w* martillo. Su base, su fuste, sus \w copas|strong="H1375"\w*, sus cálices y sus \w flores|strong="H6525"\w* \w serán|strong="H1961"\w* \w de|strong="H4480"\w* una sola pieza \w con|strong="H4480"\w* \w él|strong="H6213"\w*.  
\v 32 De sus \w lados|strong="H6654"\w* \w saldrán|strong="H3318"\w* \w seis|strong="H8337"\w* \w brazos|strong="H7070"\w*: \w tres|strong="H7969"\w* \w brazos|strong="H7070"\w* del candelabro de un \w lado|strong="H6654"\w*, y \w tres|strong="H7969"\w* \w brazos|strong="H7070"\w* del candelabro del \w otro|strong="H8145"\w* \w lado|strong="H6654"\w*.  
\v 33 Habrá \w tres|strong="H7969"\w* \w copas|strong="H1375"\w* \w en|strong="H4480"\w* forma \w de|strong="H4480"\w* \w flor|strong="H6525"\w* \w de|strong="H4480"\w* almendro \w en|strong="H4480"\w* un \w brazo|strong="H7070"\w*, \w con|strong="H4480"\w* un cáliz y una \w flor|strong="H6525"\w*; y \w tres|strong="H7969"\w* \w copas|strong="H1375"\w* \w en|strong="H4480"\w* forma \w de|strong="H4480"\w* \w flor|strong="H6525"\w* \w de|strong="H4480"\w* almendro \w en|strong="H4480"\w* el otro \w brazo|strong="H7070"\w*, \w con|strong="H4480"\w* un cáliz y una \w flor|strong="H6525"\w*; y \w así|strong="H3651"\w* \w para|strong="H4480"\w* los \w seis|strong="H8337"\w* \w brazos|strong="H7070"\w* \w que|strong="H4480"\w* \w salen|strong="H3318"\w* \w del|strong="H4480"\w* candelabro.  
\v 34 En el fuste del candelabro habrá cuatro \w copas|strong="H1375"\w* en forma de \w flor|strong="H6525"\w* de almendro, con sus cálices y sus \w flores|strong="H6525"\w*:  
\v 35 un cáliz \w debajo|strong="H8478"\w* \w de|strong="H4480"\w* un par \w de|strong="H4480"\w* \w brazos|strong="H7070"\w* \w de|strong="H4480"\w* la misma pieza, y un cáliz \w debajo|strong="H8478"\w* \w del|strong="H4480"\w* \w segundo|strong="H8147"\w* par \w de|strong="H4480"\w* \w brazos|strong="H7070"\w* \w de|strong="H4480"\w* la misma pieza, y un cáliz \w debajo|strong="H8478"\w* \w del|strong="H4480"\w* tercer par \w de|strong="H4480"\w* \w brazos|strong="H7070"\w* \w de|strong="H4480"\w* la misma pieza, \w para|strong="H4480"\w* los \w seis|strong="H8337"\w* \w brazos|strong="H7070"\w* \w que|strong="H4480"\w* \w salen|strong="H3318"\w* \w del|strong="H4480"\w* candelabro.  
\v 36 Sus cálices y sus \w brazos|strong="H7070"\w* \w serán|strong="H1961"\w* \w de|strong="H4480"\w* una sola pieza \w con|strong="H4480"\w* \w él|strong="H3605"\w*, \w todo|strong="H3605"\w* ello \w de|strong="H4480"\w* una sola pieza labrada \w a|strong="H3068"\w* martillo, \w de|strong="H4480"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*.  
\v 37 \w Harás|strong="H6213"\w* sus \w siete|strong="H7651"\w* \w lámparas|strong="H5216"\w*, \w y|strong="H5921"\w* colocarán sus \w lámparas|strong="H5216"\w* \w de|strong="H5921"\w* modo \w que|strong="H5921"\w* alumbren \w el|strong="H5921"\w* espacio \w que|strong="H5921"\w* \w está|strong="H5921"\w* frente \w a|strong="H3068"\w* \w él|strong="H5921"\w*.  
\v 38 Sus despabiladeras y sus platillos serán de \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*.  
\v 39 Se utilizará un talento de \w oro|strong="H2091"\w* \w puro|strong="H2889"\w* para hacerlo, junto con \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* utensilios.  
\v 40 \w Y|strong="H3068"\w* \w mira|strong="H7200"\w* que los \w hagas|strong="H6213"\w* conforme al modelo que te ha sido mostrado en \w el|strong="H6213"\w* \w monte|strong="H2022"\w*.   
\c 26
\p
\v 1 “Además, \w harás|strong="H6213"\w* \w el|strong="H6213"\w* \w tabernáculo|strong="H4908"\w* con \w diez|strong="H6235"\w* \w cortinas|strong="H3407"\w* \w de|strong="H3407"\w* lino fino \w torcido|strong="H7806"\w*, y tela azul, púrpura y escarlata; las \w harás|strong="H6213"\w* con \w querubines|strong="H3742"\w*, \w obra|strong="H4639"\w* \w de|strong="H3407"\w* un hábil artífice.  
\v 2 \w La|strong="H3605"\w* longitud \w de|strong="H3407"\w* \w cada|strong="H3605"\w* \w cortina|strong="H3407"\w* será \w de|strong="H3407"\w* \w veintiocho|strong="H6242"\w* codos, y \w la|strong="H3605"\w* \w anchura|strong="H7341"\w* \w de|strong="H3407"\w* \w cada|strong="H3605"\w* \w cortina|strong="H3407"\w* \w de|strong="H3407"\w* cuatro codos; \w todas|strong="H3605"\w* las \w cortinas|strong="H3407"\w* tendrán \w la|strong="H3605"\w* misma \w medida|strong="H4060"\w*.  
\v 3 \w Cinco|strong="H2568"\w* \w cortinas|strong="H3407"\w* \w estarán|strong="H1961"\w* \w unidas|strong="H2266"\w* entre \w sí|strong="H1961"\w*, y las otras \w cinco|strong="H2568"\w* \w cortinas|strong="H3407"\w* \w estarán|strong="H1961"\w* \w unidas|strong="H2266"\w* entre \w sí|strong="H1961"\w*.  
\v 4 \w Harás|strong="H6213"\w* presillas \w de|strong="H5921"\w* color azul \w en|strong="H5921"\w* \w el|strong="H5921"\w* borde \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w cortina|strong="H3407"\w* \w que|strong="H5921"\w* \w está|strong="H3651"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* extremo \w de|strong="H5921"\w* \w la|strong="H5921"\w* primera unión, \w y|strong="H5921"\w* \w harás|strong="H6213"\w* \w lo|strong="H5921"\w* mismo \w en|strong="H5921"\w* \w el|strong="H5921"\w* borde \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w cortina|strong="H3407"\w* \w que|strong="H5921"\w* \w está|strong="H3651"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* extremo \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w segunda|strong="H8145"\w* unión.  
\v 5 \w Harás|strong="H6213"\w* \w cincuenta|strong="H2572"\w* presillas en la primera \w cortina|strong="H3407"\w*, y \w harás|strong="H6213"\w* \w cincuenta|strong="H2572"\w* presillas en \w el|strong="H6213"\w* borde \w de|strong="H3407"\w* la \w cortina|strong="H3407"\w* que está en la \w segunda|strong="H8145"\w* unión. Las presillas estarán contrapuestas la una \w a|strong="H3068"\w* la \w otra|strong="H8145"\w*.  
\v 6 \w Harás|strong="H6213"\w* \w cincuenta|strong="H2572"\w* \w corchetes|strong="H7165"\w* \w de|strong="H3407"\w* \w oro|strong="H2091"\w* y unirás las \w cortinas|strong="H3407"\w* entre \w sí|strong="H1961"\w* con \w los|strong="H1961"\w* \w corchetes|strong="H7165"\w*, \w de|strong="H3407"\w* modo \w que|strong="H1961"\w* \w el|strong="H6213"\w* \w tabernáculo|strong="H4908"\w* \w sea|strong="H1961"\w* uno solo.   
\p
\v 7 “\w Harás|strong="H6213"\w* \w cortinas|strong="H3407"\w* \w de|strong="H5921"\w* pelo \w de|strong="H5921"\w* \w cabra|strong="H5795"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* sirvan \w de|strong="H5921"\w* tienda \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w tabernáculo|strong="H4908"\w*; \w harás|strong="H6213"\w* \w once|strong="H6249"\w* \w cortinas|strong="H3407"\w*.  
\v 8 La longitud \w de|strong="H3407"\w* cada \w cortina|strong="H3407"\w* será \w de|strong="H3407"\w* \w treinta|strong="H7970"\w* codos, y la \w anchura|strong="H7341"\w* \w de|strong="H3407"\w* cada \w cortina|strong="H3407"\w* \w de|strong="H3407"\w* cuatro codos; las \w once|strong="H6249"\w* \w cortinas|strong="H3407"\w* tendrán una misma \w medida|strong="H4060"\w*.  
\v 9 Unirás \w cinco|strong="H2568"\w* \w cortinas|strong="H3407"\w* \w por|strong="H6440"\w* un lado, y \w seis|strong="H8337"\w* \w cortinas|strong="H3407"\w* \w por|strong="H6440"\w* el otro, y doblarás la sexta \w cortina|strong="H3407"\w* en la \w parte|strong="H8345"\w* delantera \w de|strong="H6440"\w* la tienda.  
\v 10 \w Harás|strong="H6213"\w* \w cincuenta|strong="H2572"\w* presillas \w en|strong="H5921"\w* \w el|strong="H5921"\w* borde \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w cortina|strong="H3407"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* extremo \w de|strong="H5921"\w* \w la|strong="H5921"\w* unión, \w y|strong="H5921"\w* \w cincuenta|strong="H2572"\w* presillas \w en|strong="H5921"\w* \w el|strong="H5921"\w* borde \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w cortina|strong="H3407"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w segunda|strong="H8145"\w* unión.  
\v 11 \w Harás|strong="H6213"\w* \w cincuenta|strong="H2572"\w* \w corchetes|strong="H7165"\w* de bronce, meterás \w los|strong="H1961"\w* \w corchetes|strong="H7165"\w* en las presillas y unirás la tienda \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w sea|strong="H1961"\w* una sola.  
\v 12 \w La|strong="H5921"\w* \w parte|strong="H2677"\w* \w que|strong="H5921"\w* sobra \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w cortinas|strong="H3407"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tienda, es decir, \w la|strong="H5921"\w* mitad \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w cortina|strong="H3407"\w* \w que|strong="H5921"\w* sobra, colgará \w a|strong="H3068"\w* espaldas \w del|strong="H5921"\w* \w tabernáculo|strong="H4908"\w*.  
\v 13 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* codo \w de|strong="H5921"\w* un \w lado|strong="H6654"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* codo \w del|strong="H5921"\w* \w otro|strong="H2088"\w* \w lado|strong="H6654"\w*, \w de|strong="H5921"\w* \w lo|strong="H2088"\w* \w que|strong="H5921"\w* sobra \w de|strong="H5921"\w* \w la|strong="H5921"\w* longitud \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w cortinas|strong="H3407"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tienda, colgarán \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w costados|strong="H6654"\w* \w del|strong="H5921"\w* \w tabernáculo|strong="H4908"\w*, \w a|strong="H3068"\w* un \w lado|strong="H6654"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w otro|strong="H2088"\w*, \w para|strong="H5921"\w* cubrirlo.  
\v 14 \w Harás|strong="H6213"\w* para la tienda una cubierta de pieles de carnero teñidas de rojo, y una cubierta de pieles de tejón por \w encima|strong="H4605"\w*.   
\p
\v 15 “\w Harás|strong="H6213"\w* para \w el|strong="H6213"\w* \w tabernáculo|strong="H4908"\w* \w tablas|strong="H7175"\w* de \w madera|strong="H6086"\w* de acacia, puestas de \w pie|strong="H5975"\w*.  
\v 16 La longitud de \w cada|strong="H6235"\w* \w tabla|strong="H7175"\w* será de \w diez|strong="H6235"\w* codos, y la \w anchura|strong="H7341"\w* de \w cada|strong="H6235"\w* \w tabla|strong="H7175"\w* de un codo y \w medio|strong="H2677"\w*.  
\v 17 \w Cada|strong="H3605"\w* \w tabla|strong="H7175"\w* tendrá \w dos|strong="H8147"\w* espigas unidas entre sí; \w así|strong="H3651"\w* \w harás|strong="H6213"\w* para \w todas|strong="H3605"\w* las \w tablas|strong="H7175"\w* del \w tabernáculo|strong="H4908"\w*.  
\v 18 \w Harás|strong="H6213"\w* \w veinte|strong="H6242"\w* \w tablas|strong="H7175"\w* para \w el|strong="H6213"\w* \w lado|strong="H6285"\w* sur del \w tabernáculo|strong="H4908"\w*.  
