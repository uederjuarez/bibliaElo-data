\v 20 Para el \w segundo|strong="H8145"\w* \w lado|strong="H6763"\w* del \w tabernáculo|strong="H4908"\w*, en el \w lado|strong="H6763"\w* \w norte|strong="H6828"\w*, harás \w veinte|strong="H6242"\w* \w tablas|strong="H7175"\w*,  
\v 21 con sus cuarenta basas \w de|strong="H8478"\w* \w plata|strong="H3701"\w*: \w dos|strong="H8147"\w* basas \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* una \w tabla|strong="H7175"\w*, y \w dos|strong="H8147"\w* basas \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* la siguiente \w tabla|strong="H7175"\w*.  
\v 22 Para la parte posterior del \w tabernáculo|strong="H4908"\w*, \w hacia|strong="H6213"\w* \w el|strong="H6213"\w* occidente, \w harás|strong="H6213"\w* \w seis|strong="H8337"\w* \w tablas|strong="H7175"\w*.  
\v 23 \w Harás|strong="H6213"\w* además \w dos|strong="H8147"\w* \w tablas|strong="H7175"\w* para las esquinas del \w tabernáculo|strong="H4908"\w* en la parte posterior.  
\v 24 \w Estarán|strong="H1961"\w* unidas \w por|strong="H5921"\w* \w debajo|strong="H4295"\w*, \w y|strong="H5921"\w* \w asimismo|strong="H3651"\w* \w estarán|strong="H1961"\w* unidas \w por|strong="H5921"\w* \w arriba|strong="H7218"\w* \w hasta|strong="H5921"\w* \w la|strong="H5921"\w* primera argolla. \w Así|strong="H3651"\w* \w será|strong="H1961"\w* \w para|strong="H5921"\w* \w ambas|strong="H8147"\w*; \w serán|strong="H1961"\w* \w para|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w esquinas|strong="H4740"\w*.  
\v 25 \w De|strong="H8478"\w* modo \w que|strong="H1961"\w* \w serán|strong="H1961"\w* \w ocho|strong="H8083"\w* \w tablas|strong="H7175"\w*, con sus basas \w de|strong="H8478"\w* \w plata|strong="H3701"\w*, \w dieciséis|strong="H8337"\w* basas \w en|strong="H8478"\w* total: \w dos|strong="H8147"\w* basas \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* una \w tabla|strong="H7175"\w*, y \w dos|strong="H8147"\w* basas \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* la otra \w tabla|strong="H7175"\w*.   
\p
\v 26 “\w Harás|strong="H6213"\w* travesaños \w de|strong="H2568"\w* \w madera|strong="H6086"\w* \w de|strong="H2568"\w* acacia: \w cinco|strong="H2568"\w* para las \w tablas|strong="H7175"\w* \w de|strong="H2568"\w* un \w lado|strong="H6763"\w* del \w tabernáculo|strong="H4908"\w*,  
\v 27 y \w cinco|strong="H2568"\w* travesaños para las \w tablas|strong="H7175"\w* del \w otro|strong="H8145"\w* \w lado|strong="H6763"\w* del \w tabernáculo|strong="H4908"\w*, y \w cinco|strong="H2568"\w* travesaños para las \w tablas|strong="H7175"\w* \w de|strong="H2568"\w* la parte posterior del \w tabernáculo|strong="H4908"\w*, hacia el occidente.  
\v 28 El travesaño central \w pasará|strong="H1272"\w* \w por|strong="H4480"\w* \w en|strong="H4480"\w* \w medio|strong="H8432"\w* \w de|strong="H4480"\w* las \w tablas|strong="H7175"\w*, \w de|strong="H4480"\w* un \w extremo|strong="H7097"\w* \w al|strong="H4480"\w* \w otro|strong="H7097"\w*.  
\v 29 Recubrirás las \w tablas|strong="H7175"\w* de \w oro|strong="H2091"\w*, y \w harás|strong="H6213"\w* sus argollas de \w oro|strong="H2091"\w* para pasar por ellas los travesaños. También recubrirás los travesaños de \w oro|strong="H2091"\w*.  
\v 30 Erigirás el \w tabernáculo|strong="H4908"\w* conforme al diseño que te ha sido mostrado en el \w monte|strong="H2022"\w*.   
\p
\v 31 “\w Harás|strong="H6213"\w* un velo de color azul, púrpura, escarlata y lino fino \w torcido|strong="H7806"\w*; \w será|strong="H6213"\w* \w hecho|strong="H6213"\w* con \w querubines|strong="H3742"\w*, \w obra|strong="H4639"\w* de un hábil artífice.  
\v 32 \w Lo|strong="H5921"\w* colgarás \w sobre|strong="H5921"\w* cuatro \w columnas|strong="H5982"\w* \w de|strong="H5921"\w* acacia recubiertas \w de|strong="H5921"\w* \w oro|strong="H2091"\w*; sus capiteles serán \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w sobre|strong="H5921"\w* cuatro basas \w de|strong="H5921"\w* \w plata|strong="H3701"\w*.  
\v 33 Colgarás el velo \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* los \w corchetes|strong="H7165"\w*, y \w allí|strong="H8033"\w*, detrás del velo, introducirás el arca del \w Testimonio|strong="H5715"\w*. El velo os servirá \w de|strong="H8478"\w* separación \w entre|strong="H8478"\w* el \w Lugar|strong="H8478"\w* \w Santo|strong="H6944"\w* y el \w Lugar|strong="H8478"\w* \w Santísimo|strong="H6944"\w*.  
\v 34 \w Pondrás|strong="H5414"\w* \w el|strong="H5921"\w* propiciatorio \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* arca \w del|strong="H5921"\w* \w Testimonio|strong="H5715"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* Lugar \w Santísimo|strong="H6944"\w*.  
\v 35 \w Pondrás|strong="H5414"\w* \w la|strong="H5921"\w* \w mesa|strong="H7979"\w* \w fuera|strong="H2351"\w* \w del|strong="H5921"\w* velo, \w y|strong="H5921"\w* \w el|strong="H5921"\w* candelabro frente \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w mesa|strong="H7979"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w lado|strong="H6763"\w* sur \w del|strong="H5921"\w* \w tabernáculo|strong="H4908"\w*; \w y|strong="H5921"\w* colocarás \w la|strong="H5921"\w* \w mesa|strong="H7979"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w lado|strong="H6763"\w* \w norte|strong="H6828"\w*.   
\p
\v 36 “\w Harás|strong="H6213"\w* una cortina para la entrada de la tienda, de color azul, púrpura, escarlata y lino fino \w torcido|strong="H7806"\w*, \w obra|strong="H4639"\w* de recamador.  
\v 37 \w Harás|strong="H6213"\w* para esta cortina \w cinco|strong="H2568"\w* \w columnas|strong="H5982"\w* \w de|strong="H2568"\w* acacia, y las recubrirás \w de|strong="H2568"\w* \w oro|strong="H2091"\w*. Sus capiteles serán \w de|strong="H2568"\w* \w oro|strong="H2091"\w*, y fundirás para ellas \w cinco|strong="H2568"\w* basas \w de|strong="H2568"\w* bronce.   
\c 27
\p
\v 1 “\w Harás|strong="H6213"\w* \w el|strong="H6213"\w* \w altar|strong="H4196"\w* \w de|strong="H2568"\w* \w madera|strong="H6086"\w* \w de|strong="H2568"\w* acacia, \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* codos\f + \fr 27:1 \ft Un codo es la longitud desde la punta del dedo medio hasta el codo del brazo de un hombre, es decir, unos 46 centímetros o 18 pulgadas.\f* \w de|strong="H2568"\w* largo y \w cinco|strong="H2568"\w* codos \w de|strong="H2568"\w* ancho. \w El|strong="H6213"\w* \w altar|strong="H4196"\w* \w será|strong="H1961"\w* \w cuadrado|strong="H7251"\w*, y su \w altura|strong="H6967"\w* \w será|strong="H1961"\w* \w de|strong="H2568"\w* \w tres|strong="H7969"\w* codos. \f + \fr 27:1 \ft El altar medía unos 2,3 metros cuadrados por 1,4 metros de alto.\f*  
\v 2 \w Harás|strong="H6213"\w* sus \w cuernos|strong="H7161"\w* \w en|strong="H5921"\w* sus cuatro \w esquinas|strong="H6438"\w*; sus \w cuernos|strong="H7161"\w* \w serán|strong="H1961"\w* \w de|strong="H4480"\w* una misma pieza \w con|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* recubrirás \w de|strong="H4480"\w* bronce.  
\v 3 \w Harás|strong="H6213"\w* sus recipientes para recoger las cenizas, sus palas, sus \w tazones|strong="H4219"\w*, sus tenedores y sus braseros. \w Harás|strong="H6213"\w* \w todos|strong="H3605"\w* sus utensilios de bronce.  
\v 4 \w Le|strong="H5921"\w* \w harás|strong="H6213"\w* un enrejado \w de|strong="H5921"\w* bronce \w en|strong="H5921"\w* forma \w de|strong="H5921"\w* \w red|strong="H7568"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w red|strong="H7568"\w* \w harás|strong="H6213"\w* cuatro argollas \w de|strong="H5921"\w* bronce \w en|strong="H5921"\w* sus cuatro \w esquinas|strong="H7098"\w*.  
\v 5 La colocarás \w por|strong="H8478"\w* \w debajo|strong="H8478"\w* \w del|strong="H2677"\w* borde \w del|strong="H2677"\w* \w altar|strong="H4196"\w*, \w de|strong="H8478"\w* modo \w que|strong="H5704"\w* la \w red|strong="H7568"\w* llegue \w hasta|strong="H5704"\w* la mitad \w del|strong="H2677"\w* \w altar|strong="H4196"\w*.  
\v 6 \w Harás|strong="H6213"\w* varas para \w el|strong="H6213"\w* \w altar|strong="H4196"\w*, varas de \w madera|strong="H6086"\w* de acacia, y las recubrirás de bronce.  
\v 7 Sus varas \w se|strong="H1961"\w* meterán \w por|strong="H5921"\w* \w las|strong="H5921"\w* argollas, \w de|strong="H5921"\w* manera \w que|strong="H5921"\w* \w las|strong="H5921"\w* varas queden \w a|strong="H3068"\w* \w ambos|strong="H8147"\w* \w lados|strong="H6763"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w* \w cuando|strong="H1961"\w* \w sea|strong="H1961"\w* transportado.  
\v 8 \w Lo|strong="H6213"\w* \w harás|strong="H6213"\w* \w hueco|strong="H5014"\w*, de \w tablas|strong="H3871"\w*. \w Tal|strong="H3651"\w* \w como|strong="H3651"\w* \w se|strong="H3651"\w* te ha mostrado en \w el|strong="H6213"\w* \w monte|strong="H2022"\w*, \w así|strong="H3651"\w* \w lo|strong="H6213"\w* \w harán|strong="H6213"\w*.   
\p
\v 9 “\w Harás|strong="H6213"\w* \w el|strong="H6213"\w* \w atrio|strong="H2691"\w* del \w tabernáculo|strong="H4908"\w*. Para \w el|strong="H6213"\w* \w lado|strong="H6285"\w* sur, habrá \w cortinas|strong="H7050"\w* de lino fino \w torcido|strong="H7806"\w* de \w cien|strong="H3967"\w* codos de largo por ese \w lado|strong="H6285"\w*.  
\v 10 Sus \w columnas|strong="H5982"\w* serán \w veinte|strong="H6242"\w*, con sus \w veinte|strong="H6242"\w* basas de bronce. Los capiteles de las \w columnas|strong="H5982"\w* y sus \w molduras|strong="H2838"\w* serán de \w plata|strong="H3701"\w*.  
\v 11 \w Asimismo|strong="H3651"\w*, \w a|strong="H3068"\w* lo largo del \w lado|strong="H6285"\w* \w norte|strong="H6828"\w*, habrá \w cortinas|strong="H7050"\w* de \w cien|strong="H3967"\w* codos de largo, con sus \w veinte|strong="H6242"\w* \w columnas|strong="H5982"\w* y sus \w veinte|strong="H6242"\w* basas de bronce; los capiteles de las \w columnas|strong="H5982"\w* y sus \w molduras|strong="H2838"\w* serán de \w plata|strong="H3701"\w*.  
\v 12 \w A|strong="H3068"\w* lo ancho del \w atrio|strong="H2691"\w*, en el \w lado|strong="H6285"\w* \w occidental|strong="H3220"\w*, habrá \w cortinas|strong="H7050"\w* de \w cincuenta|strong="H2572"\w* codos, con sus \w diez|strong="H6235"\w* \w columnas|strong="H5982"\w* y sus \w diez|strong="H6235"\w* basas.  
\v 13 La \w anchura|strong="H7341"\w* del \w atrio|strong="H2691"\w* en el \w lado|strong="H6285"\w* \w oriental|strong="H4217"\w*, hacia la salida del sol, será de \w cincuenta|strong="H2572"\w* codos.  
\v 14 Las \w cortinas|strong="H7050"\w* \w a|strong="H3068"\w* un \w lado|strong="H3802"\w* \w de|strong="H2568"\w* la entrada serán \w de|strong="H2568"\w* \w quince|strong="H2568"\w* codos, con sus \w tres|strong="H7969"\w* \w columnas|strong="H5982"\w* y sus \w tres|strong="H7969"\w* basas.  
\v 15 \w Y|strong="H3068"\w* al \w otro|strong="H8145"\w* \w lado|strong="H3802"\w* habrá \w cortinas|strong="H7050"\w* \w de|strong="H2568"\w* \w quince|strong="H2568"\w* codos, con sus \w tres|strong="H7969"\w* \w columnas|strong="H5982"\w* y sus \w tres|strong="H7969"\w* basas.  
\v 16 Para la \w puerta|strong="H8179"\w* del \w atrio|strong="H2691"\w* habrá una cortina de \w veinte|strong="H6242"\w* codos, de color azul, púrpura, escarlata y lino fino \w torcido|strong="H7806"\w*, \w obra|strong="H4639"\w* de recamador, con sus cuatro \w columnas|strong="H5982"\w* y sus cuatro basas.  
\v 17 \w Todas|strong="H3605"\w* las \w columnas|strong="H5982"\w* \w alrededor|strong="H5439"\w* del \w atrio|strong="H2691"\w* estarán unidas con varillas de \w plata|strong="H3701"\w*; sus capiteles serán de \w plata|strong="H3701"\w*, y sus basas de bronce.  
\v 18 La longitud del \w atrio|strong="H2691"\w* será \w de|strong="H2568"\w* \w cien|strong="H3967"\w* codos, la \w anchura|strong="H7341"\w* \w de|strong="H2568"\w* \w cincuenta|strong="H2572"\w*, y la \w altura|strong="H6967"\w* \w de|strong="H2568"\w* las cortinas \w de|strong="H2568"\w* lino fino \w torcido|strong="H7806"\w* será \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* codos, con sus basas \w de|strong="H2568"\w* bronce.  
\v 19 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios del \w tabernáculo|strong="H4908"\w* para \w todo|strong="H3605"\w* su servicio, y \w todas|strong="H3605"\w* sus estacas, y \w todas|strong="H3605"\w* las estacas del \w atrio|strong="H2691"\w*, serán de bronce.   
\p
\v 20 “\w Mandarás|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* te \w traigan|strong="H3947"\w* \w aceite|strong="H8081"\w* \w puro|strong="H2134"\w* \w de|strong="H1121"\w* \w olivas|strong="H2132"\w* machacadas para \w el|strong="H1121"\w* alumbrado, \w a|strong="H3068"\w* fin \w de|strong="H1121"\w* hacer arder \w continuamente|strong="H8548"\w* una \w lámpara|strong="H5216"\w*.  
\v 21 \w En|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w fuera|strong="H2351"\w* \w del|strong="H5921"\w* velo \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w Testimonio|strong="H5715"\w*, Aarón \w y|strong="H5921"\w* sus \w hijos|strong="H1121"\w* \w la|strong="H5921"\w* mantendrán ardiendo \w desde|strong="H5704"\w* \w la|strong="H5921"\w* \w tarde|strong="H6153"\w* \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé. Este será un \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w* \w para|strong="H5704"\w* \w todas|strong="H1755"\w* sus \w generaciones|strong="H1755"\w* \w de|strong="H5921"\w* parte \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\c 28
\p
\v 1 “Haz \w que|strong="H1121"\w* se acerquen \w a|strong="H3068"\w* ti, \w de|strong="H1121"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, tu hermano Aarón, y con \w él|strong="H1121"\w* sus \w hijos|strong="H1121"\w*, para \w que|strong="H1121"\w* me sirvan como sacerdotes: Aarón, \w Nadab|strong="H5070"\w*, Abiú, Eleazar \w e|strong="H3068"\w* Itamar, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón.  
\v 2 \w Y|strong="H3068"\w* \w harás|strong="H6213"\w* vestiduras \w sagradas|strong="H6944"\w* para \w tu|strong="H6213"\w* hermano Aarón, para \w gloria|strong="H3519"\w* \w y|strong="H3519"\w* hermosura.  
\v 3 \w Hablarás|strong="H1696"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* artífices expertos \w a|strong="H3068"\w* quienes he llenado de \w espíritu|strong="H7307"\w* de \w sabiduría|strong="H2451"\w*, para \w que|strong="H3605"\w* confeccionen las vestiduras de Aarón con \w el|strong="H3605"\w* fin de consagrarlo para \w que|strong="H3605"\w* me sirva como sacerdote.  
\v 4 \w Estas|strong="H6213"\w* son las \w vestiduras|strong="H3801"\w* \w que|strong="H1121"\w* \w harán|strong="H6213"\w*: un pectoral, un efod, un \w manto|strong="H4598"\w*, una túnica bordada, una mitra y un ceñidor. \w Harán|strong="H6213"\w*, pues, las \w vestiduras|strong="H3801"\w* \w sagradas|strong="H6944"\w* para \w tu|strong="H6213"\w* hermano Aarón y para sus \w hijos|strong="H1121"\w*, para \w que|strong="H1121"\w* me sirvan como sacerdotes.  
\v 5 \w Tomarán|strong="H3947"\w* \w oro|strong="H2091"\w*, tela azul, púrpura, escarlata y lino fino.   
\p
\v 6 “\w Harán|strong="H6213"\w* \w el|strong="H6213"\w* efod de \w oro|strong="H2091"\w*, de hilo azul, púrpura, escarlata y lino fino \w torcido|strong="H7806"\w*, \w obra|strong="H4639"\w* de hábil artífice.  
\v 7 \w Tendrá|strong="H1961"\w* \w dos|strong="H8147"\w* \w hombreras|strong="H3802"\w* \w unidas|strong="H2266"\w* \w a|strong="H3068"\w* sus \w dos|strong="H8147"\w* extremos, \w para|strong="H1961"\w* \w que|strong="H1961"\w* pueda ser sujetado.  
\v 8 \w El|strong="H5921"\w* cinto hábilmente tejido \w que|strong="H4480"\w* \w estará|strong="H1961"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* formará una sola pieza \w con|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w será|strong="H1961"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* misma \w obra|strong="H4639"\w*: \w de|strong="H4480"\w* \w oro|strong="H2091"\w*, hilo azul, púrpura, escarlata \w y|strong="H5921"\w* lino fino \w torcido|strong="H7806"\w*.  
\v 9 \w Tomarás|strong="H3947"\w* \w dos|strong="H8147"\w* piedras \w de|strong="H5921"\w* ónice \w y|strong="H5921"\w* grabarás \w en|strong="H5921"\w* \w ellas|strong="H5921"\w* \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*:  
\v 10 \w seis|strong="H8337"\w* \w de|strong="H5921"\w* sus \w nombres|strong="H8034"\w* \w en|strong="H5921"\w* una piedra, \w y|strong="H5921"\w* \w los|strong="H5921"\w* otros \w seis|strong="H8337"\w* \w nombres|strong="H8034"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w otra|strong="H8145"\w* piedra, \w según|strong="H5921"\w* \w el|strong="H5921"\w* orden \w de|strong="H5921"\w* su nacimiento.  
\v 11 \w Con|strong="H5921"\w* \w obra|strong="H4639"\w* \w de|strong="H5921"\w* grabador \w de|strong="H5921"\w* piedra, \w como|strong="H5921"\w* \w los|strong="H1121"\w* grabados \w de|strong="H5921"\w* un sello, grabarás \w las|strong="H5921"\w* \w dos|strong="H8147"\w* piedras \w con|strong="H5921"\w* \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*; \w las|strong="H5921"\w* \w harás|strong="H6213"\w* montar \w en|strong="H5921"\w* \w engastes|strong="H4865"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w*.  
\v 12 \w Pondrás|strong="H7760"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* piedras \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w hombreras|strong="H3802"\w* \w del|strong="H5921"\w* efod, \w como|strong="H5921"\w* piedras \w de|strong="H5921"\w* \w memoria|strong="H2146"\w* \w para|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. Aarón \w llevará|strong="H5375"\w* sus \w nombres|strong="H8034"\w* \w sobre|strong="H5921"\w* sus \w dos|strong="H8147"\w* \w hombros|strong="H3802"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé \w como|strong="H5921"\w* un memorial.  
\v 13 \w Harás|strong="H6213"\w* los \w engastes|strong="H4865"\w* de \w oro|strong="H2091"\w*,  
\v 14 \w y|strong="H5921"\w* \w dos|strong="H8147"\w* \w cadenillas|strong="H8333"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*; \w las|strong="H5921"\w* \w harás|strong="H6213"\w* trenzadas \w como|strong="H5921"\w* cordones, \w y|strong="H5921"\w* fijarás \w las|strong="H5921"\w* \w cadenillas|strong="H8333"\w* trenzadas \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w engastes|strong="H4865"\w*.   
\p
\v 15 “\w Harás|strong="H6213"\w* un pectoral del \w juicio|strong="H4941"\w*, \w obra|strong="H4639"\w* de hábil artífice. \w Lo|strong="H6213"\w* \w harás|strong="H6213"\w* de la misma \w obra|strong="H4639"\w* que \w el|strong="H6213"\w* efod: de \w oro|strong="H2091"\w*, de hilo azul, púrpura, escarlata y lino fino \w torcido|strong="H7806"\w*.  
\v 16 \w Será|strong="H1961"\w* \w cuadrado|strong="H7251"\w* y \w doble|strong="H3717"\w*; de un \w palmo|strong="H2239"\w*\f + \fr 28:16 \ft Un palmo es la longitud desde la punta del pulgar hasta la punta del meñique con la mano extendida, unos 23 centímetros.\f* de largo y un \w palmo|strong="H2239"\w* de ancho.  
\v 17 Pondrás en él cuatro hileras de piedras: la primera hilera será un rubí, un \w topacio|strong="H6357"\w* y un berilo;  
\v 18 la \w segunda|strong="H8145"\w* hilera, una turquesa, un zafiro\f + \fr 28:18 \ft O lapislázuli.\f* y una esmeralda;  
\v 19 la \w tercera|strong="H7992"\w* hilera, un jacinto, una ágata y una amatista;  
\v 20 y la cuarta hilera, un \w crisólito|strong="H8658"\w*, un ónice y un jaspe. Todas \w estarán|strong="H1961"\w* montadas en engastes de \w oro|strong="H2091"\w*.  
\v 21 \w Las|strong="H5921"\w* piedras \w serán|strong="H1961"\w* \w doce|strong="H8147"\w*, \w según|strong="H5921"\w* \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Como|strong="H1961"\w* \w los|strong="H1121"\w* grabados \w de|strong="H5921"\w* un sello, cada una \w tendrá|strong="H1961"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* una \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w doce|strong="H8147"\w* \w tribus|strong="H7626"\w*.  
\v 22 \w Harás|strong="H6213"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* pectoral cadenillas \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*, trenzadas \w a|strong="H3068"\w* manera \w de|strong="H5921"\w* cordón.  
