\c 38
\p
\v 1 \w Hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w altar|strong="H4196"\w* \w del|strong="H4196"\w* \w holocausto|strong="H5930"\w* \w de|strong="H2568"\w* \w madera|strong="H6086"\w* \w de|strong="H2568"\w* acacia. Era \w cuadrado|strong="H7251"\w*. Su longitud era \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* codos, su \w anchura|strong="H7341"\w* \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* codos, y su \w altura|strong="H6967"\w* \w de|strong="H2568"\w* \w tres|strong="H7969"\w* codos.  
\v 2 \w Hizo|strong="H6213"\w* sus \w cuernos|strong="H7161"\w* \w en|strong="H5921"\w* sus cuatro \w esquinas|strong="H6438"\w*; sus \w cuernos|strong="H7161"\w* formaban una sola pieza \w con|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* recubrió \w de|strong="H4480"\w* bronce.  
\v 3 \w Hizo|strong="H6213"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w del|strong="H4196"\w* \w altar|strong="H4196"\w*: \w los|strong="H3605"\w* recipientes para las cenizas, las palas, \w los|strong="H3605"\w* \w tazones|strong="H4219"\w*, \w los|strong="H3605"\w* tenedores y \w los|strong="H3605"\w* braseros. \w Hizo|strong="H6213"\w* \w todos|strong="H3605"\w* sus utensilios de bronce.  
\v 4 \w Hizo|strong="H6213"\w* \w para|strong="H5704"\w* \w el|strong="H6213"\w* \w altar|strong="H4196"\w* un enrejado \w de|strong="H8478"\w* bronce \w en|strong="H5704"\w* forma \w de|strong="H8478"\w* \w red|strong="H7568"\w*, \w y|strong="H5704"\w* \w lo|strong="H6213"\w* puso \w por|strong="H8478"\w* \w debajo|strong="H8478"\w* \w del|strong="H2677"\w* borde \w del|strong="H2677"\w* \w altar|strong="H4196"\w*, \w de|strong="H8478"\w* modo \w que|strong="H5704"\w* llegara \w hasta|strong="H5704"\w* la mitad.  
\v 5 Fundió cuatro argollas para las cuatro esquinas del enrejado de bronce, para pasar las varas.  
\v 6 \w Hizo|strong="H6213"\w* las varas de \w madera|strong="H6086"\w* de acacia y las recubrió de bronce.  
\v 7 Metió \w las|strong="H5921"\w* varas \w por|strong="H5921"\w* \w las|strong="H5921"\w* argollas \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w lados|strong="H6763"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*, \w para|strong="H5921"\w* transportarlo \w con|strong="H5921"\w* \w ellas|strong="H5921"\w*. \w Lo|strong="H5921"\w* \w hizo|strong="H6213"\w* \w hueco|strong="H5014"\w*, \w de|strong="H5921"\w* \w tablas|strong="H3871"\w*.   
\p
\v 8 \w Hizo|strong="H6213"\w* la pila de bronce y su basa de bronce, utilizando los espejos de las mujeres que servían \w a|strong="H3068"\w* la entrada de la Tienda \w del|strong="H3653"\w* Encuentro.   
\p
\v 9 \w Hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w atrio|strong="H2691"\w*: del \w lado|strong="H6285"\w* sur, las \w cortinas|strong="H7050"\w* del \w atrio|strong="H2691"\w* eran de lino fino \w torcido|strong="H7806"\w*, de \w cien|strong="H3967"\w* codos de largo;  
\v 10 sus \w columnas|strong="H5982"\w* eran \w veinte|strong="H6242"\w*, con sus \w veinte|strong="H6242"\w* basas de bronce; los capiteles de las \w columnas|strong="H5982"\w* y sus \w molduras|strong="H2838"\w* eran de \w plata|strong="H3701"\w*.  
\v 11 Del \w lado|strong="H6285"\w* \w norte|strong="H6828"\w*, las cortinas eran de \w cien|strong="H3967"\w* codos; sus \w columnas|strong="H5982"\w* eran \w veinte|strong="H6242"\w*, con sus \w veinte|strong="H6242"\w* basas de bronce; los capiteles de las \w columnas|strong="H5982"\w* y sus \w molduras|strong="H2838"\w* eran de \w plata|strong="H3701"\w*.  
