\v 27 \w Harás|strong="H6213"\w* \w dos|strong="H8147"\w* argollas \w más|strong="H5921"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w pondrás|strong="H5414"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte inferior \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w hombreras|strong="H3802"\w* \w del|strong="H5921"\w* efod, \w por|strong="H5921"\w* \w delante|strong="H6440"\w*, \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* su unión, \w por|strong="H5921"\w* \w encima|strong="H4605"\w* \w del|strong="H5921"\w* cinto tejido \w del|strong="H5921"\w* efod.  
\v 28 Unirán \w el|strong="H5921"\w* pectoral \w por|strong="H5921"\w* sus argollas \w a|strong="H3068"\w* \w las|strong="H5921"\w* argollas \w del|strong="H5921"\w* efod \w con|strong="H5921"\w* un cordón azul, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w quede|strong="H1961"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* cinto tejido \w del|strong="H5921"\w* efod \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* separe \w el|strong="H5921"\w* pectoral \w del|strong="H5921"\w* efod.  
\v 29 Así \w llevará|strong="H5375"\w* Aarón \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* pectoral \w del|strong="H5921"\w* \w juicio|strong="H4941"\w* \w sobre|strong="H5921"\w* su \w corazón|strong="H3820"\w*, cuando \w entre|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* Lugar \w Santo|strong="H6944"\w*, \w como|strong="H5921"\w* un memorial \w continuo|strong="H8548"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé.  
\v 30 \w En|strong="H5921"\w* \w el|strong="H5921"\w* pectoral \w del|strong="H5921"\w* \w juicio|strong="H4941"\w* \w pondrás|strong="H5414"\w* \w el|strong="H5921"\w* Urim \w y|strong="H5921"\w* \w el|strong="H5921"\w* Tumim, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w estén|strong="H1961"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* Aarón \w cuando|strong="H1961"\w* \w entre|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w presencia|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé. Aarón \w llevará|strong="H5375"\w* \w continuamente|strong="H8548"\w* \w sobre|strong="H5921"\w* su \w corazón|strong="H3820"\w* \w el|strong="H5921"\w* \w juicio|strong="H4941"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé.   
\p
\v 31 “\w Harás|strong="H6213"\w* \w el|strong="H6213"\w* \w manto|strong="H4598"\w* del efod \w todo|strong="H3632"\w* de hilo azul.  
\v 32 \w Tendrá|strong="H1961"\w* una abertura \w para|strong="H1961"\w* la \w cabeza|strong="H7218"\w* \w en|strong="H8432"\w* el centro. La abertura \w tendrá|strong="H1961"\w* un borde tejido \w alrededor|strong="H5439"\w*, \w como|strong="H1961"\w* el cuello de un coselete, \w para|strong="H1961"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* \w rasgue|strong="H7167"\w*.  
\v 33 \w En|strong="H5921"\w* su borde inferior \w harás|strong="H6213"\w* \w granadas|strong="H7416"\w* \w de|strong="H5921"\w* hilo azul, púrpura \w y|strong="H5921"\w* escarlata \w alrededor|strong="H5439"\w*, \w con|strong="H5921"\w* campanillas \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w entre|strong="H8432"\w* \w ellas|strong="H5921"\w*.  
\v 34 Una \w campanilla|strong="H6472"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* una granada, otra \w campanilla|strong="H6472"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* otra granada, \w en|strong="H5921"\w* \w todo|strong="H5439"\w* \w el|strong="H5921"\w* borde inferior \w del|strong="H5921"\w* \w manto|strong="H4598"\w* \w alrededor|strong="H5439"\w*.  
\v 35 \w Estará|strong="H1961"\w* \w sobre|strong="H5921"\w* Aarón \w cuando|strong="H1961"\w* ministre; \w y|strong="H5921"\w* \w se|strong="H1961"\w* \w oirá|strong="H8085"\w* su \w sonido|strong="H6963"\w* \w cuando|strong="H1961"\w* \w entre|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* Lugar \w Santo|strong="H6944"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w cuando|strong="H1961"\w* \w salga|strong="H3318"\w*, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w muera|strong="H4191"\w*.   
\p
\v 36 “\w Harás|strong="H6213"\w* también una lámina \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w* \w y|strong="H5921"\w* grabarás \w en|strong="H5921"\w* \w ella|strong="H5921"\w*, \w como|strong="H5921"\w* \w los|strong="H5921"\w* grabados \w de|strong="H5921"\w* un sello: ‘\w SANTIDAD|strong="H6944"\w* \w A|strong="H3068"\w* YAHVÉ’.  
\v 37 \w La|strong="H5921"\w* sujetarás \w con|strong="H5921"\w* un cordón \w de|strong="H5921"\w* hilo azul, \w y|strong="H5921"\w* \w estará|strong="H1961"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* mitra. \w Estará|strong="H1961"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte delantera \w de|strong="H5921"\w* \w la|strong="H5921"\w* mitra.  
\v 38 \w Estará|strong="H1961"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w frente|strong="H4696"\w* \w de|strong="H5921"\w* Aarón, \w y|strong="H5921"\w* Aarón \w cargará|strong="H1961"\w* \w con|strong="H5921"\w* \w las|strong="H5921"\w* faltas cometidas respecto \w a|strong="H3068"\w* \w las|strong="H5921"\w* cosas \w santas|strong="H6944"\w* \w que|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* consagren \w en|strong="H5921"\w* \w todas|strong="H3605"\w* sus \w santas|strong="H6944"\w* \w ofrendas|strong="H4979"\w*; \w y|strong="H5921"\w* \w estará|strong="H1961"\w* \w siempre|strong="H8548"\w* \w en|strong="H5921"\w* su \w frente|strong="H4696"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w ellos|strong="H5921"\w* \w sean|strong="H1961"\w* aceptados \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé.  
\v 39 Tejerás \w a|strong="H3068"\w* cuadros la túnica de lino fino. \w Harás|strong="H6213"\w* una mitra de lino fino y un ceñidor, \w obra|strong="H4639"\w* de recamador.   
\p
\v 40 “Para \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón \w harás|strong="H6213"\w* \w túnicas|strong="H3801"\w*; también les \w harás|strong="H6213"\w* ceñidores \w y|strong="H3519"\w* \w tiaras|strong="H4021"\w*, para \w gloria|strong="H3519"\w* \w y|strong="H3519"\w* hermosura.  
\v 41 Se las pondrás \w a|strong="H3068"\w* tu hermano Aarón y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* con \w él|strong="H1121"\w*; \w los|strong="H1121"\w* \w ungirás|strong="H4886"\w*, \w los|strong="H1121"\w* consagrarás y \w los|strong="H1121"\w* \w santificarás|strong="H6942"\w*, para \w que|strong="H1121"\w* me sirvan como sacerdotes.  
\v 42 Les \w harás|strong="H6213"\w* calzoncillos \w de|strong="H5704"\w* lino \w para|strong="H5704"\w* \w cubrir|strong="H3680"\w* su \w desnudez|strong="H6172"\w*; les llegarán \w desde|strong="H5704"\w* la cintura \w hasta|strong="H5704"\w* \w los|strong="H1961"\w* muslos.  
\v 43 \w Estarán|strong="H1961"\w* \w sobre|strong="H5921"\w* Aarón \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* sus \w hijos|strong="H1121"\w* \w cuando|strong="H1961"\w* entren \w en|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w o|strong="H3068"\w* \w cuando|strong="H1961"\w* \w se|strong="H1961"\w* acerquen \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w para|strong="H5921"\w* servir \w en|strong="H5921"\w* \w el|strong="H5921"\w* Lugar \w Santo|strong="H6944"\w*, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* incurran \w en|strong="H5921"\w* culpa \w y|strong="H5921"\w* \w mueran|strong="H4191"\w*. \w Este|strong="H1961"\w* \w será|strong="H1961"\w* un \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w* \w para|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w para|strong="H5921"\w* su \w descendencia|strong="H2233"\w*.”   
\c 29
\p
\v 1 “\w Esto|strong="H2088"\w* \w es|strong="H2088"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w harás|strong="H6213"\w* con ellos para consagrarlos, \w a|strong="H3068"\w* fin \w de|strong="H1121"\w* \w que|strong="H1697"\w* me sirvan como sacerdotes: \w toma|strong="H3947"\w* un \w novillo|strong="H1121"\w* \w y|strong="H1241"\w* \w dos|strong="H8147"\w* carneros sin defecto;  
\v 2 \w panes|strong="H3899"\w* sin levadura, \w tortas|strong="H2471"\w* sin levadura \w amasadas|strong="H1101"\w* con \w aceite|strong="H8081"\w*, y hojaldres sin levadura untados con \w aceite|strong="H8081"\w*. Los \w harás|strong="H6213"\w* de flor de harina de \w trigo|strong="H2406"\w*.  
\v 3 \w Los|strong="H5921"\w* \w pondrás|strong="H5414"\w* \w en|strong="H5921"\w* un \w canastillo|strong="H5536"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* presentarás \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w canastillo|strong="H5536"\w*, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w novillo|strong="H6499"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* carneros.  
\v 4 Llevarás \w a|strong="H3068"\w* Aarón y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* la entrada \w de|strong="H1121"\w* la Tienda del Encuentro, y \w los|strong="H1121"\w* lavarás con \w agua|strong="H4325"\w*.  
\v 5 \w Tomarás|strong="H3947"\w* las \w vestiduras|strong="H3801"\w* y vestirás \w a|strong="H3068"\w* Aarón con la túnica, el \w manto|strong="H4598"\w* del efod, el efod y el pectoral, y lo ceñirás con el cinto hábilmente tejido del efod.  
\v 6 \w Pondrás|strong="H5414"\w* \w la|strong="H5921"\w* mitra \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* mitra colocarás \w la|strong="H5921"\w* diadema \w santa|strong="H6944"\w*.  
\v 7 Luego \w tomarás|strong="H3947"\w* \w el|strong="H5921"\w* \w aceite|strong="H8081"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w unción|strong="H4888"\w*, \w lo|strong="H5921"\w* derramarás \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w ungirás|strong="H4886"\w*.  
\v 8 Harás \w que|strong="H1121"\w* se acerquen sus \w hijos|strong="H1121"\w* y les pondrás las \w túnicas|strong="H3801"\w*.  
\v 9 \w Les|strong="H1992"\w* ceñirás \w los|strong="H1992"\w* cinturones \w a|strong="H3068"\w* Aarón y \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w*, y \w les|strong="H1992"\w* atarás \w las|strong="H1992"\w* \w tiaras|strong="H4021"\w*. \w Y|strong="H3068"\w* \w tendrán|strong="H1961"\w* \w el|strong="H1121"\w* \w sacerdocio|strong="H3550"\w* \w por|strong="H3027"\w* \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w*. \w Así|strong="H1992"\w* consagrarás \w a|strong="H3068"\w* Aarón y \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w*.   
\p
\v 10 “Llevarás \w el|strong="H5921"\w* \w novillo|strong="H1121"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w y|strong="H5921"\w* Aarón \w y|strong="H5921"\w* sus \w hijos|strong="H1121"\w* impondrán sus \w manos|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w del|strong="H5921"\w* \w novillo|strong="H1121"\w*.  
\v 11 Matarás el \w novillo|strong="H6499"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, \w a|strong="H3068"\w* la entrada \w de|strong="H6440"\w* la Tienda del Encuentro.  
\v 12 \w Tomarás|strong="H3947"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w del|strong="H5921"\w* \w novillo|strong="H6499"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w pondrás|strong="H5414"\w* \w con|strong="H5921"\w* tu dedo \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w cuernos|strong="H7161"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*, \w y|strong="H5921"\w* derramarás \w el|strong="H5921"\w* resto \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w al|strong="H5921"\w* \w pie|strong="H3247"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 13 \w Tomarás|strong="H3947"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w cubre|strong="H3680"\w* \w los|strong="H5921"\w* intestinos, \w el|strong="H5921"\w* lóbulo \w del|strong="H5921"\w* \w hígado|strong="H3516"\w*, \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w riñones|strong="H3629"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* grasa \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* quemarás \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 14 Pero \w la|strong="H1931"\w* \w carne|strong="H1320"\w* del \w novillo|strong="H6499"\w*, \w su|strong="H1931"\w* \w piel|strong="H5785"\w* y \w su|strong="H1931"\w* \w estiércol|strong="H6569"\w* \w los|strong="H1931"\w* \w quemarás|strong="H8313"\w* al fuego \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w*. \w Es|strong="H1931"\w* un sacrificio por \w el|strong="H1931"\w* \w pecado|strong="H2403"\w*.   
\p
\v 15 “También \w tomarás|strong="H3947"\w* uno \w de|strong="H5921"\w* \w los|strong="H1121"\w* carneros, \w y|strong="H5921"\w* Aarón \w y|strong="H5921"\w* sus \w hijos|strong="H1121"\w* impondrán sus \w manos|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w del|strong="H5921"\w* carnero.  
\v 16 Matarás \w el|strong="H5921"\w* carnero, \w tomarás|strong="H3947"\w* su \w sangre|strong="H1818"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w rociarás|strong="H2236"\w* \w alrededor|strong="H5439"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*.  
\v 17 Cortarás \w el|strong="H5921"\w* carnero \w en|strong="H5921"\w* pedazos, lavarás sus intestinos \w y|strong="H5921"\w* sus patas, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w pondrás|strong="H5414"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* sus pedazos \w y|strong="H5921"\w* \w con|strong="H5921"\w* su \w cabeza|strong="H7218"\w*.  
\v 18 \w Y|strong="H3068"\w* quemarás \w todo|strong="H3605"\w* \w el|strong="H1931"\w* carnero sobre \w el|strong="H1931"\w* \w altar|strong="H4196"\w*: \w es|strong="H1931"\w* un \w holocausto|strong="H5930"\w* para Yahvé; \w es|strong="H1931"\w* un aroma agradable, una ofrenda encendida para Yahvé.   
\p
\v 19 “Luego \w tomarás|strong="H3947"\w* \w el|strong="H5921"\w* \w otro|strong="H8145"\w* carnero, \w y|strong="H5921"\w* Aarón \w y|strong="H5921"\w* sus \w hijos|strong="H1121"\w* impondrán sus \w manos|strong="H3027"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w del|strong="H5921"\w* carnero.  
