\v 27 \w Moisés|strong="H4872"\w* \w extendió|strong="H5186"\w* su \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w y|strong="H5921"\w* \w al|strong="H5921"\w* amanecer \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* su estado normal. \w Los|strong="H5921"\w* \w egipcios|strong="H4714"\w* huían \w al|strong="H5921"\w* encuentro \w del|strong="H5921"\w* \w mar|strong="H3220"\w*, pero Yahvé \w derribó|strong="H5287"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w*.  
\v 28 Las \w aguas|strong="H4325"\w* \w volvieron|strong="H7725"\w* \w y|strong="H5704"\w* \w cubrieron|strong="H3680"\w* \w los|strong="H3605"\w* \w carros|strong="H7393"\w*, \w la|strong="H3605"\w* caballería \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ejército|strong="H2428"\w* del \w faraón|strong="H6547"\w* \w que|strong="H3808"\w* había entrado \w en|strong="H5704"\w* \w el|strong="H3605"\w* \w mar|strong="H3220"\w* tras \w ellos|strong="H3605"\w*. \w No|strong="H3808"\w* \w quedó|strong="H7604"\w* \w ni|strong="H3808"\w* uno solo \w de|strong="H5704"\w* \w ellos|strong="H3605"\w*.  
\v 29 Pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w caminaron|strong="H1980"\w* \w en|strong="H8432"\w* seco por \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w mar|strong="H3220"\w*, y las \w aguas|strong="H4325"\w* les eran como un \w muro|strong="H2346"\w* \w a|strong="H3068"\w* su \w derecha|strong="H3225"\w* y \w a|strong="H3068"\w* su \w izquierda|strong="H8040"\w*.  
\v 30 \w Así|strong="H1931"\w* \w salvó|strong="H3467"\w* Yahvé \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w*; \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w* \w muertos|strong="H4191"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* orilla \w del|strong="H5921"\w* \w mar|strong="H3220"\w*.  
\v 31 \w Israel|strong="H3478"\w* \w vio|strong="H7200"\w* \w el|strong="H6213"\w* \w gran|strong="H1419"\w* \w poder|strong="H3027"\w* \w que|strong="H5971"\w* Yahvé \w había|strong="H6213"\w* desplegado \w contra|strong="H3478"\w* los \w egipcios|strong="H4714"\w*, y \w el|strong="H6213"\w* \w pueblo|strong="H5971"\w* \w temió|strong="H3372"\w* \w a|strong="H3068"\w* Yahvé; y creyeron en Yahvé y en su \w siervo|strong="H5650"\w* \w Moisés|strong="H4872"\w*.   
\c 15
\p
\v 1 \w Entonces|strong="H3588"\w* \w Moisés|strong="H4872"\w* \w y|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* entonaron \w este|strong="H2063"\w* \w cántico|strong="H7892"\w* \w a|strong="H3068"\w* Yahvé, \w y|strong="H3588"\w* dijeron:  
\q1 “\w Cantaré|strong="H7891"\w* \w a|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* ha triunfado gloriosamente.  
\q2 Ha arrojado al \w mar|strong="H3220"\w* al \w caballo|strong="H5483"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* jinete.  
\v 2 \w Yah|strong="H3068"\w* \w es|strong="H1961"\w* \w mi|strong="H1961"\w* fuerza \w y|strong="H5797"\w* \w mi|strong="H1961"\w* cántico,  
\q2 \w y|strong="H5797"\w* ha \w sido|strong="H1961"\w* \w mi|strong="H1961"\w* salvación.  
\q1 \w Este|strong="H2088"\w* \w es|strong="H1961"\w* \w mi|strong="H1961"\w* Dios, \w y|strong="H5797"\w* yo \w lo|strong="H2088"\w* alabaré;  
\q2 el Dios de \w mi|strong="H1961"\w* padre, \w y|strong="H5797"\w* yo \w lo|strong="H2088"\w* exaltaré.  
\v 3 Yahvé es un guerrero.  
\q2 ¡Yahvé es su \w nombre|strong="H8034"\w*!  
\v 4 Ha arrojado al \w mar|strong="H3220"\w* los \w carros|strong="H4818"\w* del \w faraón|strong="H6547"\w* y su \w ejército|strong="H2428"\w*.  
\q2 Sus mejores capitanes se han hundido en el \w Mar|strong="H3220"\w* Rojo.  
\v 5 Los \w abismos|strong="H8415"\w* los han cubierto;  
\q2 \w descendieron|strong="H3381"\w* \w a|strong="H3068"\w* las profundidades \w como|strong="H3644"\w* una piedra.  
\v 6 Tu \w diestra|strong="H3225"\w*, oh Yahvé, es majestuosa en \w poder|strong="H3581"\w*.  
\q2 Tu \w diestra|strong="H3225"\w*, oh Yahvé, hace pedazos al enemigo.  
\v 7 Con la grandeza de tu majestad, derribas \w a|strong="H3068"\w* los que se \w levantan|strong="H6965"\w* contra ti.  
\q2 \w Envías|strong="H7971"\w* tu \w furor|strong="H2740"\w*, y los consume como \w a|strong="H3068"\w* hojarasca.  
\v 8 Al \w soplo|strong="H7307"\w* \w de|strong="H4325"\w* tu aliento, las \w aguas|strong="H4325"\w* se amontonaron;  
\q2 las \w corrientes|strong="H5140"\w* se levantaron \w como|strong="H3644"\w* un muro;  
\q2 los \w abismos|strong="H8415"\w* se cuajaron en el \w corazón|strong="H3820"\w* del \w mar|strong="H3220"\w*.  
\v 9 El enemigo dijo: ‘\w Los|strong="H7291"\w* \w perseguiré|strong="H7291"\w*, \w los|strong="H7291"\w* alcanzaré, \w repartiré|strong="H2505"\w* el botín.  
\q2 \w Mi|strong="H5315"\w* deseo se saciará en \w ellos|strong="H3027"\w*.  
\q2 Desenvainaré \w mi|strong="H5315"\w* \w espada|strong="H2719"\w*, \w mi|strong="H5315"\w* \w mano|strong="H3027"\w* \w los|strong="H7291"\w* destruirá’.  
\v 10 \w Soplaste|strong="H5398"\w* con tu \w viento|strong="H7307"\w*, y el \w mar|strong="H3220"\w* los \w cubrió|strong="H3680"\w*.  
\q2 Se hundieron como plomo en las \w aguas|strong="H4325"\w* impetuosas.  
\v 11 ¿\w Quién|strong="H4310"\w* \w como|strong="H3644"\w* \w tú|strong="H6213"\w*, \w oh|strong="H4310"\w* Yahvé, entre los dioses?  
\q2 ¿\w Quién|strong="H4310"\w* \w como|strong="H3644"\w* \w tú|strong="H6213"\w*, majestuoso en \w santidad|strong="H6944"\w*,  
\q2 temible en proezas, \w hacedor|strong="H6213"\w* \w de|strong="H3372"\w* \w maravillas|strong="H6382"\w*?  
\v 12 \w Extendiste|strong="H5186"\w* tu \w diestra|strong="H3225"\w*,  
\q2 y la tierra se los tragó.  
\v 13 Con tu \w misericordia|strong="H2617"\w* has guiado al \w pueblo|strong="H5971"\w* \w que|strong="H2098"\w* \w redimiste|strong="H1350"\w*;  
\q2 con tu poder los has llevado \w a|strong="H3068"\w* tu \w santa|strong="H6944"\w* \w morada|strong="H5116"\w*.  
\v 14 \w Los|strong="H3427"\w* \w pueblos|strong="H5971"\w* lo \w oyeron|strong="H8085"\w* y \w temblaron|strong="H7264"\w*;  
\q2 la angustia \w se|strong="H5971"\w* apoderó \w de|strong="H5971"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5971"\w* \w Filistea|strong="H6429"\w*.  
\v 15 Entonces \w los|strong="H3427"\w* jefes de Edom se aterraron;  
\q2 \w el|strong="H3605"\w* \w temblor|strong="H7461"\w* se apoderó de \w los|strong="H3427"\w* valientes de \w Moab|strong="H4124"\w*.  
\q2 \w Todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de \w Canaán|strong="H3667"\w* se acobardaron.  
\v 16 \w Terror|strong="H6343"\w* \w y|strong="H5921"\w* \w espanto|strong="H6343"\w* \w cae|strong="H5307"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*;  
\q2 \w por|strong="H5921"\w* \w la|strong="H5921"\w* grandeza \w de|strong="H5921"\w* tu \w brazo|strong="H2220"\w* enmudecen \w como|strong="H5921"\w* una piedra,  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H2098"\w* haya \w pasado|strong="H5674"\w* tu \w pueblo|strong="H5971"\w*, oh Yahvé,  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H2098"\w* haya \w pasado|strong="H5674"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H2098"\w* tú adquiriste.  
\v 17 Tú \w los|strong="H3427"\w* introducirás y \w los|strong="H3427"\w* \w plantarás|strong="H5193"\w* en \w el|strong="H3427"\w* \w monte|strong="H2022"\w* de tu \w heredad|strong="H5159"\w*,  
\q2 en \w el|strong="H3427"\w* lugar \w que|strong="H3027"\w* preparaste para tu \w morada|strong="H3427"\w*, oh Yahvé,  
\q2 en \w el|strong="H3427"\w* \w santuario|strong="H4720"\w*, oh \w Señor|strong="H3068"\w*, \w que|strong="H3027"\w* establecieron tus \w manos|strong="H3027"\w*.  
\v 18 ¡Yahvé \w reinará|strong="H4427"\w* \w eternamente|strong="H5769"\w* y \w para|strong="H5703"\w* \w siempre|strong="H5769"\w*!”   
\p
\v 19 \w Porque|strong="H3588"\w* \w los|strong="H1121"\w* \w caballos|strong="H5483"\w* \w del|strong="H5921"\w* \w faraón|strong="H6547"\w* entraron \w con|strong="H5921"\w* sus \w carros|strong="H7393"\w* \w y|strong="H3588"\w* \w con|strong="H5921"\w* \w su|strong="H3588"\w* caballería \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w y|strong="H3588"\w* Yahvé hizo \w volver|strong="H7725"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w*; \w pero|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w caminaron|strong="H1980"\w* \w en|strong="H5921"\w* seco \w por|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w*.  
\v 20 \w La|strong="H3605"\w* \w profetisa|strong="H5031"\w* \w María|strong="H4813"\w*, hermana de Aarón, \w tomó|strong="H3947"\w* un pandero \w en|strong="H3318"\w* su \w mano|strong="H3027"\w*, y \w todas|strong="H3605"\w* las mujeres \w salieron|strong="H3318"\w* tras \w ella|strong="H3605"\w* con panderos y danzas.  
\v 21 \w Y|strong="H3068"\w* \w María|strong="H4813"\w* les respondía:  
\q1 «\w Cantad|strong="H7891"\w* \w a|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* ha triunfado gloriosamente.  
\q1 Ha arrojado al \w mar|strong="H3220"\w* al \w caballo|strong="H5483"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* jinete».   
\p
\v 22 \w Moisés|strong="H4872"\w* hizo partir \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* del \w Mar|strong="H3220"\w* Rojo, y \w se|strong="H3808"\w* dirigieron al \w desierto|strong="H4057"\w* \w de|strong="H4325"\w* \w Shur|strong="H7793"\w*. \w Caminaron|strong="H3212"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* por el \w desierto|strong="H4057"\w* y \w no|strong="H3808"\w* \w hallaron|strong="H4672"\w* \w agua|strong="H4325"\w*.  
\v 23 \w Cuando|strong="H3588"\w* llegaron \w a|strong="H3068"\w* Mara, \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* \w beber|strong="H8354"\w* \w las|strong="H1992"\w* \w aguas|strong="H4325"\w* \w de|strong="H5921"\w* Mara, \w porque|strong="H3588"\w* \w eran|strong="H3808"\w* \w amargas|strong="H4751"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w le|strong="H5921"\w* pusieron \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* Mara.  
\v 24 \w El|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w murmuró|strong="H3885"\w* \w contra|strong="H5921"\w* \w Moisés|strong="H4872"\w*, diciendo: «¿\w Qué|strong="H4100"\w* hemos \w de|strong="H5921"\w* \w beber|strong="H8354"\w*?»  
\v 25 Entonces él \w clamó|strong="H6817"\w* \w a|strong="H3068"\w* Yahvé, y Yahvé le mostró un \w árbol|strong="H6086"\w*; lo \w echó|strong="H7993"\w* \w a|strong="H3068"\w* las \w aguas|strong="H4325"\w*, y las \w aguas|strong="H4325"\w* se volvieron dulces. \w Allí|strong="H8033"\w* Yahvé les \w dio|strong="H7760"\w* un \w estatuto|strong="H2706"\w* y una \w ordenanza|strong="H4941"\w*, y \w allí|strong="H8033"\w* los \w puso|strong="H7760"\w* \w a|strong="H3068"\w* \w prueba|strong="H5254"\w*.  
\v 26 \w Les|strong="H5921"\w* dijo: “\w Si|strong="H3588"\w* escucháis \w atentamente|strong="H8085"\w* \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* Yahvé vuestro \w Dios|strong="H3068"\w*, \w y|strong="H3588"\w* \w hacéis|strong="H6213"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w es|strong="H3588"\w* \w recto|strong="H3477"\w* ante sus \w ojos|strong="H5869"\w*, \w y|strong="H3588"\w* prestáis \w oído|strong="H8085"\w* \w a|strong="H3068"\w* sus \w mandamientos|strong="H4687"\w* \w y|strong="H3588"\w* guardáis \w todos|strong="H3605"\w* sus \w estatutos|strong="H2706"\w*, \w ninguna|strong="H3605"\w* \w enfermedad|strong="H4245"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w que|strong="H3588"\w* \w envié|strong="H7760"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w* \w os|strong="H5921"\w* enviaré \w a|strong="H3068"\w* \w vosotros|strong="H8085"\w*; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, vuestro sanador.”   
\p
\v 27 \w Después|strong="H5921"\w* llegaron \w a|strong="H3068"\w* Elim, \w donde|strong="H8033"\w* había \w doce|strong="H8147"\w* \w fuentes|strong="H5869"\w* \w de|strong="H5921"\w* \w agua|strong="H4325"\w* \w y|strong="H5921"\w* \w setenta|strong="H7657"\w* \w palmeras|strong="H8558"\w*, \w y|strong="H5921"\w* acamparon \w allí|strong="H8033"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*.   
\c 16
\p
\v 1 \w Partieron|strong="H5265"\w* \w de|strong="H2568"\w* Elim, y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w de|strong="H2568"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Israel|strong="H3478"\w* llegó al \w desierto|strong="H4057"\w* \w de|strong="H2568"\w* \w Sin|strong="H5512"\w*, \w que|strong="H3117"\w* está entre Elim y \w el|strong="H3605"\w* \w Sinaí|strong="H5514"\w*, \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w quince|strong="H2568"\w* del \w segundo|strong="H8145"\w* \w mes|strong="H2320"\w* \w después|strong="H8145"\w* \w de|strong="H2568"\w* su \w salida|strong="H3318"\w* \w de|strong="H2568"\w* \w la|strong="H3605"\w* tierra \w de|strong="H2568"\w* \w Egipto|strong="H4714"\w*.  
\v 2 \w Toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w murmuró|strong="H3885"\w* \w contra|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* \w contra|strong="H5921"\w* Aarón \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*;  
\v 3 \w y|strong="H3588"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w les|strong="H5921"\w* decían: «¡\w Ojalá|strong="H4310"\w* hubiéramos \w muerto|strong="H4191"\w* \w a|strong="H3068"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* Yahvé \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w cuando|strong="H3588"\w* \w nos|strong="H5921"\w* \w sentábamos|strong="H3427"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* ollas \w de|strong="H5921"\w* \w carne|strong="H1320"\w*, \w cuando|strong="H3588"\w* comíamos \w pan|strong="H3899"\w* \w hasta|strong="H5921"\w* saciarnos! \w Porque|strong="H3588"\w* \w nos|strong="H5921"\w* habéis \w sacado|strong="H3318"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w desierto|strong="H4057"\w* \w para|strong="H5921"\w* matar \w de|strong="H5921"\w* \w hambre|strong="H7458"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w esta|strong="H2088"\w* \w multitud|strong="H6951"\w*.»   
\p
\v 4 \w Entonces|strong="H3117"\w* Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: “He \w aquí|strong="H2005"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* haré llover \w pan|strong="H3899"\w* \w del|strong="H4480"\w* \w cielo|strong="H8064"\w* \w para|strong="H4616"\w* vosotros; y el \w pueblo|strong="H5971"\w* \w saldrá|strong="H3318"\w* \w a|strong="H3068"\w* recoger diariamente la porción \w de|strong="H4480"\w* \w cada|strong="H3117"\w* \w día|strong="H3117"\w*, \w para|strong="H4616"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* los pruebe, \w si|strong="H2005"\w* andan \w en|strong="H4480"\w* mi \w ley|strong="H8451"\w* \w o|strong="H3068"\w* \w no|strong="H3808"\w*.  
\v 5 Pero \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w sexto|strong="H8345"\w* \w día|strong="H3117"\w* prepararán \w lo|strong="H5921"\w* \w que|strong="H5921"\w* traigan, \w y|strong="H5921"\w* \w será|strong="H1961"\w* \w el|strong="H5921"\w* doble \w de|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w recogen|strong="H3950"\w* \w cada|strong="H3117"\w* \w día|strong="H3117"\w*.”   
\p
\v 6 \w Moisés|strong="H4872"\w* \w y|strong="H3588"\w* Aarón dijeron \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: “Al atardecer \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* Yahvé os ha \w sacado|strong="H3318"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.  
