\v 12 ¿\w No|strong="H3808"\w* \w es|strong="H2088"\w* \w esto|strong="H2088"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w te|strong="H4480"\w* decíamos \w en|strong="H4480"\w* \w Egipto|strong="H4714"\w*: ‘\w Déjanos|strong="H2308"\w* \w en|strong="H4480"\w* paz, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w sirvamos|strong="H5647"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w egipcios|strong="H4713"\w*’? \w Porque|strong="H3588"\w* \w mejor|strong="H2896"\w* \w nos|strong="H4480"\w* hubiera sido \w servir|strong="H5647"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w egipcios|strong="H4713"\w* \w que|strong="H3588"\w* \w morir|strong="H4191"\w* \w en|strong="H4480"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*”.   
