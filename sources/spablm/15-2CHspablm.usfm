\v 17 Han fundido \w la|strong="H5921"\w* \w plata|strong="H3701"\w* hallada \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w la|strong="H5921"\w* han \w entregado|strong="H5414"\w* \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* supervisores \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* obreros».  
\v 18 Además, el \w escriba|strong="H5608"\w* Safán informó \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, diciendo: «El \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w* me ha \w dado|strong="H5414"\w* un \w libro|strong="H5612"\w*». \w Y|strong="H3068"\w* Safán \w lo|strong="H5612"\w* \w leyó|strong="H7121"\w* \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w*.   
\p
\v 19 \w Cuando|strong="H1961"\w* el \w rey|strong="H4428"\w* \w oyó|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* la \w ley|strong="H8451"\w*, \w rasgó|strong="H7167"\w* sus vestiduras.  
\v 20 Luego \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Hilcías|strong="H2518"\w*, \w a|strong="H3068"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán, \w a|strong="H3068"\w* \w Abdón|strong="H5658"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Micaía, \w al|strong="H4428"\w* \w escriba|strong="H5608"\w* Safán, y \w a|strong="H3068"\w* \w Asaías|strong="H6222"\w*, \w siervo|strong="H5650"\w* del \w rey|strong="H4428"\w*, diciendo:  
\v 21 «\w Id|strong="H3212"\w*, consultad \w a|strong="H3068"\w* Yahvé \w por|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* remanente \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w del|strong="H5921"\w* \w libro|strong="H5612"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* \w ha|strong="H3808"\w* \w hallado|strong="H4672"\w*; \w porque|strong="H3588"\w* \w es|strong="H2088"\w* \w grande|strong="H1419"\w* \w la|strong="H5921"\w* \w ira|strong="H2534"\w* \w de|strong="H5921"\w* Yahvé \w que|strong="H3588"\w* \w se|strong="H5921"\w* \w ha|strong="H3808"\w* derramado \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w*, \w por|strong="H5921"\w* \w cuanto|strong="H3588"\w* nuestros padres \w no|strong="H3808"\w* \w guardaron|strong="H8104"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé, \w para|strong="H5921"\w* \w hacer|strong="H6213"\w* \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w está|strong="H2088"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w libro|strong="H5612"\w*».   
\p
\v 22 Entonces \w Hilcías|strong="H2518"\w* y \w los|strong="H3427"\w* \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* había designado \w fueron|strong="H3212"\w* \w a|strong="H3068"\w* ver \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w profetisa|strong="H5031"\w* Hulda, esposa \w de|strong="H1121"\w* Salum, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Tocate, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hasra, \w guarda|strong="H8104"\w* \w de|strong="H1121"\w* las vestiduras (\w ella|strong="H1931"\w* \w habitaba|strong="H3427"\w* \w en|strong="H3212"\w* Jerusalén, \w en|strong="H3212"\w* \w el|strong="H1931"\w* \w Segundo|strong="H4932"\w* Barrio), y \w le|strong="H1931"\w* \w hablaron|strong="H1696"\w* \w en|strong="H3212"\w* \w este|strong="H1931"\w* sentido.   
\p
\v 23 Ella les respondió: “\w Así|strong="H3541"\w* dice Yahvé, el \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*: Decid al varón \w que|strong="H3541"\w* os \w ha|strong="H3541"\w* \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* mí:  
\v 24 ‘\w Así|strong="H3541"\w* dice Yahvé: He \w aquí|strong="H2088"\w* yo \w traigo|strong="H7121"\w* \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* sus \w habitantes|strong="H3427"\w*, \w a|strong="H3068"\w* saber, \w todas|strong="H3605"\w* \w las|strong="H5921"\w* maldiciones \w que|strong="H5921"\w* \w están|strong="H3427"\w* \w escritas|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w libro|strong="H5612"\w* \w que|strong="H5921"\w* han leído \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 25 \w Por|strong="H8478"\w* \w cuanto|strong="H8478"\w* me han abandonado y han quemado incienso \w a|strong="H3068"\w* otros dioses, provocándome \w a|strong="H3068"\w* \w ira|strong="H2534"\w* con \w todas|strong="H3605"\w* las \w obras|strong="H4639"\w* \w de|strong="H8478"\w* sus \w manos|strong="H3027"\w*, \w por|strong="H8478"\w* tanto, mi \w ira|strong="H2534"\w* \w se|strong="H3808"\w* derramará sobre \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, y \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w apagará|strong="H3518"\w*’.  
\v 26 Pero \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w*, \w que|strong="H1697"\w* os \w ha|strong="H3541"\w* \w enviado|strong="H7971"\w* para consultar \w a|strong="H3068"\w* Yahvé, le diréis \w así|strong="H3541"\w*: ‘\w Así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé, el \w Dios|strong="H3068"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*: \w Por|strong="H1697"\w* cuanto \w oíste|strong="H8085"\w* las \w palabras|strong="H1697"\w* del libro,  
\v 27 \w y|strong="H1571"\w* tu \w corazón|strong="H3824"\w* \w se|strong="H5921"\w* enterneció \w y|strong="H1571"\w* \w te|strong="H5921"\w* humillaste \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Dios|strong="H3068"\w* \w al|strong="H5921"\w* \w oír|strong="H8085"\w* sus \w palabras|strong="H1697"\w* \w contra|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w y|strong="H1571"\w* \w contra|strong="H5921"\w* sus \w habitantes|strong="H3427"\w*, \w y|strong="H1571"\w* \w te|strong="H5921"\w* humillaste \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, rasgaste tus vestiduras \w y|strong="H1571"\w* lloraste \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w presencia|strong="H6440"\w*, yo \w también|strong="H1571"\w* \w te|strong="H5921"\w* he \w oído|strong="H8085"\w*, \w dice|strong="H5002"\w* Yahvé.  
\v 28 He \w aquí|strong="H2088"\w* \w que|strong="H3808"\w* yo \w te|strong="H5869"\w* recogeré \w con|strong="H5921"\w* tus padres, \w y|strong="H5921"\w* serás llevado \w a|strong="H3068"\w* tu \w sepulcro|strong="H6913"\w* \w en|strong="H5921"\w* \w paz|strong="H7965"\w*. Tus \w ojos|strong="H5869"\w* \w no|strong="H3808"\w* \w verán|strong="H7200"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H3808"\w* yo traigo \w sobre|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* sus \w habitantes|strong="H3427"\w*’”.  
\p \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* llevaron \w la|strong="H5921"\w* \w respuesta|strong="H1697"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*.   
\p
\v 29 Entonces \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w mandó|strong="H7971"\w* convocar \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de \w Judá|strong="H3063"\w* y de Jerusalén.  
\v 30 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Yahvé \w con|strong="H5704"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* hombres \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w y|strong="H5704"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5704"\w* Jerusalén, \w junto|strong="H5971"\w* \w con|strong="H5704"\w* \w los|strong="H3427"\w* \w sacerdotes|strong="H3548"\w*, \w los|strong="H3427"\w* \w levitas|strong="H3881"\w* \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w desde|strong="H5704"\w* \w el|strong="H3605"\w* \w mayor|strong="H1419"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w menor|strong="H6996"\w*. \w Y|strong="H3068"\w* \w leyó|strong="H7121"\w* \w a|strong="H3068"\w* oídos \w de|strong="H5704"\w* \w ellos|strong="H3605"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* del \w libro|strong="H5612"\w* del \w pacto|strong="H1285"\w* \w que|strong="H5704"\w* \w había|strong="H4672"\w* sido \w hallado|strong="H4672"\w* \w en|strong="H5704"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Yahvé.  
\v 31 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w se|strong="H5921"\w* \w puso|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w en|strong="H5921"\w* su lugar \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* un \w pacto|strong="H1285"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, comprometiéndose \w a|strong="H3068"\w* \w andar|strong="H3212"\w* \w en|strong="H5921"\w* pos \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w guardar|strong="H8104"\w* sus \w mandamientos|strong="H4687"\w*, sus testimonios \w y|strong="H5921"\w* sus \w estatutos|strong="H2706"\w* \w con|strong="H5921"\w* \w todo|strong="H3605"\w* su \w corazón|strong="H3824"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w toda|strong="H3605"\w* su \w alma|strong="H5315"\w*, poniendo \w por|strong="H5921"\w* \w obra|strong="H6213"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w del|strong="H5921"\w* \w pacto|strong="H1285"\w* \w escritas|strong="H3789"\w* \w en|strong="H5921"\w* \w aquel|strong="H2088"\w* \w libro|strong="H5612"\w*.  
\v 32 \w Y|strong="H3068"\w* obligó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H3605"\w* se \w hallaban|strong="H4672"\w* \w en|strong="H5975"\w* Jerusalén y \w en|strong="H5975"\w* \w Benjamín|strong="H1144"\w* \w a|strong="H3068"\w* \w que|strong="H3605"\w* se comprometieran \w a|strong="H3068"\w* cumplirlo. \w Y|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Jerusalén \w hicieron|strong="H6213"\w* conforme al \w pacto|strong="H1285"\w* de Dios, \w el|strong="H3605"\w* Dios de sus padres.  
\v 33 \w Josías|strong="H2977"\w* \w quitó|strong="H5493"\w* \w todas|strong="H3605"\w* las \w abominaciones|strong="H8441"\w* \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* territorios \w que|strong="H3808"\w* pertenecían \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w e|strong="H3068"\w* hizo \w que|strong="H3808"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* \w hallaban|strong="H4672"\w* \w en|strong="H5493"\w* \w Israel|strong="H3478"\w* sirvieran \w a|strong="H3068"\w* Yahvé su \w Dios|strong="H3068"\w*. \w Y|strong="H3068"\w* durante \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* apartaron \w de|strong="H1121"\w* seguir \w a|strong="H3068"\w* Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* sus padres.   
\c 35
\p
\v 1 \w Josías|strong="H2977"\w* celebró la \w Pascua|strong="H6453"\w* \w a|strong="H3068"\w* Yahvé en Jerusalén; \w e|strong="H3068"\w* inmolaron la \w Pascua|strong="H6453"\w* \w el|strong="H6213"\w* día catorce del \w primer|strong="H7223"\w* \w mes|strong="H2320"\w*.  
\v 2 Restableció \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w en|strong="H5921"\w* sus oficios, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w animó|strong="H2388"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* servicio \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé.  
\v 3 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w que|strong="H6258"\w* enseñaban \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* y \w que|strong="H6258"\w* \w estaban|strong="H5971"\w* consagrados \w a|strong="H3068"\w* Yahvé: «\w Poned|strong="H5414"\w* \w el|strong="H3605"\w* arca \w santa|strong="H6944"\w* en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w que|strong="H6258"\w* \w edificó|strong="H1129"\w* \w Salomón|strong="H8010"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. \w Ya|strong="H3068"\w* no \w la|strong="H3605"\w* llevaréis sobre \w los|strong="H1121"\w* \w hombros|strong="H3802"\w*. \w Ahora|strong="H6258"\w* \w servid|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé vuestro \w Dios|strong="H3068"\w* y \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.  
\v 4 Preparaos según vuestras \w casas|strong="H1004"\w* paternas y según vuestras divisiones, conforme \w a|strong="H3068"\w* lo escrito \w por|strong="H4428"\w* \w David|strong="H1732"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y conforme \w a|strong="H3068"\w* lo escrito \w por|strong="H4428"\w* su \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w*.  
\v 5 Poneos \w en|strong="H5975"\w* \w el|strong="H1121"\w* \w santuario|strong="H6944"\w* según \w los|strong="H1121"\w* grupos \w de|strong="H1121"\w* las \w familias|strong="H1004"\w* \w de|strong="H1121"\w* vuestros hermanos, \w los|strong="H1121"\w* laicos, \w de|strong="H1121"\w* modo \w que|strong="H5971"\w* \w a|strong="H3068"\w* cada grupo corresponda una porción \w de|strong="H1121"\w* una \w familia|strong="H1004"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*.  
\v 6 Inmolad la \w Pascua|strong="H6453"\w*, \w santificaos|strong="H6942"\w* y preparadla para vuestros hermanos, \w a|strong="H3068"\w* fin \w de|strong="H1697"\w* \w que|strong="H1697"\w* se \w haga|strong="H6213"\w* conforme \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé dada \w por|strong="H1697"\w* \w medio|strong="H3027"\w* \w de|strong="H1697"\w* \w Moisés|strong="H4872"\w*».   
\p
\v 7 \w Josías|strong="H2977"\w* donó \w para|strong="H5971"\w* \w los|strong="H1121"\w* laicos rebaños \w de|strong="H1121"\w* \w corderos|strong="H3532"\w* \w y|strong="H1241"\w* cabritos, \w por|strong="H4428"\w* un total \w de|strong="H1121"\w* \w treinta|strong="H7970"\w* mil, \w todos|strong="H3605"\w* \w para|strong="H5971"\w* las ofrendas \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w Pascua|strong="H6453"\w*, \w para|strong="H5971"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H5971"\w* \w estaban|strong="H5971"\w* presentes; además \w de|strong="H1121"\w* \w tres|strong="H7969"\w* mil \w novillos|strong="H1241"\w*. \w Todo|strong="H3605"\w* esto provenía \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w hacienda|strong="H7399"\w* del \w rey|strong="H4428"\w*.  
\v 8 También sus \w jefes|strong="H8269"\w* \w hicieron|strong="H5414"\w* donaciones \w voluntarias|strong="H5071"\w* \w para|strong="H5414"\w* el \w pueblo|strong="H5971"\w*, \w para|strong="H5414"\w* los \w sacerdotes|strong="H3548"\w* \w y|strong="H1241"\w* \w para|strong="H5414"\w* los \w levitas|strong="H3881"\w*. \w Hilcías|strong="H2518"\w*, \w Zacarías|strong="H2148"\w* \w y|strong="H1241"\w* \w Jehiel|strong="H3171"\w*, oficiales \w principales|strong="H8269"\w* \w de|strong="H5971"\w* la \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Dios, \w dieron|strong="H5414"\w* \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* \w para|strong="H5414"\w* los sacrificios \w de|strong="H5971"\w* la \w Pascua|strong="H6453"\w* dos \w mil|strong="H3967"\w* \w seiscientos|strong="H8337"\w* corderos \w y|strong="H1241"\w* cabritos, \w y|strong="H1241"\w* \w trescientos|strong="H7969"\w* \w novillos|strong="H1241"\w*.  
\v 9 Asimismo, Conanías, \w Semaías|strong="H8098"\w* \w y|strong="H1241"\w* Natanael, sus hermanos, junto con \w Hasabías|strong="H2811"\w*, \w Jeiel|strong="H3273"\w* \w y|strong="H1241"\w* \w Jozabad|strong="H3107"\w*, \w jefes|strong="H8269"\w* \w de|strong="H2568"\w* los \w levitas|strong="H3881"\w*, donaron \w a|strong="H3068"\w* los \w levitas|strong="H3881"\w* para los sacrificios \w de|strong="H2568"\w* la \w Pascua|strong="H6453"\w* \w cinco|strong="H2568"\w* \w mil|strong="H3967"\w* corderos \w y|strong="H1241"\w* cabritos, \w y|strong="H1241"\w* \w quinientos|strong="H2568"\w* \w novillos|strong="H1241"\w*.   
\p
\v 10 Así \w se|strong="H5921"\w* \w preparó|strong="H3559"\w* \w el|strong="H5921"\w* servicio. \w Los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w se|strong="H5921"\w* colocaron \w en|strong="H5921"\w* sus \w puestos|strong="H5975"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w en|strong="H5921"\w* sus divisiones, \w conforme|strong="H5921"\w* \w al|strong="H5921"\w* mandato \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.  
\v 11 Inmolaron la \w Pascua|strong="H6453"\w*, y los \w sacerdotes|strong="H3548"\w* rociaban la sangre \w que|strong="H3027"\w* recibían de \w manos|strong="H3027"\w* de los \w levitas|strong="H3881"\w*, mientras estos \w desollaban|strong="H6584"\w* las víctimas.  
\v 12 \w Luego|strong="H3651"\w* apartaron \w los|strong="H1121"\w* \w holocaustos|strong="H5930"\w* \w para|strong="H5414"\w* distribuirlos \w a|strong="H3068"\w* \w los|strong="H1121"\w* grupos \w de|strong="H1121"\w* las \w familias|strong="H1004"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* laicos, \w a|strong="H3068"\w* fin \w de|strong="H1121"\w* ofrecerlos \w a|strong="H3068"\w* Yahvé, \w como|strong="H3651"\w* \w está|strong="H3651"\w* \w escrito|strong="H3789"\w* \w en|strong="H5493"\w* \w el|strong="H1121"\w* \w libro|strong="H5612"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*. \w Y|strong="H3068"\w* \w lo|strong="H5612"\w* mismo \w hicieron|strong="H5414"\w* con \w los|strong="H1121"\w* \w novillos|strong="H1241"\w*.  
