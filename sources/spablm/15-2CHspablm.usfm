\v 27 Acaz \w durmió|strong="H7901"\w* \w con|strong="H5973"\w* sus padres \w y|strong="H3588"\w* \w lo|strong="H3808"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H5973"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*, \w en|strong="H5973"\w* Jerusalén, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* llevaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w sepulcros|strong="H6913"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* Ezequías \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* \w su|strong="H3588"\w* \w lugar|strong="H8478"\w*.   
\c 29
\p
\v 1 Ezequías comenzó \w a|strong="H3068"\w* reinar cuando tenía \w veinticinco|strong="H6242"\w* \w años|strong="H8141"\w*, y \w reinó|strong="H4427"\w* \w veintinueve|strong="H6242"\w* \w años|strong="H8141"\w* en Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H2568"\w* su madre \w era|strong="H8141"\w* Abías, \w hija|strong="H1323"\w* \w de|strong="H2568"\w* \w Zacarías|strong="H2148"\w*.  
\v 2 \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w recto|strong="H3477"\w* ante \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Yahvé, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* su padre \w David|strong="H1732"\w*.  
\v 3 En \w el|strong="H1931"\w* \w primer|strong="H7223"\w* \w año|strong="H8141"\w* de \w su|strong="H1931"\w* \w reinado|strong="H4427"\w*, en \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w primero|strong="H7223"\w*, \w abrió|strong="H6605"\w* las \w puertas|strong="H1817"\w* de \w la|strong="H1931"\w* \w casa|strong="H1004"\w* de Yahvé y las reparó.  
\v 4 Hizo venir \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* y \w a|strong="H3068"\w* los \w levitas|strong="H3881"\w*, los reunió en la plaza \w oriental|strong="H4217"\w*,  
\v 5 y les dijo: «¡\w Escuchadme|strong="H8085"\w*, \w levitas|strong="H3881"\w*! \w Santificaos|strong="H6942"\w* \w ahora|strong="H6258"\w*, y \w santificad|strong="H6942"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* Yahvé, el \w Dios|strong="H3068"\w* \w de|strong="H4480"\w* vuestros padres, y \w sacad|strong="H3318"\w* la inmundicia \w del|strong="H4480"\w* \w santuario|strong="H6944"\w*.  
\v 6 \w Porque|strong="H3588"\w* nuestros padres han prevaricado \w y|strong="H3588"\w* han \w hecho|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* \w ante|strong="H6440"\w* \w los|strong="H3588"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w*; \w lo|strong="H6213"\w* han abandonado, han apartado sus \w rostros|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* morada \w de|strong="H3588"\w* Yahvé, \w y|strong="H3588"\w* \w le|strong="H5869"\w* han vuelto \w la|strong="H3588"\w* espalda.  
\v 7 \w También|strong="H1571"\w* \w cerraron|strong="H5462"\w* las \w puertas|strong="H1817"\w* del pórtico \w y|strong="H1571"\w* apagaron las \w lámparas|strong="H5216"\w*; \w no|strong="H3808"\w* quemaron incienso \w ni|strong="H3808"\w* ofrecieron \w holocaustos|strong="H5930"\w* en \w el|strong="H1571"\w* \w santuario|strong="H6944"\w* \w al|strong="H5930"\w* Dios de \w Israel|strong="H3478"\w*.  
\v 8 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w la|strong="H5921"\w* \w ira|strong="H7110"\w* \w de|strong="H5921"\w* Yahvé ha caído \w sobre|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* Jerusalén, \w y|strong="H5921"\w* \w los|strong="H5921"\w* ha \w entregado|strong="H5414"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w sean|strong="H1961"\w* objeto \w de|strong="H5921"\w* \w espanto|strong="H8047"\w*, \w de|strong="H5921"\w* horror \w y|strong="H5921"\w* \w de|strong="H5921"\w* burla, \w como|strong="H1961"\w* \w lo|strong="H5921"\w* \w veis|strong="H7200"\w* \w con|strong="H5921"\w* vuestros propios \w ojos|strong="H5869"\w*.  
\v 9 \w Porque|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* nuestros padres han \w caído|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w esta|strong="H2063"\w* causa nuestros \w hijos|strong="H1121"\w*, nuestras \w hijas|strong="H1323"\w* \w y|strong="H5921"\w* nuestras \w mujeres|strong="H1323"\w* \w están|strong="H2009"\w* \w en|strong="H5921"\w* \w cautiverio|strong="H7628"\w*.  
\v 10 \w Ahora|strong="H6258"\w* he propuesto \w en|strong="H4480"\w* mi \w corazón|strong="H3824"\w* \w hacer|strong="H3772"\w* un \w pacto|strong="H1285"\w* \w con|strong="H5973"\w* Yahvé, \w el|strong="H5973"\w* \w Dios|strong="H3068"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w el|strong="H5973"\w* ardor \w de|strong="H4480"\w* su \w ira|strong="H2740"\w* \w se|strong="H4480"\w* \w aparte|strong="H5973"\w* \w de|strong="H4480"\w* \w nosotros|strong="H5973"\w*.  
\v 11 \w Hijos|strong="H1121"\w* míos, \w no|strong="H3588"\w* \w seáis|strong="H1961"\w* negligentes \w ahora|strong="H6258"\w*, \w porque|strong="H3588"\w* Yahvé os ha elegido \w para|strong="H3588"\w* \w que|strong="H3588"\w* estéis \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w* \w y|strong="H3588"\w* le sirváis, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w seáis|strong="H1961"\w* sus \w ministros|strong="H8334"\w* \w y|strong="H3588"\w* le queméis incienso».   
\p
\v 12 Entonces \w se|strong="H4480"\w* \w levantaron|strong="H6965"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*: Mahat, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Amasai|strong="H6022"\w*, y \w Joel|strong="H3100"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Azarías|strong="H5838"\w*, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Coat; \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Merari|strong="H4847"\w*: \w Cis|strong="H7027"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Abdi, y \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Jehalelel; \w de|strong="H4480"\w* \w los|strong="H1121"\w* gersonitas: Joa, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Zima, y Edén, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Joa;  
\v 13 \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Elizafán: \w Simri|strong="H8113"\w* y \w Jeiel|strong="H3273"\w*; \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Asaf: \w Zacarías|strong="H2148"\w* y Matanías;  
\v 14 \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Hemán|strong="H1968"\w*: \w Jehiel|strong="H3171"\w* y Simei; y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Jedutún: \w Semaías|strong="H8098"\w* y Uziel.  
\v 15 Reunieron \w a|strong="H3068"\w* sus hermanos, se santificaron y entraron para limpiar la \w casa|strong="H1004"\w* \w de|strong="H1697"\w* Yahvé, conforme \w al|strong="H4428"\w* mandato del \w rey|strong="H4428"\w* y \w a|strong="H3068"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé.  
