\c 24
\p
\v 1 \w Joás|strong="H3101"\w* tenía \w siete|strong="H7651"\w* \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* cuarenta \w años|strong="H8141"\w* en Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su madre \w era|strong="H8141"\w* Sibia, \w de|strong="H1121"\w* Beerseba.  
\v 2 \w Joás|strong="H3101"\w* \w hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w recto|strong="H3477"\w* ante \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Yahvé \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* del \w sacerdote|strong="H3548"\w* \w Joiada|strong="H3077"\w*.  
\v 3 \w Joiada|strong="H3077"\w* \w tomó|strong="H5375"\w* para \w él|strong="H1121"\w* \w dos|strong="H8147"\w* \w mujeres|strong="H1323"\w*, y \w engendró|strong="H3205"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.   
\p
\v 4 \w Aconteció|strong="H1961"\w* \w después|strong="H1961"\w* \w de|strong="H5973"\w* esto, \w que|strong="H1961"\w* \w Joás|strong="H3101"\w* decidió \w en|strong="H5973"\w* su \w corazón|strong="H3820"\w* restaurar la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Yahvé.  
\v 5 Reunió \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w*, y les dijo: «\w Salid|strong="H3318"\w* \w por|strong="H1697"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w* y recoged \w dinero|strong="H3701"\w* \w de|strong="H1697"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w año|strong="H8141"\w* tras \w año|strong="H8141"\w*, para reparar \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1697"\w* vuestro Dios. Procurad apresurar este \w asunto|strong="H1697"\w*». Pero \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* apresuraron.  
\v 6 Entonces \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w llamó|strong="H7121"\w* \w al|strong="H5921"\w* \w sumo|strong="H7218"\w* sacerdote \w Joiada|strong="H3077"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijo: «¿\w Por|strong="H5921"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* has exigido \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w que|strong="H3808"\w* traigan \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* Jerusalén \w el|strong="H5921"\w* tributo \w que|strong="H3808"\w* \w Moisés|strong="H4872"\w*, \w siervo|strong="H5650"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w congregación|strong="H6951"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* establecieron \w para|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* \w Testimonio|strong="H5715"\w*?»  
\v 7 \w Pues|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* aquella mujer impía, \w Atalía|strong="H6271"\w*, habían saqueado \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Dios|strong="H3068"\w*, \w y|strong="H1571"\w* habían \w empleado|strong="H6213"\w* \w todas|strong="H3605"\w* las cosas consagradas \w de|strong="H3588"\w* \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé \w para|strong="H3588"\w* \w el|strong="H3588"\w* culto \w de|strong="H3588"\w* \w los|strong="H1121"\w* baales.   
\p
\v 8 \w Por|strong="H5414"\w* orden del \w rey|strong="H4428"\w*, \w hicieron|strong="H6213"\w* un cofre y \w lo|strong="H6213"\w* \w pusieron|strong="H5414"\w* \w afuera|strong="H2351"\w*, \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* \w de|strong="H5414"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Yahvé.  
\v 9 Luego publicaron un edicto \w en|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* Jerusalén, \w para|strong="H5921"\w* \w que|strong="H5921"\w* trajeran \w a|strong="H3068"\w* Yahvé \w el|strong="H5921"\w* tributo \w que|strong="H5921"\w* \w Moisés|strong="H4872"\w*, \w siervo|strong="H5650"\w* \w de|strong="H5921"\w* \w Dios|strong="H3068"\w*, había impuesto \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*.  
\v 10 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w príncipes|strong="H8269"\w* \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* alegraron, \w y|strong="H5704"\w* trajeron \w el|strong="H3605"\w* dinero \w y|strong="H5704"\w* \w lo|strong="H5704"\w* echaron \w en|strong="H5704"\w* \w el|strong="H3605"\w* cofre \w hasta|strong="H5704"\w* llenarlo.  
\v 11 Ocurría \w que|strong="H3588"\w*, \w cuando|strong="H3588"\w* \w el|strong="H3588"\w* cofre \w era|strong="H1961"\w* \w llevado|strong="H5375"\w* \w por|strong="H3588"\w* \w los|strong="H1961"\w* \w levitas|strong="H3881"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* inspectores del \w rey|strong="H4428"\w*, \w al|strong="H6256"\w* \w ver|strong="H7200"\w* estos \w que|strong="H3588"\w* \w había|strong="H1961"\w* \w mucho|strong="H7227"\w* \w dinero|strong="H3701"\w*, venían \w el|strong="H3588"\w* \w escriba|strong="H5608"\w* del \w rey|strong="H4428"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* delegado del \w sumo|strong="H7218"\w* \w sacerdote|strong="H3548"\w*, vaciaban \w el|strong="H3588"\w* cofre, \w y|strong="H3588"\w* \w luego|strong="H6256"\w* \w lo|strong="H6213"\w* tomaban \w y|strong="H3588"\w* \w lo|strong="H6213"\w* devolvían \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w lugar|strong="H4725"\w*. \w Así|strong="H3541"\w* \w lo|strong="H6213"\w* \w hacían|strong="H6213"\w* \w día|strong="H3117"\w* tras \w día|strong="H3117"\w*, \w y|strong="H3588"\w* recogieron muchísimo \w dinero|strong="H3701"\w*.  
\v 12 \w El|strong="H6213"\w* \w rey|strong="H4428"\w* \w y|strong="H1571"\w* \w Joiada|strong="H3077"\w* \w lo|strong="H6213"\w* entregaban \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w que|strong="H1571"\w* dirigían \w la|strong="H1571"\w* \w obra|strong="H4399"\w* del servicio \w de|strong="H5414"\w* \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Yahvé. \w Estos|strong="H1571"\w* contrataron \w canteros|strong="H2672"\w* \w y|strong="H1571"\w* \w carpinteros|strong="H2796"\w* \w para|strong="H5414"\w* restaurar \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Yahvé, \w y|strong="H1571"\w* \w también|strong="H1571"\w* artesanos \w que|strong="H1571"\w* \w trabajaban|strong="H6213"\w* \w el|strong="H6213"\w* \w hierro|strong="H1270"\w* \w y|strong="H1571"\w* \w el|strong="H6213"\w* bronce \w para|strong="H5414"\w* reparar \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Yahvé.  
\v 13 Así \w trabajaron|strong="H6213"\w* \w los|strong="H5921"\w* obreros, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w de|strong="H5921"\w* restauración avanzó \w en|strong="H5921"\w* sus \w manos|strong="H3027"\w*; repararon \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Dios, \w la|strong="H5921"\w* devolvieron \w a|strong="H3068"\w* su diseño original \w y|strong="H5921"\w* \w la|strong="H5921"\w* reforzaron.  
\v 14 \w Cuando|strong="H3117"\w* terminaron, \w trajeron|strong="H6213"\w* \w el|strong="H3605"\w* \w dinero|strong="H3701"\w* \w que|strong="H3117"\w* sobraba \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w* y \w de|strong="H6440"\w* \w Joiada|strong="H3077"\w*. Con \w él|strong="H3605"\w* \w se|strong="H1961"\w* \w hicieron|strong="H6213"\w* utensilios \w para|strong="H1961"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H6440"\w* Yahvé, tanto \w para|strong="H1961"\w* \w el|strong="H3605"\w* servicio y \w para|strong="H1961"\w* ofrecer \w holocaustos|strong="H5930"\w*, \w como|strong="H1961"\w* \w cucharas|strong="H3709"\w* y \w vasos|strong="H3627"\w* \w de|strong="H6440"\w* \w oro|strong="H2091"\w* y \w plata|strong="H3701"\w*. \w Y|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H6440"\w* \w Joiada|strong="H3077"\w* \w se|strong="H1961"\w* ofrecieron \w holocaustos|strong="H5930"\w* \w continuamente|strong="H8548"\w* en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H6440"\w* Yahvé.   
\p
