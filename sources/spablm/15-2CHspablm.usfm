\v 17 \w El|strong="H1121"\w* registro genealógico \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* se hacía según sus \w casas|strong="H1004"\w* paternas, y \w el|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, \w de|strong="H1121"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* para \w arriba|strong="H4605"\w*, se hacía \w por|strong="H3881"\w* sus oficios y divisiones.  
\v 18 Estaban también registrados \w con|strong="H3588"\w* \w todos|strong="H3605"\w* sus \w niños|strong="H2945"\w*, sus \w mujeres|strong="H1323"\w*, sus \w hijos|strong="H1121"\w* \w y|strong="H3588"\w* sus \w hijas|strong="H1323"\w*, \w es|strong="H3588"\w* decir, \w toda|strong="H3605"\w* \w la|strong="H3588"\w* asamblea; \w porque|strong="H3588"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* cargo \w de|strong="H3588"\w* confianza se \w consagraban|strong="H6942"\w* \w en|strong="H3588"\w* \w santidad|strong="H6944"\w*.  
\v 19 También \w para|strong="H5414"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H1121"\w* estaban en \w los|strong="H1121"\w* \w campos|strong="H7704"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w ejidos|strong="H4054"\w* \w de|strong="H1121"\w* sus \w ciudades|strong="H5892"\w*, en \w todas|strong="H3605"\w* y \w cada|strong="H3605"\w* una \w de|strong="H1121"\w* las \w ciudades|strong="H5892"\w*, había \w hombres|strong="H1121"\w* designados \w por|strong="H5414"\w* \w nombre|strong="H8034"\w* \w para|strong="H5414"\w* distribuir las \w porciones|strong="H4490"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w varones|strong="H2145"\w* entre \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* estaban en \w los|strong="H1121"\w* registros genealógicos \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*.   
\p
\v 20 \w Así|strong="H2063"\w* \w hizo|strong="H6213"\w* Ezequías en \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w*, actuando con bondad, rectitud y verdad \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, su \w Dios|strong="H3068"\w*.  
\v 21 \w Y|strong="H3068"\w* en \w toda|strong="H3605"\w* \w obra|strong="H4639"\w* \w que|strong="H3605"\w* emprendió para \w el|strong="H3605"\w* servicio de \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de Dios, así como en \w la|strong="H3605"\w* \w ley|strong="H8451"\w* y en \w los|strong="H3605"\w* \w mandamientos|strong="H4687"\w*, \w buscando|strong="H1875"\w* \w a|strong="H3068"\w* su Dios, \w lo|strong="H6213"\w* \w hizo|strong="H6213"\w* de \w todo|strong="H3605"\w* \w corazón|strong="H3824"\w*, y fue \w prosperado|strong="H6743"\w*.   
\c 32
\p
\v 1 \w Después|strong="H5921"\w* \w de|strong="H5921"\w* estos actos \w de|strong="H5921"\w* gran fidelidad, Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, vino \w e|strong="H3068"\w* invadió \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*. Acampó \w contra|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w*, \w con|strong="H5921"\w* \w la|strong="H5921"\w* intención \w de|strong="H5921"\w* conquistarlas \w para|strong="H5921"\w* \w sí|strong="H5921"\w*.  
\v 2 \w Cuando|strong="H3588"\w* Ezequías \w vio|strong="H7200"\w* \w que|strong="H3588"\w* Senaquerib \w había|strong="H3588"\w* llegado \w con|strong="H5921"\w* \w el|strong="H5921"\w* claro propósito \w de|strong="H5921"\w* atacar \w a|strong="H3068"\w* Jerusalén,  
\v 3 se reunió \w con|strong="H5973"\w* sus \w jefes|strong="H8269"\w* y \w con|strong="H5973"\w* sus \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* \w para|strong="H5973"\w* cegar las \w fuentes|strong="H5869"\w* \w de|strong="H5973"\w* \w agua|strong="H4325"\w* \w que|strong="H4325"\w* \w estaban|strong="H4325"\w* \w fuera|strong="H2351"\w* \w de|strong="H5973"\w* la \w ciudad|strong="H5892"\w*; y ellos lo apoyaron.  
\v 4 \w Se|strong="H5971"\w* reunió, \w pues|strong="H6908"\w*, \w mucha|strong="H7227"\w* \w gente|strong="H5971"\w*, y \w cegaron|strong="H5640"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* manantiales y \w el|strong="H3605"\w* \w arroyo|strong="H5158"\w* \w que|strong="H4100"\w* fluía \w por|strong="H4100"\w* \w medio|strong="H8432"\w* del territorio, diciendo: «¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* han \w de|strong="H5971"\w* venir \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* \w de|strong="H5971"\w* Asiria y \w hallar|strong="H4672"\w* \w agua|strong="H4325"\w* \w en|strong="H8432"\w* abundancia?»   
\p
\v 5 Ezequías cobró \w ánimo|strong="H2388"\w*, reconstruyó \w todos|strong="H3605"\w* \w los|strong="H5921"\w* tramos caídos \w de|strong="H5921"\w* \w la|strong="H5921"\w* muralla, levantó \w torres|strong="H4026"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*, \w edificó|strong="H1129"\w* \w otra|strong="H6213"\w* muralla exterior, \w fortificó|strong="H2388"\w* \w el|strong="H5921"\w* Milo \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*, \w y|strong="H5921"\w* fabricó gran cantidad \w de|strong="H5921"\w* armas \w y|strong="H5921"\w* \w escudos|strong="H4043"\w*.  
\v 6 \w Puso|strong="H5414"\w* \w jefes|strong="H8269"\w* militares \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w los|strong="H5921"\w* reunió \w en|strong="H5921"\w* \w la|strong="H5921"\w* plaza \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w habló|strong="H1696"\w* \w al|strong="H5921"\w* \w corazón|strong="H3824"\w*, \w diciendo|strong="H1696"\w*:  
\v 7 «\w Esforzaos|strong="H2388"\w* \w y|strong="H3588"\w* sed valientes. \w No|strong="H3588"\w* \w temáis|strong="H3372"\w* \w ni|strong="H5973"\w* \w os|strong="H5973"\w* acobardéis \w ante|strong="H6440"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Asiria, \w ni|strong="H5973"\w* \w ante|strong="H6440"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w multitud|strong="H1995"\w* \w que|strong="H3588"\w* viene \w con|strong="H5973"\w* \w él|strong="H5973"\w*; \w porque|strong="H3588"\w* \w con|strong="H5973"\w* \w nosotros|strong="H3605"\w* \w hay|strong="H3372"\w* uno \w mayor|strong="H7227"\w* \w que|strong="H3588"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*.  
\v 8 \w Con|strong="H5973"\w* \w él|strong="H5921"\w* \w está|strong="H5921"\w* un \w brazo|strong="H2220"\w* \w de|strong="H5921"\w* \w carne|strong="H1320"\w*, pero \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w está|strong="H5921"\w* Yahvé nuestro \w Dios|strong="H3068"\w* \w para|strong="H5921"\w* ayudarnos \w y|strong="H5921"\w* pelear nuestras \w batallas|strong="H4421"\w*». \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5921"\w* sintió confortado \w con|strong="H5973"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\p
\v 9 \w Después|strong="H5921"\w* \w de|strong="H5921"\w* \w esto|strong="H2088"\w*, \w mientras|strong="H3605"\w* Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, estaba frente \w a|strong="H3068"\w* Laquis \w con|strong="H5973"\w* \w todas|strong="H3605"\w* \w sus|strong="H1931"\w* fuerzas, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w siervos|strong="H5650"\w* \w a|strong="H3068"\w* Jerusalén, \w para|strong="H5921"\w* decir \w a|strong="H3068"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w que|strong="H1931"\w* estaban \w en|strong="H5921"\w* Jerusalén:  
\v 10 “\w Así|strong="H3541"\w* dice Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria: ‘¿\w En|strong="H5921"\w* \w qué|strong="H4100"\w* confiáis, \w para|strong="H5921"\w* permanecer sitiados \w en|strong="H5921"\w* Jerusalén?  
\v 11 ¿\w No|strong="H3808"\w* os engaña Ezequías \w para|strong="H5414"\w* entregaros \w a|strong="H3068"\w* la \w muerte|strong="H4191"\w* \w por|strong="H5414"\w* \w hambre|strong="H7458"\w* y \w sed|strong="H6772"\w*, \w al|strong="H4428"\w* deciros: Yahvé nuestro \w Dios|strong="H3068"\w* nos \w librará|strong="H5337"\w* \w de|strong="H5414"\w* la \w mano|strong="H3709"\w* del \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Asiria?  
\v 12 ¿Acaso \w no|strong="H3808"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w mismo|strong="H1931"\w* Ezequías \w quien|strong="H1931"\w* \w ha|strong="H3808"\w* quitado \w sus|strong="H1931"\w* lugares \w altos|strong="H1116"\w* \w y|strong="H5921"\w* \w sus|strong="H1931"\w* \w altares|strong="H4196"\w*, \w y|strong="H5921"\w* \w ha|strong="H3808"\w* dado \w la|strong="H1931"\w* orden \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Jerusalén, diciendo: Solamente \w delante|strong="H6440"\w* \w de|strong="H5921"\w* un \w altar|strong="H4196"\w* \w adoraréis|strong="H7812"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* quemaréis incienso?  
\v 13 ¿\w No|strong="H3808"\w* \w sabéis|strong="H3045"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w yo|strong="H6213"\w* y mis padres hemos \w hecho|strong="H6213"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* las tierras? ¿Acaso \w los|strong="H3605"\w* dioses \w de|strong="H5971"\w* las \w naciones|strong="H1471"\w* \w de|strong="H5971"\w* esas tierras fueron capaces \w de|strong="H5971"\w* \w librar|strong="H5337"\w* su tierra \w de|strong="H5971"\w* mi \w mano|strong="H3027"\w*?  
