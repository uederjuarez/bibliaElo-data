\c 31
\p
\v 1 \w Cuando|strong="H5704"\w* \w todo|strong="H3605"\w* \w esto|strong="H2063"\w* terminó, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* israelitas \w que|strong="H5704"\w* estaban allí \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w y|strong="H5704"\w* rompieron \w los|strong="H1121"\w* pilares sagrados, talaron las imágenes \w de|strong="H5704"\w* Asera \w y|strong="H5704"\w* derribaron \w los|strong="H1121"\w* \w lugares|strong="H5892"\w* \w altos|strong="H1116"\w* \w y|strong="H5704"\w* \w los|strong="H1121"\w* \w altares|strong="H4196"\w* \w en|strong="H5704"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* \w y|strong="H5704"\w* \w Benjamín|strong="H1144"\w*, \w así|strong="H2063"\w* \w como|strong="H5704"\w* \w en|strong="H5704"\w* Efraín \w y|strong="H5704"\w* \w Manasés|strong="H4519"\w*, \w hasta|strong="H5704"\w* \w destruirlos|strong="H3615"\w* \w por|strong="H5704"\w* completo. \w Después|strong="H5704"\w*, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* regresaron \w a|strong="H3068"\w* sus propias \w ciudades|strong="H5892"\w*, \w cada|strong="H3605"\w* uno \w a|strong="H3068"\w* su heredad.   
