\v 21 \w Pero|strong="H3588"\w* Necao \w le|strong="H5921"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w*, diciendo: «¿\w Qué|strong="H3588"\w* \w tengo|strong="H5921"\w* \w yo|strong="H3588"\w* \w que|strong="H3588"\w* ver \w contigo|strong="H5973"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*? \w Hoy|strong="H3117"\w* \w no|strong="H3808"\w* vengo \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w sino|strong="H3588"\w* \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w con|strong="H5973"\w* \w la|strong="H5921"\w* \w cual|strong="H4100"\w* estoy \w en|strong="H5921"\w* \w guerra|strong="H4421"\w*. Dios \w me|strong="H5921"\w* \w ha|strong="H3808"\w* ordenado \w que|strong="H3588"\w* \w me|strong="H5921"\w* apresure; \w deja|strong="H7971"\w* \w de|strong="H5921"\w* oponerte \w a|strong="H3068"\w* Dios, \w que|strong="H3588"\w* \w está|strong="H5921"\w* \w conmigo|strong="H5973"\w*, \w no|strong="H3808"\w* sea \w que|strong="H3588"\w* \w él|strong="H5921"\w* \w te|strong="H5921"\w* \w destruya|strong="H7843"\w*».   
\p
\v 22 \w Pero|strong="H3588"\w* \w Josías|strong="H2977"\w* \w no|strong="H3808"\w* quiso \w apartarse|strong="H3808"\w* \w de|strong="H4480"\w* \w él|strong="H3588"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H4480"\w* disfrazó \w para|strong="H3588"\w* presentarle batalla. \w No|strong="H3808"\w* \w escuchó|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H4480"\w* Necao, \w que|strong="H3588"\w* venían \w de|strong="H4480"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H4480"\w* Dios, \w y|strong="H3588"\w* \w fue|strong="H3808"\w* \w a|strong="H3068"\w* pelear \w al|strong="H4480"\w* valle \w de|strong="H4480"\w* Meguido.  
