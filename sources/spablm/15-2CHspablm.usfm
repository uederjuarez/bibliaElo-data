\v 20 \w Pero|strong="H3588"\w* Amasías \w no|strong="H3808"\w* quiso \w escuchar|strong="H8085"\w*, \w porque|strong="H3588"\w* \w esto|strong="H1931"\w* venía \w de|strong="H3588"\w* Dios, \w para|strong="H4616"\w* entregarlos \w en|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w sus|strong="H1931"\w* enemigos, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* habían buscado \w a|strong="H3068"\w* \w los|strong="H1931"\w* dioses \w de|strong="H3588"\w* Edom.  
\v 21 \w Subió|strong="H5927"\w*, \w pues|strong="H7200"\w*, \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*; y \w él|strong="H1931"\w* y Amasías, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*, \w se|strong="H1931"\w* enfrentaron en Bet Semes, \w que|strong="H1931"\w* pertenece \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*.  
