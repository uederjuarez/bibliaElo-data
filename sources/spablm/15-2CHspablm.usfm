\v 15 \w Los|strong="H1121"\w* \w cantores|strong="H7891"\w*, \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Asaf, \w estaban|strong="H4612"\w* \w en|strong="H5921"\w* sus puestos, \w conforme|strong="H5921"\w* \w al|strong="H5921"\w* mandato \w de|strong="H5921"\w* \w David|strong="H1732"\w*, \w de|strong="H5921"\w* Asaf, \w de|strong="H5921"\w* \w Hemán|strong="H1968"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* Jedutún, \w el|strong="H5921"\w* \w vidente|strong="H2374"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*. \w Los|strong="H1121"\w* \w porteros|strong="H7778"\w* \w estaban|strong="H4612"\w* \w en|strong="H5921"\w* cada \w puerta|strong="H8179"\w*, \w y|strong="H3588"\w* \w no|strong="H3588"\w* tenían necesidad \w de|strong="H5921"\w* \w apartarse|strong="H5493"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w ministerio|strong="H5656"\w*, \w porque|strong="H3588"\w* sus hermanos \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* preparaban \w la|strong="H5921"\w* comida \w para|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
