\v 8 En \w el|strong="H1121"\w* \w año|strong="H8141"\w* \w dieciocho|strong="H8083"\w* \w de|strong="H1121"\w* su \w reinado|strong="H4427"\w*, habiendo purificado la tierra y la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Dios|strong="H3068"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Safán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Azalía, \w a|strong="H3068"\w* \w Maasías|strong="H4641"\w*, \w gobernador|strong="H8269"\w* \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w*, y \w a|strong="H3068"\w* Joa, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Joacaz, \w el|strong="H1121"\w* cronista, para \w que|strong="H1121"\w* repararan la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Yahvé su \w Dios|strong="H3068"\w*.  
\v 9 \w Ellos|strong="H3027"\w* vinieron al \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w* y le entregaron \w el|strong="H3605"\w* \w dinero|strong="H3701"\w* \w que|strong="H3605"\w* había sido depositado en \w la|strong="H8104"\w* \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Dios, \w el|strong="H3605"\w* cual \w los|strong="H3427"\w* \w levitas|strong="H3881"\w* guardianes del umbral habían recolectado \w de|strong="H5414"\w* \w Manasés|strong="H4519"\w*, \w de|strong="H5414"\w* Efraín y \w de|strong="H5414"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* remanente \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*, así como \w de|strong="H5414"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w*, \w de|strong="H5414"\w* \w Benjamín|strong="H1144"\w* y \w de|strong="H5414"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5414"\w* Jerusalén.  
\v 10 \w Lo|strong="H5921"\w* \w pusieron|strong="H5414"\w* \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* capataces encargados \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* estos \w lo|strong="H5921"\w* distribuían \w a|strong="H3068"\w* \w los|strong="H5921"\w* obreros \w que|strong="H5921"\w* \w trabajaban|strong="H6213"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé, \w para|strong="H5921"\w* reparar \w y|strong="H5921"\w* restaurar \w el|strong="H5921"\w* \w templo|strong="H1004"\w*.  
\v 11 Lo \w daban|strong="H5414"\w* \w a|strong="H3068"\w* los \w carpinteros|strong="H2796"\w* y constructores \w para|strong="H5414"\w* comprar piedra \w de|strong="H5414"\w* sillería y \w madera|strong="H6086"\w* \w para|strong="H5414"\w* las armaduras, y \w para|strong="H5414"\w* enmaderar los edificios que los \w reyes|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w* habían dejado arruinar.  
\v 12 \w Estos|strong="H3605"\w* \w hombres|strong="H1121"\w* \w hacían|strong="H6213"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w con|strong="H5921"\w* fidelidad. \w Los|strong="H1121"\w* capataces encargados \w de|strong="H4480"\w* dirigirlos eran \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* Jahat \w y|strong="H5921"\w* \w Abdías|strong="H5662"\w*, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Merari|strong="H4847"\w*; \w y|strong="H5921"\w* \w Zacarías|strong="H2148"\w* \w y|strong="H5921"\w* Mesulam, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Coat. También participaban \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H4480"\w* eran hábiles \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w instrumentos|strong="H3627"\w* musicales.  
\v 13 Estaban \w a|strong="H3068"\w* cargo \w de|strong="H5921"\w* \w los|strong="H5921"\w* cargadores \w y|strong="H5921"\w* dirigían \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* obreros \w en|strong="H5921"\w* \w cada|strong="H3605"\w* tipo \w de|strong="H5921"\w* trabajo; \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w*, algunos eran \w escribas|strong="H5608"\w*, \w oficiales|strong="H7860"\w* \w y|strong="H5921"\w* \w porteros|strong="H7778"\w*.   
\p
