\c 7
\p
\v 1 Cuando \w Salomón|strong="H8010"\w* terminó de orar, \w descendió|strong="H3381"\w* fuego del \w cielo|strong="H8064"\w* \w y|strong="H3519"\w* \w consumió|strong="H3615"\w* el \w holocausto|strong="H5930"\w* \w y|strong="H3519"\w* los \w sacrificios|strong="H2077"\w*, \w y|strong="H3519"\w* la \w gloria|strong="H3519"\w* de Yahvé \w llenó|strong="H4390"\w* la \w casa|strong="H1004"\w*.  
\v 2 \w Los|strong="H3588"\w* \w sacerdotes|strong="H3548"\w* \w no|strong="H3808"\w* \w podían|strong="H3201"\w* entrar \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w gloria|strong="H3519"\w* \w de|strong="H3588"\w* Yahvé \w había|strong="H3588"\w* llenado \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé.  
\v 3 \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* observaban \w cuando|strong="H3588"\w* \w el|strong="H5921"\w* fuego \w descendía|strong="H3381"\w* \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* posaba \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*. \w Se|strong="H5921"\w* postraron rostro \w en|strong="H5921"\w* tierra \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* pavimento, \w adoraron|strong="H7812"\w* \w y|strong="H3588"\w* dieron gracias \w a|strong="H3068"\w* Yahvé, diciendo:  
\q1 «\w Porque|strong="H3588"\w* \w él|strong="H5921"\w* \w es|strong="H3588"\w* \w bueno|strong="H2896"\w*,  
\q2 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w es|strong="H3588"\w* \w eterna|strong="H5769"\w*».   
\p
\v 4 Entonces \w el|strong="H3605"\w* \w rey|strong="H4428"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* ofrecieron \w sacrificios|strong="H2077"\w* \w ante|strong="H6440"\w* Yahvé.  
\v 5 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w ofreció|strong="H2076"\w* un \w sacrificio|strong="H2077"\w* \w de|strong="H5971"\w* \w veintidós|strong="H6242"\w* \w mil|strong="H3967"\w* reses \w y|strong="H1241"\w* \w ciento|strong="H3967"\w* \w veinte|strong="H6242"\w* \w mil|strong="H3967"\w* \w ovejas|strong="H6629"\w*. Así dedicaron \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Dios \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w y|strong="H1241"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*.  
\v 6 \w Los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w estaban|strong="H5975"\w* \w de|strong="H5921"\w* \w pie|strong="H5975"\w* \w en|strong="H5921"\w* sus \w puestos|strong="H5975"\w*; \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* también, \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w instrumentos|strong="H3627"\w* musicales \w de|strong="H5921"\w* Yahvé \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w había|strong="H5975"\w* \w hecho|strong="H6213"\w* \w para|strong="H5921"\w* \w alabar|strong="H1984"\w* \w a|strong="H3068"\w* Yahvé (\w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w es|strong="H3027"\w* \w eterna|strong="H5769"\w*), \w cuando|strong="H3588"\w* \w David|strong="H1732"\w* ofrecía alabanzas \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w*. \w Los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w tocaban|strong="H2690"\w* \w las|strong="H5921"\w* \w trompetas|strong="H2690"\w* \w frente|strong="H5048"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w*, \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w estaba|strong="H5975"\w* \w de|strong="H5921"\w* \w pie|strong="H5975"\w*.   
\p
\v 7 \w Además|strong="H3588"\w*, \w Salomón|strong="H8010"\w* consagró \w el|strong="H3588"\w* centro \w del|strong="H4196"\w* \w atrio|strong="H2691"\w* \w que|strong="H3588"\w* \w estaba|strong="H1004"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé, \w porque|strong="H3588"\w* \w allí|strong="H8033"\w* \w ofreció|strong="H6213"\w* \w los|strong="H3588"\w* \w holocaustos|strong="H5930"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* grasa \w de|strong="H3588"\w* \w los|strong="H3588"\w* sacrificios \w de|strong="H3588"\w* comunión, ya \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w altar|strong="H4196"\w* \w de|strong="H3588"\w* bronce \w que|strong="H3588"\w* \w Salomón|strong="H8010"\w* \w había|strong="H6942"\w* \w hecho|strong="H6213"\w* \w no|strong="H3808"\w* tenía capacidad \w para|strong="H3588"\w* recibir \w el|strong="H3588"\w* \w holocausto|strong="H5930"\w*, \w la|strong="H3588"\w* \w ofrenda|strong="H4503"\w* \w de|strong="H3588"\w* cereal \w y|strong="H3588"\w* \w la|strong="H3588"\w* grasa.   
\p
\v 8 \w Salomón|strong="H8010"\w* celebró \w entonces|strong="H3117"\w* \w la|strong="H1931"\w* \w fiesta|strong="H2282"\w* durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*, \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w*, una asamblea grandísima, congregada \w desde|strong="H5704"\w* \w la|strong="H1931"\w* entrada \w de|strong="H5973"\w* Hamat \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w torrente|strong="H5158"\w* \w de|strong="H5973"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 9 \w El|strong="H3588"\w* \w octavo|strong="H8066"\w* \w día|strong="H3117"\w* celebraron una asamblea solemne, \w pues|strong="H3588"\w* habían celebrado \w la|strong="H3588"\w* dedicación \w del|strong="H4196"\w* \w altar|strong="H4196"\w* durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w fiesta|strong="H2282"\w* durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.  
\v 10 \w El|strong="H5921"\w* \w día|strong="H3117"\w* \w veintitrés|strong="H6242"\w* \w del|strong="H5921"\w* \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w*, \w despidió|strong="H7971"\w* \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* sus tiendas, \w alegres|strong="H8056"\w* \w y|strong="H5921"\w* gozosos \w de|strong="H5921"\w* \w corazón|strong="H3820"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* bondad \w que|strong="H5921"\w* Yahvé \w había|strong="H6213"\w* mostrado \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.   
\p
\v 11 Así terminó \w Salomón|strong="H8010"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé \w y|strong="H5921"\w* \w el|strong="H5921"\w* palacio \w del|strong="H5921"\w* \w rey|strong="H4428"\w*, \w y|strong="H5921"\w* llevó \w a|strong="H3068"\w* cabo \w con|strong="H5921"\w* éxito \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w había|strong="H6213"\w* propuesto \w en|strong="H5921"\w* su \w corazón|strong="H3820"\w* \w hacer|strong="H6213"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé \w y|strong="H5921"\w* \w en|strong="H5921"\w* su propia \w casa|strong="H1004"\w*.   
\p
\v 12 Entonces Yahvé se \w apareció|strong="H7200"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* de \w noche|strong="H3915"\w* y le dijo: “He escuchado tu \w oración|strong="H8605"\w* y he elegido \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* para mí como \w casa|strong="H1004"\w* de \w sacrificio|strong="H2077"\w*.   
\p
\v 13 “\w Si|strong="H2005"\w* \w yo|strong="H6680"\w* cierro \w los|strong="H5921"\w* \w cielos|strong="H8064"\w* \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w haya|strong="H1961"\w* \w lluvia|strong="H4306"\w*, \w o|strong="H3068"\w* \w si|strong="H2005"\w* \w mando|strong="H6680"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* langosta \w que|strong="H3808"\w* devore \w la|strong="H5921"\w* tierra, \w o|strong="H3068"\w* \w si|strong="H2005"\w* \w envío|strong="H7971"\w* \w la|strong="H5921"\w* peste \w entre|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*,  
\v 14 \w si|strong="H6440"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* cual es \w invocado|strong="H7121"\w* \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w*, \w se|strong="H5921"\w* humilla, \w ora|strong="H6419"\w*, \w busca|strong="H1245"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* aparta \w de|strong="H4480"\w* sus \w malos|strong="H7451"\w* \w caminos|strong="H1870"\w*, \w entonces|strong="H7725"\w* \w yo|strong="H4480"\w* \w escucharé|strong="H8085"\w* \w desde|strong="H4480"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*, \w perdonaré|strong="H5545"\w* su \w pecado|strong="H2403"\w* \w y|strong="H5921"\w* \w sanaré|strong="H7495"\w* su tierra.  
\v 15 \w Ahora|strong="H6258"\w* mis \w ojos|strong="H5869"\w* \w estarán|strong="H1961"\w* \w abiertos|strong="H6605"\w* y mis oídos \w atentos|strong="H7183"\w* \w a|strong="H3068"\w* la \w oración|strong="H8605"\w* \w que|strong="H6258"\w* \w se|strong="H1961"\w* haga en \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.  
\v 16 \w Porque|strong="H8033"\w* \w ahora|strong="H6258"\w* he elegido \w y|strong="H5704"\w* consagrado \w esta|strong="H2088"\w* \w casa|strong="H1004"\w*, \w para|strong="H5704"\w* \w que|strong="H6258"\w* \w mi|strong="H1961"\w* \w nombre|strong="H8034"\w* \w esté|strong="H2088"\w* \w allí|strong="H8033"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*; \w y|strong="H5704"\w* mis \w ojos|strong="H5869"\w* \w y|strong="H5704"\w* \w mi|strong="H1961"\w* \w corazón|strong="H3820"\w* \w estarán|strong="H1961"\w* \w allí|strong="H8033"\w* \w perpetuamente|strong="H5769"\w*.   
\p
\v 17 “\w Y|strong="H3068"\w* \w en|strong="H3212"\w* cuanto \w a|strong="H3068"\w* ti, \w si|strong="H6440"\w* andas \w delante|strong="H6440"\w* \w de|strong="H6440"\w* mí como \w anduvo|strong="H1980"\w* \w tu|strong="H6213"\w* padre \w David|strong="H1732"\w*, y \w haces|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* te he \w mandado|strong="H6680"\w*, y \w guardas|strong="H8104"\w* mis \w estatutos|strong="H2706"\w* y mis decretos,  
\v 18 entonces yo afirmaré el \w trono|strong="H3678"\w* de tu \w reino|strong="H4438"\w*, como pacté con tu padre \w David|strong="H1732"\w*, diciendo: ‘\w No|strong="H3808"\w* te \w faltará|strong="H3772"\w* un varón \w que|strong="H3808"\w* gobierne en \w Israel|strong="H3478"\w*’.   
\p
\v 19 “Pero \w si|strong="H6440"\w* vosotros os apartáis y abandonáis \w mis|strong="H5414"\w* \w estatutos|strong="H2708"\w* y \w mis|strong="H5414"\w* \w mandamientos|strong="H4687"\w* que he \w puesto|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros, y vais \w a|strong="H3068"\w* \w servir|strong="H5647"\w* \w a|strong="H3068"\w* otros dioses y los adoráis,  
\v 20 entonces \w os|strong="H5921"\w* \w arrancaré|strong="H5428"\w* \w de|strong="H5921"\w* raíz \w de|strong="H5921"\w* \w mi|strong="H5921"\w* tierra \w que|strong="H5921"\w* \w os|strong="H5921"\w* he \w dado|strong="H5414"\w*; \w y|strong="H5921"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w*, \w que|strong="H5921"\w* he consagrado \w para|strong="H5921"\w* \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w*, \w la|strong="H5921"\w* apartaré \w de|strong="H5921"\w* \w mi|strong="H5921"\w* vista \w y|strong="H5921"\w* \w la|strong="H5921"\w* convertiré \w en|strong="H5921"\w* refrán \w y|strong="H5921"\w* burla \w entre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w*.  
\v 21 \w Y|strong="H3068"\w* \w en|strong="H5921"\w* \w cuanto|strong="H4100"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w casa|strong="H1004"\w*, \w que|strong="H4100"\w* \w fue|strong="H1961"\w* tan excelsa, \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w que|strong="H4100"\w* \w pase|strong="H5674"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ella|strong="H5921"\w* \w se|strong="H1961"\w* asombrará \w y|strong="H5921"\w* dirá: ‘¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* ha \w hecho|strong="H6213"\w* \w esto|strong="H2063"\w* Yahvé \w a|strong="H3068"\w* \w esta|strong="H2063"\w* tierra \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w casa|strong="H1004"\w*?’  
\v 22 \w Y|strong="H3068"\w* responderán: ‘\w Porque|strong="H5921"\w* abandonaron \w a|strong="H3068"\w* Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* sus padres, \w que|strong="H5921"\w* \w los|strong="H5921"\w* \w sacó|strong="H3318"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* aferraron \w a|strong="H3068"\w* otros dioses, \w los|strong="H5921"\w* \w adoraron|strong="H7812"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w sirvieron|strong="H5647"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w él|strong="H5921"\w* ha traído \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w todo|strong="H3605"\w* \w este|strong="H2063"\w* \w mal|strong="H7451"\w*’”.   
\c 8
\p
\v 1 Al cabo de \w veinte|strong="H6242"\w* \w años|strong="H8141"\w*, en \w los|strong="H1961"\w* \w que|strong="H1961"\w* \w Salomón|strong="H8010"\w* \w había|strong="H1961"\w* \w edificado|strong="H1129"\w* la \w casa|strong="H1004"\w* de Yahvé y su propia \w casa|strong="H1004"\w*,  
\v 2 \w Salomón|strong="H8010"\w* reconstruyó las \w ciudades|strong="H5892"\w* \w que|strong="H1121"\w* Huram le había \w dado|strong="H5414"\w*, \w e|strong="H3068"\w* \w hizo|strong="H1129"\w* \w que|strong="H1121"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* las \w habitaran|strong="H3427"\w*.   
\p
\v 3 \w Salomón|strong="H8010"\w* marchó \w a|strong="H3068"\w* Hamat \w de|strong="H5921"\w* Soba \w y|strong="H5921"\w* \w la|strong="H5921"\w* conquistó.  
\v 4 \w Edificó|strong="H1129"\w* Tadmor en \w el|strong="H3605"\w* \w desierto|strong="H4057"\w*, y \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de abastecimiento \w que|strong="H3605"\w* \w edificó|strong="H1129"\w* en Hamat.  
\v 5 También \w edificó|strong="H1129"\w* Bet Horón la de arriba y Bet Horón la de abajo, \w ciudades|strong="H5892"\w* \w fortificadas|strong="H4692"\w* con murallas, \w puertas|strong="H1817"\w* y \w cerrojos|strong="H1280"\w*;  
\v 6 y Baalat, y \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de almacenamiento \w que|strong="H1961"\w* \w tenía|strong="H1961"\w* \w Salomón|strong="H8010"\w*, \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w para|strong="H1961"\w* sus \w carros|strong="H7393"\w*, las \w ciudades|strong="H5892"\w* \w para|strong="H1961"\w* su caballería, y \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1961"\w* \w Salomón|strong="H8010"\w* \w quiso|strong="H2836"\w* \w edificar|strong="H1129"\w* en Jerusalén, en \w el|strong="H3605"\w* \w Líbano|strong="H3844"\w* y en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra de su dominio.   
\p
