\v 16 \w Cuando|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w no|strong="H3808"\w* \w los|strong="H1992"\w* \w escuchaba|strong="H8085"\w*, \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w respondió|strong="H7725"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* diciendo: «¿\w Qué|strong="H3588"\w* \w parte|strong="H2506"\w* tenemos \w nosotros|strong="H3605"\w* \w con|strong="H3588"\w* \w David|strong="H1732"\w*? ¡\w No|strong="H3808"\w* tenemos \w herencia|strong="H5159"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Jesé! ¡\w A|strong="H3068"\w* tus tiendas, \w Israel|strong="H3478"\w*! ¡\w Mira|strong="H7200"\w* \w ahora|strong="H6258"\w* \w por|strong="H3588"\w* tu propia \w casa|strong="H1004"\w*, \w David|strong="H1732"\w*!» \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w se|strong="H3808"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* tiendas.   
\p
\v 17 Pero \w Roboam|strong="H7346"\w* \w reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H5921"\w* \w habitaban|strong="H3427"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 18 Entonces \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Hadoram, \w que|strong="H5921"\w* estaba \w a|strong="H3068"\w* cargo \w de|strong="H5921"\w* \w los|strong="H1121"\w* trabajos forzados, pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w lo|strong="H5921"\w* \w mataron|strong="H4191"\w* \w a|strong="H3068"\w* pedradas. \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w*, sin embargo, logró \w subir|strong="H5927"\w* rápidamente \w a|strong="H3068"\w* su \w carro|strong="H4818"\w* \w para|strong="H5921"\w* huir \w a|strong="H3068"\w* Jerusalén.  
\v 19 \w Así|strong="H2088"\w* se rebeló \w Israel|strong="H3478"\w* \w contra|strong="H3478"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* \w David|strong="H1732"\w*, \w hasta|strong="H5704"\w* el \w día|strong="H3117"\w* \w de|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\c 11
\p
\v 1 Cuando \w Roboam|strong="H7346"\w* llegó \w a|strong="H3068"\w* Jerusalén, reunió \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* y \w de|strong="H5973"\w* \w Benjamín|strong="H1144"\w*, \w ciento|strong="H3967"\w* \w ochenta|strong="H8084"\w* \w mil|strong="H3967"\w* \w guerreros|strong="H6213"\w* escogidos, \w para|strong="H5973"\w* \w combatir|strong="H4421"\w* \w contra|strong="H5973"\w* \w Israel|strong="H3478"\w* y devolver \w el|strong="H5973"\w* \w reino|strong="H4467"\w* \w a|strong="H3068"\w* \w Roboam|strong="H7346"\w*.  
\v 2 Pero la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Semaías|strong="H8098"\w*, hombre \w de|strong="H1697"\w* \w Dios|strong="H3068"\w*, diciendo:  
\v 3 “Habla \w a|strong="H3068"\w* \w Roboam|strong="H7346"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* en \w Judá|strong="H3063"\w* y \w Benjamín|strong="H1144"\w*, diciendo:  
\v 4 ‘\w Así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé: \w No|strong="H3808"\w* subiréis \w ni|strong="H3808"\w* combatiréis \w contra|strong="H5973"\w* vuestros hermanos. \w Vuelva|strong="H7725"\w* \w cada|strong="H1697"\w* uno \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*, \w porque|strong="H3588"\w* \w esto|strong="H2088"\w* \w ha|strong="H3541"\w* \w sido|strong="H1961"\w* obra mía’”. Ellos \w escucharon|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé, \w y|strong="H3588"\w* \w desistieron|strong="H7725"\w* \w de|strong="H3588"\w* \w ir|strong="H3212"\w* \w contra|strong="H5973"\w* \w Jeroboam|strong="H3379"\w*.   
\p
\v 5 \w Roboam|strong="H7346"\w* \w habitó|strong="H3427"\w* en Jerusalén y \w edificó|strong="H1129"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H4692"\w* en \w Judá|strong="H3063"\w*.  
\v 6 \w Edificó|strong="H1129"\w* Belén, Etam, Tecoa,  
\v 7 Bet Zur, Soco, Adulam,  
\v 8 Gat, \w Maresa|strong="H4762"\w*, Zif,  
\v 9 Adoraim, Laquis, \w Azeca|strong="H5825"\w*,  
\v 10 Zora, Ajalón y \w Hebrón|strong="H2275"\w*, que son \w ciudades|strong="H5892"\w* fortificadas en \w Judá|strong="H3063"\w* y en \w Benjamín|strong="H1144"\w*.  
\v 11 Reforzó las fortalezas y \w puso|strong="H5414"\w* en ellas comandantes, y almacenes \w de|strong="H5057"\w* víveres, \w aceite|strong="H8081"\w* y \w vino|strong="H3196"\w*.  
\v 12 En \w cada|strong="H3605"\w* \w ciudad|strong="H5892"\w* puso \w escudos|strong="H6793"\w* y \w lanzas|strong="H7420"\w*, y las hizo \w sumamente|strong="H3966"\w* fuertes. \w Así|strong="H2388"\w* \w retuvo|strong="H2388"\w* \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* y \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w*.   
\p
\v 13 \w Los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w que|strong="H5921"\w* estaban \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w se|strong="H5921"\w* presentaron ante \w él|strong="H5921"\w* \w desde|strong="H5921"\w* \w todos|strong="H3605"\w* sus territorios.  
\v 14 \w Pues|strong="H3588"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* abandonaron sus tierras \w de|strong="H3588"\w* pastos \w y|strong="H3588"\w* sus posesiones, \w y|strong="H3588"\w* se vinieron \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Jerusalén, \w porque|strong="H3588"\w* \w Jeroboam|strong="H3379"\w* \w y|strong="H3588"\w* sus \w hijos|strong="H1121"\w* \w los|strong="H1121"\w* habían destituido \w de|strong="H3588"\w* ejercer \w el|strong="H3588"\w* \w sacerdocio|strong="H3547"\w* \w para|strong="H3588"\w* Yahvé;  
\v 15 y \w él|strong="H6213"\w* se \w había|strong="H5975"\w* instituido sus propios \w sacerdotes|strong="H3548"\w* para los lugares \w altos|strong="H1116"\w*, para los demonios con forma de \w macho|strong="H8163"\w* cabrío, y para los \w becerros|strong="H5695"\w* que \w había|strong="H5975"\w* \w hecho|strong="H6213"\w*.  
\v 16 Tras \w los|strong="H3605"\w* levitas, \w los|strong="H3605"\w* \w de|strong="H5414"\w* \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w* \w que|strong="H3605"\w* habían resuelto en su \w corazón|strong="H3824"\w* buscar \w a|strong="H3068"\w* Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*, vinieron \w a|strong="H3068"\w* Jerusalén \w para|strong="H5414"\w* ofrecer \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H5414"\w* sus padres.  
\v 17 \w De|strong="H3588"\w* este modo fortalecieron \w el|strong="H3588"\w* \w reino|strong="H4438"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3588"\w* durante \w tres|strong="H7969"\w* \w años|strong="H8141"\w* apoyaron \w a|strong="H3068"\w* \w Roboam|strong="H7346"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Salomón|strong="H8010"\w*; \w pues|strong="H3588"\w* \w anduvieron|strong="H1980"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w David|strong="H1732"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Salomón|strong="H8010"\w* durante esos \w tres|strong="H7969"\w* \w años|strong="H8141"\w*.   
\p
\v 18 \w Roboam|strong="H7346"\w* \w tomó|strong="H3947"\w* por esposa \w a|strong="H3068"\w* Mahalat, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Jerimot, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, y \w de|strong="H1121"\w* Abihail, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Eliab, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jesé.  
\v 19 Ella le dio \w a|strong="H3068"\w* luz \w hijos|strong="H1121"\w*: \w Jeús|strong="H3266"\w*, \w Semarías|strong="H8114"\w* y Zaham.  
\v 20 Después de ella \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* Maaca, \w hija|strong="H1323"\w* de Absalón, la cual le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Abías, Atai, \w Ziza|strong="H2124"\w* y Selomit.  
\v 21 \w Roboam|strong="H7346"\w* amó \w a|strong="H3068"\w* Maaca, \w hija|strong="H1323"\w* \w de|strong="H3588"\w* Absalón, \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* sus otras \w mujeres|strong="H1323"\w* \w y|strong="H3588"\w* \w concubinas|strong="H6370"\w* (\w pues|strong="H3588"\w* \w tomó|strong="H5375"\w* \w dieciocho|strong="H8083"\w* \w mujeres|strong="H1323"\w* \w y|strong="H3588"\w* \w sesenta|strong="H8346"\w* \w concubinas|strong="H6370"\w*, \w y|strong="H3588"\w* \w engendró|strong="H3205"\w* \w veintiocho|strong="H6242"\w* \w hijos|strong="H1121"\w* \w y|strong="H3588"\w* \w sesenta|strong="H8346"\w* \w hijas|strong="H1323"\w*).  
\v 22 \w Roboam|strong="H7346"\w* designó \w a|strong="H3068"\w* Abías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Maaca, \w como|strong="H3588"\w* \w jefe|strong="H7218"\w* \w y|strong="H3588"\w* \w príncipe|strong="H5057"\w* \w entre|strong="H3588"\w* sus hermanos, \w con|strong="H3588"\w* \w la|strong="H3588"\w* intención \w de|strong="H3588"\w* hacerlo \w rey|strong="H4427"\w*.  
\v 23 Actuó con astucia, y distribuyó \w a|strong="H3068"\w* varios \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* \w por|strong="H5414"\w* \w todas|strong="H3605"\w* las regiones \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* y \w Benjamín|strong="H1144"\w*, \w por|strong="H5414"\w* \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* fortificadas; les \w dio|strong="H5414"\w* provisiones en \w abundancia|strong="H7230"\w* y les buscó \w muchas|strong="H1995"\w* esposas.   
\c 12
\p
\v 1 \w Cuando|strong="H1961"\w* \w Roboam|strong="H7346"\w* \w hubo|strong="H1961"\w* consolidado \w el|strong="H5973"\w* \w reino|strong="H4438"\w* y \w se|strong="H1961"\w* hizo fuerte, abandonó \w la|strong="H3605"\w* \w ley|strong="H8451"\w* \w de|strong="H5973"\w* Yahvé, y \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*.  
\v 2 \w En|strong="H5921"\w* \w el|strong="H5921"\w* \w quinto|strong="H2549"\w* \w año|strong="H8141"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w*, \w Sisac|strong="H7895"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w subió|strong="H5927"\w* \w contra|strong="H5921"\w* Jerusalén (\w por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w se|strong="H1961"\w* \w habían|strong="H1961"\w* rebelado \w contra|strong="H5921"\w* Yahvé)  
\v 3 \w con|strong="H5973"\w* \w mil|strong="H3967"\w* \w doscientos|strong="H3967"\w* \w carros|strong="H7393"\w* y \w sesenta|strong="H8346"\w* \w mil|strong="H3967"\w* \w jinetes|strong="H6571"\w*; y \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* venía \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w de|strong="H5973"\w* \w Egipto|strong="H4714"\w* era innumerable: libios, suquienos y etíopes.  
\v 4 \w Tomó|strong="H3920"\w* las \w ciudades|strong="H5892"\w* fortificadas \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w y|strong="H5704"\w* \w llegó|strong="H5704"\w* \w hasta|strong="H5704"\w* Jerusalén.  
\v 5 Entonces \w el|strong="H5030"\w* \w profeta|strong="H5030"\w* \w Semaías|strong="H8098"\w* se presentó \w ante|strong="H6440"\w* \w Roboam|strong="H7346"\w* \w y|strong="H3541"\w* los \w jefes|strong="H8269"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*, \w que|strong="H3541"\w* se habían reunido en Jerusalén \w por|strong="H6440"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w Sisac|strong="H7895"\w*, \w y|strong="H3541"\w* les dijo: “\w Así|strong="H3541"\w* dice Yahvé: ‘Vosotros \w me|strong="H3541"\w* habéis abandonado, \w por|strong="H6440"\w* eso yo también os he abandonado en \w manos|strong="H3027"\w* \w de|strong="H6440"\w* \w Sisac|strong="H7895"\w*’”.   
\p
\v 6 Los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* \w Israel|strong="H3478"\w* y el \w rey|strong="H4428"\w* se humillaron, y dijeron: «\w Justo|strong="H6662"\w* es Yahvé».   
\p
\v 7 \w Cuando|strong="H3588"\w* Yahvé \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* \w habían|strong="H1961"\w* \w humillado|strong="H3665"\w*, \w vino|strong="H1961"\w* \w la|strong="H5413"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé \w a|strong="H3068"\w* \w Semaías|strong="H8098"\w*, diciendo: «\w Se|strong="H1961"\w* han \w humillado|strong="H3665"\w*; \w no|strong="H3808"\w* \w los|strong="H1992"\w* \w destruiré|strong="H7843"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w les|strong="H1992"\w* concederé un breve respiro, \w y|strong="H3588"\w* \w mi|strong="H3389"\w* \w ira|strong="H2534"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* derramará \w sobre|strong="H1961"\w* Jerusalén \w por|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w Sisac|strong="H7895"\w*.  
\v 8 Sin embargo, \w serán|strong="H1961"\w* sus \w siervos|strong="H5650"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w conozcan|strong="H3045"\w* \w la|strong="H3588"\w* diferencia \w entre|strong="H3588"\w* \w serme|strong="H1961"\w* \w siervos|strong="H5650"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w y|strong="H3588"\w* ser \w siervos|strong="H5650"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w reinos|strong="H4467"\w* \w de|strong="H3588"\w* las naciones».   
\p
\v 9 \w Subió|strong="H5927"\w*, pues, \w Sisac|strong="H7895"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w contra|strong="H5921"\w* Jerusalén, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w llevó|strong="H3947"\w* \w los|strong="H5921"\w* tesoros \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé \w y|strong="H5921"\w* \w los|strong="H5921"\w* tesoros \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*; \w se|strong="H5921"\w* \w lo|strong="H5921"\w* \w llevó|strong="H3947"\w* \w todo|strong="H3605"\w*. También \w se|strong="H5921"\w* \w llevó|strong="H3947"\w* \w los|strong="H5921"\w* \w escudos|strong="H4043"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w que|strong="H5921"\w* \w Salomón|strong="H8010"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w*.  
\v 10 \w En|strong="H5921"\w* su \w lugar|strong="H8478"\w*, \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w* \w hizo|strong="H6213"\w* \w escudos|strong="H4043"\w* \w de|strong="H5921"\w* bronce, \w y|strong="H5921"\w* \w los|strong="H5921"\w* entregó \w al|strong="H5921"\w* \w cuidado|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w capitanes|strong="H8269"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* guardia, \w que|strong="H5921"\w* custodiaban \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w del|strong="H5921"\w* palacio \w real|strong="H4428"\w*.  
\v 11 Cada vez \w que|strong="H1961"\w* el \w rey|strong="H4428"\w* entraba en la \w casa|strong="H1004"\w* de Yahvé, \w los|strong="H1961"\w* guardias venían y \w los|strong="H1961"\w* \w llevaban|strong="H5375"\w*, y \w luego|strong="H7323"\w* \w los|strong="H1961"\w* devolvían \w a|strong="H3068"\w* la cámara de la guardia.  
\v 12 \w Y|strong="H3068"\w* \w como|strong="H1571"\w* \w él|strong="H1571"\w* \w se|strong="H1961"\w* humilló, \w la|strong="H1571"\w* ira \w de|strong="H4480"\w* Yahvé \w se|strong="H1961"\w* apartó \w de|strong="H4480"\w* \w él|strong="H1571"\w* \w para|strong="H4480"\w* \w no|strong="H3808"\w* \w destruirlo|strong="H7843"\w* \w por|strong="H4480"\w* completo; \w y|strong="H1571"\w* \w además|strong="H1571"\w*, \w en|strong="H4480"\w* \w Judá|strong="H3063"\w* todavía \w había|strong="H1961"\w* \w cosas|strong="H1697"\w* \w buenas|strong="H2896"\w*.   
\p
\v 13 \w Así|strong="H3588"\w* se afianzó \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w* \w en|strong="H3588"\w* Jerusalén \w y|strong="H3588"\w* \w reinó|strong="H4427"\w*; \w Roboam|strong="H7346"\w* tenía cuarenta \w y|strong="H3588"\w* un \w años|strong="H8141"\w* \w cuando|strong="H3588"\w* comenzó \w a|strong="H3068"\w* reinar, \w y|strong="H3588"\w* \w reinó|strong="H4427"\w* \w diecisiete|strong="H7651"\w* \w años|strong="H8141"\w* \w en|strong="H3588"\w* Jerusalén, \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w que|strong="H3588"\w* Yahvé \w había|strong="H3588"\w* elegido \w de|strong="H3588"\w* \w entre|strong="H3588"\w* \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w para|strong="H3588"\w* poner \w allí|strong="H8033"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w*. \w Su|strong="H3588"\w* madre se \w llamaba|strong="H8034"\w* Naamá, \w la|strong="H3588"\w* amonita.  
\v 14 \w Pero|strong="H3588"\w* \w hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w dispuso|strong="H6213"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w* \w para|strong="H3588"\w* buscar \w a|strong="H3068"\w* Yahvé.   
\p
\v 15 \w Los|strong="H1992"\w* \w hechos|strong="H1697"\w* \w de|strong="H1697"\w* \w Roboam|strong="H7346"\w*, \w los|strong="H1992"\w* \w primeros|strong="H7223"\w* y \w los|strong="H1992"\w* últimos, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* en \w los|strong="H1992"\w* registros del \w profeta|strong="H5030"\w* \w Semaías|strong="H8098"\w* y del \w vidente|strong="H2374"\w* \w Iddo|strong="H5714"\w*, en \w las|strong="H1992"\w* genealogías? Hubo \w guerras|strong="H4421"\w* continuas \w entre|strong="H3808"\w* \w Roboam|strong="H7346"\w* y \w Jeroboam|strong="H3379"\w*.  
\v 16 \w Y|strong="H3068"\w* \w durmió|strong="H7901"\w* \w Roboam|strong="H7346"\w* \w con|strong="H5973"\w* sus padres, y fue \w sepultado|strong="H6912"\w* \w en|strong="H5973"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H8478"\w* \w David|strong="H1732"\w*; y \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w* Abías, su \w hijo|strong="H1121"\w*.   
\c 13
\p
\v 1 \w En|strong="H5921"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* \w dieciocho|strong="H8083"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w Jeroboam|strong="H3379"\w*, Abías comenzó \w a|strong="H3068"\w* reinar \w sobre|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 2 \w Reinó|strong="H4427"\w* \w tres|strong="H7969"\w* \w años|strong="H8141"\w* \w en|strong="H4480"\w* Jerusalén. Su madre \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* Micaías, \w hija|strong="H1323"\w* \w de|strong="H4480"\w* Uriel \w de|strong="H4480"\w* Guibeá. \w Y|strong="H3068"\w* \w hubo|strong="H1961"\w* \w guerra|strong="H4421"\w* \w entre|strong="H4480"\w* Abías y \w Jeroboam|strong="H3379"\w*.  
\v 3 Abías se dispuso \w para|strong="H5973"\w* la \w batalla|strong="H4421"\w* \w con|strong="H5973"\w* un \w ejército|strong="H2428"\w* \w de|strong="H5973"\w* \w valientes|strong="H1368"\w* guerreros, cuatrocientos \w mil|strong="H3967"\w* \w hombres|strong="H1368"\w* escogidos, y \w Jeroboam|strong="H3379"\w* \w ordenó|strong="H6186"\w* la \w batalla|strong="H4421"\w* \w contra|strong="H5973"\w* \w él|strong="H5973"\w* \w con|strong="H5973"\w* \w ochocientos|strong="H8083"\w* \w mil|strong="H3967"\w* \w hombres|strong="H1368"\w* escogidos, que eran \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*.  
\v 4 Abías \w se|strong="H5921"\w* puso \w en|strong="H5921"\w* pie \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* Zemaraim, \w que|strong="H5921"\w* \w está|strong="H6965"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* región montañosa \w de|strong="H5921"\w* Efraín, \w y|strong="H5921"\w* dijo: “\w Escuchadme|strong="H8085"\w*, \w Jeroboam|strong="H3379"\w* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*:  
\v 5 ¿\w No|strong="H3808"\w* \w sabéis|strong="H3045"\w* \w que|strong="H3588"\w* Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w dio|strong="H5414"\w* \w el|strong="H5921"\w* \w reino|strong="H4467"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w para|strong="H5921"\w* \w siempre|strong="H5769"\w*, \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* mediante un \w pacto|strong="H1285"\w* \w de|strong="H5921"\w* \w sal|strong="H4417"\w*?  
\v 6 Pero \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Nabat|strong="H5028"\w*, \w siervo|strong="H5650"\w* \w de|strong="H5921"\w* \w Salomón|strong="H8010"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*, \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* rebeló \w contra|strong="H5921"\w* su señor.  
\v 7 \w Se|strong="H1961"\w* \w juntaron|strong="H6908"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w hombres|strong="H1121"\w* indignos, compañeros \w perversos|strong="H1121"\w* \w que|strong="H3808"\w* \w se|strong="H1961"\w* fortalecieron \w contra|strong="H5921"\w* \w Roboam|strong="H7346"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Salomón|strong="H8010"\w*, \w cuando|strong="H1961"\w* \w Roboam|strong="H7346"\w* \w era|strong="H1961"\w* joven \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w corazón|strong="H3824"\w* indeciso, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w pudo|strong="H2388"\w* resistirles.   
\p
\v 8 “\w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* \w vosotros|strong="H5973"\w* pretendéis resistir al \w reino|strong="H4467"\w* \w de|strong="H6440"\w* Yahvé, \w que|strong="H6258"\w* está \w en|strong="H5973"\w* \w manos|strong="H3027"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w David|strong="H1732"\w*. Sois una \w gran|strong="H7227"\w* \w multitud|strong="H1995"\w*, y \w los|strong="H1121"\w* \w becerros|strong="H5695"\w* \w de|strong="H6440"\w* \w oro|strong="H2091"\w* \w que|strong="H6258"\w* \w Jeroboam|strong="H3379"\w* \w os|strong="H5973"\w* \w hizo|strong="H6213"\w* \w por|strong="H6440"\w* dioses están \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*.  
\v 9 ¿Acaso \w no|strong="H3808"\w* habéis expulsado \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w de|strong="H1121"\w* Yahvé, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón \w y|strong="H1241"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, \w y|strong="H1241"\w* os habéis \w hecho|strong="H6213"\w* \w sacerdotes|strong="H3548"\w* según las costumbres \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w pueblos|strong="H5971"\w* \w de|strong="H1121"\w* otras tierras? \w Cualquiera|strong="H3605"\w* \w que|strong="H3808"\w* viene \w a|strong="H3068"\w* consagrarse con un \w novillo|strong="H1121"\w* \w y|strong="H1241"\w* \w siete|strong="H7651"\w* carneros puede ser \w sacerdote|strong="H3548"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w son|strong="H1961"\w* dioses.   
\p
\v 10 «Pero en cuanto \w a|strong="H3068"\w* nosotros, Yahvé es nuestro \w Dios|strong="H3068"\w*, y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* hemos abandonado. Tenemos \w sacerdotes|strong="H3548"\w* \w que|strong="H3808"\w* sirven \w a|strong="H3068"\w* Yahvé, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, y \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* en su ministerio.  
\v 11 \w Ellos|strong="H5921"\w* queman \w holocaustos|strong="H5930"\w* \w e|strong="H3068"\w* incienso \w aromático|strong="H5561"\w* \w a|strong="H3068"\w* Yahvé todas \w las|strong="H5921"\w* mañanas \w y|strong="H3588"\w* todas \w las|strong="H5921"\w* tardes. \w También|strong="H7979"\w* ponen \w en|strong="H5921"\w* orden \w los|strong="H5921"\w* \w panes|strong="H3899"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* proposición \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w mesa|strong="H7979"\w* \w pura|strong="H2889"\w*, \w y|strong="H3588"\w* cuidan \w el|strong="H5921"\w* candelabro \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w con|strong="H5921"\w* sus \w lámparas|strong="H5216"\w*, \w para|strong="H5921"\w* \w que|strong="H3588"\w* ardan cada \w tarde|strong="H6153"\w*; \w porque|strong="H3588"\w* \w nosotros|strong="H5921"\w* \w guardamos|strong="H8104"\w* \w la|strong="H5921"\w* \w ordenanza|strong="H4931"\w* \w de|strong="H5921"\w* Yahvé, nuestro \w Dios|strong="H3068"\w*, \w pero|strong="H3588"\w* vosotros \w lo|strong="H5921"\w* habéis abandonado.  
\v 12 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w Dios|strong="H3068"\w* \w está|strong="H5921"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w*, \w y|strong="H3588"\w* sus \w sacerdotes|strong="H3548"\w* \w con|strong="H5973"\w* \w las|strong="H5921"\w* \w trompetas|strong="H2689"\w* \w de|strong="H5921"\w* \w alarma|strong="H8643"\w* \w para|strong="H5921"\w* tocar \w a|strong="H3068"\w* rebato \w contra|strong="H5921"\w* \w vosotros|strong="H5973"\w*. \w Hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w no|strong="H3808"\w* luchéis \w contra|strong="H5921"\w* Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* vuestros padres, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* prosperaréis».   
\p
\v 13 Pero \w Jeroboam|strong="H3379"\w* hizo \w que|strong="H1961"\w* una emboscada diera un \w rodeo|strong="H5437"\w* \w para|strong="H1961"\w* llegarles \w por|strong="H6440"\w* la retaguardia; \w de|strong="H6440"\w* modo \w que|strong="H1961"\w* sus tropas \w estaban|strong="H1961"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*, y la emboscada \w estaba|strong="H1961"\w* \w a|strong="H3068"\w* sus espaldas.  
\v 14 Cuando los \w de|strong="H6440"\w* \w Judá|strong="H3063"\w* \w miraron|strong="H6437"\w* \w hacia|strong="H6440"\w* atrás, he \w aquí|strong="H2009"\w* que tenían la \w batalla|strong="H4421"\w* \w por|strong="H6440"\w* \w delante|strong="H6440"\w* y \w por|strong="H6440"\w* detrás; entonces \w clamaron|strong="H6817"\w* \w a|strong="H3068"\w* Yahvé, y los \w sacerdotes|strong="H3548"\w* \w tocaron|strong="H2690"\w* las \w trompetas|strong="H2689"\w*.  
\v 15 Luego \w los|strong="H3605"\w* hombres \w de|strong="H6440"\w* \w Judá|strong="H3063"\w* lanzaron \w el|strong="H3605"\w* grito \w de|strong="H6440"\w* guerra. \w Y|strong="H3068"\w* \w mientras|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H6440"\w* \w Judá|strong="H3063"\w* gritaban, Dios \w hirió|strong="H5062"\w* \w a|strong="H3068"\w* \w Jeroboam|strong="H3379"\w* y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Abías y \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*.  
\v 16 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w huyeron|strong="H5127"\w* \w ante|strong="H6440"\w* \w Judá|strong="H3063"\w*, y Dios \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* en sus \w manos|strong="H3027"\w*.  
\v 17 Abías y su \w gente|strong="H5971"\w* les causaron una \w gran|strong="H7227"\w* \w mortandad|strong="H4347"\w*, \w de|strong="H2568"\w* modo \w que|strong="H5971"\w* \w cayeron|strong="H5307"\w* \w muertos|strong="H2491"\w* \w quinientos|strong="H2568"\w* \w mil|strong="H3967"\w* hombres escogidos \w de|strong="H2568"\w* \w Israel|strong="H3478"\w*.  
\v 18 \w Así|strong="H3588"\w* fueron humillados \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w*, \w y|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* prevalecieron, \w porque|strong="H3588"\w* \w se|strong="H1931"\w* apoyaron \w en|strong="H5921"\w* Yahvé, \w el|strong="H1931"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w sus|strong="H1931"\w* padres.  
\v 19 Abías \w persiguió|strong="H7291"\w* \w a|strong="H3068"\w* \w Jeroboam|strong="H3379"\w* y le arrebató varias \w ciudades|strong="H5892"\w*: Betel \w con|strong="H4480"\w* sus \w aldeas|strong="H1323"\w*, Jesana \w con|strong="H4480"\w* sus \w aldeas|strong="H1323"\w* y Efrón \w con|strong="H4480"\w* sus \w aldeas|strong="H1323"\w*.   
\p
\v 20 \w Jeroboam|strong="H3379"\w* \w no|strong="H3808"\w* \w volvió|strong="H5750"\w* \w a|strong="H3068"\w* recuperar su poderío \w en|strong="H5750"\w* los \w días|strong="H3117"\w* \w de|strong="H5750"\w* Abías. El \w Señor|strong="H3068"\w* \w lo|strong="H3808"\w* \w hirió|strong="H5062"\w* y \w murió|strong="H4191"\w*.  
\v 21 Pero Abías se hizo \w poderoso|strong="H2388"\w*, \w tomó|strong="H5375"\w* para sí catorce \w mujeres|strong="H1323"\w*, y \w engendró|strong="H3205"\w* \w veintidós|strong="H6242"\w* \w hijos|strong="H1121"\w* y \w dieciséis|strong="H8337"\w* \w hijas|strong="H1323"\w*.  
\v 22 Los demás \w hechos|strong="H1697"\w* \w de|strong="H1697"\w* Abías, su conducta y sus dichos, están \w escritos|strong="H3789"\w* en \w el|strong="H5030"\w* comentario del \w profeta|strong="H5030"\w* \w Iddo|strong="H5714"\w*.   
\c 14
\p
\v 1 Abías durmió con sus padres, y \w lo|strong="H6213"\w* sepultaron en la ciudad \w de|strong="H5869"\w* David; y su hijo Asá reinó en su lugar. En sus días, la tierra \w tuvo|strong="H6213"\w* paz durante diez años.  
\v 2 Asá hizo lo que era bueno y recto \w a|strong="H3068"\w* los ojos de Yahvé, su Dios,  
\v 3 pues quitó los altares extranjeros y los lugares altos, derribó los pilares sagrados y taló las imágenes de Asera.  
\v 4 \w Y|strong="H3068"\w* ordenó \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w que|strong="H3605"\w* buscara \w a|strong="H3068"\w* Yahvé, \w el|strong="H3605"\w* Dios \w de|strong="H6440"\w* sus padres, y \w que|strong="H3605"\w* pusiera \w en|strong="H5493"\w* práctica \w la|strong="H3605"\w* ley y \w los|strong="H3605"\w* mandamientos.  
\v 5 También quitó \w de|strong="H3588"\w* todas las \w ciudades|strong="H5892"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w los|strong="H5973"\w* \w lugares|strong="H5892"\w* altos \w y|strong="H3588"\w* \w los|strong="H5973"\w* altares \w de|strong="H3588"\w* incienso, \w y|strong="H3588"\w* \w el|strong="H5973"\w* reino estuvo \w en|strong="H5973"\w* paz bajo \w su|strong="H3588"\w* mandato.  
\v 6 \w Edificó|strong="H1129"\w* \w ciudades|strong="H5892"\w* fortificadas \w en|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w pues|strong="H3588"\w* \w la|strong="H3588"\w* tierra estaba \w en|strong="H3588"\w* paz, \w y|strong="H3588"\w* \w no|strong="H3588"\w* hubo guerra \w contra|strong="H6440"\w* \w él|strong="H3588"\w* \w en|strong="H3588"\w* aquellos años, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* le \w había|strong="H3588"\w* dado descanso.  
\v 7 Por tanto, dijo \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*: «Edifiquemos estas ciudades y cerquémoslas con muros, torres, \w puertas|strong="H7969"\w* y cerrojos. \w La|strong="H3605"\w* tierra aún \w está|strong="H1961"\w* \w a|strong="H3068"\w* nuestra disposición, porque hemos buscado \w a|strong="H3068"\w* Yahvé, nuestro Dios; \w lo|strong="H3605"\w* hemos buscado, y \w él|strong="H3605"\w* nos ha dado descanso por \w todas|strong="H3605"\w* partes». Así \w que|strong="H1869"\w* edificaron y prosperaron.   
\p
\v 8 Asá tenía un \w ejército|strong="H2428"\w* \w de|strong="H5704"\w* \w trescientos|strong="H7969"\w* \w mil|strong="H3967"\w* hombres \w de|strong="H5704"\w* Judá, armados \w con|strong="H5704"\w* escudos \w y|strong="H5704"\w* lanzas, \w y|strong="H5704"\w* \w doscientos|strong="H3967"\w* ochenta \w mil|strong="H3967"\w* hombres \w de|strong="H5704"\w* Benjamín, armados \w con|strong="H5704"\w* escudos \w y|strong="H5704"\w* arcos. Todos ellos eran guerreros \w valientes|strong="H2428"\w*.   
\p
\v 9 Zéraj el etíope \w salió|strong="H3318"\w* \w contra|strong="H6440"\w* ellos con un ejército \w de|strong="H6440"\w* un millón \w de|strong="H6440"\w* hombres y trescientos carros, y llegó hasta \w Maresa|strong="H4762"\w*.  
\v 10 Asá salió \w a|strong="H3068"\w* \w su|strong="H3588"\w* encuentro, \w y|strong="H3588"\w* \w se|strong="H5921"\w* dispusieron \w para|strong="H5921"\w* \w la|strong="H5921"\w* batalla \w en|strong="H5921"\w* \w el|strong="H5921"\w* valle \w de|strong="H5921"\w* Sefata, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* Maresa.  
\v 11 Entonces Asá clamó \w a|strong="H3068"\w* Yahvé, su \w Dios|strong="H3068"\w*, y dijo: «\w Señor|strong="H3068"\w*, para ti \w no|strong="H6440"\w* hay diferencia entre ayudar al poderoso y ayudar al que \w no|strong="H6440"\w* tiene fuerzas. Ayúdanos, oh Yahvé, nuestro \w Dios|strong="H3068"\w*, \w porque|strong="H6440"\w* en ti nos apoyamos, y en tu nombre hemos venido \w contra|strong="H6440"\w* esta inmensa multitud. Oh Yahvé, tú eres nuestro \w Dios|strong="H3068"\w*; \w no|strong="H6440"\w* permitas que el hombre prevalezca \w contra|strong="H6440"\w* ti».   
\p
\v 12 \w El|strong="H5973"\w* \w Señor|strong="H3068"\w* derrotó \w a|strong="H3068"\w* \w los|strong="H1992"\w* etíopes \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Asá \w y|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Judá, \w y|strong="H3588"\w* \w los|strong="H1992"\w* etíopes huyeron.  
\v 13 Asá \w y|strong="H3588"\w* \w el|strong="H5921"\w* \w pueblo|strong="H7227"\w* \w que|strong="H3588"\w* \w estaba|strong="H1961"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w los|strong="H5921"\w* persiguieron \w hasta|strong="H5921"\w* \w Gerar|strong="H1642"\w*. \w Y|strong="H3068"\w* cayeron tantos \w de|strong="H5921"\w* \w los|strong="H5921"\w* etíopes \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w quedó|strong="H1961"\w* \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* aliento \w para|strong="H5921"\w* recuperarse, \w pues|strong="H3588"\w* \w fueron|strong="H1961"\w* destruidos \w delante|strong="H5921"\w* \w del|strong="H5921"\w* \w Señor|strong="H3068"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* ejército. \w Los|strong="H5921"\w* \w de|strong="H5921"\w* Judá \w se|strong="H1961"\w* llevaron un botín inmenso.  
\v 14 Atacaron todas las ciudades \w en|strong="H5221"\w* los alrededores de Gerar, porque \w el|strong="H1571"\w* terror de Yahvé había caído sobre ellas. \w Y|strong="H3068"\w* saquearon todas las ciudades, \w pues|strong="H1571"\w* había \w mucho|strong="H7230"\w* botín \w en|strong="H5221"\w* ellas.  
\v 15 También atacaron los campamentos de los ganaderos, y se llevaron ovejas y camellos en abundancia; después regresaron \w a|strong="H3068"\w* Jerusalén.   
\c 15
\p
\v 1 \w El|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Dios \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Oded.  
\v 2 \w Él|strong="H5973"\w* \w salió|strong="H3318"\w* al encuentro \w de|strong="H6440"\w* Asá y \w le|strong="H5973"\w* dijo: «¡\w Escuchadme|strong="H8085"\w*, Asá, y \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* y \w Benjamín|strong="H1144"\w*! Yahvé \w estará|strong="H1961"\w* \w con|strong="H5973"\w* \w vosotros|strong="H8085"\w* \w mientras|strong="H3605"\w* \w vosotros|strong="H8085"\w* estéis \w con|strong="H5973"\w* \w él|strong="H5973"\w*. \w Si|strong="H6440"\w* \w lo|strong="H3605"\w* buscáis, \w él|strong="H5973"\w* \w se|strong="H1961"\w* \w dejará|strong="H5800"\w* \w hallar|strong="H4672"\w* \w de|strong="H6440"\w* \w vosotros|strong="H8085"\w*; pero \w si|strong="H6440"\w* \w lo|strong="H3605"\w* abandonáis, \w él|strong="H5973"\w* \w os|strong="H5973"\w* abandonará.  
\v 3 Durante \w mucho|strong="H7227"\w* \w tiempo|strong="H3117"\w* \w Israel|strong="H3478"\w* estuvo \w sin|strong="H3808"\w* el Dios verdadero, \w sin|strong="H3808"\w* \w sacerdote|strong="H3548"\w* \w que|strong="H3808"\w* \w enseñara|strong="H3384"\w* y \w sin|strong="H3808"\w* \w ley|strong="H8451"\w*.  
\v 4 Pero cuando \w en|strong="H5921"\w* su \w angustia|strong="H6862"\w* \w se|strong="H5921"\w* \w volvieron|strong="H7725"\w* \w a|strong="H3068"\w* Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w buscaron|strong="H1245"\w*, \w él|strong="H5921"\w* \w se|strong="H5921"\w* dejó \w hallar|strong="H4672"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 5 \w En|strong="H5921"\w* \w aquellos|strong="H1992"\w* tiempos \w no|strong="H3588"\w* \w había|strong="H3588"\w* \w paz|strong="H7965"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H3588"\w* \w salía|strong="H3318"\w* ni \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H3588"\w* entraba, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* \w grandes|strong="H7227"\w* tribulaciones \w para|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w las|strong="H1992"\w* tierras.  
\v 6 Las \w naciones|strong="H1471"\w* se despedazaban unas \w a|strong="H3068"\w* otras, \w y|strong="H3588"\w* las \w ciudades|strong="H5892"\w* \w entre|strong="H3588"\w* \w sí|strong="H3588"\w*, \w porque|strong="H3588"\w* Dios \w los|strong="H3605"\w* turbaba \w con|strong="H3588"\w* \w toda|strong="H3605"\w* clase \w de|strong="H3588"\w* adversidades.  
\v 7 ¡\w Pero|strong="H3588"\w* \w vosotros|strong="H3426"\w*, \w esforzaos|strong="H2388"\w*! \w No|strong="H3588"\w* dejéis \w que|strong="H3588"\w* vuestras \w manos|strong="H3027"\w* \w desfallezcan|strong="H7503"\w*, \w porque|strong="H3588"\w* vuestra \w obra|strong="H6468"\w* será recompensada».   
\p
\v 8 Cuando Asá \w oyó|strong="H8085"\w* estas \w palabras|strong="H1697"\w* y \w la|strong="H3605"\w* profecía \w del|strong="H4480"\w* \w profeta|strong="H5030"\w* Oded, cobró \w ánimo|strong="H2388"\w* y quitó \w los|strong="H3605"\w* ídolos \w abominables|strong="H8251"\w* \w de|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* y \w de|strong="H4480"\w* \w Benjamín|strong="H1144"\w*, y \w de|strong="H4480"\w* las \w ciudades|strong="H5892"\w* \w que|strong="H4480"\w* había conquistado \w en|strong="H4480"\w* \w la|strong="H3605"\w* región montañosa \w de|strong="H4480"\w* Efraín; y \w restauró|strong="H2388"\w* \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w de|strong="H4480"\w* Yahvé \w que|strong="H4480"\w* estaba \w delante|strong="H6440"\w* \w del|strong="H4480"\w* pórtico \w de|strong="H4480"\w* Yahvé.  
\v 9 Luego reunió \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w Benjamín|strong="H1144"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* forasteros \w de|strong="H5921"\w* Efraín, \w Manasés|strong="H4519"\w* \w y|strong="H3588"\w* \w Simeón|strong="H8095"\w* \w que|strong="H3588"\w* residían \w con|strong="H5973"\w* \w ellos|strong="H5921"\w*; \w pues|strong="H3588"\w* \w muchos|strong="H7230"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w se|strong="H5921"\w* habían pasado \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w al|strong="H5921"\w* \w ver|strong="H7200"\w* \w que|strong="H3588"\w* Yahvé, \w su|strong="H3588"\w* \w Dios|strong="H3068"\w*, estaba \w con|strong="H5973"\w* \w él|strong="H5921"\w*.  
\v 10 Se congregaron en Jerusalén en el tercer \w mes|strong="H2320"\w* del \w año|strong="H8141"\w* \w decimoquinto|strong="H6240"\w* del \w reinado|strong="H4438"\w* \w de|strong="H2568"\w* Asá.  
\v 11 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w sacrificaron|strong="H2076"\w* \w a|strong="H3068"\w* Yahvé, \w del|strong="H4480"\w* botín \w que|strong="H4480"\w* habían traído, \w setecientas|strong="H7651"\w* reses \w y|strong="H1241"\w* \w siete|strong="H7651"\w* \w mil|strong="H3967"\w* \w ovejas|strong="H6629"\w*.  
\v 12 \w E|strong="H3068"\w* hicieron un \w pacto|strong="H1285"\w* para buscar \w a|strong="H3068"\w* Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* de sus padres, con \w todo|strong="H3605"\w* su \w corazón|strong="H3824"\w* y con \w toda|strong="H3605"\w* su \w alma|strong="H5315"\w*;  
\v 13 acordando \w que|strong="H4480"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H4480"\w* \w no|strong="H3808"\w* buscara \w a|strong="H3068"\w* Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w fuera|strong="H4480"\w* condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*, ya \w fuera|strong="H4480"\w* \w pequeño|strong="H6996"\w* \w o|strong="H3068"\w* \w grande|strong="H1419"\w*, hombre \w o|strong="H3068"\w* mujer.  
\v 14 Prestaron juramento \w a|strong="H3068"\w* Yahvé en \w alta|strong="H1419"\w* \w voz|strong="H6963"\w*, con \w júbilo|strong="H8643"\w*, y al son de \w trompetas|strong="H2689"\w* y cuernos.  
\v 15 \w Todo|strong="H3605"\w* \w Judá|strong="H3063"\w* \w se|strong="H5921"\w* alegró \w de|strong="H5921"\w* este \w juramento|strong="H7621"\w*, \w porque|strong="H3588"\w* habían \w jurado|strong="H7650"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w corazón|strong="H3824"\w* \w y|strong="H3588"\w* \w lo|strong="H5921"\w* habían buscado \w con|strong="H5921"\w* \w toda|strong="H3605"\w* \w su|strong="H3588"\w* \w voluntad|strong="H7522"\w*, \w y|strong="H3588"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* dejó \w hallar|strong="H4672"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w Y|strong="H3068"\w* Yahvé \w les|strong="H5921"\w* dio descanso \w por|strong="H5921"\w* \w todas|strong="H3605"\w* \w partes|strong="H5439"\w*.   
\p
\v 16 \w El|strong="H6213"\w* \w rey|strong="H4428"\w* Asá llegó incluso \w a|strong="H3068"\w* destituir \w a|strong="H3068"\w* su madre Maaca de su posición de \w reina|strong="H4428"\w* madre, \w porque|strong="H4428"\w* ella \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* una imagen abominable de Asera. Asá derribó su imagen, \w la|strong="H1571"\w* redujo \w a|strong="H3068"\w* polvo \w y|strong="H1571"\w* \w la|strong="H1571"\w* \w quemó|strong="H8313"\w* \w en|strong="H5493"\w* \w el|strong="H6213"\w* \w torrente|strong="H5158"\w* Cedrón.  
\v 17 \w Aunque|strong="H7535"\w* \w los|strong="H3605"\w* lugares \w altos|strong="H1116"\w* \w no|strong="H3808"\w* \w fueron|strong="H1961"\w* quitados de \w Israel|strong="H3478"\w*, \w el|strong="H3605"\w* \w corazón|strong="H3824"\w* de Asá \w fue|strong="H1961"\w* \w íntegro|strong="H8003"\w* \w todos|strong="H3605"\w* sus \w días|strong="H3117"\w*.  
\v 18 \w Y|strong="H3068"\w* trajo \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de Dios los utensilios consagrados por su padre, y los que él mismo \w había|strong="H6942"\w* \w consagrado|strong="H6944"\w*: \w plata|strong="H3701"\w*, \w oro|strong="H2091"\w* y \w vasos|strong="H3627"\w*.  
\v 19 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w más|strong="H5704"\w* \w guerra|strong="H4421"\w* \w hasta|strong="H5704"\w* el \w año|strong="H8141"\w* trigésimo quinto del \w reinado|strong="H4438"\w* \w de|strong="H5704"\w* Asá.   
\c 16
\p
\v 1 \w En|strong="H5921"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* trigésimo sexto \w del|strong="H5921"\w* \w reinado|strong="H4428"\w* \w de|strong="H5921"\w* Asá, \w Baasa|strong="H1201"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w subió|strong="H5927"\w* \w contra|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* fortificó \w Ramá|strong="H7414"\w*, \w con|strong="H5921"\w* \w el|strong="H5921"\w* fin \w de|strong="H5921"\w* impedir \w que|strong="H5921"\w* nadie \w saliera|strong="H3318"\w* \w o|strong="H3068"\w* entrara \w al|strong="H5921"\w* territorio \w de|strong="H5921"\w* Asá, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 2 Entonces Asá \w sacó|strong="H3318"\w* \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w* de \w los|strong="H3427"\w* tesoros de la \w casa|strong="H1004"\w* de Yahvé y del palacio \w real|strong="H4428"\w*, y \w envió|strong="H7971"\w* mensajeros \w a|strong="H3068"\w* Ben Hadad, \w rey|strong="H4428"\w* de Aram, que \w habitaba|strong="H3427"\w* \w en|strong="H3318"\w* \w Damasco|strong="H1834"\w*, diciéndole:  
\v 3 «Haya una \w alianza|strong="H1285"\w* \w entre|strong="H5921"\w* tú \w y|strong="H5921"\w* \w yo|strong="H2009"\w*, \w como|strong="H5921"\w* \w la|strong="H5921"\w* \w hubo|strong="H5927"\w* \w entre|strong="H5921"\w* \w mi|strong="H5921"\w* padre \w y|strong="H5921"\w* tu padre. He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* \w envío|strong="H7971"\w* \w plata|strong="H3701"\w* \w y|strong="H5921"\w* \w oro|strong="H2091"\w*. \w Ve|strong="H3212"\w*, \w y|strong="H5921"\w* rompe tu \w alianza|strong="H1285"\w* \w con|strong="H5921"\w* \w Baasa|strong="H1201"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* retire \w de|strong="H5921"\w* \w mi|strong="H5921"\w* territorio».   
\p
\v 4 Ben Hadad prestó \w oídos|strong="H8085"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* Asá y \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w capitanes|strong="H8269"\w* \w de|strong="H8269"\w* sus \w ejércitos|strong="H2428"\w* \w contra|strong="H3478"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H8269"\w* \w Israel|strong="H3478"\w*; y conquistaron Ijón, \w Dan|strong="H1835"\w*, Abel Maim y \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H8269"\w* abastecimiento \w de|strong="H8269"\w* Neftalí.  
\v 5 \w Cuando|strong="H1961"\w* \w Baasa|strong="H1201"\w* \w se|strong="H1961"\w* enteró de esto, \w dejó|strong="H2308"\w* de fortificar \w Ramá|strong="H7414"\w* y detuvo sus obras.  
\v 6 Entonces \w el|strong="H3605"\w* \w rey|strong="H4428"\w* Asá convocó \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w*, y se \w llevaron|strong="H5375"\w* las piedras y \w la|strong="H3605"\w* \w madera|strong="H6086"\w* con las \w que|strong="H3605"\w* \w Baasa|strong="H1201"\w* había estado \w edificando|strong="H1129"\w* \w Ramá|strong="H7414"\w*; y con ellas Asá fortificó Geba y \w Mizpa|strong="H4709"\w*.   
\p
\v 7 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w el|strong="H1931"\w* \w vidente|strong="H7200"\w* \w Hananí|strong="H2607"\w* acudió \w a|strong="H3068"\w* Asá, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w le|strong="H1931"\w* dijo: «\w Por|strong="H5921"\w* \w cuanto|strong="H3651"\w* \w te|strong="H5921"\w* has apoyado \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Aram, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* has apoyado \w en|strong="H5921"\w* Yahvé, tu \w Dios|strong="H3068"\w*, \w el|strong="H1931"\w* \w ejército|strong="H2426"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Aram \w ha|strong="H3808"\w* escapado \w de|strong="H5921"\w* tus \w manos|strong="H3027"\w*.  
\v 8 ¿Acaso \w los|strong="H5921"\w* etíopes \w y|strong="H5921"\w* \w los|strong="H5921"\w* libios \w no|strong="H3808"\w* \w eran|strong="H1961"\w* un \w ejército|strong="H2428"\w* \w numerosísimo|strong="H7230"\w*, \w con|strong="H5921"\w* \w carros|strong="H7393"\w* \w y|strong="H5921"\w* muchísimos \w jinetes|strong="H6571"\w*? \w Sin|strong="H3808"\w* embargo, \w como|strong="H1961"\w* \w te|strong="H5921"\w* apoyaste \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w Señor|strong="H3068"\w*, \w él|strong="H5921"\w* \w los|strong="H5921"\w* \w entregó|strong="H5414"\w* \w en|strong="H5921"\w* tus \w manos|strong="H3027"\w*.  
\v 9 \w Porque|strong="H3588"\w* \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* Yahvé \w recorren|strong="H7751"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, \w para|strong="H5921"\w* mostrar \w su|strong="H3588"\w* poder \w a|strong="H3068"\w* favor \w de|strong="H5921"\w* \w aquellos|strong="H3605"\w* cuyo \w corazón|strong="H3824"\w* \w es|strong="H3588"\w* \w íntegro|strong="H8003"\w* \w para|strong="H5921"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w*. \w Has|strong="H3426"\w* actuado \w neciamente|strong="H5528"\w* \w en|strong="H5921"\w* \w esto|strong="H2063"\w*; \w por|strong="H5921"\w* \w lo|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w a|strong="H3068"\w* partir \w de|strong="H5921"\w* \w ahora|strong="H6258"\w* tendrás \w guerras|strong="H4421"\w*».   
\p
\v 10 \w Entonces|strong="H3588"\w* Asá \w se|strong="H1931"\w* indignó \w contra|strong="H5921"\w* \w el|strong="H1931"\w* \w vidente|strong="H7200"\w* \w y|strong="H3588"\w* \w lo|strong="H1931"\w* metió \w en|strong="H5921"\w* \w la|strong="H1931"\w* cárcel, \w pues|strong="H3588"\w* \w estaba|strong="H1004"\w* furioso \w con|strong="H5973"\w* \w él|strong="H1931"\w* \w a|strong="H3068"\w* causa \w de|strong="H4480"\w* \w este|strong="H1931"\w* asunto. \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w tiempo|strong="H6256"\w*, Asá oprimió también \w a|strong="H3068"\w* algunos \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 11 \w Los|strong="H5921"\w* \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Asá, \w los|strong="H5921"\w* \w primeros|strong="H7223"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* últimos, \w están|strong="H2009"\w* \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w libro|strong="H5612"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 12 \w En|strong="H5704"\w* \w el|strong="H3588"\w* \w año|strong="H8141"\w* trigésimo noveno \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w reinado|strong="H4438"\w*, Asá \w enfermó|strong="H2456"\w* gravemente \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w pies|strong="H7272"\w*. \w Sin|strong="H3808"\w* embargo, \w en|strong="H5704"\w* \w su|strong="H3588"\w* \w enfermedad|strong="H2483"\w* \w no|strong="H3808"\w* \w buscó|strong="H1875"\w* \w a|strong="H3068"\w* Yahvé, \w sino|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w médicos|strong="H7495"\w*.  
\v 13 Asá \w durmió|strong="H7901"\w* \w con|strong="H5973"\w* sus padres y \w murió|strong="H4191"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w año|strong="H8141"\w* cuadragésimo primero \w de|strong="H5973"\w* su \w reinado|strong="H4427"\w*.  
\v 14 \w Lo|strong="H5704"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H5704"\w* el \w sepulcro|strong="H6913"\w* \w que|strong="H5704"\w* él se había labrado \w en|strong="H5704"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* \w David|strong="H1732"\w*. \w Lo|strong="H5704"\w* acostaron \w en|strong="H5704"\w* un lecho \w lleno|strong="H4390"\w* \w de|strong="H5704"\w* \w especias|strong="H1314"\w* aromáticas \w y|strong="H5704"\w* \w de|strong="H5704"\w* diversos ungüentos preparados \w por|strong="H5704"\w* el arte \w de|strong="H5704"\w* los perfumistas, \w y|strong="H5704"\w* encendieron \w en|strong="H5704"\w* su honor una hoguera inmensa.   
\c 17
\p
\v 1 Su \w hijo|strong="H1121"\w* Josafat \w reinó|strong="H4427"\w* \w en|strong="H5921"\w* su \w lugar|strong="H8478"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* hizo fuerte \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 2 Colocó tropas en \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*, y \w puso|strong="H5414"\w* guarniciones en \w la|strong="H3605"\w* tierra \w de|strong="H5414"\w* \w Judá|strong="H3063"\w* y en las \w ciudades|strong="H5892"\w* \w de|strong="H5414"\w* Efraín \w que|strong="H3605"\w* su padre Asá había conquistado.  
\v 3 Yahvé \w estuvo|strong="H1961"\w* \w con|strong="H5973"\w* Josafat, \w porque|strong="H3588"\w* \w anduvo|strong="H1980"\w* \w en|strong="H5973"\w* \w los|strong="H5973"\w* \w primeros|strong="H7223"\w* \w caminos|strong="H1870"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* padre \w David|strong="H1732"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w buscó|strong="H1875"\w* \w a|strong="H3068"\w* \w los|strong="H5973"\w* baales,  
\v 4 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w buscó|strong="H1875"\w* al Dios \w de|strong="H3588"\w* \w su|strong="H3588"\w* padre \w y|strong="H3588"\w* \w anduvo|strong="H1980"\w* \w en|strong="H3588"\w* sus \w mandamientos|strong="H4687"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* según las costumbres \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.  
\v 5 \w Por|strong="H3027"\w* eso \w el|strong="H3605"\w* \w Señor|strong="H3068"\w* \w afirmó|strong="H3559"\w* \w el|strong="H3605"\w* \w reino|strong="H4467"\w* en sus \w manos|strong="H3027"\w*. \w Todo|strong="H3605"\w* \w Judá|strong="H3063"\w* llevó \w tributo|strong="H4503"\w* \w a|strong="H3068"\w* Josafat, \w y|strong="H3519"\w* \w él|strong="H3605"\w* \w tuvo|strong="H1961"\w* \w riquezas|strong="H6239"\w* \w y|strong="H3519"\w* \w gloria|strong="H3519"\w* en \w abundancia|strong="H7230"\w*.  
\v 6 Su \w corazón|strong="H3820"\w* se enalteció \w en|strong="H5493"\w* los \w caminos|strong="H1870"\w* \w de|strong="H5750"\w* Yahvé; y \w además|strong="H5750"\w*, \w quitó|strong="H5493"\w* \w de|strong="H5750"\w* \w Judá|strong="H3063"\w* los lugares \w altos|strong="H1116"\w* y las imágenes \w de|strong="H5750"\w* Asera.   
\p
\v 7 En el tercer \w año|strong="H8141"\w* \w de|strong="H8269"\w* su \w reinado|strong="H4427"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* sus \w príncipes|strong="H8269"\w* Ben Hail, \w Abdías|strong="H5662"\w*, \w Zacarías|strong="H2148"\w*, Natanael y Micaías, para que \w enseñaran|strong="H3925"\w* en las \w ciudades|strong="H5892"\w* \w de|strong="H8269"\w* \w Judá|strong="H3063"\w*;  
\v 8 y \w con|strong="H5973"\w* ellos \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w levitas|strong="H3881"\w* \w Semaías|strong="H8098"\w*, Netanías, \w Zebadías|strong="H2069"\w*, \w Asael|strong="H6214"\w*, Semiramot, Jonatán, Adonías, \w Tobías|strong="H2900"\w* y Tobadonías; y \w con|strong="H5973"\w* ellos \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w sacerdotes|strong="H3548"\w* Elisama y \w Joram|strong="H3088"\w*.  
\v 9 \w Ellos|strong="H3605"\w* enseñaron \w en|strong="H5973"\w* \w Judá|strong="H3063"\w*, llevando \w consigo|strong="H5973"\w* \w el|strong="H5973"\w* \w libro|strong="H5612"\w* \w de|strong="H5973"\w* \w la|strong="H3605"\w* \w ley|strong="H8451"\w* \w de|strong="H5973"\w* Yahvé. Recorrieron \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* y enseñaron al \w pueblo|strong="H5971"\w*.   
\p
\v 10 \w El|strong="H5921"\w* \w temor|strong="H6343"\w* \w del|strong="H5921"\w* \w Señor|strong="H3068"\w* cayó \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* tierras \w que|strong="H3808"\w* rodeaban \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*, \w de|strong="H5921"\w* modo \w que|strong="H3808"\w* \w no|strong="H3808"\w* hicieron \w la|strong="H5921"\w* \w guerra|strong="H3898"\w* \w contra|strong="H5921"\w* Josafat.  
\v 11 Algunos \w de|strong="H4480"\w* los \w filisteos|strong="H6430"\w* le trajeron \w a|strong="H3068"\w* Josafat regalos \w y|strong="H1571"\w* \w plata|strong="H3701"\w* \w como|strong="H1571"\w* \w tributo|strong="H4503"\w*. Los árabes \w también|strong="H1571"\w* le trajeron rebaños: \w siete|strong="H7651"\w* \w mil|strong="H3967"\w* \w setecientos|strong="H7651"\w* carneros \w y|strong="H1571"\w* \w siete|strong="H7651"\w* \w mil|strong="H3967"\w* \w setecientos|strong="H7651"\w* machos cabríos.  
\v 12 Josafat \w se|strong="H1961"\w* engrandeció \w sobremanera|strong="H4605"\w*, \w y|strong="H5704"\w* \w edificó|strong="H1129"\w* \w fortalezas|strong="H1003"\w* \w y|strong="H5704"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5704"\w* abastecimiento \w en|strong="H5704"\w* \w Judá|strong="H3063"\w*.  
\v 13 Llevó \w a|strong="H3068"\w* cabo \w grandes|strong="H7227"\w* obras en las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w*, y \w tuvo|strong="H1961"\w* en Jerusalén guerreros y \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*.  
\v 14 Este es \w el|strong="H5973"\w* censo \w de|strong="H5973"\w* ellos según sus \w casas|strong="H1004"\w* paternas: \w de|strong="H5973"\w* \w Judá|strong="H3063"\w*, \w los|strong="H5973"\w* \w jefes|strong="H8269"\w* \w de|strong="H5973"\w* millares: \w el|strong="H5973"\w* \w jefe|strong="H8269"\w* \w Adná|strong="H5734"\w*, y \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w trescientos|strong="H7969"\w* \w mil|strong="H3967"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*;  
\v 15 \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w el|strong="H5921"\w* \w jefe|strong="H8269"\w* \w Johanán|strong="H3076"\w*, \w y|strong="H5921"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w doscientos|strong="H3967"\w* \w ochenta|strong="H8084"\w* \w mil|strong="H3967"\w*;  
\v 16 \w y|strong="H5921"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w Amasías|strong="H6007"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Zicri, \w que|strong="H5921"\w* \w se|strong="H5921"\w* había ofrecido \w voluntariamente|strong="H5068"\w* \w a|strong="H3068"\w* Yahvé, \w y|strong="H5921"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w doscientos|strong="H3967"\w* \w mil|strong="H3967"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*.  
\v 17 \w De|strong="H4480"\w* \w Benjamín|strong="H1144"\w*: Eliada, \w hombre|strong="H1368"\w* \w valeroso|strong="H2428"\w*, y \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w doscientos|strong="H3967"\w* \w mil|strong="H3967"\w* \w hombres|strong="H1368"\w* \w armados|strong="H5401"\w* \w con|strong="H5973"\w* \w arco|strong="H7198"\w* y \w escudo|strong="H4043"\w*;  
\v 18 \w y|strong="H5921"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w Jozabad|strong="H3075"\w*, \w y|strong="H5921"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w ciento|strong="H3967"\w* \w ochenta|strong="H8084"\w* \w mil|strong="H3967"\w* hombres pertrechados \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H6635"\w*.  
\v 19 \w Estos|strong="H3605"\w* eran \w los|strong="H3605"\w* \w que|strong="H3605"\w* estaban \w al|strong="H4428"\w* servicio del \w rey|strong="H4428"\w*, además \w de|strong="H5414"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* había \w puesto|strong="H5414"\w* en las \w ciudades|strong="H5892"\w* fortificadas \w por|strong="H5414"\w* \w toda|strong="H3605"\w* \w Judá|strong="H3063"\w*.   
\c 18
\p
\v 1 Josafat \w tuvo|strong="H1961"\w* \w riquezas|strong="H6239"\w* \w y|strong="H3519"\w* \w gloria|strong="H3519"\w* en \w abundancia|strong="H7230"\w*, \w y|strong="H3519"\w* \w se|strong="H1961"\w* emparentó con Ajab.  
\v 2 Al cabo \w de|strong="H5973"\w* algunos \w años|strong="H8141"\w*, \w descendió|strong="H3381"\w* \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w* \w para|strong="H5973"\w* visitar \w a|strong="H3068"\w* Ajab. Ajab \w mató|strong="H2076"\w* \w ovejas|strong="H6629"\w* \w y|strong="H1241"\w* \w vacas|strong="H1241"\w* \w en|strong="H5973"\w* \w abundancia|strong="H7230"\w* \w para|strong="H5973"\w* \w él|strong="H5973"\w* \w y|strong="H1241"\w* \w para|strong="H5973"\w* la \w gente|strong="H5971"\w* \w que|strong="H5971"\w* lo acompañaba, \w y|strong="H1241"\w* lo persuadió \w para|strong="H5973"\w* \w que|strong="H5971"\w* subiera \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w contra|strong="H5973"\w* Ramot \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w*.  
\v 3 Ajab, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*, dijo \w a|strong="H3068"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w*: «¿\w Irás|strong="H3212"\w* \w conmigo|strong="H5973"\w* \w a|strong="H3068"\w* Ramot \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w*?»  
\p \w Él|strong="H5973"\w* \w le|strong="H5973"\w* respondió: «Yo soy \w como|strong="H3644"\w* tú, y mi \w pueblo|strong="H5971"\w* \w como|strong="H3644"\w* tu \w pueblo|strong="H5971"\w*; estaremos \w contigo|strong="H5973"\w* \w en|strong="H5973"\w* la \w guerra|strong="H4421"\w*».  
\v 4 Pero Josafat dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*: «\w Por|strong="H1697"\w* favor, consulta \w hoy|strong="H3117"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé».   
\p
\v 5 Entonces \w el|strong="H5030"\w* \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w* reunió \w a|strong="H3068"\w* los \w profetas|strong="H5030"\w*, cuatrocientos hombres, y les preguntó: «¿\w Iremos|strong="H3212"\w* \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w* \w contra|strong="H3478"\w* Ramot \w de|strong="H5414"\w* \w Galaad|strong="H1568"\w*, \w o|strong="H3068"\w* me abstendré?»  
\p \w Ellos|strong="H3027"\w* dijeron: «\w Sube|strong="H5927"\w*, \w porque|strong="H4428"\w* Dios la \w entregará|strong="H5414"\w* \w en|strong="H3212"\w* \w manos|strong="H3027"\w* del \w rey|strong="H4428"\w*».   
\p
\v 6 Pero Josafat preguntó: «¿No \w hay|strong="H5750"\w* \w aquí|strong="H6311"\w* \w algún|strong="H5750"\w* \w otro|strong="H5750"\w* \w profeta|strong="H5030"\w* \w de|strong="H5750"\w* Yahvé \w a|strong="H3068"\w* quien podamos consultar?»   
\p
\v 7 \w El|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* respondió \w a|strong="H3068"\w* Josafat: «\w Aún|strong="H5750"\w* \w hay|strong="H5750"\w* un \w hombre|strong="H1121"\w* \w por|strong="H5921"\w* medio \w del|strong="H5921"\w* \w cual|strong="H1931"\w* podemos consultar \w a|strong="H3068"\w* Yahvé, \w pero|strong="H3588"\w* \w yo|strong="H3588"\w* \w lo|strong="H1931"\w* \w aborrezco|strong="H8130"\w*, \w porque|strong="H3588"\w* \w nunca|strong="H3588"\w* \w me|strong="H5921"\w* \w profetiza|strong="H5012"\w* \w el|strong="H1931"\w* \w bien|strong="H2896"\w*, \w sino|strong="H3588"\w* \w siempre|strong="H3605"\w* \w el|strong="H1931"\w* \w mal|strong="H7451"\w*. \w Es|strong="H1931"\w* Micaías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Imlá».  
\p Josafat dijo: «\w No|strong="H3588"\w* hable \w así|strong="H3651"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w*».   
\p
\v 8 Entonces \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* un oficial y le ordenó: «Trae \w de|strong="H1121"\w* prisa \w a|strong="H3068"\w* Micaías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Imlá».   
\p
\v 9 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w estaban|strong="H3427"\w* \w sentados|strong="H3427"\w* \w cada|strong="H3605"\w* uno \w en|strong="H5921"\w* su \w trono|strong="H3678"\w*, \w vestidos|strong="H3847"\w* \w con|strong="H5921"\w* sus ropas \w reales|strong="H4428"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* plaza \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w Samaria|strong="H8111"\w*; \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w profetas|strong="H5030"\w* \w profetizaban|strong="H5012"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 10 Sedequías, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Quenaaná, se \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* unos \w cuernos|strong="H7161"\w* \w de|strong="H5704"\w* \w hierro|strong="H1270"\w* \w y|strong="H5704"\w* decía: “\w Así|strong="H3541"\w* dice Yahvé: ‘\w Con|strong="H5704"\w* estos \w acornearás|strong="H5055"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* sirios \w hasta|strong="H5704"\w* \w destruirlos|strong="H3615"\w* \w por|strong="H5704"\w* completo’”.   
\p
\v 11 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w* \w profetizaban|strong="H5012"\w* \w lo|strong="H3605"\w* \w mismo|strong="H3605"\w*, diciendo: «\w Sube|strong="H5927"\w* \w a|strong="H3068"\w* Ramot \w de|strong="H5414"\w* \w Galaad|strong="H1568"\w* y serás \w prosperado|strong="H6743"\w*, \w porque|strong="H4428"\w* Yahvé \w la|strong="H3605"\w* \w entregará|strong="H5414"\w* en \w manos|strong="H3027"\w* del \w rey|strong="H4428"\w*».   
\p
\v 12 \w El|strong="H5030"\w* \w mensajero|strong="H4397"\w* \w que|strong="H4994"\w* \w había|strong="H1961"\w* ido \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* Micaías le \w habló|strong="H1696"\w*, \w diciendo|strong="H1696"\w*: «He \w aquí|strong="H2009"\w* \w que|strong="H4994"\w* \w las|strong="H1992"\w* \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w*, \w a|strong="H3068"\w* una sola voz, anuncian \w el|strong="H5030"\w* \w bien|strong="H2896"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*. Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* tu \w palabra|strong="H1697"\w* \w sea|strong="H1961"\w* \w como|strong="H1961"\w* la \w de|strong="H1697"\w* uno \w de|strong="H1697"\w* \w ellos|strong="H1992"\w*, y \w que|strong="H4994"\w* anuncies \w el|strong="H5030"\w* \w bien|strong="H2896"\w*».   
\p
\v 13 \w Pero|strong="H3588"\w* Micaías respondió: «\w Vive|strong="H2416"\w* Yahvé, \w que|strong="H3588"\w* lo \w que|strong="H3588"\w* mi \w Dios|strong="H3068"\w* \w me|strong="H3588"\w* \w diga|strong="H1696"\w*, eso \w hablaré|strong="H1696"\w*».   
\p
\v 14 Cuando \w llegó|strong="H5927"\w* ante el \w rey|strong="H4428"\w*, el \w rey|strong="H4428"\w* le preguntó: «Micaías, ¿\w iremos|strong="H3212"\w* \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w* contra Ramot \w de|strong="H5414"\w* \w Galaad|strong="H1568"\w*, \w o|strong="H3068"\w* me abstendré?»  
\p Él respondió: «\w Subid|strong="H5927"\w* y seréis prosperados; serán entregados \w en|strong="H3212"\w* vuestras \w manos|strong="H3027"\w*».   
\p
\v 15 El \w rey|strong="H4428"\w* le \w dijo|strong="H1696"\w*: «¿\w Cuántas|strong="H4100"\w* \w veces|strong="H6471"\w* he \w de|strong="H5704"\w* conjurarte \w para|strong="H5704"\w* \w que|strong="H4100"\w* \w no|strong="H3808"\w* me \w digas|strong="H1696"\w* \w sino|strong="H7535"\w* la verdad \w en|strong="H5704"\w* el \w nombre|strong="H8034"\w* \w de|strong="H5704"\w* Yahvé?»   
\p
\v 16 \w Entonces|strong="H7725"\w* Micaías dijo: “He \w visto|strong="H7200"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w esparcido|strong="H6327"\w* \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*, \w como|strong="H5921"\w* \w ovejas|strong="H6629"\w* \w sin|strong="H3808"\w* \w pastor|strong="H7462"\w*. \w Y|strong="H3068"\w* Yahvé dijo: ‘\w Estos|strong="H3605"\w* \w no|strong="H3808"\w* tienen \w señor|strong="H3068"\w*; \w vuelva|strong="H7725"\w* \w cada|strong="H3605"\w* uno \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* \w en|strong="H5921"\w* \w paz|strong="H7965"\w*’”.   
\p
\v 17 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* Josafat: «¿\w No|strong="H3808"\w* \w te|strong="H5921"\w* dije \w que|strong="H3588"\w* este \w no|strong="H3808"\w* \w profetizaría|strong="H5012"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* \w nada|strong="H3808"\w* \w bueno|strong="H2896"\w*, \w sino|strong="H3588"\w* sólo \w el|strong="H5921"\w* \w mal|strong="H7451"\w*?»   
\p
\v 18 \w Y|strong="H3068"\w* Micaías añadió: “\w Escuchad|strong="H8085"\w*, \w pues|strong="H3651"\w*, \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé: \w Vi|strong="H7200"\w* \w a|strong="H3068"\w* Yahvé \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* su \w trono|strong="H3678"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w ejército|strong="H6635"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w cielos|strong="H8064"\w* \w de|strong="H5921"\w* \w pie|strong="H5975"\w* \w a|strong="H3068"\w* su \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* su \w izquierda|strong="H8040"\w*.  
\v 19 \w Y|strong="H3068"\w* Yahvé preguntó: ‘¿\w Quién|strong="H4310"\w* persuadirá \w a|strong="H3068"\w* Ajab, \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*, para \w que|strong="H4310"\w* \w suba|strong="H5927"\w* y \w caiga|strong="H5307"\w* en Ramot de \w Galaad|strong="H1568"\w*?’ \w Y|strong="H3068"\w* uno decía de una manera, y \w otro|strong="H2088"\w* decía de otra.  
\v 20 Entonces \w salió|strong="H3318"\w* un \w espíritu|strong="H7307"\w*, \w se|strong="H4100"\w* \w puso|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé y dijo: ‘Yo \w lo|strong="H4100"\w* persuadiré’.  
\p “Yahvé le preguntó: ‘¿\w De|strong="H6440"\w* \w qué|strong="H4100"\w* manera?’   
\p
\v 21 “\w Él|strong="H3605"\w* respondió: ‘\w Saldré|strong="H3318"\w* \w y|strong="H1571"\w* \w seré|strong="H1961"\w* \w espíritu|strong="H7307"\w* de \w mentira|strong="H8267"\w* \w en|strong="H3318"\w* \w la|strong="H1571"\w* \w boca|strong="H6310"\w* de \w todos|strong="H3605"\w* sus \w profetas|strong="H5030"\w*’.  
\p “\w Y|strong="H3068"\w* Yahvé dijo: ‘\w Tú|strong="H6213"\w* \w lo|strong="H6213"\w* persuadirás, \w y|strong="H1571"\w* \w ciertamente|strong="H1571"\w* prevalecerás. Ve \w y|strong="H1571"\w* \w hazlo|strong="H6213"\w* \w así|strong="H3651"\w*’.   
\p
\v 22 «\w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H6258"\w* Yahvé ha \w puesto|strong="H5414"\w* un \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w mentira|strong="H8267"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* estos tus \w profetas|strong="H5030"\w*, \w y|strong="H5921"\w* Yahvé ha decretado \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*».   
\p
\v 23 Entonces \w se|strong="H5921"\w* \w acercó|strong="H5066"\w* Sedequías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Quenaaná, golpeó \w a|strong="H3068"\w* Micaías \w en|strong="H5921"\w* \w la|strong="H5921"\w* mejilla \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w dijo|strong="H1696"\w*: «¿\w Por|strong="H5921"\w* \w qué|strong="H5921"\w* \w camino|strong="H1870"\w* \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Yahvé \w para|strong="H5921"\w* \w hablarte|strong="H1696"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*?»   
\p
\v 24 Micaías respondió: «He \w aquí|strong="H2005"\w*, tú \w lo|strong="H1931"\w* \w verás|strong="H7200"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w cuando|strong="H3117"\w* vayas de aposento en aposento para esconderte».   
\p
\v 25 \w El|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* ordenó: “\w Tomad|strong="H3947"\w* \w a|strong="H3068"\w* Micaías y llevadlo \w a|strong="H3068"\w* Amón, \w gobernador|strong="H8269"\w* \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w*, y \w a|strong="H3068"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* del \w rey|strong="H4428"\w*;  
\v 26 \w y|strong="H5704"\w* decidles: ‘\w Así|strong="H3541"\w* dice el \w rey|strong="H4428"\w*: \w Poned|strong="H7760"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* hombre \w en|strong="H5704"\w* la cárcel, \w y|strong="H5704"\w* sustentadle \w con|strong="H5704"\w* \w pan|strong="H3899"\w* \w de|strong="H5704"\w* aflicción \w y|strong="H5704"\w* \w agua|strong="H4325"\w* \w de|strong="H5704"\w* aflicción, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* yo regrese \w en|strong="H5704"\w* \w paz|strong="H7965"\w*’”.   
\p
\v 27 Micaías \w dijo|strong="H1696"\w*: «\w Si|strong="H3808"\w* tú logras regresar en \w paz|strong="H7965"\w*, Yahvé \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w hablado|strong="H1696"\w* por medio \w de|strong="H5971"\w* mí». \w Y|strong="H3068"\w* añadió: «¡\w Escuchad|strong="H8085"\w*, \w pueblos|strong="H5971"\w* \w todos|strong="H3605"\w*!»   
\p
\v 28 \w Subieron|strong="H5927"\w*, pues, el \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w* y Josafat, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*, \w a|strong="H3068"\w* Ramot de \w Galaad|strong="H1568"\w*.  
\v 29 El \w rey|strong="H4428"\w* \w de|strong="H3847"\w* \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* Josafat: «Yo me disfrazaré para entrar en la \w batalla|strong="H4421"\w*, pero tú \w vístete|strong="H3847"\w* con tus ropas \w reales|strong="H4428"\w*». Se disfrazó, pues, el \w rey|strong="H4428"\w* \w de|strong="H3847"\w* \w Israel|strong="H3478"\w*, y entraron en la \w batalla|strong="H4421"\w*.  
\v 30 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Siria \w había|strong="H3588"\w* \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w capitanes|strong="H8269"\w* \w de|strong="H3588"\w* sus \w carros|strong="H7393"\w*: «\w No|strong="H3808"\w* \w peleéis|strong="H3898"\w* \w ni|strong="H3808"\w* \w contra|strong="H3478"\w* \w el|strong="H3588"\w* \w pequeño|strong="H6996"\w* \w ni|strong="H3808"\w* \w contra|strong="H3478"\w* \w el|strong="H3588"\w* \w grande|strong="H1419"\w*, \w sino|strong="H3588"\w* únicamente \w contra|strong="H3478"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*».   
\p
\v 31 \w Cuando|strong="H1961"\w* \w los|strong="H1992"\w* \w capitanes|strong="H8269"\w* \w de|strong="H4480"\w* \w los|strong="H1992"\w* \w carros|strong="H7393"\w* \w vieron|strong="H7200"\w* \w a|strong="H3068"\w* Josafat, dijeron: «¡\w Este|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*!» \w Y|strong="H3068"\w* \w lo|strong="H1931"\w* rodearon \w para|strong="H5921"\w* atacarlo; pero Josafat \w clamó|strong="H2199"\w*, \w y|strong="H5921"\w* Yahvé \w lo|strong="H1931"\w* \w ayudó|strong="H5826"\w*, \w y|strong="H5921"\w* \w Dios|strong="H3068"\w* \w los|strong="H1992"\w* \w apartó|strong="H5437"\w* \w de|strong="H4480"\w* \w él|strong="H1931"\w*.  
\v 32 \w Pues|strong="H3588"\w* \w cuando|strong="H3588"\w* \w los|strong="H1961"\w* \w capitanes|strong="H8269"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w carros|strong="H7393"\w* \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w era|strong="H1961"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, dejaron \w de|strong="H3588"\w* perseguirlo.  
\v 33 \w Pero|strong="H3588"\w* un hombre disparó \w su|strong="H3588"\w* \w arco|strong="H7198"\w* \w al|strong="H4480"\w* azar \w e|strong="H3068"\w* \w hirió|strong="H5221"\w* \w al|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w por|strong="H3588"\w* \w entre|strong="H3588"\w* las junturas \w de|strong="H4480"\w* \w la|strong="H3588"\w* armadura. \w Entonces|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* dijo \w al|strong="H4480"\w* conductor \w de|strong="H4480"\w* \w su|strong="H3588"\w* carro: «Da \w la|strong="H3588"\w* \w vuelta|strong="H2015"\w* \w y|strong="H3588"\w* \w sácame|strong="H3318"\w* \w del|strong="H4480"\w* \w campo|strong="H4264"\w* \w de|strong="H4480"\w* batalla, \w porque|strong="H3588"\w* estoy gravemente herido».  
\v 34 \w La|strong="H1931"\w* \w batalla|strong="H4421"\w* arreció \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*; \w y|strong="H5704"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* mantuvo \w en|strong="H5704"\w* \w pie|strong="H5975"\w* \w en|strong="H5704"\w* \w su|strong="H1931"\w* \w carro|strong="H4818"\w* frente \w a|strong="H3068"\w* \w los|strong="H1931"\w* sirios \w hasta|strong="H5704"\w* \w la|strong="H1931"\w* \w tarde|strong="H6153"\w*, pero \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w hora|strong="H6256"\w* \w de|strong="H5704"\w* \w la|strong="H1931"\w* puesta del \w sol|strong="H8121"\w*, \w murió|strong="H4191"\w*.   
\c 19
\p
\v 1 Josafat, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*, regresó en \w paz|strong="H7965"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* en Jerusalén.  
\v 2 \w Y|strong="H3068"\w* \w le|strong="H5921"\w* \w salió|strong="H3318"\w* \w al|strong="H5921"\w* encuentro \w el|strong="H5921"\w* \w vidente|strong="H2374"\w* \w Jehú|strong="H3058"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Hananí|strong="H2607"\w*, \w y|strong="H5921"\w* dijo \w al|strong="H5921"\w* \w rey|strong="H4428"\w* Josafat: «¿Acaso debías ayudar \w al|strong="H5921"\w* \w impío|strong="H7563"\w* \w y|strong="H5921"\w* amar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* \w aborrecen|strong="H8130"\w* \w a|strong="H3068"\w* Yahvé? \w Por|strong="H5921"\w* \w esto|strong="H2063"\w*, \w la|strong="H5921"\w* \w ira|strong="H7110"\w* \w de|strong="H5921"\w* Yahvé ha caído \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*.  
\v 3 Sin embargo, \w se|strong="H4480"\w* han \w hallado|strong="H4672"\w* \w cosas|strong="H1697"\w* \w buenas|strong="H2896"\w* \w en|strong="H4480"\w* \w ti|strong="H4480"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* has quitado \w de|strong="H4480"\w* \w la|strong="H1197"\w* tierra las imágenes \w de|strong="H4480"\w* Asera \w y|strong="H3588"\w* has \w dispuesto|strong="H3559"\w* tu \w corazón|strong="H3824"\w* \w para|strong="H3588"\w* buscar \w a|strong="H3068"\w* Dios».   
\p
\v 4 Josafat \w habitó|strong="H3427"\w* \w en|strong="H5704"\w* Jerusalén; \w y|strong="H5704"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w salir|strong="H3318"\w* \w por|strong="H5704"\w* entre \w el|strong="H3427"\w* \w pueblo|strong="H5971"\w*, \w desde|strong="H5704"\w* Beerseba \w hasta|strong="H5704"\w* la región montañosa \w de|strong="H5704"\w* Efraín, \w y|strong="H5704"\w* \w los|strong="H3427"\w* hizo \w volver|strong="H7725"\w* \w a|strong="H3068"\w* Yahvé, \w el|strong="H3427"\w* \w Dios|strong="H3068"\w* \w de|strong="H5704"\w* sus padres.  
\v 5 Estableció \w jueces|strong="H8199"\w* \w en|strong="H5975"\w* \w la|strong="H3605"\w* tierra, \w en|strong="H5975"\w* \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* de \w Judá|strong="H3063"\w*, \w ciudad|strong="H5892"\w* por \w ciudad|strong="H5892"\w*,  
\v 6 \w y|strong="H3588"\w* dijo \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w jueces|strong="H8199"\w*: «\w Considerad|strong="H7200"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w hacéis|strong="H6213"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w juzgáis|strong="H8199"\w* \w en|strong="H5973"\w* lugar \w del|strong="H5973"\w* hombre, \w sino|strong="H3588"\w* \w de|strong="H3588"\w* Yahvé, \w y|strong="H3588"\w* \w él|strong="H5973"\w* estará \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w* \w cuando|strong="H3588"\w* dictéis \w sentencia|strong="H4941"\w*.  
\v 7 \w Ahora|strong="H6258"\w*, \w pues|strong="H3588"\w*, \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w temor|strong="H6343"\w* \w de|strong="H5921"\w* Yahvé \w esté|strong="H1961"\w* \w sobre|strong="H5921"\w* \w vosotros|strong="H5973"\w*. Tened cuidado \w con|strong="H5973"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w hacéis|strong="H6213"\w*, \w porque|strong="H3588"\w* \w en|strong="H5921"\w* Yahvé nuestro \w Dios|strong="H3068"\w* \w no|strong="H6213"\w* \w hay|strong="H1961"\w* injusticia, \w ni|strong="H5973"\w* acepción \w de|strong="H5921"\w* personas, \w ni|strong="H5973"\w* admisión \w de|strong="H5921"\w* \w soborno|strong="H7810"\w*».   
\p
\v 8 \w En|strong="H4480"\w* Jerusalén, Josafat \w también|strong="H1571"\w* estableció \w a|strong="H3068"\w* algunos \w de|strong="H4480"\w* los \w levitas|strong="H3881"\w*, \w sacerdotes|strong="H3548"\w* \w y|strong="H1571"\w* \w jefes|strong="H7218"\w* \w de|strong="H4480"\w* las familias \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w para|strong="H4480"\w* \w el|strong="H1571"\w* \w juicio|strong="H4941"\w* \w de|strong="H4480"\w* Yahvé \w y|strong="H1571"\w* \w para|strong="H4480"\w* resolver las controversias. \w Y|strong="H3068"\w* regresaron \w a|strong="H3068"\w* Jerusalén.  
\v 9 \w Les|strong="H5921"\w* dio \w estas|strong="H6213"\w* órdenes: «Actuaréis \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w temor|strong="H3374"\w* \w de|strong="H5921"\w* Yahvé, \w con|strong="H5921"\w* fidelidad \w y|strong="H5921"\w* \w con|strong="H5921"\w* un \w corazón|strong="H3824"\w* \w íntegro|strong="H8003"\w*.  
\v 10 \w En|strong="H5921"\w* \w cualquier|strong="H3605"\w* \w pleito|strong="H7379"\w* \w que|strong="H3808"\w* llegue \w a|strong="H3068"\w* vosotros \w de|strong="H5921"\w* parte \w de|strong="H5921"\w* vuestros hermanos \w que|strong="H3808"\w* \w habitan|strong="H3427"\w* \w en|strong="H5921"\w* sus \w ciudades|strong="H5892"\w*, ya \w sea|strong="H1961"\w* \w sobre|strong="H5921"\w* derramamiento \w de|strong="H5921"\w* \w sangre|strong="H1818"\w* \w o|strong="H3068"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w*, \w los|strong="H3427"\w* \w mandamientos|strong="H4687"\w*, \w los|strong="H3427"\w* \w estatutos|strong="H2706"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w ordenanzas|strong="H2706"\w*, deberéis advertirles \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* pequen \w contra|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w así|strong="H3541"\w* \w no|strong="H3808"\w* \w venga|strong="H1961"\w* \w la|strong="H5921"\w* \w ira|strong="H7110"\w* \w sobre|strong="H5921"\w* vosotros \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* vuestros hermanos. \w Haced|strong="H6213"\w* \w esto|strong="H3541"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w seréis|strong="H1961"\w* culpables.  
\v 11 He \w aquí|strong="H2009"\w*, \w el|strong="H5921"\w* \w sumo|strong="H7218"\w* \w sacerdote|strong="H3548"\w* Amarías \w estará|strong="H1961"\w* \w sobre|strong="H5921"\w* \w vosotros|strong="H5973"\w* \w en|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* asuntos \w de|strong="H5921"\w* Yahvé; \w y|strong="H5921"\w* \w Zebadías|strong="H2069"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Ismael|strong="H3458"\w*, \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w en|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* asuntos \w del|strong="H5921"\w* \w rey|strong="H4428"\w*. \w Los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w servirán|strong="H1961"\w* \w como|strong="H5973"\w* \w oficiales|strong="H7860"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w vosotros|strong="H5973"\w*. \w Esforzaos|strong="H2388"\w* \w y|strong="H5921"\w* obrad \w con|strong="H5973"\w* valentía, \w y|strong="H5921"\w* \w que|strong="H5921"\w* Yahvé \w esté|strong="H1961"\w* \w con|strong="H5973"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w hace|strong="H6213"\w* \w el|strong="H5921"\w* \w bien|strong="H2896"\w*».   
\c 20
\p
\v 1 \w Después|strong="H5921"\w* \w de|strong="H5921"\w* estas cosas, \w aconteció|strong="H1961"\w* \w que|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, \w y|strong="H5921"\w* \w con|strong="H5973"\w* \w ellos|strong="H5921"\w* algunos \w de|strong="H5921"\w* \w los|strong="H1121"\w* meunitas, vinieron \w contra|strong="H5921"\w* Josafat \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w*.  
\v 2 Acudieron algunos \w y|strong="H5921"\w* dieron \w aviso|strong="H5046"\w* \w a|strong="H3068"\w* Josafat, diciendo: «Una \w gran|strong="H7227"\w* \w multitud|strong="H1995"\w* viene \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w desde|strong="H5921"\w* \w el|strong="H1931"\w* otro \w lado|strong="H5676"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w*, \w desde|strong="H5921"\w* Aram; \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w*, \w están|strong="H2009"\w* \w en|strong="H5921"\w* Hazazón Tamar» (\w que|strong="H1931"\w* \w es|strong="H1931"\w* \w En|strong="H5921"\w* Gedi).  
\v 3 Josafat \w tuvo|strong="H3372"\w* \w miedo|strong="H3372"\w* \w y|strong="H5921"\w* dispuso su corazón \w para|strong="H5921"\w* buscar \w a|strong="H3068"\w* Yahvé, \w y|strong="H5921"\w* \w proclamó|strong="H7121"\w* un \w ayuno|strong="H6685"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w*.  
\v 4 Se reunieron \w los|strong="H3605"\w* de \w Judá|strong="H3063"\w* para pedir ayuda \w a|strong="H3068"\w* Yahvé; de \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w* acudieron para buscar \w a|strong="H3068"\w* Yahvé.   
\p
\v 5 Josafat se \w puso|strong="H5975"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w en|strong="H5975"\w* la asamblea \w de|strong="H6440"\w* \w Judá|strong="H3063"\w* y \w de|strong="H6440"\w* Jerusalén, \w en|strong="H5975"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* Yahvé, \w delante|strong="H6440"\w* del \w atrio|strong="H2691"\w* \w nuevo|strong="H2319"\w*,  
\v 6 y dijo: “Oh Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5973"\w* nuestros padres, ¿\w no|strong="H3808"\w* \w eres|strong="H1931"\w* tú \w Dios|strong="H3068"\w* \w en|strong="H5973"\w* \w los|strong="H3605"\w* \w cielos|strong="H8064"\w*, y gobiernas sobre \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reinos|strong="H4467"\w* \w de|strong="H5973"\w* las \w naciones|strong="H1471"\w*? \w En|strong="H5973"\w* tu \w mano|strong="H3027"\w* hay \w fuerza|strong="H3581"\w* y \w poder|strong="H3581"\w*, \w de|strong="H5973"\w* modo \w que|strong="H1931"\w* \w nadie|strong="H3808"\w* puede resistirte.  
\v 7 ¿\w No|strong="H3808"\w* expulsaste tú, Dios nuestro, \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H6440"\w* \w esta|strong="H2063"\w* tierra \w delante|strong="H6440"\w* \w de|strong="H6440"\w* tu \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, y \w la|strong="H2063"\w* \w diste|strong="H5414"\w* \w a|strong="H3068"\w* \w la|strong="H2063"\w* \w descendencia|strong="H2233"\w* \w de|strong="H6440"\w* tu amigo Abraham \w para|strong="H5414"\w* \w siempre|strong="H5769"\w*?  
\v 8 Ellos han habitado en ella, y te han \w edificado|strong="H1129"\w* en ella un \w santuario|strong="H4720"\w* \w a|strong="H3068"\w* tu \w nombre|strong="H8034"\w*, diciendo:  
\v 9 ‘\w Si|strong="H3588"\w* \w nos|strong="H5921"\w* sobreviene \w el|strong="H5921"\w* \w mal|strong="H7451"\w*, \w ya|strong="H2088"\w* sea \w la|strong="H5921"\w* \w espada|strong="H2719"\w*, \w el|strong="H5921"\w* juicio, \w la|strong="H5921"\w* peste \w o|strong="H3068"\w* \w el|strong="H5921"\w* \w hambre|strong="H7458"\w*, \w nos|strong="H5921"\w* presentaremos \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w* \w y|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* (\w porque|strong="H3588"\w* tu \w nombre|strong="H8034"\w* \w está|strong="H2088"\w* \w en|strong="H5921"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w*), \w y|strong="H3588"\w* \w clamaremos|strong="H2199"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w en|strong="H5921"\w* nuestra \w tribulación|strong="H6869"\w*, \w y|strong="H3588"\w* tú \w nos|strong="H5921"\w* escucharás \w y|strong="H3588"\w* \w nos|strong="H5921"\w* \w salvarás|strong="H3467"\w*’.  
\v 10 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, he \w aquí|strong="H2009"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w y|strong="H3588"\w* \w del|strong="H5921"\w* \w monte|strong="H2022"\w* \w Seír|strong="H8165"\w*, \w a|strong="H3068"\w* cuyas tierras \w no|strong="H3808"\w* permitiste \w que|strong="H3588"\w* \w Israel|strong="H3478"\w* entrara \w cuando|strong="H3588"\w* venían \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* apartaron \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w destruyeron|strong="H8045"\w*;  
\v 11 \w mira|strong="H2009"\w* \w cómo|strong="H5921"\w* \w nos|strong="H5921"\w* pagan, viniendo \w a|strong="H3068"\w* arrojarnos \w de|strong="H5921"\w* tu \w posesión|strong="H3425"\w* \w que|strong="H5921"\w* tú \w nos|strong="H5921"\w* diste \w en|strong="H5921"\w* herencia.  
\v 12 \w Oh|strong="H4100"\w* Dios nuestro, ¿\w no|strong="H3808"\w* \w los|strong="H5921"\w* \w juzgarás|strong="H8199"\w* \w tú|strong="H8199"\w*? \w Porque|strong="H3588"\w* \w nosotros|strong="H5921"\w* carecemos \w de|strong="H5921"\w* \w fuerza|strong="H3581"\w* \w ante|strong="H6440"\w* \w esta|strong="H2088"\w* \w gran|strong="H7227"\w* \w multitud|strong="H1995"\w* \w que|strong="H3588"\w* viene \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*; \w no|strong="H3808"\w* \w sabemos|strong="H3045"\w* \w qué|strong="H3588"\w* \w hacer|strong="H6213"\w*, \w pero|strong="H3588"\w* nuestros \w ojos|strong="H5869"\w* \w están|strong="H2088"\w* puestos \w en|strong="H5921"\w* \w ti|strong="H5921"\w*”.   
\p
\v 13 \w Todo|strong="H3605"\w* \w Judá|strong="H3063"\w* \w estaba|strong="H5975"\w* \w de|strong="H6440"\w* \w pie|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, \w con|strong="H1571"\w* sus \w niños|strong="H2945"\w*, sus mujeres \w y|strong="H1571"\w* sus \w hijos|strong="H1121"\w*.   
\p
\v 14 Entonces \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H4480"\w* Yahvé \w vino|strong="H1961"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* asamblea \w sobre|strong="H5921"\w* \w Jahaziel|strong="H3166"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Jeiel|strong="H3273"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Matanías, un \w levita|strong="H3881"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Asaf;  
\v 15 \w y|strong="H3588"\w* dijo: “\w Escuchad|strong="H7181"\w*, \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3588"\w* vosotros \w habitantes|strong="H3427"\w* \w de|strong="H3588"\w* Jerusalén, \w y|strong="H3588"\w* tú, \w rey|strong="H4428"\w* Josafat. \w Así|strong="H3541"\w* os dice Yahvé: ‘\w No|strong="H3808"\w* \w temáis|strong="H3372"\w* \w ni|strong="H3808"\w* os acobardéis \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w esta|strong="H2088"\w* \w gran|strong="H7227"\w* \w multitud|strong="H1995"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w* \w no|strong="H3808"\w* \w es|strong="H2088"\w* vuestra, \w sino|strong="H3588"\w* \w de|strong="H3588"\w* \w Dios|strong="H3068"\w*.  
\v 16 \w Descended|strong="H3381"\w* \w mañana|strong="H4279"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*. He \w aquí|strong="H2005"\w* \w que|strong="H5921"\w* \w ellos|strong="H5921"\w* \w subirán|strong="H5927"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* cuesta \w de|strong="H5921"\w* Ziz, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w hallaréis|strong="H4672"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* extremo \w del|strong="H5921"\w* valle, frente \w al|strong="H5921"\w* \w desierto|strong="H4057"\w* \w de|strong="H5921"\w* Jeruel.  
\v 17 \w No|strong="H3808"\w* tendréis \w que|strong="H3808"\w* pelear \w en|strong="H5973"\w* \w esta|strong="H2063"\w* ocasión. Poneos firmes, quedaos quietos y \w ved|strong="H7200"\w* \w la|strong="H2063"\w* salvación \w que|strong="H3808"\w* Yahvé obrará \w a|strong="H3068"\w* vuestro favor, oh \w Judá|strong="H3063"\w* y Jerusalén. \w No|strong="H3808"\w* \w temáis|strong="H3372"\w* \w ni|strong="H3808"\w* \w os|strong="H5973"\w* acobardéis. \w Salid|strong="H3318"\w* \w mañana|strong="H4279"\w* \w a|strong="H3068"\w* su encuentro, \w porque|strong="H3808"\w* Yahvé \w estará|strong="H5975"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*’”.   
\p
\v 18 Entonces Josafat \w inclinó|strong="H6915"\w* su \w rostro|strong="H6440"\w* \w a|strong="H3068"\w* tierra, y \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* y \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H6440"\w* Jerusalén se postraron \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, para adorar \w a|strong="H3068"\w* Yahvé.  
\v 19 \w Y|strong="H3068"\w* \w se|strong="H4480"\w* \w levantaron|strong="H6965"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Coat y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Coré|strong="H7145"\w* \w para|strong="H4480"\w* \w alabar|strong="H1984"\w* \w a|strong="H3068"\w* Yahvé, \w el|strong="H1121"\w* \w Dios|strong="H3068"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*.   
\p
\v 20 Se levantaron muy de \w mañana|strong="H1242"\w* y \w salieron|strong="H3318"\w* al \w desierto|strong="H4057"\w* de Tecoa. \w Y|strong="H3068"\w* mientras \w salían|strong="H3318"\w*, Josafat se \w puso|strong="H5975"\w* \w en|strong="H3318"\w* \w pie|strong="H5975"\w* y dijo: «¡\w Escuchadme|strong="H8085"\w*, \w Judá|strong="H3063"\w* y \w habitantes|strong="H3427"\w* de Jerusalén! Creed \w en|strong="H3318"\w* Yahvé vuestro \w Dios|strong="H3068"\w*, y \w estaréis|strong="H3427"\w* seguros; creed \w a|strong="H3068"\w* sus \w profetas|strong="H5030"\w*, y seréis prosperados».   
\p
\v 21 Después \w de|strong="H3588"\w* consultar \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*, designó \w a|strong="H3068"\w* algunos \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w cantaran|strong="H7891"\w* \w a|strong="H3068"\w* Yahvé \w y|strong="H3588"\w* lo \w alabaran|strong="H1984"\w* vestidos \w con|strong="H3588"\w* ornamentos \w sagrados|strong="H6944"\w*, \w mientras|strong="H3588"\w* marchaban al frente del ejército, diciendo: «Dad gracias \w a|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w es|strong="H3588"\w* \w eterna|strong="H5769"\w*».  
\v 22 \w Cuando|strong="H6256"\w* \w comenzaron|strong="H2490"\w* \w a|strong="H3068"\w* entonar cantos \w de|strong="H5921"\w* júbilo \w y|strong="H5921"\w* \w alabanza|strong="H8416"\w*, Yahvé \w puso|strong="H5414"\w* emboscadas \w contra|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w y|strong="H5921"\w* \w del|strong="H5921"\w* \w monte|strong="H2022"\w* \w Seír|strong="H8165"\w* \w que|strong="H5921"\w* habían venido \w contra|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* fueron derrotados.  
\v 23 \w Porque|strong="H5921"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w se|strong="H5921"\w* levantaron \w contra|strong="H5921"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w del|strong="H5921"\w* \w monte|strong="H2022"\w* \w Seír|strong="H8165"\w*, \w para|strong="H5921"\w* \w destruirlos|strong="H8045"\w* \w y|strong="H5921"\w* aniquilarlos \w por|strong="H5921"\w* completo; \w y|strong="H5921"\w* cuando \w acabaron|strong="H3615"\w* \w con|strong="H5921"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w Seír|strong="H8165"\w*, \w se|strong="H5921"\w* \w ayudaron|strong="H5826"\w* unos \w a|strong="H3068"\w* otros \w a|strong="H3068"\w* destruirse mutuamente.   
\p
\v 24 Cuando \w Judá|strong="H3063"\w* llegó \w a|strong="H3068"\w* \w la|strong="H5921"\w* atalaya \w del|strong="H5921"\w* \w desierto|strong="H4057"\w*, \w miraron|strong="H6437"\w* \w hacia|strong="H5921"\w* \w la|strong="H5921"\w* \w multitud|strong="H1995"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2005"\w* \w que|strong="H5921"\w* solo había cadáveres \w tendidos|strong="H5307"\w* \w en|strong="H5921"\w* tierra; \w no|strong="H5921"\w* había escapado nadie.  
\v 25 Josafat \w y|strong="H3588"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w fueron|strong="H1961"\w* \w a|strong="H3068"\w* recoger \w el|strong="H1931"\w* botín, \w y|strong="H3588"\w* \w hallaron|strong="H4672"\w* \w entre|strong="H3588"\w* \w los|strong="H1931"\w* cadáveres \w gran|strong="H7227"\w* cantidad \w de|strong="H3588"\w* \w enseres|strong="H3627"\w* \w y|strong="H3588"\w* joyas preciosas, las cuales despojaron \w para|strong="H3588"\w* \w sí|strong="H3588"\w*, \w hasta|strong="H3117"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* pudieron llevar \w más|strong="H3588"\w*. Pasaron \w tres|strong="H7969"\w* \w días|strong="H3117"\w* recogiendo \w el|strong="H1931"\w* botín, \w porque|strong="H3588"\w* \w era|strong="H1961"\w* muchísimo.  
\v 26 \w Al|strong="H5921"\w* \w cuarto|strong="H7243"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* congregaron \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w valle|strong="H6010"\w* \w de|strong="H5921"\w* Beracá, \w porque|strong="H3588"\w* \w allí|strong="H8033"\w* \w bendijeron|strong="H1288"\w* \w a|strong="H3068"\w* Yahvé. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w llamaron|strong="H7121"\w* \w a|strong="H3068"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* «\w Valle|strong="H6010"\w* \w de|strong="H5921"\w* Beracá», \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w hoy|strong="H3117"\w*.  
\v 27 Después, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* Jerusalén, \w con|strong="H3588"\w* Josafat \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w cabeza|strong="H7218"\w*, emprendieron \w el|strong="H3588"\w* regreso \w a|strong="H3068"\w* Jerusalén \w con|strong="H3588"\w* \w gozo|strong="H8057"\w*, \w porque|strong="H3588"\w* Yahvé les \w había|strong="H3588"\w* dado \w alegría|strong="H8057"\w* sobre sus enemigos.  
\v 28 Entraron en Jerusalén al son \w de|strong="H5035"\w* \w arpas|strong="H3658"\w*, liras y \w trompetas|strong="H2689"\w*, y se dirigieron \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5035"\w* Yahvé.  
\v 29 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w temor|strong="H6343"\w* \w de|strong="H5921"\w* \w Dios|strong="H3068"\w* cayó \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w de|strong="H5921"\w* aquellas tierras \w cuando|strong="H3588"\w* \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* Yahvé \w había|strong="H1961"\w* peleado \w contra|strong="H5921"\w* \w los|strong="H5921"\w* enemigos \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 30 Así \w el|strong="H8252"\w* \w reino|strong="H4438"\w* de Josafat tuvo paz, porque su Dios le dio descanso por \w todas|strong="H5439"\w* \w partes|strong="H5439"\w*.   
\p
\v 31 Así \w reinó|strong="H4427"\w* Josafat \w sobre|strong="H5921"\w* \w Judá|strong="H3063"\w*. Tenía \w treinta|strong="H7970"\w* \w y|strong="H5921"\w* \w cinco|strong="H2568"\w* \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* \w veinticinco|strong="H6242"\w* \w años|strong="H8141"\w* \w en|strong="H5921"\w* Jerusalén. Su madre \w se|strong="H5921"\w* \w llamaba|strong="H8034"\w* \w Azubá|strong="H5806"\w*, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Silhí|strong="H7977"\w*.  
\v 32 \w Anduvo|strong="H3212"\w* \w en|strong="H4480"\w* \w el|strong="H6213"\w* \w camino|strong="H1870"\w* \w de|strong="H4480"\w* su padre Asá y \w no|strong="H3808"\w* \w se|strong="H4480"\w* apartó \w de|strong="H4480"\w* \w él|strong="H6213"\w*, \w haciendo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante los \w ojos|strong="H5869"\w* \w de|strong="H4480"\w* Yahvé.  
\v 33 \w Sin|strong="H3808"\w* embargo, los lugares \w altos|strong="H1116"\w* \w no|strong="H3808"\w* fueron quitados, \w pues|strong="H5750"\w* el \w pueblo|strong="H5971"\w* \w aún|strong="H5750"\w* \w no|strong="H3808"\w* había \w dispuesto|strong="H3559"\w* su \w corazón|strong="H3824"\w* \w para|strong="H5493"\w* buscar al Dios \w de|strong="H5750"\w* sus padres.   
\p
\v 34 \w Los|strong="H1121"\w* demás \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Josafat, \w los|strong="H1121"\w* \w primeros|strong="H7223"\w* \w y|strong="H5921"\w* \w los|strong="H1121"\w* últimos, están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* crónicas \w de|strong="H5921"\w* \w Jehú|strong="H3058"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Hananí|strong="H2607"\w*, \w las|strong="H5921"\w* cuales están incluidas \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w libro|strong="H5612"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 35 Después \w de|strong="H5973"\w* \w esto|strong="H1931"\w*, Josafat, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w*, \w se|strong="H1931"\w* alió \w con|strong="H5973"\w* Ocozías, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* actuaba \w con|strong="H5973"\w* gran impiedad.  
\v 36 Se alió \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w para|strong="H5973"\w* construir barcos que fueran \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*, y construyeron \w los|strong="H5973"\w* barcos \w en|strong="H5973"\w* Ezión Geber.  
\v 37 Pero Eliezer, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Dodavahu, \w de|strong="H5921"\w* \w Maresa|strong="H4762"\w*, \w profetizó|strong="H5012"\w* \w contra|strong="H5921"\w* Josafat, diciendo: «\w Por|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w te|strong="H5921"\w* has aliado \w con|strong="H5973"\w* Ocozías, Yahvé \w ha|strong="H3808"\w* destruido tus \w obras|strong="H4639"\w*». \w Y|strong="H3068"\w* \w los|strong="H1121"\w* barcos naufragaron, \w de|strong="H5921"\w* modo \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w pudieron|strong="H6113"\w* \w ir|strong="H3212"\w* \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*.   
\c 21
\p
\v 1 Josafat \w durmió|strong="H7901"\w* \w con|strong="H5973"\w* sus padres y fue \w sepultado|strong="H6912"\w* \w con|strong="H5973"\w* ellos \w en|strong="H5973"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H8478"\w* \w David|strong="H1732"\w*; y su \w hijo|strong="H1121"\w* \w Joram|strong="H3088"\w* \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w*.  
\v 2 Tuvo hermanos, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Josafat: \w Azarías|strong="H5838"\w*, \w Jehiel|strong="H3171"\w*, \w Zacarías|strong="H2148"\w*, \w Azarías|strong="H5838"\w*, \w Miguel|strong="H4317"\w* y Sefatías. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* eran \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.  
\v 3 \w Su|strong="H1931"\w* padre \w les|strong="H1992"\w* \w había|strong="H3588"\w* \w dado|strong="H5414"\w* espléndidos regalos \w de|strong="H3588"\w* \w plata|strong="H3701"\w*, \w oro|strong="H2091"\w* \w y|strong="H3588"\w* objetos preciosos, \w junto|strong="H5973"\w* \w con|strong="H5973"\w* \w ciudades|strong="H5892"\w* fortificadas \w en|strong="H5973"\w* \w Judá|strong="H3063"\w*; \w pero|strong="H3588"\w* \w entregó|strong="H5414"\w* \w el|strong="H1931"\w* \w reino|strong="H4467"\w* \w a|strong="H3068"\w* \w Joram|strong="H3088"\w*, \w por|strong="H3588"\w* ser \w el|strong="H1931"\w* \w primogénito|strong="H1060"\w*.  
\v 4 \w Cuando|strong="H1571"\w* \w Joram|strong="H3088"\w* \w se|strong="H5921"\w* afianzó \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w reino|strong="H4467"\w* \w de|strong="H5921"\w* su padre \w y|strong="H1571"\w* \w se|strong="H5921"\w* hizo fuerte, \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* algunos \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w príncipes|strong="H8269"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 5 \w Joram|strong="H3088"\w* tenía \w treinta|strong="H7970"\w* y \w dos|strong="H8147"\w* \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w ocho|strong="H8083"\w* \w años|strong="H8141"\w* en Jerusalén.  
\v 6 \w Anduvo|strong="H3212"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, tal \w como|strong="H3588"\w* \w había|strong="H1961"\w* \w hecho|strong="H6213"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Ajab (\w pues|strong="H3588"\w* \w tenía|strong="H1961"\w* \w por|strong="H3588"\w* mujer \w a|strong="H3068"\w* una \w hija|strong="H1323"\w* \w de|strong="H3588"\w* Ajab), \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* Yahvé.  
\v 7 \w Sin|strong="H3808"\w* embargo, Yahvé \w no|strong="H3808"\w* quiso \w destruir|strong="H7843"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w a|strong="H3068"\w* causa \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w alianza|strong="H1285"\w* \w que|strong="H3808"\w* había \w hecho|strong="H3772"\w* con \w él|strong="H3605"\w*, y \w porque|strong="H3808"\w* le había prometido mantener \w siempre|strong="H3605"\w* una \w lámpara|strong="H5216"\w* \w para|strong="H4616"\w* \w él|strong="H3605"\w* y \w para|strong="H4616"\w* sus \w hijos|strong="H1121"\w*.   
\p
\v 8 \w En|strong="H5921"\w* sus \w días|strong="H3117"\w* Edom \w se|strong="H5921"\w* rebeló \w contra|strong="H5921"\w* \w el|strong="H5921"\w* dominio \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* establecieron su propio \w rey|strong="H4428"\w*.  
\v 9 Entonces \w Joram|strong="H3088"\w* \w pasó|strong="H5674"\w* hacia allá \w con|strong="H5973"\w* sus \w jefes|strong="H8269"\w* y \w con|strong="H5973"\w* \w todos|strong="H3605"\w* sus \w carros|strong="H7393"\w*. \w Se|strong="H1961"\w* \w levantó|strong="H6965"\w* \w de|strong="H5973"\w* \w noche|strong="H3915"\w* y atacó \w a|strong="H3068"\w* \w los|strong="H3605"\w* edomitas \w que|strong="H1961"\w* \w lo|strong="H3605"\w* \w habían|strong="H1961"\w* cercado, y \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w capitanes|strong="H8269"\w* \w de|strong="H5973"\w* \w los|strong="H3605"\w* \w carros|strong="H7393"\w*.  
\v 10 \w Así|strong="H2088"\w* \w se|strong="H1931"\w* rebeló Edom contra \w el|strong="H1931"\w* dominio \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w hoy|strong="H3117"\w*. \w En|strong="H5704"\w* \w aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w tiempo|strong="H6256"\w*, \w también|strong="H2088"\w* \w Libna|strong="H3841"\w* \w se|strong="H1931"\w* rebeló contra \w su|strong="H1931"\w* dominio, \w porque|strong="H3588"\w* Joram \w había|strong="H3588"\w* abandonado \w a|strong="H3068"\w* Yahvé, \w el|strong="H1931"\w* \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w sus|strong="H1931"\w* padres.   
\p
\v 11 \w Además|strong="H1571"\w*, \w hizo|strong="H6213"\w* lugares \w altos|strong="H1116"\w* en \w los|strong="H3427"\w* \w montes|strong="H2022"\w* de \w Judá|strong="H3063"\w*, indujo \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Jerusalén \w a|strong="H3068"\w* prostituirse, \w y|strong="H1571"\w* descarrió \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*.  
\v 12 \w Y|strong="H3068"\w* le llegó una carta del \w profeta|strong="H5030"\w* Elías \w que|strong="H3808"\w* decía: “\w Así|strong="H3541"\w* dice Yahvé, \w el|strong="H5030"\w* \w Dios|strong="H3068"\w* \w de|strong="H8478"\w* tu padre \w David|strong="H1732"\w*: ‘\w Por|strong="H8478"\w* \w cuanto|strong="H8478"\w* \w no|strong="H3808"\w* has \w andado|strong="H1980"\w* \w en|strong="H8478"\w* los \w caminos|strong="H1870"\w* \w de|strong="H8478"\w* tu padre Josafat, \w ni|strong="H3808"\w* \w en|strong="H8478"\w* los \w caminos|strong="H1870"\w* \w de|strong="H8478"\w* Asá, \w rey|strong="H4428"\w* \w de|strong="H8478"\w* \w Judá|strong="H3063"\w*,  
\v 13 \w sino|strong="H2896"\w* \w que|strong="H4480"\w* \w has|strong="H2026"\w* andado \w en|strong="H4480"\w* \w el|strong="H3427"\w* \w camino|strong="H1870"\w* \w de|strong="H4480"\w* \w los|strong="H3427"\w* \w reyes|strong="H4428"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w y|strong="H1571"\w* \w has|strong="H2026"\w* hecho \w que|strong="H4480"\w* \w Judá|strong="H3063"\w* \w y|strong="H1571"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H4480"\w* Jerusalén \w se|strong="H4480"\w* prostituyan \w como|strong="H1571"\w* \w se|strong="H4480"\w* prostituyó \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H4480"\w* Ajab; \w y|strong="H1571"\w* \w por|strong="H4480"\w* cuanto \w has|strong="H2026"\w* matado \w a|strong="H3068"\w* tus hermanos, \w a|strong="H3068"\w* \w la|strong="H1571"\w* \w familia|strong="H1004"\w* \w de|strong="H4480"\w* tu padre, \w los|strong="H3427"\w* cuales eran \w mejores|strong="H2896"\w* \w que|strong="H4480"\w* tú,  
\v 14 he \w aquí|strong="H2009"\w*, Yahvé \w herirá|strong="H5062"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* con una \w gran|strong="H1419"\w* \w plaga|strong="H4046"\w*, \w a|strong="H3068"\w* tus \w hijos|strong="H1121"\w*, \w a|strong="H3068"\w* tus mujeres y \w a|strong="H3068"\w* \w todas|strong="H3605"\w* tus posesiones;  
\v 15 \w y|strong="H5921"\w* tú padecerás una grave \w enfermedad|strong="H2483"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w entrañas|strong="H4578"\w*, \w hasta|strong="H5704"\w* \w que|strong="H4480"\w* \w las|strong="H5921"\w* \w entrañas|strong="H4578"\w* \w se|strong="H5921"\w* \w te|strong="H5921"\w* \w salgan|strong="H3318"\w* \w a|strong="H3068"\w* causa \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w enfermedad|strong="H2483"\w*, \w día|strong="H3117"\w* tras \w día|strong="H3117"\w*’”.   
\p
\v 16 Yahvé \w despertó|strong="H5782"\w* \w contra|strong="H5921"\w* \w Joram|strong="H3088"\w* \w el|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* árabes \w que|strong="H5921"\w* están \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* etíopes.  
\v 17 \w Subieron|strong="H5927"\w* contra \w Judá|strong="H3063"\w*, invadieron \w el|strong="H3588"\w* país \w y|strong="H1571"\w* \w se|strong="H3808"\w* llevaron \w todos|strong="H3605"\w* \w los|strong="H1121"\w* bienes \w que|strong="H3588"\w* \w se|strong="H3808"\w* \w hallaban|strong="H4672"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* palacio del \w rey|strong="H4428"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w y|strong="H1571"\w* \w a|strong="H3068"\w* sus mujeres, \w de|strong="H3588"\w* modo \w que|strong="H3588"\w* \w no|strong="H3808"\w* le \w quedó|strong="H7604"\w* \w ningún|strong="H3605"\w* \w hijo|strong="H1121"\w*, excepto Joacaz, \w el|strong="H3588"\w* \w menor|strong="H6996"\w* \w de|strong="H3588"\w* \w ellos|strong="H1571"\w*.   
\p
\v 18 Después de \w todo|strong="H3605"\w* \w esto|strong="H2063"\w*, Yahvé \w lo|strong="H3605"\w* \w hirió|strong="H5062"\w* en las \w entrañas|strong="H4578"\w* con una \w enfermedad|strong="H2483"\w* incurable.  
\v 19 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3808"\w*, \w con|strong="H5973"\w* \w el|strong="H5973"\w* paso \w del|strong="H5973"\w* \w tiempo|strong="H6256"\w*, \w al|strong="H6256"\w* cabo \w de|strong="H5973"\w* \w dos|strong="H8147"\w* \w años|strong="H3117"\w*, las \w entrañas|strong="H4578"\w* \w se|strong="H1961"\w* \w le|strong="H5973"\w* \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* causa \w de|strong="H5973"\w* su \w enfermedad|strong="H2483"\w*, y \w murió|strong="H4191"\w* \w entre|strong="H5973"\w* terribles dolores. Su \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* encendió \w ninguna|strong="H3808"\w* hoguera \w en|strong="H5973"\w* su honor, \w como|strong="H5973"\w* las \w que|strong="H3808"\w* \w habían|strong="H1961"\w* encendido por sus padres.  
\v 20 \w Tenía|strong="H1961"\w* \w treinta|strong="H7970"\w* y \w dos|strong="H8147"\w* \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w ocho|strong="H8083"\w* \w años|strong="H8141"\w* \w en|strong="H6912"\w* Jerusalén. Murió \w sin|strong="H3808"\w* \w que|strong="H3808"\w* \w nadie|strong="H3808"\w* \w lo|strong="H3808"\w* lamentara, y \w lo|strong="H3808"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H6912"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, pero \w no|strong="H3808"\w* \w en|strong="H6912"\w* \w los|strong="H1121"\w* \w sepulcros|strong="H6913"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w*.   
\c 22
\p
\v 1 \w Los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H3588"\w* Jerusalén proclamaron \w rey|strong="H4428"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w lugar|strong="H8478"\w* \w a|strong="H3068"\w* Ocozías, \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* \w menor|strong="H6996"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* banda armada \w que|strong="H3588"\w* \w había|strong="H3588"\w* venido \w con|strong="H3588"\w* \w los|strong="H3427"\w* árabes \w al|strong="H4428"\w* \w campamento|strong="H4264"\w* \w había|strong="H3588"\w* matado \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* mayores. \w Así|strong="H3588"\w* \w reinó|strong="H4427"\w* Ocozías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Joram|strong="H3088"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*.  
\v 2 Ocozías tenía cuarenta y \w dos|strong="H8147"\w* \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* un \w año|strong="H8141"\w* en Jerusalén. Su madre se \w llamaba|strong="H8034"\w* \w Atalía|strong="H6271"\w*, nieta \w de|strong="H1121"\w* \w Omrí|strong="H6018"\w*.  
\v 3 \w Él|strong="H1931"\w* \w también|strong="H1571"\w* \w anduvo|strong="H1980"\w* \w en|strong="H3588"\w* \w los|strong="H1961"\w* \w caminos|strong="H1870"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Ajab, \w porque|strong="H3588"\w* \w su|strong="H1931"\w* madre \w le|strong="H1931"\w* \w aconsejaba|strong="H3289"\w* \w a|strong="H3068"\w* obrar perversamente.  
\v 4 \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* Yahvé, \w como|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Ajab, \w pues|strong="H3588"\w* \w después|strong="H1961"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* padre, \w ellos|strong="H1992"\w* \w fueron|strong="H1961"\w* \w sus|strong="H1992"\w* \w consejeros|strong="H3289"\w*, \w para|strong="H3588"\w* \w su|strong="H1992"\w* propia ruina.  
\v 5 \w Siguiendo|strong="H3212"\w* \w el|strong="H5921"\w* \w consejo|strong="H6098"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w* \w con|strong="H5921"\w* \w Joram|strong="H3088"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ajab, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w contra|strong="H5921"\w* \w Hazael|strong="H2371"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria, \w en|strong="H5921"\w* Ramot \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*; \w y|strong="H1571"\w* \w los|strong="H1121"\w* sirios \w hirieron|strong="H5221"\w* \w a|strong="H3068"\w* \w Joram|strong="H3088"\w*.  
\v 6 \w Él|strong="H1931"\w* regresó \w a|strong="H3068"\w* \w Jezreel|strong="H3157"\w* \w para|strong="H3588"\w* curarse \w de|strong="H3588"\w* las \w heridas|strong="H4347"\w* \w que|strong="H3588"\w* \w le|strong="H1931"\w* habían infligido \w en|strong="H3588"\w* \w Ramá|strong="H7414"\w* \w cuando|strong="H3588"\w* \w peleó|strong="H3898"\w* contra \w Hazael|strong="H2371"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Siria. \w Y|strong="H3068"\w* \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Joram|strong="H3088"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w descendió|strong="H3381"\w* \w a|strong="H3068"\w* \w Jezreel|strong="H3157"\w* \w para|strong="H3588"\w* visitar \w a|strong="H3068"\w* \w Joram|strong="H3088"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Ajab, \w porque|strong="H3588"\w* estaba \w enfermo|strong="H2470"\w*.   
\p
\v 7 Pero la ruina \w de|strong="H5973"\w* Ocozías \w vino|strong="H1961"\w* \w de|strong="H5973"\w* \w Dios|strong="H3068"\w* por \w haber|strong="H1961"\w* ido \w a|strong="H3068"\w* visitar \w a|strong="H3068"\w* \w Joram|strong="H3088"\w*; \w pues|strong="H1961"\w*, al llegar, \w salió|strong="H3318"\w* \w con|strong="H5973"\w* \w Joram|strong="H3088"\w* al encuentro \w de|strong="H5973"\w* \w Jehú|strong="H3058"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Nimsí, \w a|strong="H3068"\w* quien Yahvé \w había|strong="H1961"\w* \w ungido|strong="H4886"\w* \w para|strong="H1961"\w* exterminar \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Ajab.  
\v 8 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1121"\w*, mientras \w Jehú|strong="H3058"\w* ejecutaba \w el|strong="H5973"\w* juicio \w contra|strong="H5973"\w* la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Ajab, \w halló|strong="H4672"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w príncipes|strong="H8269"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w los|strong="H1121"\w* hermanos \w de|strong="H5973"\w* Ocozías \w que|strong="H1121"\w* servían \w a|strong="H3068"\w* Ocozías, y \w los|strong="H1121"\w* \w mató|strong="H2026"\w*.  
\v 9 \w Luego|strong="H1931"\w* \w buscó|strong="H1875"\w* \w a|strong="H3068"\w* Ocozías (\w que|strong="H3588"\w* \w se|strong="H1931"\w* \w había|strong="H3588"\w* \w escondido|strong="H2244"\w* \w en|strong="H3588"\w* \w Samaria|strong="H8111"\w*); \w lo|strong="H1931"\w* apresaron, \w lo|strong="H1931"\w* llevaron ante \w Jehú|strong="H3058"\w* \w y|strong="H3588"\w* \w lo|strong="H1931"\w* \w mataron|strong="H4191"\w*. \w Y|strong="H3068"\w* \w le|strong="H1931"\w* dieron sepultura, \w porque|strong="H3588"\w* decían: «\w Es|strong="H1931"\w* \w nieto|strong="H1121"\w* \w de|strong="H3588"\w* Josafat, \w quien|strong="H3605"\w* \w buscó|strong="H1875"\w* \w a|strong="H3068"\w* Yahvé \w con|strong="H3588"\w* \w todo|strong="H3605"\w* \w su|strong="H1931"\w* \w corazón|strong="H3824"\w*». \w Así|strong="H3588"\w*, \w en|strong="H3588"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Ocozías \w no|strong="H3588"\w* quedó \w nadie|strong="H3605"\w* \w con|strong="H3588"\w* \w poder|strong="H3581"\w* \w para|strong="H3588"\w* \w retener|strong="H6113"\w* \w el|strong="H1931"\w* \w reino|strong="H4467"\w*.   
\p
\v 10 \w Cuando|strong="H3588"\w* \w Atalía|strong="H6271"\w*, madre \w de|strong="H3588"\w* Ocozías, \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* \w había|strong="H3588"\w* \w muerto|strong="H4191"\w*, se \w levantó|strong="H6965"\w* \w y|strong="H3588"\w* exterminó \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w descendencia|strong="H2233"\w* \w real|strong="H4467"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*.  
\v 11 \w Pero|strong="H3588"\w* Josabet, \w hija|strong="H1323"\w* del \w rey|strong="H4428"\w*, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Ocozías, \w lo|strong="H1931"\w* sacó furtivamente \w de|strong="H3588"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w* \w a|strong="H3068"\w* quienes \w estaban|strong="H1961"\w* \w matando|strong="H4191"\w*, \w y|strong="H3588"\w* \w lo|strong="H1931"\w* \w escondió|strong="H5641"\w* \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* nodriza \w en|strong="H8432"\w* un aposento. \w Así|strong="H3588"\w*, Josabet, \w hija|strong="H1323"\w* del \w rey|strong="H4428"\w* \w Joram|strong="H3088"\w* \w y|strong="H3588"\w* esposa del \w sacerdote|strong="H3548"\w* \w Joiada|strong="H3077"\w* (\w porque|strong="H3588"\w* \w era|strong="H1961"\w* hermana \w de|strong="H3588"\w* Ocozías), \w lo|strong="H1931"\w* \w escondió|strong="H5641"\w* \w de|strong="H3588"\w* \w Atalía|strong="H6271"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w matara|strong="H4191"\w*.  
\v 12 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* niño \w estuvo|strong="H1961"\w* \w escondido|strong="H2244"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Dios durante \w seis|strong="H8337"\w* \w años|strong="H8141"\w*, mientras \w Atalía|strong="H6271"\w* \w reinaba|strong="H4427"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* país.   
\c 23
\p
\v 1 \w En|strong="H5973"\w* \w el|strong="H5973"\w* \w séptimo|strong="H7637"\w* \w año|strong="H8141"\w*, \w Joiada|strong="H3077"\w* cobró \w ánimo|strong="H2388"\w* y \w tomó|strong="H3947"\w* \w en|strong="H5973"\w* \w alianza|strong="H1285"\w* \w consigo|strong="H5973"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H5973"\w* centenas: \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Jeroham|strong="H3395"\w*, \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Johanán|strong="H3076"\w*, \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Obed|strong="H5744"\w*, \w Maasías|strong="H4641"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Adaías|strong="H5718"\w*, y Elisafat, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Zicri.  
\v 2 Recorrieron \w Judá|strong="H3063"\w*, reunieron \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* de \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w* y \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w jefes|strong="H7218"\w* de las familias de \w Israel|strong="H3478"\w*, y vinieron \w a|strong="H3068"\w* Jerusalén.  
\v 3 \w Toda|strong="H3605"\w* \w la|strong="H5921"\w* asamblea \w hizo|strong="H3772"\w* un \w pacto|strong="H1285"\w* \w con|strong="H5973"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Dios|strong="H3068"\w*. \w Y|strong="H3068"\w* Joiada\f + \fr 23:3 \ft Hebreo: \fq Él\f* \w les|strong="H1992"\w* \w dijo|strong="H1696"\w*: «He \w aquí|strong="H2009"\w*, \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w reinará|strong="H4427"\w*, tal \w como|strong="H5973"\w* Yahvé ha prometido respecto \w a|strong="H3068"\w* \w los|strong="H1992"\w* descendientes \w de|strong="H5921"\w* \w David|strong="H1732"\w*.  
\v 4 \w Esto|strong="H2088"\w* \w es|strong="H2088"\w* \w lo|strong="H1697"\w* \w que|strong="H4480"\w* debéis \w hacer|strong="H6213"\w*: una \w tercera|strong="H7992"\w* parte \w de|strong="H4480"\w* vosotros, \w sacerdotes|strong="H3548"\w* y \w levitas|strong="H3881"\w* \w que|strong="H4480"\w* entráis \w de|strong="H4480"\w* turno \w el|strong="H6213"\w* \w sábado|strong="H7676"\w*, seréis \w porteros|strong="H7778"\w* \w en|strong="H4480"\w* los umbrales.  
\v 5 Otra \w tercera|strong="H7992"\w* parte \w estará|strong="H3605"\w* en \w el|strong="H3605"\w* palacio del \w rey|strong="H4428"\w*, y \w la|strong="H3605"\w* otra \w tercera|strong="H7992"\w* parte en \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* del Cimiento. \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* quedará en \w los|strong="H3605"\w* \w atrios|strong="H2691"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Yahvé.  
\v 6 \w Pero|strong="H3588"\w* \w que|strong="H3588"\w* \w nadie|strong="H3605"\w* \w entre|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé, excepto \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w los|strong="H1992"\w* \w levitas|strong="H3881"\w* \w que|strong="H3588"\w* \w ministran|strong="H8334"\w*; \w ellos|strong="H1992"\w* pueden entrar \w porque|strong="H3588"\w* están consagrados. \w Todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w guardará|strong="H8104"\w* \w el|strong="H3588"\w* mandato \w de|strong="H3588"\w* Yahvé.  
\v 7 \w Los|strong="H1961"\w* \w levitas|strong="H3881"\w* \w rodearán|strong="H5362"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, cada uno con sus \w armas|strong="H3627"\w* \w en|strong="H3318"\w* la \w mano|strong="H3027"\w*; y \w cualquiera|strong="H3318"\w* \w que|strong="H1961"\w* intente entrar \w en|strong="H3318"\w* el \w templo|strong="H1004"\w*, \w será|strong="H1961"\w* \w muerto|strong="H4191"\w*. \w Estaréis|strong="H1961"\w* con el \w rey|strong="H4428"\w* \w cuando|strong="H1961"\w* entre y \w cuando|strong="H1961"\w* \w salga|strong="H3318"\w*».   
\p
\v 8 \w Los|strong="H3605"\w* \w levitas|strong="H3881"\w* \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* \w hicieron|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* \w mandado|strong="H6680"\w* \w el|strong="H5973"\w* \w sacerdote|strong="H3548"\w* \w Joiada|strong="H3077"\w*. \w Cada|strong="H3605"\w* jefe \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* sus hombres, tanto \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* entraban \w de|strong="H3588"\w* turno \w el|strong="H5973"\w* \w sábado|strong="H7676"\w* \w como|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w salían|strong="H3318"\w* \w el|strong="H5973"\w* \w sábado|strong="H7676"\w*, \w porque|strong="H3588"\w* \w el|strong="H5973"\w* \w sacerdote|strong="H3548"\w* \w Joiada|strong="H3077"\w* \w no|strong="H3808"\w* \w había|strong="H3588"\w* despedido \w a|strong="H3068"\w* \w los|strong="H3605"\w* grupos.  
\v 9 El \w sacerdote|strong="H3548"\w* \w Joiada|strong="H3077"\w* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* centenas las lanzas, las rodelas y los \w escudos|strong="H4043"\w* que habían pertenecido \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* y que se guardaban en la \w casa|strong="H1004"\w* \w de|strong="H8269"\w* Dios.  
\v 10 \w Y|strong="H3068"\w* situó \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w cada|strong="H3605"\w* uno \w con|strong="H5921"\w* su arma \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w*, \w desde|strong="H5704"\w* \w el|strong="H5921"\w* \w lado|strong="H3802"\w* \w derecho|strong="H3233"\w* \w del|strong="H5921"\w* \w templo|strong="H1004"\w* \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w lado|strong="H3802"\w* \w izquierdo|strong="H8042"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w templo|strong="H1004"\w*, rodeando \w al|strong="H5921"\w* \w rey|strong="H4428"\w*.  
