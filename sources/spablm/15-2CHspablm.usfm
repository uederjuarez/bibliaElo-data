\v 2 Ezequías restableció \w las|strong="H5921"\w* divisiones \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w según|strong="H5921"\w* sus turnos, cada cual \w según|strong="H5921"\w* su \w ministerio|strong="H5656"\w*, \w tanto|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w como|strong="H5921"\w* \w levitas|strong="H3881"\w*, \w para|strong="H5921"\w* ofrecer \w los|strong="H5921"\w* \w holocaustos|strong="H5930"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* sacrificios \w de|strong="H5921"\w* comunión, \w para|strong="H5921"\w* ministrar, \w para|strong="H5921"\w* dar gracias \w y|strong="H5921"\w* \w para|strong="H5921"\w* \w alabar|strong="H1984"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H8179"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* atrios \w de|strong="H5921"\w* Yahvé.  
\v 3 También destinó una porción \w de|strong="H4480"\w* sus propios bienes \w para|strong="H4480"\w* los \w holocaustos|strong="H5930"\w*: \w para|strong="H4480"\w* los \w holocaustos|strong="H5930"\w* \w de|strong="H4480"\w* la \w mañana|strong="H1242"\w* y \w de|strong="H4480"\w* la \w tarde|strong="H6153"\w*, y \w para|strong="H4480"\w* los \w holocaustos|strong="H5930"\w* \w de|strong="H4480"\w* los \w sábados|strong="H7676"\w*, lunas \w nuevas|strong="H2320"\w* y fiestas señaladas, tal como \w está|strong="H3789"\w* \w escrito|strong="H3789"\w* \w en|strong="H4480"\w* la \w ley|strong="H8451"\w* \w de|strong="H4480"\w* Yahvé.  
\v 4 Además, ordenó al \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w habitaba|strong="H3427"\w* en Jerusalén \w que|strong="H5971"\w* \w diera|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w sacerdotes|strong="H3548"\w* y \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w levitas|strong="H3881"\w* la porción \w que|strong="H5971"\w* les correspondía, \w a|strong="H3068"\w* fin \w de|strong="H5971"\w* \w que|strong="H5971"\w* pudieran dedicarse \w enteramente|strong="H5414"\w* \w a|strong="H3068"\w* la \w ley|strong="H8451"\w* \w de|strong="H5971"\w* Yahvé.  
\v 5 Tan pronto como se divulgó \w el|strong="H3605"\w* edicto, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* entregaron en \w abundancia|strong="H7230"\w* las \w primicias|strong="H7225"\w* del \w grano|strong="H1715"\w*, del \w vino|strong="H8492"\w* nuevo, del \w aceite|strong="H3323"\w*, \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w miel|strong="H1706"\w* y \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w frutos|strong="H8393"\w* del \w campo|strong="H7704"\w*. También trajeron en \w abundancia|strong="H7230"\w* \w el|strong="H3605"\w* diezmo \w de|strong="H1121"\w* \w todas|strong="H3605"\w* las \w cosas|strong="H1697"\w*.  
\v 6 \w Los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w y|strong="H1571"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* \w que|strong="H1571"\w* \w habitaban|strong="H3427"\w* en \w las|strong="H1992"\w* \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, trajeron \w igualmente|strong="H1571"\w* \w el|strong="H1121"\w* diezmo del \w ganado|strong="H6629"\w* mayor \w y|strong="H1571"\w* menor, \w y|strong="H1571"\w* \w el|strong="H1121"\w* diezmo \w de|strong="H1121"\w* \w las|strong="H1992"\w* \w cosas|strong="H1992"\w* \w santas|strong="H6944"\w* consagradas \w a|strong="H3068"\w* Yahvé \w su|strong="H1992"\w* \w Dios|strong="H3068"\w*, \w y|strong="H1571"\w* \w los|strong="H1992"\w* depositaron en montones.   
\p
\v 7 \w Comenzaron|strong="H2490"\w* \w a|strong="H3068"\w* formar los montones en el tercer \w mes|strong="H2320"\w* y terminaron en el \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w*.  
\v 8 Cuando Ezequías y los \w jefes|strong="H8269"\w* vinieron y \w vieron|strong="H7200"\w* los montones, \w bendijeron|strong="H1288"\w* \w a|strong="H3068"\w* Yahvé y \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.  
\v 9 Ezequías preguntó \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* montones,  
\v 10 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w sumo|strong="H7218"\w* \w sacerdote|strong="H3548"\w* \w Azarías|strong="H5838"\w*, \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Sadoc|strong="H6659"\w*, le respondió: «\w Desde|strong="H5704"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* traer las \w ofrendas|strong="H8641"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé, hemos tenido \w para|strong="H5704"\w* comer \w y|strong="H3588"\w* saciarnos, \w y|strong="H3588"\w* nos ha sobrado \w en|strong="H5704"\w* gran cantidad; \w porque|strong="H3588"\w* Yahvé ha bendecido \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H3588"\w* ha quedado \w esta|strong="H2088"\w* inmensa \w abundancia|strong="H7230"\w*».   
\p
\v 11 Entonces Ezequías ordenó que se prepararan \w cámaras|strong="H3957"\w* en la \w casa|strong="H1004"\w* de Yahvé, y así lo hicieron.  
\v 12 \w Y|strong="H3068"\w* trajeron allí fielmente \w las|strong="H5921"\w* \w ofrendas|strong="H8641"\w*, \w los|strong="H5921"\w* diezmos \w y|strong="H5921"\w* \w las|strong="H5921"\w* cosas consagradas. \w El|strong="H5921"\w* \w levita|strong="H3881"\w* Conanías era \w el|strong="H5921"\w* encargado principal \w de|strong="H5921"\w* \w ellas|strong="H5921"\w*, \w y|strong="H5921"\w* su hermano Simei era \w el|strong="H5921"\w* \w segundo|strong="H4932"\w* \w al|strong="H5921"\w* mando.  
\v 13 \w Jehiel|strong="H3171"\w*, \w Azazías|strong="H5812"\w*, Nahat, \w Asael|strong="H6214"\w*, Jerimot, \w Jozabad|strong="H3107"\w*, Eliel, Ismaquías, Mahat y \w Benaía|strong="H1141"\w* eran inspectores bajo la autoridad \w de|strong="H5057"\w* Conanías y \w de|strong="H5057"\w* su hermano Simei, \w por|strong="H3027"\w* nombramiento del \w rey|strong="H4428"\w* Ezequías y \w de|strong="H5057"\w* \w Azarías|strong="H5838"\w*, \w príncipe|strong="H5057"\w* \w de|strong="H5057"\w* la \w casa|strong="H1004"\w* \w de|strong="H5057"\w* Dios.  
\v 14 \w El|strong="H5921"\w* \w levita|strong="H3881"\w* Coré, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Imná|strong="H3232"\w*, guardián \w de|strong="H5921"\w* \w la|strong="H5921"\w* puerta \w oriental|strong="H4217"\w*, estaba \w a|strong="H3068"\w* cargo \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w ofrendas|strong="H8641"\w* \w voluntarias|strong="H5071"\w* hechas \w a|strong="H3068"\w* \w Dios|strong="H3068"\w*, \w para|strong="H5921"\w* distribuir \w las|strong="H5921"\w* \w ofrendas|strong="H8641"\w* consagradas \w a|strong="H3068"\w* Yahvé \w y|strong="H5921"\w* \w las|strong="H5921"\w* cosas santísimas.  
