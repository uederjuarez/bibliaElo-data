\v 33 Las ofrendas consagradas fueron \w seiscientas|strong="H8337"\w* reses \w y|strong="H1241"\w* \w tres|strong="H7969"\w* \w mil|strong="H3967"\w* \w ovejas|strong="H6629"\w*.  
\v 34 \w Pero|strong="H3588"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w eran|strong="H1961"\w* muy \w pocos|strong="H4592"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* daban abasto \w para|strong="H5704"\w* desollar \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w holocaustos|strong="H5930"\w*. \w Por|strong="H3588"\w* tanto, sus hermanos \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* les \w ayudaron|strong="H2388"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w obra|strong="H4399"\w* \w se|strong="H1961"\w* terminó \w y|strong="H3588"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w los|strong="H3605"\w* demás \w sacerdotes|strong="H3548"\w* \w se|strong="H1961"\w* santificaron, \w pues|strong="H3588"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* \w habían|strong="H1961"\w* \w sido|strong="H1961"\w* \w más|strong="H3588"\w* \w rectos|strong="H3477"\w* \w de|strong="H3588"\w* \w corazón|strong="H3824"\w* \w para|strong="H5704"\w* santificarse \w que|strong="H3588"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w*.  
\v 35 \w Además|strong="H1571"\w*, hubo \w holocaustos|strong="H5930"\w* en \w abundancia|strong="H7230"\w*, junto \w con|strong="H1571"\w* \w la|strong="H1571"\w* grasa de los sacrificios de comunión \w y|strong="H1571"\w* las \w libaciones|strong="H5262"\w* para cada \w holocausto|strong="H5930"\w*. \w Así|strong="H1571"\w* quedó restablecido \w el|strong="H1571"\w* servicio de \w la|strong="H1571"\w* \w casa|strong="H1004"\w* de Yahvé.  
\v 36 \w Y|strong="H3068"\w* Ezequías \w se|strong="H1961"\w* alegró \w con|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w que|strong="H3588"\w* Dios hubiera preparado \w el|strong="H5921"\w* corazón \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w pues|strong="H3588"\w* \w todo|strong="H3605"\w* \w esto|strong="H1697"\w* \w se|strong="H1961"\w* \w había|strong="H1961"\w* logrado tan \w repentinamente|strong="H6597"\w*.   
\c 30
\p
\v 1 Ezequías \w envió|strong="H7971"\w* mensajeros \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w y|strong="H1571"\w* \w Judá|strong="H3063"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w escribió|strong="H3789"\w* cartas \w a|strong="H3068"\w* Efraín \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w Manasés|strong="H4519"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* vinieran \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé \w en|strong="H5921"\w* Jerusalén \w a|strong="H3068"\w* \w celebrar|strong="H6213"\w* \w la|strong="H5921"\w* \w Pascua|strong="H6453"\w* \w a|strong="H3068"\w* Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 2 Pues \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w había|strong="H6213"\w* acordado con sus \w jefes|strong="H8269"\w* y con \w toda|strong="H3605"\w* \w la|strong="H3605"\w* asamblea en Jerusalén \w celebrar|strong="H6213"\w* \w la|strong="H3605"\w* \w Pascua|strong="H6453"\w* en \w el|strong="H3605"\w* \w mes|strong="H2320"\w* \w segundo|strong="H8145"\w*.  
\v 3 \w No|strong="H3808"\w* habían podido celebrarla \w en|strong="H3588"\w* \w su|strong="H1931"\w* \w tiempo|strong="H6256"\w* debido \w a|strong="H3068"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* habían santificado suficientes \w sacerdotes|strong="H3548"\w*, \w ni|strong="H3808"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w se|strong="H1931"\w* \w había|strong="H6942"\w* reunido \w en|strong="H3588"\w* Jerusalén.  
\v 4 Este acuerdo \w pareció|strong="H5869"\w* \w bien|strong="H5869"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* del \w rey|strong="H4428"\w* y \w de|strong="H1697"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* asamblea.  
\v 5 \w Así|strong="H3588"\w* \w que|strong="H3588"\w* emitieron un decreto \w para|strong="H5704"\w* \w hacer|strong="H6213"\w* \w pasar|strong="H5674"\w* un \w pregón|strong="H6963"\w* \w por|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w desde|strong="H5704"\w* Beerseba \w hasta|strong="H5704"\w* \w Dan|strong="H1835"\w*, convocándolos \w a|strong="H3068"\w* venir \w a|strong="H3068"\w* Jerusalén \w para|strong="H5704"\w* \w celebrar|strong="H6213"\w* \w la|strong="H3588"\w* \w Pascua|strong="H6453"\w* \w a|strong="H3068"\w* Yahvé, \w el|strong="H3588"\w* \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*; \w porque|strong="H3588"\w* \w hacía|strong="H6213"\w* \w mucho|strong="H7230"\w* tiempo \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w la|strong="H3588"\w* celebraban \w en|strong="H5704"\w* gran asamblea, \w conforme|strong="H5704"\w* \w a|strong="H3068"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w está|strong="H5975"\w* \w escrito|strong="H3789"\w*.   
\p
\v 6 \w Fueron|strong="H3212"\w*, pues, \w correos|strong="H7323"\w* con las cartas del \w rey|strong="H4428"\w* y \w de|strong="H1121"\w* sus \w jefes|strong="H8269"\w* \w por|strong="H3027"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* y \w Judá|strong="H3063"\w*, con \w el|strong="H3605"\w* siguiente mandato del \w rey|strong="H4428"\w*: «\w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w volveos|strong="H7725"\w* \w a|strong="H3068"\w* Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* Abraham, \w de|strong="H1121"\w* \w Isaac|strong="H3327"\w* y \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, para \w que|strong="H1121"\w* \w él|strong="H3605"\w* se \w vuelva|strong="H7725"\w* \w al|strong="H4428"\w* remanente \w de|strong="H1121"\w* vosotros \w que|strong="H1121"\w* ha escapado \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H1121"\w* Asiria.  
\v 7 \w No|strong="H1961"\w* \w seáis|strong="H1961"\w* \w como|strong="H1961"\w* vuestros padres y \w como|strong="H1961"\w* vuestros hermanos, \w que|strong="H1961"\w* \w prevaricaron|strong="H4603"\w* \w contra|strong="H1961"\w* Yahvé, el \w Dios|strong="H3068"\w* \w de|strong="H5414"\w* sus padres, \w por|strong="H5414"\w* lo cual él \w los|strong="H1961"\w* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* la desolación, \w como|strong="H1961"\w* vosotros mismos \w veis|strong="H7200"\w*.  
