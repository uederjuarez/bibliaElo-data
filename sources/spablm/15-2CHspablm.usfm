\v 23 \w A|strong="H3068"\w* \w la|strong="H5921"\w* vuelta \w del|strong="H5921"\w* \w año|strong="H8141"\w*, \w el|strong="H5921"\w* \w ejército|strong="H2426"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* sirios \w subió|strong="H5927"\w* \w contra|strong="H5921"\w* Joás. Llegaron \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Jerusalén, \w destruyeron|strong="H7843"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w príncipes|strong="H8269"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w y|strong="H5921"\w* \w enviaron|strong="H7971"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* botín \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Damasco|strong="H1834"\w*.  
