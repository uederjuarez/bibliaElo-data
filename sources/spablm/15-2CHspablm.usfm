\v 20 \w Entonces|strong="H3588"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w Dios|strong="H3068"\w* \w vino|strong="H4100"\w* \w sobre|strong="H5921"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Joiada|strong="H3077"\w*; \w él|strong="H5921"\w* \w se|strong="H5921"\w* \w puso|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w en|strong="H5921"\w* un lugar \w más|strong="H3588"\w* alto \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H3588"\w* \w les|strong="H5921"\w* dijo: “\w Así|strong="H3541"\w* dice \w Dios|strong="H3068"\w*: ‘¿\w Por|strong="H5921"\w* \w qué|strong="H3588"\w* \w quebrantáis|strong="H5674"\w* \w los|strong="H1121"\w* \w mandamientos|strong="H4687"\w* \w de|strong="H5921"\w* Yahvé \w y|strong="H3588"\w* \w no|strong="H3808"\w* prosperáis? \w Por|strong="H5921"\w* \w cuanto|strong="H3588"\w* habéis abandonado \w a|strong="H3068"\w* Yahvé, \w él|strong="H5921"\w* también \w os|strong="H5921"\w* \w ha|strong="H3541"\w* abandonado \w a|strong="H3068"\w* vosotros’”.   
