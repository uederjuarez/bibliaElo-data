\v 24 Tomó \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w oro|strong="H2091"\w*, \w la|strong="H3605"\w* \w plata|strong="H3701"\w* y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* utensilios \w que|strong="H1121"\w* se \w hallaban|strong="H4672"\w* \w en|strong="H5973"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Dios \w al|strong="H4428"\w* cuidado \w de|strong="H5973"\w* Obed Edom, \w así|strong="H5973"\w* \w como|strong="H5973"\w* \w los|strong="H1121"\w* tesoros \w del|strong="H5973"\w* palacio \w real|strong="H4428"\w* y algunos rehenes, y regresó \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*.   
\p
\v 25 Amasías, \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H2568"\w* \w Judá|strong="H3063"\w*, \w vivió|strong="H2421"\w* \w quince|strong="H2568"\w* \w años|strong="H8141"\w* después \w de|strong="H2568"\w* la \w muerte|strong="H4191"\w* \w de|strong="H2568"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* Joacaz, \w rey|strong="H4428"\w* \w de|strong="H2568"\w* \w Israel|strong="H3478"\w*.  
\v 26 \w Los|strong="H5921"\w* demás \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Amasías, \w los|strong="H5921"\w* \w primeros|strong="H7223"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* últimos, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w libro|strong="H5612"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?  
\v 27 \w Desde|strong="H5921"\w* \w el|strong="H5921"\w* momento \w en|strong="H5921"\w* \w que|strong="H5921"\w* Amasías \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* Yahvé, \w conspiraron|strong="H7194"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* Jerusalén. \w Él|strong="H5921"\w* \w huyó|strong="H5127"\w* \w a|strong="H3068"\w* Laquis, pero \w enviaron|strong="H7971"\w* tras \w él|strong="H5921"\w* \w a|strong="H3068"\w* Laquis \w y|strong="H5921"\w* \w allí|strong="H8033"\w* \w lo|strong="H5921"\w* \w mataron|strong="H4191"\w*.  
\v 28 \w Lo|strong="H5921"\w* \w trajeron|strong="H5375"\w* \w sobre|strong="H5921"\w* \w caballos|strong="H5483"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w sepultaron|strong="H6912"\w* \w con|strong="H5973"\w* sus padres \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\c 26
\p
\v 1 \w Todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H8478"\w* \w Judá|strong="H3063"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* Uzías, \w que|strong="H1931"\w* \w tenía|strong="H1931"\w* \w dieciséis|strong="H8337"\w* \w años|strong="H8141"\w*, y \w lo|strong="H1931"\w* proclamó \w rey|strong="H4427"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w su|strong="H1931"\w* padre Amasías.  
\v 2 \w Él|strong="H1931"\w* \w reedificó|strong="H1129"\w* Elot y \w la|strong="H1931"\w* \w restituyó|strong="H7725"\w* \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*, después \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* Amasías \w durmió|strong="H7901"\w* \w con|strong="H5973"\w* \w sus|strong="H1931"\w* padres.  
\v 3 Uzías tenía \w dieciséis|strong="H8337"\w* \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w cincuenta|strong="H2572"\w* y \w dos|strong="H8147"\w* \w años|strong="H8141"\w* \w en|strong="H4480"\w* Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H4480"\w* su madre \w era|strong="H8141"\w* Jecolía, \w de|strong="H4480"\w* Jerusalén.  
\v 4 \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w recto|strong="H3477"\w* ante \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Yahvé, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* su padre Amasías.  
\v 5 \w Se|strong="H1961"\w* dispuso \w a|strong="H3068"\w* buscar \w a|strong="H3068"\w* \w Dios|strong="H3068"\w* en \w los|strong="H1961"\w* \w días|strong="H3117"\w* de \w Zacarías|strong="H2148"\w*, quien \w tenía|strong="H1961"\w* entendimiento en las visiones de \w Dios|strong="H3068"\w*; y mientras \w buscó|strong="H1875"\w* \w a|strong="H3068"\w* Yahvé, \w Dios|strong="H3068"\w* lo hizo \w prosperar|strong="H6743"\w*.   
\p
\v 6 \w Salió|strong="H3318"\w* y \w peleó|strong="H3898"\w* contra los \w filisteos|strong="H6430"\w*; derribó la muralla \w de|strong="H3898"\w* Gat, la muralla \w de|strong="H3898"\w* Jabnia y la muralla \w de|strong="H3898"\w* Asdod, y \w edificó|strong="H1129"\w* \w ciudades|strong="H5892"\w* \w en|strong="H3318"\w* la región \w de|strong="H3898"\w* Asdod y entre los \w filisteos|strong="H6430"\w*.  
\v 7 Dios \w lo|strong="H5921"\w* \w ayudó|strong="H5826"\w* \w contra|strong="H5921"\w* \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w*, \w contra|strong="H5921"\w* \w los|strong="H3427"\w* árabes \w que|strong="H5921"\w* \w habitaban|strong="H3427"\w* \w en|strong="H5921"\w* Gur Baal, \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w los|strong="H3427"\w* meunitas.  
\v 8 \w Los|strong="H3588"\w* amonitas pagaron \w tributo|strong="H4503"\w* \w a|strong="H3068"\w* Uzías, \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w fama|strong="H8034"\w* se extendió \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* frontera \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w porque|strong="H3588"\w* se \w había|strong="H3588"\w* hecho sumamente \w poderoso|strong="H2388"\w*.  
\v 9 \w Además|strong="H5921"\w*, Uzías \w edificó|strong="H1129"\w* \w torres|strong="H4026"\w* \w en|strong="H5921"\w* Jerusalén, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w del|strong="H5921"\w* Ángulo, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w del|strong="H5921"\w* \w Valle|strong="H1516"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* esquina \w de|strong="H5921"\w* \w la|strong="H5921"\w* muralla, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w fortificó|strong="H2388"\w*.  
\v 10 \w Edificó|strong="H1129"\w* \w torres|strong="H4026"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w* \w y|strong="H3588"\w* excavó \w muchas|strong="H7227"\w* cisternas, \w porque|strong="H3588"\w* \w tenía|strong="H1961"\w* \w grandes|strong="H7227"\w* rebaños, tanto \w en|strong="H3588"\w* \w la|strong="H3588"\w* Sefelá \w como|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* llanura; \w y|strong="H3588"\w* \w tenía|strong="H1961"\w* labradores \w y|strong="H3588"\w* viñadores \w en|strong="H3588"\w* \w los|strong="H1961"\w* \w montes|strong="H2022"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w los|strong="H1961"\w* campos fértiles, \w pues|strong="H3588"\w* \w era|strong="H1961"\w* amante \w de|strong="H3588"\w* \w la|strong="H3588"\w* agricultura.  
\v 11 Uzías \w tenía|strong="H1961"\w* un \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* \w guerreros|strong="H6213"\w* listos \w para|strong="H5921"\w* \w salir|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w* \w en|strong="H5921"\w* divisiones, \w según|strong="H5921"\w* \w el|strong="H5921"\w* censo realizado \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w escriba|strong="H5608"\w* \w Jeiel|strong="H3273"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* oficial \w Maasías|strong="H4641"\w*, bajo \w el|strong="H5921"\w* mando \w de|strong="H5921"\w* \w Hananías|strong="H2608"\w*, uno \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.  
\v 12 \w El|strong="H3605"\w* \w número|strong="H4557"\w* total de \w los|strong="H3605"\w* \w jefes|strong="H7218"\w* de las casas paternas, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, era de dos \w mil|strong="H3967"\w* \w seiscientos|strong="H8337"\w*.  
\v 13 Bajo su mando \w había|strong="H6213"\w* un \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* \w trescientos|strong="H7969"\w* \w siete|strong="H7651"\w* \w mil|strong="H3967"\w* \w quinientos|strong="H2568"\w* hombres, adiestrados \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w* \w con|strong="H5921"\w* gran \w poder|strong="H3581"\w*, \w para|strong="H5921"\w* ayudar \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* enemigo.  
\v 14 Uzías \w preparó|strong="H3559"\w* para \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ejército|strong="H6635"\w* \w escudos|strong="H4043"\w*, \w lanzas|strong="H7420"\w*, yelmos, cotas de malla, \w arcos|strong="H7198"\w* y piedras para \w las|strong="H1992"\w* hondas.  
\v 15 \w En|strong="H5921"\w* Jerusalén fabricó máquinas ingeniosas, inventadas \w por|strong="H5921"\w* expertos, \w para|strong="H5704"\w* colocarlas \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w torres|strong="H4026"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w esquinas|strong="H6438"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* muros, \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* lanzar flechas \w y|strong="H3588"\w* \w grandes|strong="H1419"\w* piedras. \w Su|strong="H3588"\w* \w fama|strong="H8034"\w* \w se|strong="H1961"\w* difundió \w por|strong="H5921"\w* todas partes, \w porque|strong="H3588"\w* \w fue|strong="H1961"\w* ayudado \w maravillosamente|strong="H6381"\w* \w hasta|strong="H5704"\w* hacerse muy \w poderoso|strong="H2388"\w*.   
\p
\v 16 Pero \w cuando|strong="H5704"\w* \w se|strong="H5921"\w* hizo fuerte, su \w corazón|strong="H3820"\w* \w se|strong="H5921"\w* enalteció \w para|strong="H5704"\w* su propia ruina, \w y|strong="H5921"\w* cometió una transgresión \w contra|strong="H5921"\w* Yahvé, su \w Dios|strong="H3068"\w*, pues entró \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w templo|strong="H1964"\w* \w de|strong="H5921"\w* Yahvé \w para|strong="H5704"\w* quemar incienso \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w del|strong="H5921"\w* incienso.  
\v 17 \w El|strong="H5973"\w* \w sacerdote|strong="H3548"\w* \w Azarías|strong="H5838"\w* entró \w tras|strong="H5973"\w* \w él|strong="H5973"\w*, acompañado por \w ochenta|strong="H8084"\w* \w sacerdotes|strong="H3548"\w* \w de|strong="H5973"\w* Yahvé, \w hombres|strong="H1121"\w* valerosos.  
\v 18 \w Se|strong="H5921"\w* enfrentaron \w al|strong="H5921"\w* \w rey|strong="H4428"\w* Uzías \w y|strong="H3588"\w* \w le|strong="H5921"\w* dijeron: «\w No|strong="H3808"\w* \w te|strong="H5921"\w* corresponde \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, Uzías, quemar incienso \w a|strong="H3068"\w* Yahvé, \w sino|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Aarón, \w que|strong="H3588"\w* han sido consagrados \w para|strong="H5921"\w* quemarlo. \w Sal|strong="H3318"\w* \w del|strong="H4480"\w* \w santuario|strong="H4720"\w*, \w porque|strong="H3588"\w* has prevaricado, \w y|strong="H3588"\w* esto \w no|strong="H3808"\w* \w te|strong="H5921"\w* traerá \w gloria|strong="H3519"\w* \w de|strong="H4480"\w* parte \w de|strong="H4480"\w* Yahvé \w Dios|strong="H3068"\w*».   
\p
\v 19 Uzías, \w que|strong="H5921"\w* tenía un incensario \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w para|strong="H5921"\w* quemar \w el|strong="H5921"\w* incienso, \w se|strong="H5921"\w* enfureció; \w y|strong="H5921"\w* mientras \w se|strong="H5921"\w* enfurecía \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w*, \w la|strong="H5921"\w* \w lepra|strong="H6883"\w* brotó \w en|strong="H5921"\w* su \w frente|strong="H4696"\w*, allí mismo, \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w del|strong="H5921"\w* incienso.  
\v 20 \w El|strong="H1931"\w* \w sumo|strong="H7218"\w* \w sacerdote|strong="H3548"\w* \w Azarías|strong="H5838"\w* \w y|strong="H1571"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w se|strong="H1931"\w* \w volvieron|strong="H6437"\w* \w hacia|strong="H8033"\w* \w él|strong="H1931"\w*, \w y|strong="H1571"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w tenía|strong="H1931"\w* lepra \w en|strong="H3588"\w* \w la|strong="H1931"\w* \w frente|strong="H4696"\w*; \w así|strong="H1571"\w* \w que|strong="H3588"\w* \w lo|strong="H1931"\w* echaron apresuradamente \w de|strong="H3588"\w* \w allí|strong="H8033"\w*, \w e|strong="H3068"\w* incluso \w él|strong="H1931"\w* \w mismo|strong="H1931"\w* \w se|strong="H1931"\w* dio prisa \w en|strong="H3588"\w* \w salir|strong="H3318"\w*, \w porque|strong="H3588"\w* Yahvé \w lo|strong="H1931"\w* \w había|strong="H3588"\w* herido.  
\v 21 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* Uzías \w fue|strong="H1961"\w* \w leproso|strong="H6879"\w* \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w muerte|strong="H4194"\w*, \w y|strong="H3588"\w* \w habitó|strong="H3427"\w* \w en|strong="H5921"\w* una \w casa|strong="H1004"\w* aislada, \w por|strong="H5921"\w* ser \w leproso|strong="H6879"\w*, ya \w que|strong="H3588"\w* \w fue|strong="H1961"\w* excluido \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé. \w Su|strong="H3588"\w* \w hijo|strong="H1121"\w* Jotam \w quedó|strong="H1961"\w* \w a|strong="H3068"\w* cargo \w del|strong="H5921"\w* palacio \w real|strong="H4428"\w* \w y|strong="H3588"\w* gobernaba \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.   
\p
\v 22 \w Los|strong="H1121"\w* demás \w hechos|strong="H1697"\w* \w de|strong="H1121"\w* Uzías, \w los|strong="H1121"\w* \w primeros|strong="H7223"\w* y \w los|strong="H1121"\w* últimos, \w los|strong="H1121"\w* \w escribió|strong="H3789"\w* \w el|strong="H1121"\w* \w profeta|strong="H5030"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amoz.  
\v 23 Uzías \w durmió|strong="H7901"\w* \w con|strong="H5973"\w* \w sus|strong="H1931"\w* padres, \w y|strong="H3588"\w* \w lo|strong="H1931"\w* \w sepultaron|strong="H6912"\w* \w con|strong="H5973"\w* \w ellos|strong="H1931"\w* \w en|strong="H5973"\w* \w el|strong="H1931"\w* \w campo|strong="H7704"\w* \w de|strong="H3588"\w* \w sepultura|strong="H6900"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w*, \w pues|strong="H3588"\w* dijeron: «\w Es|strong="H1931"\w* \w leproso|strong="H6879"\w*». \w Y|strong="H3068"\w* \w su|strong="H1931"\w* \w hijo|strong="H1121"\w* Jotam \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* \w su|strong="H1931"\w* \w lugar|strong="H8478"\w*.   
\c 27
\p
\v 1 Jotam tenía \w veinticinco|strong="H6242"\w* \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w dieciséis|strong="H8337"\w* \w años|strong="H8141"\w* en Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H2568"\w* su madre \w era|strong="H8141"\w* Jerusá, \w hija|strong="H1323"\w* \w de|strong="H2568"\w* \w Sadoc|strong="H6659"\w*.  
\v 2 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5750"\w* Yahvé, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* su padre Uzías; con \w la|strong="H3605"\w* salvedad \w de|strong="H5750"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* invadió \w el|strong="H3605"\w* \w templo|strong="H1964"\w* \w de|strong="H5750"\w* Yahvé. Pero \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* continuaba corrompiéndose.  
\v 3 \w Él|strong="H1931"\w* \w edificó|strong="H1129"\w* \w la|strong="H1931"\w* \w puerta|strong="H8179"\w* superior de \w la|strong="H1931"\w* \w casa|strong="H1004"\w* de Yahvé, y construyó \w muchas|strong="H7230"\w* obras en \w la|strong="H1931"\w* muralla de Ofel.  
\v 4 Además, \w edificó|strong="H1129"\w* \w ciudades|strong="H5892"\w* en la región montañosa de \w Judá|strong="H3063"\w*, y construyó \w fortalezas|strong="H1003"\w* y \w torres|strong="H4026"\w* en los bosques.  
\v 5 \w Peleó|strong="H3898"\w* \w contra|strong="H5921"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* amonitas \w y|strong="H5921"\w* \w los|strong="H1121"\w* derrotó. \w Aquel|strong="H1931"\w* \w año|strong="H8141"\w*, \w los|strong="H1121"\w* amonitas \w le|strong="H1931"\w* \w pagaron|strong="H7725"\w* \w cien|strong="H3967"\w* \w talentos|strong="H3603"\w* \w de|strong="H5921"\w* \w plata|strong="H3701"\w*, \w diez|strong="H6235"\w* \w mil|strong="H6235"\w* \w coros|strong="H3734"\w* \w de|strong="H5921"\w* \w trigo|strong="H2406"\w* \w y|strong="H5921"\w* \w diez|strong="H6235"\w* \w mil|strong="H6235"\w* \w coros|strong="H3734"\w* \w de|strong="H5921"\w* \w cebada|strong="H8184"\w*.\f + \fr 27:5 \ft 10.000 coros de cebada equivalen aproximadamente a 1.310 toneladas métricas.\f* \w Lo|strong="H1931"\w* \w mismo|strong="H1931"\w* \w le|strong="H1931"\w* \w pagaron|strong="H7725"\w* \w los|strong="H1121"\w* amonitas \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w segundo|strong="H8145"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* tercer \w año|strong="H8141"\w*.  
\v 6 \w Así|strong="H3588"\w* Jotam se hizo \w poderoso|strong="H2388"\w*, \w porque|strong="H3588"\w* \w preparó|strong="H3559"\w* sus \w caminos|strong="H1870"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Yahvé, \w su|strong="H3588"\w* \w Dios|strong="H3068"\w*.  
\v 7 \w Los|strong="H5921"\w* demás \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Jotam, \w todas|strong="H3605"\w* sus \w guerras|strong="H4421"\w* \w y|strong="H5921"\w* su conducta, están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w libro|strong="H5612"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 8 \w Tenía|strong="H1961"\w* \w veinticinco|strong="H6242"\w* \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w dieciséis|strong="H8337"\w* \w años|strong="H8141"\w* en Jerusalén.  
\v 9 Jotam \w durmió|strong="H7901"\w* \w con|strong="H5973"\w* sus padres, y lo \w sepultaron|strong="H6912"\w* \w en|strong="H5973"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H8478"\w* \w David|strong="H1732"\w*; y su \w hijo|strong="H1121"\w* Acaz \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w*.   
\c 28
\p
\v 1 Acaz tenía \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w dieciséis|strong="H8337"\w* \w años|strong="H8141"\w* en Jerusalén. Pero \w no|strong="H3808"\w* \w hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H1121"\w* Yahvé, como \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* su padre \w David|strong="H1732"\w*,  
\v 2 sino \w que|strong="H1571"\w* \w anduvo|strong="H3212"\w* \w en|strong="H3212"\w* los \w caminos|strong="H1870"\w* de los \w reyes|strong="H4428"\w* de \w Israel|strong="H3478"\w*, \w e|strong="H3068"\w* incluso \w hizo|strong="H6213"\w* \w imágenes|strong="H4541"\w* fundidas para los baales.  
\v 3 Quemó incienso en \w el|strong="H1931"\w* \w valle|strong="H1516"\w* del \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Hinom, \w e|strong="H3068"\w* hizo pasar \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* \w por|strong="H6440"\w* \w el|strong="H1931"\w* fuego, \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* las \w abominaciones|strong="H8441"\w* \w de|strong="H6440"\w* las \w naciones|strong="H1471"\w* \w que|strong="H1931"\w* Yahvé había expulsado \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.  
\v 4 Asimismo, \w sacrificó|strong="H2076"\w* \w y|strong="H5921"\w* quemó incienso \w en|strong="H5921"\w* \w los|strong="H3605"\w* lugares \w altos|strong="H1116"\w*, \w en|strong="H5921"\w* \w las|strong="H5921"\w* colinas \w y|strong="H5921"\w* \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w frondoso|strong="H7488"\w*.   
\p
\v 5 \w Por|strong="H4480"\w* lo cual Yahvé, su \w Dios|strong="H3068"\w*, lo \w entregó|strong="H5414"\w* \w en|strong="H4480"\w* \w manos|strong="H3027"\w* \w del|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* Siria. Los sirios lo derrotaron, tomaron \w de|strong="H4480"\w* \w él|strong="H1571"\w* un \w gran|strong="H1419"\w* número \w de|strong="H4480"\w* cautivos \w y|strong="H1571"\w* los llevaron \w a|strong="H3068"\w* \w Damasco|strong="H1834"\w*. \w También|strong="H1571"\w* \w fue|strong="H1571"\w* \w entregado|strong="H5414"\w* \w en|strong="H4480"\w* \w manos|strong="H3027"\w* \w del|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w el|strong="H1571"\w* cual le infligió una \w gran|strong="H1419"\w* derrota.  
\v 6 Pues \w Peka|strong="H6492"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Remalías, \w mató|strong="H2026"\w* en \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* \w ciento|strong="H3967"\w* \w veinte|strong="H6242"\w* \w mil|strong="H3967"\w* \w hombres|strong="H1121"\w* en un solo \w día|strong="H3117"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w valientes|strong="H2428"\w*, porque habían abandonado \w a|strong="H3068"\w* Yahvé, \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* sus padres.  
\v 7 Zicri, un \w hombre|strong="H1121"\w* \w poderoso|strong="H1368"\w* \w de|strong="H1121"\w* Efraín, \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w Maasías|strong="H4641"\w*, \w hijo|strong="H1121"\w* del \w rey|strong="H4428"\w*, \w a|strong="H3068"\w* \w Azricam|strong="H5840"\w*, \w mayordomo|strong="H1004"\w* del palacio, y \w a|strong="H3068"\w* Elcaná, \w que|strong="H1121"\w* \w era|strong="H1121"\w* \w el|strong="H1121"\w* \w segundo|strong="H4932"\w* después del \w rey|strong="H4428"\w*.  
\v 8 \w Los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* tomaron cautivos \w a|strong="H3068"\w* \w doscientos|strong="H3967"\w* \w mil|strong="H3967"\w* \w de|strong="H1121"\w* \w sus|strong="H1992"\w* hermanos: \w mujeres|strong="H1323"\w*, \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*; \w les|strong="H1992"\w* tomaron \w también|strong="H1571"\w* un inmenso botín \w y|strong="H1571"\w* \w lo|strong="H1992"\w* llevaron \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*.  
\v 9 Pero \w había|strong="H1961"\w* \w allí|strong="H8033"\w* un \w profeta|strong="H5030"\w* \w de|strong="H5921"\w* Yahvé \w llamado|strong="H8034"\w* Oded, \w el|strong="H5921"\w* cual \w salió|strong="H3318"\w* \w al|strong="H5921"\w* encuentro \w del|strong="H5921"\w* \w ejército|strong="H6635"\w* \w que|strong="H5921"\w* regresaba \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* dijo: «He \w aquí|strong="H2009"\w*, \w porque|strong="H5921"\w* Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* vuestros padres, \w se|strong="H1961"\w* ha \w enojado|strong="H2534"\w* \w contra|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w los|strong="H5921"\w* ha \w entregado|strong="H5414"\w* \w en|strong="H5921"\w* vuestras \w manos|strong="H3027"\w*; pero vosotros \w los|strong="H5921"\w* habéis matado \w con|strong="H5921"\w* una furia \w que|strong="H5921"\w* ha \w llegado|strong="H5060"\w* \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*.  
\v 10 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* pretendéis someter \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* y \w de|strong="H5973"\w* Jerusalén \w como|strong="H5973"\w* esclavos y esclavas vuestros. ¿Acaso \w no|strong="H3808"\w* hay \w entre|strong="H5973"\w* \w vosotros|strong="H5973"\w* graves transgresiones \w contra|strong="H5973"\w* Yahvé, vuestro \w Dios|strong="H3068"\w*?  
\v 11 \w Escuchadme|strong="H8085"\w* \w ahora|strong="H6258"\w*, \w y|strong="H3588"\w* devolved \w a|strong="H3068"\w* \w los|strong="H5921"\w* cautivos \w que|strong="H3588"\w* habéis tomado \w de|strong="H5921"\w* vuestros hermanos, \w porque|strong="H3588"\w* \w la|strong="H5921"\w* ardiente \w ira|strong="H2740"\w* \w de|strong="H5921"\w* Yahvé \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w vosotros|strong="H8085"\w*».  
