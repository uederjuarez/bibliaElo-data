\toc1 SEGUNDO LIBRO DE LAS CRÓNICAS 
\toc2 2 CRÓNICAS 
\mt2 Segundo libro de las  
\mt1 Crónicas  
\c 1
\p
\v 1 \w Salomón|strong="H8010"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*, \w se|strong="H5921"\w* afianzó firmemente \w en|strong="H5921"\w* su \w reino|strong="H4438"\w*, \w y|strong="H5921"\w* Yahvé\f + \fr 1:1 \ft «Yahvé» es el nombre propio de Dios, a veces traducido como «SEÑOR» (en mayúsculas) en otras traducciones.\f* su \w Dios|strong="H3068"\w*\f + \fr 1:1 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f* estaba \w con|strong="H5973"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w engrandeció|strong="H1431"\w* \w sobremanera|strong="H4605"\w*.   
\p
\v 2 \w Salomón|strong="H8010"\w* habló \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w capitanes|strong="H8269"\w* \w de|strong="H8269"\w* millares y \w de|strong="H8269"\w* centenas, \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w jueces|strong="H8199"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w príncipes|strong="H8269"\w* \w de|strong="H8269"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* familia.  
\v 3 \w Entonces|strong="H3588"\w* \w Salomón|strong="H8010"\w*, \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* asamblea \w con|strong="H5973"\w* \w él|strong="H5973"\w*, \w se|strong="H1961"\w* dirigió al lugar alto \w que|strong="H3588"\w* \w estaba|strong="H1961"\w* \w en|strong="H5973"\w* \w Gabaón|strong="H1391"\w*, \w porque|strong="H3588"\w* \w allí|strong="H8033"\w* \w estaba|strong="H1961"\w* \w la|strong="H3588"\w* Tienda \w del|strong="H5973"\w* Encuentro \w de|strong="H3588"\w* \w Dios|strong="H3068"\w*, \w que|strong="H3588"\w* \w Moisés|strong="H4872"\w*, \w siervo|strong="H5650"\w* \w de|strong="H3588"\w* Yahvé, \w había|strong="H1961"\w* \w hecho|strong="H6213"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w desierto|strong="H4057"\w*.  
\v 4 \w Pero|strong="H3588"\w* \w David|strong="H1732"\w* \w había|strong="H3588"\w* hecho \w subir|strong="H5927"\w* \w el|strong="H3588"\w* Arca \w de|strong="H3588"\w* Dios desde Quiriat Jearim al lugar \w que|strong="H3588"\w* \w David|strong="H1732"\w* \w había|strong="H3588"\w* preparado \w para|strong="H3588"\w* ella, \w pues|strong="H3588"\w* le \w había|strong="H3588"\w* levantado una tienda \w en|strong="H3588"\w* Jerusalén.  
\v 5 Además, \w el|strong="H1121"\w* \w altar|strong="H4196"\w* \w de|strong="H6440"\w* bronce \w que|strong="H1121"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* Bezalel, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Uri, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Hur|strong="H2354"\w*, \w estaba|strong="H7760"\w* allí \w delante|strong="H6440"\w* \w del|strong="H4196"\w* \w tabernáculo|strong="H4908"\w* \w de|strong="H6440"\w* Yahvé, y \w Salomón|strong="H8010"\w* y la asamblea acudieron \w a|strong="H3068"\w* consultarlo allí.  
\v 6 \w Salomón|strong="H8010"\w* \w subió|strong="H5927"\w* \w allí|strong="H8033"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* bronce \w que|strong="H5921"\w* estaba \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w en|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w y|strong="H5921"\w* \w ofreció|strong="H5927"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* mil \w holocaustos|strong="H5930"\w*.   
\p
\v 7 \w Aquella|strong="H1931"\w* \w noche|strong="H3915"\w*, Dios \w se|strong="H1931"\w* \w le|strong="H1931"\w* \w apareció|strong="H7200"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* y \w le|strong="H1931"\w* dijo: «\w Pide|strong="H7592"\w* \w lo|strong="H1931"\w* \w que|strong="H4100"\w* quieras \w que|strong="H4100"\w* yo te \w dé|strong="H5414"\w*».   
\p
\v 8 \w Salomón|strong="H8010"\w* dijo \w a|strong="H3068"\w* Dios: «\w Tú|strong="H6213"\w* \w has|strong="H4427"\w* mostrado una \w gran|strong="H1419"\w* \w misericordia|strong="H2617"\w* \w con|strong="H5973"\w* mi padre \w David|strong="H1732"\w*, y \w me|strong="H5973"\w* \w has|strong="H4427"\w* \w hecho|strong="H6213"\w* \w rey|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w*.  
\v 9 \w Ahora|strong="H6258"\w*, Yahvé \w Dios|strong="H3068"\w*, \w que|strong="H3588"\w* \w se|strong="H5921"\w* cumpla tu promesa \w a|strong="H3068"\w* \w mi|strong="H5921"\w* padre \w David|strong="H1732"\w*, \w pues|strong="H3588"\w* \w me|strong="H5921"\w* \w has|strong="H4427"\w* hecho \w rey|strong="H4427"\w* \w sobre|strong="H5921"\w* un \w pueblo|strong="H5971"\w* tan \w numeroso|strong="H7227"\w* \w como|strong="H3588"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tierra|strong="H6083"\w*.  
\v 10 \w Dame|strong="H5414"\w* \w ahora|strong="H6258"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H3588"\w* \w conocimiento|strong="H4093"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* pueda \w salir|strong="H3318"\w* \w y|strong="H3588"\w* entrar \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*; \w porque|strong="H3588"\w*, ¿\w quién|strong="H4310"\w* podrá \w gobernar|strong="H8199"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w gran|strong="H1419"\w* \w pueblo|strong="H5971"\w* \w tuyo|strong="H5971"\w*?»   
\p
\v 11 Dios dijo \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*: «\w Por|strong="H5921"\w* \w cuanto|strong="H3282"\w* \w esto|strong="H2063"\w* \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w tu|strong="H8199"\w* \w corazón|strong="H3824"\w*, \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w has|strong="H4427"\w* pedido \w riquezas|strong="H6239"\w*, \w ni|strong="H3808"\w* bienes, \w ni|strong="H3808"\w* honores, \w ni|strong="H3808"\w* \w la|strong="H5921"\w* \w vida|strong="H5315"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3808"\w* \w te|strong="H5921"\w* odian, \w ni|strong="H3808"\w* \w tampoco|strong="H1571"\w* \w has|strong="H4427"\w* pedido larga \w vida|strong="H5315"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w has|strong="H4427"\w* pedido \w sabiduría|strong="H2451"\w* \w y|strong="H1571"\w* \w conocimiento|strong="H4093"\w* \w para|strong="H5921"\w* \w ti|strong="H5921"\w*, \w para|strong="H5921"\w* \w gobernar|strong="H8199"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w cual|strong="H5315"\w* \w te|strong="H5921"\w* he \w hecho|strong="H1961"\w* \w rey|strong="H4427"\w*,  
\v 12 \w por|strong="H6440"\w* \w tanto|strong="H3651"\w*, \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H3519"\w* el \w conocimiento|strong="H4093"\w* te \w son|strong="H1961"\w* concedidos. Te \w daré|strong="H5414"\w* \w riquezas|strong="H6239"\w*, bienes \w y|strong="H3519"\w* honor, \w como|strong="H1961"\w* \w no|strong="H3808"\w* \w los|strong="H1961"\w* \w ha|strong="H3808"\w* tenido \w ninguno|strong="H3808"\w* \w de|strong="H6440"\w* \w los|strong="H1961"\w* \w reyes|strong="H4428"\w* \w que|strong="H3808"\w* han \w sido|strong="H1961"\w* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* ti, \w ni|strong="H3808"\w* \w los|strong="H1961"\w* \w tendrá|strong="H1961"\w* \w ninguno|strong="H3808"\w* \w después|strong="H1961"\w* \w de|strong="H6440"\w* ti».   
\p
\v 13 \w Salomón|strong="H8010"\w* regresó \w a|strong="H3068"\w* Jerusalén \w desde|strong="H5921"\w* \w el|strong="H5921"\w* lugar alto \w que|strong="H5921"\w* estaba \w en|strong="H5921"\w* \w Gabaón|strong="H1391"\w*, \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w de|strong="H5921"\w* \w las|strong="H5921"\w* Reuniones, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 14 \w Salomón|strong="H8010"\w* reunió \w carros|strong="H7393"\w* y \w jinetes|strong="H6571"\w*. \w Tenía|strong="H1961"\w* \w mil|strong="H3967"\w* cuatrocientos \w carros|strong="H7393"\w* y \w doce|strong="H8147"\w* \w mil|strong="H3967"\w* \w jinetes|strong="H6571"\w* \w que|strong="H1961"\w* dispuso \w en|strong="H5973"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w carros|strong="H7393"\w*, y \w junto|strong="H5973"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w en|strong="H5973"\w* Jerusalén.  
\v 15 El \w rey|strong="H4428"\w* \w hizo|strong="H5414"\w* que la \w plata|strong="H3701"\w* y el \w oro|strong="H2091"\w* fueran tan comunes en Jerusalén como las piedras, \w e|strong="H3068"\w* \w hizo|strong="H5414"\w* que los cedros abundaran tanto como los sicómoros que hay en la llanura.  
\v 16 Los \w caballos|strong="H5483"\w* que tenía \w Salomón|strong="H8010"\w* eran traídos de \w Egipto|strong="H4714"\w* y de Coa. Los \w mercaderes|strong="H5503"\w* del \w rey|strong="H4428"\w* los compraban en Coa.  
\v 17 Importaban de \w Egipto|strong="H4714"\w* un \w carro|strong="H4818"\w* \w por|strong="H3027"\w* \w seiscientas|strong="H8337"\w* piezas de \w plata|strong="H3701"\w* y un \w caballo|strong="H5483"\w* \w por|strong="H3027"\w* \w ciento|strong="H3967"\w* \w cincuenta|strong="H2572"\w*.\f + \fr 1:17 \ft Las piezas de plata eran probablemente siclos, por lo que 600 piezas serían unas 13,2 libras o 6 kilogramos de plata, y 150 serían unas 3,3 libras o 1,5 kilogramos de plata.\f* \w Así|strong="H3651"\w* \w también|strong="H3651"\w* \w los|strong="H3605"\w* exportaban, \w por|strong="H3027"\w* \w medio|strong="H3027"\w* de \w ellos|strong="H3027"\w*, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* hititas y \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* sirios. \f + \fr 1:17 \ft «Beracah» significa «bendición».\f*   
\c 2
\p
\v 1 \w Salomón|strong="H8010"\w* decidió edificar una casa \w para|strong="H5921"\w* \w el|strong="H5921"\w* nombre \w de|strong="H5921"\w* Yahvé \w y|strong="H5921"\w* una casa \w para|strong="H5921"\w* su reino.  
\v 2 \w Salomón|strong="H8010"\w* reclutó \w a|strong="H3068"\w* setenta mil hombres \w para|strong="H5973"\w* llevar cargas, ochenta mil hombres \w para|strong="H5973"\w* cortar piedra \w en|strong="H5973"\w* \w los|strong="H3427"\w* montes, y tres mil seiscientos \w para|strong="H5973"\w* supervisarlos.   
\p
\v 3 Salomón envió \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Hiram, rey \w de|strong="H5921"\w* Tiro: “\w De|strong="H5921"\w* \w la|strong="H5921"\w* misma manera \w que|strong="H5921"\w* trataste \w con|strong="H5921"\w* David \w mi|strong="H5921"\w* padre \w y|strong="H5921"\w* \w le|strong="H5921"\w* enviaste cedros \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* construyera una \w casa|strong="H1004"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* cual habitar, \w así|strong="H2063"\w* trata conmigo.  
\v 4 He aquí \w que|strong="H3588"\w* voy \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* una \w casa|strong="H1004"\w* al nombre \w de|strong="H3588"\w* Yahvé, mi Dios, \w para|strong="H3588"\w* consagrársela, \w para|strong="H3588"\w* quemar ante \w él|strong="H3588"\w* incienso \w de|strong="H3588"\w* especias aromáticas, \w para|strong="H3588"\w* presentar \w los|strong="H3605"\w* panes \w de|strong="H3588"\w* \w la|strong="H3605"\w* proposición \w continuamente|strong="H3605"\w* \w y|strong="H3588"\w* \w para|strong="H3588"\w* \w los|strong="H3605"\w* holocaustos \w de|strong="H3588"\w* \w la|strong="H3605"\w* mañana \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* tarde, \w en|strong="H3588"\w* \w los|strong="H3605"\w* sábados, \w en|strong="H3588"\w* las lunas nuevas \w y|strong="H3588"\w* \w en|strong="H3588"\w* las fiestas señaladas \w de|strong="H3588"\w* Yahvé, nuestro Dios. Esta \w es|strong="H3588"\w* una ordenanza perpetua \w para|strong="H3588"\w* Israel.   
\p
\v 5 “\w La|strong="H3588"\w* \w casa|strong="H1004"\w* \w que|strong="H3588"\w* voy \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* \w será|strong="H3808"\w* grande, \w porque|strong="H3588"\w* nuestro Dios \w es|strong="H3588"\w* \w más|strong="H3588"\w* grande \w que|strong="H3588"\w* todos \w los|strong="H3588"\w* dioses.  
\v 6 Pero, ¿\w quién|strong="H6213"\w* es capaz \w de|strong="H5973"\w* edificarle una casa, \w ya|strong="H6258"\w* \w que|strong="H6258"\w* \w los|strong="H5973"\w* cielos y \w el|strong="H5973"\w* cielo \w de|strong="H5973"\w* \w los|strong="H5973"\w* cielos \w no|strong="H6213"\w* pueden contenerlo? ¿\w Quién|strong="H6213"\w* soy \w yo|strong="H6213"\w*, \w pues|strong="H6258"\w*, \w para|strong="H5973"\w* edificarle una casa, sino solo \w para|strong="H5973"\w* quemar incienso ante \w él|strong="H5973"\w*?   
\p
\v 7 “\w Ahora|strong="H2009"\w*, \w pues|strong="H3588"\w*, \w envíame|strong="H7971"\w* un hombre hábil \w para|strong="H3588"\w* trabajar \w el|strong="H5973"\w* oro, \w la|strong="H3588"\w* plata, \w el|strong="H5973"\w* bronce, \w el|strong="H5973"\w* hierro, \w la|strong="H3588"\w* púrpura, \w el|strong="H5973"\w* carmesí \w y|strong="H3588"\w* \w el|strong="H5973"\w* azul, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w sepa|strong="H3045"\w* grabar, \w para|strong="H3588"\w* \w que|strong="H3588"\w* trabaje \w con|strong="H5973"\w* \w los|strong="H5973"\w* artesanos \w que|strong="H3588"\w* \w están|strong="H2009"\w* \w conmigo|strong="H5973"\w* \w en|strong="H5973"\w* Judá \w y|strong="H3588"\w* \w en|strong="H5973"\w* Jerusalén, \w los|strong="H5973"\w* cuales dispuso \w mi|strong="H2009"\w* padre.   
\p
\v 8 «Envíame también \w madera|strong="H6086"\w* \w de|strong="H3588"\w* cedro, \w de|strong="H3588"\w* ciprés \w y|strong="H3588"\w* \w de|strong="H3588"\w* sándalo del Líbano. \w Ciertamente|strong="H3588"\w* mis siervos irán \w con|strong="H3588"\w* \w los|strong="H3588"\w* \w tuyos|strong="H1004"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* sé \w que|strong="H3588"\w* tus siervos \w son|strong="H3588"\w* expertos \w en|strong="H3588"\w* talar \w los|strong="H3588"\w* \w árboles|strong="H6086"\w* del Líbano,  
\v 9 \w para|strong="H5414"\w* prepararme \w madera|strong="H6086"\w* en abundancia, \w porque|strong="H2009"\w* la casa que voy \w a|strong="H3068"\w* edificar \w será|strong="H5414"\w* grande y maravillosa.  
\v 10 He aquí \w que|strong="H5921"\w* yo \w daré|strong="H5414"\w* \w a|strong="H3068"\w* tus siervos, \w los|strong="H5921"\w* leñadores \w que|strong="H5921"\w* cortan \w la|strong="H5921"\w* madera, veinte mil coros \w de|strong="H5921"\w* trigo batido, veinte mil coros \w de|strong="H5921"\w* cebada, veinte mil batos \w de|strong="H5921"\w* vino \w y|strong="H5921"\w* veinte mil batos \w de|strong="H5921"\w* aceite».   
\p
\v 11 Entonces Huram, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Tiro, respondió \w por|strong="H5414"\w* escrito y \w se|strong="H3045"\w* \w lo|strong="H6213"\w* envió \w a|strong="H3068"\w* \w Salomón|strong="H4428"\w*: «\w Porque|strong="H1732"\w* Yahvé ama \w a|strong="H3068"\w* su pueblo, te ha constituido \w rey|strong="H4428"\w* sobre \w él|strong="H1121"\w*».  
\v 12 Huram continuó: “Bendito sea Yahvé, el Dios de Israel, \w que|strong="H6258"\w* hizo el cielo y la tierra, \w que|strong="H6258"\w* ha dado al rey David un hijo \w sabio|strong="H2450"\w*, dotado de prudencia y entendimiento, \w para|strong="H6258"\w* \w que|strong="H6258"\w* edifique una casa \w para|strong="H6258"\w* Yahvé y una casa \w para|strong="H6258"\w* su reino.   
\p
\v 13 “\w Te|strong="H4480"\w* he enviado, \w pues|strong="H4480"\w*, un \w hombre|strong="H1121"\w* \w hábil|strong="H2450"\w*, dotado \w de|strong="H4480"\w* entendimiento, Huram-abí,  
\v 14 hijo de una mujer de las hijas de Dan, y cuyo padre era un hombre de Tiro. Él es hábil \w para|strong="H6258"\w* trabajar el oro, la plata, el bronce, el hierro, la piedra, la madera, la púrpura, el azul, el lino fino y el carmesí; también \w para|strong="H6258"\w* hacer cualquier clase de grabado \w e|strong="H3068"\w* idear cualquier diseño \w que|strong="H6258"\w* se le encomiende, \w para|strong="H6258"\w* \w que|strong="H6258"\w* ocupe un lugar con tus artesanos, y con los artesanos de mi señor David, tu padre.   
\p
\v 15 «Ahora, \w pues|strong="H4480"\w*, \w el|strong="H5921"\w* trigo, \w la|strong="H5921"\w* cebada, \w el|strong="H5921"\w* aceite \w y|strong="H5921"\w* \w el|strong="H5921"\w* vino \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w que|strong="H4480"\w* ha hablado \w mi|strong="H5921"\w* señor, envíelos \w a|strong="H3068"\w* sus siervos;  
\v 16 y \w nosotros|strong="H3605"\w* cortaremos madera del Líbano, \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w que|strong="H1616"\w* necesites. Te \w la|strong="H3605"\w* llevaremos en balsas por mar hasta Jope, y luego tú \w la|strong="H3605"\w* harás subir \w a|strong="H3068"\w* Jerusalén».   
\p
\v 17 Salomón \w hizo|strong="H6213"\w* un censo \w de|strong="H5971"\w* todos \w los|strong="H1992"\w* extranjeros \w que|strong="H5971"\w* \w estaban|strong="H5971"\w* en la tierra \w de|strong="H5971"\w* Israel, según \w el|strong="H6213"\w* censo con \w que|strong="H5971"\w* \w los|strong="H1992"\w* \w había|strong="H6213"\w* contado \w su|strong="H1992"\w* padre David, y \w se|strong="H1992"\w* hallaron \w ciento|strong="H3967"\w* cincuenta y \w tres|strong="H7969"\w* \w mil|strong="H3967"\w* \w seiscientos|strong="H8337"\w*.  
\v 18 Puso \w a|strong="H3068"\w* setenta mil de ellos para llevar cargas, \w a|strong="H3068"\w* ochenta mil como canteros en los montes, y \w a|strong="H3068"\w* tres mil seiscientos como capataces para asignar al pueblo su trabajo.   
\c 3
\p
\v 1 \w Salomón|strong="H8010"\w* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* la \w Casa|strong="H1004"\w* de Yahvé en Jerusalén, en el \w monte|strong="H2022"\w* Moriah, \w donde|strong="H4725"\w* Yahvé se había aparecido \w a|strong="H3068"\w* \w David|strong="H1732"\w* su padre, en el \w lugar|strong="H4725"\w* que \w David|strong="H1732"\w* había designado en la era de Ornán el \w jebuseo|strong="H2983"\w*.  
\v 2 \w Comenzó|strong="H2490"\w* \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* en el \w segundo|strong="H8145"\w* día del \w segundo|strong="H8145"\w* \w mes|strong="H2320"\w*, en el cuarto \w año|strong="H8141"\w* de su \w reinado|strong="H4438"\w*.  
\v 3 Estas son las medidas que \w Salomón|strong="H8010"\w* estableció para los \w cimientos|strong="H3245"\w* de la \w casa|strong="H1004"\w* de Dios: la longitud, en codos según la \w antigua|strong="H7223"\w* \w medida|strong="H4060"\w*, era de \w sesenta|strong="H8346"\w* codos, y la \w anchura|strong="H7341"\w* de \w veinte|strong="H6242"\w* codos.  
\v 4 \w El|strong="H5921"\w* pórtico \w que|strong="H5921"\w* \w estaba|strong="H1004"\w* \w delante|strong="H6440"\w*, \w a|strong="H3068"\w* \w lo|strong="H5921"\w* ancho \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, medía \w veinte|strong="H6242"\w* codos \w de|strong="H5921"\w* largo, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w altura|strong="H1363"\w* era \w de|strong="H5921"\w* \w ciento|strong="H3967"\w* \w veinte|strong="H6242"\w*; \w y|strong="H5921"\w* \w lo|strong="H5921"\w* recubrió \w por|strong="H5921"\w* \w dentro|strong="H6440"\w* \w con|strong="H5921"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w*.  
\v 5 Techó \w la|strong="H5921"\w* sala \w mayor|strong="H1419"\w* \w con|strong="H5921"\w* \w madera|strong="H6086"\w* \w de|strong="H5921"\w* ciprés, \w la|strong="H5921"\w* cual recubrió \w de|strong="H5921"\w* \w oro|strong="H2091"\w* fino, \w y|strong="H5921"\w* \w la|strong="H5921"\w* adornó \w con|strong="H5921"\w* palmeras \w y|strong="H5921"\w* cadenas.  
\v 6 Adornó la \w casa|strong="H1004"\w* con piedras \w preciosas|strong="H3368"\w* para embellecerla; y el \w oro|strong="H2091"\w* era de Parvaim.  
\v 7 También recubrió \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, \w las|strong="H5921"\w* vigas, \w los|strong="H5921"\w* umbrales, \w las|strong="H5921"\w* paredes \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H1817"\w*; \w y|strong="H5921"\w* grabó \w querubines|strong="H3742"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* paredes.   
\p
\v 8 \w Hizo|strong="H6213"\w* asimismo \w el|strong="H5921"\w* lugar \w santísimo|strong="H6944"\w*. Su longitud, \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w anchura|strong="H7341"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, era \w de|strong="H5921"\w* \w veinte|strong="H6242"\w* codos, \w y|strong="H5921"\w* su \w anchura|strong="H7341"\w* \w de|strong="H5921"\w* \w veinte|strong="H6242"\w* codos; \w y|strong="H5921"\w* \w lo|strong="H5921"\w* recubrió \w de|strong="H5921"\w* \w oro|strong="H2091"\w* fino, \w con|strong="H5921"\w* un peso \w de|strong="H5921"\w* \w seiscientos|strong="H8337"\w* \w talentos|strong="H3603"\w*.  
\v 9 El \w peso|strong="H4948"\w* de los clavos era de \w cincuenta|strong="H2572"\w* \w siclos|strong="H8255"\w* de \w oro|strong="H2091"\w*. Recubrió también de \w oro|strong="H2091"\w* las cámaras superiores.   
\p
\v 10 En \w el|strong="H6213"\w* lugar \w santísimo|strong="H6944"\w* \w hizo|strong="H6213"\w* \w dos|strong="H8147"\w* \w querubines|strong="H3742"\w* de madera tallada, y los recubrió de \w oro|strong="H2091"\w*.  
\v 11 Las \w alas|strong="H3671"\w* \w de|strong="H2568"\w* los \w querubines|strong="H3742"\w* medían \w veinte|strong="H6242"\w* codos en total; el \w ala|strong="H3671"\w* \w de|strong="H2568"\w* uno \w de|strong="H2568"\w* ellos medía \w cinco|strong="H2568"\w* codos y \w llegaba|strong="H5060"\w* \w hasta|strong="H3671"\w* la \w pared|strong="H7023"\w* \w de|strong="H2568"\w* la \w Casa|strong="H1004"\w*, y la otra \w ala|strong="H3671"\w* medía \w cinco|strong="H2568"\w* codos y \w tocaba|strong="H5060"\w* el \w ala|strong="H3671"\w* del otro \w querubín|strong="H3742"\w*.  
\v 12 El \w ala|strong="H3671"\w* del otro \w querubín|strong="H3742"\w* medía \w cinco|strong="H2568"\w* codos y \w llegaba|strong="H5060"\w* \w hasta|strong="H3671"\w* la \w pared|strong="H7023"\w* \w de|strong="H2568"\w* la \w casa|strong="H1004"\w*, y la otra \w ala|strong="H3671"\w* medía \w cinco|strong="H2568"\w* codos y se unía al \w ala|strong="H3671"\w* del primer \w querubín|strong="H3742"\w*.  
\v 13 \w Las|strong="H1992"\w* \w alas|strong="H3671"\w* \w de|strong="H5921"\w* \w estos|strong="H1992"\w* \w querubines|strong="H3742"\w* \w se|strong="H5921"\w* \w extendían|strong="H6566"\w* \w veinte|strong="H6242"\w* codos. \w Estaban|strong="H5975"\w* \w de|strong="H5921"\w* \w pie|strong="H7272"\w*, \w y|strong="H5921"\w* \w sus|strong="H1992"\w* \w rostros|strong="H6440"\w* miraban \w hacia|strong="H5921"\w* \w la|strong="H5921"\w* sala principal.  
\v 14 \w Hizo|strong="H6213"\w* \w el|strong="H5921"\w* velo \w de|strong="H5921"\w* azul, púrpura, \w carmesí|strong="H3758"\w* \w y|strong="H5921"\w* lino fino, \w y|strong="H5921"\w* bordó \w en|strong="H5921"\w* \w él|strong="H5921"\w* \w querubines|strong="H3742"\w*.   
\p
\v 15 \w Delante|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w hizo|strong="H6213"\w* \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w* \w de|strong="H5921"\w* \w treinta|strong="H7970"\w* \w y|strong="H5921"\w* \w cinco|strong="H2568"\w* codos \w de|strong="H5921"\w* altura, \w y|strong="H5921"\w* \w el|strong="H5921"\w* capitel \w que|strong="H5921"\w* \w estaba|strong="H1004"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w de|strong="H5921"\w* cada una \w de|strong="H5921"\w* \w ellas|strong="H5921"\w* era \w de|strong="H5921"\w* \w cinco|strong="H2568"\w* codos.  
\v 16 \w Hizo|strong="H6213"\w* cadenas \w en|strong="H5921"\w* \w el|strong="H5921"\w* santuario interior \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w puso|strong="H5414"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*; \w hizo|strong="H6213"\w* \w cien|strong="H3967"\w* \w granadas|strong="H7416"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w puso|strong="H5414"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* cadenas.  
\v 17 \w Erigió|strong="H6965"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w templo|strong="H1964"\w*, una \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* otra \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w*; \w y|strong="H5921"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* Jaquín, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w* \w Boaz|strong="H1162"\w*.   
\c 4
\p
\v 1 Luego \w hizo|strong="H6213"\w* un \w altar|strong="H4196"\w* de bronce de \w veinte|strong="H6242"\w* codos de largo, \w veinte|strong="H6242"\w* codos de ancho y \w diez|strong="H6235"\w* codos de alto.  
\v 2 También \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w mar|strong="H3220"\w* \w de|strong="H2568"\w* fundición, \w de|strong="H2568"\w* \w diez|strong="H6235"\w* codos \w de|strong="H2568"\w* borde \w a|strong="H3068"\w* borde. Era circular, \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* codos \w de|strong="H2568"\w* \w altura|strong="H6967"\w* y \w de|strong="H2568"\w* \w treinta|strong="H7970"\w* codos \w de|strong="H2568"\w* circunferencia.  
\v 3 \w Debajo|strong="H8478"\w* \w de|strong="H8478"\w* su borde había figuras \w de|strong="H8478"\w* \w bueyes|strong="H1241"\w* que lo rodeaban, \w diez|strong="H6235"\w* \w por|strong="H8478"\w* \w cada|strong="H6235"\w* codo \w alrededor|strong="H5439"\w* del \w mar|strong="H3220"\w*. Los \w bueyes|strong="H1241"\w* estaban dispuestos \w en|strong="H8478"\w* \w dos|strong="H8147"\w* hileras, fundidos \w en|strong="H8478"\w* una sola pieza con el \w mar|strong="H3220"\w*.  
\v 4 \w Estaba|strong="H5975"\w* asentado \w sobre|strong="H5921"\w* \w doce|strong="H8147"\w* \w bueyes|strong="H1241"\w*: \w tres|strong="H7969"\w* \w miraban|strong="H6437"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w norte|strong="H6828"\w*, \w tres|strong="H7969"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* occidente, \w tres|strong="H7969"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* sur \w y|strong="H5921"\w* \w tres|strong="H7969"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w oriente|strong="H4217"\w*; \w el|strong="H5921"\w* \w mar|strong="H3220"\w* descansaba \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w todas|strong="H3605"\w* sus partes traseras quedaban \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* interior.  
\v 5 Su grosor era de un palmo, y su borde estaba labrado como el borde de un \w cáliz|strong="H3563"\w*, como una \w flor|strong="H6525"\w* de lirio. Tenía capacidad para \w tres|strong="H7969"\w* mil \w batos|strong="H1324"\w*.  
\v 6 \w Hizo|strong="H6213"\w* también \w diez|strong="H6235"\w* \w fuentes|strong="H3595"\w*, y \w puso|strong="H5414"\w* \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w derecha|strong="H3225"\w* y \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w izquierda|strong="H8040"\w* \w para|strong="H5414"\w* lavar en ellas. Allí \w lavaban|strong="H7364"\w* \w lo|strong="H6213"\w* destinado \w al|strong="H5930"\w* \w holocausto|strong="H5930"\w*, pero \w el|strong="H6213"\w* \w mar|strong="H3220"\w* era \w para|strong="H5414"\w* que se \w lavaran|strong="H7364"\w* los \w sacerdotes|strong="H3548"\w*.   
\p
\v 7 \w Hizo|strong="H6213"\w* los \w diez|strong="H6235"\w* candelabros \w de|strong="H2568"\w* \w oro|strong="H2091"\w*, según su \w ordenanza|strong="H4941"\w*, y los \w puso|strong="H5414"\w* en \w el|strong="H6213"\w* \w templo|strong="H1964"\w*, \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w derecha|strong="H3225"\w* y \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w izquierda|strong="H8040"\w*.  
\v 8 \w Hizo|strong="H6213"\w* \w también|strong="H7979"\w* \w diez|strong="H6235"\w* \w mesas|strong="H7979"\w* y las colocó en \w el|strong="H6213"\w* \w templo|strong="H1964"\w*, \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w derecha|strong="H3225"\w* y \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w izquierda|strong="H8040"\w*; \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w cien|strong="H3967"\w* \w tazones|strong="H4219"\w* \w de|strong="H2568"\w* \w oro|strong="H2091"\w*.  
\v 9 Además, \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w atrio|strong="H2691"\w* de los \w sacerdotes|strong="H3548"\w*, \w el|strong="H6213"\w* \w gran|strong="H1419"\w* \w atrio|strong="H2691"\w*, y las \w puertas|strong="H1817"\w* para \w el|strong="H6213"\w* \w atrio|strong="H2691"\w*, y recubrió sus \w puertas|strong="H1817"\w* de bronce.  
\v 10 Colocó el \w mar|strong="H3220"\w* al \w lado|strong="H3802"\w* \w derecho|strong="H3233"\w* \w de|strong="H5414"\w* la casa, \w hacia|strong="H4136"\w* el sudeste.   
\p
\v 11 Huram \w hizo|strong="H6213"\w* las ollas, las palas y los \w cuencos|strong="H4219"\w*.  
\p Así terminó Huram la \w obra|strong="H4399"\w* que realizaba para \w el|strong="H6213"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* en la \w casa|strong="H1004"\w* de Dios:  
\v 12 \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w*, \w los|strong="H5921"\w* tazones, \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w capiteles|strong="H3805"\w* \w que|strong="H5921"\w* \w estaban|strong="H7218"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*, \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w redes|strong="H3805"\w* \w para|strong="H5921"\w* \w cubrir|strong="H3680"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* tazones \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w capiteles|strong="H3805"\w* \w que|strong="H5921"\w* \w estaban|strong="H7218"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*,  
\v 13 \w y|strong="H5921"\w* \w las|strong="H5921"\w* cuatrocientas \w granadas|strong="H7416"\w* \w para|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w redes|strong="H3805"\w*, dispuestas \w en|strong="H5921"\w* \w dos|strong="H8147"\w* filas \w de|strong="H5921"\w* \w granadas|strong="H7416"\w* \w para|strong="H5921"\w* cada red, \w con|strong="H5921"\w* \w el|strong="H5921"\w* fin \w de|strong="H5921"\w* \w cubrir|strong="H3680"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* tazones \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w capiteles|strong="H3805"\w* \w que|strong="H5921"\w* estaban \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*.  
\v 14 También \w hizo|strong="H6213"\w* \w las|strong="H5921"\w* \w basas|strong="H4350"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w* \w hizo|strong="H6213"\w* \w las|strong="H5921"\w* \w fuentes|strong="H3595"\w*,  
\v 15 un \w mar|strong="H3220"\w* único, \w y|strong="H1241"\w* los \w doce|strong="H8147"\w* \w bueyes|strong="H1241"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* él.  
\v 16 Huram-abí \w hizo|strong="H6213"\w* también las ollas, las palas, \w los|strong="H3605"\w* garfios y \w todos|strong="H3605"\w* sus utensilios de bronce pulido para \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, para \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de Yahvé.  
\v 17 El \w rey|strong="H4428"\w* los fundió en la llanura del \w Jordán|strong="H3383"\w*, en moldes de arcilla entre Sucot y Zereda.  
\v 18 \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* utensilios \w en|strong="H3588"\w* \w tan|strong="H3966"\w* \w gran|strong="H3966"\w* cantidad \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* pudo calcular \w el|strong="H3588"\w* \w peso|strong="H4948"\w* del bronce.   
\p
\v 19 Así \w hizo|strong="H6213"\w* \w Salomón|strong="H8010"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* utensilios \w que|strong="H5921"\w* \w había|strong="H6213"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Dios: \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w las|strong="H5921"\w* \w mesas|strong="H7979"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w panes|strong="H3899"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* proposición \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w*,  
\v 20 \w y|strong="H1197"\w* los candelabros con sus \w lámparas|strong="H5216"\w* \w de|strong="H6440"\w* \w oro|strong="H2091"\w* \w puro|strong="H5462"\w*, para que ardieran según \w la|strong="H1197"\w* \w ordenanza|strong="H4941"\w* \w ante|strong="H6440"\w* el santuario interior;  
\v 21 las \w flores|strong="H6525"\w*, las \w lámparas|strong="H5216"\w* y las tenazas eran del \w oro|strong="H2091"\w* más puro;  
\v 22 también las despabiladeras, los \w cuencos|strong="H4219"\w*, las \w cucharas|strong="H3709"\w* y los \w incensarios|strong="H4289"\w* eran de \w oro|strong="H2091"\w* \w puro|strong="H5462"\w*. En cuanto \w a|strong="H3068"\w* la entrada de la \w casa|strong="H1004"\w*, sus \w puertas|strong="H1817"\w* \w interiores|strong="H6442"\w* para el lugar \w santísimo|strong="H6944"\w* y las \w puertas|strong="H1817"\w* de la sala principal del \w templo|strong="H1964"\w* eran de \w oro|strong="H2091"\w*.   
\c 5
\p
\v 1 Así quedó terminada \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* \w que|strong="H3605"\w* \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* \w para|strong="H5414"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Yahvé. \w Salomón|strong="H8010"\w* trajo las cosas \w que|strong="H3605"\w* su padre \w David|strong="H1732"\w* \w había|strong="H6213"\w* \w consagrado|strong="H6944"\w*, \w la|strong="H3605"\w* \w plata|strong="H3701"\w*, \w el|strong="H3605"\w* \w oro|strong="H2091"\w* y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios, y \w los|strong="H3605"\w* depositó en \w los|strong="H3605"\w* tesoros \w de|strong="H5414"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5414"\w* \w Dios|strong="H3068"\w*.   
\p
\v 2 Entonces \w Salomón|strong="H8010"\w* reunió en Jerusalén \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las \w tribus|strong="H4294"\w*, \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las familias \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, para hacer \w subir|strong="H5927"\w* \w el|strong="H1931"\w* arca \w de|strong="H1121"\w* \w la|strong="H1931"\w* \w alianza|strong="H1285"\w* \w de|strong="H1121"\w* Yahvé desde \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Sión|strong="H6726"\w*.  
\v 3 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres de \w Israel|strong="H3478"\w* \w se|strong="H1931"\w* congregaron ante \w el|strong="H1931"\w* \w rey|strong="H4428"\w* para \w la|strong="H1931"\w* \w fiesta|strong="H2282"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w se|strong="H1931"\w* celebraba en \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w séptimo|strong="H7637"\w*.  
\v 4 Vinieron \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de \w Israel|strong="H3478"\w*, y \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* \w alzaron|strong="H5375"\w* \w el|strong="H3605"\w* arca.  
\v 5 \w Subieron|strong="H5927"\w* \w el|strong="H3605"\w* arca, \w la|strong="H3605"\w* Tienda del Encuentro y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w sagrados|strong="H6944"\w* \w que|strong="H3605"\w* estaban en \w la|strong="H3605"\w* Tienda; \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w levitas|strong="H3881"\w* \w los|strong="H3605"\w* llevaron.  
\v 6 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* asamblea \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* había reunido \w con|strong="H5921"\w* \w él|strong="H5921"\w* estaban \w ante|strong="H6440"\w* \w el|strong="H5921"\w* arca, \w sacrificando|strong="H2076"\w* \w ovejas|strong="H6629"\w* \w y|strong="H5921"\w* \w bueyes|strong="H1241"\w* \w en|strong="H5921"\w* tal cantidad \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* podían \w contar|strong="H5608"\w* \w ni|strong="H3808"\w* \w numerar|strong="H4487"\w*.  
\v 7 Los \w sacerdotes|strong="H3548"\w* introdujeron el arca \w de|strong="H8478"\w* la \w alianza|strong="H1285"\w* \w de|strong="H8478"\w* Yahvé \w en|strong="H8478"\w* su \w lugar|strong="H4725"\w*, \w en|strong="H8478"\w* el \w santuario|strong="H6944"\w* interior \w de|strong="H8478"\w* la \w casa|strong="H1004"\w*, \w en|strong="H8478"\w* el \w lugar|strong="H4725"\w* \w santísimo|strong="H6944"\w*, \w bajo|strong="H8478"\w* las \w alas|strong="H3671"\w* \w de|strong="H8478"\w* los \w querubines|strong="H3742"\w*.  
\v 8 \w Pues|strong="H1961"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w* \w extendían|strong="H6566"\w* sus \w alas|strong="H3671"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w lugar|strong="H4725"\w* \w del|strong="H5921"\w* arca, \w de|strong="H5921"\w* modo \w que|strong="H5921"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w* \w cubrían|strong="H3680"\w* \w por|strong="H5921"\w* \w encima|strong="H4605"\w* \w el|strong="H5921"\w* arca \w y|strong="H5921"\w* sus varales.  
\v 9 \w Los|strong="H5921"\w* varales \w eran|strong="H1961"\w* tan largos \w que|strong="H4480"\w* sus extremos \w se|strong="H1961"\w* \w veían|strong="H7200"\w* \w desde|strong="H4480"\w* \w el|strong="H5921"\w* arca frente \w al|strong="H5921"\w* santuario interior, pero \w no|strong="H3808"\w* \w se|strong="H1961"\w* \w veían|strong="H7200"\w* \w desde|strong="H4480"\w* \w fuera|strong="H2351"\w*; \w y|strong="H5921"\w* \w allí|strong="H8033"\w* permanecen \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H4480"\w* \w hoy|strong="H3117"\w*.  
\v 10 \w En|strong="H5973"\w* \w el|strong="H5973"\w* arca no había nada \w más|strong="H7535"\w* \w que|strong="H1121"\w* las \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* \w que|strong="H1121"\w* \w Moisés|strong="H4872"\w* \w puso|strong="H5414"\w* allí \w en|strong="H5973"\w* \w Horeb|strong="H2722"\w*, cuando Yahvé \w hizo|strong="H3772"\w* la \w alianza|strong="H3772"\w* \w con|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*, al \w salir|strong="H3318"\w* \w de|strong="H5973"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 11 \w Cuando|strong="H3588"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w salieron|strong="H3318"\w* \w del|strong="H4480"\w* lugar \w santo|strong="H6944"\w* (\w porque|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H3588"\w* \w estaban|strong="H1961"\w* presentes \w se|strong="H1961"\w* \w habían|strong="H1961"\w* \w santificado|strong="H6944"\w*, sin \w guardar|strong="H8104"\w* \w el|strong="H3588"\w* turno \w de|strong="H4480"\w* sus divisiones;  
\v 12 y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w cantores|strong="H7891"\w*, Asaf, \w Hemán|strong="H1968"\w*, Jedutún, sus \w hijos|strong="H1121"\w* y sus hermanos, \w vestidos|strong="H3847"\w* \w de|strong="H5973"\w* lino fino, \w con|strong="H5973"\w* \w címbalos|strong="H4700"\w*, \w salterios|strong="H5035"\w* y \w arpas|strong="H3658"\w*, \w estaban|strong="H5975"\w* \w de|strong="H5973"\w* \w pie|strong="H5975"\w* al lado \w oriental|strong="H4217"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*, y \w con|strong="H5973"\w* \w ellos|strong="H3605"\w* \w ciento|strong="H3967"\w* \w veinte|strong="H6242"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H1121"\w* \w tocaban|strong="H2690"\w* las \w trompetas|strong="H2689"\w*);  
\v 13 \w cuando|strong="H3588"\w* \w los|strong="H1961"\w* trompetistas \w y|strong="H3588"\w* \w los|strong="H1961"\w* \w cantores|strong="H7891"\w* \w se|strong="H1961"\w* unieron al unísono \w para|strong="H3588"\w* hacer \w oír|strong="H8085"\w* una sola \w voz|strong="H6963"\w* \w en|strong="H3588"\w* \w alabanza|strong="H1984"\w* \w y|strong="H3588"\w* acción \w de|strong="H3588"\w* gracias \w a|strong="H3068"\w* Yahvé, \w y|strong="H3588"\w* \w cuando|strong="H3588"\w* alzaron \w la|strong="H3588"\w* \w voz|strong="H6963"\w* al \w son|strong="H1961"\w* \w de|strong="H3588"\w* las \w trompetas|strong="H2689"\w*, \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w címbalos|strong="H4700"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w instrumentos|strong="H3627"\w* \w de|strong="H3588"\w* \w música|strong="H7892"\w*, \w y|strong="H3588"\w* alabaron \w a|strong="H3068"\w* Yahvé, diciendo:  
\q1 «\w Porque|strong="H3588"\w* \w él|strong="H3588"\w* \w es|strong="H1961"\w* \w bueno|strong="H2896"\w*,  
\q2 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w es|strong="H1961"\w* \w eterna|strong="H5769"\w*»,  
\m \w entonces|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w se|strong="H1961"\w* \w llenó|strong="H4390"\w* \w de|strong="H3588"\w* una \w nube|strong="H6051"\w*, \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé,  
\v 14 \w de|strong="H3588"\w* modo \w que|strong="H3588"\w* \w los|strong="H3588"\w* \w sacerdotes|strong="H3548"\w* \w no|strong="H3808"\w* \w podían|strong="H3201"\w* mantenerse \w en|strong="H3588"\w* \w pie|strong="H5975"\w* \w para|strong="H3588"\w* ministrar \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w nube|strong="H6051"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w gloria|strong="H3519"\w* \w de|strong="H3588"\w* Yahvé llenaba \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Dios|strong="H3068"\w*.   
\c 6
\p
\v 1 Entonces \w Salomón|strong="H8010"\w* dijo: «Yahvé ha dicho que moraría en la densa \w oscuridad|strong="H6205"\w*.  
\v 2 Pero yo te he \w edificado|strong="H1129"\w* una \w casa|strong="H1004"\w* y un hogar, un lugar para que habites para \w siempre|strong="H5769"\w*».   
\p
\v 3 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* volvió su \w rostro|strong="H6440"\w* y \w bendijo|strong="H1288"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* asamblea \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*; y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* asamblea \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w permaneció|strong="H5975"\w* \w de|strong="H6440"\w* \w pie|strong="H5975"\w*.   
\p
\v 4 \w Y|strong="H3068"\w* \w dijo|strong="H1696"\w*: “\w Bendito|strong="H1288"\w* sea Yahvé, el \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*, \w que|strong="H6310"\w* \w habló|strong="H1696"\w* con su \w boca|strong="H6310"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, mi padre, y con sus \w manos|strong="H3027"\w* lo ha cumplido, \w diciendo|strong="H1696"\w*:  
\v 5 ‘\w Desde|strong="H4480"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w en|strong="H5921"\w* \w que|strong="H4480"\w* \w saqué|strong="H3318"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*, \w no|strong="H3808"\w* elegí \w ninguna|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w de|strong="H4480"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w tribus|strong="H7626"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w para|strong="H5921"\w* \w edificar|strong="H1129"\w* una \w casa|strong="H1004"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H4480"\w* habitara \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* elegí \w a|strong="H3068"\w* \w ningún|strong="H3605"\w* hombre \w para|strong="H5921"\w* \w que|strong="H4480"\w* \w fuera|strong="H1961"\w* \w príncipe|strong="H5057"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*;  
\v 6 pero ahora he elegido Jerusalén, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w* \w esté|strong="H1961"\w* \w allí|strong="H8033"\w*; \w y|strong="H5921"\w* he elegido \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* gobierne \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.’  
\v 7 \w Estaba|strong="H1961"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w corazón|strong="H3824"\w* \w de|strong="H5973"\w* \w mi|strong="H1961"\w* padre \w David|strong="H1732"\w* \w edificar|strong="H1129"\w* una \w casa|strong="H1004"\w* \w para|strong="H1961"\w* \w el|strong="H5973"\w* \w nombre|strong="H8034"\w* \w de|strong="H5973"\w* Yahvé, \w el|strong="H5973"\w* \w Dios|strong="H3068"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*.  
\v 8 \w Pero|strong="H3588"\w* Yahvé dijo \w a|strong="H3068"\w* \w mi|strong="H1961"\w* padre \w David|strong="H1732"\w*: ‘\w Puesto|strong="H3588"\w* \w que|strong="H3588"\w* tuviste \w en|strong="H5973"\w* tu \w corazón|strong="H3824"\w* \w edificar|strong="H1129"\w* una \w casa|strong="H1004"\w* \w para|strong="H3588"\w* \w mi|strong="H1961"\w* \w nombre|strong="H8034"\w*, hiciste \w bien|strong="H2895"\w* \w en|strong="H5973"\w* tenerlo \w en|strong="H5973"\w* tu \w corazón|strong="H3824"\w*;  
\v 9 \w sin|strong="H3808"\w* embargo, \w no|strong="H3808"\w* serás tú \w quien|strong="H1931"\w* \w edifique|strong="H1129"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w*, \w sino|strong="H3588"\w* tu \w hijo|strong="H1121"\w* \w que|strong="H3588"\w* \w saldrá|strong="H3318"\w* \w de|strong="H3588"\w* tus \w lomos|strong="H2504"\w*, \w él|strong="H1931"\w* \w edificará|strong="H1129"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w para|strong="H3588"\w* mi \w nombre|strong="H8034"\w*.’   
\p
\v 10 «Yahvé ha cumplido \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w que|strong="H5921"\w* había pronunciado, pues yo \w me|strong="H5921"\w* he levantado \w en|strong="H5921"\w* \w lugar|strong="H8478"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*, \w mi|strong="H5921"\w* padre, \w y|strong="H5921"\w* \w me|strong="H5921"\w* he \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w como|strong="H5921"\w* \w lo|strong="H1697"\w* había prometido Yahvé, \w y|strong="H5921"\w* he \w edificado|strong="H1129"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 11 \w Allí|strong="H8033"\w* he colocado \w el|strong="H5973"\w* arca, \w en|strong="H5973"\w* la \w cual|strong="H5973"\w* \w está|strong="H8033"\w* la \w alianza|strong="H1285"\w* \w de|strong="H5973"\w* Yahvé, \w que|strong="H1121"\w* \w hizo|strong="H3772"\w* \w con|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*».   
\p
\v 12 Luego se \w puso|strong="H5975"\w* \w de|strong="H6440"\w* \w pie|strong="H5975"\w* \w ante|strong="H6440"\w* \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w de|strong="H6440"\w* Yahvé, \w en|strong="H5975"\w* \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* asamblea \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, y \w extendió|strong="H6566"\w* sus \w manos|strong="H3709"\w*  
\v 13 (\w pues|strong="H3588"\w* \w Salomón|strong="H8010"\w* \w había|strong="H5975"\w* \w hecho|strong="H6213"\w* una plataforma \w de|strong="H5921"\w* bronce \w de|strong="H5921"\w* \w cinco|strong="H2568"\w* codos \w de|strong="H5921"\w* largo, \w cinco|strong="H2568"\w* codos \w de|strong="H5921"\w* ancho \w y|strong="H3588"\w* \w tres|strong="H7969"\w* codos \w de|strong="H5921"\w* alto, \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w había|strong="H5975"\w* colocado \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H5921"\w* \w atrio|strong="H5835"\w*; \w se|strong="H5921"\w* \w puso|strong="H5414"\w* \w de|strong="H5921"\w* \w pie|strong="H5975"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*, \w se|strong="H5921"\w* arrodilló ante \w toda|strong="H3605"\w* \w la|strong="H5921"\w* asamblea \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w extendió|strong="H6566"\w* sus \w manos|strong="H3709"\w* \w hacia|strong="H6213"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*).  
\v 14 Entonces dijo: “Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w no|strong="H6440"\w* hay \w Dios|strong="H3068"\w* \w como|strong="H3644"\w* tú en \w el|strong="H3605"\w* \w cielo|strong="H8064"\w* ni en \w la|strong="H3605"\w* tierra; tú \w que|strong="H3605"\w* \w guardas|strong="H8104"\w* \w el|strong="H3605"\w* \w pacto|strong="H1285"\w* y \w la|strong="H3605"\w* \w misericordia|strong="H2617"\w* con tus \w siervos|strong="H5650"\w* \w que|strong="H3605"\w* \w andan|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti \w de|strong="H6440"\w* \w todo|strong="H3605"\w* \w corazón|strong="H3820"\w*;  
\v 15 \w que|strong="H3117"\w* has cumplido con tu \w siervo|strong="H5650"\w* \w David|strong="H1732"\w*, mi padre, \w lo|strong="H2088"\w* \w que|strong="H3117"\w* le prometiste. Sí, tú \w hablaste|strong="H1696"\w* con tu \w boca|strong="H6310"\w*, y \w lo|strong="H2088"\w* has cumplido con tu \w mano|strong="H3027"\w*, como se ve en el \w día|strong="H3117"\w* de \w hoy|strong="H3117"\w*.   
\p
