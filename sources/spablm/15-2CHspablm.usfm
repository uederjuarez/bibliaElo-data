\p
\v 22 En \w el|strong="H3605"\w* primer \w año|strong="H8141"\w* \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, para \w que|strong="H1571"\w* se cumpliera \w la|strong="H1571"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w por|strong="H1697"\w* \w boca|strong="H6310"\w* \w de|strong="H1697"\w* \w Jeremías|strong="H3414"\w*, Yahvé \w despertó|strong="H5782"\w* \w el|strong="H3605"\w* \w espíritu|strong="H7307"\w* \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, \w el|strong="H3605"\w* cual hizo \w pregonar|strong="H5674"\w* \w de|strong="H1697"\w* \w palabra|strong="H1697"\w* \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w por|strong="H1697"\w* escrito, \w por|strong="H1697"\w* \w todo|strong="H3605"\w* su \w reino|strong="H4438"\w*, este decreto:  
\v 23 “\w Así|strong="H3541"\w* dice \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*: ‘Yahvé, \w el|strong="H1931"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*, \w me|strong="H5921"\w* \w ha|strong="H3541"\w* \w dado|strong="H5414"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra, \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w ha|strong="H3541"\w* mandado \w que|strong="H4310"\w* \w le|strong="H1931"\w* \w edifique|strong="H1129"\w* una \w casa|strong="H1004"\w* \w en|strong="H5921"\w* Jerusalén, \w que|strong="H4310"\w* \w está|strong="H1931"\w* \w en|strong="H5921"\w* \w Judá|strong="H3063"\w*. \w Quien|strong="H4310"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w vosotros|strong="H5973"\w* pertenezca \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*, sea Yahvé \w su|strong="H1931"\w* \w Dios|strong="H3068"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w*, \w y|strong="H5921"\w* \w suba|strong="H5927"\w* allá’”.   