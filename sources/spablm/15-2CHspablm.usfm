\v 14 \w Asimismo|strong="H1571"\w*, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H1571"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w prevaricaron|strong="H4603"\w* \w cada|strong="H3605"\w* vez \w más|strong="H1571"\w*, imitando \w todas|strong="H3605"\w* las \w abominaciones|strong="H8441"\w* \w de|strong="H5971"\w* las \w naciones|strong="H1471"\w* paganas, \w y|strong="H1571"\w* profanaron \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Yahvé, \w que|strong="H1571"\w* \w él|strong="H3605"\w* \w había|strong="H6942"\w* santificado en Jerusalén.   
\p
\v 15 Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* sus padres, \w les|strong="H5921"\w* \w enviaba|strong="H7971"\w* constantes advertencias \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* sus \w mensajeros|strong="H4397"\w*, \w porque|strong="H3588"\w* tenía compasión \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w morada|strong="H4583"\w*.  
\v 16 Pero ellos \w se|strong="H1961"\w* burlaban \w de|strong="H5704"\w* \w los|strong="H1961"\w* \w mensajeros|strong="H4397"\w* \w de|strong="H5704"\w* \w Dios|strong="H3068"\w*, menospreciaban sus \w palabras|strong="H1697"\w* \w y|strong="H5704"\w* \w se|strong="H1961"\w* mofaban \w de|strong="H5704"\w* sus \w profetas|strong="H5030"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* la \w ira|strong="H2534"\w* \w de|strong="H5704"\w* Yahvé \w se|strong="H1961"\w* encendió \w contra|strong="H1961"\w* su \w pueblo|strong="H5971"\w* \w y|strong="H5704"\w* ya \w no|strong="H1961"\w* \w hubo|strong="H1961"\w* \w remedio|strong="H4832"\w*.   
\p
