\v 10 \w Los|strong="H5921"\w* \w correos|strong="H7323"\w* \w pasaron|strong="H5674"\w* \w de|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w en|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Efraín \w y|strong="H5921"\w* \w Manasés|strong="H4519"\w*, \w hasta|strong="H5704"\w* \w Zabulón|strong="H2074"\w*; pero \w la|strong="H5921"\w* gente \w se|strong="H1961"\w* reía \w y|strong="H5921"\w* \w se|strong="H1961"\w* burlaba \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
