\c 10
\p
\v 1 \w Roboam|strong="H7346"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Siquem, \w porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w había|strong="H3588"\w* \w ido|strong="H3212"\w* \w a|strong="H3068"\w* Siquem \w para|strong="H3588"\w* proclamarlo \w rey|strong="H4427"\w*.  
