\c 1
\p
\v 1 \w En|strong="H5921"\w* \w el|strong="H5921"\w* tercer \w año|strong="H8141"\w* \w del|strong="H5921"\w* \w reinado|strong="H4428"\w* \w de|strong="H5921"\w* \w Joacim|strong="H3079"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, llegó \w a|strong="H3068"\w* Jerusalén \w y|strong="H5921"\w* \w la|strong="H5921"\w* sitió.  
\v 2 El Señor\f + \fr 1:2 \ft La palabra traducida «Señor» es «Adonai».\f* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* \w Joacim|strong="H3079"\w*, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*, con algunos \w de|strong="H5414"\w* los utensilios \w de|strong="H5414"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Dios;\f + \fr 1:2 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f* y los llevó \w a|strong="H3068"\w* la tierra \w de|strong="H5414"\w* Sinar, \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* su dios. Llevó los utensilios \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* del tesoro \w de|strong="H5414"\w* su dios.   
\p
\v 3 \w El|strong="H1121"\w* \w rey|strong="H4428"\w* habló \w con|strong="H4480"\w* Aspenaz, jefe \w de|strong="H4480"\w* sus \w eunucos|strong="H5631"\w*, \w para|strong="H4480"\w* \w que|strong="H4480"\w* trajera \w a|strong="H3068"\w* algunos \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w de|strong="H4480"\w* la \w descendencia|strong="H2233"\w* \w real|strong="H4428"\w*\f + \fr 1:3 \ft o, semilla\f* y \w de|strong="H4480"\w* \w los|strong="H1121"\w* nobles,  
\v 4 jóvenes \w en|strong="H5975"\w* \w los|strong="H3605"\w* \w que|strong="H3045"\w* no \w hubiese|strong="H5975"\w* \w ningún|strong="H3605"\w* defecto, de \w buen|strong="H2896"\w* \w parecer|strong="H4758"\w*, \w instruidos|strong="H3925"\w* \w en|strong="H5975"\w* \w toda|strong="H3605"\w* \w sabiduría|strong="H2451"\w*, dotados de \w conocimiento|strong="H1847"\w*, \w que|strong="H3045"\w* comprendiesen \w la|strong="H3605"\w* \w ciencia|strong="H1847"\w* y \w que|strong="H3045"\w* tuviesen \w la|strong="H3605"\w* capacidad de estar \w en|strong="H5975"\w* \w el|strong="H3605"\w* palacio del \w rey|strong="H4428"\w*; y \w que|strong="H3045"\w* les enseñase \w la|strong="H3605"\w* escritura y \w la|strong="H3605"\w* \w lengua|strong="H3956"\w* de \w los|strong="H3605"\w* \w caldeos|strong="H3778"\w*.  
\v 5 El \w rey|strong="H4428"\w* dispuso para ellos una \w ración|strong="H1697"\w* \w diaria|strong="H3117"\w* \w de|strong="H6440"\w* los manjares del \w rey|strong="H4428"\w* y del \w vino|strong="H3196"\w* \w que|strong="H1697"\w* él bebía, y \w que|strong="H1697"\w* fuesen educados durante \w tres|strong="H7969"\w* \w años|strong="H8141"\w*, para \w que|strong="H1697"\w* \w al|strong="H4428"\w* final \w de|strong="H6440"\w* ellos se presentasen \w ante|strong="H6440"\w* el \w rey|strong="H4428"\w*.   
\p
\v 6 Entre estos \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* \w estaban|strong="H1961"\w* \w Daniel|strong="H1840"\w*, \w Ananías|strong="H2608"\w*, \w Misael|strong="H4332"\w* y \w Azarías|strong="H5838"\w*.  
\v 7 \w El|strong="H1992"\w* \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* \w los|strong="H1992"\w* \w eunucos|strong="H5631"\w* \w les|strong="H1992"\w* \w dio|strong="H7760"\w* \w nombres|strong="H8034"\w*: \w a|strong="H3068"\w* \w Daniel|strong="H1840"\w* le \w puso|strong="H7760"\w* \w el|strong="H1992"\w* \w nombre|strong="H8034"\w* \w de|strong="H8269"\w* \w Beltsasar|strong="H1095"\w*; \w a|strong="H3068"\w* \w Ananías|strong="H2608"\w*, \w el|strong="H1992"\w* \w de|strong="H8269"\w* Sadrac; \w a|strong="H3068"\w* \w Misael|strong="H4332"\w*, \w el|strong="H1992"\w* \w de|strong="H8269"\w* Mesac; y \w a|strong="H3068"\w* \w Azarías|strong="H5838"\w*, \w el|strong="H1992"\w* \w de|strong="H8269"\w* Abednego.   
\p
\v 8 Pero \w Daniel|strong="H1840"\w* \w se|strong="H5921"\w* \w propuso|strong="H7760"\w* \w en|strong="H5921"\w* su \w corazón|strong="H3820"\w* \w no|strong="H3808"\w* \w contaminarse|strong="H1351"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* manjares \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w ni|strong="H3808"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w vino|strong="H3196"\w* \w que|strong="H3808"\w* bebía. \w Por|strong="H5921"\w* eso \w pidió|strong="H1245"\w* \w al|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w eunucos|strong="H5631"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* \w le|strong="H5921"\w* obligase \w a|strong="H3068"\w* \w contaminarse|strong="H1351"\w*.  
\v 9 Ahora bien, Dios \w hizo|strong="H5414"\w* que \w Daniel|strong="H1840"\w* encontrara \w gracia|strong="H2617"\w* y compasión \w a|strong="H3068"\w* los ojos del \w jefe|strong="H8269"\w* \w de|strong="H6440"\w* los \w eunucos|strong="H5631"\w*.  
\v 10 El \w jefe|strong="H7218"\w* \w de|strong="H4480"\w* los \w eunucos|strong="H5631"\w* dijo \w a|strong="H3068"\w* \w Daniel|strong="H1840"\w*: «Temo \w a|strong="H3068"\w* mi señor el \w rey|strong="H4428"\w*, \w que|strong="H4100"\w* \w ha|strong="H4487"\w* dispuesto vuestra \w comida|strong="H3978"\w* y vuestra bebida. \w Pues|strong="H7200"\w*, ¿\w por|strong="H4480"\w* \w qué|strong="H4100"\w* habría \w de|strong="H4480"\w* \w ver|strong="H7200"\w* vuestros \w rostros|strong="H6440"\w* \w más|strong="H4480"\w* demacrados \w que|strong="H4100"\w* los \w de|strong="H4480"\w* los jóvenes \w de|strong="H4480"\w* vuestra edad? Entonces pondríais \w en|strong="H4480"\w* peligro mi \w cabeza|strong="H7218"\w* \w ante|strong="H6440"\w* el \w rey|strong="H4428"\w*».   
\p
\v 11 Entonces \w Daniel|strong="H1840"\w* dijo \w al|strong="H5921"\w* \w mayordomo|strong="H5921"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w eunucos|strong="H5631"\w* había designado \w sobre|strong="H5921"\w* \w Daniel|strong="H1840"\w*, \w Ananías|strong="H2608"\w*, \w Misael|strong="H4332"\w* \w y|strong="H5921"\w* \w Azarías|strong="H5838"\w*:  
\v 12 «\w Te|strong="H4480"\w* \w ruego|strong="H4994"\w* \w que|strong="H4480"\w* \w pongas|strong="H5414"\w* \w a|strong="H3068"\w* \w prueba|strong="H5254"\w* \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w* durante \w diez|strong="H6235"\w* \w días|strong="H3117"\w*, y \w que|strong="H4480"\w* \w nos|strong="H4480"\w* den \w legumbres|strong="H2235"\w* \w para|strong="H4480"\w* comer y \w agua|strong="H4325"\w* \w para|strong="H4480"\w* \w beber|strong="H8354"\w*.  
\v 13 Que se examinen luego nuestros \w rostros|strong="H6440"\w* \w ante|strong="H6440"\w* \w ti|strong="H5973"\w*, y \w el|strong="H5973"\w* \w de|strong="H6440"\w* \w los|strong="H5973"\w* jóvenes que comen \w de|strong="H6440"\w* \w los|strong="H5973"\w* manjares \w del|strong="H5973"\w* \w rey|strong="H4428"\w*; y según \w veas|strong="H7200"\w*, trata \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w*».  
\v 14 \w Así|strong="H2088"\w* \w que|strong="H1697"\w* los \w escuchó|strong="H8085"\w* en \w este|strong="H2088"\w* \w asunto|strong="H1697"\w*, y los puso \w a|strong="H3068"\w* \w prueba|strong="H5254"\w* durante \w diez|strong="H6235"\w* \w días|strong="H3117"\w*.   
\p
\v 15 \w Al|strong="H4480"\w* cabo \w de|strong="H4480"\w* \w diez|strong="H6235"\w* \w días|strong="H3117"\w*, sus \w rostros|strong="H4758"\w* parecían \w más|strong="H4480"\w* \w hermosos|strong="H2896"\w* y estaban \w más|strong="H4480"\w* robustos \w que|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* jóvenes \w que|strong="H4480"\w* comían \w de|strong="H4480"\w* \w los|strong="H3605"\w* manjares \w del|strong="H4480"\w* \w rey|strong="H4428"\w*.  
\v 16 Entonces el mayordomo les quitó \w los|strong="H1961"\w* manjares y el \w vino|strong="H3196"\w* \w que|strong="H1961"\w* les \w habían|strong="H1961"\w* \w dado|strong="H5414"\w* \w de|strong="H5414"\w* beber, y les \w dio|strong="H5414"\w* \w legumbres|strong="H2235"\w*.   
\p
\v 17 En cuanto \w a|strong="H3068"\w* \w estos|strong="H3605"\w* cuatro jóvenes, Dios les \w dio|strong="H5414"\w* \w conocimiento|strong="H4093"\w* y destreza en \w toda|strong="H3605"\w* ciencia y \w sabiduría|strong="H2451"\w*; y \w Daniel|strong="H1840"\w* tuvo entendimiento en \w toda|strong="H3605"\w* clase \w de|strong="H5414"\w* visiones y \w sueños|strong="H2472"\w*.   
\p
\v 18 \w Al|strong="H4428"\w* cabo \w de|strong="H6440"\w* los \w días|strong="H3117"\w* \w que|strong="H3117"\w* el \w rey|strong="H4428"\w* había señalado para traerlos, el \w jefe|strong="H8269"\w* \w de|strong="H6440"\w* los \w eunucos|strong="H5631"\w* los llevó \w ante|strong="H6440"\w* \w Nabucodonosor|strong="H5019"\w*.  
\v 19 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w habló|strong="H1696"\w* con \w ellos|strong="H3605"\w*, y \w entre|strong="H3808"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* encontró \w a|strong="H3068"\w* \w ninguno|strong="H3808"\w* como \w Daniel|strong="H1840"\w*, \w Ananías|strong="H2608"\w*, \w Misael|strong="H4332"\w* y \w Azarías|strong="H5838"\w*. \w Por|strong="H6440"\w* \w lo|strong="H3808"\w* tanto, pasaron \w a|strong="H3068"\w* servir \w ante|strong="H6440"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w*.  
\v 20 \w En|strong="H5921"\w* \w todo|strong="H3605"\w* \w asunto|strong="H1697"\w* \w de|strong="H5921"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H5921"\w* entendimiento \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w les|strong="H1992"\w* preguntó, \w los|strong="H1992"\w* encontró \w diez|strong="H6235"\w* \w veces|strong="H3027"\w* mejores \w que|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w magos|strong="H2748"\w* \w y|strong="H5921"\w* encantadores \w que|strong="H5921"\w* \w había|strong="H4672"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w su|strong="H1992"\w* \w reino|strong="H4438"\w*.   
\p
\v 21 \w Daniel|strong="H1840"\w* continuó allí \w hasta|strong="H5704"\w* el primer \w año|strong="H8141"\w* del \w rey|strong="H4428"\w* \w Ciro|strong="H3566"\w*.   
\c 2
\p
\v 1 \w En|strong="H5921"\w* \w el|strong="H5921"\w* \w segundo|strong="H8147"\w* \w año|strong="H8141"\w* \w del|strong="H5921"\w* \w reinado|strong="H4438"\w* \w de|strong="H5921"\w* \w Nabucodonosor|strong="H5019"\w*, \w este|strong="H1961"\w* \w tuvo|strong="H1961"\w* \w sueños|strong="H2472"\w*, \w y|strong="H5921"\w* su \w espíritu|strong="H7307"\w* \w se|strong="H1961"\w* turbó, \w y|strong="H5921"\w* \w se|strong="H1961"\w* \w le|strong="H5921"\w* \w fue|strong="H1961"\w* \w el|strong="H5921"\w* \w sueño|strong="H2472"\w*.  
\v 2 Entonces el \w rey|strong="H4428"\w* \w ordenó|strong="H5975"\w* que se llamase \w a|strong="H3068"\w* los \w magos|strong="H2748"\w*, \w a|strong="H3068"\w* los encantadores, \w a|strong="H3068"\w* los hechiceros y \w a|strong="H3068"\w* los \w caldeos|strong="H3778"\w* para que le explicasen \w al|strong="H4428"\w* \w rey|strong="H4428"\w* sus \w sueños|strong="H2472"\w*. Así que entraron y se presentaron \w ante|strong="H6440"\w* el \w rey|strong="H4428"\w*.  
\v 3 \w El|strong="H1992"\w* \w rey|strong="H4428"\w* \w les|strong="H1992"\w* dijo: «He tenido un \w sueño|strong="H2472"\w*, y mi \w espíritu|strong="H7307"\w* \w está|strong="H1992"\w* turbado \w por|strong="H4428"\w* conocer \w el|strong="H1992"\w* \w sueño|strong="H2472"\w*».   
\p
\v 4 Entonces los \w caldeos|strong="H3778"\w* \w hablaron|strong="H1696"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* en lengua aramea: «¡Oh \w rey|strong="H4428"\w*, \w vive|strong="H2418"\w* para siempre! Cuenta el \w sueño|strong="H2493"\w* \w a|strong="H3068"\w* tus \w siervos|strong="H5649"\w*, y nosotros te mostraremos la interpretación».   
\p
\v 5 El \w rey|strong="H4430"\w* \w respondió|strong="H6032"\w* \w a|strong="H3068"\w* los \w caldeos|strong="H3779"\w*: «El asunto se me ha ido \w de|strong="H4481"\w* las manos. \w Si|strong="H2006"\w* \w no|strong="H3809"\w* me dais \w a|strong="H3068"\w* conocer el \w sueño|strong="H2493"\w* \w y|strong="H3809"\w* su interpretación, seréis despedazados, \w y|strong="H3809"\w* vuestras casas serán convertidas \w en|strong="H4481"\w* un estercolero.  
\v 6 Pero \w si|strong="H2006"\w* me mostráis el \w sueño|strong="H2493"\w* y su interpretación, \w recibiréis|strong="H6902"\w* \w de|strong="H4481"\w* \w mí|strong="H6925"\w* regalos, recompensas y gran honor. \w Por|strong="H4481"\w* lo tanto, \w mostradme|strong="H2324"\w* el \w sueño|strong="H2493"\w* y su interpretación».   
\p
\v 7 \w Respondieron|strong="H6032"\w* por segunda vez y dijeron: «Que el \w rey|strong="H4430"\w* cuente el \w sueño|strong="H2493"\w* \w a|strong="H3068"\w* sus \w siervos|strong="H5649"\w* y nosotros mostraremos la interpretación».   
\p
\v 8 El \w rey|strong="H4430"\w* \w respondió|strong="H6032"\w*: «Sé con certeza \w que|strong="H1768"\w* tratáis \w de|strong="H4481"\w* ganar \w tiempo|strong="H5732"\w*, \w porque|strong="H1768"\w* \w veis|strong="H2370"\w* \w que|strong="H1768"\w* el asunto se me ha ido \w de|strong="H4481"\w* las manos.  
\v 9 Pero \w si|strong="H2006"\w* \w no|strong="H3809"\w* me dais \w a|strong="H3068"\w* conocer \w el|strong="H1932"\w* \w sueño|strong="H2493"\w*, \w no|strong="H3809"\w* hay más \w que|strong="H1768"\w* \w una|strong="H1932"\w* \w sentencia|strong="H1882"\w* para vosotros, \w pues|strong="H1768"\w* habéis preparado \w palabras|strong="H4406"\w* mentirosas \w y|strong="H3809"\w* corruptas para hablar ante \w mí|strong="H6925"\w*, \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* la situación cambie. \w Por|strong="H1768"\w* tanto, decidme \w el|strong="H1932"\w* \w sueño|strong="H2493"\w*, \w y|strong="H3809"\w* sabré \w que|strong="H1768"\w* podéis mostrarme su interpretación».   
\p
\v 10 Los \w caldeos|strong="H3779"\w* \w respondieron|strong="H6032"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w* \w y|strong="H3809"\w* dijeron: «\w No|strong="H3809"\w* hay hombre \w en|strong="H5922"\w* la tierra \w que|strong="H1768"\w* \w pueda|strong="H3202"\w* \w declarar|strong="H2324"\w* el asunto del \w rey|strong="H4430"\w*, \w porque|strong="H1768"\w* \w ningún|strong="H3606"\w* \w rey|strong="H4430"\w*, \w señor|strong="H7990"\w* \w o|strong="H3068"\w* gobernante ha pedido tal \w cosa|strong="H4406"\w* \w a|strong="H3068"\w* \w ningún|strong="H3606"\w* \w mago|strong="H2749"\w*, encantador \w o|strong="H3068"\w* \w caldeo|strong="H3779"\w*.  
\v 11 Es una \w cosa|strong="H4406"\w* difícil la \w que|strong="H1768"\w* requiere el \w rey|strong="H4430"\w*, \w y|strong="H3809"\w* \w no|strong="H3809"\w* hay otro \w que|strong="H1768"\w* pueda revelarla ante el \w rey|strong="H4430"\w*, excepto los dioses, \w cuya|strong="H1768"\w* morada \w no|strong="H3809"\w* es \w con|strong="H5974"\w* la \w carne|strong="H1321"\w*».   
\p
\v 12 \w A|strong="H3068"\w* causa de \w esto|strong="H1836"\w*, el \w rey|strong="H4430"\w* se \w enojó|strong="H7108"\w* y se enfureció en gran manera, y ordenó que \w todos|strong="H3606"\w* los \w sabios|strong="H2445"\w* de Babilonia fuesen destruidos.  
\v 13 Así que se publicó el decreto de que los \w sabios|strong="H2445"\w* debían ser asesinados, y buscaron \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* y \w a|strong="H3068"\w* sus compañeros para matarlos.   
\p
\v 14 Entonces \w Daniel|strong="H1841"\w* \w habló|strong="H8421"\w* con consejo y prudencia \w a|strong="H3068"\w* Arioc, \w capitán|strong="H7229"\w* \w de|strong="H1768"\w* la guardia del \w rey|strong="H4430"\w*, \w que|strong="H1768"\w* había salido para matar \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w* \w de|strong="H1768"\w* Babilonia.  
\v 15 \w Habló|strong="H6032"\w* y dijo \w a|strong="H3068"\w* Arioc, capitán \w del|strong="H4481"\w* \w rey|strong="H4430"\w*: «¿\w Por|strong="H4481"\w* \w qué|strong="H1768"\w* es tan apresurado este decreto \w del|strong="H4481"\w* \w rey|strong="H4430"\w*?» Entonces Arioc dio \w a|strong="H3068"\w* conocer el asunto \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*.  
\v 16 \w Daniel|strong="H1841"\w* \w entró|strong="H5954"\w* y pidió \w al|strong="H4481"\w* \w rey|strong="H4430"\w* \w que|strong="H1768"\w* le diese un plazo para mostrarle \w al|strong="H4481"\w* \w rey|strong="H4430"\w* la interpretación.   
\p
\v 17 Entonces \w Daniel|strong="H1841"\w* fue \w a|strong="H3068"\w* su \w casa|strong="H1005"\w* y dio \w a|strong="H3068"\w* conocer el asunto \w a|strong="H3068"\w* \w Ananías|strong="H2608"\w*, \w Misael|strong="H4333"\w* y Azarías, sus compañeros,  
\v 18 \w para|strong="H5922"\w* \w que|strong="H1768"\w* pidiesen misericordia \w al|strong="H5922"\w* Dios \w del|strong="H4481"\w* \w cielo|strong="H8065"\w* \w sobre|strong="H5922"\w* \w este|strong="H1836"\w* \w misterio|strong="H7328"\w*, \w a|strong="H3068"\w* fin \w de|strong="H4481"\w* \w que|strong="H1768"\w* \w Daniel|strong="H1841"\w* \w y|strong="H3809"\w* sus compañeros \w no|strong="H3809"\w* pereciesen \w con|strong="H5974"\w* el resto \w de|strong="H4481"\w* los \w sabios|strong="H2445"\w* \w de|strong="H4481"\w* Babilonia.  
\v 19 Entonces el \w misterio|strong="H7328"\w* le fue revelado \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* en una visión nocturna. \w Y|strong="H3068"\w* \w Daniel|strong="H1841"\w* \w bendijo|strong="H1289"\w* al Dios del \w cielo|strong="H8065"\w*.  
\v 20 \w Daniel|strong="H1841"\w* \w habló|strong="H6032"\w* y dijo:  
\q1 «\w Bendito|strong="H1289"\w* \w sea|strong="H1934"\w* \w el|strong="H1934"\w* \w nombre|strong="H8036"\w* \w de|strong="H4481"\w* Dios \w por|strong="H4481"\w* los siglos \w de|strong="H4481"\w* los siglos;  
\q2 \w porque|strong="H1768"\w* la \w sabiduría|strong="H2452"\w* y \w el|strong="H1934"\w* poder son suyos.   
\q1
\v 21 \w Él|strong="H1932"\w* cambia los \w tiempos|strong="H5732"\w* y las épocas;  
\q2 \w quita|strong="H5709"\w* \w reyes|strong="H4430"\w* y pone \w reyes|strong="H4430"\w*;  
\q1 \w da|strong="H3052"\w* \w sabiduría|strong="H2452"\w* \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w*,  
\q2 y conocimiento \w a|strong="H3068"\w* los entendidos.   
\q1
\v 22 \w Él|strong="H1932"\w* \w revela|strong="H1541"\w* las cosas profundas y ocultas;  
\q2 \w conoce|strong="H3046"\w* lo \w que|strong="H4101"\w* hay en las tinieblas,  
\q2 y la \w luz|strong="H5094"\w* \w mora|strong="H8271"\w* \w con|strong="H5974"\w* \w él|strong="H1932"\w*.   
\q1
\v 23 \w A|strong="H3068"\w* ti, oh Dios \w de|strong="H4481"\w* mis padres, te doy gracias y te \w alabo|strong="H7624"\w*,  
\q1 \w porque|strong="H1768"\w* me has dado \w sabiduría|strong="H2452"\w* y fuerza,  
\q2 y \w ahora|strong="H3705"\w* me has revelado lo \w que|strong="H1768"\w* te pedimos;  
\q2 \w pues|strong="H1768"\w* nos has dado \w a|strong="H3068"\w* conocer el asunto \w del|strong="H4481"\w* \w rey|strong="H4430"\w*».   
\p
\v 24 \w Por|strong="H5922"\w* lo tanto, \w Daniel|strong="H1841"\w* \w fue|strong="H5954"\w* \w a|strong="H3068"\w* ver \w a|strong="H3068"\w* Arioc, \w a|strong="H3068"\w* quien el \w rey|strong="H4430"\w* había designado \w para|strong="H5922"\w* destruir \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w* \w de|strong="H5922"\w* Babilonia. \w Fue|strong="H5954"\w* y le dijo lo siguiente: «No destruyas \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w* \w de|strong="H5922"\w* Babilonia. \w Llévame|strong="H5954"\w* ante el \w rey|strong="H4430"\w* y \w yo|strong="H1836"\w* le mostraré la interpretación».   
\p
\v 25 Entonces Arioc llevó \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* ante el \w rey|strong="H4430"\w* \w a|strong="H3068"\w* toda prisa, y le dijo \w así|strong="H3652"\w*: «He \w hallado|strong="H7912"\w* \w a|strong="H3068"\w* un hombre \w de|strong="H4481"\w* los cautivos \w de|strong="H4481"\w* \w Judá|strong="H3061"\w* \w que|strong="H1768"\w* dará \w a|strong="H3068"\w* conocer \w al|strong="H4481"\w* \w rey|strong="H4430"\w* la interpretación».   
\p
\v 26 El \w rey|strong="H4430"\w* \w habló|strong="H6032"\w* y dijo \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*, \w cuyo|strong="H1768"\w* \w nombre|strong="H8036"\w* era \w Beltsasar|strong="H1096"\w*: «¿Eres tú capaz \w de|strong="H1768"\w* darme \w a|strong="H3068"\w* conocer el \w sueño|strong="H2493"\w* \w que|strong="H1768"\w* he visto y su interpretación?»   
\p
\v 27 \w Daniel|strong="H1841"\w* \w respondió|strong="H6032"\w* \w delante|strong="H6925"\w* del \w rey|strong="H4430"\w* \w y|strong="H3809"\w* dijo: “El \w misterio|strong="H7328"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w demanda|strong="H7593"\w*, \w ni|strong="H3809"\w* \w sabios|strong="H2445"\w*, \w ni|strong="H3809"\w* encantadores, \w ni|strong="H3809"\w* \w magos|strong="H2749"\w*, \w ni|strong="H3809"\w* \w adivinos|strong="H1505"\w* lo pueden \w revelar|strong="H3202"\w* al \w rey|strong="H4430"\w*;  
\v 28 pero hay un Dios \w en|strong="H5922"\w* los cielos \w que|strong="H1768"\w* \w revela|strong="H1541"\w* los misterios, y \w él|strong="H1934"\w* ha dado \w a|strong="H3068"\w* conocer \w al|strong="H5922"\w* \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* lo \w que|strong="H1768"\w* ha \w de|strong="H5922"\w* acontecer \w en|strong="H5922"\w* los últimos \w días|strong="H3118"\w*. Tu \w sueño|strong="H2493"\w* y las visiones \w de|strong="H5922"\w* tu cabeza \w en|strong="H5922"\w* tu cama son estos:   
\p
\v 29 “Estando tú, oh \w rey|strong="H4430"\w*, \w en|strong="H5922"\w* tu cama, te vinieron pensamientos \w sobre|strong="H5922"\w* lo \w que|strong="H1768"\w* había \w de|strong="H5922"\w* ser \w en|strong="H5922"\w* lo porvenir; y \w el|strong="H1934"\w* \w que|strong="H1768"\w* \w revela|strong="H1541"\w* los misterios te ha mostrado lo \w que|strong="H1768"\w* ha \w de|strong="H5922"\w* ser.  
\v 30 \w Y|strong="H3068"\w* \w en|strong="H5922"\w* cuanto \w a|strong="H3068"\w* mí, \w este|strong="H1836"\w* \w misterio|strong="H7328"\w* \w no|strong="H3809"\w* me ha sido revelado \w por|strong="H4481"\w* ninguna \w sabiduría|strong="H2452"\w* \w que|strong="H1768"\w* \w yo|strong="H1836"\w* tenga \w más|strong="H3861"\w* \w que|strong="H1768"\w* cualquier \w otro|strong="H3606"\w* \w viviente|strong="H2417"\w*, \w sino|strong="H3861"\w* \w para|strong="H5922"\w* \w que|strong="H1768"\w* se \w dé|strong="H4481"\w* \w a|strong="H3068"\w* conocer la interpretación \w al|strong="H5922"\w* \w rey|strong="H4430"\w*, \w y|strong="H3809"\w* \w para|strong="H5922"\w* \w que|strong="H1768"\w* entiendas los pensamientos \w de|strong="H4481"\w* tu \w corazón|strong="H3825"\w*.   
\p
\v 31 “Tú, oh \w rey|strong="H4430"\w*, mirabas, y he aquí,\f + \fr 2:31 \ft «He aquí», de «הִנֵּה», significa mirar, fijarse, observar, ver o contemplar. Se utiliza a menudo como interjección.\f* una gran \w estatua|strong="H6755"\w*. Esta \w estatua|strong="H6755"\w*, que era muy grande y cuyo brillo era extraordinario, estaba en pie \w delante|strong="H6903"\w* de ti; y \w su|strong="H1934"\w* aspecto era terrible.  
\v 32 La cabeza \w de|strong="H1768"\w* esta \w estatua|strong="H6755"\w* \w era|strong="H1932"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* fino, su pecho y sus brazos \w de|strong="H1768"\w* \w plata|strong="H3702"\w*, su vientre y sus muslos \w de|strong="H1768"\w* bronce,  
\v 33 sus piernas \w de|strong="H4481"\w* \w hierro|strong="H6523"\w*, sus \w pies|strong="H7271"\w* \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* \w hierro|strong="H6523"\w* y \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* barro cocido.  
\v 34 Estabas mirando, \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* una piedra fue cortada \w sin|strong="H3809"\w* intervención \w de|strong="H5922"\w* manos, la cual golpeó \w a|strong="H3068"\w* la \w estatua|strong="H6755"\w* \w en|strong="H5922"\w* \w sus|strong="H1934"\w* \w pies|strong="H7271"\w* \w de|strong="H5922"\w* \w hierro|strong="H6523"\w* \w y|strong="H3809"\w* \w de|strong="H5922"\w* barro cocido, \w y|strong="H3809"\w* \w los|strong="H1994"\w* \w desmenuzó|strong="H1855"\w*.  
\v 35 Entonces \w fueron|strong="H1934"\w* desmenuzados también \w el|strong="H1934"\w* \w hierro|strong="H6523"\w*, \w el|strong="H1934"\w* barro cocido, \w el|strong="H1934"\w* bronce, la \w plata|strong="H3702"\w* \w y|strong="H3809"\w* \w el|strong="H1934"\w* \w oro|strong="H1722"\w*, \w y|strong="H3809"\w* se volvieron como \w el|strong="H1934"\w* tamo \w de|strong="H4481"\w* las eras \w del|strong="H4481"\w* verano. \w El|strong="H1934"\w* viento se \w los|strong="H1994"\w* llevó, \w de|strong="H4481"\w* modo \w que|strong="H1768"\w* \w no|strong="H3809"\w* se halló lugar para \w ellos|strong="H4481"\w*. \w Y|strong="H3068"\w* la piedra \w que|strong="H1768"\w* golpeó \w a|strong="H3068"\w* la \w estatua|strong="H6755"\w* se hizo un gran \w monte|strong="H2906"\w* \w que|strong="H1768"\w* llenó \w toda|strong="H3606"\w* la tierra.   
\p
\v 36 “\w Este|strong="H1836"\w* es el \w sueño|strong="H2493"\w*; también su interpretación diremos en presencia del \w rey|strong="H4430"\w*.  
\v 37 Tú, oh \w rey|strong="H4430"\w*, eres \w rey|strong="H4430"\w* \w de|strong="H1768"\w* \w reyes|strong="H4430"\w*, \w a|strong="H3068"\w* quien el Dios del \w cielo|strong="H8065"\w* ha dado el \w reino|strong="H4437"\w*, el poder, la fuerza y la majestad.  
\v 38 Dondequiera \w que|strong="H1768"\w* \w habitan|strong="H1753"\w* los \w hijos|strong="H1123"\w* \w de|strong="H1768"\w* los hombres, las \w bestias|strong="H2423"\w* del \w campo|strong="H1251"\w* y las aves del \w cielo|strong="H8065"\w*, \w él|strong="H1932"\w* los ha entregado en tu \w mano|strong="H3028"\w*, y te ha dado \w el|strong="H1932"\w* dominio sobre \w todos|strong="H3606"\w* ellos. Tú eres aquella cabeza \w de|strong="H1768"\w* \w oro|strong="H1722"\w*.   
\p
\v 39 “\w Después|strong="H4481"\w* \w de|strong="H4481"\w* ti, se levantará \w otro|strong="H3606"\w* \w reino|strong="H4437"\w* inferior \w al|strong="H4481"\w* tuyo; y \w luego|strong="H4481"\w* un \w tercer|strong="H8523"\w* \w reino|strong="H4437"\w* \w de|strong="H4481"\w* bronce, el cual dominará sobre \w toda|strong="H3606"\w* la tierra.  
\v 40 \w Y|strong="H3068"\w* \w el|strong="H1934"\w* \w cuarto|strong="H7244"\w* \w reino|strong="H4437"\w* será \w fuerte|strong="H8624"\w* \w como|strong="H6903"\w* \w el|strong="H1934"\w* \w hierro|strong="H6523"\w*; y \w como|strong="H6903"\w* \w el|strong="H1934"\w* \w hierro|strong="H6523"\w* \w desmenuza|strong="H1855"\w* y rompe \w todas|strong="H3606"\w* las cosas, así \w él|strong="H1934"\w* lo \w desmenuzará|strong="H1855"\w* y lo quebrantará \w todo|strong="H3606"\w*.  
\v 41 \w Y|strong="H3068"\w* lo \w que|strong="H1768"\w* \w viste|strong="H2370"\w* \w de|strong="H4481"\w* los \w pies|strong="H7271"\w* y los dedos, \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* barro cocido \w de|strong="H4481"\w* alfarero y \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* \w hierro|strong="H6523"\w*, será un \w reino|strong="H4437"\w* dividido; pero habrá \w en|strong="H4481"\w* \w él|strong="H1934"\w* algo \w de|strong="H4481"\w* la fuerza \w del|strong="H4481"\w* \w hierro|strong="H6523"\w*, así \w como|strong="H6903"\w* \w viste|strong="H2370"\w* \w el|strong="H1934"\w* \w hierro|strong="H6523"\w* \w mezclado|strong="H6151"\w* con \w el|strong="H1934"\w* barro cenagoso.  
\v 42 \w Y|strong="H3068"\w* \w por|strong="H4481"\w* ser los dedos \w de|strong="H4481"\w* los \w pies|strong="H7271"\w* \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* \w hierro|strong="H6523"\w* y \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* barro cocido, \w el|strong="H1934"\w* \w reino|strong="H4437"\w* será \w en|strong="H4481"\w* parte \w fuerte|strong="H8624"\w* y \w en|strong="H4481"\w* parte frágil.  
\v 43 \w Así|strong="H1836"\w* como \w viste|strong="H2370"\w* \w el|strong="H1934"\w* \w hierro|strong="H6523"\w* \w mezclado|strong="H6151"\w* \w con|strong="H5974"\w* barro cocido, se mezclarán \w por|strong="H1768"\w* medio \w de|strong="H1768"\w* alianzas humanas; pero \w no|strong="H3809"\w* se unirán \w el|strong="H1934"\w* uno \w con|strong="H5974"\w* \w el|strong="H1934"\w* otro, como \w el|strong="H1934"\w* \w hierro|strong="H6523"\w* \w no|strong="H3809"\w* se mezcla \w con|strong="H5974"\w* \w el|strong="H1934"\w* barro.   
\p
\v 44 «En los \w días|strong="H3118"\w* \w de|strong="H1768"\w* estos \w reyes|strong="H4430"\w*, \w el|strong="H1932"\w* Dios del \w cielo|strong="H8065"\w* levantará un \w reino|strong="H4437"\w* \w que|strong="H1768"\w* \w no|strong="H3809"\w* será jamás destruido, \w ni|strong="H3809"\w* será \w el|strong="H1932"\w* \w reino|strong="H4437"\w* dejado \w a|strong="H3068"\w* \w otro|strong="H3606"\w* \w pueblo|strong="H5972"\w*; \w desmenuzará|strong="H1855"\w* \w y|strong="H3809"\w* consumirá \w a|strong="H3068"\w* \w todos|strong="H3606"\w* estos \w reinos|strong="H4437"\w*, pero \w él|strong="H1932"\w* \w permanecerá|strong="H6966"\w* para siempre.  
\v 45 \w De|strong="H1768"\w* la manera \w que|strong="H1768"\w* \w viste|strong="H2370"\w* \w que|strong="H1768"\w* del \w monte|strong="H2906"\w* fue cortada una piedra \w sin|strong="H3809"\w* intervención \w de|strong="H1768"\w* manos, la cual \w desmenuzó|strong="H1855"\w* \w el|strong="H1934"\w* \w hierro|strong="H6523"\w*, \w el|strong="H1934"\w* bronce, \w el|strong="H1934"\w* barro, la \w plata|strong="H3702"\w* \w y|strong="H3809"\w* \w el|strong="H1934"\w* \w oro|strong="H1722"\w*, \w el|strong="H1934"\w* gran Dios ha mostrado al \w rey|strong="H4430"\w* lo \w que|strong="H1768"\w* ha \w de|strong="H1768"\w* acontecer en lo porvenir. \w El|strong="H1934"\w* \w sueño|strong="H2493"\w* es verdadero, \w y|strong="H3809"\w* fiel \w su|strong="H1934"\w* interpretación».   
\p
\v 46 Entonces el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* se postró \w sobre|strong="H5922"\w* su rostro, se humilló ante \w Daniel|strong="H1841"\w*, y mandó \w que|strong="H5922"\w* le ofreciesen \w presentes|strong="H4504"\w* \w e|strong="H3068"\w* incienso.  
\v 47 \w El|strong="H1932"\w* \w rey|strong="H4430"\w* \w habló|strong="H6032"\w* \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* y le dijo: «\w Ciertamente|strong="H7187"\w* \w vuestro|strong="H1932"\w* Dios es Dios \w de|strong="H4481"\w* dioses, y \w Señor|strong="H4756"\w* \w de|strong="H4481"\w* los \w reyes|strong="H4430"\w*, y \w el|strong="H1932"\w* \w que|strong="H1768"\w* \w revela|strong="H1541"\w* los misterios, \w pues|strong="H1768"\w* pudiste \w revelar|strong="H3202"\w* \w este|strong="H1836"\w* \w misterio|strong="H7328"\w*».   
\p
\v 48 Entonces el \w rey|strong="H4430"\w* \w engrandeció|strong="H7236"\w* \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*, le \w dio|strong="H3052"\w* muchos y \w grandes|strong="H7260"\w* regalos, lo hizo gobernador \w de|strong="H5922"\w* \w toda|strong="H3606"\w* la provincia \w de|strong="H5922"\w* Babilonia y jefe supremo \w de|strong="H5922"\w* \w todos|strong="H3606"\w* los \w sabios|strong="H2445"\w* \w de|strong="H5922"\w* Babilonia.  
\v 49 \w Y|strong="H3068"\w* \w Daniel|strong="H1841"\w* \w solicitó|strong="H1156"\w* \w del|strong="H4481"\w* \w rey|strong="H4430"\w*, y él puso \w sobre|strong="H5922"\w* los negocios \w de|strong="H4481"\w* la provincia \w de|strong="H4481"\w* Babilonia \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego; pero \w Daniel|strong="H1841"\w* permaneció \w en|strong="H5922"\w* la corte \w del|strong="H4481"\w* \w rey|strong="H4430"\w*.   
\c 3
\p
\v 1 El \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* \w hizo|strong="H5648"\w* \w una|strong="H5648"\w* \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w*, \w cuya|strong="H1768"\w* \w altura|strong="H7314"\w* era \w de|strong="H1768"\w* sesenta codos\f + \fr 3:1 \ft Un codo es la longitud desde la punta del dedo corazón hasta el codo del brazo de un hombre, es decir, unas 18 pulgadas o 46 centímetros.\f* y su anchura \w de|strong="H1768"\w* seis codos. La levantó en la llanura \w de|strong="H1768"\w* Dura, en la provincia \w de|strong="H1768"\w* Babilonia.  
\v 2 Entonces el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* mandó reunir \w a|strong="H3068"\w* los sátrapas, \w a|strong="H3068"\w* los \w magistrados|strong="H5460"\w* y \w a|strong="H3068"\w* los capitanes, \w a|strong="H3068"\w* los oidores, \w a|strong="H3068"\w* los tesoreros, \w a|strong="H3068"\w* los consejeros, \w a|strong="H3068"\w* los jueces y \w a|strong="H3068"\w* \w todos|strong="H3606"\w* los gobernantes \w de|strong="H1768"\w* las provincias, para \w que|strong="H1768"\w* viniesen \w a|strong="H3068"\w* la dedicación \w de|strong="H1768"\w* la \w estatua|strong="H6755"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* había erigido.  
\v 3 Se reunieron, \w pues|strong="H1768"\w*, los sátrapas, los \w magistrados|strong="H5460"\w* y los capitanes, los oidores, los tesoreros, los consejeros, los jueces y \w todos|strong="H3606"\w* los gobernantes \w de|strong="H1768"\w* las provincias para asistir \w a|strong="H3068"\w* la dedicación \w de|strong="H1768"\w* la \w estatua|strong="H6755"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* había erigido; y se pusieron en pie ante la \w estatua|strong="H6755"\w* \w que|strong="H1768"\w* \w Nabucodonosor|strong="H5020"\w* había levantado.   
\p
\v 4 Entonces el heraldo proclamó en voz alta: «\w A|strong="H3068"\w* vosotros se os ordena, oh pueblos, naciones y lenguas,  
\v 5 \w que|strong="H1768"\w* al oír el sonido del \w cuerno|strong="H7162"\w*, \w de|strong="H1768"\w* la flauta, \w de|strong="H1768"\w* la cítara, \w de|strong="H1768"\w* la lira, del arpa, \w de|strong="H1768"\w* la zampoña y \w de|strong="H1768"\w* \w toda|strong="H3606"\w* clase \w de|strong="H1768"\w* música, os postréis y adoréis la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* ha levantado.  
\v 6 \w Y|strong="H3068"\w* cualquiera \w que|strong="H1768"\w* \w no|strong="H3809"\w* se postre \w y|strong="H3809"\w* adore, será arrojado en la misma \w hora|strong="H8160"\w* en \w medio|strong="H1459"\w* \w de|strong="H1768"\w* un horno \w de|strong="H1768"\w* \w fuego|strong="H5135"\w* ardiente».   
\p
\v 7 \w Por|strong="H1768"\w* eso, en aquel momento, \w cuando|strong="H1768"\w* \w todos|strong="H3606"\w* los pueblos oyeron el sonido del \w cuerno|strong="H7162"\w*, \w de|strong="H1768"\w* la flauta, \w de|strong="H1768"\w* la cítara, \w de|strong="H1768"\w* la lira, del arpa, \w de|strong="H1768"\w* la zampoña y \w de|strong="H1768"\w* \w toda|strong="H3606"\w* clase \w de|strong="H1768"\w* música, \w todos|strong="H3606"\w* los pueblos, las naciones y las lenguas se postraron y adoraron la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* había levantado.   
\p
\v 8 \w Por|strong="H1768"\w* lo cual, en ese momento se acercaron ciertos \w caldeos|strong="H3779"\w* y presentaron una acusación contra los \w judíos|strong="H3062"\w*.  
\v 9 Hablaron y dijeron al \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w*: «¡Oh \w rey|strong="H4430"\w*, \w vive|strong="H2418"\w* para siempre!  
\v 10 Tú, oh \w rey|strong="H4430"\w*, has decretado \w que|strong="H1768"\w* \w todo|strong="H3606"\w* hombre \w que|strong="H1768"\w* oiga el sonido del \w cuerno|strong="H7162"\w*, \w de|strong="H1768"\w* la flauta, \w de|strong="H1768"\w* la cítara, \w de|strong="H1768"\w* la lira, del arpa, \w de|strong="H1768"\w* la zampoña y \w de|strong="H1768"\w* \w toda|strong="H3606"\w* clase \w de|strong="H1768"\w* música, se postrará y adorará la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w*;  
\v 11 \w y|strong="H3809"\w* el \w que|strong="H1768"\w* \w no|strong="H3809"\w* se postre \w y|strong="H3809"\w* adore, será arrojado en \w medio|strong="H1459"\w* \w de|strong="H1768"\w* un horno \w de|strong="H1768"\w* \w fuego|strong="H5135"\w* ardiente.  
\v 12 Hay unos \w varones|strong="H1400"\w* \w judíos|strong="H3062"\w*, \w a|strong="H3068"\w* quienes has puesto \w sobre|strong="H5922"\w* los negocios \w de|strong="H5922"\w* la provincia \w de|strong="H5922"\w* Babilonia: Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego. Estos \w hombres|strong="H1400"\w*, oh \w rey|strong="H4430"\w*, \w no|strong="H3809"\w* te han mostrado respeto. \w No|strong="H3809"\w* sirven \w a|strong="H3068"\w* tus dioses \w ni|strong="H3809"\w* \w adoran|strong="H6399"\w* la \w estatua|strong="H6755"\w* \w de|strong="H5922"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* has levantado».   
\p
\v 13 Entonces \w Nabucodonosor|strong="H5020"\w*, con ira y furor, mandó traer \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego. Al instante, estos \w varones|strong="H1400"\w* fueron llevados ante el \w rey|strong="H4430"\w*.  
\v 14 \w Nabucodonosor|strong="H5020"\w* les \w habló|strong="H6032"\w* \w y|strong="H3809"\w* dijo: «¿Es cierto, Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego, \w que|strong="H1768"\w* \w no|strong="H3809"\w* servís \w a|strong="H3068"\w* mis dioses \w ni|strong="H3809"\w* \w adoráis|strong="H5457"\w* la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* he levantado?  
\v 15 \w Ahora|strong="H3705"\w* bien, \w si|strong="H2006"\w* \w estáis|strong="H2006"\w* dispuestos, para \w que|strong="H1768"\w* \w al|strong="H4481"\w* oír \w el|strong="H1932"\w* sonido \w del|strong="H4481"\w* \w cuerno|strong="H7162"\w*, \w de|strong="H4481"\w* la flauta, \w de|strong="H4481"\w* la cítara, \w de|strong="H4481"\w* la lira, \w del|strong="H4481"\w* arpa, \w de|strong="H4481"\w* la zampoña \w y|strong="H3809"\w* \w de|strong="H4481"\w* \w toda|strong="H3606"\w* clase \w de|strong="H4481"\w* música, os postréis \w y|strong="H3809"\w* adoréis la \w estatua|strong="H6755"\w* \w que|strong="H1768"\w* he hecho, bien \w está|strong="H2006"\w*; pero \w si|strong="H2006"\w* \w no|strong="H3809"\w* la \w adoráis|strong="H5457"\w*, seréis arrojados \w en|strong="H4481"\w* la misma \w hora|strong="H8160"\w* \w en|strong="H4481"\w* \w medio|strong="H1459"\w* \w de|strong="H4481"\w* un horno \w de|strong="H4481"\w* \w fuego|strong="H5135"\w* ardiente. ¿\w Y|strong="H3068"\w* \w qué|strong="H1768"\w* dios será \w aquel|strong="H1932"\w* \w que|strong="H1768"\w* os \w libre|strong="H7804"\w* \w de|strong="H4481"\w* mis manos?»   
\p
\v 16 Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego \w respondieron|strong="H6032"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w*: «Oh \w Nabucodonosor|strong="H5020"\w*, \w no|strong="H3809"\w* tenemos necesidad \w de|strong="H5922"\w* responderte \w sobre|strong="H5922"\w* \w este|strong="H1836"\w* asunto.  
\v 17 \w Si|strong="H2006"\w* es así, nuestro Dios \w a|strong="H3068"\w* quien servimos \w puede|strong="H3202"\w* librarnos \w del|strong="H4481"\w* horno \w de|strong="H4481"\w* \w fuego|strong="H5135"\w* ardiente; y \w de|strong="H4481"\w* tu \w mano|strong="H3028"\w*, oh \w rey|strong="H4430"\w*, nos librará.  
\v 18 \w Y|strong="H3068"\w* \w si|strong="H2006"\w* \w no|strong="H3809"\w*, has \w de|strong="H1768"\w* \w saber|strong="H3046"\w*, oh \w rey|strong="H4430"\w*, \w que|strong="H1768"\w* \w no|strong="H3809"\w* serviremos \w a|strong="H3068"\w* tus dioses \w ni|strong="H3809"\w* \w adoraremos|strong="H5457"\w* la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* has levantado».   
\p
\v 19 Entonces \w Nabucodonosor|strong="H5020"\w* se llenó \w de|strong="H5922"\w* ira, y se demudó el aspecto \w de|strong="H5922"\w* su rostro \w contra|strong="H5922"\w* Sadrac, Mesac y Abed-nego. \w Habló|strong="H6032"\w* y ordenó \w que|strong="H1768"\w* calentasen el horno siete \w veces|strong="H2298"\w* más \w de|strong="H5922"\w* lo acostumbrado.  
\v 20 \w Y|strong="H3068"\w* mandó \w a|strong="H3068"\w* \w algunos|strong="H1400"\w* \w hombres|strong="H1400"\w* \w muy|strong="H2429"\w* \w vigorosos|strong="H1401"\w* \w que|strong="H1768"\w* tenía en su ejército, \w que|strong="H1768"\w* \w atasen|strong="H3729"\w* \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego, para arrojarlos al horno \w de|strong="H1768"\w* \w fuego|strong="H5135"\w* ardiente.  
\v 21 Entonces estos \w varones|strong="H1400"\w* fueron \w atados|strong="H3729"\w* con sus calzas, sus túnicas, sus mantos y sus otras ropas, y fueron arrojados en \w medio|strong="H1459"\w* del horno de \w fuego|strong="H5135"\w* ardiente.  
\v 22 \w Y|strong="H3068"\w* \w como|strong="H6903"\w* la orden \w del|strong="H4481"\w* \w rey|strong="H4430"\w* era apremiante y el horno se había calentado \w en|strong="H4481"\w* gran manera, la \w llama|strong="H7631"\w* \w del|strong="H4481"\w* \w fuego|strong="H5135"\w* \w mató|strong="H6992"\w* \w a|strong="H3068"\w* aquellos \w que|strong="H1768"\w* habían alzado \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego.  
\v 23 \w Y|strong="H3068"\w* estos \w tres|strong="H8532"\w* \w varones|strong="H1400"\w*, Sadrac, Mesac y Abed-nego, \w cayeron|strong="H5308"\w* \w atados|strong="H3729"\w* \w dentro|strong="H1459"\w* del horno de \w fuego|strong="H5135"\w* ardiente.   
\p
\v 24 Entonces el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* se asombró \w y|strong="H3809"\w* se levantó apresuradamente. \w Habló|strong="H6032"\w* \w y|strong="H3809"\w* dijo \w a|strong="H3068"\w* sus consejeros: «¿\w No|strong="H3809"\w* arrojamos \w a|strong="H3068"\w* \w tres|strong="H8532"\w* \w hombres|strong="H1400"\w* \w atados|strong="H3729"\w* en \w medio|strong="H1459"\w* del \w fuego|strong="H5135"\w*?».  
\p Ellos \w respondieron|strong="H6032"\w* al \w rey|strong="H4430"\w*: «Es cierto, oh \w rey|strong="H4430"\w*».   
\p
\v 25 Él \w respondió|strong="H6032"\w* \w y|strong="H3809"\w* dijo: «He aquí, yo veo \w a|strong="H3068"\w* cuatro \w hombres|strong="H1400"\w* \w sueltos|strong="H8271"\w*, \w que|strong="H1768"\w* se pasean en \w medio|strong="H1459"\w* del \w fuego|strong="H5135"\w*, \w y|strong="H3809"\w* \w no|strong="H3809"\w* sufren \w ningún|strong="H3809"\w* daño; \w y|strong="H3809"\w* el aspecto del \w cuarto|strong="H7244"\w* es \w semejante|strong="H1821"\w* \w a|strong="H3068"\w* un \w hijo|strong="H1247"\w* \w de|strong="H1768"\w* los dioses\f + \fr 3:25 \ft O, el Hijo de Dios.\f*».   
\p
\v 26 Entonces \w Nabucodonosor|strong="H5020"\w* se acercó \w a|strong="H3068"\w* la puerta \w del|strong="H4481"\w* horno \w de|strong="H4481"\w* \w fuego|strong="H5135"\w* ardiente, y llamó diciendo: «¡Sadrac, Mesac y Abed-nego, \w siervos|strong="H5649"\w* \w del|strong="H4481"\w* Dios Altísimo, \w salid|strong="H5312"\w* y venid!».  
\p Entonces Sadrac, Mesac y Abed-nego \w salieron|strong="H5312"\w* \w de|strong="H4481"\w* \w en|strong="H4481"\w* \w medio|strong="H1459"\w* \w del|strong="H4481"\w* \w fuego|strong="H5135"\w*.  
\v 27 \w Y|strong="H3068"\w* se reunieron los sátrapas, los \w magistrados|strong="H5460"\w*, los capitanes \w y|strong="H3809"\w* los consejeros del \w rey|strong="H4430"\w*, para mirar \w a|strong="H3068"\w* estos \w hombres|strong="H1400"\w*, cómo el \w fuego|strong="H5135"\w* \w no|strong="H3809"\w* había tenido poder alguno sobre sus cuerpos, \w ni|strong="H3809"\w* el \w cabello|strong="H8177"\w* \w de|strong="H1768"\w* sus \w cabezas|strong="H7217"\w* se había chamuscado, \w ni|strong="H3809"\w* sus calzas se habían alterado, \w ni|strong="H3809"\w* el \w olor|strong="H7382"\w* del \w fuego|strong="H5135"\w* había quedado en ellos.   
\p
\v 28 \w Nabucodonosor|strong="H5020"\w* \w habló|strong="H6032"\w* \w y|strong="H3809"\w* dijo: «\w Bendito|strong="H1289"\w* sea el Dios \w de|strong="H5922"\w* Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego, \w que|strong="H1768"\w* \w envió|strong="H7972"\w* \w a|strong="H3068"\w* su ángel \w y|strong="H3809"\w* libró \w a|strong="H3068"\w* sus \w siervos|strong="H5649"\w* \w que|strong="H1768"\w* confiaron \w en|strong="H5922"\w* él, los cuales desobedecieron la palabra del \w rey|strong="H4430"\w* \w y|strong="H3809"\w* \w entregaron|strong="H3052"\w* sus cuerpos \w antes|strong="H3809"\w* \w que|strong="H1768"\w* servir \w y|strong="H3809"\w* adorar \w a|strong="H3068"\w* \w otro|strong="H3606"\w* dios \w que|strong="H1768"\w* \w no|strong="H3809"\w* fuese su Dios.  
\v 29 \w Por|strong="H4481"\w* lo tanto, decreto \w que|strong="H1768"\w* \w todo|strong="H3606"\w* \w pueblo|strong="H5972"\w*, nación \w o|strong="H3068"\w* lengua \w que|strong="H1768"\w* diga \w blasfemia|strong="H1768"\w* \w contra|strong="H5922"\w* el Dios \w de|strong="H4481"\w* Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego, sea descuartizado, \w y|strong="H3809"\w* su \w casa|strong="H1005"\w* convertida \w en|strong="H5922"\w* un estercolero; \w por|strong="H4481"\w* cuanto \w no|strong="H3809"\w* hay dios \w que|strong="H1768"\w* \w pueda|strong="H3202"\w* \w librar|strong="H5338"\w* \w como|strong="H6903"\w* \w este|strong="H1836"\w*».   
\p
\v 30 Entonces el \w rey|strong="H4430"\w* \w engrandeció|strong="H6744"\w* \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego en la provincia de Babilonia.   
\c 4
\mi
\v 1 \w El|strong="H1934"\w* rey \w Nabucodonosor|strong="H5020"\w*,  
\mi \w a|strong="H3068"\w* todos los pueblos, naciones y lenguas que habitan en toda la tierra:  
\mi Que la paz se os multiplique.   
\mi
\v 2 Me ha parecido bien mostrar las señales y los prodigios \w que|strong="H5922"\w* el Dios Altísimo ha hecho conmigo.   
\q1
\v 3 ¡\w Qué|strong="H1768"\w* grandes son sus señales!  
\q2 ¡\w Qué|strong="H1768"\w* poderosas son sus maravillas!  
\q1 Su reino es un reino sempiterno,  
\q2 y su dominio es \w de|strong="H4481"\w* generación \w en|strong="H4481"\w* generación.   
\mi
\v 4 Yo, Nabucodonosor, estaba tranquilo en \w mi|strong="H6925"\w* casa \w y|strong="H3809"\w* floreciente en \w mi|strong="H6925"\w* palacio.  
\v 5 Tuve un \w sueño|strong="H2493"\w* \w que|strong="H1768"\w* me espantó, y los pensamientos \w en|strong="H5705"\w* \w mi|strong="H6925"\w* cama y las visiones \w de|strong="H1768"\w* \w mi|strong="H6925"\w* cabeza me turbaron.  
\v 6 \w Por|strong="H1768"\w* lo tanto, decreté \w que|strong="H1768"\w* trajesen ante mí \w a|strong="H3068"\w* \w todos|strong="H3606"\w* los sabios \w de|strong="H1768"\w* Babilonia, para \w que|strong="H1768"\w* me diesen \w a|strong="H3068"\w* conocer la interpretación del \w sueño|strong="H2493"\w*.  
\v 7 Entonces entraron los magos, los encantadores, los caldeos y los adivinos; y les conté \w el|strong="H1934"\w* sueño, pero no me dieron \w a|strong="H3068"\w* conocer \w su|strong="H1934"\w* interpretación.  
\v 8 Pero al fin se presentó ante mí Daniel, cuyo nombre es Beltsasar, según el nombre de mi dios, y en quien mora el espíritu de los dioses santos. Conté el sueño delante de él, diciendo:   
\mi
\v 9 “Beltsasar, jefe \w de|strong="H4481"\w* los magos, ya \w que|strong="H4481"\w* sé \w que|strong="H4481"\w* el espíritu \w de|strong="H4481"\w* los dioses santos está \w en|strong="H4481"\w* ti y \w que|strong="H4481"\w* \w ningún|strong="H3606"\w* misterio te es oculto, declárame las visiones \w de|strong="H4481"\w* mi sueño \w que|strong="H4481"\w* he visto y su interpretación.  
\v 10 Estas \w fueron|strong="H1934"\w* las visiones \w de|strong="H4481"\w* mi cabeza \w en|strong="H5922"\w* mi cama: \w Miraba|strong="H1934"\w*, y he aquí un árbol \w en|strong="H5922"\w* medio \w de|strong="H4481"\w* la tierra, \w cuya|strong="H1934"\w* altura era muy grande.  
\v 11 El árbol creció y se hizo fuerte. Su copa llegaba hasta el cielo, y se le veía desde los confines \w de|strong="H4481"\w* toda la tierra.  
\v 12 Su follaje era hermoso y su fruto abundante, y en él había alimento para todos. Las \w bestias|strong="H2423"\w* del \w campo|strong="H1251"\w* se cobijaban bajo su sombra, y las aves del \w cielo|strong="H8065"\w* hacían morada en sus ramas, y toda carne se alimentaba \w de|strong="H1768"\w* él.   
\mi
\v 13 “Miraba \w en|strong="H5922"\w* las visiones \w de|strong="H4481"\w* mi cabeza \w en|strong="H5922"\w* mi cama, y he aquí \w que|strong="H4481"\w* un vigilante y santo descendía \w del|strong="H4481"\w* cielo.  
\v 14 Clamó \w a|strong="H3068"\w* gran voz y dijo así: ‘¡Derribad el árbol y cortad sus ramas! Sacudid sus hojas y esparcid sus frutos. \w Que|strong="H1768"\w* huyan las bestias \w de|strong="H5922"\w* debajo \w de|strong="H5922"\w* él, y las aves \w de|strong="H5922"\w* sus ramas.  
\v 15 \w Sin|strong="H3809"\w* embargo, dejad la cepa \w de|strong="H1768"\w* sus raíces en la tierra, atada con una atadura \w de|strong="H1768"\w* hierro \w y|strong="H3809"\w* \w de|strong="H1768"\w* bronce, entre la hierba tierna del campo; \w y|strong="H3809"\w* \w que|strong="H1768"\w* se moje con el rocío del cielo. \w Que|strong="H1768"\w* su parte sea con las bestias en la hierba \w de|strong="H1768"\w* la tierra.  
\v 16 \w Que|strong="H1768"\w* su corazón deje \w de|strong="H1768"\w* ser humano, y se le \w dé|strong="H1768"\w* un corazón \w de|strong="H1768"\w* bestia. \w Y|strong="H3068"\w* \w que|strong="H1768"\w* pasen sobre él siete tiempos.   
\mi
\v 17 “‘La sentencia es \w por|strong="H1768"\w* decreto \w de|strong="H1768"\w* los vigilantes, y la orden \w por|strong="H1768"\w* palabra \w de|strong="H1768"\w* los santos, con el fin \w de|strong="H1768"\w* \w que|strong="H1768"\w* los vivientes conozcan \w que|strong="H1768"\w* el Altísimo gobierna en el reino \w de|strong="H1768"\w* los hombres, y \w que|strong="H1768"\w* lo da \w a|strong="H3068"\w* quien él quiere, y pone sobre él al más humilde \w de|strong="H1768"\w* los hombres’.   
\mi
\v 18 «Este es el sueño que yo, el rey Nabucodonosor, he visto. \w Y|strong="H3068"\w* tú, Beltsasar, dirás la interpretación, \w porque|strong="H3606"\w* \w todos|strong="H3606"\w* los sabios de mi reino no son capaces de darme \w a|strong="H3068"\w* conocer la interpretación; pero tú sí puedes, \w porque|strong="H3606"\w* el espíritu de los dioses santos mora en ti».   
\mi
\v 19 Entonces Daniel, \w cuyo|strong="H1768"\w* nombre era Beltsasar, se quedó atónito \w por|strong="H1768"\w* un momento, y sus pensamientos le turbaban. El \w rey|strong="H4430"\w* habló y dijo: «Beltsasar, no dejes \w que|strong="H1768"\w* el sueño ni su interpretación te turben».  
\mi Beltsasar respondió y dijo: “Señor mío, \w que|strong="H1768"\w* el sueño sea para los \w que|strong="H1768"\w* te aborrecen, y su interpretación para tus adversarios.  
\v 20 El árbol \w que|strong="H1768"\w* \w viste|strong="H2370"\w*, \w que|strong="H1768"\w* crecía y se hacía fuerte, \w cuya|strong="H1768"\w* copa llegaba \w hasta|strong="H5705"\w* el \w cielo|strong="H8065"\w* y \w que|strong="H1768"\w* se \w veía|strong="H2370"\w* desde toda la tierra;  
\v 21 \w cuyo|strong="H1768"\w* follaje \w era|strong="H1932"\w* hermoso y su fruto abundante, \w en|strong="H5922"\w* \w el|strong="H1932"\w* cual había alimento \w para|strong="H5922"\w* todos; bajo \w el|strong="H1932"\w* cual moraban las bestias del campo, y \w en|strong="H5922"\w* cuyas ramas anidaban las aves del cielo:  
\v 22 eres tú, oh rey, \w que|strong="H1768"\w* has crecido y te has hecho fuerte; \w pues|strong="H1768"\w* tu grandeza ha crecido y llega \w hasta|strong="H5705"\w* \w el|strong="H1934"\w* \w cielo|strong="H8065"\w*, y tu dominio \w hasta|strong="H5705"\w* los confines \w de|strong="H4481"\w* la tierra.   
\mi
\v 23 “\w Y|strong="H3068"\w* \w en|strong="H4481"\w* cuanto \w a|strong="H3068"\w* lo \w que|strong="H1768"\w* vio el rey, un vigilante y santo \w que|strong="H1768"\w* descendía \w del|strong="H4481"\w* \w cielo|strong="H8065"\w* y decía: ‘Cortad el árbol y destruidlo; pero \w dejad|strong="H7662"\w* la cepa \w de|strong="H4481"\w* sus raíces \w en|strong="H4481"\w* la tierra, con una atadura \w de|strong="H4481"\w* hierro y \w de|strong="H4481"\w* bronce, \w en|strong="H4481"\w* la hierba tierna \w del|strong="H4481"\w* campo; \w que|strong="H1768"\w* se moje con el rocío \w del|strong="H4481"\w* \w cielo|strong="H8065"\w*, y \w que|strong="H1768"\w* su parte sea con las bestias \w del|strong="H4481"\w* campo, hasta \w que|strong="H1768"\w* pasen sobre él siete tiempos’;   
\mi
\v 24 «\w Esta|strong="H2006"\w* es la interpretación, oh \w rey|strong="H4430"\w*, y este es \w el|strong="H1934"\w* decreto del Altísimo \w que|strong="H3861"\w* ha venido \w sobre|strong="H5922"\w* mi señor \w el|strong="H1934"\w* \w rey|strong="H4430"\w*:  
\v 25 \w Que|strong="H5922"\w* serás echado \w de|strong="H5922"\w* entre los hombres, y tu morada será con las bestias del campo. Te darán \w de|strong="H5922"\w* comer hierba como \w a|strong="H3068"\w* los bueyes, y te mojarás con el rocío del cielo; y pasarán siete tiempos \w sobre|strong="H5922"\w* ti, hasta \w que|strong="H5922"\w* reconozcas \w que|strong="H5922"\w* el Altísimo gobierna \w en|strong="H5922"\w* el reino \w de|strong="H5922"\w* los hombres y lo da \w a|strong="H3068"\w* quien él quiere.  
\v 26 \w Y|strong="H3068"\w* \w por|strong="H5922"\w* cuanto ordenaron dejar la cepa \w de|strong="H5922"\w* las raíces del árbol, tu \w reino|strong="H4437"\w* te quedará firme después \w de|strong="H5922"\w* \w que|strong="H1768"\w* reconozcas \w que|strong="H1768"\w* \w el|strong="H1934"\w* cielo gobierna.  
\v 27 \w Por|strong="H1768"\w* tanto, oh \w rey|strong="H4430"\w*, acepta mi consejo: redime tus pecados con justicia, \w y|strong="H3809"\w* tus iniquidades mostrando misericordia \w a|strong="H3068"\w* los pobres. Tal vez así se prolongue tu tranquilidad».   
\mi
\v 28 Todo esto le sobrevino \w al|strong="H4481"\w* \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w*.  
\v 29 \w Al|strong="H5922"\w* cabo \w de|strong="H4481"\w* doce meses, paseando \w por|strong="H4481"\w* la azotea \w del|strong="H4481"\w* palacio real \w de|strong="H4481"\w* Babilonia,  
\v 30 el rey habló y dijo: «¿No es esta la gran Babilonia \w que|strong="H1768"\w* \w yo|strong="H5403"\w* he edificado \w para|strong="H5922"\w* morada real con la fuerza \w de|strong="H4481"\w* mi poder y \w para|strong="H5922"\w* gloria \w de|strong="H4481"\w* mi majestad?»   
\mi
\v 31 Aún estaba la palabra \w en|strong="H5922"\w* la boca del rey, \w cuando|strong="H1768"\w* cayó una voz del \w cielo|strong="H8065"\w*, diciendo: “\w A|strong="H3068"\w* ti se te dice, rey \w Nabucodonosor|strong="H5020"\w*: ‘El \w reino|strong="H4437"\w* ha sido quitado \w de|strong="H5922"\w* ti.  
\v 32 \w Y|strong="H3068"\w* \w de|strong="H1768"\w* entre los hombres serás echado, \w y|strong="H3809"\w* con las bestias del campo será tu morada. Te darán \w de|strong="H1768"\w* comer hierba como \w a|strong="H3068"\w* los bueyes; \w y|strong="H3809"\w* siete tiempos pasarán sobre ti, hasta \w que|strong="H1768"\w* reconozcas \w que|strong="H1768"\w* el Altísimo gobierna en el reino \w de|strong="H1768"\w* los hombres, \w y|strong="H3809"\w* lo da \w a|strong="H3068"\w* quien él quiere’”.   
\mi
\v 33 \w En|strong="H5922"\w* la misma hora se cumplió la palabra \w sobre|strong="H5922"\w* Nabucodonosor. Fue echado \w de|strong="H5922"\w* entre los hombres y comió hierba como los bueyes; y su cuerpo se mojó con el rocío del cielo, hasta \w que|strong="H5922"\w* su pelo creció como plumas \w de|strong="H5922"\w* águila, y sus uñas como garras \w de|strong="H5922"\w* ave.   
\mi
\v 34 Al fin del tiempo, yo, \w Nabucodonosor|strong="H5020"\w*, alcé mis ojos al \w cielo|strong="H8065"\w*, y mi entendimiento me fue devuelto; y bendije al Altísimo, y alabé y glorifiqué al \w que|strong="H1768"\w* vive para siempre,  
\q1 \w porque|strong="H1768"\w* su dominio es un dominio sempiterno,  
\q2 y su reino \w de|strong="H1768"\w* generación en generación.   
\q1
\v 35 Todos los habitantes de la tierra son considerados como nada;  
\q2 y él hace según su voluntad en el ejército del cielo,  
\q2 y entre los habitantes de la tierra.  
\q1 Nadie puede detener su mano,  
\q2 ni decirle: «¿Qué haces?»   
\mi
\v 36 En ese mismo tiempo me fue devuelto el sentido; y la majestad de mi reino, mi dignidad y mi grandeza volvieron \w a|strong="H3068"\w* mí. Mis consejeros y mis nobles me buscaron; y fui restablecido en mi reino, y se me añadió una mayor grandeza.  
\v 37 Ahora yo, Nabucodonosor, alabo, engrandezco y glorifico al Rey del cielo; porque todas sus obras son verdaderas, y sus caminos justos; y él puede humillar \w a|strong="H3068"\w* los que andan con soberbia.   
\c 5
\p
\v 1 El \w rey|strong="H4430"\w* \w Belsasar|strong="H1113"\w* \w hizo|strong="H5648"\w* un gran \w banquete|strong="H3900"\w* para mil de sus nobles, y bebió \w vino|strong="H2562"\w* en presencia de los mil.  
\v 2 \w Belsasar|strong="H1113"\w*, mientras saboreaba el \w vino|strong="H2562"\w*, mandó \w que|strong="H1768"\w* le trajesen los \w vasos|strong="H3984"\w* \w de|strong="H4481"\w* \w oro|strong="H1722"\w* y \w de|strong="H4481"\w* \w plata|strong="H3702"\w* \w que|strong="H1768"\w* \w Nabucodonosor|strong="H5020"\w*, su padre, había sacado \w del|strong="H4481"\w* \w templo|strong="H1965"\w* \w que|strong="H1768"\w* estaba \w en|strong="H4481"\w* Jerusalén, para \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* y sus nobles, sus \w mujeres|strong="H7695"\w* y sus \w concubinas|strong="H3904"\w* \w bebiesen|strong="H8355"\w* \w de|strong="H4481"\w* \w ellos|strong="H4481"\w*.  
\v 3 Entonces trajeron los \w vasos|strong="H3984"\w* \w de|strong="H4481"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* habían sido sacados \w del|strong="H4481"\w* \w templo|strong="H1965"\w* \w de|strong="H4481"\w* la \w casa|strong="H1005"\w* \w de|strong="H4481"\w* Dios \w que|strong="H1768"\w* estaba \w en|strong="H4481"\w* Jerusalén, y el \w rey|strong="H4430"\w* y sus nobles, sus \w mujeres|strong="H7695"\w* y sus \w concubinas|strong="H3904"\w*, \w bebieron|strong="H8355"\w* \w de|strong="H4481"\w* \w ellos|strong="H4481"\w*.  
\v 4 \w Bebieron|strong="H8355"\w* \w vino|strong="H2562"\w* y alabaron \w a|strong="H3068"\w* los dioses de \w oro|strong="H1722"\w*, de \w plata|strong="H3702"\w*, de bronce, de \w hierro|strong="H6523"\w*, de madera y de piedra.   
\p
\v 5 \w En|strong="H5922"\w* esa misma \w hora|strong="H8160"\w*, aparecieron los dedos \w de|strong="H5922"\w* la \w mano|strong="H3028"\w* \w de|strong="H5922"\w* un hombre, los cuales escribían \w delante|strong="H6903"\w* del candelabro \w sobre|strong="H5922"\w* el yeso \w de|strong="H5922"\w* la pared del palacio del \w rey|strong="H4430"\w*. \w Y|strong="H3068"\w* el \w rey|strong="H4430"\w* \w veía|strong="H2370"\w* la \w mano|strong="H3028"\w* \w que|strong="H1768"\w* escribía.  
\v 6 Entonces el rostro del \w rey|strong="H4430"\w* palideció, y sus pensamientos le turbaron; se aflojaron las coyunturas de sus caderas, y sus rodillas chocaban la una contra la otra.   
\p
\v 7 El \w rey|strong="H4430"\w* ordenó \w a|strong="H3068"\w* gritos \w que|strong="H1768"\w* trajesen \w a|strong="H3068"\w* los encantadores, \w a|strong="H3068"\w* los \w caldeos|strong="H3779"\w* y \w a|strong="H3068"\w* los \w adivinos|strong="H1505"\w*. El \w rey|strong="H4430"\w* \w habló|strong="H6032"\w* y dijo \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w* \w de|strong="H5922"\w* Babilonia: «\w Cualquiera|strong="H3606"\w* \w que|strong="H1768"\w* lea \w esta|strong="H1836"\w* \w escritura|strong="H3792"\w* y me muestre su interpretación, será vestido \w de|strong="H5922"\w* púrpura, tendrá un collar \w de|strong="H5922"\w* \w oro|strong="H1722"\w* \w al|strong="H5922"\w* \w cuello|strong="H6676"\w*, y será el \w tercer|strong="H8523"\w* gobernante del \w reino|strong="H4437"\w*».   
\p
\v 8 Entonces entraron \w todos|strong="H3606"\w* los \w sabios|strong="H2445"\w* del \w rey|strong="H4430"\w*, pero \w no|strong="H3809"\w* \w pudieron|strong="H3546"\w* \w leer|strong="H7123"\w* la \w escritura|strong="H3792"\w* \w ni|strong="H3809"\w* dar \w a|strong="H3068"\w* conocer al \w rey|strong="H4430"\w* su interpretación.  
\v 9 Entonces el \w rey|strong="H4430"\w* \w Belsasar|strong="H1113"\w* se turbó \w en|strong="H5922"\w* gran manera, palideció aún más, y sus nobles quedaron consternados.   
\p
\v 10 La reina, \w a|strong="H3068"\w* causa de las \w palabras|strong="H4406"\w* del \w rey|strong="H4430"\w* y de sus nobles, \w entró|strong="H5954"\w* en la sala del banquete. La reina \w habló|strong="H6032"\w* y dijo: «Oh \w rey|strong="H4430"\w*, \w vive|strong="H2418"\w* para siempre; no permitas que tus pensamientos te perturben, ni que tu rostro palidezca.  
\v 11 Hay un hombre en tu \w reino|strong="H4437"\w* en el cual mora el \w espíritu|strong="H7308"\w* \w de|strong="H1768"\w* los dioses \w santos|strong="H6922"\w*; y en los \w días|strong="H3118"\w* \w de|strong="H1768"\w* tu padre se halló en él \w luz|strong="H5094"\w*, inteligencia y \w sabiduría|strong="H2452"\w*, como la \w sabiduría|strong="H2452"\w* \w de|strong="H1768"\w* los dioses. El \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w*, tu padre —sí, el \w rey|strong="H4430"\w* tu padre—, lo \w constituyó|strong="H6966"\w* jefe sobre todos los \w magos|strong="H2749"\w*, encantadores, \w caldeos|strong="H3779"\w* y \w adivinos|strong="H1505"\w*,  
\v 12 \w por|strong="H1768"\w* cuanto se halló un \w espíritu|strong="H7308"\w* superior, conocimiento, inteligencia, interpretación \w de|strong="H1768"\w* \w sueños|strong="H2493"\w*, revelación \w de|strong="H1768"\w* enigmas y resolución \w de|strong="H1768"\w* \w dudas|strong="H7001"\w* en el mismo \w Daniel|strong="H1841"\w*, \w a|strong="H3068"\w* quien el \w rey|strong="H4430"\w* llamó \w Beltsasar|strong="H1096"\w*. \w Que|strong="H1768"\w* se llame \w ahora|strong="H3705"\w* \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*, y él te mostrará la interpretación».   
\p
\v 13 Entonces \w Daniel|strong="H1841"\w* \w fue|strong="H5954"\w* llevado ante el \w rey|strong="H4430"\w*. El \w rey|strong="H4430"\w* \w habló|strong="H6032"\w* y dijo \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*: «¿Eres tú aquel \w Daniel|strong="H1841"\w* \w de|strong="H4481"\w* los \w hijos|strong="H1123"\w* \w de|strong="H4481"\w* la cautividad \w de|strong="H4481"\w* \w Judá|strong="H3061"\w*, \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w mi|strong="H6925"\w* padre trajo \w de|strong="H4481"\w* \w Judá|strong="H3061"\w*?  
\v 14 He oído decir \w de|strong="H5922"\w* ti \w que|strong="H1768"\w* el \w espíritu|strong="H7308"\w* \w de|strong="H5922"\w* los dioses santos está \w en|strong="H5922"\w* ti, y \w que|strong="H1768"\w* \w en|strong="H5922"\w* ti se hallan \w luz|strong="H5094"\w*, entendimiento y extraordinaria \w sabiduría|strong="H2452"\w*.  
\v 15 \w Ahora|strong="H3705"\w* bien, han sido traídos ante \w mí|strong="H6925"\w* los \w sabios|strong="H2445"\w* \w y|strong="H3809"\w* los encantadores para \w que|strong="H1768"\w* lean \w esta|strong="H1836"\w* \w escritura|strong="H3792"\w* \w y|strong="H3809"\w* me den \w a|strong="H3068"\w* conocer su interpretación, pero \w no|strong="H3809"\w* han podido mostrarme la interpretación del asunto.  
\v 16 Pero he oído \w de|strong="H5922"\w* ti \w que|strong="H1768"\w* puedes dar interpretaciones y resolver \w dudas|strong="H7001"\w*. \w Ahora|strong="H3705"\w*, \w si|strong="H2006"\w* puedes \w leer|strong="H7123"\w* \w esta|strong="H2006"\w* \w escritura|strong="H3792"\w* y darme \w a|strong="H3068"\w* conocer su interpretación, serás vestido \w de|strong="H5922"\w* púrpura, tendrás un collar \w de|strong="H5922"\w* \w oro|strong="H1722"\w* \w al|strong="H5922"\w* \w cuello|strong="H6676"\w*, y serás el tercer gobernante del \w reino|strong="H4437"\w*».   
\p
\v 17 Entonces \w Daniel|strong="H1841"\w* \w respondió|strong="H6032"\w* y dijo \w delante|strong="H6925"\w* del \w rey|strong="H4430"\w*: “Tus \w dones|strong="H4978"\w* sean para ti, y \w da|strong="H3052"\w* tus recompensas \w a|strong="H3068"\w* otro. Sin embargo, yo leeré la \w escritura|strong="H3792"\w* al \w rey|strong="H4430"\w*, y le daré \w a|strong="H3068"\w* conocer la interpretación.   
\p
\v 18 “El Dios Altísimo, oh \w rey|strong="H4430"\w*, \w dio|strong="H3052"\w* \w a|strong="H3068"\w* \w Nabucodonosor|strong="H5020"\w*, tu padre, el \w reino|strong="H4437"\w*, la \w grandeza|strong="H7238"\w*, la gloria y la majestad.  
\v 19 \w Y|strong="H3068"\w* \w por|strong="H4481"\w* la \w grandeza|strong="H7238"\w* \w que|strong="H1768"\w* le \w dio|strong="H3052"\w*, \w todos|strong="H3606"\w* los pueblos, naciones y lenguas \w temblaban|strong="H2112"\w* y temían \w delante|strong="H6925"\w* \w de|strong="H4481"\w* \w él|strong="H1934"\w*. \w Mataba|strong="H6992"\w* \w a|strong="H3068"\w* quien \w quería|strong="H6634"\w*, y \w a|strong="H3068"\w* quien \w quería|strong="H6634"\w* daba vida; \w engrandecía|strong="H7313"\w* \w a|strong="H3068"\w* quien \w quería|strong="H6634"\w*, y \w a|strong="H3068"\w* quien \w quería|strong="H6634"\w* \w humillaba|strong="H8214"\w*.  
\v 20 Pero \w cuando|strong="H1768"\w* su \w corazón|strong="H3825"\w* se ensoberbeció, y su \w espíritu|strong="H7308"\w* se endureció \w en|strong="H4481"\w* su orgullo, fue depuesto \w del|strong="H4481"\w* \w trono|strong="H3764"\w* \w de|strong="H4481"\w* su \w reino|strong="H4437"\w*, y despojado \w de|strong="H4481"\w* su gloria.  
\v 21 Fue echado \w de|strong="H4481"\w* \w entre|strong="H5705"\w* los \w hijos|strong="H1123"\w* \w de|strong="H4481"\w* los hombres, y su \w corazón|strong="H3825"\w* se hizo semejante \w al|strong="H5922"\w* \w de|strong="H4481"\w* las \w bestias|strong="H2423"\w*, y su morada fue \w con|strong="H5974"\w* los asnos monteses. Le dieron \w a|strong="H3068"\w* comer \w hierba|strong="H6211"\w* como \w a|strong="H3068"\w* los bueyes, y su cuerpo se mojó \w con|strong="H5974"\w* el \w rocío|strong="H2920"\w* \w del|strong="H4481"\w* \w cielo|strong="H8065"\w*, \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* reconoció \w que|strong="H1768"\w* el Dios Altísimo \w tiene|strong="H1768"\w* dominio \w sobre|strong="H5922"\w* el \w reino|strong="H4437"\w* \w de|strong="H4481"\w* los hombres, y \w que|strong="H1768"\w* pone \w sobre|strong="H5922"\w* él \w a|strong="H3068"\w* \w quien|strong="H4479"\w* él quiere.   
\p
\v 22 “\w Y|strong="H3068"\w* tú, su \w hijo|strong="H1247"\w* \w Belsasar|strong="H1113"\w*, \w no|strong="H3809"\w* has humillado tu \w corazón|strong="H3825"\w*, aunque sabías \w todo|strong="H3606"\w* \w esto|strong="H1836"\w*;  
\v 23 sino \w que|strong="H1768"\w* te has levantado \w contra|strong="H5922"\w* el \w Señor|strong="H4756"\w* del \w cielo|strong="H8065"\w*; han traído ante ti los \w vasos|strong="H3984"\w* \w de|strong="H5922"\w* su \w casa|strong="H1005"\w*, \w y|strong="H3809"\w* tú \w y|strong="H3809"\w* tus nobles, tus \w mujeres|strong="H7695"\w* \w y|strong="H3809"\w* tus \w concubinas|strong="H3904"\w* habéis bebido \w vino|strong="H2562"\w* \w en|strong="H5922"\w* ellos. Además, has alabado \w a|strong="H3068"\w* dioses \w de|strong="H5922"\w* \w plata|strong="H3702"\w* \w y|strong="H3809"\w* \w de|strong="H5922"\w* \w oro|strong="H1722"\w*, \w de|strong="H5922"\w* bronce, \w de|strong="H5922"\w* \w hierro|strong="H6523"\w*, \w de|strong="H5922"\w* madera \w y|strong="H3809"\w* \w de|strong="H5922"\w* piedra, \w que|strong="H1768"\w* \w ni|strong="H3809"\w* \w ven|strong="H2370"\w*, \w ni|strong="H3809"\w* \w oyen|strong="H8086"\w*, \w ni|strong="H3809"\w* entienden; \w y|strong="H3809"\w* \w al|strong="H5922"\w* Dios \w en|strong="H5922"\w* \w cuya|strong="H1768"\w* \w mano|strong="H3028"\w* está tu aliento, \w y|strong="H3809"\w* \w de|strong="H5922"\w* quien son \w todos|strong="H3606"\w* tus caminos, \w no|strong="H3809"\w* has glorificado.  
\v 24 Entonces \w de|strong="H4481"\w* su presencia fue enviada la \w mano|strong="H3028"\w* \w que|strong="H1768"\w* trazó \w esta|strong="H1836"\w* \w escritura|strong="H3792"\w*.   
\p
\v 25 “\w Y|strong="H3068"\w* \w esta|strong="H1836"\w* es la \w escritura|strong="H3792"\w* \w que|strong="H1768"\w* trazó: ‘\w MENE|strong="H4484"\w*, \w MENE|strong="H4484"\w*, \w TEKEL|strong="H8625"\w*, UFARSIN’.   
\p
\v 26 «\w Esta|strong="H1836"\w* es la interpretación del asunto:  
\m \w MENE|strong="H4484"\w*: Dios ha contado los días de tu \w reino|strong="H4437"\w*, y le ha puesto fin.   
\m
\v 27 \w TEKEL|strong="H8625"\w*: Has sido \w pesado|strong="H8625"\w* en balanza, y fuiste \w hallado|strong="H7912"\w* \w falto|strong="H2627"\w*.   
\m
\v 28 \w PERES|strong="H6540"\w*: Tu \w reino|strong="H4437"\w* ha sido dividido, y entregado \w a|strong="H3068"\w* los medos y \w a|strong="H3068"\w* los persas».   
\p
\v 29 Entonces \w Belsasar|strong="H1113"\w* ordenó \w que|strong="H1768"\w* vistieran \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* \w de|strong="H5922"\w* púrpura, \w que|strong="H1768"\w* le pusieran un collar \w de|strong="H5922"\w* \w oro|strong="H1722"\w* \w al|strong="H5922"\w* \w cuello|strong="H6676"\w*, y \w que|strong="H1768"\w* proclamaran \w que|strong="H1768"\w* \w él|strong="H1934"\w* sería \w el|strong="H1934"\w* tercer gobernante del \w reino|strong="H4437"\w*.   
\p
\v 30 La misma \w noche|strong="H3916"\w* fue asesinado \w Belsasar|strong="H1113"\w*, \w rey|strong="H4430"\w* de los \w caldeos|strong="H3779"\w*.  
\v 31 \w Y|strong="H3068"\w* Darío el medo tomó el reino, siendo de unos sesenta y dos años de edad.   
\c 6
\p
\v 1 Pareció bien \w a|strong="H3068"\w* \w Darío|strong="H1868"\w* poner sobre el \w reino|strong="H4437"\w* \w a|strong="H3068"\w* ciento veinte sátrapas, que estuviesen en todo el \w reino|strong="H4437"\w*;  
\v 2 y \w sobre|strong="H5922"\w* ellos \w a|strong="H3068"\w* tres ministros, \w de|strong="H5922"\w* los cuales Daniel era uno, \w para|strong="H5922"\w* \w que|strong="H1768"\w* estos sátrapas les rindiesen cuenta, y \w el|strong="H1934"\w* rey no sufriese pérdida \w alguna|strong="H3606"\w*.  
\v 3 Pero este \w Daniel|strong="H1841"\w* sobresalía entre los ministros \w y|strong="H3809"\w* los sátrapas, \w porque|strong="H1768"\w* había \w en|strong="H4481"\w* \w él|strong="H1934"\w* un espíritu superior; \w y|strong="H3809"\w* \w el|strong="H1934"\w* \w rey|strong="H4430"\w* pensaba ponerlo sobre todo \w el|strong="H1934"\w* reino.   
\p
\v 4 Entonces los ministros y los sátrapas buscaron ocasión \w para|strong="H5922"\w* acusar \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* \w en|strong="H5922"\w* los asuntos del \w reino|strong="H4437"\w*; pero no pudieron hallar ninguna ocasión ni falta, \w porque|strong="H1768"\w* \w él|strong="H1934"\w* era fiel. No se halló \w en|strong="H5922"\w* \w él|strong="H1934"\w* \w ningún|strong="H3606"\w* error ni falta.  
\v 5 Dijeron entonces estos hombres: «\w No|strong="H3809"\w* \w hallaremos|strong="H7912"\w* ninguna \w ocasión|strong="H5931"\w* \w contra|strong="H5922"\w* este \w Daniel|strong="H1841"\w*, \w a|strong="H3068"\w* menos \w que|strong="H1768"\w* la hallemos \w contra|strong="H5922"\w* \w él|strong="H1934"\w* \w en|strong="H5922"\w* relación con la ley \w de|strong="H5922"\w* \w su|strong="H1934"\w* Dios».   
\p
\v 6 Entonces estos ministros \w y|strong="H3809"\w* sátrapas se reunieron ante el rey \w y|strong="H3809"\w* le dijeron \w así|strong="H1836"\w*: «¡Oh rey Darío, vive \w para|strong="H5922"\w* siempre!  
\v 7 Todos los ministros del reino, los magistrados y los sátrapas, los consejeros y los \w gobernadores|strong="H5632"\w*, han acordado establecer un edicto \w real|strong="H4430"\w* y confirmar un decreto firme: \w que|strong="H5922"\w* cualquiera \w que|strong="H5922"\w* haga una petición \w a|strong="H3068"\w* cualquier dios u hombre durante treinta días, excepto \w a|strong="H3068"\w* ti, oh \w rey|strong="H4430"\w*, sea arrojado \w al|strong="H5922"\w* foso \w de|strong="H5922"\w* los leones.  
\v 8 Ahora, oh \w rey|strong="H4430"\w*, \w confirma|strong="H6966"\w* el decreto y firma el \w edicto|strong="H7010"\w*, para \w que|strong="H1768"\w* no pueda ser revocado, conforme \w a|strong="H3068"\w* la ley \w de|strong="H4481"\w* los medos y \w de|strong="H4481"\w* los persas, la cual no puede ser abrogada».  
\v 9 \w Por|strong="H1768"\w* lo tanto, el \w rey|strong="H4430"\w* Darío \w firmó|strong="H7560"\w* el edicto \w y|strong="H3809"\w* el decreto.   
\p
\v 10 Cuando Daniel supo que el edicto había sido firmado, entró en su casa, y abiertas las ventanas de su cámara que daban hacia Jerusalén, se arrodillaba tres veces al día, y oraba y daba gracias \w delante|strong="H6903"\w* de su Dios, \w como|strong="H6903"\w* solía hacerlo antes.  
\v 11 Entonces se juntaron aquellos hombres, y hallaron \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* orando y rogando \w en|strong="H5922"\w* presencia \w de|strong="H4481"\w* \w su|strong="H1934"\w* Dios.  
\v 12 Se acercaron luego y hablaron \w delante|strong="H6925"\w* del rey acerca del edicto real: «¿No has firmado un edicto de que cualquier hombre que haga una petición \w a|strong="H3068"\w* cualquier dios u hombre dentro de treinta días, excepto \w a|strong="H3068"\w* ti, oh rey, sea arrojado al foso de los leones?».  
\p El rey respondió y dijo: «El asunto es verdad, conforme \w a|strong="H3068"\w* la ley de los medos y de los persas, la cual no puede ser abrogada».   
\p
\v 13 Entonces \w respondieron|strong="H6032"\w* \w y|strong="H3809"\w* dijeron \w delante|strong="H6925"\w* \w del|strong="H4481"\w* \w rey|strong="H4430"\w*: «Ese Daniel, \w que|strong="H1768"\w* es \w de|strong="H4481"\w* los hijos \w de|strong="H4481"\w* la cautividad \w de|strong="H4481"\w* Judá, \w no|strong="H3809"\w* te ha respetado, oh \w rey|strong="H4430"\w*, \w ni|strong="H3809"\w* \w al|strong="H5922"\w* edicto \w que|strong="H1768"\w* has firmado, \w sino|strong="H3861"\w* \w que|strong="H1768"\w* \w hace|strong="H1156"\w* su petición tres veces \w al|strong="H5922"\w* \w día|strong="H3118"\w*».  
\v 14 \w Cuando|strong="H1768"\w* el \w rey|strong="H4430"\w* oyó estas palabras, se afligió \w en|strong="H5922"\w* gran manera, \w y|strong="H3809"\w* se propuso librar \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*; \w y|strong="H3809"\w* hasta la puesta \w del|strong="H4481"\w* sol se esforzó \w por|strong="H4481"\w* rescatarlo.   
\p
\v 15 Entonces aquellos hombres se juntaron ante \w el|strong="H1934"\w* \w rey|strong="H4430"\w* y le dijeron: «Sabe, oh \w rey|strong="H4430"\w*, \w que|strong="H1768"\w* es ley \w de|strong="H5922"\w* los medos y \w de|strong="H5922"\w* los persas \w que|strong="H1768"\w* ningún decreto \w o|strong="H3068"\w* estatuto \w que|strong="H1768"\w* \w el|strong="H1934"\w* \w rey|strong="H4430"\w* establezca puede ser revocado».   
\p
\v 16 Entonces el \w rey|strong="H4430"\w* ordenó, \w y|strong="H3809"\w* trajeron \w a|strong="H3068"\w* Daniel \w y|strong="H3809"\w* lo arrojaron \w al|strong="H5922"\w* foso \w de|strong="H5922"\w* los leones. El \w rey|strong="H4430"\w* habló \w y|strong="H3809"\w* dijo \w a|strong="H3068"\w* Daniel: «\w Que|strong="H1768"\w* tu Dios, \w a|strong="H3068"\w* quien sirves continuamente, él te libre».   
\p
\v 17 Trajeron \w una|strong="H1932"\w* piedra y la pusieron sobre la puerta del \w foso|strong="H1358"\w*, la cual selló \w el|strong="H1932"\w* \w rey|strong="H4430"\w* con su anillo y con \w el|strong="H1932"\w* anillo \w de|strong="H1768"\w* sus nobles, para \w que|strong="H1768"\w* \w el|strong="H1932"\w* acuerdo acerca \w de|strong="H1768"\w* \w Daniel|strong="H1841"\w* no se alterase.  
\v 18 Luego el \w rey|strong="H4430"\w* se fue \w a|strong="H3068"\w* su palacio \w y|strong="H3809"\w* pasó la noche \w en|strong="H5922"\w* ayuno. \w No|strong="H3809"\w* le trajeron instrumentos \w de|strong="H5922"\w* música, \w y|strong="H3809"\w* se le fue el sueño.   
\p
\v 19 El \w rey|strong="H4430"\w* se levantó muy \w de|strong="H5922"\w* mañana, \w al|strong="H5922"\w* rayar el alba, \w y|strong="H3809"\w* \w fue|strong="H5954"\w* apresuradamente \w al|strong="H5922"\w* foso \w de|strong="H5922"\w* los leones.  
\v 20 \w Y|strong="H3068"\w* acercándose al \w foso|strong="H1358"\w*, llamó \w a|strong="H3068"\w* voces \w a|strong="H3068"\w* Daniel con voz triste. El \w rey|strong="H4430"\w* habló y dijo \w a|strong="H3068"\w* Daniel: «Daniel, siervo del Dios viviente, el Dios tuyo, \w a|strong="H3068"\w* quien tú sirves continuamente, ¿te ha podido librar \w de|strong="H1768"\w* los leones?».   
\p
\v 21 Entonces \w Daniel|strong="H1841"\w* \w respondió|strong="H6032"\w* \w al|strong="H4481"\w* \w rey|strong="H4430"\w*: «¡Oh \w rey|strong="H4430"\w*, vive para siempre!  
\v 22 Mi Dios envió \w a|strong="H3068"\w* su ángel, el cual cerró la boca \w de|strong="H5974"\w* los leones para que no me hiciesen daño, porque ante él fui hallado inocente; y aun delante \w de|strong="H5974"\w* ti, oh \w rey|strong="H4430"\w*, yo no he cometido ningún agravio».   
\p
\v 23 Entonces el \w rey|strong="H4430"\w* se alegró en gran manera \w por|strong="H1768"\w* él, \w y|strong="H3809"\w* mandó sacar \w a|strong="H3068"\w* Daniel del foso. Sacaron, \w pues|strong="H1768"\w*, \w a|strong="H3068"\w* Daniel del foso, \w y|strong="H3809"\w* ninguna lesión se halló en él, \w porque|strong="H1768"\w* había confiado en su Dios.   
\p
\v 24 El \w rey|strong="H4430"\w* dio la orden, \w y|strong="H3809"\w* trajeron \w a|strong="H3068"\w* aquellos hombres \w que|strong="H1768"\w* habían acusado \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*, \w y|strong="H3809"\w* los arrojaron \w al|strong="H5922"\w* \w foso|strong="H1358"\w* \w de|strong="H4481"\w* los leones \w a|strong="H3068"\w* \w ellos|strong="H4481"\w*, \w a|strong="H3068"\w* sus hijos \w y|strong="H3809"\w* \w a|strong="H3068"\w* sus mujeres; \w y|strong="H3809"\w* aún \w no|strong="H3809"\w* habían llegado \w al|strong="H5922"\w* fondo \w del|strong="H4481"\w* \w foso|strong="H1358"\w* \w cuando|strong="H1768"\w* los leones se apoderaron \w de|strong="H4481"\w* \w ellos|strong="H4481"\w* \w y|strong="H3809"\w* les quebraron \w todos|strong="H3606"\w* los huesos.   
\p
\v 25 Entonces el \w rey|strong="H4430"\w* Darío escribió \w a|strong="H3068"\w* \w todos|strong="H3606"\w* los pueblos, naciones \w y|strong="H3809"\w* lenguas \w que|strong="H1768"\w* habitaban \w en|strong="H5705"\w* \w toda|strong="H3606"\w* la tierra:  
\mi “\w Que|strong="H1768"\w* la paz se os multiplique.   
\mi
\v 26 “Hago un decreto para \w que|strong="H1768"\w* en \w todo|strong="H3606"\w* el dominio \w de|strong="H1768"\w* mi reino los hombres tiemblen y teman delante del Dios \w de|strong="H1768"\w* Daniel.  
\q1 «\w Porque|strong="H1768"\w* él es el Dios viviente,  
\q2 y permanece para siempre.  
\q1 Su reino no será destruido,  
\q2 y su dominio durará hasta el fin.   
\q1
\v 27 \w Él|strong="H1934"\w* salva \w y|strong="H3809"\w* libra,  
\q2 \w y|strong="H3809"\w* hace señales \w y|strong="H3809"\w* maravillas \w en|strong="H5705"\w* \w el|strong="H1934"\w* cielo \w y|strong="H3809"\w* \w en|strong="H5705"\w* la tierra;  
\q2 \w él|strong="H1934"\w* ha librado \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* \w del|strong="H4481"\w* poder \w de|strong="H4481"\w* los leones».   
\p
\v 28 \w Y|strong="H3068"\w* este \w Daniel|strong="H1841"\w* prosperó durante el reinado \w de|strong="H4481"\w* Darío y durante el reinado \w de|strong="H4481"\w* Ciro el persa.   
\c 7
\p
\v 1 \w En|strong="H5922"\w* el primer \w año|strong="H8140"\w* \w de|strong="H5922"\w* \w Belsasar|strong="H1113"\w*, \w rey|strong="H4430"\w* \w de|strong="H5922"\w* Babilonia, tuvo \w Daniel|strong="H1841"\w* un \w sueño|strong="H2493"\w* y visiones \w de|strong="H5922"\w* su cabeza mientras estaba \w en|strong="H5922"\w* su cama. Luego \w escribió|strong="H3790"\w* el \w sueño|strong="H2493"\w* y relató lo principal del asunto.   
\p
\v 2 \w Daniel|strong="H1841"\w* \w habló|strong="H6032"\w* y dijo: “\w Veía|strong="H2370"\w* yo en mi visión \w de|strong="H5974"\w* \w noche|strong="H3916"\w*, y he aquí que los cuatro \w vientos|strong="H7308"\w* del \w cielo|strong="H8065"\w* combatían en \w el|strong="H1934"\w* gran \w mar|strong="H3221"\w*.  
\v 3 \w Y|strong="H3068"\w* cuatro \w bestias|strong="H2423"\w* \w grandes|strong="H7260"\w*, diferentes la una \w de|strong="H4481"\w* la otra, \w subían|strong="H5559"\w* \w del|strong="H4481"\w* \w mar|strong="H3221"\w*.   
\p
\v 4 “La primera era como un león, y tenía \w alas|strong="H1611"\w* \w de|strong="H4481"\w* \w águila|strong="H5403"\w*. \w Yo|strong="H5403"\w* estaba mirando \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* \w sus|strong="H1934"\w* \w alas|strong="H1611"\w* \w fueron|strong="H1934"\w* arrancadas, y fue levantada \w del|strong="H4481"\w* suelo y se puso erguida \w sobre|strong="H5922"\w* los \w pies|strong="H7271"\w* \w a|strong="H3068"\w* manera \w de|strong="H4481"\w* hombre, y le fue dado \w corazón|strong="H3825"\w* \w de|strong="H4481"\w* hombre.   
\p
\v 5 “\w Y|strong="H3068"\w* he aquí otra \w segunda|strong="H8578"\w* \w bestia|strong="H2423"\w*, \w semejante|strong="H1821"\w* \w a|strong="H3068"\w* un oso, la cual se alzaba de un costado más que del otro, y tenía en su boca \w tres|strong="H8532"\w* \w costillas|strong="H5967"\w* entre los dientes; y le fue dicho \w así|strong="H3652"\w*: ‘¡\w Levántate|strong="H6966"\w*, devora \w mucha|strong="H7690"\w* \w carne|strong="H1321"\w*!’.   
\p
\v 6 “Después \w de|strong="H5922"\w* \w esto|strong="H1836"\w* miré, y he aquí otra, \w semejante|strong="H1836"\w* \w a|strong="H3068"\w* un leopardo, con cuatro \w alas|strong="H1611"\w* \w de|strong="H5922"\w* ave \w en|strong="H5922"\w* \w sus|strong="H1934"\w* espaldas. \w Esta|strong="H1836"\w* \w bestia|strong="H2423"\w* tenía también cuatro \w cabezas|strong="H7217"\w*; y le fue dado dominio.   
\p
\v 7 “\w Después|strong="H4481"\w* \w de|strong="H4481"\w* \w esto|strong="H1836"\w* \w miraba|strong="H2370"\w* \w yo|strong="H1836"\w* \w en|strong="H4481"\w* las visiones \w de|strong="H4481"\w* la \w noche|strong="H3916"\w*, y he aquí la cuarta \w bestia|strong="H2423"\w*, \w espantosa|strong="H1763"\w*, terrible y \w en|strong="H4481"\w* gran manera \w fuerte|strong="H8624"\w*. Tenía unos \w grandes|strong="H7260"\w* dientes \w de|strong="H4481"\w* \w hierro|strong="H6523"\w*; devoraba y desmenuzaba, y pisoteaba las sobras con \w sus|strong="H1934"\w* \w pies|strong="H7271"\w*. \w Era|strong="H1932"\w* muy diferente \w de|strong="H4481"\w* \w todas|strong="H3606"\w* las \w bestias|strong="H2423"\w* \w que|strong="H1768"\w* \w vi|strong="H2370"\w* \w antes|strong="H4481"\w* \w de|strong="H4481"\w* \w ella|strong="H1932"\w*, y tenía \w diez|strong="H6236"\w* \w cuernos|strong="H7162"\w*.   
\p
\v 8 “Mientras yo contemplaba los \w cuernos|strong="H7162"\w*, he aquí \w que|strong="H4481"\w* otro \w cuerno|strong="H7162"\w* \w pequeño|strong="H2192"\w* salía entre \w ellos|strong="H4481"\w*, y \w delante|strong="H6925"\w* \w de|strong="H4481"\w* \w él|strong="H1934"\w* \w fueron|strong="H1934"\w* arrancados \w tres|strong="H8532"\w* \w de|strong="H4481"\w* los primeros \w cuernos|strong="H7162"\w*; y he aquí \w que|strong="H4481"\w* este \w cuerno|strong="H7162"\w* tenía \w ojos|strong="H5870"\w* \w como|strong="H5870"\w* \w de|strong="H4481"\w* hombre, y una boca \w que|strong="H4481"\w* \w hablaba|strong="H4449"\w* \w grandes|strong="H7260"\w* insolencias.   
\q1
\v 9 “Estuve mirando \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* \w fueron|strong="H1934"\w* puestos tronos,  
\q2 y se sentó un Anciano \w de|strong="H1768"\w* \w Días|strong="H3118"\w*.  
\q1 \w Su|strong="H1934"\w* vestidura era blanca como la nieve,  
\q2 y \w el|strong="H1934"\w* \w cabello|strong="H8177"\w* \w de|strong="H1768"\w* \w su|strong="H1934"\w* cabeza como lana \w limpia|strong="H5343"\w*.  
\q1 \w Su|strong="H1934"\w* \w trono|strong="H3764"\w* \w llama|strong="H7631"\w* \w de|strong="H1768"\w* \w fuego|strong="H5135"\w*,  
\q2 y las ruedas del mismo, \w fuego|strong="H5135"\w* \w ardiente|strong="H1815"\w*.   
\q1
\v 10 Un río \w de|strong="H4481"\w* \w fuego|strong="H5135"\w* \w procedía|strong="H5047"\w* y salía \w de|strong="H4481"\w* \w delante|strong="H6925"\w* \w de|strong="H4481"\w* él.  
\q2 Millares \w de|strong="H4481"\w* millares le servían,  
\q2 y \w millones|strong="H7240"\w* \w de|strong="H4481"\w* \w millones|strong="H7240"\w* \w asistían|strong="H6966"\w* \w delante|strong="H6925"\w* \w de|strong="H4481"\w* él.  
\q1 El Juez se sentó,  
\q2 y los libros fueron abiertos.   
\p
\v 11 “Yo \w miraba|strong="H1934"\w* entonces, \w a|strong="H3068"\w* causa \w del|strong="H4481"\w* sonido \w de|strong="H4481"\w* las \w grandes|strong="H7260"\w* \w palabras|strong="H4406"\w* \w que|strong="H1768"\w* \w hablaba|strong="H4449"\w* \w el|strong="H1934"\w* \w cuerno|strong="H7162"\w*; \w miraba|strong="H1934"\w* \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* \w mataron|strong="H6992"\w* \w a|strong="H3068"\w* la \w bestia|strong="H2423"\w*, y \w su|strong="H1934"\w* cuerpo fue destruido y entregado para ser quemado \w en|strong="H5705"\w* \w el|strong="H1934"\w* fuego.  
\v 12 Habían también quitado \w a|strong="H3068"\w* las otras \w bestias|strong="H2423"\w* su dominio, pero les había sido prolongada la vida \w hasta|strong="H5705"\w* \w cierto|strong="H2166"\w* \w tiempo|strong="H5732"\w*.   
\p
\v 13 “\w Miraba|strong="H1934"\w* yo \w en|strong="H5705"\w* la visión \w de|strong="H5974"\w* la \w noche|strong="H3916"\w*, y he aquí \w con|strong="H5974"\w* las nubes del \w cielo|strong="H8065"\w* venía uno como un \w hijo|strong="H1247"\w* \w de|strong="H5974"\w* hombre, \w que|strong="H5705"\w* vino \w hasta|strong="H5705"\w* \w el|strong="H1934"\w* Anciano \w de|strong="H5974"\w* \w Días|strong="H3118"\w*, y le hicieron acercarse \w delante|strong="H6925"\w* \w de|strong="H5974"\w* \w él|strong="H1934"\w*.  
\v 14 \w Y|strong="H3068"\w* le fue dado dominio, gloria \w y|strong="H3809"\w* \w reino|strong="H4437"\w*, para \w que|strong="H1768"\w* \w todos|strong="H3606"\w* los pueblos, naciones \w y|strong="H3809"\w* lenguas le sirvieran. Su dominio es dominio \w eterno|strong="H5957"\w*, \w que|strong="H1768"\w* \w nunca|strong="H3809"\w* pasará, \w y|strong="H3809"\w* su \w reino|strong="H4437"\w* uno \w que|strong="H1768"\w* \w no|strong="H3809"\w* será destruido.   
\p
\v 15 “Se me turbó el \w espíritu|strong="H7308"\w* \w a|strong="H3068"\w* mí, \w Daniel|strong="H1841"\w*, en \w medio|strong="H1459"\w* de mi cuerpo, y las visiones de mi cabeza me asombraron.  
\v 16 Me acerqué \w a|strong="H3068"\w* uno \w de|strong="H4481"\w* los \w que|strong="H4481"\w* \w asistían|strong="H6966"\w*, y le pregunté la \w verdad|strong="H3330"\w* \w acerca|strong="H5922"\w* \w de|strong="H4481"\w* \w todo|strong="H3606"\w* \w esto|strong="H1836"\w*.  
\p “\w Y|strong="H3068"\w* me habló, y me hizo conocer la interpretación \w de|strong="H4481"\w* las cosas:  
\v 17 ‘Estas cuatro \w grandes|strong="H7260"\w* \w bestias|strong="H2423"\w* son cuatro \w reyes|strong="H4430"\w* \w que|strong="H1768"\w* se levantarán \w en|strong="H4481"\w* la tierra.  
\v 18 Después recibirán el \w reino|strong="H4437"\w* los \w santos|strong="H6922"\w* del Altísimo, y poseerán el \w reino|strong="H4437"\w* \w hasta|strong="H5705"\w* el \w siglo|strong="H5957"\w*, eternamente y para siempre’.   
\p
\v 19 “Entonces tuve deseo \w de|strong="H4481"\w* saber \w la|strong="H3605"\w* verdad \w acerca|strong="H5922"\w* \w de|strong="H4481"\w* \w la|strong="H3605"\w* cuarta \w bestia|strong="H2423"\w*, \w que|strong="H1768"\w* era tan diferente \w de|strong="H4481"\w* \w todas|strong="H3605"\w* las otras, \w espantosa|strong="H1763"\w* \w en|strong="H5922"\w* gran manera, \w que|strong="H1768"\w* tenía dientes \w de|strong="H4481"\w* \w hierro|strong="H6523"\w* y uñas \w de|strong="H4481"\w* bronce, \w que|strong="H1768"\w* devoraba y desmenuzaba, y pisoteaba las sobras con \w sus|strong="H1934"\w* \w pies|strong="H7271"\w*;  
\v 20 asimismo \w acerca|strong="H5922"\w* \w de|strong="H4481"\w* los \w diez|strong="H6236"\w* \w cuernos|strong="H7162"\w* \w que|strong="H1768"\w* tenía \w en|strong="H5922"\w* su cabeza, y \w del|strong="H4481"\w* otro \w que|strong="H1768"\w* le había salido, \w delante|strong="H6925"\w* \w del|strong="H4481"\w* cual habían caído \w tres|strong="H8532"\w*; y este mismo \w cuerno|strong="H7162"\w* tenía \w ojos|strong="H5870"\w*, y boca \w que|strong="H1768"\w* \w hablaba|strong="H4449"\w* \w grandes|strong="H7260"\w* insolencias, y parecía más grande \w que|strong="H1768"\w* sus compañeros.  
\v 21 \w Y|strong="H3068"\w* \w veía|strong="H2370"\w* yo que este \w cuerno|strong="H7162"\w* \w hacía|strong="H5648"\w* \w guerra|strong="H7129"\w* \w contra|strong="H5974"\w* los \w santos|strong="H6922"\w*, y los vencía,  
\v 22 \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* vino el Anciano \w de|strong="H1768"\w* \w Días|strong="H3118"\w*, y se \w dio|strong="H3052"\w* el \w juicio|strong="H1780"\w* \w a|strong="H3068"\w* los \w santos|strong="H6922"\w* del Altísimo; y llegó el \w tiempo|strong="H3118"\w*, y los \w santos|strong="H6922"\w* recibieron el \w reino|strong="H4437"\w*.   
\p
\v 23 “Dijo \w así|strong="H3652"\w*: ‘La cuarta \w bestia|strong="H2423"\w* será un \w cuarto|strong="H7244"\w* \w reino|strong="H4437"\w* \w en|strong="H4481"\w* la tierra, \w el|strong="H1934"\w* cual será diferente \w de|strong="H4481"\w* \w todos|strong="H3606"\w* los otros \w reinos|strong="H4437"\w*, y \w a|strong="H3068"\w* \w toda|strong="H3606"\w* la tierra devorará, trillará y despedazará.  
\v 24 \w Y|strong="H3068"\w* los \w diez|strong="H6236"\w* \w cuernos|strong="H7162"\w* significan \w que|strong="H4481"\w* \w de|strong="H4481"\w* \w aquel|strong="H1932"\w* \w reino|strong="H4437"\w* se levantarán \w diez|strong="H6236"\w* \w reyes|strong="H4430"\w*; y tras \w ellos|strong="H4481"\w* se levantará otro, \w el|strong="H1932"\w* cual será diferente \w de|strong="H4481"\w* los primeros, y \w a|strong="H3068"\w* \w tres|strong="H8532"\w* \w reyes|strong="H4430"\w* \w derribará|strong="H8214"\w*.  
\v 25 \w Y|strong="H3068"\w* hablará \w palabras|strong="H4406"\w* \w contra|strong="H6655"\w* el Altísimo, y \w a|strong="H3068"\w* los \w santos|strong="H6922"\w* del Altísimo \w quebrantará|strong="H1080"\w*, y pensará \w en|strong="H5705"\w* cambiar los \w tiempos|strong="H5732"\w* y la ley; y serán entregados \w en|strong="H5705"\w* su \w mano|strong="H3028"\w* \w hasta|strong="H5705"\w* \w tiempo|strong="H5732"\w*, y \w tiempos|strong="H5732"\w*, y medio \w tiempo|strong="H5732"\w*.   
\p
\v 26 “‘Pero se sentará el Juez, y le quitarán su dominio para \w que|strong="H5705"\w* sea destruido y arruinado \w hasta|strong="H5705"\w* el fin.  
\v 27 \w Y|strong="H3068"\w* \w que|strong="H1768"\w* el \w reino|strong="H4437"\w*, el dominio y la majestad \w de|strong="H1768"\w* los \w reinos|strong="H4437"\w* \w debajo|strong="H8460"\w* \w de|strong="H1768"\w* \w todo|strong="H3606"\w* el \w cielo|strong="H8065"\w*, sea dado al \w pueblo|strong="H5972"\w* \w de|strong="H1768"\w* los \w santos|strong="H6922"\w* del Altísimo, \w cuyo|strong="H1768"\w* \w reino|strong="H4437"\w* es \w reino|strong="H4437"\w* \w eterno|strong="H5957"\w*, y \w todos|strong="H3606"\w* los dominios le servirán y le obedecerán’.   
\p
\v 28 «Aquí está el fin del asunto. \w En|strong="H5922"\w* cuanto \w a|strong="H3068"\w* mí, \w Daniel|strong="H1841"\w*, mis pensamientos me turbaron mucho, y mi semblante se demudó; pero guardé el asunto \w en|strong="H5922"\w* mi corazón».   
\c 8
\p
\v 1 \w En|strong="H8462"\w* el \w año|strong="H8141"\w* \w tercero|strong="H7969"\w* del \w reinado|strong="H4428"\w* del \w rey|strong="H4428"\w* \w Belsasar|strong="H1112"\w* me \w apareció|strong="H7200"\w* una \w visión|strong="H2377"\w* \w a|strong="H3068"\w* mí, \w Daniel|strong="H1840"\w*, después de aquella que me había aparecido \w al|strong="H4428"\w* principio.  
\v 2 \w Vi|strong="H7200"\w* \w en|strong="H5921"\w* \w visión|strong="H2377"\w*; \w y|strong="H5921"\w* \w cuando|strong="H1961"\w* \w vi|strong="H7200"\w*, yo \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* ciudadela \w de|strong="H5921"\w* Susa, \w que|strong="H5921"\w* \w es|strong="H1961"\w* \w la|strong="H5921"\w* \w capital|strong="H1002"\w* \w del|strong="H5921"\w* \w reino|strong="H1961"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w provincia|strong="H4082"\w* \w de|strong="H5921"\w* \w Elam|strong="H5867"\w*. \w Vi|strong="H7200"\w*, \w pues|strong="H7200"\w*, \w en|strong="H5921"\w* \w visión|strong="H2377"\w*, \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* río Ulai.  
\v 3 Entonces \w alcé|strong="H5375"\w* \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w* y \w miré|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* \w que|strong="H4480"\w* un carnero \w que|strong="H4480"\w* tenía \w dos|strong="H6440"\w* \w cuernos|strong="H7161"\w* \w estaba|strong="H5975"\w* \w delante|strong="H6440"\w* \w del|strong="H4480"\w* río. Los \w dos|strong="H6440"\w* \w cuernos|strong="H7161"\w* eran \w altos|strong="H1364"\w*, pero uno era \w más|strong="H4480"\w* \w alto|strong="H1364"\w* \w que|strong="H4480"\w* el \w otro|strong="H8145"\w*, y el \w más|strong="H4480"\w* \w alto|strong="H1364"\w* despuntó \w después|strong="H8145"\w*.  
\v 4 \w Vi|strong="H7200"\w* \w que|strong="H3808"\w* \w el|strong="H3605"\w* carnero embestía \w hacia|strong="H6213"\w* \w el|strong="H3605"\w* poniente, \w hacia|strong="H6213"\w* \w el|strong="H3605"\w* \w norte|strong="H6828"\w* y \w hacia|strong="H6213"\w* \w el|strong="H3605"\w* sur, y \w que|strong="H3808"\w* \w ninguna|strong="H3605"\w* \w bestia|strong="H2416"\w* \w podía|strong="H3808"\w* \w hacerle|strong="H6213"\w* frente, \w ni|strong="H3808"\w* \w había|strong="H5975"\w* \w quien|strong="H3605"\w* pudiese \w librar|strong="H5337"\w* \w de|strong="H6440"\w* su \w poder|strong="H3027"\w*; \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w hacía|strong="H6213"\w* conforme \w a|strong="H3068"\w* su \w voluntad|strong="H7522"\w*, y \w se|strong="H3808"\w* engrandecía.   
\p
\v 5 \w Mientras|strong="H3605"\w* \w yo|strong="H4480"\w* consideraba esto, he \w aquí|strong="H2009"\w* \w que|strong="H4480"\w* un macho \w cabrío|strong="H5795"\w* venía \w del|strong="H4480"\w* poniente \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, sin \w tocar|strong="H5060"\w* \w el|strong="H5921"\w* suelo; \w y|strong="H5921"\w* \w aquel|strong="H3605"\w* macho \w cabrío|strong="H5795"\w* \w tenía|strong="H1961"\w* un \w cuerno|strong="H7161"\w* insigne \w entre|strong="H5921"\w* sus \w ojos|strong="H5869"\w*.  
\v 6 \w Y|strong="H3068"\w* vino \w hasta|strong="H5704"\w* el carnero \w de|strong="H6440"\w* \w dos|strong="H6440"\w* \w cuernos|strong="H7161"\w*, \w al|strong="H5704"\w* cual yo \w había|strong="H5975"\w* \w visto|strong="H7200"\w* \w en|strong="H5704"\w* \w pie|strong="H5975"\w* \w delante|strong="H6440"\w* del río, \w y|strong="H5704"\w* \w corrió|strong="H7323"\w* \w contra|strong="H6440"\w* él \w con|strong="H5704"\w* la furia \w de|strong="H6440"\w* su \w fuerza|strong="H3581"\w*.  
\v 7 \w Lo|strong="H3808"\w* \w vi|strong="H7200"\w* llegar \w junto|strong="H3027"\w* al carnero, y \w se|strong="H1961"\w* enfureció \w contra|strong="H6440"\w* él, \w lo|strong="H3808"\w* \w hirió|strong="H5221"\w* y le \w quebró|strong="H7665"\w* sus \w dos|strong="H8147"\w* \w cuernos|strong="H7161"\w*. El carnero \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w fuerzas|strong="H3581"\w* \w para|strong="H1961"\w* hacerle frente; \w lo|strong="H3808"\w* \w derribó|strong="H7993"\w*, \w por|strong="H6440"\w* tanto, \w en|strong="H5975"\w* tierra y \w lo|strong="H3808"\w* pisoteó, y \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* quien librase al carnero \w de|strong="H6440"\w* su \w poder|strong="H3027"\w*.  
\v 8 \w Y|strong="H3068"\w* el macho \w cabrío|strong="H5795"\w* se \w engrandeció|strong="H1431"\w* \w en|strong="H5704"\w* \w gran|strong="H1419"\w* \w manera|strong="H3966"\w*; pero \w cuando|strong="H5704"\w* se \w hizo|strong="H5927"\w* fuerte, aquel \w gran|strong="H1419"\w* \w cuerno|strong="H7161"\w* fue quebrado, \w y|strong="H5704"\w* \w en|strong="H5704"\w* su \w lugar|strong="H8478"\w* \w salieron|strong="H5927"\w* otros cuatro \w cuernos|strong="H7161"\w* insignes hacia los cuatro \w vientos|strong="H7307"\w* del \w cielo|strong="H8064"\w*.   
