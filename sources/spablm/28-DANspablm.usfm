\p
\v 23 “\w Y|strong="H3068"\w* \w al|strong="H4428"\w* fin del \w reinado|strong="H4428"\w* \w de|strong="H6440"\w* estos, cuando los transgresores lleguen \w al|strong="H4428"\w* colmo, se levantará un \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w rostro|strong="H6440"\w* \w altivo|strong="H5794"\w*, y entendido \w en|strong="H5975"\w* enigmas.  
\v 24 Su \w poder|strong="H3581"\w* \w se|strong="H3808"\w* fortalecerá, \w mas|strong="H3808"\w* \w no|strong="H3808"\w* con \w fuerza|strong="H3581"\w* propia; y causará grandes ruinas, y \w prosperará|strong="H6743"\w*, y \w hará|strong="H6213"\w* arbitrariamente, y \w destruirá|strong="H7843"\w* \w a|strong="H3068"\w* los \w fuertes|strong="H6099"\w* y al \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* los \w santos|strong="H6918"\w*.  
\v 25 \w Con|strong="H5921"\w* su sagacidad hará \w prosperar|strong="H6743"\w* \w el|strong="H5921"\w* \w engaño|strong="H4820"\w* \w en|strong="H5921"\w* su \w mano|strong="H3027"\w*; \w y|strong="H5921"\w* \w en|strong="H5921"\w* su \w corazón|strong="H3824"\w* \w se|strong="H5921"\w* engrandecerá, \w y|strong="H5921"\w* sin aviso \w destruirá|strong="H7843"\w* \w a|strong="H3068"\w* \w muchos|strong="H7227"\w*. \w Se|strong="H5921"\w* levantará \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w Príncipe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w príncipes|strong="H8269"\w*, pero \w será|strong="H7665"\w* \w quebrantado|strong="H7665"\w*, aunque \w no|strong="H7843"\w* \w por|strong="H5921"\w* \w mano|strong="H3027"\w* humana.   
\p
\v 26 «\w La|strong="H1931"\w* \w visión|strong="H2377"\w* \w de|strong="H3588"\w* las tardes \w y|strong="H3588"\w* mañanas \w que|strong="H3588"\w* \w se|strong="H1931"\w* ha referido \w es|strong="H1931"\w* verdadera; \w y|strong="H3588"\w* tú \w guarda|strong="H5640"\w* \w la|strong="H1931"\w* \w visión|strong="H2377"\w*, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w para|strong="H3588"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*».   
\p
\v 27 \w Y|strong="H3068"\w* \w yo|strong="H6213"\w*, \w Daniel|strong="H1840"\w*, \w quedé|strong="H1961"\w* quebrantado, \w y|strong="H5921"\w* \w estuve|strong="H1961"\w* \w enfermo|strong="H2470"\w* algunos \w días|strong="H3117"\w*. \w Cuando|strong="H3117"\w* convalecí, atendí \w los|strong="H5921"\w* negocios \w del|strong="H5921"\w* \w rey|strong="H4428"\w*; pero \w estaba|strong="H1961"\w* espantado \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w visión|strong="H4758"\w*, \w y|strong="H5921"\w* \w no|strong="H6213"\w* \w la|strong="H5921"\w* entendía.   
\c 9
\p
\v 1 \w En|strong="H5921"\w* \w el|strong="H5921"\w* primer \w año|strong="H8141"\w* \w de|strong="H5921"\w* \w Darío|strong="H1867"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Asuero, \w del|strong="H5921"\w* \w linaje|strong="H2233"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* medos, \w que|strong="H5921"\w* fue constituido \w rey|strong="H4427"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w reino|strong="H4427"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w caldeos|strong="H3778"\w*,  
\v 2 en \w el|strong="H5030"\w* primer \w año|strong="H8141"\w* \w de|strong="H1697"\w* su \w reinado|strong="H4427"\w*, yo, \w Daniel|strong="H1840"\w*, comprendí \w por|strong="H1697"\w* medio \w de|strong="H1697"\w* \w los|strong="H1961"\w* \w libros|strong="H5612"\w* \w el|strong="H5030"\w* \w número|strong="H4557"\w* \w de|strong="H1697"\w* \w los|strong="H1961"\w* \w años|strong="H8141"\w* \w sobre|strong="H1961"\w* \w los|strong="H1961"\w* cuales \w vino|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé\f + \fr 9:2 \ft «Yahvé» es el nombre propio de Dios, a veces traducido como «SEÑOR» (en mayúsculas) en otras traducciones. \f* al \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*, \w para|strong="H1961"\w* \w que|strong="H1697"\w* \w se|strong="H1961"\w* cumpliesen las desolaciones \w de|strong="H1697"\w* Jerusalén: \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*.  
\v 3 \w Y|strong="H3068"\w* volví \w mi|strong="H1245"\w* \w rostro|strong="H6440"\w* \w hacia|strong="H6440"\w* el Señor Dios, \w buscándole|strong="H1245"\w* en \w oración|strong="H8605"\w* y súplica, con \w ayuno|strong="H6685"\w*, cilicio y ceniza.   
\p
\v 4 \w Oré|strong="H6419"\w* \w a|strong="H3068"\w* Yahvé, mi \w Dios|strong="H3068"\w*, \w e|strong="H3068"\w* hice confesión, \w diciendo|strong="H4687"\w*:  
\mi “Oh \w Señor|strong="H3068"\w*, \w Dios|strong="H3068"\w* \w grande|strong="H1419"\w* y temible, que \w guardas|strong="H8104"\w* el \w pacto|strong="H1285"\w* y \w la|strong="H8104"\w* \w misericordia|strong="H2617"\w* con los que te aman y \w guardan|strong="H8104"\w* tus \w mandamientos|strong="H4687"\w*;  
\v 5 hemos \w pecado|strong="H2398"\w*, hemos cometido iniquidad, hemos obrado \w impíamente|strong="H7561"\w* y nos hemos rebelado, apartándonos de tus \w mandamientos|strong="H4687"\w* y de tus \w ordenanzas|strong="H4941"\w*.  
\v 6 \w No|strong="H3808"\w* hemos obedecido \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w*, \w que|strong="H3808"\w* en tu \w nombre|strong="H8034"\w* \w hablaron|strong="H1696"\w* \w a|strong="H3068"\w* nuestros \w reyes|strong="H4428"\w*, \w a|strong="H3068"\w* nuestros \w príncipes|strong="H8269"\w*, \w a|strong="H3068"\w* nuestros padres y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* tierra.   
\mi
\v 7 “Tuya \w es|strong="H2088"\w*, Señor, \w la|strong="H3605"\w* \w justicia|strong="H6666"\w*, y nuestra \w la|strong="H3605"\w* \w confusión|strong="H1322"\w* \w de|strong="H6440"\w* \w rostro|strong="H6440"\w*, como en \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w de|strong="H6440"\w* \w hoy|strong="H3117"\w*; \w de|strong="H6440"\w* \w los|strong="H3427"\w* hombres \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*, \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H6440"\w* Jerusalén y \w de|strong="H6440"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w de|strong="H6440"\w* \w cerca|strong="H7138"\w* y \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w de|strong="H6440"\w* \w lejos|strong="H7350"\w*, en \w todas|strong="H3605"\w* las tierras adonde \w los|strong="H3427"\w* has arrojado \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w la|strong="H3605"\w* \w prevaricación|strong="H4603"\w* \w que|strong="H3117"\w* \w cometieron|strong="H4604"\w* \w contra|strong="H6440"\w* ti.  
\v 8 Oh \w Señor|strong="H3068"\w*, nuestra es la \w confusión|strong="H1322"\w* \w de|strong="H6440"\w* \w rostro|strong="H6440"\w*, \w de|strong="H6440"\w* nuestros \w reyes|strong="H4428"\w*, \w de|strong="H6440"\w* nuestros \w príncipes|strong="H8269"\w* y \w de|strong="H6440"\w* nuestros padres, \w porque|strong="H6440"\w* hemos \w pecado|strong="H2398"\w* \w contra|strong="H6440"\w* ti.  
\v 9 Del Señor, nuestro Dios, \w son|strong="H3588"\w* \w la|strong="H3588"\w* misericordia \w y|strong="H3588"\w* \w el|strong="H3588"\w* perdón, \w aunque|strong="H3588"\w* nos hemos rebelado contra \w él|strong="H3588"\w*,  
\v 10 y \w no|strong="H3808"\w* hemos obedecido \w a|strong="H3068"\w* la \w voz|strong="H6963"\w* \w de|strong="H6440"\w* Yahvé, nuestro \w Dios|strong="H3068"\w*, \w para|strong="H5414"\w* \w andar|strong="H3212"\w* \w en|strong="H3212"\w* sus \w leyes|strong="H8451"\w*, \w que|strong="H3808"\w* \w él|strong="H5030"\w* \w puso|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* nosotros \w por|strong="H6440"\w* \w medio|strong="H3027"\w* \w de|strong="H6440"\w* sus \w siervos|strong="H5650"\w* los \w profetas|strong="H5030"\w*.  
\v 11 \w Todo|strong="H3605"\w* \w Israel|strong="H3478"\w* ha transgredido tu \w ley|strong="H8451"\w*, \w apartándose|strong="H5493"\w* \w para|strong="H5921"\w* \w no|strong="H3588"\w* \w escuchar|strong="H8085"\w* tu \w voz|strong="H6963"\w*.  
\mi “\w Por|strong="H5921"\w* ello \w se|strong="H5921"\w* ha derramado \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w la|strong="H5921"\w* maldición \w y|strong="H3588"\w* \w el|strong="H5921"\w* \w juramento|strong="H7621"\w* \w que|strong="H3588"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*, \w siervo|strong="H5650"\w* \w de|strong="H5921"\w* Dios, \w porque|strong="H3588"\w* hemos \w pecado|strong="H2398"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 12 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* \w ha|strong="H3808"\w* \w cumplido|strong="H6213"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w que|strong="H3808"\w* \w habló|strong="H1696"\w* \w contra|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w y|strong="H5921"\w* \w contra|strong="H5921"\w* nuestros jefes \w que|strong="H3808"\w* \w nos|strong="H5921"\w* \w gobernaron|strong="H8199"\w*, trayendo \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w* un \w mal|strong="H7451"\w* tan \w grande|strong="H1419"\w*; pues \w nunca|strong="H3808"\w* \w fue|strong="H3808"\w* \w hecho|strong="H6213"\w* \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w* \w nada|strong="H3808"\w* \w semejante|strong="H7451"\w* \w a|strong="H3068"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* \w ha|strong="H3808"\w* \w hecho|strong="H6213"\w* \w contra|strong="H5921"\w* Jerusalén.  
\v 13 \w Conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w está|strong="H2063"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*, \w todo|strong="H3605"\w* \w este|strong="H2063"\w* \w mal|strong="H7451"\w* vino \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w*. \w Sin|strong="H3808"\w* embargo, \w no|strong="H3808"\w* hemos implorado \w el|strong="H5921"\w* favor \w de|strong="H5921"\w* Yahvé, nuestro \w Dios|strong="H3068"\w*, \w para|strong="H5921"\w* convertirnos \w de|strong="H5921"\w* nuestras \w iniquidades|strong="H5771"\w* \w y|strong="H5921"\w* \w entender|strong="H7919"\w* tu verdad.  
\v 14 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, Yahvé \w veló|strong="H8245"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w y|strong="H3588"\w* \w lo|strong="H3808"\w* trajo \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w*; \w porque|strong="H3588"\w* \w justo|strong="H6662"\w* \w es|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w* \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w obras|strong="H4639"\w* \w que|strong="H3588"\w* \w ha|strong="H3808"\w* \w hecho|strong="H6213"\w*, \w y|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w no|strong="H3808"\w* \w obedecimos|strong="H8085"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w voz|strong="H6963"\w*.   
\mi
\v 15 “\w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, Señor, Dios nuestro, \w que|strong="H6258"\w* \w sacaste|strong="H3318"\w* \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* la tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w* con \w mano|strong="H3027"\w* \w poderosa|strong="H2389"\w*, y te \w hiciste|strong="H6213"\w* renombre, como \w en|strong="H3318"\w* \w este|strong="H2088"\w* \w día|strong="H3117"\w*; hemos \w pecado|strong="H2398"\w*, hemos obrado \w impíamente|strong="H7561"\w*.  
\v 16 Oh Señor, conforme \w a|strong="H3068"\w* \w toda|strong="H3605"\w* tu \w justicia|strong="H6666"\w*, \w apártese|strong="H7725"\w* \w ahora|strong="H4994"\w* tu \w ira|strong="H2534"\w* \w y|strong="H3588"\w* tu \w furor|strong="H2534"\w* \w de|strong="H3588"\w* tu \w ciudad|strong="H5892"\w* \w de|strong="H3588"\w* Jerusalén, tu \w monte|strong="H2022"\w* \w santo|strong="H6944"\w*; \w porque|strong="H3588"\w* \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* nuestros \w pecados|strong="H5771"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* las \w iniquidades|strong="H5771"\w* \w de|strong="H3588"\w* nuestros padres, Jerusalén \w y|strong="H3588"\w* tu \w pueblo|strong="H5971"\w* \w son|strong="H3588"\w* \w el|strong="H3588"\w* \w oprobio|strong="H2781"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* nos \w rodean|strong="H5439"\w*.   
\mi
\v 17 «\w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, Dios nuestro, \w escucha|strong="H8085"\w* \w la|strong="H5921"\w* \w oración|strong="H8605"\w* \w de|strong="H5921"\w* tu \w siervo|strong="H5650"\w* \w y|strong="H5921"\w* sus \w ruegos|strong="H8469"\w*, \w y|strong="H5921"\w* haz \w que|strong="H6258"\w* tu \w rostro|strong="H6440"\w* resplandezca \w sobre|strong="H5921"\w* tu \w santuario|strong="H4720"\w* desolado, \w por|strong="H5921"\w* amor \w del|strong="H5921"\w* Señor.  
\v 18 \w Inclina|strong="H5186"\w*, oh Dios \w mío|strong="H5921"\w*, tu \w oído|strong="H8085"\w*, \w y|strong="H3588"\w* \w escucha|strong="H8085"\w*; \w abre|strong="H6491"\w* tus \w ojos|strong="H5869"\w* \w y|strong="H3588"\w* \w mira|strong="H7200"\w* nuestras desolaciones \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cual|strong="H3588"\w* \w es|strong="H3588"\w* \w invocado|strong="H7121"\w* tu \w nombre|strong="H8034"\w*; \w porque|strong="H3588"\w* \w no|strong="H3808"\w* elevamos nuestras súplicas \w ante|strong="H6440"\w* \w ti|strong="H5921"\w* confiados \w en|strong="H5921"\w* nuestras \w justicias|strong="H6666"\w*, \w sino|strong="H3588"\w* \w en|strong="H5921"\w* tus \w grandes|strong="H7227"\w* \w misericordias|strong="H7356"\w*.  
\v 19 ¡Oh Señor, \w oye|strong="H8085"\w*! ¡Oh Señor, \w perdona|strong="H5545"\w*! ¡Oh Señor, \w atiende|strong="H7181"\w* \w y|strong="H3588"\w* actúa! \w No|strong="H6213"\w* tardes, \w por|strong="H5921"\w* amor \w de|strong="H5921"\w* \w ti|strong="H5921"\w* mismo, Dios \w mío|strong="H5971"\w*; \w porque|strong="H3588"\w* \w tu|strong="H6213"\w* \w nombre|strong="H8034"\w* \w es|strong="H3588"\w* \w invocado|strong="H7121"\w* \w sobre|strong="H5921"\w* \w tu|strong="H6213"\w* \w ciudad|strong="H5892"\w* \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w*».   
\b  
\p
\v 20 \w Aún|strong="H5750"\w* estaba yo \w hablando|strong="H1696"\w* \w y|strong="H5921"\w* orando, \w confesando|strong="H3034"\w* \w mi|strong="H5921"\w* \w pecado|strong="H2403"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* derramando \w mi|strong="H5921"\w* \w ruego|strong="H8467"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w mi|strong="H5921"\w* \w Dios|strong="H3068"\w*, \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w santo|strong="H6944"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w Dios|strong="H3068"\w*;  
\v 21 sí, \w aún|strong="H5750"\w* estaba \w hablando|strong="H1696"\w* \w en|strong="H8462"\w* \w oración|strong="H8605"\w*, \w cuando|strong="H6256"\w* aquel varón \w Gabriel|strong="H1403"\w*, \w a|strong="H3068"\w* quien había \w visto|strong="H7200"\w* \w en|strong="H8462"\w* la \w visión|strong="H2377"\w* \w al|strong="H6256"\w* principio, volando \w con|strong="H5060"\w* presteza, me \w tocó|strong="H5060"\w* \w a|strong="H3068"\w* la \w hora|strong="H6256"\w* del sacrificio \w de|strong="H5750"\w* la \w tarde|strong="H6153"\w*.  
\v 22 \w Y|strong="H3068"\w* \w me|strong="H5973"\w* hizo \w entender|strong="H7919"\w*, y \w habló|strong="H1696"\w* \w conmigo|strong="H5973"\w*, \w diciendo|strong="H1696"\w*: “\w Daniel|strong="H1840"\w*, \w ahora|strong="H6258"\w* he \w salido|strong="H3318"\w* \w para|strong="H5973"\w* darte sabiduría y entendimiento.  
\v 23 Al principio \w de|strong="H3588"\w* tus \w ruegos|strong="H8469"\w* fue dada \w la|strong="H3588"\w* orden, \w y|strong="H3588"\w* \w yo|strong="H3588"\w* he venido \w para|strong="H3588"\w* enseñártela, \w porque|strong="H3588"\w* tú eres muy amado. Entiende, \w pues|strong="H3588"\w*, \w la|strong="H3588"\w* \w palabra|strong="H1697"\w*, \w y|strong="H3588"\w* comprende \w la|strong="H3588"\w* \w visión|strong="H4758"\w*:   
\p
\v 24 “\w Setenta|strong="H7657"\w* \w semanas|strong="H7620"\w* están determinadas \w sobre|strong="H5921"\w* tu \w pueblo|strong="H5971"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* tu \w santa|strong="H6944"\w* \w ciudad|strong="H5892"\w*, \w para|strong="H5921"\w* terminar \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w prevaricación|strong="H6588"\w*, poner fin \w al|strong="H5921"\w* \w pecado|strong="H2403"\w*, \w expiar|strong="H3722"\w* \w la|strong="H5921"\w* \w iniquidad|strong="H5771"\w*, traer \w la|strong="H5921"\w* \w justicia|strong="H6664"\w* perdurable, sellar \w la|strong="H5921"\w* \w visión|strong="H2377"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w profecía|strong="H2377"\w*, \w y|strong="H5921"\w* ungir \w al|strong="H5921"\w* \w Santo|strong="H6944"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w santos|strong="H6944"\w*.   
\p
\v 25 “\w Sabe|strong="H3045"\w*, \w pues|strong="H4480"\w*, \w y|strong="H5704"\w* \w entiende|strong="H3045"\w*, \w que|strong="H4480"\w* \w desde|strong="H4480"\w* la \w salida|strong="H4161"\w* \w de|strong="H4480"\w* la orden \w para|strong="H5704"\w* restaurar \w y|strong="H5704"\w* \w edificar|strong="H1129"\w* Jerusalén \w hasta|strong="H5704"\w* el \w Ungido|strong="H4899"\w*,\f + \fr 9:25 \ft «Ungido» también puede traducirse como «Mesías» (igual que «Cristo»).\f* el \w Príncipe|strong="H5057"\w*, habrá \w siete|strong="H7651"\w* \w semanas|strong="H7620"\w*, \w y|strong="H5704"\w* \w sesenta|strong="H8346"\w* \w y|strong="H5704"\w* \w dos|strong="H8147"\w* \w semanas|strong="H7620"\w*; \w se|strong="H3045"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* la plaza \w y|strong="H5704"\w* el muro \w en|strong="H4480"\w* \w tiempos|strong="H6256"\w* \w angustiosos|strong="H6695"\w*.  
\v 26 \w Y|strong="H3068"\w* \w después|strong="H5704"\w* \w de|strong="H5704"\w* las \w sesenta|strong="H8346"\w* \w y|strong="H5704"\w* \w dos|strong="H8147"\w* \w semanas|strong="H7620"\w* \w se|strong="H5971"\w* quitará la vida \w al|strong="H5704"\w* \w Ungido|strong="H4899"\w*,\f + \fr 9:26 \ft «Ungido» también puede traducirse como «Mesías» (igual que «Cristo»).\f* \w y|strong="H5704"\w* nada le quedará. \w Y|strong="H3068"\w* el \w pueblo|strong="H5971"\w* \w de|strong="H5704"\w* un \w príncipe|strong="H5057"\w* \w que|strong="H5704"\w* ha \w de|strong="H5704"\w* venir \w destruirá|strong="H7843"\w* la \w ciudad|strong="H5892"\w* \w y|strong="H5704"\w* el \w santuario|strong="H6944"\w*; \w y|strong="H5704"\w* su \w fin|strong="H7093"\w* será \w con|strong="H5704"\w* inundación, \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* el \w fin|strong="H7093"\w* \w de|strong="H5704"\w* la \w guerra|strong="H4421"\w* están decretadas las desolaciones.  
\v 27 \w Y|strong="H3068"\w* \w por|strong="H5921"\w* otra \w semana|strong="H7620"\w* \w confirmará|strong="H1396"\w* \w el|strong="H5921"\w* \w pacto|strong="H1285"\w* \w con|strong="H5921"\w* \w muchos|strong="H7227"\w*; \w a|strong="H3068"\w* \w la|strong="H5921"\w* mitad \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w semana|strong="H7620"\w* hará cesar \w el|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w ofrenda|strong="H4503"\w*. \w Después|strong="H5921"\w*, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w ala|strong="H3671"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w abominaciones|strong="H8251"\w* vendrá \w el|strong="H5921"\w* desolador, \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* ruina decretada \w se|strong="H5921"\w* derrame \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* desolador”.   
\c 10
\p
\v 1 En el \w año|strong="H8141"\w* \w tercero|strong="H7969"\w* \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, \w fue|strong="H6635"\w* revelada una \w palabra|strong="H1697"\w* \w a|strong="H3068"\w* \w Daniel|strong="H1840"\w*, cuyo \w nombre|strong="H8034"\w* \w era|strong="H8141"\w* \w Beltsasar|strong="H1095"\w*; y la \w palabra|strong="H1697"\w* \w era|strong="H8141"\w* verdadera, y anunciaba un \w gran|strong="H1419"\w* conflicto. Él comprendió la \w palabra|strong="H1697"\w*, y tuvo inteligencia en la \w visión|strong="H4758"\w*.   
\p
\v 2 En \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* yo, \w Daniel|strong="H1840"\w*, \w estuve|strong="H1961"\w* afligido por espacio de \w tres|strong="H7969"\w* \w semanas|strong="H7620"\w* enteras.  
\v 3 \w No|strong="H3808"\w* comí \w manjar|strong="H3899"\w* delicado, \w ni|strong="H3808"\w* \w carne|strong="H1320"\w* \w ni|strong="H3808"\w* \w vino|strong="H3196"\w* entraron \w en|strong="H5704"\w* mi \w boca|strong="H6310"\w*, \w ni|strong="H3808"\w* me ungí \w con|strong="H5704"\w* ungüento alguno, \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* cumplieron las \w tres|strong="H7969"\w* \w semanas|strong="H7620"\w* enteras.   
\p
\v 4 \w Y|strong="H3068"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w veinticuatro|strong="H6242"\w* \w del|strong="H5921"\w* \w primer|strong="H7223"\w* \w mes|strong="H2320"\w*, \w estando|strong="H1961"\w* yo \w a|strong="H3068"\w* \w la|strong="H1931"\w* orilla \w del|strong="H5921"\w* \w gran|strong="H1419"\w* \w río|strong="H5104"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* Hidequel,\f + \fr 10:4 \ft Los terafines eran ídolos domésticos que podían estar asociados a los derechos de herencia de los bienes del hogar.\f*  
\v 5 \w alcé|strong="H5375"\w* \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w* y \w miré|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* un varón \w vestido|strong="H3847"\w* \w de|strong="H3847"\w* lino, y \w ceñidos|strong="H2296"\w* sus \w lomos|strong="H4975"\w* \w de|strong="H3847"\w* \w oro|strong="H3800"\w* \w fino|strong="H3800"\w* \w de|strong="H3847"\w* Ufaz.  
\v 6 Su cuerpo era como \w de|strong="H6440"\w* \w crisólito|strong="H8658"\w*, su \w rostro|strong="H6440"\w* \w parecía|strong="H5869"\w* un relámpago, y sus \w ojos|strong="H5869"\w* como antorchas \w de|strong="H6440"\w* fuego; sus \w brazos|strong="H2220"\w* y sus \w pies|strong="H4772"\w* eran como el \w color|strong="H5869"\w* del bronce bruñido, y el \w sonido|strong="H6963"\w* \w de|strong="H6440"\w* sus \w palabras|strong="H1697"\w* como el \w estruendo|strong="H6963"\w* \w de|strong="H6440"\w* una \w multitud|strong="H1995"\w*.   
\p
\v 7 \w Y|strong="H3068"\w* solo yo, \w Daniel|strong="H1840"\w*, \w vi|strong="H7200"\w* \w aquella|strong="H5921"\w* \w visión|strong="H4759"\w*, \w pues|strong="H7200"\w* \w los|strong="H5921"\w* hombres \w que|strong="H3808"\w* \w estaban|strong="H1961"\w* \w conmigo|strong="H5973"\w* \w no|strong="H3808"\w* \w la|strong="H5921"\w* \w vieron|strong="H7200"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* un \w gran|strong="H1419"\w* \w temor|strong="H2731"\w* \w y|strong="H5921"\w* \w huyeron|strong="H1272"\w* \w a|strong="H3068"\w* esconderse.  
\v 8 \w Quedé|strong="H7604"\w*, \w pues|strong="H7200"\w*, yo solo, \w y|strong="H5921"\w* \w vi|strong="H7200"\w* \w esta|strong="H2063"\w* \w gran|strong="H1419"\w* \w visión|strong="H4759"\w*. \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w quedó|strong="H7604"\w* \w en|strong="H5921"\w* \w mí|strong="H5921"\w* \w vigor|strong="H3581"\w*, \w pues|strong="H7200"\w* \w mi|strong="H5921"\w* lozanía \w se|strong="H5921"\w* demudó \w en|strong="H5921"\w* palidez, \w y|strong="H5921"\w* \w me|strong="H5921"\w* faltaron \w las|strong="H5921"\w* \w fuerzas|strong="H3581"\w*.  
\v 9 Sin embargo, \w oí|strong="H8085"\w* \w el|strong="H5921"\w* \w sonido|strong="H6963"\w* \w de|strong="H5921"\w* sus \w palabras|strong="H1697"\w*; \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w oír|strong="H8085"\w* \w el|strong="H5921"\w* \w sonido|strong="H6963"\w* \w de|strong="H5921"\w* sus \w palabras|strong="H1697"\w*, caí \w en|strong="H5921"\w* un profundo sopor \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w*, \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w rostro|strong="H6440"\w* \w en|strong="H5921"\w* tierra.   
\p
\v 10 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* una \w mano|strong="H3027"\w* \w me|strong="H5921"\w* \w tocó|strong="H5060"\w*, \w e|strong="H3068"\w* hizo \w que|strong="H5921"\w* \w me|strong="H5921"\w* pusiese \w sobre|strong="H5921"\w* mis \w rodillas|strong="H1290"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w palmas|strong="H3709"\w* \w de|strong="H5921"\w* mis \w manos|strong="H3027"\w*.  
\v 11 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* \w dijo|strong="H1696"\w*: «\w Daniel|strong="H1840"\w*, varón muy amado, \w está|strong="H2088"\w* atento \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* \w hablaré|strong="H1696"\w*, \w y|strong="H3588"\w* \w ponte|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w*, \w porque|strong="H3588"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* he sido \w enviado|strong="H7971"\w* \w ahora|strong="H6258"\w*». \w Cuando|strong="H3588"\w* \w me|strong="H5921"\w* \w dijo|strong="H1696"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*, \w me|strong="H5921"\w* \w puse|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w temblando|strong="H7460"\w*.   
\p
\v 12 \w Entonces|strong="H3117"\w* \w me|strong="H4480"\w* dijo: «\w No|strong="H3588"\w* \w temas|strong="H3372"\w*, \w Daniel|strong="H1840"\w*, \w porque|strong="H3588"\w* \w desde|strong="H4480"\w* \w el|strong="H3588"\w* \w primer|strong="H7223"\w* \w día|strong="H3117"\w* \w que|strong="H3588"\w* dispusiste tu \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* entender \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w humillarte|strong="H6031"\w* \w en|strong="H4480"\w* \w la|strong="H3588"\w* \w presencia|strong="H6440"\w* \w de|strong="H4480"\w* tu Dios, fueron oídas tus \w palabras|strong="H1697"\w*; \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H4480"\w* tus \w palabras|strong="H1697"\w* \w yo|strong="H4480"\w* he venido.  
\v 13 Mas el \w príncipe|strong="H8269"\w* del \w reino|strong="H4438"\w* \w de|strong="H5048"\w* \w Persia|strong="H6539"\w* se me opuso durante veintiún \w días|strong="H3117"\w*; pero he \w aquí|strong="H2009"\w* \w que|strong="H3117"\w* \w Miguel|strong="H4317"\w*, uno \w de|strong="H5048"\w* los \w príncipes|strong="H8269"\w* \w principales|strong="H8269"\w*, vino para ayudarme, y quedé \w allí|strong="H8033"\w* con los \w reyes|strong="H4428"\w* \w de|strong="H5048"\w* \w Persia|strong="H6539"\w*.  
\v 14 He venido \w ahora|strong="H3117"\w* \w para|strong="H3588"\w* hacerte saber lo \w que|strong="H3588"\w* ha \w de|strong="H3588"\w* venir \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* \w en|strong="H3588"\w* \w los|strong="H3588"\w* últimos \w días|strong="H3117"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w visión|strong="H2377"\w* \w es|strong="H3588"\w* \w aún|strong="H5750"\w* \w para|strong="H3588"\w* muchos \w días|strong="H3117"\w*».   
\p
\v 15 Mientras \w me|strong="H5973"\w* decía estas \w palabras|strong="H1697"\w*, bajé mi \w rostro|strong="H6440"\w* \w a|strong="H3068"\w* tierra y enmudecí.  
\v 16 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* uno \w con|strong="H5921"\w* \w semejanza|strong="H1823"\w* \w de|strong="H5921"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w* \w tocó|strong="H5060"\w* mis \w labios|strong="H8193"\w*. Entonces \w abrí|strong="H6605"\w* \w mi|strong="H5921"\w* \w boca|strong="H6310"\w* \w y|strong="H5921"\w* \w hablé|strong="H1696"\w*, \w y|strong="H5921"\w* \w dije|strong="H1696"\w* \w al|strong="H5921"\w* \w que|strong="H3808"\w* \w estaba|strong="H5975"\w* \w delante|strong="H5048"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*: «Señor \w mío|strong="H5921"\w*, \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w visión|strong="H4759"\w* \w me|strong="H5921"\w* han sobrevenido dolores, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w me|strong="H5921"\w* quedan \w fuerzas|strong="H3581"\w*.  
\v 17 \w Pues|strong="H6258"\w*, ¿\w cómo|strong="H5973"\w* \w podrá|strong="H3201"\w* \w el|strong="H5973"\w* \w siervo|strong="H5650"\w* \w de|strong="H5973"\w* mi señor \w hablar|strong="H1696"\w* \w con|strong="H5973"\w* mi señor? \w Porque|strong="H3808"\w* al instante \w me|strong="H5973"\w* faltaron las \w fuerzas|strong="H3581"\w*, y \w no|strong="H3808"\w* \w me|strong="H5973"\w* \w ha|strong="H3808"\w* quedado aliento».   
\p
\v 18 Entonces el que tenía \w apariencia|strong="H4758"\w* de hombre me \w tocó|strong="H5060"\w* otra vez, y me fortaleció.  
\v 19 \w Y|strong="H3068"\w* \w me|strong="H3588"\w* \w dijo|strong="H1696"\w*: «Varón muy amado, \w no|strong="H3588"\w* \w temas|strong="H3372"\w*. \w La|strong="H3588"\w* \w paz|strong="H7965"\w* sea \w contigo|strong="H5973"\w*. \w Esfuérzate|strong="H2388"\w* \w y|strong="H3588"\w* cobra \w ánimo|strong="H2388"\w*».  
\p \w Y|strong="H3068"\w* \w mientras|strong="H3588"\w* \w él|strong="H5973"\w* \w me|strong="H3588"\w* \w hablaba|strong="H1696"\w*, recobré las fuerzas \w y|strong="H3588"\w* \w dije|strong="H1696"\w*: «\w Hable|strong="H1696"\w* mi señor, \w porque|strong="H3588"\w* \w me|strong="H3588"\w* has fortalecido».   
\p
\v 20 \w Él|strong="H5973"\w* \w me|strong="H5973"\w* dijo: «¿\w Sabes|strong="H3045"\w* \w por|strong="H4100"\w* \w qué|strong="H4100"\w* he venido \w a|strong="H3068"\w* \w ti|strong="H5973"\w*? \w Pues|strong="H6258"\w* \w ahora|strong="H6258"\w* tengo \w que|strong="H4100"\w* \w volver|strong="H7725"\w* \w para|strong="H5973"\w* pelear \w contra|strong="H5973"\w* \w el|strong="H5973"\w* \w príncipe|strong="H8269"\w* \w de|strong="H5973"\w* \w Persia|strong="H6539"\w*. \w Y|strong="H3068"\w* al terminar \w con|strong="H5973"\w* \w él|strong="H5973"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H4100"\w* vendrá \w el|strong="H5973"\w* \w príncipe|strong="H8269"\w* \w de|strong="H5973"\w* \w Grecia|strong="H3120"\w*.  
\v 21 \w Pero|strong="H3588"\w* \w te|strong="H5921"\w* declararé \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w está|strong="H5921"\w* escrito \w en|strong="H5921"\w* \w el|strong="H5921"\w* libro \w de|strong="H5921"\w* \w la|strong="H5921"\w* verdad. \w Y|strong="H3068"\w* ninguno \w me|strong="H5921"\w* ayuda \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w sino|strong="H3588"\w* \w Miguel|strong="H4317"\w*, vuestro \w príncipe|strong="H8269"\w*».   
\c 11
\p
\v 1 “\w Y|strong="H3068"\w* yo mismo, \w en|strong="H5975"\w* el primer \w año|strong="H8141"\w* de \w Darío|strong="H1867"\w* el medo, \w estuve|strong="H5975"\w* \w a|strong="H3068"\w* su lado para animarlo y fortalecerlo.   
\p
\v 2 “\w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* te mostraré \w la|strong="H3605"\w* verdad. He \w aquí|strong="H2009"\w* \w que|strong="H6258"\w* \w aún|strong="H5750"\w* se levantarán \w tres|strong="H7969"\w* \w reyes|strong="H4428"\w* \w en|strong="H5750"\w* \w Persia|strong="H6539"\w*, y \w el|strong="H3605"\w* \w cuarto|strong="H7243"\w* se hará \w de|strong="H5750"\w* muchas \w más|strong="H5750"\w* \w riquezas|strong="H6239"\w* \w que|strong="H6258"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w*. \w Y|strong="H3068"\w* \w al|strong="H4428"\w* hacerse fuerte con sus \w riquezas|strong="H6239"\w*, incitará \w a|strong="H3068"\w* \w todos|strong="H3605"\w* contra \w el|strong="H3605"\w* \w reino|strong="H4438"\w* \w de|strong="H5750"\w* \w Grecia|strong="H3120"\w*.  
\v 3 Se levantará luego un \w rey|strong="H4428"\w* \w valiente|strong="H1368"\w*, \w el|strong="H6213"\w* cual dominará con \w gran|strong="H7227"\w* poder y \w hará|strong="H6213"\w* su \w voluntad|strong="H7522"\w*.  
\v 4 \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* \w se|strong="H3808"\w* haya levantado, \w su|strong="H3588"\w* \w reino|strong="H4438"\w* \w será|strong="H7665"\w* \w quebrantado|strong="H7665"\w* \w y|strong="H3588"\w* repartido hacia \w los|strong="H3588"\w* cuatro \w vientos|strong="H7307"\w* del \w cielo|strong="H8064"\w*; \w no|strong="H3808"\w* \w será|strong="H7665"\w* \w para|strong="H3588"\w* \w su|strong="H3588"\w* descendencia, \w ni|strong="H3808"\w* según \w el|strong="H3588"\w* dominio \w con|strong="H3588"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* gobernó; \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w reino|strong="H4438"\w* \w será|strong="H7665"\w* arrancado, \w y|strong="H3588"\w* \w será|strong="H7665"\w* \w para|strong="H3588"\w* otros aparte \w de|strong="H3588"\w* ellos.   
\p
