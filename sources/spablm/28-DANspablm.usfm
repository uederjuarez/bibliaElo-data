\v 9 \w Y|strong="H3068"\w* \w de|strong="H4480"\w* uno \w de|strong="H4480"\w* \w ellos|strong="H1992"\w* \w salió|strong="H3318"\w* un \w cuerno|strong="H7161"\w* pequeño, \w que|strong="H4480"\w* \w creció|strong="H1431"\w* \w mucho|strong="H3499"\w* \w hacia|strong="H4480"\w* \w el|strong="H1992"\w* sur, \w hacia|strong="H4480"\w* \w el|strong="H1992"\w* \w oriente|strong="H4217"\w* y \w hacia|strong="H4480"\w* la tierra gloriosa.  
\v 10 \w Se|strong="H4480"\w* \w engrandeció|strong="H1431"\w* \w hasta|strong="H5704"\w* \w el|strong="H5307"\w* \w ejército|strong="H6635"\w* \w del|strong="H4480"\w* \w cielo|strong="H8064"\w*; \w y|strong="H5704"\w* \w echó|strong="H5307"\w* \w por|strong="H4480"\w* tierra \w a|strong="H3068"\w* una parte \w del|strong="H4480"\w* \w ejército|strong="H6635"\w* \w y|strong="H5704"\w* \w de|strong="H4480"\w* las \w estrellas|strong="H3556"\w*, \w y|strong="H5704"\w* las pisoteó.  
\v 11 \w Aun|strong="H5704"\w* \w se|strong="H4480"\w* \w engrandeció|strong="H1431"\w* \w contra|strong="H4480"\w* el \w Príncipe|strong="H8269"\w* \w de|strong="H4480"\w* los \w ejércitos|strong="H6635"\w*, \w y|strong="H5704"\w* \w por|strong="H4480"\w* él \w fue|strong="H6635"\w* quitado el sacrificio \w continuo|strong="H8548"\w*, \w y|strong="H5704"\w* el lugar \w de|strong="H4480"\w* su \w santuario|strong="H4720"\w* \w fue|strong="H6635"\w* \w echado|strong="H7993"\w* \w por|strong="H4480"\w* tierra.  
\v 12 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w prevaricación|strong="H6588"\w* \w le|strong="H5921"\w* \w fue|strong="H6635"\w* \w entregado|strong="H5414"\w* \w el|strong="H5921"\w* \w ejército|strong="H6635"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* sacrificio \w continuo|strong="H8548"\w*; \w y|strong="H5921"\w* \w echó|strong="H7993"\w* \w por|strong="H5921"\w* tierra \w la|strong="H5921"\w* verdad, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* su voluntad, \w y|strong="H5921"\w* prosperó.   
\p
\v 13 Entonces \w oí|strong="H8085"\w* \w hablar|strong="H1696"\w* \w a|strong="H3068"\w* un \w santo|strong="H6918"\w*; \w y|strong="H5704"\w* otro \w santo|strong="H6918"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* aquel \w que|strong="H5704"\w* \w hablaba|strong="H1696"\w*: «¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* durará la \w visión|strong="H2377"\w* del sacrificio \w continuo|strong="H8548"\w*, \w y|strong="H5704"\w* \w de|strong="H5704"\w* la \w prevaricación|strong="H6588"\w* \w asoladora|strong="H8074"\w*, \w que|strong="H5704"\w* \w entrega|strong="H5414"\w* el \w santuario|strong="H6944"\w* \w y|strong="H5704"\w* el \w ejército|strong="H6635"\w* \w para|strong="H5704"\w* ser pisoteados?»   
\p
\v 14 \w Y|strong="H3068"\w* él me dijo: «\w Hasta|strong="H5704"\w* dos \w mil|strong="H3967"\w* \w trescientas|strong="H7969"\w* tardes \w y|strong="H5704"\w* mañanas; \w luego|strong="H5704"\w* el \w santuario|strong="H6944"\w* será purificado».   
\p
\v 15 \w Aconteció|strong="H1961"\w* \w que|strong="H1961"\w* mientras \w yo|strong="H2009"\w*, \w Daniel|strong="H1840"\w*, consideraba la \w visión|strong="H2377"\w* y \w procuraba|strong="H1245"\w* comprenderla, he \w aquí|strong="H2009"\w* \w se|strong="H1961"\w* \w puso|strong="H5975"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* \w mí|strong="H2009"\w* uno con \w apariencia|strong="H4758"\w* \w de|strong="H5048"\w* \w hombre|strong="H1397"\w*.  
