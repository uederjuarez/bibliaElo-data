\p
\v 17 \w Vino|strong="H5307"\w* \w luego|strong="H6256"\w* \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* \w donde|strong="H5921"\w* \w yo|strong="H3588"\w* \w estaba|strong="H5975"\w*; \w y|strong="H3588"\w* \w con|strong="H5921"\w* \w su|strong="H3588"\w* venida \w me|strong="H5921"\w* asombré, \w y|strong="H3588"\w* \w caí|strong="H5307"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w*. \w Pero|strong="H3588"\w* \w él|strong="H5921"\w* \w me|strong="H5921"\w* dijo: «Entiende, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w porque|strong="H3588"\w* \w la|strong="H5921"\w* \w visión|strong="H2377"\w* \w es|strong="H3588"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w del|strong="H5921"\w* \w fin|strong="H7093"\w*».   
\p
