\v 19 \w Y|strong="H3068"\w* dijo: “He \w aquí|strong="H2005"\w* \w yo|strong="H3588"\w* \w te|strong="H3588"\w* enseñaré lo \w que|strong="H3588"\w* ha \w de|strong="H3588"\w* venir al \w fin|strong="H7093"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* ira; \w porque|strong="H3588"\w* eso \w es|strong="H1961"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w tiempo|strong="H4150"\w* \w señalado|strong="H4150"\w* del \w fin|strong="H7093"\w*.  
\v 20 En cuanto \w al|strong="H4428"\w* carnero que \w viste|strong="H7200"\w*, que \w tenía|strong="H1167"\w* dos \w cuernos|strong="H7161"\w*, estos son \w los|strong="H1167"\w* \w reyes|strong="H4428"\w* de \w Media|strong="H4074"\w* y de \w Persia|strong="H6539"\w*.  
\v 21 \w El|strong="H1931"\w* \w macho|strong="H8163"\w* cabrío peludo \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5869"\w* \w Grecia|strong="H3120"\w*, y \w el|strong="H1931"\w* \w cuerno|strong="H7161"\w* \w grande|strong="H1419"\w* \w que|strong="H1931"\w* \w tenía|strong="H1931"\w* entre \w sus|strong="H1931"\w* \w ojos|strong="H5869"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w primer|strong="H7223"\w* \w rey|strong="H4428"\w*.  
