\v 35 \w También|strong="H5750"\w* algunos \w de|strong="H4480"\w* \w los|strong="H3588"\w* sabios \w caerán|strong="H3782"\w* \w para|strong="H5704"\w* ser depurados \w y|strong="H3588"\w* limpiados \w y|strong="H3588"\w* emblanquecidos, \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w tiempo|strong="H6256"\w* \w determinado|strong="H7093"\w*; \w porque|strong="H3588"\w* \w el|strong="H3588"\w* plazo \w aún|strong="H5750"\w* \w no|strong="H3588"\w* \w se|strong="H4480"\w* ha cumplido.   
\p
\v 36 “\w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w hará|strong="H6213"\w* \w su|strong="H3588"\w* \w voluntad|strong="H7522"\w*, \w y|strong="H3588"\w* \w se|strong="H5921"\w* ensoberbecerá, \w y|strong="H3588"\w* \w se|strong="H5921"\w* engrandecerá \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* dios; \w y|strong="H3588"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* Dios \w de|strong="H5921"\w* \w los|strong="H5921"\w* dioses \w hablará|strong="H1696"\w* \w maravillas|strong="H6381"\w*, \w y|strong="H3588"\w* \w prosperará|strong="H6743"\w*, \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* sea consumada \w la|strong="H5921"\w* ira; \w porque|strong="H3588"\w* \w lo|strong="H5921"\w* determinado \w se|strong="H5921"\w* \w cumplirá|strong="H6213"\w*.  
\v 37 \w No|strong="H3808"\w* hará caso \w del|strong="H5921"\w* dios \w de|strong="H5921"\w* sus padres, \w ni|strong="H3808"\w* \w del|strong="H5921"\w* \w amor|strong="H2532"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* mujeres; \w ni|strong="H3808"\w* respetará \w a|strong="H3068"\w* dios \w alguno|strong="H3605"\w*, \w porque|strong="H3588"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w se|strong="H5921"\w* engrandecerá.  
\v 38 \w Mas|strong="H5921"\w* honrará \w en|strong="H5921"\w* su lugar \w al|strong="H5921"\w* dios \w de|strong="H5921"\w* \w las|strong="H5921"\w* fortalezas, un dios \w que|strong="H3808"\w* sus padres \w no|strong="H3808"\w* \w conocieron|strong="H3045"\w*; \w lo|strong="H3808"\w* honrará \w con|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w plata|strong="H3701"\w*, \w con|strong="H5921"\w* piedras \w preciosas|strong="H3368"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w cosas|strong="H3045"\w* \w de|strong="H5921"\w* gran \w precio|strong="H3701"\w*.  
\v 39 \w Con|strong="H5973"\w* un dios \w ajeno|strong="H5236"\w* se \w hará|strong="H6213"\w* \w de|strong="H5973"\w* las fortalezas \w más|strong="H7227"\w* inexpugnables, \w y|strong="H3519"\w* colmará \w de|strong="H5973"\w* honores \w a|strong="H3068"\w* \w los|strong="H5973"\w* que \w le|strong="H5973"\w* reconozcan; \w los|strong="H5973"\w* \w hará|strong="H6213"\w* gobernar sobre \w muchos|strong="H7227"\w*, \w y|strong="H3519"\w* por \w precio|strong="H4242"\w* \w repartirá|strong="H2505"\w* la tierra.   
\p
\v 40 “Pero \w al|strong="H5921"\w* cabo \w del|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w del|strong="H5921"\w* sur contenderá \w con|strong="H5973"\w* \w él|strong="H5921"\w*; \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w del|strong="H5921"\w* \w norte|strong="H6828"\w* \w se|strong="H5921"\w* \w levantará|strong="H8175"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w como|strong="H5973"\w* un torbellino, \w con|strong="H5973"\w* \w carros|strong="H7393"\w* \w y|strong="H5921"\w* gente \w de|strong="H5921"\w* \w a|strong="H3068"\w* caballo, \w y|strong="H5921"\w* \w muchas|strong="H7227"\w* naves; \w y|strong="H5921"\w* entrará \w por|strong="H5921"\w* \w las|strong="H5921"\w* tierras, \w e|strong="H3068"\w* \w inundará|strong="H7857"\w*, \w y|strong="H5921"\w* \w pasará|strong="H5674"\w*.  
\v 41 Entrará \w a|strong="H3068"\w* la tierra gloriosa, y \w muchas|strong="H7227"\w* provincias \w caerán|strong="H3782"\w*; pero \w escaparán|strong="H4422"\w* \w de|strong="H1121"\w* su \w mano|strong="H3027"\w* Edom y \w Moab|strong="H4124"\w*, y la mayoría \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón.  
\v 42 \w Extenderá|strong="H7971"\w* su \w mano|strong="H3027"\w* \w contra|strong="H1961"\w* las tierras, y \w no|strong="H3808"\w* \w escapará|strong="H6413"\w* el país de \w Egipto|strong="H4714"\w*.  
\v 43 Se apoderará de \w los|strong="H3605"\w* tesoros de \w oro|strong="H2091"\w* y \w plata|strong="H3701"\w*, y de \w todas|strong="H3605"\w* las cosas preciosas de \w Egipto|strong="H4714"\w*; y \w los|strong="H3605"\w* libios y \w los|strong="H3605"\w* etíopes seguirán sus pasos.  
\v 44 Pero noticias del \w oriente|strong="H4217"\w* y del \w norte|strong="H6828"\w* lo espantarán, y \w saldrá|strong="H3318"\w* con \w gran|strong="H1419"\w* \w ira|strong="H2534"\w* para \w destruir|strong="H2763"\w* y matar \w a|strong="H3068"\w* \w muchos|strong="H7227"\w*.  
\v 45 \w Y|strong="H3068"\w* plantará las tiendas \w de|strong="H5704"\w* su palacio entre los \w mares|strong="H3220"\w* \w y|strong="H5704"\w* el \w monte|strong="H2022"\w* glorioso \w y|strong="H5704"\w* \w santo|strong="H6944"\w*; pero llegará \w a|strong="H3068"\w* su \w fin|strong="H7093"\w*, \w y|strong="H5704"\w* no tendrá quien le ayude.   
\c 12
\p
\v 1 «\w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w se|strong="H1961"\w* levantará \w Miguel|strong="H4317"\w*, \w el|strong="H1931"\w* \w gran|strong="H1419"\w* \w príncipe|strong="H8269"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w de|strong="H5921"\w* parte \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* tu \w pueblo|strong="H5971"\w*; \w y|strong="H5921"\w* \w será|strong="H1961"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5921"\w* \w angustia|strong="H6869"\w*, \w cual|strong="H1931"\w* \w nunca|strong="H3808"\w* \w fue|strong="H1961"\w* \w desde|strong="H5704"\w* \w que|strong="H1931"\w* \w hubo|strong="H1961"\w* \w nación|strong="H1471"\w* \w hasta|strong="H5704"\w* \w entonces|strong="H6256"\w*. Pero \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w será|strong="H1961"\w* \w libertado|strong="H4422"\w* tu \w pueblo|strong="H5971"\w*, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1931"\w* \w se|strong="H1961"\w* \w hallen|strong="H4672"\w* \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w libro|strong="H5612"\w*.  
\v 2 \w Y|strong="H3068"\w* \w muchos|strong="H7227"\w* de los que duermen en el \w polvo|strong="H6083"\w* de la \w tierra|strong="H6083"\w* serán despertados, unos para \w vida|strong="H2416"\w* \w eterna|strong="H5769"\w*, y otros para vergüenza y \w confusión|strong="H5769"\w* \w perpetua|strong="H5769"\w*.  
\v 3 Los entendidos \w resplandecerán|strong="H2096"\w* como el resplandor del firmamento; y los que enseñan la justicia \w a|strong="H3068"\w* la \w multitud|strong="H7227"\w*, como las \w estrellas|strong="H3556"\w* \w a|strong="H3068"\w* \w perpetua|strong="H5769"\w* \w eternidad|strong="H5703"\w*.  
\v 4 Pero tú, \w Daniel|strong="H1840"\w*, \w cierra|strong="H5640"\w* las \w palabras|strong="H1697"\w* \w y|strong="H5704"\w* \w sella|strong="H2856"\w* el \w libro|strong="H5612"\w* \w hasta|strong="H5704"\w* el \w tiempo|strong="H6256"\w* del \w fin|strong="H7093"\w*. \w Muchos|strong="H7227"\w* correrán \w de|strong="H5704"\w* aquí \w para|strong="H5704"\w* allá, \w y|strong="H5704"\w* la \w ciencia|strong="H1847"\w* se \w aumentará|strong="H7235"\w*».   
\p
\v 5 \w Y|strong="H3068"\w* \w yo|strong="H2009"\w*, \w Daniel|strong="H1840"\w*, \w miré|strong="H7200"\w*, y he \w aquí|strong="H2008"\w* otros \w dos|strong="H8147"\w* que \w estaban|strong="H5975"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w*, \w el|strong="H2975"\w* uno \w a|strong="H3068"\w* \w esta|strong="H5975"\w* orilla del \w río|strong="H2975"\w*, y \w el|strong="H2975"\w* \w otro|strong="H8193"\w* \w a|strong="H3068"\w* la otra orilla del \w río|strong="H2975"\w*.  
\v 6 \w Y|strong="H3068"\w* dijo uno \w al|strong="H5704"\w* varón \w vestido|strong="H3847"\w* \w de|strong="H5704"\w* lino, \w que|strong="H5704"\w* estaba \w sobre|strong="H4605"\w* las \w aguas|strong="H4325"\w* del \w río|strong="H2975"\w*: «¿\w Cuándo|strong="H4970"\w* será \w el|strong="H2975"\w* \w fin|strong="H7093"\w* \w de|strong="H5704"\w* estas \w maravillas|strong="H6382"\w*?»   
\p
\v 7 \w Y|strong="H3068"\w* \w oí|strong="H8085"\w* al varón \w vestido|strong="H3847"\w* \w de|strong="H3588"\w* lino, \w que|strong="H3588"\w* \w estaba|strong="H2416"\w* \w sobre|strong="H4605"\w* las \w aguas|strong="H4325"\w* \w del|strong="H2677"\w* \w río|strong="H2975"\w*, \w el|strong="H3588"\w* \w cual|strong="H3588"\w* \w alzó|strong="H7311"\w* \w su|strong="H3588"\w* \w diestra|strong="H3225"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w siniestra|strong="H8040"\w* al \w cielo|strong="H8064"\w*, \w y|strong="H3588"\w* \w juró|strong="H7650"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w vive|strong="H2416"\w* \w por|strong="H3588"\w* \w los|strong="H3605"\w* \w siglos|strong="H5769"\w*, \w que|strong="H3588"\w* será \w por|strong="H3588"\w* \w tiempo|strong="H4150"\w*, \w tiempos|strong="H4150"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* mitad \w de|strong="H3588"\w* un \w tiempo|strong="H4150"\w*. \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w se|strong="H5971"\w* \w acabe|strong="H3615"\w* \w la|strong="H3588"\w* dispersión \w del|strong="H2677"\w* \w poder|strong="H3027"\w* \w del|strong="H2677"\w* \w pueblo|strong="H5971"\w* \w santo|strong="H6944"\w*, \w todas|strong="H3605"\w* estas cosas serán cumplidas.   
\p
\v 8 \w Y|strong="H3068"\w* yo \w oí|strong="H8085"\w*, \w mas|strong="H3808"\w* \w no|strong="H3808"\w* entendí. \w Y|strong="H3068"\w* dije: «Señor mío, ¿\w cuál|strong="H4100"\w* \w será|strong="H3808"\w* el fin de estas cosas?»   
\p
\v 9 \w Él|strong="H3588"\w* respondió: “\w Anda|strong="H3212"\w*, \w Daniel|strong="H1840"\w*, \w pues|strong="H3588"\w* estas \w palabras|strong="H1697"\w* están cerradas \w y|strong="H3588"\w* selladas \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w tiempo|strong="H6256"\w* del \w fin|strong="H7093"\w*.  
\v 10 \w Muchos|strong="H7227"\w* serán limpios, emblanquecidos y purificados; \w los|strong="H3605"\w* \w impíos|strong="H7563"\w* obrarán \w impíamente|strong="H7561"\w*, y \w ninguno|strong="H3808"\w* de \w los|strong="H3605"\w* \w impíos|strong="H7563"\w* entenderá, pero \w los|strong="H3605"\w* entendidos comprenderán.   
\p
\v 11 “\w Y|strong="H3068"\w* desde el \w tiempo|strong="H6256"\w* \w en|strong="H5493"\w* \w que|strong="H3117"\w* sea quitado el sacrificio \w continuo|strong="H8548"\w* \w hasta|strong="H3117"\w* la \w abominación|strong="H8251"\w* desoladora, \w habrá|strong="H3117"\w* \w mil|strong="H3967"\w* \w doscientos|strong="H3967"\w* \w noventa|strong="H8673"\w* \w días|strong="H3117"\w*.  
\v 12 Bienaventurado el \w que|strong="H3117"\w* espere, y llegue \w a|strong="H3068"\w* \w mil|strong="H3967"\w* \w trescientos|strong="H7969"\w* \w treinta|strong="H7970"\w* y \w cinco|strong="H2568"\w* \w días|strong="H3117"\w*.   
\p
\v 13 «\w Y|strong="H3068"\w* tú \w irás|strong="H3212"\w* \w hasta|strong="H3117"\w* el \w fin|strong="H7093"\w*, y reposarás, y te levantarás para recibir tu heredad al \w fin|strong="H7093"\w* de los \w días|strong="H3117"\w*».   