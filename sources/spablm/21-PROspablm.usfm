\v 24 \w Hace|strong="H6213"\w* \w telas|strong="H5466"\w* \w de|strong="H5414"\w* lino y las \w vende|strong="H4376"\w*,  
\q2 y \w da|strong="H5414"\w* \w cintas|strong="H2289"\w* al mercader.   
\q1
\v 25 Fuerza \w y|strong="H5797"\w* honor son su vestidura;  
\q2 \w y|strong="H5797"\w* se ríe de lo por venir.   
\q1
\v 26 \w Abre|strong="H6605"\w* su \w boca|strong="H6310"\w* \w con|strong="H5921"\w* \w sabiduría|strong="H2451"\w*,  
\q2 \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* clemencia \w está|strong="H5921"\w* \w en|strong="H5921"\w* su \w lengua|strong="H3956"\w*.   
\q1
\v 27 \w Considera|strong="H6822"\w* la marcha de su \w casa|strong="H1004"\w*,  
\q2 y \w no|strong="H3808"\w* come el \w pan|strong="H3899"\w* de balde.   
\q1
\v 28 Se \w levantan|strong="H6965"\w* sus \w hijos|strong="H1121"\w* y la llaman bienaventurada;  
\q2 y su \w marido|strong="H1167"\w* también la \w alaba|strong="H1984"\w*:   
\q1
\v 29 «\w Muchas|strong="H7227"\w* \w mujeres|strong="H1323"\w* \w hicieron|strong="H6213"\w* \w el|strong="H5921"\w* bien;  
\q2 \w mas|strong="H5921"\w* \w tú|strong="H6213"\w* sobrepasas \w a|strong="H3068"\w* \w todas|strong="H3605"\w*».   
\q1
\v 30 \w Engañosa|strong="H8267"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w gracia|strong="H2580"\w*, y vana \w la|strong="H1931"\w* \w hermosura|strong="H3308"\w*;  
