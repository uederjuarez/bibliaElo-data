\mt1 Proverbios  
\c 1
\p
\v 1 \w Los|strong="H1121"\w* \w proverbios|strong="H4912"\w* \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*:   
\q1
\v 2 para conocer \w sabiduría|strong="H2451"\w* y disciplina; para comprender los dichos de \w la|strong="H2451"\w* inteligencia;  
\q2 para discernir las palabras del entendimiento;   
\q1
\v 3 para \w recibir|strong="H3947"\w* instrucción en el trato sabio,  
\q2 en la rectitud, la \w justicia|strong="H6664"\w* y la equidad;   
\q1
\v 4 \w para|strong="H5414"\w* \w dar|strong="H5414"\w* sagacidad \w a|strong="H3068"\w* los \w simples|strong="H6612"\w*,  
\q2 \w conocimiento|strong="H1847"\w* y discreción al joven —   
\q1
\v 5 para que el \w sabio|strong="H2450"\w* \w escuche|strong="H8085"\w* y aumente su saber;  
\q2 para que el hombre de entendimiento adquiera \w sabios|strong="H2450"\w* consejos;   
\q1
\v 6 para entender \w los|strong="H2450"\w* \w proverbios|strong="H4912"\w* y las parábolas,  
\q2 las \w palabras|strong="H1697"\w* y \w los|strong="H2450"\w* enigmas \w de|strong="H1697"\w* \w los|strong="H2450"\w* \w sabios|strong="H2450"\w*.   
\b  
\q1
\v 7 El \w temor|strong="H3374"\w* de Yahvé\f + \fr 1:7 \ft «Yahvé» es el nombre propio de Dios, a veces traducido como «SEÑOR» (en mayúsculas) en otras traducciones.\f* es el \w principio|strong="H7225"\w* de \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*,  
\q2 \w mas|strong="H2451"\w* los necios desprecian \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* y \w la|strong="H2451"\w* instrucción.   
\q1
\v 8 \w Escucha|strong="H8085"\w*, \w hijo|strong="H1121"\w* mío, la instrucción \w de|strong="H1121"\w* tu padre,  
\q2 y no abandones la \w enseñanza|strong="H4148"\w* \w de|strong="H1121"\w* tu madre;   
\q1
\v 9 \w pues|strong="H3588"\w* \w serán|strong="H1992"\w* corona \w de|strong="H3588"\w* \w gracia|strong="H2580"\w* \w para|strong="H3588"\w* tu \w cabeza|strong="H7218"\w*,  
\q2 \w y|strong="H3588"\w* collares \w para|strong="H3588"\w* tu cuello.   
\q1
\v 10 \w Hijo|strong="H1121"\w* mío, si \w los|strong="H1121"\w* \w pecadores|strong="H2400"\w* quisieren seducirte,  
\q2 no consientas en ello.   
\q1
\v 11 Si dijeren: «\w Ven|strong="H3212"\w* con nosotros;  
\q2 pongamos asechanzas para derramar \w sangre|strong="H1818"\w*;  
\q2 \w acechemos|strong="H6845"\w* al \w inocente|strong="H5355"\w* sin motivo;   
\q1
\v 12 devorémoslos \w vivos|strong="H2416"\w* como el Seol, \f + \fr 1:12 \ft El Seol es el lugar de los muertos.\f*  
\q2 y enteros, como los que \w descienden|strong="H3381"\w* \w a|strong="H3068"\w* la fosa;   
\q1
\v 13 \w hallaremos|strong="H4672"\w* \w toda|strong="H3605"\w* suerte de \w riquezas|strong="H1952"\w*,  
\q2 llenaremos nuestras \w casas|strong="H1004"\w* con \w el|strong="H3605"\w* botín;   
\q1
\v 14 \w echa|strong="H5307"\w* tu \w suerte|strong="H1486"\w* con \w nosotros|strong="H3605"\w*;  
\q2 \w tengamos|strong="H1961"\w* \w todos|strong="H3605"\w* una sola \w bolsa|strong="H3599"\w*» —   
\q1
\v 15 \w hijo|strong="H1121"\w* mío, \w no|strong="H1870"\w* \w andes|strong="H3212"\w* \w en|strong="H3212"\w* \w el|strong="H1121"\w* \w camino|strong="H1870"\w* con ellos;  
\q2 \w aparta|strong="H4513"\w* tu \w pie|strong="H7272"\w* \w de|strong="H1121"\w* sus \w veredas|strong="H5410"\w*,   
\q1
\v 16 \w porque|strong="H3588"\w* sus \w pies|strong="H7272"\w* \w corren|strong="H7323"\w* hacia \w el|strong="H3588"\w* \w mal|strong="H7451"\w*,  
\q2 \w y|strong="H3588"\w* se apresuran \w a|strong="H3068"\w* derramar \w sangre|strong="H1818"\w*.   
\q1
\v 17 \w Pues|strong="H3588"\w* \w en|strong="H3588"\w* \w vano|strong="H2600"\w* se tiende \w la|strong="H3605"\w* \w red|strong="H7568"\w* ante \w los|strong="H1167"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* \w cualquier|strong="H3605"\w* \w ave|strong="H1167"\w*;   
\q1
\v 18 mas \w ellos|strong="H1992"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* propia \w sangre|strong="H1818"\w* ponen asechanzas,  
\q2 y contra \w su|strong="H1992"\w* propia \w vida|strong="H5315"\w* tienden la red.   
\q1
\v 19 \w Tales|strong="H3651"\w* son las sendas de \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* es dado \w a|strong="H3068"\w* \w la|strong="H3605"\w* codicia;  
\q2 \w la|strong="H3605"\w* \w cual|strong="H5315"\w* \w quita|strong="H3947"\w* \w la|strong="H3605"\w* \w vida|strong="H5315"\w* de sus poseedores.   
\b  
\q1
\v 20 La \w sabiduría|strong="H2454"\w* \w clama|strong="H7442"\w* \w por|strong="H5414"\w* las \w calles|strong="H7339"\w*;  
\q2 alza su \w voz|strong="H6963"\w* en las \w plazas|strong="H7339"\w*;   
\q1
\v 21 \w clama|strong="H7121"\w* en los \w lugares|strong="H5892"\w* de mucho estruendo;  
\q2 \w a|strong="H3068"\w* la entrada de las \w puertas|strong="H8179"\w* de la \w ciudad|strong="H5892"\w* pronuncia sus palabras:   
\q1
\v 22 “¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w*, oh \w simples|strong="H6612"\w*, amaréis la simpleza?  
\q2 ¿\w Y|strong="H3068"\w* \w hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* \w los|strong="H1992"\w* \w burladores|strong="H3944"\w* \w se|strong="H1992"\w* deleitarán \w en|strong="H5704"\w* \w el|strong="H1992"\w* escarnio,  
\q2 \w y|strong="H5704"\w* \w los|strong="H1992"\w* insensatos \w aborrecerán|strong="H8130"\w* \w el|strong="H1992"\w* \w conocimiento|strong="H1847"\w*?   
\q1
\v 23 \w Volveos|strong="H7725"\w* \w a|strong="H3068"\w* \w mi|strong="H2009"\w* \w reprensión|strong="H8433"\w*.  
\q2 He \w aquí|strong="H2009"\w*,\f + \fr 1:23 \ft «He aquí», de «הִנֵּה», significa mirar, fijarse, observar, ver o contemplar. Se utiliza a menudo como interjección.\f* \w yo|strong="H2009"\w* derramaré \w mi|strong="H2009"\w* \w espíritu|strong="H7307"\w* sobre vosotros;  
\q2 os haré \w saber|strong="H3045"\w* mis \w palabras|strong="H1697"\w*.   
\q1
\v 24 \w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w llamé|strong="H7121"\w* y \w no|strong="H3985"\w* quisisteis oír,  
\q2 \w extendí|strong="H5186"\w* mi \w mano|strong="H3027"\w* y \w no|strong="H3985"\w* hubo quien atendiese,   
\q1
\v 25 \w sino|strong="H3808"\w* \w que|strong="H3808"\w* habéis desechado \w todo|strong="H3605"\w* \w consejo|strong="H6098"\w* mío  
\q2 y mi \w reprensión|strong="H8433"\w* \w no|strong="H3808"\w* habéis querido;   
\q1
\v 26 \w también|strong="H1571"\w* yo me reiré de vuestra desdicha;  
\q2 me burlaré \w cuando|strong="H1571"\w* os viniere lo \w que|strong="H1571"\w* teméis,   
\q1
\v 27 cuando viniere \w como|strong="H5921"\w* una tormenta \w lo|strong="H5921"\w* \w que|strong="H5921"\w* teméis,  
\q2 \w y|strong="H5921"\w* vuestra calamidad llegare \w como|strong="H5921"\w* un \w torbellino|strong="H5492"\w*;  
\q2 cuando \w sobre|strong="H5921"\w* vosotros viniere \w tribulación|strong="H6869"\w* \w y|strong="H5921"\w* \w angustia|strong="H6869"\w*.   
\q1
\v 28 Entonces me \w llamaréis|strong="H7121"\w*, y \w no|strong="H3808"\w* \w responderé|strong="H6030"\w*;  
\q2 me buscaréis con diligencia, y \w no|strong="H3808"\w* me \w hallaréis|strong="H4672"\w*.   
\q1
\v 29 \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w aborrecieron|strong="H8130"\w* \w la|strong="H3588"\w* \w sabiduría|strong="H1847"\w*,  
\q2 \w y|strong="H3588"\w* \w no|strong="H3808"\w* escogieron \w el|strong="H3588"\w* \w temor|strong="H3374"\w* \w de|strong="H3588"\w* Yahvé,   
\q1
\v 30 \w ni|strong="H3808"\w* quisieron mi \w consejo|strong="H6098"\w*,  
\q2 y menospreciaron \w toda|strong="H3605"\w* mi \w reprensión|strong="H8433"\w*,   
\q1
\v 31 comerán, pues, del \w fruto|strong="H6529"\w* \w de|strong="H7646"\w* su \w camino|strong="H1870"\w*,  
\q2 y se hartarán \w de|strong="H7646"\w* sus propios \w consejos|strong="H4156"\w*.   
\q1
\v 32 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* desvío \w de|strong="H3588"\w* \w los|strong="H3588"\w* ignorantes \w los|strong="H3588"\w* \w matará|strong="H2026"\w*,  
\q2 \w y|strong="H3588"\w* \w la|strong="H3588"\w* prosperidad \w de|strong="H3588"\w* \w los|strong="H3588"\w* necios \w los|strong="H3588"\w* echará \w a|strong="H3068"\w* perder.   
\q1
\v 33 Mas el \w que|strong="H6343"\w* me \w oyere|strong="H8085"\w*, \w habitará|strong="H7931"\w* confiadamente  
\q2 y vivirá tranquilo, sin \w temor|strong="H6343"\w* del \w mal|strong="H7451"\w*”.   
\c 2
\q1
\v 1 \w Hijo|strong="H1121"\w* mío, si recibes mis palabras  
\q2 y atesoras mis \w mandamientos|strong="H4687"\w* dentro \w de|strong="H1121"\w* ti,   
\q1
\v 2 haciendo que tu oído se \w incline|strong="H5186"\w* \w a|strong="H3068"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*  
\q2 y entregues tu \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* \w la|strong="H2451"\w* prudencia;   
\q1
\v 3 \w si|strong="H3588"\w* \w de|strong="H3588"\w* veras invocas \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w inteligencia|strong="H8394"\w*  
\q2 \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* prudencia elevas tu \w voz|strong="H6963"\w*;   
\q1
\v 4 si como \w a|strong="H3068"\w* la \w plata|strong="H3701"\w* la \w buscas|strong="H1245"\w*  
\q2 y la rastreas como \w a|strong="H3068"\w* \w tesoros|strong="H4301"\w* escondidos,   
\q1
\v 5 entonces entenderás el \w temor|strong="H3374"\w* de Yahvé  
\q2 y \w hallarás|strong="H4672"\w* el \w conocimiento|strong="H1847"\w* de \w Dios|strong="H3068"\w*. \f + \fr 2:5 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f*   
\q1
\v 6 \w Porque|strong="H3588"\w* Yahvé \w da|strong="H5414"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*;  
\q2 \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w boca|strong="H6310"\w* proceden \w la|strong="H2451"\w* \w ciencia|strong="H1847"\w* \w y|strong="H3588"\w* \w la|strong="H2451"\w* \w inteligencia|strong="H8394"\w*.   
\q1
\v 7 Él reserva la sana \w sabiduría|strong="H8454"\w* para los \w rectos|strong="H3477"\w*;  
\q2 es broquel para los que \w caminan|strong="H1980"\w* en \w integridad|strong="H8537"\w*,   
\q1
\v 8 \w a|strong="H3068"\w* fin de que \w guarden|strong="H8104"\w* las sendas del \w juicio|strong="H4941"\w*  
\q2 y preserve el \w camino|strong="H1870"\w* de sus \w santos|strong="H2623"\w*.   
\q1
\v 9 Entonces entenderás \w justicia|strong="H6664"\w*, \w juicio|strong="H4941"\w*  
\q2 y equidad, y \w todo|strong="H3605"\w* \w buen|strong="H2896"\w* \w camino|strong="H4570"\w*.   
\q1
\v 10 \w Cuando|strong="H3588"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* entrare \w en|strong="H3588"\w* tu \w corazón|strong="H3820"\w*  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w conocimiento|strong="H1847"\w* fuere grato \w a|strong="H3068"\w* tu \w alma|strong="H5315"\w*,   
\q1
\v 11 \w la|strong="H5921"\w* discreción \w te|strong="H5921"\w* \w guardará|strong="H8104"\w*;  
\q2 \w te|strong="H5921"\w* preservará \w la|strong="H5921"\w* \w inteligencia|strong="H8394"\w*,   
\q1
\v 12 para librarte del \w mal|strong="H7451"\w* \w camino|strong="H1870"\w*,  
\q2 \w de|strong="H7451"\w* los hombres que \w hablan|strong="H1696"\w* \w perversidades|strong="H8419"\w*,   
\q1
\v 13 que \w abandonan|strong="H5800"\w* las sendas \w derechas|strong="H3476"\w*  
\q2 para \w andar|strong="H3212"\w* \w por|strong="H1870"\w* \w caminos|strong="H1870"\w* de \w tinieblas|strong="H2822"\w*;   
\q1
\v 14 que se alegran \w haciendo|strong="H6213"\w* \w el|strong="H6213"\w* \w mal|strong="H7451"\w*,  
\q2 que se huelgan en las \w perversidades|strong="H8419"\w* del vicio;   
\q1
\v 15 cuyas veredas son torcidas  
\q2 y torcidos sus \w caminos|strong="H4570"\w*;   
\q1
\v 16 para librarte de la mujer \w ajena|strong="H5237"\w*,  
\q2 de la \w extraña|strong="H5237"\w* que halaga con sus palabras,   
\q1
\v 17 la cual abandona al compañero \w de|strong="H7911"\w* su \w juventud|strong="H5271"\w*  
\q2 y se olvida del \w pacto|strong="H1285"\w* \w de|strong="H7911"\w* su Dios.   
\q1
\v 18 \w Por|strong="H3588"\w* lo \w cual|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w* se desliza hacia \w la|strong="H3588"\w* \w muerte|strong="H4194"\w*,  
\q2 \w y|strong="H3588"\w* sus sendas hacia las sombras.   
\q1
\v 19 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3808"\w* \w a|strong="H3068"\w* \w ella|strong="H3605"\w* van, \w no|strong="H3808"\w* \w volverán|strong="H7725"\w*,  
\q2 \w ni|strong="H3808"\w* alcanzarán \w los|strong="H3605"\w* senderos de \w la|strong="H3605"\w* \w vida|strong="H2416"\w*.   
\q1
\v 20 Así \w andarás|strong="H3212"\w* \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* \w de|strong="H6662"\w* los \w buenos|strong="H2896"\w*  
\q2 y \w guardarás|strong="H8104"\w* las veredas \w de|strong="H6662"\w* los \w justos|strong="H6662"\w*;   
\q1
\v 21 \w porque|strong="H3588"\w* \w los|strong="H3588"\w* \w rectos|strong="H3477"\w* \w habitarán|strong="H7931"\w* \w la|strong="H3588"\w* tierra  
\q2 \w y|strong="H3588"\w* \w los|strong="H3588"\w* íntegros \w permanecerán|strong="H3498"\w* \w en|strong="H8549"\w* ella,   
\q1
\v 22 \w mas|strong="H4480"\w* los \w impíos|strong="H7563"\w* serán cortados \w de|strong="H4480"\w* la tierra  
\q2 y los prevaricadores serán \w de|strong="H4480"\w* \w ella|strong="H4480"\w* desarraigados.   
\c 3
\q1
\v 1 \w Hijo|strong="H1121"\w* mío, no te \w olvides|strong="H7911"\w* \w de|strong="H1121"\w* mi \w ley|strong="H8451"\w*, y tu \w corazón|strong="H3820"\w* \w guarde|strong="H5341"\w* mis \w mandamientos|strong="H4687"\w*;   
\q2
\v 2 \w porque|strong="H3588"\w* largura \w de|strong="H3588"\w* \w días|strong="H3117"\w* \w y|strong="H3588"\w* \w años|strong="H8141"\w* \w de|strong="H3588"\w* \w vida|strong="H2416"\w* \w y|strong="H3588"\w* \w paz|strong="H7965"\w* \w te|strong="H3588"\w* aumentarán.   
\q1
\v 3 Nunca \w se|strong="H5921"\w* aparten \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w la|strong="H5921"\w* \w misericordia|strong="H2617"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* verdad;  
\q2 \w átalas|strong="H7194"\w* \w a|strong="H3068"\w* tu cuello, \w escríbelas|strong="H3789"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tabla \w de|strong="H5921"\w* tu \w corazón|strong="H3820"\w*;   
\q1
\v 4 y \w hallarás|strong="H4672"\w* \w gracia|strong="H2580"\w* y \w buena|strong="H2896"\w* \w opinión|strong="H7922"\w* ante los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Dios y \w de|strong="H5869"\w* los hombres.   
\q1
\v 5 Fíate de Yahvé de \w todo|strong="H3605"\w* tu \w corazón|strong="H3820"\w*, y no te apoyes en tu propia prudencia.   
\q1
\v 6 \w Reconócelo|strong="H3045"\w* en \w todos|strong="H3605"\w* tus \w caminos|strong="H1870"\w*, y \w él|strong="H1931"\w* \w enderezará|strong="H3474"\w* tus veredas.   
\q1
\v 7 \w No|strong="H1961"\w* \w seas|strong="H1961"\w* \w sabio|strong="H2450"\w* \w en|strong="H5493"\w* tu propia opinión; \w teme|strong="H3372"\w* \w a|strong="H3068"\w* Yahvé y \w apártate|strong="H5493"\w* del \w mal|strong="H7451"\w*;   
\q1
\v 8 porque \w será|strong="H1961"\w* \w medicina|strong="H7500"\w* \w a|strong="H3068"\w* tu cuerpo, y refrigerio \w para|strong="H1961"\w* tus \w huesos|strong="H6106"\w*.   
\q1
\v 9 \w Honra|strong="H3513"\w* \w a|strong="H3068"\w* Yahvé con tus bienes, y con las \w primicias|strong="H7225"\w* de \w todos|strong="H3605"\w* tus \w frutos|strong="H8393"\w*;   
\q1
\v 10 y serán \w llenos|strong="H4390"\w* tus graneros con abundancia, y tus lagares \w rebosarán|strong="H6555"\w* de \w mosto|strong="H8492"\w*.   
\q1
\v 11 No menosprecies, \w hijo|strong="H1121"\w* mío, \w el|strong="H1121"\w* castigo \w de|strong="H1121"\w* Yahvé, ni te fatigues \w de|strong="H1121"\w* su \w corrección|strong="H4148"\w*;   
\q1
\v 12 \w porque|strong="H3588"\w* Yahvé al \w que|strong="H3588"\w* ama \w castiga|strong="H3198"\w*, \w como|strong="H3588"\w* \w el|strong="H3588"\w* padre al \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* quien quiere.   
\b  
\q1
\v 13 Bienaventurado el hombre que \w halla|strong="H4672"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*, y que obtiene \w la|strong="H2451"\w* \w inteligencia|strong="H8394"\w*;   
\q1
\v 14 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* ganancia \w es|strong="H3588"\w* \w mejor|strong="H2896"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* ganancia \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w plata|strong="H3701"\w*, \w y|strong="H3588"\w* sus \w frutos|strong="H8393"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* oro fino.   
\q1
