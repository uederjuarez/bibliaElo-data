\q2 y tu \w corazón|strong="H3820"\w* \w hablará|strong="H1696"\w* \w perversidades|strong="H8419"\w*.   
\q1
\v 34 \w Serás|strong="H1961"\w* \w como|strong="H1961"\w* el \w que|strong="H1961"\w* \w yace|strong="H7901"\w* en medio del \w mar|strong="H3220"\w*,  
\q2 \w o|strong="H3068"\w* \w como|strong="H1961"\w* el \w que|strong="H1961"\w* \w está|strong="H1961"\w* en la punta de un mastelero.   
\q1
\v 35 \w Y|strong="H3068"\w* dirás: «Me \w hirieron|strong="H5221"\w*, \w mas|strong="H5750"\w* \w no|strong="H1077"\w* me dolió;  
\q2 me azotaron, \w mas|strong="H5750"\w* \w no|strong="H1077"\w* lo sentí; \w cuando|strong="H4970"\w* despertare, \w aún|strong="H5750"\w* lo \w volveré|strong="H3254"\w* \w a|strong="H3068"\w* buscar».   
\c 24
\q1
\v 1 \w No|strong="H1961"\w* tengas \w envidia|strong="H7065"\w* \w de|strong="H7451"\w* \w los|strong="H1961"\w* hombres malvados,  
\q2 ni desees estar \w con|strong="H7065"\w* ellos;   
\q1
\v 2 \w porque|strong="H3588"\w* sus corazones traman \w la|strong="H3588"\w* violencia  
\q2 \w y|strong="H3588"\w* sus \w labios|strong="H8193"\w* \w hablan|strong="H1696"\w* \w de|strong="H3588"\w* iniquidad.   
\q1
\v 3 Con \w sabiduría|strong="H2451"\w* se \w edifica|strong="H1129"\w* una \w casa|strong="H1004"\w*,  
\q2 y con prudencia se establece;   
\q1
\v 4 con \w conocimiento|strong="H1847"\w* se llenan las cámaras  
\q2 de \w todo|strong="H3605"\w* tesoro \w preciado|strong="H3368"\w* y hermoso.   
\q1
\v 5 El \w hombre|strong="H1397"\w* \w sabio|strong="H2450"\w* es \w fuerte|strong="H5797"\w*,  
\q2 \w y|strong="H5797"\w* el \w hombre|strong="H1397"\w* de \w conocimiento|strong="H1847"\w* aumenta su \w poder|strong="H3581"\w*;   
\q1
\v 6 \w pues|strong="H3588"\w* \w con|strong="H3588"\w* sabios consejos \w harás|strong="H6213"\w* \w la|strong="H3588"\w* \w guerra|strong="H4421"\w*,  
\q2 \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w multitud|strong="H7230"\w* \w de|strong="H3588"\w* \w consejeros|strong="H3289"\w* está \w la|strong="H3588"\w* victoria.   
\q1
\v 7 Muy \w alta|strong="H7311"\w* está la \w sabiduría|strong="H2454"\w* para el fatuo;  
\q2 en la \w puerta|strong="H8179"\w* \w no|strong="H3808"\w* \w abrirá|strong="H6605"\w* él su \w boca|strong="H6310"\w*.   
\q1
\v 8 Al que \w maquina|strong="H2803"\w* hacer el \w mal|strong="H7489"\w*,  
\q2 le \w llamarán|strong="H7121"\w* intrigante.   
\q1
\v 9 El pensamiento del necio \w es|strong="H8441"\w* \w pecado|strong="H2403"\w*,  
\q2 y el escarnecedor \w es|strong="H8441"\w* \w abominación|strong="H8441"\w* \w a|strong="H3068"\w* los hombres.   
\q1
\v 10 Si flaqueas en el \w día|strong="H3117"\w* de la \w angustia|strong="H6869"\w*,  
\q2 tu \w fuerza|strong="H3581"\w* es pequeña.   
\q1
\v 11 ¡\w Libra|strong="H5337"\w* \w a|strong="H3068"\w* los que son llevados \w a|strong="H3068"\w* la \w muerte|strong="H4194"\w*!  
\q2 ¡Salva \w a|strong="H3068"\w* los que van tambaleándose al degolladero!   
\q1
\v 12 \w Si|strong="H3588"\w* dijeres: «He \w aquí|strong="H2088"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H1931"\w* sabíamos»,  
\q2 ¿acaso \w no|strong="H3808"\w* \w lo|strong="H1931"\w* considerará \w el|strong="H1931"\w* \w que|strong="H3588"\w* \w pesa|strong="H8505"\w* \w los|strong="H1931"\w* corazones?  
\q1 \w El|strong="H1931"\w* \w que|strong="H3588"\w* \w guarda|strong="H5341"\w* tu \w alma|strong="H5315"\w*, ¿\w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w sabrá|strong="H3045"\w*?  
\q2 ¿\w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w de|strong="H3588"\w* pagar \w a|strong="H3068"\w* cada uno según \w sus|strong="H1931"\w* \w obras|strong="H6467"\w*?   
\q1
\v 13 Come, \w hijo|strong="H1121"\w* \w mío|strong="H5921"\w*, \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w miel|strong="H1706"\w*, \w porque|strong="H3588"\w* \w es|strong="H3588"\w* \w buena|strong="H2896"\w*,  
\q2 \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* destila \w el|strong="H5921"\w* \w panal|strong="H5317"\w*, \w que|strong="H3588"\w* \w es|strong="H3588"\w* \w dulce|strong="H4966"\w* \w a|strong="H3068"\w* tu paladar;   
\q1
\v 14 \w así|strong="H3651"\w* \w será|strong="H3808"\w* para \w tu|strong="H3426"\w* \w alma|strong="H5315"\w* el \w conocimiento|strong="H3045"\w* de \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*.  
\q2 \w Si|strong="H3808"\w* \w la|strong="H2451"\w* \w hallares|strong="H4672"\w*, \w habrá|strong="H3426"\w* recompensa,  
\q2 y \w tu|strong="H3426"\w* \w esperanza|strong="H8615"\w* \w no|strong="H3808"\w* \w será|strong="H3808"\w* frustrada.   
\q1
\v 15 \w No|strong="H7563"\w* aceches, oh \w impío|strong="H7563"\w*, la \w morada|strong="H5116"\w* del \w justo|strong="H6662"\w*,  
\q2 ni destruyas su lugar \w de|strong="H6662"\w* descanso;   
\q1
\v 16 \w porque|strong="H3588"\w* \w siete|strong="H7651"\w* \w veces|strong="H7651"\w* \w cae|strong="H5307"\w* \w el|strong="H3588"\w* \w justo|strong="H6662"\w*, \w y|strong="H3588"\w* se levanta;  
\q2 \w mas|strong="H3588"\w* \w los|strong="H3588"\w* \w impíos|strong="H7563"\w* \w caerán|strong="H5307"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* calamidad.   
\q1
\v 17 No te alegres cuando \w caiga|strong="H5307"\w* tu enemigo,  
\q2 ni se \w goce|strong="H8055"\w* tu \w corazón|strong="H3820"\w* cuando \w él|strong="H5307"\w* tropiece;   
\q1
\v 18 \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H5921"\w* Yahvé \w lo|strong="H5921"\w* \w mire|strong="H7200"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* desagrade,  
\q2 \w y|strong="H5921"\w* aparte \w de|strong="H5921"\w* \w él|strong="H5921"\w* su enojo.   
\q1
\v 19 \w No|strong="H7563"\w* \w te|strong="H7489"\w* impacientes \w a|strong="H3068"\w* causa de los \w malignos|strong="H7489"\w*,  
\q2 ni tengas \w envidia|strong="H7065"\w* de los \w impíos|strong="H7563"\w*;   
\q1
\v 20 \w porque|strong="H3588"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w malo|strong="H7451"\w* \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* buen fin,  
\q2 \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w lámpara|strong="H5216"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w impíos|strong="H7563"\w* \w se|strong="H1961"\w* apagará.   
\q1
\v 21 \w Teme|strong="H3372"\w* \w a|strong="H3068"\w* Yahvé, \w hijo|strong="H1121"\w* mío, y \w al|strong="H4428"\w* \w rey|strong="H4428"\w*;  
\q2 no \w te|strong="H5973"\w* juntes \w con|strong="H5973"\w* \w los|strong="H1121"\w* veleidosos;   
\q1
\v 22 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* quebrantamiento vendrá \w de|strong="H3588"\w* repente;  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* desastre \w de|strong="H3588"\w* \w ambos|strong="H8147"\w*, ¿\w quién|strong="H4310"\w* lo \w sabe|strong="H3045"\w*?   
\b  
\p
\v 23 \w También|strong="H1571"\w* \w estos|strong="H1571"\w* son dichos \w de|strong="H6440"\w* \w los|strong="H2450"\w* \w sabios|strong="H2450"\w*:  
\b  
\q1 Hacer acepción \w de|strong="H6440"\w* personas en \w el|strong="H1571"\w* \w juicio|strong="H4941"\w* \w no|strong="H1077"\w* es \w bueno|strong="H2896"\w*.   
\q1
\v 24 Al \w que|strong="H5971"\w* dijere al \w impío|strong="H7563"\w*: «Eres \w justo|strong="H6662"\w*»,  
\q2 los \w pueblos|strong="H5971"\w* lo maldecirán, y lo detestarán las naciones;   
\q1
\v 25 \w mas|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w lo|strong="H5921"\w* reprendieren tendrán felicidad,  
\q2 \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* vendrá gran \w bendición|strong="H1293"\w*.   
\q1
\v 26 \w Besados|strong="H5401"\w* serán los \w labios|strong="H8193"\w*  
\q2 del \w que|strong="H1697"\w* responde \w palabras|strong="H1697"\w* \w rectas|strong="H5228"\w*.   
\q1
\v 27 \w Prepara|strong="H3559"\w* tus labores \w fuera|strong="H2351"\w*,  
\q2 y disponlas en tus \w campos|strong="H7704"\w*;  
\q2 \w edifica|strong="H1129"\w* después tu \w casa|strong="H1004"\w*.   
\q1
\v 28 \w No|strong="H1961"\w* \w seas|strong="H1961"\w* \w testigo|strong="H5707"\w* sin causa \w contra|strong="H1961"\w* tu \w prójimo|strong="H7453"\w*,  
\q2 ni \w lisonjees|strong="H6601"\w* con tus \w labios|strong="H8193"\w*.   
\q1
\v 29 \w No|strong="H6213"\w* digas: «Le \w haré|strong="H6213"\w* \w como|strong="H3651"\w* \w él|strong="H6213"\w* me \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* mí;  
\q2 \w pagaré|strong="H7725"\w* \w a|strong="H3068"\w* cada uno según su \w obra|strong="H6213"\w*».   
\q1
\v 30 \w Pasé|strong="H5674"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w campo|strong="H7704"\w* \w del|strong="H5921"\w* \w perezoso|strong="H6102"\w*,  
\q2 \w y|strong="H5921"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w viña|strong="H3754"\w* \w del|strong="H5921"\w* hombre \w falto|strong="H2638"\w* \w de|strong="H5921"\w* cordura;   
\q1
\v 31 y he \w aquí|strong="H2009"\w* \w que|strong="H3605"\w* \w por|strong="H6440"\w* \w toda|strong="H3605"\w* \w ella|strong="H3605"\w* habían crecido \w los|strong="H3605"\w* espinos,  
\q2 \w ortigas|strong="H2738"\w* habían cubierto su \w faz|strong="H6440"\w*,  
\q2 y su cerca \w de|strong="H6440"\w* piedra \w estaba|strong="H2009"\w* derribada.   
\q1
\v 32 \w Miré|strong="H7200"\w*, y lo medité en mi \w corazón|strong="H3820"\w*;  
\q2 lo \w vi|strong="H7200"\w*, y aprendí la lección:   
\q1
\v 33 Un \w poco|strong="H4592"\w* de \w sueño|strong="H8142"\w*, un \w poco|strong="H4592"\w* de dormitar,  
\q2 un \w poco|strong="H4592"\w* de cruzar las \w manos|strong="H3027"\w* para reposar;   
\q1
\v 34 así vendrá tu \w pobreza|strong="H7389"\w* como un caminante,  
\q2 y tu necesidad como un hombre armado.   
\c 25
\p
\v 1 \w Estos|strong="H1571"\w* \w también|strong="H1571"\w* son \w proverbios|strong="H4912"\w* de \w Salomón|strong="H8010"\w*, los cuales transcribieron los varones de Ezequías, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*.   
\q1
\v 2 \w Gloria|strong="H3519"\w* \w de|strong="H1697"\w* Dios \w es|strong="H1697"\w* \w ocultar|strong="H5641"\w* un \w asunto|strong="H1697"\w*,  
\q2 \w mas|strong="H3519"\w* la \w gloria|strong="H3519"\w* \w de|strong="H1697"\w* los \w reyes|strong="H4428"\w* \w es|strong="H1697"\w* escudriñar la \w palabra|strong="H1697"\w*.   
\q1
\v 3 Como los \w cielos|strong="H8064"\w* en su altura y la tierra en su profundidad,  
\q2 así el \w corazón|strong="H3820"\w* de los \w reyes|strong="H4428"\w* es inescrutable.   
\q1
\v 4 \w Quita|strong="H1898"\w* las \w escorias|strong="H5509"\w* de la \w plata|strong="H3701"\w*,  
\q2 y \w saldrá|strong="H3318"\w* un \w vaso|strong="H3627"\w* para el \w fundidor|strong="H6884"\w*.   
\q1
\v 5 \w Aparta|strong="H1898"\w* \w al|strong="H4428"\w* \w impío|strong="H7563"\w* \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* del \w rey|strong="H4428"\w*,  
\q2 y su \w trono|strong="H3678"\w* se afirmará en \w justicia|strong="H6664"\w*.   
\q1
\v 6 \w No|strong="H6440"\w* te alabes \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w*,  
\q2 ni te pongas \w en|strong="H5975"\w* el \w lugar|strong="H4725"\w* \w de|strong="H6440"\w* los \w grandes|strong="H1419"\w*;   
\q1
\v 7 \w porque|strong="H3588"\w* \w mejor|strong="H2896"\w* \w es|strong="H3588"\w* \w que|strong="H3588"\w* se \w te|strong="H5869"\w* diga: «\w Sube|strong="H5927"\w* \w acá|strong="H2008"\w*»,  
\q2 \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w que|strong="H3588"\w* seas humillado \w delante|strong="H6440"\w* del príncipe  
\q2 \w a|strong="H3068"\w* quien tus \w ojos|strong="H5869"\w* han \w visto|strong="H7200"\w*.   
\q1
\v 8 \w No|strong="H6435"\w* \w salgas|strong="H3318"\w* apresuradamente \w a|strong="H3068"\w* pleitear,  
\q2 \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H4100"\w* \w no|strong="H6435"\w* sepas \w qué|strong="H4100"\w* \w hacer|strong="H6213"\w* al fin, después \w que|strong="H4100"\w* \w tu|strong="H6213"\w* \w prójimo|strong="H7453"\w* te haya \w avergonzado|strong="H3637"\w*.   
\q1
\v 9 \w Trata|strong="H7379"\w* tu \w causa|strong="H7378"\w* con tu \w compañero|strong="H7453"\w*,  
\q2 y no \w descubras|strong="H1540"\w* el secreto \w a|strong="H3068"\w* \w otro|strong="H7453"\w*;   
\q2
\v 10 \w no|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3808"\w* te deshonre el \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w oyere|strong="H8085"\w*,  
\q2 y tu infamia \w no|strong="H3808"\w* pueda repararse.   
\b  
\q1
\v 11 \w Manzana|strong="H8598"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w con|strong="H5921"\w* figuras \w de|strong="H5921"\w* \w plata|strong="H3701"\w*  
\q2 \w es|strong="H1697"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w dicha|strong="H1696"\w* \w como|strong="H5921"\w* conviene.   
\q1
\v 12 \w Como|strong="H5921"\w* \w zarcillo|strong="H5141"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* joyel \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w fino|strong="H3800"\w*  
\q2 es \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w reprende|strong="H3198"\w* \w al|strong="H5921"\w* \w sabio|strong="H2450"\w* \w que|strong="H5921"\w* tiene \w oído|strong="H8085"\w* \w dócil|strong="H8085"\w*.   
\q1
\v 13 Como frío de nieve en \w tiempo|strong="H3117"\w* de la siega,  
\q2 así es el \w mensajero|strong="H6735"\w* \w fiel|strong="H6735"\w* \w a|strong="H3068"\w* los \w que|strong="H3117"\w* lo envían,  
\q2 \w pues|strong="H7971"\w* refrigera el \w alma|strong="H5315"\w* de sus señores.   
\q1
\v 14 Como \w nubes|strong="H5387"\w* y \w vientos|strong="H7307"\w* sin \w lluvia|strong="H1653"\w*,  
\q2 así es el hombre que se jacta de \w falsa|strong="H8267"\w* liberalidad.   
\q1
\v 15 Con la larga paciencia se aplaca el \w príncipe|strong="H7101"\w*,  
\q2 y la \w lengua|strong="H3956"\w* \w blanda|strong="H7390"\w* \w quebranta|strong="H7665"\w* los huesos.   
\q1
\v 16 ¿\w Hallaste|strong="H4672"\w* \w miel|strong="H1706"\w*?  
\q2 Come lo \w que|strong="H6435"\w* te baste,  
\q2 \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* hastiado \w de|strong="H7646"\w* ella \w la|strong="H7646"\w* vomites.   
\q1
\v 17 \w Detén|strong="H3365"\w* tu \w pie|strong="H7272"\w* \w de|strong="H7646"\w* \w la|strong="H7646"\w* \w casa|strong="H1004"\w* \w de|strong="H7646"\w* tu vecino,  
\q2 \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* harto \w de|strong="H7646"\w* ti te aborrezca.   
\q1
\v 18 \w Martillo|strong="H4650"\w*, \w cuchillo|strong="H2719"\w* y \w saeta|strong="H2671"\w* \w aguda|strong="H8150"\w*  
\q2 es el hombre que habla \w falso|strong="H8267"\w* \w testimonio|strong="H5707"\w* contra su \w prójimo|strong="H7453"\w*.   
\q1
\v 19 \w Como|strong="H7272"\w* \w diente|strong="H8127"\w* roto y \w pie|strong="H7272"\w* descoyuntado  
\q2 es la \w confianza|strong="H4009"\w* en el prevaricador en \w tiempo|strong="H3117"\w* de \w angustia|strong="H6869"\w*.   
\q1
\v 20 \w Como|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* quita \w la|strong="H5921"\w* ropa \w en|strong="H5921"\w* \w tiempo|strong="H3117"\w* \w de|strong="H5921"\w* frío,  
\q2 \w o|strong="H3068"\w* \w como|strong="H5921"\w* \w el|strong="H5921"\w* \w vinagre|strong="H2558"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* nitro,  
\q2 así es \w el|strong="H5921"\w* \w que|strong="H5921"\w* canta \w canciones|strong="H7892"\w* \w al|strong="H5921"\w* \w corazón|strong="H3820"\w* \w afligido|strong="H7451"\w*.   
\q1
\v 21 Si el \w que|strong="H4325"\w* te \w aborrece|strong="H8130"\w* tuviere hambre, dale \w de|strong="H4325"\w* comer \w pan|strong="H3899"\w*,  
\q2 y si tuviere sed, dale \w de|strong="H4325"\w* \w beber|strong="H8248"\w* \w agua|strong="H4325"\w*;   
\q1
\v 22 \w porque|strong="H3588"\w* \w ascuas|strong="H1513"\w* amontonas \w sobre|strong="H5921"\w* \w su|strong="H3588"\w* \w cabeza|strong="H7218"\w*,  
\q2 \w y|strong="H3588"\w* Yahvé \w te|strong="H5921"\w* \w lo|strong="H5921"\w* \w pagará|strong="H7999"\w*.   
\q1
\v 23 El \w viento|strong="H7307"\w* del \w norte|strong="H6828"\w* \w ahuyenta|strong="H2342"\w* la \w lluvia|strong="H1653"\w*,  
\q2 y el \w rostro|strong="H6440"\w* \w airado|strong="H2194"\w* la \w lengua|strong="H3956"\w* \w detractora|strong="H5643"\w*.   
