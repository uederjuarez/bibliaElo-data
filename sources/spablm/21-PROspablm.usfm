\c 31
\p
\v 1 \w Palabras|strong="H1697"\w* del \w rey|strong="H4428"\w* \w Lemuel|strong="H3927"\w*; la profecía con \w que|strong="H1697"\w* le enseñó su madre:   
\b  
\q1
\v 2 «¿\w Qué|strong="H4100"\w*, \w hijo|strong="H1248"\w* mío?  
\q2 ¿\w Y|strong="H3068"\w* \w qué|strong="H4100"\w*, \w hijo|strong="H1248"\w* de mi vientre?  
\q2 ¿\w Y|strong="H3068"\w* \w qué|strong="H4100"\w*, \w hijo|strong="H1248"\w* de mis \w votos|strong="H5088"\w*?   
\q1
\v 3 \w No|strong="H1870"\w* \w des|strong="H5414"\w* tu fuerza \w a|strong="H3068"\w* las mujeres,  
\q2 ni tus \w caminos|strong="H1870"\w* \w a|strong="H3068"\w* lo que destruye \w a|strong="H3068"\w* los \w reyes|strong="H4428"\w*.   
\q1
\v 4 No es de los \w reyes|strong="H4428"\w*, oh \w Lemuel|strong="H3927"\w*,  
\q2 no es de los \w reyes|strong="H4428"\w* \w beber|strong="H8354"\w* \w vino|strong="H3196"\w*,  
\q2 ni de los príncipes la \w bebida|strong="H7941"\w* fuerte;   
\q1
\v 5 \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* \w bebiendo|strong="H8354"\w* \w olviden|strong="H7911"\w* \w la|strong="H3605"\w* ley,  
\q2 y perviertan \w el|strong="H3605"\w* derecho \w de|strong="H8138"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* afligidos.   
\q1
\v 6 \w Dad|strong="H5414"\w* la \w bebida|strong="H7941"\w* fuerte al que \w va|strong="H3068"\w* \w a|strong="H3068"\w* perecer,  
\q2 y el \w vino|strong="H3196"\w* \w a|strong="H3068"\w* los \w de|strong="H5414"\w* \w amargo|strong="H4751"\w* \w ánimo|strong="H5315"\w*.   
\q1
\v 7 \w Beban|strong="H8354"\w*, y olvídense \w de|strong="H5750"\w* su necesidad,  
\q2 y \w de|strong="H5750"\w* su miseria \w no|strong="H3808"\w* \w se|strong="H3808"\w* acuerden \w más|strong="H5750"\w*.   
\q1
