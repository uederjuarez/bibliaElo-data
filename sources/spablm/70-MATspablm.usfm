\mt2 El santo evangelio según  
\mt1 San Mateo  
\c 1
\p
\v 1 \w El|strong="G2424"\w* libro de la genealogía de \w Jesucristo|strong="G2424"\w*,\f + \fr 1:1 \ft Mesías (hebreo) y Cristo (griego) significan ambos «Ungido»\f* \w hijo|strong="G5207"\w* de \w David|strong="G1138"\w*, \w hijo|strong="G5207"\w* de Abraham.   
\p
\v 2 Abraham fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* \w Isaac|strong="G2464"\w*. \w Isaac|strong="G2464"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* \w Jacob|strong="G2384"\w*. \w Jacob|strong="G2384"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Judá \w y|strong="G2532"\w* \w sus|strong="G3588"\w* hermanos.  
\v 3 Judá fue \w el|strong="G3588"\w* padre \w de|strong="G1537"\w* Fares \w y|strong="G2532"\w* Zara \w por|strong="G1537"\w* Tamar. Fares fue \w el|strong="G3588"\w* padre \w de|strong="G1537"\w* \w Esrom|strong="G2074"\w*. \w Esrom|strong="G2074"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G1537"\w* Aram.  
\v 4 Aram fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Aminadab. Aminadab fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Naasón. Naasón fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* \w Salmón|strong="G4533"\w*.  
\v 5 \w Salmón|strong="G4533"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G1537"\w* \w Booz|strong="G1003"\w*, \w de|strong="G1537"\w* Rahab. \w Booz|strong="G1003"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G1537"\w* \w Obed|strong="G5601"\w* \w por|strong="G1537"\w* Rut. \w Obed|strong="G5601"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G1537"\w* Jesé.  
\v 6 Jesé fue \w el|strong="G3588"\w* padre \w del|strong="G3588"\w* rey \w David|strong="G1138"\w*. \w El|strong="G3588"\w* rey\f + \fr 1:6 \ft NU omite «el rey».\f* \w David|strong="G1138"\w* fue padre \w de|strong="G1537"\w* \w Salomón|strong="G4672"\w* \w por|strong="G1537"\w* \w la|strong="G3588"\w* \w que|strong="G3588"\w* había sido esposa \w de|strong="G1537"\w* \w Urías|strong="G3774"\w*.  
\v 7 \w Salomón|strong="G4672"\w* fue padre \w de|strong="G3588"\w* \w Roboam|strong="G4497"\w*. \w Roboam|strong="G4497"\w* fue padre \w de|strong="G3588"\w* Abías. Abías fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Asa.  
\v 8 Asa fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Josafat. Josafat fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* \w Joram|strong="G2496"\w*. \w Joram|strong="G2496"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Uzías.  
\v 9 Uzías fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Jotam. Jotam fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Acaz. Acaz fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Ezequías.  
\v 10 Ezequías fue padre \w de|strong="G3588"\w* \w Manasés|strong="G3128"\w*. \w Manasés|strong="G3128"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Amón. Amón fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* \w Josías|strong="G2502"\w*.  
\v 11 \w Josías|strong="G2502"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G1909"\w* Jechoniah \w y|strong="G2532"\w* \w sus|strong="G3588"\w* hermanos \w en|strong="G1909"\w* \w el|strong="G3588"\w* momento \w del|strong="G3588"\w* exilio \w a|strong="G1909"\w* Babilonia.   
\p
\v 12 \w Después|strong="G3326"\w* \w del|strong="G3588"\w* exilio \w a|strong="G1161"\w* Babilonia, Jechoniah fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Salatiel. Salatiel fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* \w Zorobabel|strong="G2216"\w*.  
\v 13 \w Zorobabel|strong="G2216"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Abiud. Abiud fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Eliaquim. Eliaquim fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Azor.  
\v 14 Azor fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* \w Sadoc|strong="G4524"\w*. \w Sadoc|strong="G4524"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Aquim. Aquim fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* \w Eliud|strong="G1664"\w*.  
\v 15 \w Eliud|strong="G1664"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Eleazar. Eleazar fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* Matán. Matán fue \w el|strong="G3588"\w* padre \w de|strong="G3588"\w* \w Jacob|strong="G2384"\w*.  
\v 16 \w Jacob|strong="G2384"\w* fue \w el|strong="G3588"\w* padre \w de|strong="G1537"\w* \w José|strong="G2501"\w*, \w el|strong="G3588"\w* esposo \w de|strong="G1537"\w* \w María|strong="G3137"\w*, \w de|strong="G1537"\w* \w quien|strong="G3739"\w* \w nació|strong="G1080"\w* \w Jesús|strong="G2424"\w*,\f + \fr 1:16 \ft «Jesús» significa «Salvación».\f* \w llamado|strong="G3739"\w* \w Cristo|strong="G5547"\w*.   
\p
\v 17 \w Así|strong="G2532"\w* \w que|strong="G3588"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* \w generaciones|strong="G1074"\w* desde Abraham \w hasta|strong="G2193"\w* \w David|strong="G1138"\w* son \w catorce|strong="G1180"\w* \w generaciones|strong="G1074"\w*; desde \w David|strong="G1138"\w* \w hasta|strong="G2193"\w* \w el|strong="G3588"\w* exilio \w a|strong="G2193"\w* Babilonia, \w catorce|strong="G1180"\w* \w generaciones|strong="G1074"\w*; \w y|strong="G2532"\w* desde \w el|strong="G3588"\w* exilio \w a|strong="G2193"\w* Babilonia \w hasta|strong="G2193"\w* \w el|strong="G3588"\w* \w Cristo|strong="G5547"\w*, \w catorce|strong="G1180"\w* \w generaciones|strong="G1074"\w*.   
\p
\v 18 \w El|strong="G3588"\w* nacimiento \w de|strong="G1537"\w* \w Jesucristo|strong="G2424"\w* \w fue|strong="G4905"\w* \w así|strong="G3779"\w*: \w Después|strong="G1161"\w* \w de|strong="G1537"\w* \w que|strong="G3588"\w* \w su|strong="G3588"\w* \w madre|strong="G3384"\w*, \w María|strong="G3137"\w*, \w se|strong="G1438"\w* comprometiera \w con|strong="G1722"\w* \w José|strong="G2501"\w*, \w antes|strong="G4250"\w* \w de|strong="G1537"\w* \w que|strong="G3588"\w* \w se|strong="G1438"\w* \w juntasen|strong="G4905"\w*, \w fue|strong="G4905"\w* \w hallada|strong="G2147"\w* embarazada \w por|strong="G1722"\w* \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo.  
\v 19 \w José|strong="G2501"\w*, \w su|strong="G3588"\w* marido, \w siendo|strong="G1161"\w* \w un|strong="G3588"\w* hombre \w justo|strong="G1342"\w*, \w y|strong="G2532"\w* \w no|strong="G3361"\w* \w queriendo|strong="G1014"\w* hacer \w de|strong="G3588"\w* \w ella|strong="G3588"\w* \w un|strong="G3588"\w* ejemplo público, pensaba repudiarla \w en|strong="G3588"\w* secreto.  
\v 20 \w Pero|strong="G1161"\w* \w cuando|strong="G1722"\w* pensaba \w en|strong="G1722"\w* \w estas|strong="G3778"\w* cosas, he aquí \w que|strong="G3588"\w* \f + \fr 1:20 \ft «Contemplar», de «ἰδοὺ», significa mirar, fijarse, observar, ver o contemplar. Se utiliza a menudo como interjección.\f*\w un|strong="G3588"\w* ángel \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* se \w le|strong="G1722"\w* \w apareció|strong="G5316"\w* \w en|strong="G1722"\w* \w sueños|strong="G3677"\w*, \w diciendo|strong="G3004"\w*: “\w José|strong="G2501"\w*, \w hijo|strong="G5207"\w* \w de|strong="G1537"\w* \w David|strong="G1138"\w*, \w no|strong="G3361"\w* \w temas|strong="G5399"\w* recibir \w a|strong="G1722"\w* \w María|strong="G3137"\w* \w como|strong="G2596"\w* \w esposa|strong="G1135"\w*, \w porque|strong="G1063"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* ha sido concebido \w en|strong="G1722"\w* \w ella|strong="G3588"\w* \w es|strong="G3778"\w* \w del|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo.  
\v 21 \w Ella|strong="G3588"\w* dará \w a|strong="G1161"\w* luz \w un|strong="G3588"\w* \w hijo|strong="G5207"\w*. Le pondrás \w el|strong="G3588"\w* \w nombre|strong="G3686"\w* \w de|strong="G3588"\w* \w Jesús|strong="G2424"\w*, \f + \fr 1:21 \ft «Jesús» significa «Salvación».\f*\w porque|strong="G1063"\w* es \w él|strong="G3588"\w* \w quien|strong="G3588"\w* \w salvará|strong="G4982"\w* \w a|strong="G1161"\w* \w su|strong="G3588"\w* \w pueblo|strong="G2992"\w* \w de|strong="G3588"\w* \w sus|strong="G3588"\w* pecados”.   
\p
\v 22 \w Todo|strong="G3650"\w* \w esto|strong="G3778"\w* ha sucedido \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w se|strong="G1096"\w* cumpla \w lo|strong="G3588"\w* \w dicho|strong="G2046"\w* \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w del|strong="G3588"\w* \w profeta|strong="G4396"\w*, \w que|strong="G3588"\w* \w dijo|strong="G3004"\w*   
\q1
\v 23 «He aquí \w que|strong="G3588"\w* \w la|strong="G3588"\w* \w virgen|strong="G3933"\w* quedará encinta,  
\q2 \w y|strong="G2532"\w* dará \w a|strong="G1722"\w* luz \w un|strong="G3588"\w* \w hijo|strong="G5207"\w*.  
\q1 Llamarán \w su|strong="G3588"\w* \w nombre|strong="G3686"\w* Emanuel».  
\q2 \w que|strong="G3588"\w* \w es|strong="G3739"\w*, \w interpretado|strong="G3177"\w*, «\w Dios|strong="G2316"\w* \w con|strong="G3326"\w* \w nosotros|strong="G2249"\w*». \f + \fr 1:23 \ft Isaías 7:14\f*   
\p
\v 24 \w José|strong="G2501"\w* \w se|strong="G2532"\w* \w levantó|strong="G1453"\w* \w de|strong="G3588"\w* \w su|strong="G3588"\w* \w sueño|strong="G5258"\w* \w e|strong="G2532"\w* \w hizo|strong="G4160"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* ángel \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* le \w había|strong="G4160"\w* ordenado, \w y|strong="G2532"\w* \w tomó|strong="G3880"\w* \w a|strong="G1161"\w* \w su|strong="G3588"\w* \w mujer|strong="G1135"\w* para \w sí|strong="G2532"\w*;  
\v 25 \w y|strong="G2532"\w* \w no|strong="G3756"\w* \w la|strong="G3588"\w* \w conoció|strong="G1097"\w* sexualmente \w hasta|strong="G2193"\w* \w que|strong="G3588"\w* dio \w a|strong="G2193"\w* luz \w a|strong="G2193"\w* \w su|strong="G3588"\w* \w hijo|strong="G5207"\w* primogénito. \w Le|strong="G1438"\w* puso \w el|strong="G3588"\w* \w nombre|strong="G3686"\w* \w de|strong="G3588"\w* \w Jesús|strong="G2424"\w*.   
\c 2
\p
\v 1 \w Cuando|strong="G1722"\w* \w Jesús|strong="G2424"\w* \w nació|strong="G1080"\w* \w en|strong="G1722"\w* Belén \w de|strong="G1722"\w* \w Judea|strong="G2449"\w*, \w en|strong="G1722"\w* tiempos \w del|strong="G3588"\w* rey \w Herodes|strong="G2264"\w*, \w vinieron|strong="G3854"\w* \w a|strong="G1519"\w* Jerusalén \w unos|strong="G3588"\w*\f + \fr 2:1 \ft La palabra «sabios» (magoi) también puede significar maestros, científicos, médicos, astrólogos, videntes, intérpretes de sueños o hechiceros.\f* sabios \w del|strong="G3588"\w* Oriente, diciendo:  
\v 2 «¿\w Dónde|strong="G4226"\w* \w está|strong="G3588"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* ha nacido \w como|strong="G2532"\w* Rey \w de|strong="G1722"\w* \w los|strong="G3588"\w* \w judíos|strong="G2453"\w*? \w Porque|strong="G1063"\w* hemos visto \w su|strong="G3588"\w* estrella \w en|strong="G1722"\w* \w el|strong="G3588"\w* oriente \w y|strong="G2532"\w* hemos \w venido|strong="G2064"\w* \w a|strong="G1722"\w* adorarle».  
\v 3 \w Al|strong="G3588"\w* oírlo, \w el|strong="G3588"\w* rey \w Herodes|strong="G2264"\w* \w se|strong="G2532"\w* turbó, \w y|strong="G2532"\w* \w toda|strong="G3956"\w* Jerusalén \w con|strong="G3326"\w* \w él|strong="G3588"\w*.  
\v 4 Reuniendo \w a|strong="G3844"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* jefes \w de|strong="G3844"\w* \w los|strong="G3588"\w* sacerdotes \w y|strong="G2532"\w* \w a|strong="G3844"\w* \w los|strong="G3588"\w* \w escribas|strong="G1122"\w* \w del|strong="G3588"\w* \w pueblo|strong="G2992"\w*, \w les|strong="G3844"\w* \w preguntó|strong="G4441"\w* \w dónde|strong="G4226"\w* iba \w a|strong="G3844"\w* \w nacer|strong="G1080"\w* \w el|strong="G3588"\w* \w Cristo|strong="G5547"\w*.  
\v 5 \w Ellos|strong="G3588"\w* \w le|strong="G1722"\w* respondieron: “\w En|strong="G1722"\w* Belén \w de|strong="G1722"\w* \w Judea|strong="G2449"\w*, \w porque|strong="G1063"\w* \w así|strong="G3779"\w* \w está|strong="G3588"\w* \w escrito|strong="G1125"\w* \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w profeta|strong="G4396"\w*,   
\q1
\v 6 ‘\w Tú|strong="G4771"\w* Belén, \w tierra|strong="G1093"\w* \w de|strong="G1537"\w* \w Judá|strong="G2448"\w*,  
\q2 \w no|strong="G4771"\w* \w eres|strong="G1510"\w* \w en|strong="G1722"\w* absoluto \w el|strong="G3588"\w* menos importante \w entre|strong="G1722"\w* \w los|strong="G3588"\w* \w príncipes|strong="G2232"\w* \w de|strong="G1537"\w* \w Judá|strong="G2448"\w*;  
\q1 \w porque|strong="G1063"\w* \w de|strong="G1537"\w* ti \w saldrá|strong="G1831"\w* \w un|strong="G3588"\w* \w gobernador|strong="G2232"\w*  
\q2 \w que|strong="G3588"\w* \w pastoreará|strong="G4165"\w* \w a|strong="G1722"\w* \w mi|strong="G3588"\w* \w pueblo|strong="G2992"\w*, \w Israel|strong="G2474"\w*”. \f + \fr 2:6 \ft Miqueas 5:2\f*   
\p
\v 7 \w Entonces|strong="G5119"\w* \w Herodes|strong="G2264"\w* \w llamó|strong="G2564"\w* \w en|strong="G3844"\w* secreto \w a|strong="G3844"\w* \w los|strong="G3588"\w* sabios \w y|strong="G5119"\w* se enteró \w por|strong="G3844"\w* \w ellos|strong="G3588"\w* \w de|strong="G3844"\w* \w la|strong="G3588"\w* hora exacta \w en|strong="G3844"\w* \w que|strong="G3588"\w* \w apareció|strong="G5316"\w* \w la|strong="G3588"\w* estrella.  
\v 8 \w Los|strong="G3588"\w* \w envió|strong="G3992"\w* \w a|strong="G1519"\w* Belén \w y|strong="G2532"\w* \w les|strong="G1519"\w* \w dijo|strong="G3004"\w*: «\w Id|strong="G4198"\w* \w y|strong="G2532"\w* buscad diligentemente \w al|strong="G3588"\w* \w niño|strong="G3813"\w*. Cuando \w lo|strong="G3588"\w* hayáis encontrado, traedme \w la|strong="G3588"\w* noticia, \w para|strong="G1519"\w* \w que|strong="G3588"\w* \w yo|strong="G1473"\w* \w también|strong="G2532"\w* \w vaya|strong="G2064"\w* \w a|strong="G1519"\w* adorarlo».   
\p
\v 9 \w Ellos|strong="G3588"\w*, habiendo oído \w al|strong="G3588"\w* rey, \w se|strong="G1438"\w* \w pusieron|strong="G2476"\w* \w en|strong="G1722"\w* camino; \w y|strong="G2532"\w* he aquí \w que|strong="G3588"\w* \w la|strong="G3588"\w* estrella \w que|strong="G3588"\w* habían visto \w en|strong="G1722"\w* \w el|strong="G3588"\w* oriente, \w iba|strong="G4198"\w* \w delante|strong="G2476"\w* \w de|strong="G1722"\w* \w ellos|strong="G3588"\w* \w hasta|strong="G2193"\w* \w que|strong="G3588"\w* \w llegó|strong="G2064"\w* \w y|strong="G2532"\w* \w se|strong="G1438"\w* paró \w sobre|strong="G1883"\w* \w donde|strong="G3757"\w* \w estaba|strong="G2476"\w* \w el|strong="G3588"\w* \w niño|strong="G3813"\w*.  
\v 10 \w Al|strong="G3588"\w* ver \w la|strong="G3588"\w* estrella, se alegraron \w mucho|strong="G4970"\w*.  
\v 11 Entraron \w en|strong="G1519"\w* \w la|strong="G3588"\w* \w casa|strong="G3614"\w* \w y|strong="G2532"\w* vieron \w al|strong="G3588"\w* \w niño|strong="G3813"\w* \w con|strong="G3326"\w* \w María|strong="G3137"\w*, \w su|strong="G3588"\w* \w madre|strong="G3384"\w*, \w y|strong="G2532"\w* \w se|strong="G2532"\w* postraron \w y|strong="G2532"\w* \w lo|strong="G3588"\w* \w adoraron|strong="G4352"\w*. Abriendo \w sus|strong="G3588"\w* \w tesoros|strong="G2344"\w*, \w le|strong="G1519"\w* \w ofrecieron|strong="G4374"\w* regalos: \w oro|strong="G5557"\w*, incienso \w y|strong="G2532"\w* \w mirra|strong="G4666"\w*.  
\v 12 \w Al|strong="G3588"\w* ser advertidos \w en|strong="G1519"\w* \w sueños|strong="G3677"\w* \w de|strong="G1519"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* debían volver \w a|strong="G1519"\w* \w Herodes|strong="G2264"\w*, regresaron \w a|strong="G1519"\w* \w su|strong="G3588"\w* \w país|strong="G5561"\w* \w por|strong="G1223"\w* \w otro|strong="G3588"\w* \w camino|strong="G3598"\w*.   
\p
\v 13 Cuando \w se|strong="G2212"\w* fueron, \w he|strong="G3195"\w* aquí \w que|strong="G3588"\w* \w un|strong="G3588"\w* ángel \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w se|strong="G2212"\w* \w le|strong="G2596"\w* \w apareció|strong="G5316"\w* \w a|strong="G1519"\w* \w José|strong="G2501"\w* \w en|strong="G1519"\w* \w sueños|strong="G3677"\w*, \w diciendo|strong="G3004"\w*: «\w Levántate|strong="G1453"\w* \w y|strong="G2532"\w* \w toma|strong="G3880"\w* \w al|strong="G3588"\w* \w niño|strong="G3813"\w* \w y|strong="G2532"\w* \w a|strong="G1519"\w* \w su|strong="G3588"\w* \w madre|strong="G3384"\w*, \w y|strong="G2532"\w* \w huye|strong="G5343"\w* \w a|strong="G1519"\w* Egipto, \w y|strong="G2532"\w* quédate \w allí|strong="G1563"\w* \w hasta|strong="G2193"\w* \w que|strong="G3588"\w* yo \w te|strong="G4771"\w* diga, \w porque|strong="G1063"\w* \w Herodes|strong="G2264"\w* \w buscará|strong="G2212"\w* \w al|strong="G3588"\w* \w niño|strong="G3813"\w* \w para|strong="G1519"\w* destruirlo.»   
\p
