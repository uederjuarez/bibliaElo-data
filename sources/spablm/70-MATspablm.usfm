\v 19 \wj \+w Además|strong="G3825"\+w*, \+w os|strong="G3004"\+w* aseguro \+w que|strong="G3754"\+w* \+w si|strong="G1437"\+w* \+w dos|strong="G1417"\+w* \+w de|strong="G1537"\+w* \+w vosotros|strong="G5210"\+w* \+w se|strong="G1096"\+w* ponen \+w de|strong="G1537"\+w* acuerdo \+w en|strong="G1722"\+w* \+w la|strong="G3588"\+w* \+w tierra|strong="G1093"\+w* \+w sobre|strong="G1909"\+w* \+w cualquier|strong="G3739"\+w* \+w cosa|strong="G1722"\+w* \+w que|strong="G3754"\+w* pidan, \+w les|strong="G1909"\+w* \+w será|strong="G1096"\+w* \+w hecho|strong="G1096"\+w* \+w por|strong="G1722"\+w* \+w mi|strong="G3588"\+w* \+w Padre|strong="G3962"\+w* \+w que|strong="G3754"\+w* \+w está|strong="G3588"\+w* \+w en|strong="G1722"\+w* \+w el|strong="G3588"\+w* \+w cielo|strong="G3772"\+w*. \wj*  
\v 20 \wj \+w Porque|strong="G1063"\+w* \+w donde|strong="G3757"\+w* \+w hay|strong="G3588"\+w* \+w dos|strong="G1417"\+w* \+w o|strong="G2228"\+w* \+w tres|strong="G5140"\+w* reunidos \+w en|strong="G1722"\+w* \+w mi|strong="G1699"\+w* \+w nombre|strong="G3686"\+w*, \+w allí|strong="G1563"\+w* \+w estoy|strong="G1510"\+w* yo \+w en|strong="G1722"\+w* \+w medio|strong="G3319"\+w* \+w de|strong="G1722"\+w* \+w ellos|strong="G3588"\+w*». \wj*   
\p
\v 21 \w Entonces|strong="G5119"\w* \w Pedro|strong="G4074"\w* \w se|strong="G2532"\w* acercó \w y|strong="G2532"\w* \w le|strong="G1519"\w* \w dijo|strong="G3004"\w*: «\w Señor|strong="G2962"\w*, ¿\w cuántas|strong="G4212"\w* veces va \w a|strong="G1519"\w* pecar \w mi|strong="G3588"\w* hermano \w contra|strong="G1519"\w* \w mí|strong="G3588"\w*, \w y|strong="G2532"\w* \w le|strong="G1519"\w* perdono? ¿\w Hasta|strong="G2193"\w* \w siete|strong="G2034"\w* veces?»   
\p
\v 22 \w Jesús|strong="G2424"\w* le \w dijo|strong="G3004"\w*: \wj “\+w No|strong="G3756"\+w* \+w te|strong="G4771"\+w* \+w digo|strong="G3004"\+w* \+w hasta|strong="G2193"\+w* \+w siete|strong="G2033"\+w* veces, sino \+w hasta|strong="G2193"\+w* \+w setenta|strong="G1441"\+w* veces \+w siete|strong="G2033"\+w*. \wj*  
\v 23 \wj \+w Por|strong="G1223"\+w* \+w eso|strong="G1223"\+w*, \+w el|strong="G3588"\+w* Reino \+w de|strong="G1223"\+w* \+w los|strong="G3588"\+w* \+w Cielos|strong="G3772"\+w* se parece \+w a|strong="G3326"\+w* cierto rey \+w que|strong="G3588"\+w* \+w quería|strong="G2309"\+w* ajustar \+w cuentas|strong="G3056"\+w* \+w con|strong="G3326"\+w* \+w sus|strong="G3588"\+w* \+w siervos|strong="G1401"\+w*. \wj*  
\v 24 \wj Cuando empezó \+w a|strong="G1161"\+w* ajustar cuentas, le \+w presentaron|strong="G4374"\+w* \+w a|strong="G1161"\+w* \+w uno|strong="G1520"\+w* \+w que|strong="G1161"\+w* le \+w debía|strong="G3781"\+w* \+w diez|strong="G3463"\+w* mil \+w talentos|strong="G5007"\+w*. \wj*\f + \fr 18:24 \ft Diez mil talentos (unas 300 toneladas de plata) representan una suma de dinero extremadamente grande, equivalente a unos 60.000.000 denarios, donde un denario era el típico salario de un día de trabajo agrícola.\f*  
\v 25 \wj \+w Pero|strong="G1161"\+w* \+w como|strong="G2532"\+w* \+w no|strong="G3361"\+w* \+w podía|strong="G2192"\+w* pagar, \+w su|strong="G3588"\+w* \+w señor|strong="G2962"\+w* \+w mandó|strong="G2753"\+w* venderlo, \+w con|strong="G2532"\+w* \+w su|strong="G3588"\+w* \+w mujer|strong="G1135"\+w*, \+w sus|strong="G3588"\+w* \+w hijos|strong="G5043"\+w* \+w y|strong="G2532"\+w* \+w todo|strong="G3956"\+w* \+w lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w tenía|strong="G2192"\+w*, \+w y|strong="G2532"\+w* \+w que|strong="G3588"\+w* \+w se|strong="G2532"\+w* le pagara. \wj*  
\v 26 \wj \+w El|strong="G3588"\+w* \+w siervo|strong="G1401"\+w*, \+w pues|strong="G3767"\+w*, \+w se|strong="G2532"\+w* postró \+w y|strong="G2532"\+w* \+w se|strong="G2532"\+w* arrodilló \+w ante|strong="G1909"\+w* \+w él|strong="G3588"\+w*, \+w diciendo|strong="G3004"\+w*: «Señor, ten \+w paciencia|strong="G3114"\+w* \+w conmigo|strong="G1909"\+w* \+w y|strong="G2532"\+w* \+w te|strong="G4771"\+w* \+w lo|strong="G3588"\+w* pagaré \+w todo|strong="G3956"\+w*». \wj*  
\v 27 \wj \+w El|strong="G3588"\+w* \+w señor|strong="G2962"\+w* \+w de|strong="G3588"\+w* \+w aquel|strong="G3588"\+w* \+w siervo|strong="G1401"\+w*, compadecido, \+w lo|strong="G3588"\+w* liberó \+w y|strong="G2532"\+w* le perdonó \+w la|strong="G3588"\+w* \+w deuda|strong="G1156"\+w*. \wj*   
\p
\v 28 \wj “\+w Pero|strong="G1161"\+w* \+w aquel|strong="G3588"\+w* \+w siervo|strong="G1401"\+w* \+w salió|strong="G1831"\+w* \+w y|strong="G2532"\+w* encontró \+w a|strong="G1161"\+w* \+w uno|strong="G1520"\+w* \+w de|strong="G3588"\+w* \+w sus|strong="G3588"\+w* \+w consiervos|strong="G4889"\+w* \+w que|strong="G3588"\+w* le \+w debía|strong="G3784"\+w* \+w cien|strong="G1540"\+w* \+w denarios|strong="G1220"\+w*,\wj*\f + \fr 18:28 \ft 100 denarios eran aproximadamente la sexagésima parte de un talento, es decir, unos 500 gramos (1,1 libras) de plata.\f* \wj \+w lo|strong="G3588"\+w* agarró \+w y|strong="G2532"\+w* \+w lo|strong="G3588"\+w* \+w tomó|strong="G2902"\+w* \+w por|strong="G3739"\+w* \+w el|strong="G3588"\+w* cuello, \+w diciendo|strong="G3004"\+w*: «¡Págame \+w lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* me \+w debes|strong="G3784"\+w*!». \wj*   
\p
\v 29 “\wj \+w Entonces|strong="G2532"\+w* \+w su|strong="G3588"\+w* \+w consiervo|strong="G4889"\+w* \+w se|strong="G2532"\+w* postró \+w a|strong="G1909"\+w* \+w sus|strong="G3588"\+w* pies \+w y|strong="G2532"\+w* \+w le|strong="G1909"\+w* \+w rogó|strong="G3870"\+w*, \+w diciendo|strong="G3004"\+w*: «Ten \+w paciencia|strong="G3114"\+w* \+w conmigo|strong="G1909"\+w*, \+w y|strong="G2532"\+w* \+w te|strong="G4771"\+w* \+w lo|strong="G3588"\+w* pagaré». \wj*  
\v 30 \wj \+w Pero|strong="G1161"\+w* \+w él|strong="G3588"\+w* \+w no|strong="G3756"\+w* \+w quiso|strong="G2309"\+w*, \+w sino|strong="G1161"\+w* \+w que|strong="G3588"\+w* fue \+w y|strong="G1161"\+w* \+w lo|strong="G3588"\+w* echó \+w en|strong="G1519"\+w* \+w la|strong="G3588"\+w* \+w cárcel|strong="G5438"\+w* \+w hasta|strong="G2193"\+w* \+w que|strong="G3588"\+w* \+w le|strong="G1519"\+w* devolviera \+w lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w le|strong="G1519"\+w* \+w debía|strong="G3784"\+w*. \wj*  
\v 31 \wj Cuando \+w sus|strong="G3588"\+w* \+w consiervos|strong="G4889"\+w* vieron \+w lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w se|strong="G1438"\+w* \+w había|strong="G1096"\+w* \+w hecho|strong="G1096"\+w*, \+w se|strong="G1438"\+w* entristecieron \+w mucho|strong="G4970"\+w*, \+w y|strong="G2532"\+w* \+w vinieron|strong="G2064"\+w* a contarle a \+w su|strong="G3588"\+w* \+w señor|strong="G2962"\+w* \+w todo|strong="G3956"\+w* \+w lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w se|strong="G1438"\+w* \+w había|strong="G1096"\+w* \+w hecho|strong="G1096"\+w*. \wj*  
\v 32 \wj \+w Entonces|strong="G5119"\+w* \+w su|strong="G3588"\+w* \+w señor|strong="G2962"\+w* \+w lo|strong="G3588"\+w* \+w llamó|strong="G4341"\+w* \+w y|strong="G5119"\+w* le \+w dijo|strong="G3004"\+w*: “¡\+w Siervo|strong="G1401"\+w* \+w malvado|strong="G4190"\+w*! \+w Te|strong="G4771"\+w* perdoné \+w toda|strong="G3956"\+w* esa \+w deuda|strong="G3782"\+w* \+w porque|strong="G1893"\+w* \+w me|strong="G1473"\+w* \+w lo|strong="G3588"\+w* \+w rogaste|strong="G3870"\+w*. \wj*  
\v 33 \wj ¿\+w No|strong="G3756"\+w* debías \+w tú|strong="G4771"\+w* \+w también|strong="G2532"\+w* tener misericordia \+w de|strong="G3588"\+w* \+w tu|strong="G4771"\+w* \+w consiervo|strong="G4889"\+w*, \+w como|strong="G5613"\+w* \+w yo|strong="G2504"\+w* tuve misericordia \+w de|strong="G3588"\+w* ti?’\wj*  
