\v 35 \wj \+w Así|strong="G3779"\+w* \+w hará|strong="G4160"\+w* \+w también|strong="G2532"\+w* \+w mi|strong="G3588"\+w* \+w Padre|strong="G3962"\+w* \+w celestial|strong="G3770"\+w* \+w con|strong="G2532"\+w* \+w vosotros|strong="G5210"\+w*, \+w si|strong="G1437"\+w* \+w no|strong="G3361"\+w* perdonáis \+w cada|strong="G1538"\+w* \+w uno|strong="G1538"\+w* a \+w vuestro|strong="G3588"\+w* hermano \+w de|strong="G3588"\+w* \+w corazón|strong="G2588"\+w* \+w por|strong="G3588"\+w* \+w sus|strong="G3588"\+w* fechorías.” \wj*   
\c 19
\p
\v 1 \w Cuando|strong="G3753"\w* \w Jesús|strong="G2424"\w* terminó \w estas|strong="G3778"\w* \w palabras|strong="G3056"\w*, salió \w de|strong="G1519"\w* \w Galilea|strong="G1056"\w* \w y|strong="G2532"\w* \w llegó|strong="G2064"\w* \w a|strong="G1519"\w* \w los|strong="G3588"\w* límites \w de|strong="G1519"\w* \w Judea|strong="G2449"\w*, \w al|strong="G3588"\w* \w otro|strong="G3588"\w* lado \w del|strong="G3588"\w* \w Jordán|strong="G2446"\w*.  
\v 2 \w Le|strong="G1438"\w* siguieron grandes multitudes, \w y|strong="G2532"\w* \w allí|strong="G1563"\w* \w los|strong="G2532"\w* curó.   
\p
\v 3 \w Los|strong="G3588"\w* \w fariseos|strong="G5330"\w* \w se|strong="G2532"\w* acercaron \w a|strong="G2596"\w* \w él|strong="G3588"\w* \w para|strong="G2596"\w* ponerle \w a|strong="G2596"\w* prueba \w y|strong="G2532"\w* \w decirle|strong="G3004"\w*: «¿\w Es|strong="G1487"\w* \w lícito|strong="G1832"\w* \w que|strong="G3588"\w* \w un|strong="G3588"\w* hombre \w se|strong="G2532"\w* divorcie \w de|strong="G2596"\w* \w su|strong="G3588"\w* \w mujer|strong="G1135"\w* \w por|strong="G2596"\w* \w cualquier|strong="G3956"\w* motivo?»   
\p
\v 4 \w Él|strong="G3588"\w* respondió: \wj “¿\+w No|strong="G3756"\+w* \+w habéis|strong="G2532"\+w* leído \+w que|strong="G3754"\+w* \+w el|strong="G3588"\+w* \+w que|strong="G3754"\+w* \+w los|strong="G3588"\+w* \+w hizo|strong="G4160"\+w* desde \+w el|strong="G3588"\+w* principio \+w los|strong="G3588"\+w* \+w hizo|strong="G4160"\+w* varón \+w y|strong="G2532"\+w* mujer, \wj*\f + \fr 19:4 \ft Génesis 1:27\f*  
\v 5 \wj \+w y|strong="G2532"\+w* \+w dijo|strong="G3004"\+w*: «\+w Por|strong="G1519"\+w* eso \+w el|strong="G3588"\+w* hombre \+w dejará|strong="G2641"\+w* \+w a|strong="G1519"\+w* \+w su|strong="G3588"\+w* \+w padre|strong="G3962"\+w* \+w y|strong="G2532"\+w* \+w a|strong="G1519"\+w* \+w su|strong="G3588"\+w* \+w madre|strong="G3384"\+w*, \+w y|strong="G2532"\+w* \+w se|strong="G2532"\+w* unirá \+w a|strong="G1519"\+w* \+w su|strong="G3588"\+w* \+w mujer|strong="G1135"\+w*, \+w y|strong="G2532"\+w* \+w los|strong="G3588"\+w* \+w dos|strong="G1417"\+w* \+w se|strong="G2532"\+w* convertirán \+w en|strong="G1519"\+w* \+w una|strong="G1520"\+w* sola \+w carne|strong="G4561"\+w*»? \wj*\f + \fr 19:5 \ft Génesis 2:24\f*  
\v 6 \w De|strong="G3588"\w* \wj \+w modo|strong="G5620"\+w* \+w que|strong="G3588"\+w* \+w ya|strong="G3765"\+w* \+w no|strong="G3361"\+w* \+w son|strong="G1510"\+w* \+w dos|strong="G1417"\+w*, \+w sino|strong="G3361"\+w* \+w una|strong="G1520"\+w* sola \+w carne|strong="G4561"\+w*. \+w Por|strong="G3739"\+w* \+w tanto|strong="G5620"\+w*, \+w lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w Dios|strong="G2316"\+w* ha unido, \+w que|strong="G3588"\+w* \+w no|strong="G3361"\+w* \+w lo|strong="G3588"\+w* separe \+w el|strong="G3588"\+w* hombre”. \wj*   
\p
\v 7 \w Le|strong="G1438"\w* preguntaron: «¿\w Por|strong="G3767"\w* \w qué|strong="G5101"\w*, \w entonces|strong="G2532"\w*, \w Moisés|strong="G3475"\w* \w nos|strong="G1438"\w* ordenó \w que|strong="G5101"\w* \w le|strong="G1438"\w* diéramos un certificado \w de|strong="G1325"\w* divorcio \w y|strong="G2532"\w* \w nos|strong="G1438"\w* divorciáramos \w de|strong="G1325"\w* ella?»   
\p
\v 8 \w Les|strong="G4314"\w* \w dijo|strong="G3004"\w*: \wj «\+w Moisés|strong="G3475"\+w*, \+w a|strong="G4314"\+w* causa \+w de|strong="G4314"\+w* \+w la|strong="G3588"\+w* \+w dureza|strong="G4641"\+w* \+w de|strong="G4314"\+w* \+w vuestros|strong="G5210"\+w* corazones, \+w os|strong="G4314"\+w* \+w permitió|strong="G2010"\+w* divorciaros \+w de|strong="G4314"\+w* \+w vuestras|strong="G3588"\+w* \+w mujeres|strong="G1135"\+w*, \+w pero|strong="G1161"\+w* desde \+w el|strong="G3588"\+w* principio \+w no|strong="G3756"\+w* ha \+w sido|strong="G1096"\+w* \+w así|strong="G3779"\+w*. \wj*  
\v 9 \wj \+w Os|strong="G3004"\+w* \+w digo|strong="G3004"\+w* \+w que|strong="G3754"\+w* \+w el|strong="G3588"\+w* \+w que|strong="G3754"\+w* \+w se|strong="G2532"\+w* divorcia \+w de|strong="G1909"\+w* \+w su|strong="G3588"\+w* \+w mujer|strong="G1135"\+w*, salvo \+w por|strong="G1909"\+w* inmoralidad sexual, \+w y|strong="G2532"\+w* \+w se|strong="G2532"\+w* casa \+w con|strong="G1909"\+w* otra, comete adulterio; \+w y|strong="G2532"\+w* \+w el|strong="G3588"\+w* \+w que|strong="G3754"\+w* \+w se|strong="G2532"\+w* casa \+w con|strong="G1909"\+w* \+w ella|strong="G3588"\+w* estando divorciada, comete adulterio.» \wj*   
\p
\v 10 \w Sus|strong="G3588"\w* \w discípulos|strong="G3101"\w* \w le|strong="G3326"\w* \w dijeron|strong="G3004"\w*: «\w Si|strong="G1487"\w* \w este|strong="G3588"\w* \w es|strong="G1487"\w* \w el|strong="G3588"\w* caso \w del|strong="G3588"\w* hombre \w con|strong="G3326"\w* \w su|strong="G3588"\w* \w mujer|strong="G1135"\w*, \w no|strong="G3756"\w* \w conviene|strong="G4851"\w* \w casarse|strong="G1060"\w*».   
\p
\v 11 \w Pero|strong="G1161"\w* \w él|strong="G3588"\w* les \w dijo|strong="G3004"\w*: \wj «\+w No|strong="G3756"\+w* \+w todos|strong="G3956"\+w* \+w los|strong="G3588"\+w* hombres pueden recibir \+w esta|strong="G3778"\+w* \+w palabra|strong="G3056"\+w*, \+w sino|strong="G1161"\+w* \+w aquellos|strong="G3588"\+w* \+w a|strong="G1161"\+w* \+w quienes|strong="G3739"\+w* se les ha \+w dado|strong="G1325"\+w*. \wj*  
