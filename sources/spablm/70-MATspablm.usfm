\v 17 \wj “\+w No|strong="G3756"\+w* \+w penséis|strong="G3543"\+w* \+w que|strong="G3754"\+w* he \+w venido|strong="G2064"\+w* a abolir \+w la|strong="G3588"\+w* \+w ley|strong="G3551"\+w* \+w o|strong="G2228"\+w* \+w los|strong="G3588"\+w* \+w profetas|strong="G4396"\+w*. \+w No|strong="G3756"\+w* he \+w venido|strong="G2064"\+w* a abolir, \+w sino|strong="G3361"\+w* a \+w cumplir|strong="G4137"\+w*. \wj*  
\v 18 \wj \+w Porque|strong="G1063"\+w* \+w de|strong="G3588"\+w* \+w cierto|strong="G1063"\+w* \+w os|strong="G3004"\+w* \+w digo|strong="G3004"\+w* \+w que|strong="G3588"\+w* \+w hasta|strong="G2193"\+w* \+w que|strong="G3588"\+w* pasen \+w el|strong="G3588"\+w* \+w cielo|strong="G3772"\+w* \+w y|strong="G2532"\+w* \+w la|strong="G3588"\+w* \+w tierra|strong="G1093"\+w*, \+w ni|strong="G2532"\+w* \+w una|strong="G1520"\+w* letra\wj*\f + \fr 5:18 \ft literalmente, iota\f* \wj mínima \+w ni|strong="G2532"\+w* \+w un|strong="G1520"\+w* trazo\wj*\f + \fr 5:18 \ft o, serif\f* \wj \+w de|strong="G3588"\+w* pluma \+w pasarán|strong="G3928"\+w* \+w de|strong="G3588"\+w* \+w la|strong="G3588"\+w* \+w ley|strong="G3551"\+w*, \+w hasta|strong="G2193"\+w* \+w que|strong="G3588"\+w* \+w todo|strong="G3956"\+w* \+w se|strong="G1096"\+w* cumpla. \wj*  
\v 19 \wj \+w Por|strong="G1722"\+w* \+w lo|strong="G3588"\+w* \+w tanto|strong="G3739"\+w*, \+w el|strong="G3588"\+w* \+w que|strong="G3588"\+w* quebrante \+w uno|strong="G1520"\+w* \+w de|strong="G1722"\+w* \+w estos|strong="G3778"\+w* \+w mandamientos|strong="G1785"\+w* \+w más|strong="G1161"\+w* pequeños \+w y|strong="G2532"\+w* \+w enseñe|strong="G1321"\+w* \+w a|strong="G1722"\+w* \+w otros|strong="G3588"\+w* \+w a|strong="G1722"\+w* hacerlo, será \+w llamado|strong="G2564"\+w* \+w el|strong="G3588"\+w* \+w más|strong="G1161"\+w* pequeño \+w en|strong="G1722"\+w* \+w el|strong="G3588"\+w* Reino \+w de|strong="G1722"\+w* \+w los|strong="G3588"\+w* \+w Cielos|strong="G3772"\+w*; \+w pero|strong="G1161"\+w* \+w el|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w los|strong="G3588"\+w* cumpla \+w y|strong="G2532"\+w* \+w los|strong="G3588"\+w* \+w enseñe|strong="G1321"\+w* será \+w llamado|strong="G2564"\+w* \+w grande|strong="G3173"\+w* \+w en|strong="G1722"\+w* \+w el|strong="G3588"\+w* Reino \+w de|strong="G1722"\+w* \+w los|strong="G3588"\+w* \+w Cielos|strong="G3772"\+w*. \wj*  
