\p
\v 11 Jesús les contestó: \wj «\+w En|strong="G3588"\+w* efecto, \+w Elías|strong="G2243"\+w* \+w viene|strong="G2064"\+w* primero \+w y|strong="G2532"\+w* restaurará \+w todas|strong="G3956"\+w* \+w las|strong="G3588"\+w* cosas; \wj*  
\v 12 \wj \+w pero|strong="G1161"\+w* yo \+w os|strong="G3004"\+w* \+w digo|strong="G3004"\+w* \+w que|strong="G3754"\+w* \+w Elías|strong="G2243"\+w* \+w ya|strong="G2235"\+w* \+w ha|strong="G3195"\+w* \+w venido|strong="G2064"\+w*, \+w y|strong="G2532"\+w* \+w no|strong="G3756"\+w* \+w lo|strong="G3588"\+w* reconocieron, \+w sino|strong="G1161"\+w* \+w que|strong="G3754"\+w* \+w le|strong="G1722"\+w* \+w hicieron|strong="G4160"\+w* \+w lo|strong="G3588"\+w* \+w que|strong="G3754"\+w* \+w quisieron|strong="G2309"\+w*. \+w Así|strong="G3779"\+w* \+w también|strong="G2532"\+w* \+w el|strong="G3588"\+w* \+w Hijo|strong="G5207"\+w* \+w del|strong="G3588"\+w* Hombre sufrirá \+w por|strong="G1722"\+w* \+w ellos|strong="G3588"\+w*». \wj*  
\v 13 \w Entonces|strong="G5119"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* comprendieron \w que|strong="G3754"\w* les \w hablaba|strong="G3004"\w* \w de|strong="G4012"\w* \w Juan|strong="G2491"\w* \w el|strong="G3588"\w* Bautista.   
\p
\v 14 Cuando \w llegaron|strong="G4334"\w* \w a|strong="G4314"\w* \w la|strong="G3588"\w* \w multitud|strong="G3793"\w*, \w se|strong="G4314"\w* \w le|strong="G4314"\w* acercó \w un|strong="G3588"\w* hombre \w que|strong="G3588"\w* \w se|strong="G4314"\w* arrodilló ante \w él|strong="G3588"\w* \w y|strong="G2532"\w* \w le|strong="G4314"\w* dijo:  
\v 15 «\w Señor|strong="G2962"\w*, ten compasión \w de|strong="G1519"\w* \w mi|strong="G3588"\w* \w hijo|strong="G5207"\w*, \w porque|strong="G1063"\w* es epiléptico \w y|strong="G2532"\w* sufre gravemente; \w pues|strong="G1063"\w* \w muchas|strong="G4178"\w* veces \w cae|strong="G4098"\w* \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w fuego|strong="G4442"\w* \w y|strong="G2532"\w* otras \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w agua|strong="G5204"\w*.  
\v 16 \w Lo|strong="G3588"\w* llevé a \w tus|strong="G3588"\w* \w discípulos|strong="G3101"\w*, \w y|strong="G2532"\w* \w no|strong="G3756"\w* \w pudieron|strong="G1410"\w* sanarlo».   
\p
\v 17 \w Jesús|strong="G2424"\w* respondió: \wj «¡\+w Generación|strong="G1074"\+w* infiel \+w y|strong="G2532"\+w* \+w perversa|strong="G1294"\+w*! ¿\+w Hasta|strong="G2193"\+w* \+w cuándo|strong="G4219"\+w* \+w estaré|strong="G1510"\+w* \+w con|strong="G3326"\+w* \+w vosotros|strong="G5210"\+w*? ¿\+w Hasta|strong="G2193"\+w* \+w cuándo|strong="G4219"\+w* \+w os|strong="G3004"\+w* soportaré? Traédmelo \+w a|strong="G2193"\+w* \+w mí|strong="G3588"\+w*». \wj*  
\v 18 \w Jesús|strong="G2424"\w* \w reprendió|strong="G2008"\w* \w al|strong="G3588"\w* \w demonio|strong="G1140"\w*, \w y|strong="G2532"\w* \w salió|strong="G1831"\w* \w de|strong="G3588"\w* \w él|strong="G3588"\w*, \w y|strong="G2532"\w* \w el|strong="G3588"\w* muchacho quedó \w sano|strong="G2323"\w* desde \w aquella|strong="G1565"\w* \w hora|strong="G5610"\w*.   
\p
\v 19 \w Entonces|strong="G5119"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* se acercaron \w a|strong="G2596"\w* \w Jesús|strong="G2424"\w* \w en|strong="G2596"\w* privado \w y|strong="G5119"\w* \w le|strong="G2596"\w* \w dijeron|strong="G3004"\w*: «¿\w Por|strong="G1223"\w* \w qué|strong="G3588"\w* \w no|strong="G3756"\w* \w pudimos|strong="G1410"\w* expulsarlo?»   
\p
\v 20 Les \w dijo|strong="G3004"\w*: \wj “\+w Por|strong="G1223"\+w* \+w vuestra|strong="G4771"\+w* incredulidad. \+w Porque|strong="G1063"\+w* \+w ciertamente|strong="G1063"\+w* \+w os|strong="G3004"\+w* \+w digo|strong="G3004"\+w* \+w que|strong="G3588"\+w* \+w si|strong="G1437"\+w* \+w tenéis|strong="G2192"\+w* \+w fe|strong="G4102"\+w* \+w como|strong="G5613"\+w* \+w un|strong="G3588"\+w* \+w grano|strong="G2848"\+w* \+w de|strong="G1223"\+w* mostaza, le \+w diréis|strong="G2046"\+w* \+w a|strong="G1161"\+w* \+w este|strong="G3778"\+w* \+w monte|strong="G3735"\+w*: «Muévete \+w de|strong="G1223"\+w* \+w aquí|strong="G1759"\+w* \+w para|strong="G1223"\+w* \+w allá|strong="G1563"\+w*», \+w y|strong="G2532"\+w* \+w se|strong="G2532"\+w* moverá; \+w y|strong="G2532"\+w* \+w nada|strong="G3762"\+w* \+w os|strong="G3004"\+w* será imposible. \wj*  
\v 21 \wj Pero esta clase no sale sino con oración y ayuno”. \wj*   
\p
\v 22 Mientras \w estaban|strong="G3195"\w* \w en|strong="G1722"\w* \w Galilea|strong="G1056"\w*, \w Jesús|strong="G2424"\w* \w les|strong="G1519"\w* \w dijo|strong="G3004"\w*: \wj «\+w El|strong="G3588"\+w* \+w Hijo|strong="G5207"\+w* \+w del|strong="G3588"\+w* Hombre va \+w a|strong="G1519"\+w* ser \+w entregado|strong="G3860"\+w* \+w en|strong="G1722"\+w* \+w manos|strong="G5495"\+w* \+w de|strong="G1722"\+w* \+w los|strong="G3588"\+w* hombres, \wj*  
\v 23 \wj \+w y|strong="G2532"\+w* \+w lo|strong="G3588"\+w* matarán, \+w y|strong="G2532"\+w* \+w al|strong="G3588"\+w* \+w tercer|strong="G5154"\+w* \+w día|strong="G2250"\+w* \+w resucitará|strong="G1453"\+w*.» \wj*  
\p \w Lo|strong="G3588"\w* sentían \w mucho|strong="G4970"\w*.   
\p
\v 24 Cuando \w llegaron|strong="G4334"\w* \w a|strong="G1519"\w* \w Capernaúm|strong="G2584"\w*, \w los|strong="G3588"\w* \w que|strong="G3588"\w* recogían \w las|strong="G3588"\w* monedas\f + \fr 17:24 \ft Una didracma es una moneda de plata griega que vale 2 dracmas, más o menos lo mismo que 2 denarios romanos, o sea, el salario de 2 días. Se utilizaba comúnmente para pagar el impuesto del templo de medio shekel, porque 2 dracmas valían un medio shekel de plata. Un siclo equivale a unos 10 gramos o a unas 0,35 onzas.\f* \w de|strong="G1519"\w* \w la|strong="G3588"\w* didracma \w se|strong="G2532"\w* acercaron \w a|strong="G1519"\w* \w Pedro|strong="G4074"\w* \w y|strong="G2532"\w* \w le|strong="G1519"\w* \w dijeron|strong="G3004"\w*: «¿\w Tu|strong="G4771"\w* \w maestro|strong="G1320"\w* \w no|strong="G3756"\w* \w paga|strong="G5055"\w* \w la|strong="G3588"\w* didracma?»  
\v 25 \w Él|strong="G3588"\w* respondió: «\w Sí|strong="G3483"\w*».  
\p Cuando \w entró|strong="G1525"\w* \w en|strong="G1519"\w* \w la|strong="G3588"\w* \w casa|strong="G3614"\w*, \w Jesús|strong="G2424"\w* \w se|strong="G2532"\w* \w le|strong="G1519"\w* anticipó \w diciendo|strong="G3004"\w*: \wj «¿\+w Qué|strong="G3588"\+w* \+w te|strong="G4771"\+w* \+w parece|strong="G1380"\+w*, \+w Simón|strong="G4613"\+w*? ¿\+w De|strong="G1519"\+w* \+w quién|strong="G5101"\+w* reciben peaje \+w o|strong="G2228"\+w* \+w tributo|strong="G2778"\+w* \+w los|strong="G3588"\+w* reyes \+w de|strong="G1519"\+w* \+w la|strong="G3588"\+w* \+w tierra|strong="G1093"\+w*? ¿\+w De|strong="G1519"\+w* \+w sus|strong="G3588"\+w* \+w hijos|strong="G5207"\+w*, \+w o|strong="G2228"\+w* \+w de|strong="G1519"\+w* \+w los|strong="G3588"\+w* extraños?» \wj*   
\p
\v 26 Pedro le \w dijo|strong="G3004"\w*: «\w De|strong="G3588"\w* \w los|strong="G3588"\w* extraños».  
\p \w Jesús|strong="G2424"\w* le \w dijo|strong="G3004"\w*: \wj «\+w Por|strong="G3588"\+w* \+w lo|strong="G3588"\+w* tanto, \+w los|strong="G3588"\+w* \+w hijos|strong="G5207"\+w* están exentos. \wj*  
\v 27 \wj \+w Pero|strong="G1161"\+w*, \+w para|strong="G1519"\+w* \+w no|strong="G3361"\+w* hacerles tropezar, \+w ve|strong="G4198"\+w* \+w al|strong="G3588"\+w* \+w mar|strong="G2281"\+w*, echa \+w el|strong="G3588"\+w* anzuelo \+w y|strong="G2532"\+w* recoge \+w el|strong="G3588"\+w* \+w primer|strong="G4413"\+w* \+w pez|strong="G2486"\+w* \+w que|strong="G3588"\+w* salga. \+w Cuando|strong="G2443"\+w* \+w le|strong="G1438"\+w* hayas abierto \+w la|strong="G3588"\+w* \+w boca|strong="G4750"\+w*, encontrarás \+w una|strong="G3588"\+w* moneda \+w de|strong="G1519"\+w* plata.\wj*\f + \fr 17:27 \ft Un stater es una moneda de plata equivalente a cuatro dracmas áticas o dos alejandrinas, o a un siclo judío: lo suficiente para cubrir el impuesto de medio siclo del templo para dos personas. Un siclo equivale a unos 10 gramos o unas 0,35 onzas, generalmente en forma de moneda de plata.\f* \wj Tómala \+w y|strong="G2532"\+w* dásela \+w por|strong="G1519"\+w* \+w mí|strong="G3588"\+w* \+w y|strong="G2532"\+w* \+w por|strong="G1519"\+w* \+w ti|strong="G1438"\+w*». \wj*   
\c 18
\p
\v 1 \w En|strong="G1722"\w* \w aquella|strong="G1565"\w* \w hora|strong="G5610"\w*, \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* se acercaron \w a|strong="G1722"\w* \w Jesús|strong="G2424"\w* \w y|strong="G1510"\w* \w le|strong="G1722"\w* \w dijeron|strong="G3004"\w*: «¿\w Quién|strong="G5101"\w* es \w el|strong="G3588"\w* \w mayor|strong="G3173"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* Reino \w de|strong="G1722"\w* \w los|strong="G3588"\w* \w Cielos|strong="G3772"\w*?»   
\p
\v 2 Jesús \w llamó|strong="G4341"\w* \w a|strong="G1722"\w* \w un|strong="G1722"\w* \w niño|strong="G3813"\w*, lo puso \w en|strong="G1722"\w* \w medio|strong="G3319"\w* \w de|strong="G1722"\w* ellos  
\v 3 \w y|strong="G2532"\w* \w les|strong="G1519"\w* \w dijo|strong="G3004"\w*: \wj “\+w Os|strong="G3004"\+w* aseguro \+w que|strong="G3588"\+w* \+w si|strong="G1437"\+w* \+w no|strong="G3756"\+w* \+w os|strong="G3004"\+w* convertís \+w y|strong="G2532"\+w* \+w os|strong="G3004"\+w* hacéis \+w como|strong="G5613"\+w* \+w niños|strong="G3813"\+w*, \+w no|strong="G3756"\+w* \+w entraréis|strong="G1525"\+w* \+w en|strong="G1519"\+w* \+w el|strong="G3588"\+w* Reino \+w de|strong="G1519"\+w* \+w los|strong="G3588"\+w* \+w Cielos|strong="G3772"\+w*. \wj*  
\v 4 \wj \+w Por|strong="G1722"\+w* tanto, \+w el|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w se|strong="G1438"\+w* \+w humille|strong="G5013"\+w* \+w como|strong="G5613"\+w* \+w este|strong="G3778"\+w* \+w niño|strong="G3813"\+w* \+w es|strong="G3778"\+w* \+w el|strong="G3588"\+w* \+w mayor|strong="G3173"\+w* \+w en|strong="G1722"\+w* \+w el|strong="G3588"\+w* Reino \+w de|strong="G1722"\+w* \+w los|strong="G3588"\+w* \+w Cielos|strong="G3772"\+w*. \wj*  
\v 5 \wj \+w El|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w recibe|strong="G1209"\+w* \+w a|strong="G1909"\+w* \+w un|strong="G1520"\+w* \+w niño|strong="G3813"\+w* \+w como|strong="G2532"\+w* \+w éste|strong="G3588"\+w* \+w en|strong="G1909"\+w* \+w mi|strong="G3588"\+w* \+w nombre|strong="G3686"\+w*, \+w me|strong="G1473"\+w* \+w recibe|strong="G1209"\+w* \+w a|strong="G1909"\+w* \+w mí|strong="G3588"\+w*;\wj*  
\v 6 \wj \+w pero|strong="G1161"\+w* \+w el|strong="G3588"\+w* \+w que|strong="G3588"\+w* hace tropezar \+w a|strong="G1519"\+w* \+w uno|strong="G1520"\+w* \+w de|strong="G4012"\+w* \+w estos|strong="G3778"\+w* \+w pequeños|strong="G3398"\+w* \+w que|strong="G3588"\+w* \+w creen|strong="G4100"\+w* \+w en|strong="G1722"\+w* \+w mí|strong="G3588"\+w*, \+w más|strong="G1161"\+w* \+w le|strong="G1722"\+w* valdría \+w que|strong="G3588"\+w* \+w le|strong="G1722"\+w* colgaran \+w al|strong="G3588"\+w* \+w cuello|strong="G5137"\+w* \+w una|strong="G1520"\+w* enorme piedra \+w de|strong="G4012"\+w* molino \+w y|strong="G2532"\+w* \+w lo|strong="G3588"\+w* hundieran \+w en|strong="G1722"\+w* \+w el|strong="G3588"\+w* fondo \+w del|strong="G3588"\+w* \+w mar|strong="G2281"\+w*. \wj*   
\p
\v 7 \wj “¡\+w Ay|strong="G3759"\+w* \+w del|strong="G3588"\+w* \+w mundo|strong="G2889"\+w* \+w por|strong="G1223"\+w* \+w los|strong="G3588"\+w* tropiezos! \+w Porque|strong="G1063"\+w* \+w es|strong="G3739"\+w* necesario \+w que|strong="G3588"\+w* \+w las|strong="G3588"\+w* ocasiones \+w vengan|strong="G2064"\+w*, \+w pero|strong="G1063"\+w* ¡\+w ay|strong="G3759"\+w* \+w de|strong="G1223"\+w* \+w la|strong="G3588"\+w* persona \+w por|strong="G1223"\+w* \+w la|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w viene|strong="G2064"\+w* \+w la|strong="G3588"\+w* ocasión! \wj*  
\v 8 \wj \+w Si|strong="G1487"\+w* \+w tu|strong="G4771"\+w* \+w mano|strong="G5495"\+w* \+w o|strong="G2228"\+w* \+w tu|strong="G4771"\+w* \+w pie|strong="G4228"\+w* \+w te|strong="G4771"\+w* hacen tropezar, \+w córtalo|strong="G1581"\+w* \+w y|strong="G2532"\+w* apártalo \+w de|strong="G1519"\+w* ti. \+w Es|strong="G1487"\+w* \+w mejor|strong="G2570"\+w* \+w que|strong="G3588"\+w* \+w entres|strong="G1525"\+w* \+w en|strong="G1519"\+w* \+w la|strong="G3588"\+w* \+w vida|strong="G2222"\+w* \+w manco|strong="G5560"\+w* \+w o|strong="G2228"\+w* lisiado, \+w antes|strong="G1161"\+w* \+w que|strong="G3588"\+w* \+w tener|strong="G2192"\+w* \+w dos|strong="G1417"\+w* \+w manos|strong="G5495"\+w* \+w o|strong="G2228"\+w* \+w dos|strong="G1417"\+w* \+w pies|strong="G4228"\+w* \+w para|strong="G1519"\+w* \+w ser|strong="G2192"\+w* arrojado \+w al|strong="G3588"\+w* \+w fuego|strong="G4442"\+w* eterno. \wj*  
\v 9 \wj \+w Si|strong="G1487"\+w* \+w tu|strong="G4771"\+w* \+w ojo|strong="G3788"\+w* \+w te|strong="G4771"\+w* hace tropezar, arráncalo \+w y|strong="G2532"\+w* échalo \+w de|strong="G1519"\+w* ti. \+w Es|strong="G1487"\+w* \+w mejor|strong="G2570"\+w* \+w que|strong="G3588"\+w* \+w entres|strong="G1525"\+w* \+w en|strong="G1519"\+w* \+w la|strong="G3588"\+w* \+w vida|strong="G2222"\+w* \+w con|strong="G2532"\+w* \+w un|strong="G3588"\+w* solo \+w ojo|strong="G3788"\+w*, \+w en|strong="G1519"\+w* lugar \+w de|strong="G1519"\+w* \+w tener|strong="G2192"\+w* \+w dos|strong="G1417"\+w* \+w ojos|strong="G3788"\+w* \+w para|strong="G1519"\+w* \+w ser|strong="G2192"\+w* arrojado \+w a|strong="G1519"\+w* \+w la|strong="G3588"\+w* \+w Gehenna|strong="G1067"\+w*\wj*\f + \fr 18:9 \ft NU omite el versículo 11.\f* \wj \+w del|strong="G3588"\+w* \+w fuego|strong="G4442"\+w*. \wj*  
\v 10 \wj \+w Mirad|strong="G3708"\+w* \+w que|strong="G3754"\+w* \+w no|strong="G3361"\+w* despreciéis \+w a|strong="G1722"\+w* \+w uno|strong="G1520"\+w* \+w de|strong="G1722"\+w* \+w estos|strong="G3778"\+w* \+w pequeños|strong="G3398"\+w*, \+w porque|strong="G1063"\+w* \+w os|strong="G3004"\+w* \+w digo|strong="G3004"\+w* \+w que|strong="G3754"\+w* \+w en|strong="G1722"\+w* \+w el|strong="G3588"\+w* \+w cielo|strong="G3772"\+w* \+w sus|strong="G3588"\+w* ángeles ven \+w siempre|strong="G3588"\+w* \+w el|strong="G3588"\+w* \+w rostro|strong="G4383"\+w* \+w de|strong="G1722"\+w* \+w mi|strong="G3588"\+w* \+w Padre|strong="G3962"\+w* \+w que|strong="G3754"\+w* \+w está|strong="G3778"\+w* \+w en|strong="G1722"\+w* \+w el|strong="G3588"\+w* \+w cielo|strong="G3772"\+w*. \wj*  
\v 11 \wj Porque el Hijo del Hombre ha venido a salvar lo que se había perdido. \wj*   
\p
\v 12 \wj “¿\+w Qué|strong="G3588"\+w* \+w os|strong="G5210"\+w* \+w parece|strong="G1380"\+w*? \+w Si|strong="G1437"\+w* \+w un|strong="G1520"\+w* hombre tiene \+w cien|strong="G1540"\+w* \+w ovejas|strong="G4263"\+w*, \+w y|strong="G2532"\+w* \+w una|strong="G1520"\+w* \+w de|strong="G1537"\+w* \+w ellas|strong="G3588"\+w* \+w se|strong="G1096"\+w* extravía, ¿\+w no|strong="G3780"\+w* deja \+w las|strong="G3588"\+w* noventa \+w y|strong="G2532"\+w* \+w nueve|strong="G1767"\+w*, \+w va|strong="G4198"\+w* \+w a|strong="G1909"\+w* \+w los|strong="G3588"\+w* \+w montes|strong="G3735"\+w* \+w y|strong="G2532"\+w* \+w busca|strong="G2212"\+w* \+w la|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w se|strong="G1096"\+w* ha extraviado? \wj*  
\v 13 \wj \+w Si|strong="G1437"\+w* \+w la|strong="G3588"\+w* encuentra, \+w os|strong="G3004"\+w* aseguro \+w que|strong="G3754"\+w* \+w se|strong="G1096"\+w* alegra \+w más|strong="G2532"\+w* \+w por|strong="G1909"\+w* \+w ella|strong="G3588"\+w* \+w que|strong="G3754"\+w* \+w por|strong="G1909"\+w* \+w las|strong="G3588"\+w* noventa \+w y|strong="G2532"\+w* \+w nueve|strong="G1767"\+w* \+w que|strong="G3754"\+w* \+w no|strong="G3361"\+w* \+w se|strong="G1096"\+w* \+w han|strong="G3361"\+w* descarriado. \wj*  
\v 14 \wj \+w Así|strong="G3779"\+w* \+w pues|strong="G3779"\+w*, \+w no|strong="G3756"\+w* \+w es|strong="G3756"\+w* \+w la|strong="G3588"\+w* \+w voluntad|strong="G2307"\+w* \+w de|strong="G1722"\+w* \+w vuestro|strong="G3588"\+w* \+w Padre|strong="G3962"\+w* \+w que|strong="G3588"\+w* \+w está|strong="G3778"\+w* \+w en|strong="G1722"\+w* \+w los|strong="G3588"\+w* \+w cielos|strong="G3772"\+w* \+w que|strong="G3588"\+w* \+w se|strong="G3779"\+w* pierda \+w uno|strong="G1520"\+w* \+w de|strong="G1722"\+w* \+w estos|strong="G3778"\+w* \+w pequeños|strong="G3398"\+w*. \wj*   
\p
\v 15 \wj «\+w Si|strong="G1437"\+w* \+w tu|strong="G4771"\+w* hermano peca \+w contra|strong="G1519"\+w* ti, \+w ve|strong="G5217"\+w*, muéstrale \+w su|strong="G3588"\+w* falta \+w entre|strong="G1519"\+w* \+w tú|strong="G4771"\+w* \+w y|strong="G2532"\+w* \+w él|strong="G3588"\+w* \+w solo|strong="G3441"\+w*. \+w Si|strong="G1437"\+w* \+w te|strong="G4771"\+w* escucha, habrás recuperado \+w a|strong="G1519"\+w* \+w tu|strong="G4771"\+w* hermano. \wj*  
\v 16 \wj \+w Pero|strong="G1161"\+w* \+w si|strong="G1437"\+w* \+w no|strong="G3361"\+w* \+w te|strong="G4771"\+w* escucha, llévate \+w a|strong="G1909"\+w* \+w uno|strong="G1520"\+w* \+w o|strong="G2228"\+w* \+w dos|strong="G1417"\+w* \+w más|strong="G1161"\+w* \+w contigo|strong="G3326"\+w*, \+w para|strong="G2443"\+w* \+w que|strong="G2443"\+w* \+w en|strong="G1909"\+w* \+w boca|strong="G4750"\+w* \+w de|strong="G1909"\+w* \+w dos|strong="G1417"\+w* \+w o|strong="G2228"\+w* \+w tres|strong="G5140"\+w* \+w testigos|strong="G3144"\+w* quede establecida \+w toda|strong="G3956"\+w* \+w palabra|strong="G4487"\+w*. \wj*\f + \fr 18:16 \ft Deuteronomio 19:15\f*  
\v 17 \wj \+w Si|strong="G1437"\+w* \+w se|strong="G2532"\+w* niega \+w a|strong="G1161"\+w* escucharles, díselo \+w a|strong="G1161"\+w* \+w la|strong="G3588"\+w* asamblea. \+w Si|strong="G1437"\+w* \+w también|strong="G2532"\+w* \+w se|strong="G2532"\+w* niega \+w a|strong="G1161"\+w* escuchar \+w a|strong="G1161"\+w* \+w la|strong="G3588"\+w* asamblea, \+w que|strong="G3588"\+w* \+w sea|strong="G3588"\+w* para ti \+w como|strong="G5618"\+w* \+w un|strong="G3588"\+w* gentil \+w o|strong="G2532"\+w* \+w un|strong="G3588"\+w* recaudador \+w de|strong="G3588"\+w* impuestos. \wj*  
