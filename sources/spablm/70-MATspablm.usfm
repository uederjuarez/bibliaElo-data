\v 22 \wj \+w Lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w se|strong="G1096"\+w* \+w sembró|strong="G4687"\+w* \+w entre|strong="G1519"\+w* espinos, \+w éste|strong="G3778"\+w* \+w es|strong="G1096"\+w* \+w el|strong="G3588"\+w* \+w que|strong="G3588"\+w* oye \+w la|strong="G3588"\+w* \+w palabra|strong="G3056"\+w*, \+w pero|strong="G1161"\+w* \+w los|strong="G3588"\+w* afanes \+w de|strong="G1519"\+w* \+w este|strong="G3778"\+w* siglo \+w y|strong="G2532"\+w* \+w el|strong="G3588"\+w* engaño \+w de|strong="G1519"\+w* \+w las|strong="G3588"\+w* \+w riquezas|strong="G4149"\+w* \+w ahogan|strong="G4846"\+w* \+w la|strong="G3588"\+w* \+w palabra|strong="G3056"\+w*, \+w y|strong="G2532"\+w* queda \+w sin|strong="G2532"\+w* fruto. \wj*  
