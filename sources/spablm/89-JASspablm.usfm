\c 1
\p
\v 1 Santiago, \w siervo|strong="G1401"\w* \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*, \w a|strong="G1722"\w* \w las|strong="G3588"\w* \w doce|strong="G1427"\w* \w tribus|strong="G5443"\w* \w que|strong="G3588"\w* están \w en|strong="G1722"\w* \w la|strong="G3588"\w* Dispersión: Saludos.   
\p
\v 2 Hermanos míos, estad contentos \w cuando|strong="G3752"\w* caigáis \w en|strong="G3752"\w* \w diversas|strong="G4164"\w* pruebas,  
\v 3 \w sabiendo|strong="G1097"\w* \w que|strong="G3754"\w* \w la|strong="G3588"\w* \w prueba|strong="G1383"\w* \w de|strong="G3588"\w* \w vuestra|strong="G3588"\w* \w fe|strong="G4102"\w* \w produce|strong="G2716"\w* \w paciencia|strong="G5281"\w*.  
\v 4 Dejad \w que|strong="G3588"\w* \w la|strong="G3588"\w* \w paciencia|strong="G5281"\w* \w tenga|strong="G2192"\w* \w su|strong="G3588"\w* \w obra|strong="G2041"\w* \w perfecta|strong="G5046"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* seáis \w perfectos|strong="G5046"\w* \w y|strong="G2532"\w* \w cabales|strong="G3648"\w*, \w sin|strong="G3367"\w* \w que|strong="G3588"\w* os \w falte|strong="G3007"\w* \w nada|strong="G3367"\w*.   
\p
\v 5 \w Pero|strong="G1161"\w* \w si|strong="G1487"\w* \w a|strong="G3844"\w* \w alguno|strong="G5100"\w* \w de|strong="G3844"\w* \w vosotros|strong="G5210"\w* le \w falta|strong="G3007"\w* \w sabiduría|strong="G4678"\w*, pídala \w a|strong="G3844"\w* \w Dios|strong="G2316"\w*, \w que|strong="G3588"\w* \w da|strong="G1325"\w* \w a|strong="G3844"\w* \w todos|strong="G3956"\w* \w con|strong="G3844"\w* liberalidad \w y|strong="G2532"\w* \w sin|strong="G3361"\w* reproche, \w y|strong="G2532"\w* le será concedida.  
\v 6 \w Pero|strong="G1161"\w* \w que|strong="G3588"\w* pida \w con|strong="G1722"\w* \w fe|strong="G4102"\w*, \w sin|strong="G3367"\w* \w dudar|strong="G1252"\w*, \w porque|strong="G1063"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* duda es \w como|strong="G2532"\w* \w la|strong="G3588"\w* ola \w del|strong="G3588"\w* \w mar|strong="G2281"\w*, impulsada \w por|strong="G1722"\w* \w el|strong="G3588"\w* viento \w y|strong="G2532"\w* zarandeada.  
\v 7 \w Porque|strong="G1063"\w* ese hombre \w no|strong="G3361"\w* debe pensar \w que|strong="G3754"\w* \w recibirá|strong="G2983"\w* \w algo|strong="G5100"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*.  
\v 8 Es \w un|strong="G3588"\w* hombre \w de|strong="G1722"\w* doble ánimo, inestable \w en|strong="G1722"\w* \w todos|strong="G3956"\w* \w sus|strong="G3588"\w* \w caminos|strong="G3598"\w*.   
\p
\v 9 \w Que|strong="G3588"\w* \w el|strong="G3588"\w* hermano \w de|strong="G1722"\w* condición \w humilde|strong="G5011"\w* se \w gloríe|strong="G2744"\w* \w en|strong="G1722"\w* \w su|strong="G3588"\w* alta posición;  
\v 10 \w y|strong="G1161"\w* \w el|strong="G3588"\w* \w rico|strong="G4145"\w*, \w en|strong="G1722"\w* \w su|strong="G3588"\w* \w humillación|strong="G5014"\w*, \w porque|strong="G3754"\w* \w como|strong="G5613"\w* \w la|strong="G3588"\w* flor \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w hierba|strong="G5528"\w*, \w pasará|strong="G3928"\w*.  
\v 11 \w Porque|strong="G1063"\w* \w el|strong="G3588"\w* \w sol|strong="G2246"\w* \w se|strong="G3779"\w* levanta \w con|strong="G1722"\w* \w el|strong="G3588"\w* viento abrasador \w y|strong="G2532"\w* marchita \w la|strong="G3588"\w* \w hierba|strong="G5528"\w*; \w y|strong="G2532"\w* \w su|strong="G3588"\w* flor cae, \w y|strong="G2532"\w* \w la|strong="G3588"\w* belleza \w de|strong="G1722"\w* \w su|strong="G3588"\w* aspecto perece. \w Así|strong="G3779"\w* \w también|strong="G2532"\w* \w el|strong="G3588"\w* \w rico|strong="G4145"\w* \w se|strong="G3779"\w* desvanecerá \w en|strong="G1722"\w* \w sus|strong="G3588"\w* \w caminos|strong="G4197"\w*.   
\p
\v 12 \w Bienaventurado|strong="G3107"\w* \w el|strong="G3588"\w* varón \w que|strong="G3754"\w* soporta \w la|strong="G3588"\w* \w tentación|strong="G3986"\w*, \w porque|strong="G3754"\w* cuando \w haya|strong="G1096"\w* \w sido|strong="G1096"\w* \w aprobado|strong="G1384"\w*, \w recibirá|strong="G2983"\w* \w la|strong="G3588"\w* \w corona|strong="G4735"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w vida|strong="G2222"\w* \w que|strong="G3754"\w* \w el|strong="G3588"\w* Señor \w prometió|strong="G1861"\w* a \w los|strong="G3588"\w* \w que|strong="G3754"\w* le aman.   
\p
\v 13 \w Que|strong="G3754"\w* \w nadie|strong="G3762"\w* diga cuando es \w tentado|strong="G3985"\w*: «\w Soy|strong="G1510"\w* \w tentado|strong="G3985"\w* \w por|strong="G3754"\w* \w Dios|strong="G2316"\w*», \w porque|strong="G1063"\w* \w Dios|strong="G2316"\w* \w no|strong="G3367"\w* puede ser \w tentado|strong="G3985"\w* \w por|strong="G3754"\w* \w el|strong="G3588"\w* \w mal|strong="G2556"\w*, \w y|strong="G1161"\w* \w él|strong="G3588"\w* mismo \w no|strong="G3367"\w* \w tienta|strong="G3985"\w* \w a|strong="G1161"\w* \w nadie|strong="G3762"\w*.  
\v 14 \w Pero|strong="G1161"\w* \w cada|strong="G1538"\w* \w uno|strong="G1538"\w* es \w tentado|strong="G3985"\w* cuando es atraído \w por|strong="G5259"\w* \w su|strong="G3588"\w* \w propia|strong="G2398"\w* \w concupiscencia|strong="G1939"\w* \w y|strong="G2532"\w* seducido.  
\v 15 \w Entonces|strong="G1161"\w* \w la|strong="G3588"\w* \w concupiscencia|strong="G1939"\w*, cuando ha concebido, engendra \w el|strong="G3588"\w* pecado. \w El|strong="G3588"\w* pecado, cuando ha crecido, \w produce|strong="G5088"\w* \w la|strong="G3588"\w* \w muerte|strong="G2288"\w*.  
\v 16 \w No|strong="G3361"\w* os dejéis \w engañar|strong="G4105"\w*, mis amados hermanos.  
\v 17 \w Toda|strong="G3956"\w* buena \w dádiva|strong="G1394"\w* \w y|strong="G2532"\w* \w todo|strong="G3956"\w* \w don|strong="G1434"\w* \w perfecto|strong="G5046"\w* viene \w de|strong="G3844"\w* \w lo|strong="G3588"\w* alto, \w del|strong="G3588"\w* \w Padre|strong="G3962"\w* \w de|strong="G3844"\w* \w las|strong="G3588"\w* \w luces|strong="G5457"\w*, \w en|strong="G3844"\w* \w quien|strong="G3739"\w* \w no|strong="G3756"\w* puede haber variación \w ni|strong="G2532"\w* sombra \w de|strong="G3844"\w* cambio.  
\v 18 \w De|strong="G1519"\w* \w su|strong="G3588"\w* propia voluntad nos hizo nacer \w por|strong="G1519"\w* \w la|strong="G3588"\w* \w palabra|strong="G3056"\w* \w de|strong="G1519"\w* \w la|strong="G3588"\w* verdad, \w para|strong="G1519"\w* \w que|strong="G3588"\w* seamos \w una|strong="G5100"\w* especie \w de|strong="G1519"\w* primicias \w de|strong="G1519"\w* \w sus|strong="G3588"\w* \w criaturas|strong="G2938"\w*.   
\p
\v 19 \w Así|strong="G1161"\w* \w que|strong="G3588"\w*, mis amados hermanos, \w todo|strong="G3956"\w* hombre \w sea|strong="G3588"\w* \w pronto|strong="G5036"\w* \w para|strong="G1519"\w* oír, tardo \w para|strong="G1519"\w* \w hablar|strong="G2980"\w* \w y|strong="G1161"\w* tardo \w para|strong="G1519"\w* \w la|strong="G3588"\w* \w ira|strong="G3709"\w*;  
\v 20 \w porque|strong="G1063"\w* la \w ira|strong="G3709"\w* del hombre \w no|strong="G3756"\w* produce la \w justicia|strong="G1343"\w* de \w Dios|strong="G2316"\w*.  
\v 21 \w Por|strong="G1722"\w* tanto, desechando \w toda|strong="G3956"\w* \w inmundicia|strong="G4507"\w* \w y|strong="G2532"\w* \w abundancia|strong="G4050"\w* \w de|strong="G1722"\w* \w maldad|strong="G2549"\w*, \w recibid|strong="G1209"\w* \w con|strong="G1722"\w* \w mansedumbre|strong="G4240"\w* \w la|strong="G3588"\w* \w palabra|strong="G3056"\w* implantada, \w la|strong="G3588"\w* \w cual|strong="G3588"\w* \w puede|strong="G1410"\w* \w salvar|strong="G4982"\w* \w vuestras|strong="G3588"\w* \w almas|strong="G5590"\w*.   
\p
\v 22 \w Pero|strong="G1161"\w* \w sed|strong="G1096"\w* \w hacedores|strong="G4163"\w* \w de|strong="G1161"\w* la \w palabra|strong="G3056"\w*, \w y|strong="G2532"\w* \w no|strong="G3361"\w* \w sólo|strong="G3441"\w* oidores, \w engañándoos|strong="G3884"\w* \w a|strong="G1161"\w* \w vosotros|strong="G1438"\w* mismos.  
\v 23 \w Porque|strong="G3754"\w* \w si|strong="G1487"\w* \w alguno|strong="G5100"\w* \w es|strong="G1487"\w* oidor \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w palabra|strong="G3056"\w* \w y|strong="G2532"\w* \w no|strong="G3756"\w* \w hacedor|strong="G4163"\w*, \w es|strong="G1487"\w* \w como|strong="G2532"\w* \w un|strong="G5100"\w* hombre \w que|strong="G3754"\w* mira \w su|strong="G3588"\w* \w rostro|strong="G4383"\w* \w natural|strong="G1078"\w* \w en|strong="G1722"\w* \w un|strong="G5100"\w* \w espejo|strong="G2072"\w*;  
\v 24 \w porque|strong="G1063"\w* \w se|strong="G1438"\w* ve a \w sí|strong="G1438"\w* mismo, \w y|strong="G2532"\w* \w se|strong="G1438"\w* va, \w y|strong="G2532"\w* enseguida \w se|strong="G1438"\w* olvida de la clase de hombre \w que|strong="G1063"\w* \w era|strong="G1510"\w*.  
\v 25 \w Pero|strong="G1161"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* mira atentamente \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w perfecta|strong="G5046"\w* \w ley|strong="G3551"\w*, \w la|strong="G3588"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w libertad|strong="G1657"\w*, \w y|strong="G2532"\w* persevera \w en|strong="G1722"\w* \w ella|strong="G3588"\w*, \w no|strong="G3756"\w* \w siendo|strong="G1096"\w* \w un|strong="G3588"\w* oidor \w olvidadizo|strong="G1953"\w*, \w sino|strong="G1161"\w* \w un|strong="G3588"\w* \w hacedor|strong="G4163"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w obra|strong="G2041"\w*, \w este|strong="G3778"\w* \w será|strong="G1096"\w* \w bienaventurado|strong="G3107"\w* \w en|strong="G1722"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \w hace|strong="G2041"\w*.   
\p
\v 26 \w Si|strong="G1487"\w* \w alguno|strong="G5100"\w* \w de|strong="G3588"\w* \w vosotros|strong="G3588"\w* se cree \w religioso|strong="G2357"\w* mientras \w no|strong="G3361"\w* \w refrena|strong="G5468"\w* \w su|strong="G3588"\w* \w lengua|strong="G1100"\w*, \w sino|strong="G1487"\w* \w que|strong="G3588"\w* engaña a \w su|strong="G3588"\w* \w corazón|strong="G2588"\w*, \w la|strong="G3588"\w* \w religión|strong="G2356"\w* \w de|strong="G3588"\w* \w ese|strong="G3778"\w* hombre \w es|strong="G1487"\w* \w vana|strong="G3152"\w*.  
\v 27 \w La|strong="G3588"\w* \w religión|strong="G2356"\w* \w pura|strong="G2513"\w* \w y|strong="G2532"\w* \w sin|strong="G2532"\w* mácula ante \w Dios|strong="G2316"\w* \w el|strong="G3588"\w* \w Padre|strong="G3962"\w* \w es|strong="G3778"\w* \w esta|strong="G3778"\w*: \w visitar|strong="G1980"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w huérfanos|strong="G3737"\w* \w y|strong="G2532"\w* \w a|strong="G1722"\w* \w las|strong="G3588"\w* \w viudas|strong="G5503"\w* \w en|strong="G1722"\w* \w sus|strong="G3588"\w* \w tribulaciones|strong="G2347"\w*, \w y|strong="G2532"\w* guardarse \w sin|strong="G2532"\w* mancha \w del|strong="G3588"\w* \w mundo|strong="G2889"\w*.   
\c 2
\p
\v 1 Hermanos míos, \w no|strong="G3361"\w* \w tengáis|strong="G2192"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w de|strong="G1722"\w* \w nuestro|strong="G2249"\w* \w glorioso|strong="G1391"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w* \w con|strong="G1722"\w* \w acepción|strong="G4382"\w* \w de|strong="G1722"\w* personas.  
\v 2 \w Porque|strong="G1063"\w* \w si|strong="G1437"\w* \w entra|strong="G1525"\w* \w en|strong="G1722"\w* \w vuestra|strong="G4771"\w* \w congregación|strong="G4864"\w* \w un|strong="G1722"\w* hombre \w con|strong="G1722"\w* \w un|strong="G1722"\w* anillo \w de|strong="G1722"\w* oro, \w vestido|strong="G2066"\w* \w con|strong="G1722"\w* ropas finas, \w y|strong="G2532"\w* \w entra|strong="G1525"\w* \w también|strong="G2532"\w* \w un|strong="G1722"\w* \w pobre|strong="G4434"\w* \w vestido|strong="G2066"\w* \w con|strong="G1722"\w* ropas sucias,  
\v 3 \w y|strong="G2532"\w* \w os|strong="G3004"\w* fijáis especialmente \w en|strong="G1909"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w lleva|strong="G5409"\w* \w las|strong="G3588"\w* ropas finas \w y|strong="G2532"\w* \w le|strong="G1909"\w* \w decís|strong="G3004"\w*: «\w Siéntate|strong="G2521"\w* \w aquí|strong="G5602"\w* \w en|strong="G1909"\w* \w un|strong="G3588"\w* buen lugar», \w y|strong="G2532"\w* \w al|strong="G3588"\w* \w pobre|strong="G4434"\w* \w le|strong="G1909"\w* \w decís|strong="G3004"\w*: «\w Ponte|strong="G2476"\w* \w ahí|strong="G1563"\w* \w de|strong="G1909"\w* \w pie|strong="G2476"\w*», \w o|strong="G2228"\w* «\w Siéntate|strong="G2521"\w* junto \w al|strong="G3588"\w* escabel \w de|strong="G1909"\w* mis pies»  
\v 4 ¿\w no|strong="G3756"\w* \w habéis|strong="G2532"\w* \w hecho|strong="G1096"\w* distinciones \w entre|strong="G1722"\w* \w vosotros|strong="G1438"\w*, \w y|strong="G2532"\w* \w os|strong="G1438"\w* \w habéis|strong="G2532"\w* convertido \w en|strong="G1722"\w* \w jueces|strong="G2923"\w* \w con|strong="G1722"\w* \w malos|strong="G4190"\w* \w pensamientos|strong="G1261"\w*?  
\v 5 Escuchad, mis amados hermanos. ¿\w No|strong="G3756"\w* ha elegido \w Dios|strong="G2316"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w pobres|strong="G4434"\w* \w de|strong="G1722"\w* \w este|strong="G3588"\w* \w mundo|strong="G2889"\w* \w para|strong="G1722"\w* \w que|strong="G3588"\w* sean \w ricos|strong="G4145"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w y|strong="G2532"\w* \w herederos|strong="G2818"\w* \w del|strong="G3588"\w* Reino \w que|strong="G3588"\w* \w prometió|strong="G1861"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w le|strong="G1722"\w* aman?  
\v 6 \w Pero|strong="G1161"\w* \w vosotros|strong="G5210"\w* \w habéis|strong="G2532"\w* deshonrado \w al|strong="G3588"\w* \w pobre|strong="G4434"\w*. ¿\w No|strong="G3756"\w* \w os|strong="G5210"\w* \w oprimen|strong="G2616"\w* \w los|strong="G3588"\w* \w ricos|strong="G4145"\w* \w y|strong="G2532"\w* son \w ellos|strong="G3588"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w os|strong="G5210"\w* \w arrastran|strong="G1670"\w* ante \w los|strong="G3588"\w* tribunales?  
\v 7 ¿\w No|strong="G3756"\w* blasfeman \w ellos|strong="G3588"\w* \w el|strong="G3588"\w* honorable \w nombre|strong="G3686"\w* \w que|strong="G3588"\w* fue invocado \w sobre|strong="G1909"\w* \w vosotros|strong="G5210"\w*?   
\p
\v 8 Sin embargo, \w si|strong="G1487"\w* \w cumplís|strong="G5055"\w* \w la|strong="G3588"\w* \w ley|strong="G3551"\w* real \w según|strong="G2596"\w* \w la|strong="G3588"\w* \w Escritura|strong="G1124"\w*: «Amarás \w a|strong="G2596"\w* \w tu|strong="G4771"\w* \w prójimo|strong="G4139"\w* \w como|strong="G5613"\w* \w a|strong="G2596"\w* \w ti|strong="G4572"\w* mismo», \w hacéis|strong="G4160"\w* \w bien|strong="G2573"\w*.  
\v 9 \w Pero|strong="G1161"\w* \w si|strong="G1487"\w* hacéis acepción \w de|strong="G5259"\w* personas, \w cometéis|strong="G2038"\w* pecado, \w y|strong="G1161"\w* sois condenados \w por|strong="G5259"\w* \w la|strong="G3588"\w* \w ley|strong="G3551"\w* \w como|strong="G5613"\w* \w transgresores|strong="G3848"\w*.  
\v 10 \w Porque|strong="G1063"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w guarda|strong="G5083"\w* \w toda|strong="G3956"\w* \w la|strong="G3588"\w* \w ley|strong="G3551"\w* \w y|strong="G1161"\w* tropieza \w en|strong="G1722"\w* \w un|strong="G1520"\w* punto, \w se|strong="G1096"\w* hace culpable \w de|strong="G1722"\w* \w todos|strong="G3956"\w*.  
\v 11 \w Porque|strong="G1063"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w dijo|strong="G3004"\w*: «\w No|strong="G3756"\w* cometas adulterio», \w también|strong="G2532"\w* \w dijo|strong="G3004"\w*: «\w No|strong="G3756"\w* cometas homicidio». \w Ahora|strong="G1161"\w* \w bien|strong="G1161"\w*, \w si|strong="G1487"\w* \w no|strong="G3756"\w* cometes adulterio \w pero|strong="G1161"\w* cometes homicidio, te has convertido \w en|strong="G3588"\w* \w transgresor|strong="G3848"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w ley|strong="G3551"\w*.  
\v 12 \w Así|strong="G3779"\w* \w hablad|strong="G2980"\w* \w y|strong="G2532"\w* \w así|strong="G3779"\w* \w haced|strong="G4160"\w*, \w como|strong="G5613"\w* quienes \w han|strong="G3195"\w* \w de|strong="G1223"\w* ser juzgados \w por|strong="G1223"\w* la \w ley|strong="G3551"\w* \w de|strong="G1223"\w* la \w libertad|strong="G1657"\w*.  
\v 13 \w Porque|strong="G1063"\w* \w el|strong="G3588"\w* \w juicio|strong="G2920"\w* será \w sin|strong="G3361"\w* \w misericordia|strong="G1656"\w* \w para|strong="G3361"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* ha mostrado \w misericordia|strong="G1656"\w*. \w La|strong="G3588"\w* \w misericordia|strong="G1656"\w* triunfa sobre \w el|strong="G3588"\w* \w juicio|strong="G2920"\w*.   
