\p un \w jarro|strong="H4219"\w* de \w plata|strong="H3701"\w* de \w setenta|strong="H7657"\w* \w siclos|strong="H8255"\w*, según el \w siclo|strong="H8255"\w* del \w santuario|strong="H6944"\w*, \w ambos|strong="H8147"\w* \w llenos|strong="H4392"\w* de harina fina \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w* \w para|strong="H4948"\w* una \w ofrenda|strong="H4503"\w* vegetal;   
\p
\v 14 una \w cuchara|strong="H3709"\w* de \w oro|strong="H2091"\w* de \w diez|strong="H6235"\w* siclos, \w llena|strong="H4392"\w* de incienso;   
\p
\v 15 un \w novillo|strong="H1121"\w*,  
\p un carnero,  
\p un \w cordero|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w*, para \w el|strong="H1121"\w* \w holocausto|strong="H5930"\w*;   
\p
\v 16 un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w* como ofrenda por el \w pecado|strong="H2403"\w*;   
\p
\v 17 \w y|strong="H1241"\w* para \w el|strong="H1121"\w* \w sacrificio|strong="H2077"\w* \w de|strong="H2568"\w* paz, \w dos|strong="H8147"\w* \w bueyes|strong="H1241"\w*, \w cinco|strong="H2568"\w* carneros, \w cinco|strong="H2568"\w* machos cabríos \w y|strong="H1241"\w* \w cinco|strong="H2568"\w* \w corderos|strong="H3532"\w* \w de|strong="H2568"\w* un \w año|strong="H8141"\w*. \w Esta|strong="H2088"\w* fue la \w ofrenda|strong="H7133"\w* \w de|strong="H2568"\w* \w Naasón|strong="H5177"\w*, \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* \w Aminadab|strong="H5992"\w*.   
\p
