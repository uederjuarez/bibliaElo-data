\c 5
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 «\w Manda|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w que|strong="H4480"\w* saquen \w del|strong="H4480"\w* \w campamento|strong="H4264"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w leproso|strong="H6879"\w*, \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H4480"\w* tenga flujo y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H4480"\w* esté impuro \w por|strong="H4480"\w* causa \w de|strong="H4480"\w* un cadáver.  
\v 3 Pondréis \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w* tanto \w a|strong="H3068"\w* los hombres \w como|strong="H5704"\w* \w a|strong="H3068"\w* las \w mujeres|strong="H5704"\w*, \w para|strong="H5704"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* contaminen su \w campamento|strong="H4264"\w*, \w en|strong="H5704"\w* \w medio|strong="H8432"\w* del cual yo \w habito|strong="H7931"\w*».   
\p
\v 4 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w lo|strong="H6213"\w* \w hicieron|strong="H6213"\w* \w así|strong="H3651"\w*, y \w los|strong="H1121"\w* \w pusieron|strong="H6213"\w* \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w*; \w tal|strong="H3651"\w* \w como|strong="H3651"\w* Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w así|strong="H3651"\w* \w lo|strong="H6213"\w* \w hicieron|strong="H6213"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.   
\p
\v 5 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 6 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: ‘\w Cuando|strong="H3588"\w* un \w hombre|strong="H1121"\w* \w o|strong="H3068"\w* una mujer cometa \w cualquier|strong="H3605"\w* \w pecado|strong="H2403"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* cometen \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*, \w de|strong="H3588"\w* modo \w que|strong="H3588"\w* peque \w contra|strong="H3478"\w* Yahvé, \w y|strong="H3588"\w* \w esa|strong="H1931"\w* \w persona|strong="H5315"\w* sea culpable,  
\v 7 \w entonces|strong="H7725"\w* \w confesará|strong="H3034"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w que|strong="H5921"\w* ha cometido; \w y|strong="H5921"\w* \w hará|strong="H6213"\w* \w la|strong="H5921"\w* restitución \w por|strong="H5921"\w* su culpa \w en|strong="H5921"\w* su totalidad, \w añadiendo|strong="H3254"\w* \w a|strong="H3068"\w* \w ella|strong="H5921"\w* \w la|strong="H5921"\w* quinta parte, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w la|strong="H5921"\w* \w dará|strong="H5414"\w* \w a|strong="H3068"\w* \w aquel|strong="H6213"\w* \w contra|strong="H5921"\w* \w quien|strong="H6213"\w* ha sido culpable.  
\v 8 Pero \w si|strong="H5921"\w* \w el|strong="H5921"\w* hombre \w no|strong="H5921"\w* tiene \w pariente|strong="H1350"\w* \w a|strong="H3068"\w* quien hacer \w la|strong="H5921"\w* restitución \w por|strong="H5921"\w* \w la|strong="H5921"\w* culpa, \w la|strong="H5921"\w* restitución \w por|strong="H5921"\w* \w la|strong="H5921"\w* culpa \w que|strong="H5921"\w* \w se|strong="H5921"\w* haga \w a|strong="H3068"\w* Yahvé será \w del|strong="H5921"\w* \w sacerdote|strong="H3548"\w*, \w además|strong="H5921"\w* \w del|strong="H5921"\w* carnero \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w expiación|strong="H3722"\w*, \w con|strong="H5921"\w* \w el|strong="H5921"\w* cual \w se|strong="H5921"\w* hará \w la|strong="H5921"\w* \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 9 \w Toda|strong="H3605"\w* \w ofrenda|strong="H8641"\w* \w de|strong="H1121"\w* \w todas|strong="H3605"\w* las cosas \w santas|strong="H6944"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w que|strong="H1121"\w* presenten al \w sacerdote|strong="H3548"\w*, \w será|strong="H1961"\w* suya.  
\v 10 Las cosas \w santas|strong="H6944"\w* \w de|strong="H5414"\w* cada uno \w serán|strong="H1961"\w* suyas; todo lo \w que|strong="H1961"\w* cualquiera \w dé|strong="H5414"\w* al \w sacerdote|strong="H3548"\w*, \w será|strong="H1961"\w* suyo’”.   
\p
\v 11 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 12 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Si|strong="H3588"\w* \w la|strong="H3588"\w* mujer \w de|strong="H3588"\w* un \w hombre|strong="H1121"\w* se desvía \w y|strong="H3588"\w* le \w es|strong="H3588"\w* infiel,  
\v 13 y un hombre \w se|strong="H1931"\w* acuesta con \w ella|strong="H1931"\w* carnalmente, y \w esto|strong="H1931"\w* \w se|strong="H1931"\w* oculta \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w su|strong="H1931"\w* marido y \w se|strong="H1931"\w* mantiene en secreto, y \w ella|strong="H1931"\w* \w se|strong="H1931"\w* mancha, y \w no|strong="H3808"\w* hay \w testigo|strong="H5707"\w* contra \w ella|strong="H1931"\w*, \w ni|strong="H3808"\w* \w es|strong="H1931"\w* sorprendida en \w el|strong="H1931"\w* acto;  
\v 14 \w y|strong="H5921"\w* \w el|strong="H1931"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w celos|strong="H7065"\w* \w se|strong="H1931"\w* apodera \w de|strong="H5921"\w* \w él|strong="H1931"\w*, \w y|strong="H5921"\w* \w tiene|strong="H1931"\w* \w celos|strong="H7065"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* mujer, estando \w ella|strong="H1931"\w* \w contaminada|strong="H2930"\w*; \w o|strong="H3068"\w* \w si|strong="H3808"\w* \w el|strong="H1931"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w celos|strong="H7065"\w* \w se|strong="H1931"\w* apodera \w de|strong="H5921"\w* \w él|strong="H1931"\w*, \w y|strong="H5921"\w* \w tiene|strong="H1931"\w* \w celos|strong="H7065"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* mujer, \w no|strong="H3808"\w* estando \w ella|strong="H1931"\w* \w contaminada|strong="H2930"\w*;  
\v 15 \w entonces|strong="H3588"\w* \w el|strong="H1931"\w* hombre llevará \w a|strong="H3068"\w* \w su|strong="H1931"\w* mujer \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w*, \w y|strong="H3588"\w* presentará \w su|strong="H1931"\w* \w ofrenda|strong="H4503"\w* \w por|strong="H5921"\w* \w ella|strong="H1931"\w*: \w la|strong="H1931"\w* décima parte \w de|strong="H5921"\w* un efa \w de|strong="H5921"\w* \w harina|strong="H7058"\w* \w de|strong="H5921"\w* \w cebada|strong="H8184"\w*. \w No|strong="H3808"\w* derramará \w aceite|strong="H8081"\w* \w ni|strong="H3808"\w* \w pondrá|strong="H5414"\w* \w incienso|strong="H3828"\w* \w sobre|strong="H5921"\w* \w ella|strong="H1931"\w*, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* una \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* celos, una \w ofrenda|strong="H4503"\w* recordatoria, \w que|strong="H3588"\w* \w trae|strong="H5414"\w* \w la|strong="H1931"\w* \w iniquidad|strong="H5771"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w memoria|strong="H2142"\w*.  
\v 16 El \w sacerdote|strong="H3548"\w* la acercará y la pondrá \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.  
\v 17 El \w sacerdote|strong="H3548"\w* \w tomará|strong="H3947"\w* \w agua|strong="H4325"\w* \w santa|strong="H6918"\w* \w en|strong="H4480"\w* una \w vasija|strong="H3627"\w* \w de|strong="H4480"\w* \w barro|strong="H6083"\w*; y el \w sacerdote|strong="H3548"\w* \w tomará|strong="H3947"\w* un poco \w del|strong="H4480"\w* \w polvo|strong="H6083"\w* \w que|strong="H4480"\w* \w está|strong="H1961"\w* \w en|strong="H4480"\w* el suelo \w del|strong="H4480"\w* \w tabernáculo|strong="H4908"\w* y lo echará \w en|strong="H4480"\w* el \w agua|strong="H4325"\w*.  
\v 18 \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w pondrá|strong="H5414"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* mujer \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w descubrirá|strong="H6544"\w* \w la|strong="H1931"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* mujer, \w y|strong="H5921"\w* \w pondrá|strong="H5414"\w* \w en|strong="H5921"\w* \w sus|strong="H1931"\w* \w manos|strong="H3027"\w* \w la|strong="H1931"\w* \w ofrenda|strong="H4503"\w* conmemorativa, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* celos. \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w tendrá|strong="H1961"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w mano|strong="H3027"\w* \w el|strong="H1931"\w* \w agua|strong="H4325"\w* \w amarga|strong="H4751"\w* \w que|strong="H1931"\w* \w trae|strong="H5414"\w* maldición.  
\v 19 El \w sacerdote|strong="H3548"\w* le hará prestar juramento y le dirá \w a|strong="H3068"\w* la mujer: «\w Si|strong="H3808"\w* \w ningún|strong="H3808"\w* hombre \w se|strong="H3808"\w* \w ha|strong="H3808"\w* \w acostado|strong="H7901"\w* contigo y \w si|strong="H3808"\w* \w no|strong="H3808"\w* te has desviado \w a|strong="H3068"\w* la impureza, estando \w bajo|strong="H8478"\w* la autoridad \w de|strong="H8478"\w* tu marido, \w sé|strong="H3808"\w* \w libre|strong="H5352"\w* \w de|strong="H8478"\w* esta \w agua|strong="H4325"\w* \w amarga|strong="H4751"\w* \w que|strong="H3808"\w* trae maldición.  
\v 20 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w te|strong="H3588"\w* \w has|strong="H5414"\w* desviado, estando \w bajo|strong="H8478"\w* \w la|strong="H3588"\w* autoridad \w de|strong="H3588"\w* tu marido, \w y|strong="H3588"\w* \w si|strong="H3588"\w* \w te|strong="H3588"\w* \w has|strong="H5414"\w* \w contaminado|strong="H2930"\w*, \w y|strong="H3588"\w* algún hombre se ha acostado contigo \w además|strong="H3588"\w* \w de|strong="H3588"\w* tu marido,»  
\v 21 entonces \w el|strong="H5307"\w* \w sacerdote|strong="H3548"\w* \w hará|strong="H5414"\w* \w que|strong="H5971"\w* la mujer \w jure|strong="H7650"\w* con \w el|strong="H5307"\w* \w juramento|strong="H7621"\w* \w de|strong="H5971"\w* maldición, y \w el|strong="H5307"\w* \w sacerdote|strong="H3548"\w* le dirá \w a|strong="H3068"\w* la mujer: «\w Que|strong="H5971"\w* Yahvé te ponga \w por|strong="H5414"\w* maldición y \w por|strong="H5414"\w* \w juramento|strong="H7621"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5971"\w* tu \w pueblo|strong="H5971"\w*, cuando Yahvé \w haga|strong="H5414"\w* \w que|strong="H5971"\w* tu \w muslo|strong="H3409"\w* decaiga y tu vientre \w se|strong="H5971"\w* hinche;  
\v 22 y esta \w agua|strong="H4325"\w* \w que|strong="H4325"\w* trae maldición entrará en tus \w entrañas|strong="H4578"\w* para hacer \w que|strong="H4325"\w* tu vientre se hinche y tu \w muslo|strong="H3409"\w* decaiga». \w Y|strong="H3068"\w* la mujer dirá: «Amén, amén».   
\p
\v 23 “‘El \w sacerdote|strong="H3548"\w* \w escribirá|strong="H3789"\w* estas maldiciones en un \w libro|strong="H5612"\w*, y las borrará en el \w agua|strong="H4325"\w* \w amarga|strong="H4751"\w*.  
\v 24 Hará \w que|strong="H4325"\w* la mujer beba el \w agua|strong="H4325"\w* \w amarga|strong="H4751"\w* \w que|strong="H4325"\w* trae maldición; y el \w agua|strong="H4325"\w* \w que|strong="H4325"\w* trae la maldición entrará en ella y se volverá \w amarga|strong="H4751"\w*.  
\v 25 El \w sacerdote|strong="H3548"\w* \w tomará|strong="H3947"\w* \w de|strong="H6440"\w* la \w mano|strong="H3027"\w* \w de|strong="H6440"\w* la mujer la \w ofrenda|strong="H4503"\w* \w de|strong="H6440"\w* celos, \w mecerá|strong="H5130"\w* la \w ofrenda|strong="H4503"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé y la \w ofrecerá|strong="H7126"\w* sobre el \w altar|strong="H4196"\w*.  
\v 26 El \w sacerdote|strong="H3548"\w* tomará un puñado \w de|strong="H4480"\w* la \w ofrenda|strong="H4503"\w*, como su porción conmemorativa, y la \w quemará|strong="H6999"\w* \w sobre|strong="H4480"\w* el \w altar|strong="H4196"\w*, y después hará \w que|strong="H4480"\w* la mujer beba el \w agua|strong="H4325"\w*.  
\v 27 \w Cuando|strong="H1961"\w* le \w haya|strong="H1961"\w* \w hecho|strong="H1961"\w* \w beber|strong="H8248"\w* \w el|strong="H5307"\w* \w agua|strong="H4325"\w*, \w sucederá|strong="H1961"\w* \w que|strong="H5971"\w* \w si|strong="H1961"\w* ella \w se|strong="H1961"\w* ha \w contaminado|strong="H2930"\w* y ha cometido infidelidad \w contra|strong="H1961"\w* su marido, \w el|strong="H5307"\w* \w agua|strong="H4325"\w* \w que|strong="H5971"\w* trae la maldición entrará en ella produciendo \w amargura|strong="H4751"\w*, y su vientre \w se|strong="H1961"\w* hinchará, y su \w muslo|strong="H3409"\w* decaerá; y la mujer \w será|strong="H1961"\w* una maldición en \w medio|strong="H7130"\w* \w de|strong="H5971"\w* su \w pueblo|strong="H5971"\w*.  
\v 28 Pero \w si|strong="H3808"\w* \w la|strong="H1931"\w* mujer \w no|strong="H3808"\w* \w se|strong="H1931"\w* \w ha|strong="H3808"\w* \w contaminado|strong="H2930"\w*, \w sino|strong="H3808"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w limpia|strong="H2889"\w*, entonces quedará \w libre|strong="H5352"\w* y concebirá \w descendencia|strong="H2233"\w*.   
\p
\v 29 “‘\w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w ley|strong="H8451"\w* \w de|strong="H8478"\w* los celos, cuando \w la|strong="H2063"\w* mujer, estando \w bajo|strong="H8478"\w* \w la|strong="H2063"\w* potestad \w de|strong="H8478"\w* su marido, se desvía y se contamina,  
\v 30 \w o|strong="H3068"\w* cuando \w el|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w celos|strong="H7065"\w* \w se|strong="H5921"\w* apodera \w de|strong="H5921"\w* un hombre, \w y|strong="H5921"\w* tiene \w celos|strong="H7065"\w* \w de|strong="H5921"\w* su mujer; entonces \w presentará|strong="H5975"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* mujer \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* aplicará \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* \w toda|strong="H3605"\w* \w esta|strong="H2063"\w* \w ley|strong="H8451"\w*.  
\v 31 \w El|strong="H1931"\w* hombre quedará \w libre|strong="H5352"\w* de \w iniquidad|strong="H5771"\w*, y \w la|strong="H1931"\w* mujer cargará con \w su|strong="H1931"\w* \w iniquidad|strong="H5771"\w*’”.   
\c 6
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Cuando|strong="H3588"\w* un \w hombre|strong="H1121"\w* \w o|strong="H3068"\w* una mujer haga un \w voto|strong="H5087"\w* especial, \w el|strong="H3588"\w* \w voto|strong="H5087"\w* \w de|strong="H3588"\w* \w nazareo|strong="H5139"\w*, \w para|strong="H3588"\w* consagrarse \w a|strong="H3068"\w* Yahvé,  
\v 3 \w se|strong="H3808"\w* abstendrá de \w vino|strong="H3196"\w* y de \w bebida|strong="H7941"\w* fuerte. \w No|strong="H3808"\w* \w beberá|strong="H8354"\w* \w vinagre|strong="H2558"\w* de \w vino|strong="H3196"\w*, \w ni|strong="H3808"\w* \w vinagre|strong="H2558"\w* de \w bebida|strong="H7941"\w* fuerte, \w ni|strong="H3808"\w* \w beberá|strong="H8354"\w* jugo de uva, \w ni|strong="H3808"\w* comerá \w uvas|strong="H6025"\w* \w frescas|strong="H3892"\w* \w o|strong="H3068"\w* \w secas|strong="H3002"\w*.  
\v 4 Durante \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H5704"\w* su \w nazareato|strong="H5145"\w*, \w no|strong="H3808"\w* comerá \w nada|strong="H3808"\w* \w que|strong="H3808"\w* provenga \w de|strong="H5704"\w* \w la|strong="H3605"\w* \w vid|strong="H1612"\w*, \w desde|strong="H5704"\w* las semillas \w hasta|strong="H5704"\w* \w los|strong="H3605"\w* hollejos.   
\p
\v 5 “‘Durante \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w del|strong="H5921"\w* \w voto|strong="H5088"\w* \w de|strong="H5921"\w* su \w nazareato|strong="H5145"\w*, \w ninguna|strong="H3605"\w* \w navaja|strong="H8593"\w* \w pasará|strong="H5674"\w* \w por|strong="H5921"\w* su \w cabeza|strong="H7218"\w*, \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w se|strong="H1961"\w* cumplan \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* su \w consagración|strong="H5145"\w* \w a|strong="H3068"\w* Yahvé. \w Será|strong="H1961"\w* \w santo|strong="H6918"\w*. Dejará crecer \w los|strong="H5921"\w* mechones \w de|strong="H5921"\w* su \w cabello|strong="H5145"\w*.   
\p
\v 6 “‘\w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* consagre \w a|strong="H3068"\w* Yahvé \w no|strong="H3808"\w* \w se|strong="H3808"\w* acercará \w a|strong="H3068"\w* \w ningún|strong="H3605"\w* cadáver.  
\v 7 \w No|strong="H3808"\w* \w se|strong="H5921"\w* \w contaminará|strong="H2930"\w* \w por|strong="H5921"\w* \w su|strong="H3588"\w* padre, \w ni|strong="H3808"\w* \w por|strong="H5921"\w* \w su|strong="H3588"\w* madre, \w ni|strong="H3808"\w* \w por|strong="H5921"\w* \w su|strong="H3588"\w* hermano, \w ni|strong="H3808"\w* \w por|strong="H5921"\w* \w su|strong="H3588"\w* hermana, \w cuando|strong="H3588"\w* mueran, \w porque|strong="H3588"\w* \w la|strong="H5921"\w* \w consagración|strong="H5145"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* Dios \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w su|strong="H3588"\w* \w cabeza|strong="H7218"\w*.  
\v 8 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* de \w su|strong="H1931"\w* \w nazareato|strong="H5145"\w* \w será|strong="H1931"\w* \w santo|strong="H6918"\w* para Yahvé.   
\p
\v 9 “‘\w Si|strong="H3588"\w* alguno muere muy \w repentinamente|strong="H6597"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w y|strong="H3588"\w* contamina \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w consagración|strong="H5145"\w*, \w entonces|strong="H3117"\w* \w se|strong="H5921"\w* rapará \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* purificación. \w Al|strong="H5921"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w se|strong="H5921"\w* \w la|strong="H5921"\w* rapará.  
\v 10 Al \w octavo|strong="H8066"\w* \w día|strong="H3117"\w* traerá \w dos|strong="H8147"\w* \w tórtolas|strong="H8449"\w* \w o|strong="H3068"\w* \w dos|strong="H8147"\w* pichones al \w sacerdote|strong="H3548"\w*, \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* \w de|strong="H1121"\w* la Tienda del Encuentro.  
\v 11 \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w ofrecerá|strong="H6213"\w* uno \w como|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w pecado|strong="H2403"\w* \w y|strong="H5921"\w* \w el|strong="H1931"\w* otro \w como|strong="H5921"\w* \w holocausto|strong="H5930"\w*, \w y|strong="H5921"\w* \w hará|strong="H6213"\w* \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w él|strong="H1931"\w*, \w porque|strong="H5921"\w* \w pecó|strong="H2398"\w* \w a|strong="H3068"\w* causa \w del|strong="H5921"\w* muerto, \w y|strong="H5921"\w* santificará \w su|strong="H1931"\w* \w cabeza|strong="H7218"\w* \w ese|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*.  
\v 12 Consagrará \w de|strong="H3588"\w* nuevo \w para|strong="H3588"\w* Yahvé \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w nazareato|strong="H5145"\w*, \w y|strong="H3588"\w* traerá un \w cordero|strong="H3532"\w* \w de|strong="H3588"\w* un \w año|strong="H8141"\w* \w como|strong="H3588"\w* ofrenda \w por|strong="H3588"\w* \w la|strong="H3588"\w* culpa; \w pero|strong="H3588"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* anteriores serán anulados, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w consagración|strong="H5145"\w* fue profanada.   
\p
\v 13 “‘\w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w ley|strong="H8451"\w* del \w nazareo|strong="H5139"\w*: \w cuando|strong="H3117"\w* se cumplan los \w días|strong="H3117"\w* de su \w consagración|strong="H5145"\w*, será llevado \w a|strong="H3068"\w* \w la|strong="H2063"\w* \w puerta|strong="H6607"\w* de \w la|strong="H2063"\w* Tienda del Encuentro,  
\v 14 y \w presentará|strong="H7126"\w* su \w ofrenda|strong="H7133"\w* \w a|strong="H3068"\w* Yahvé: un \w cordero|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto para \w el|strong="H1121"\w* \w holocausto|strong="H5930"\w*, una \w cordera|strong="H3535"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto para la \w ofrenda|strong="H7133"\w* por \w el|strong="H1121"\w* \w pecado|strong="H2403"\w*, un carnero sin defecto para \w el|strong="H1121"\w* sacrificio \w de|strong="H1121"\w* paz,  
\v 15 un \w canastillo|strong="H5536"\w* de panes \w ázimos|strong="H4682"\w*, \w tortas|strong="H2471"\w* de harina fina \w amasadas|strong="H1101"\w* con \w aceite|strong="H8081"\w*, y hojaldres \w ázimos|strong="H4682"\w* untados con \w aceite|strong="H8081"\w*, junto con su \w ofrenda|strong="H4503"\w* vegetal y sus \w libaciones|strong="H5262"\w*.  
\v 16 \w El|strong="H6213"\w* \w sacerdote|strong="H3548"\w* los \w presentará|strong="H7126"\w* \w ante|strong="H6440"\w* Yahvé, y \w ofrecerá|strong="H7126"\w* su ofrenda \w por|strong="H6440"\w* \w el|strong="H6213"\w* \w pecado|strong="H2403"\w* y su \w holocausto|strong="H5930"\w*.  
\v 17 \w Ofrecerá|strong="H6213"\w* \w el|strong="H5921"\w* carnero \w como|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w de|strong="H5921"\w* paz \w a|strong="H3068"\w* Yahvé, \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w canastillo|strong="H5536"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* panes \w ázimos|strong="H4682"\w*. \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w ofrecerá|strong="H6213"\w* también su \w ofrenda|strong="H4503"\w* vegetal \w y|strong="H5921"\w* su \w libación|strong="H5262"\w*.  
\v 18 \w El|strong="H5921"\w* \w nazareo|strong="H5139"\w* \w se|strong="H5921"\w* rapará \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* su \w consagración|strong="H5145"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* Tienda \w del|strong="H5921"\w* Encuentro, \w tomará|strong="H3947"\w* \w el|strong="H5921"\w* \w cabello|strong="H5145"\w* \w de|strong="H5921"\w* su \w consagración|strong="H5145"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w pondrá|strong="H5414"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* fuego \w que|strong="H5921"\w* arde \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* \w sacrificio|strong="H2077"\w* \w de|strong="H5921"\w* paz.  
\v 19 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w tomará|strong="H3947"\w* \w la|strong="H5921"\w* espaldilla \w cocida|strong="H1311"\w* \w del|strong="H4480"\w* carnero, una \w torta|strong="H2471"\w* ázima \w del|strong="H4480"\w* \w canastillo|strong="H5536"\w* \w y|strong="H5921"\w* un \w hojaldre|strong="H7550"\w* ázimo, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w pondrá|strong="H5414"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3709"\w* \w del|strong="H4480"\w* \w nazareo|strong="H5139"\w* \w después|strong="H5921"\w* \w de|strong="H4480"\w* \w que|strong="H4480"\w* este \w se|strong="H5921"\w* haya rapado \w la|strong="H5921"\w* cabeza \w de|strong="H4480"\w* su \w consagración|strong="H5145"\w*;  
\v 20 \w y|strong="H5921"\w* \w el|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w los|strong="H5921"\w* \w mecerá|strong="H5130"\w* \w como|strong="H5921"\w* \w ofrenda|strong="H8641"\w* mecida \w ante|strong="H6440"\w* Yahvé. Son cosa sagrada \w para|strong="H5921"\w* \w el|strong="H1931"\w* \w sacerdote|strong="H3548"\w*, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w el|strong="H1931"\w* pecho \w mecido|strong="H8573"\w* \w y|strong="H5921"\w* \w la|strong="H1931"\w* espaldilla \w elevada|strong="H8641"\w*. \w Después|strong="H5921"\w*, \w el|strong="H1931"\w* \w nazareo|strong="H5139"\w* podrá \w beber|strong="H8354"\w* \w vino|strong="H3196"\w*.   
\p
\v 21 “‘\w Esta|strong="H2063"\w* \w es|strong="H3027"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w del|strong="H5921"\w* \w nazareo|strong="H5139"\w* \w que|strong="H5921"\w* \w hace|strong="H6213"\w* \w voto|strong="H5087"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* su \w ofrenda|strong="H7133"\w* \w a|strong="H3068"\w* Yahvé \w por|strong="H5921"\w* su \w consagración|strong="H5145"\w*, \w además|strong="H5921"\w* \w de|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* sus recursos \w le|strong="H5921"\w* permitan. \w Según|strong="H5921"\w* \w el|strong="H5921"\w* \w voto|strong="H5087"\w* \w que|strong="H5921"\w* haya \w hecho|strong="H6213"\w*, \w así|strong="H3651"\w* obrará \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* su \w consagración|strong="H5145"\w*’”.   
\p
\v 22 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 23 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* Aarón \w y|strong="H3541"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*, \w diciendo|strong="H1696"\w*: ‘\w Así|strong="H3541"\w* \w bendeciréis|strong="H1288"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. Les diréis:   
\q1
\v 24 Que Yahvé te \w bendiga|strong="H1288"\w* y te \w guarde|strong="H8104"\w*;   
\q2
\v 25 Haga Yahvé resplandecer su \w rostro|strong="H6440"\w* sobre ti,  
\q2 y tenga \w de|strong="H6440"\w* ti \w misericordia|strong="H2603"\w*;   
\q1
\v 26 \w Alce|strong="H5375"\w* Yahvé su \w rostro|strong="H6440"\w* sobre ti,  
\q2 y \w ponga|strong="H7760"\w* en ti \w paz|strong="H7965"\w*’.   
\p
\v 27 «Así \w pondrán|strong="H7760"\w* \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w* \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* yo \w los|strong="H1121"\w* \w bendeciré|strong="H1288"\w*».   
\c 7
\p
\v 1 \w El|strong="H3605"\w* \w día|strong="H3117"\w* en \w que|strong="H3117"\w* \w Moisés|strong="H4872"\w* terminó de \w levantar|strong="H6965"\w* \w el|strong="H3605"\w* \w tabernáculo|strong="H4908"\w*, \w lo|strong="H3605"\w* \w ungió|strong="H4886"\w* y \w lo|strong="H3605"\w* \w santificó|strong="H6942"\w* con \w todo|strong="H3605"\w* su mobiliario, y \w el|strong="H3605"\w* \w altar|strong="H4196"\w* con \w todos|strong="H3605"\w* sus utensilios, y \w los|strong="H3605"\w* \w ungió|strong="H4886"\w* y \w santificó|strong="H6942"\w*;  
\v 2 \w los|strong="H1992"\w* \w príncipes|strong="H5387"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w los|strong="H1992"\w* \w jefes|strong="H7218"\w* \w de|strong="H5921"\w* \w las|strong="H1992"\w* \w casas|strong="H1004"\w* \w de|strong="H5921"\w* \w sus|strong="H1992"\w* padres, presentaron ofrendas. \w Estos|strong="H1992"\w* eran \w los|strong="H1992"\w* \w príncipes|strong="H5387"\w* \w de|strong="H5921"\w* \w las|strong="H1992"\w* \w tribus|strong="H4294"\w*, \w los|strong="H1992"\w* \w que|strong="H5921"\w* \w estaban|strong="H5975"\w* \w a|strong="H3068"\w* \w cargo|strong="H6485"\w* \w de|strong="H5921"\w* \w los|strong="H1992"\w* empadronados;  
\v 3 \w y|strong="H5921"\w* \w trajeron|strong="H7126"\w* su \w ofrenda|strong="H7133"\w* \w ante|strong="H6440"\w* Yahvé: \w seis|strong="H8337"\w* carretas cubiertas \w y|strong="H5921"\w* \w doce|strong="H8147"\w* \w bueyes|strong="H1241"\w*; una carreta \w por|strong="H5921"\w* cada \w dos|strong="H8147"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w príncipes|strong="H5387"\w*, \w y|strong="H5921"\w* \w por|strong="H5921"\w* cada uno un \w buey|strong="H7794"\w*. \w Los|strong="H5921"\w* presentaron \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w tabernáculo|strong="H4908"\w*.  
\v 4 Yahvé habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, diciendo:  
\v 5 «Acéptalos \w de|strong="H5414"\w* ellos, \w para|strong="H5414"\w* \w que|strong="H1961"\w* \w sean|strong="H1961"\w* utilizados en el servicio \w de|strong="H5414"\w* la Tienda del Encuentro; y \w los|strong="H1961"\w* \w darás|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w levitas|strong="H3881"\w*, \w a|strong="H3068"\w* cada uno \w según|strong="H6310"\w* su \w ministerio|strong="H5656"\w*».   
\p
\v 6 \w Moisés|strong="H4872"\w* \w tomó|strong="H3947"\w* las carretas \w y|strong="H1241"\w* los \w bueyes|strong="H1241"\w* \w y|strong="H1241"\w* los \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* los \w levitas|strong="H3881"\w*.  
\v 7 \w Dio|strong="H5414"\w* \w dos|strong="H8147"\w* carretas \w y|strong="H1241"\w* cuatro \w bueyes|strong="H1241"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gersón|strong="H1648"\w*, \w según|strong="H6310"\w* su \w ministerio|strong="H5656"\w*.  
\v 8 \w A|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w* les \w dio|strong="H5414"\w* cuatro carretas \w y|strong="H1241"\w* \w ocho|strong="H8083"\w* \w bueyes|strong="H1241"\w*, \w según|strong="H6310"\w* su \w ministerio|strong="H5656"\w*, bajo la dirección \w de|strong="H1121"\w* Itamar, \w hijo|strong="H1121"\w* del \w sacerdote|strong="H3548"\w* Aarón.  
\v 9 \w Pero|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Coat \w no|strong="H3808"\w* \w les|strong="H5921"\w* \w dio|strong="H5414"\w* \w nada|strong="H3808"\w*, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w ministerio|strong="H5656"\w* \w del|strong="H5921"\w* \w santuario|strong="H6944"\w* \w les|strong="H5921"\w* correspondía \w a|strong="H3068"\w* \w ellos|strong="H5921"\w* \w y|strong="H3588"\w* debían \w llevarlo|strong="H5375"\w* \w sobre|strong="H5921"\w* sus \w hombros|strong="H3802"\w*.   
\p
\v 10 Los \w príncipes|strong="H5387"\w* presentaron \w ofrendas|strong="H7133"\w* para la dedicación \w del|strong="H4196"\w* \w altar|strong="H4196"\w* el \w día|strong="H3117"\w* en \w que|strong="H3117"\w* fue \w ungido|strong="H4886"\w*. Los \w príncipes|strong="H5387"\w* presentaron sus \w ofrendas|strong="H7133"\w* \w delante|strong="H6440"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*.   
\p
\v 11 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «Presentarán su \w ofrenda|strong="H7133"\w*, \w cada|strong="H3117"\w* \w príncipe|strong="H5387"\w* en su \w día|strong="H3117"\w*, para la dedicación \w del|strong="H4196"\w* \w altar|strong="H4196"\w*».   
\p
\v 12 \w El|strong="H1121"\w* \w que|strong="H3117"\w* presentó su \w ofrenda|strong="H7133"\w* \w el|strong="H1121"\w* \w primer|strong="H7223"\w* \w día|strong="H3117"\w* \w fue|strong="H1961"\w* \w Naasón|strong="H5177"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Aminadab|strong="H5992"\w*, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*,  
