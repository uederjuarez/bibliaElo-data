\v 16 «\w A|strong="H3068"\w* cargo \w de|strong="H1121"\w* Eleazar, \w hijo|strong="H1121"\w* del \w sacerdote|strong="H3548"\w* Aarón, \w estará|strong="H3605"\w* \w el|strong="H3605"\w* \w aceite|strong="H8081"\w* para \w la|strong="H3605"\w* luz, \w el|strong="H3605"\w* incienso \w aromático|strong="H5561"\w*, \w la|strong="H3605"\w* \w ofrenda|strong="H4503"\w* \w continua|strong="H8548"\w* y \w el|strong="H3605"\w* \w aceite|strong="H8081"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w unción|strong="H4888"\w*, \w el|strong="H3605"\w* cargo \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w tabernáculo|strong="H4908"\w* y \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1121"\w* hay en \w él|strong="H3605"\w*, del \w santuario|strong="H6944"\w* y \w de|strong="H1121"\w* sus \w enseres|strong="H3627"\w*».   
