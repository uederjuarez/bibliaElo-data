\v 49 Acamparon \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*, \w desde|strong="H5704"\w* Bet-jesimot \w hasta|strong="H5704"\w* Abel-sitim, \w en|strong="H5921"\w* \w las|strong="H5921"\w* llanuras \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*.  
\v 50 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* llanuras \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*, frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*, \w diciendo|strong="H1696"\w*:  
\v 51 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Cuando|strong="H3588"\w* hayáis \w pasado|strong="H5674"\w* \w el|strong="H3588"\w* \w Jordán|strong="H3383"\w* \w para|strong="H3588"\w* entrar \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w*,  
\v 52 expulsaréis \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* del país; destruiréis \w todos|strong="H3605"\w* sus \w ídolos|strong="H6754"\w* \w de|strong="H6440"\w* piedra, destruiréis \w todas|strong="H3605"\w* sus \w imágenes|strong="H4541"\w* fundidas y derribaréis \w todos|strong="H3605"\w* sus lugares \w altos|strong="H1116"\w*.  
\v 53 Tomaréis posesión \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w y|strong="H3588"\w* \w habitaréis|strong="H3427"\w* \w en|strong="H3588"\w* ella, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* os he \w dado|strong="H5414"\w* \w la|strong="H3588"\w* tierra \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* poseáis.  
\v 54 \w Heredaréis|strong="H5157"\w* la tierra por sorteo según vuestras \w familias|strong="H4940"\w*. \w A|strong="H3068"\w* las \w más|strong="H7227"\w* numerosas les daréis una \w herencia|strong="H5159"\w* \w mayor|strong="H7227"\w*, y \w a|strong="H3068"\w* las menos numerosas les daréis una \w herencia|strong="H5159"\w* \w menor|strong="H4591"\w*. \w Donde|strong="H8033"\w* le caiga la \w suerte|strong="H1486"\w* \w a|strong="H3068"\w* \w cada|strong="H8033"\w* uno, \w allí|strong="H8033"\w* \w será|strong="H1961"\w* su \w herencia|strong="H5159"\w*. Según las \w tribus|strong="H4294"\w* de vuestros padres \w heredaréis|strong="H5157"\w*.   
\p
\v 55 “‘Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* expulsáis \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* vosotros, \w los|strong="H1992"\w* \w que|strong="H3808"\w* dejéis \w quedar|strong="H1961"\w* \w serán|strong="H1961"\w* \w como|strong="H1961"\w* aguijones \w en|strong="H5921"\w* vuestros \w ojos|strong="H5869"\w* \w y|strong="H5921"\w* \w como|strong="H1961"\w* espinas \w en|strong="H5921"\w* vuestros \w costados|strong="H6654"\w*, \w y|strong="H5921"\w* \w os|strong="H5921"\w* hostigarán \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H3808"\w* habitéis.  
\v 56 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H1961"\w*, tal \w como|strong="H1961"\w* \w yo|strong="H6213"\w* \w había|strong="H1961"\w* pensado \w hacerles|strong="H6213"\w* \w a|strong="H3068"\w* ellos, así os \w haré|strong="H6213"\w* \w a|strong="H3068"\w* vosotros’”.   
\c 34
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Manda|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* diles: ‘\w Cuando|strong="H3588"\w* entréis \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w* (\w esta|strong="H2063"\w* \w es|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* os corresponderá \w en|strong="H3588"\w* \w herencia|strong="H5159"\w*, \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w* según sus fronteras),  
\v 3 \w vuestra|strong="H1961"\w* frontera sur \w será|strong="H1961"\w* \w desde|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w* \w de|strong="H5921"\w* Zin \w a|strong="H3068"\w* \w lo|strong="H5921"\w* largo \w de|strong="H5921"\w* \w la|strong="H5921"\w* frontera \w de|strong="H5921"\w* Edom, \w y|strong="H5921"\w* vuestro \w límite|strong="H7097"\w* sur \w será|strong="H1961"\w* \w desde|strong="H5921"\w* \w el|strong="H5921"\w* \w extremo|strong="H7097"\w* \w del|strong="H5921"\w* \w Mar|strong="H3220"\w* \w Salado|strong="H4417"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w oriente|strong="H6924"\w*.  
\v 4 \w Vuestra|strong="H1961"\w* frontera girará \w hacia|strong="H5045"\w* \w el|strong="H5674"\w* sur de \w la|strong="H1366"\w* subida de Acrabim, y \w pasará|strong="H5674"\w* por Zin; su extremo \w estará|strong="H1961"\w* al sur de Cades Barnea. De allí \w saldrá|strong="H3318"\w* \w hacia|strong="H5045"\w* Hazar-adar, y \w pasará|strong="H5674"\w* por Asmón.  
\v 5 \w La|strong="H1366"\w* frontera girará desde Asmón hasta el \w torrente|strong="H5158"\w* de \w Egipto|strong="H4714"\w*, y terminará en el \w mar|strong="H3220"\w*.   
\p
\v 6 “‘En cuanto \w a|strong="H3068"\w* \w la|strong="H1366"\w* frontera \w occidental|strong="H3220"\w*, \w tendréis|strong="H1961"\w* el \w Mar|strong="H3220"\w* \w Grande|strong="H1419"\w* \w como|strong="H1961"\w* frontera. \w Esta|strong="H2088"\w* \w será|strong="H1961"\w* \w vuestra|strong="H1961"\w* frontera \w occidental|strong="H3220"\w*.   
\p
\v 7 “‘\w Esta|strong="H2088"\w* \w será|strong="H1961"\w* \w vuestra|strong="H1961"\w* frontera \w norte|strong="H6828"\w*: \w desde|strong="H4480"\w* el \w Mar|strong="H3220"\w* \w Grande|strong="H1419"\w* trazaréis una línea \w hasta|strong="H2088"\w* el \w monte|strong="H2022"\w* Hor.  
\v 8 Desde el \w monte|strong="H2022"\w* Hor trazaréis \w la|strong="H1366"\w* línea hasta \w la|strong="H1366"\w* entrada de Hamat, y \w la|strong="H1366"\w* frontera llegará hasta Zedad.  
\v 9 \w Luego|strong="H3318"\w* \w la|strong="H1366"\w* frontera seguirá \w hasta|strong="H2088"\w* Zifrón, y terminará \w en|strong="H3318"\w* Hazar-enán. \w Esta|strong="H2088"\w* \w será|strong="H1961"\w* \w vuestra|strong="H1961"\w* frontera \w norte|strong="H6828"\w*.   
\p
\v 10 “‘Trazaréis vuestra frontera \w oriental|strong="H6924"\w* desde Hazar-enán hasta Sefam.  
\v 11 \w La|strong="H5921"\w* frontera \w descenderá|strong="H3381"\w* \w desde|strong="H5921"\w* Sefam \w hasta|strong="H5921"\w* Ribla, \w al|strong="H5921"\w* \w lado|strong="H3802"\w* \w oriental|strong="H6924"\w* \w de|strong="H5921"\w* \w Aín|strong="H5871"\w*. \w La|strong="H5921"\w* frontera seguirá \w descendiendo|strong="H3381"\w* \w y|strong="H5921"\w* llegará \w hasta|strong="H5921"\w* \w la|strong="H5921"\w* ribera \w oriental|strong="H6924"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w* \w de|strong="H5921"\w* Cineret.  
\v 12 \w La|strong="H2063"\w* frontera bajará \w a|strong="H3068"\w* lo largo del \w Jordán|strong="H3383"\w* y terminará en el \w Mar|strong="H3220"\w* \w Salado|strong="H4417"\w*. \w Esta|strong="H2063"\w* \w será|strong="H1961"\w* \w vuestra|strong="H2063"\w* tierra con sus fronteras \w alrededor|strong="H5439"\w*’”.   
\p
\v 13 \w Moisés|strong="H4872"\w* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, diciendo: «\w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* tierra \w que|strong="H1121"\w* \w heredaréis|strong="H5157"\w* \w por|strong="H5414"\w* sorteo, \w la|strong="H2063"\w* cual Yahvé ha \w ordenado|strong="H6680"\w* \w que|strong="H1121"\w* se \w dé|strong="H1121"\w* \w a|strong="H3068"\w* las \w nueve|strong="H8672"\w* \w tribus|strong="H4294"\w* y \w a|strong="H3068"\w* \w la|strong="H2063"\w* media \w tribu|strong="H4294"\w*;  
\v 14 \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w tribu|strong="H4294"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Rubén, según las \w casas|strong="H1004"\w* \w de|strong="H3588"\w* sus padres, \w la|strong="H3588"\w* \w tribu|strong="H4294"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Gad|strong="H1425"\w*, según las \w casas|strong="H1004"\w* \w de|strong="H3588"\w* sus padres, \w y|strong="H3588"\w* \w la|strong="H3588"\w* media \w tribu|strong="H4294"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w*, ya han recibido \w su|strong="H3588"\w* \w herencia|strong="H5159"\w*.  
\v 15 Las \w dos|strong="H8147"\w* \w tribus|strong="H4294"\w* y la media \w tribu|strong="H4294"\w* han recibido su \w herencia|strong="H5159"\w* al otro \w lado|strong="H5676"\w* \w del|strong="H2677"\w* \w Jordán|strong="H3383"\w*, frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*, al \w oriente|strong="H4217"\w*, hacia la salida \w del|strong="H2677"\w* sol».   
\p
\v 16 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 17 «Estos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w que|strong="H1121"\w* os repartirán la tierra en herencia: \w El|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Eleazar y \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*.  
\v 18 \w Tomaréis|strong="H3947"\w* también \w a|strong="H3068"\w* un \w príncipe|strong="H5387"\w* de cada \w tribu|strong="H4294"\w* para repartir la tierra en herencia.  
\v 19 Estos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*: \w De|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jefone.  
\v 20 \w De|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Simeón|strong="H8095"\w*, Semuel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amiud.  
\v 21 \w De|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w*, Elidad, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Quislón.  
\v 22 \w De|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w*, \w el|strong="H1121"\w* \w príncipe|strong="H5387"\w* Buqui, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jogli.  
\v 23 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*: \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w el|strong="H1121"\w* \w príncipe|strong="H5387"\w* \w Haniel|strong="H2592"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Efod.  
\v 24 \w Y|strong="H3068"\w* \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Efraín, \w el|strong="H1121"\w* \w príncipe|strong="H5387"\w* Kemuel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Siftán.  
\v 25 \w De|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zabulón|strong="H2074"\w*, \w el|strong="H1121"\w* \w príncipe|strong="H5387"\w* Elizafán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Parnac.  
\v 26 \w De|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Isacar, \w el|strong="H1121"\w* \w príncipe|strong="H5387"\w* \w Paltiel|strong="H6409"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Azán.  
\v 27 \w De|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aser, \w el|strong="H1121"\w* \w príncipe|strong="H5387"\w* Ahiud, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Selomi.  
\v 28 \w Y|strong="H3068"\w* \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Neftalí, \w el|strong="H1121"\w* \w príncipe|strong="H5387"\w* \w Pedael|strong="H6300"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amiud».  
\v 29 Estos son \w a|strong="H3068"\w* quienes Yahvé \w mandó|strong="H6680"\w* \w que|strong="H1121"\w* repartieran la herencia \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* en la tierra \w de|strong="H1121"\w* \w Canaán|strong="H3667"\w*.   
\c 35
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* llanuras \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*, frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Ordena|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w*, \w de|strong="H1121"\w* la \w herencia|strong="H5159"\w* \w que|strong="H1121"\w* reciban, den \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w levitas|strong="H3881"\w* \w ciudades|strong="H5892"\w* en las \w que|strong="H1121"\w* \w habitar|strong="H3427"\w*. \w Daréis|strong="H5414"\w* también \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w levitas|strong="H3881"\w* tierras \w de|strong="H1121"\w* pastoreo \w alrededor|strong="H5439"\w* \w de|strong="H1121"\w* las \w ciudades|strong="H5892"\w*.  
\v 3 \w Ellos|strong="H3605"\w* \w tendrán|strong="H1961"\w* las \w ciudades|strong="H5892"\w* \w para|strong="H1961"\w* habitarlas; y las tierras de pastoreo \w serán|strong="H1961"\w* \w para|strong="H1961"\w* sus ganados, \w para|strong="H1961"\w* sus rebaños y \w para|strong="H1961"\w* \w todos|strong="H3605"\w* sus \w animales|strong="H2416"\w*.   
\p
\v 4 “Las tierras \w de|strong="H5414"\w* pastoreo \w de|strong="H5414"\w* las \w ciudades|strong="H5892"\w* que \w daréis|strong="H5414"\w* \w a|strong="H3068"\w* los \w levitas|strong="H3881"\w* se extenderán \w desde|strong="H5439"\w* el muro \w de|strong="H5414"\w* la \w ciudad|strong="H5892"\w* hacia \w afuera|strong="H2351"\w*, mil codos\f + \fr 35:4 \ft Un codo es la longitud desde la punta del dedo medio hasta el codo del brazo de un hombre, es decir, unas 18 pulgadas o 46 centímetros.\f* \w a|strong="H3068"\w* su \w alrededor|strong="H5439"\w*.  
\v 5 \w Mediréis|strong="H4058"\w* \w fuera|strong="H2351"\w* de la \w ciudad|strong="H5892"\w* dos mil codos \w por|strong="H2088"\w* el \w lado|strong="H6285"\w* \w oriental|strong="H6924"\w*, dos mil codos \w por|strong="H2088"\w* el \w lado|strong="H6285"\w* sur, dos mil codos \w por|strong="H2088"\w* el \w lado|strong="H6285"\w* \w occidental|strong="H3220"\w* y dos mil codos \w por|strong="H2088"\w* el \w lado|strong="H6285"\w* \w norte|strong="H6828"\w*, quedando la \w ciudad|strong="H5892"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w*. \w Estas|strong="H2088"\w* \w serán|strong="H1961"\w* las tierras de pastoreo de sus \w ciudades|strong="H5892"\w*.   
\p
\v 6 «\w De|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w que|strong="H5921"\w* \w daréis|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w*, \w seis|strong="H8337"\w* serán \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* refugio, \w las|strong="H5921"\w* cuales designaréis \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w homicida|strong="H7523"\w* pueda huir \w allí|strong="H8033"\w*. \w Además|strong="H5921"\w* \w de|strong="H5921"\w* \w ellas|strong="H5921"\w*, \w les|strong="H5921"\w* \w daréis|strong="H5414"\w* cuarenta \w y|strong="H5921"\w* \w dos|strong="H8147"\w* \w ciudades|strong="H5892"\w*.  
\v 7 \w Todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w que|strong="H3605"\w* \w daréis|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* serán cuarenta y \w ocho|strong="H8083"\w* \w ciudades|strong="H5892"\w*, junto con sus tierras \w de|strong="H5414"\w* pastoreo.  
\v 8 En cuanto \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w* \w que|strong="H1121"\w* \w daréis|strong="H5414"\w* \w de|strong="H1121"\w* la \w heredad|strong="H5159"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w de|strong="H1121"\w* las tribus \w más|strong="H7227"\w* numerosas tomaréis \w más|strong="H7227"\w*, y \w de|strong="H1121"\w* las menos numerosas tomaréis menos. Cada tribu \w dará|strong="H5414"\w* \w de|strong="H1121"\w* sus \w ciudades|strong="H5892"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* en proporción \w a|strong="H3068"\w* la \w herencia|strong="H5159"\w* \w que|strong="H1121"\w* reciba».  
\v 9 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 10 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Cuando|strong="H3588"\w* hayáis \w pasado|strong="H5674"\w* \w el|strong="H3588"\w* \w Jordán|strong="H3383"\w* \w para|strong="H3588"\w* entrar \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w*,  
\v 11 os designaréis \w ciudades|strong="H5892"\w* \w para|strong="H1961"\w* \w que|strong="H1961"\w* os sirvan de \w ciudades|strong="H5892"\w* de refugio, \w a|strong="H3068"\w* fin de \w que|strong="H1961"\w* pueda huir \w allí|strong="H8033"\w* el \w homicida|strong="H7523"\w* \w que|strong="H1961"\w* mate \w a|strong="H3068"\w* cualquier \w persona|strong="H5315"\w* sin intención.  
\v 12 \w Estas|strong="H5975"\w* \w ciudades|strong="H5892"\w* \w os|strong="H5704"\w* \w servirán|strong="H1961"\w* \w de|strong="H6440"\w* refugio \w contra|strong="H6440"\w* el vengador \w de|strong="H6440"\w* la sangre, \w para|strong="H5704"\w* \w que|strong="H3808"\w* el \w homicida|strong="H7523"\w* \w no|strong="H3808"\w* \w muera|strong="H4191"\w* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* presentarse \w ante|strong="H6440"\w* la congregación \w para|strong="H5704"\w* ser juzgado.  
\v 13 \w De|strong="H5414"\w* las \w ciudades|strong="H5892"\w* \w que|strong="H1961"\w* \w daréis|strong="H5414"\w*, \w seis|strong="H8337"\w* \w serán|strong="H1961"\w* \w para|strong="H5414"\w* vosotros \w ciudades|strong="H5892"\w* \w de|strong="H5414"\w* refugio.  
\v 14 \w Daréis|strong="H5414"\w* \w tres|strong="H7969"\w* \w ciudades|strong="H5892"\w* \w a|strong="H3068"\w* \w este|strong="H1961"\w* \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, y \w daréis|strong="H5414"\w* \w tres|strong="H7969"\w* \w ciudades|strong="H5892"\w* en la tierra \w de|strong="H5414"\w* \w Canaán|strong="H3667"\w*. \w Serán|strong="H1961"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5414"\w* refugio.  
\v 15 Estas \w seis|strong="H8337"\w* \w ciudades|strong="H5892"\w* \w servirán|strong="H1961"\w* \w de|strong="H1121"\w* refugio \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, así \w como|strong="H1961"\w* al \w extranjero|strong="H1616"\w* y al forastero \w que|strong="H1616"\w* habite \w entre|strong="H8432"\w* vosotros, \w para|strong="H1961"\w* \w que|strong="H1616"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H1616"\w* mate \w a|strong="H3068"\w* alguien sin intención pueda huir \w allí|strong="H8033"\w*.   
\p
\v 16 “‘Pero \w si|strong="H1931"\w* \w lo|strong="H1931"\w* golpeó con un \w instrumento|strong="H3627"\w* de \w hierro|strong="H1270"\w*, y \w a|strong="H3068"\w* consecuencia de \w ello|strong="H1931"\w* \w murió|strong="H4191"\w*, \w es|strong="H1931"\w* un asesino. \w El|strong="H1931"\w* asesino \w será|strong="H1931"\w* condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*.  
\v 17 \w Si|strong="H1931"\w* \w lo|strong="H1931"\w* golpeó con una piedra \w en|strong="H5221"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w*, con \w la|strong="H1931"\w* \w cual|strong="H1931"\w* un hombre puede \w morir|strong="H4191"\w*, y \w a|strong="H3068"\w* consecuencia de \w ello|strong="H1931"\w* \w murió|strong="H4191"\w*, \w es|strong="H1931"\w* un asesino. \w El|strong="H1931"\w* asesino \w será|strong="H1931"\w* condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*.  
\v 18 \w O|strong="H3068"\w* \w si|strong="H1931"\w* \w lo|strong="H1931"\w* golpeó con un \w instrumento|strong="H3627"\w* de \w madera|strong="H6086"\w* \w en|strong="H5221"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w*, con \w el|strong="H1931"\w* \w cual|strong="H1931"\w* un hombre puede \w morir|strong="H4191"\w*, y \w a|strong="H3068"\w* consecuencia de \w ello|strong="H1931"\w* \w murió|strong="H4191"\w*, \w es|strong="H1931"\w* un asesino. \w El|strong="H1931"\w* asesino \w morirá|strong="H4191"\w*.  
\v 19 \w El|strong="H1931"\w* vengador \w de|strong="H1818"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* dará \w muerte|strong="H4191"\w* al asesino; cuando \w lo|strong="H1931"\w* encuentre, \w lo|strong="H1931"\w* \w matará|strong="H4191"\w*.  
\v 20 \w Si|strong="H5921"\w* \w lo|strong="H5921"\w* empujó \w por|strong="H5921"\w* \w odio|strong="H8135"\w*, \w o|strong="H3068"\w* \w le|strong="H5921"\w* arrojó algo estando \w al|strong="H5921"\w* acecho, \w y|strong="H5921"\w* \w a|strong="H3068"\w* consecuencia \w de|strong="H5921"\w* ello \w murió|strong="H4191"\w*,  
\v 21 \w o|strong="H3068"\w* \w por|strong="H3027"\w* enemistad \w lo|strong="H1931"\w* golpeó con \w su|strong="H1931"\w* \w mano|strong="H3027"\w*, y \w a|strong="H3068"\w* consecuencia \w de|strong="H1818"\w* \w ello|strong="H1931"\w* \w murió|strong="H4191"\w*, \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w lo|strong="H1931"\w* golpeó \w ciertamente|strong="H4191"\w* \w morirá|strong="H4191"\w*. \w Es|strong="H1931"\w* un asesino. \w El|strong="H1931"\w* vengador \w de|strong="H1818"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* dará \w muerte|strong="H4191"\w* al asesino cuando \w lo|strong="H1931"\w* encuentre.   
\p
\v 22 “‘Pero \w si|strong="H3808"\w* \w lo|strong="H3808"\w* empujó \w de|strong="H5921"\w* improviso \w y|strong="H5921"\w* \w sin|strong="H3808"\w* enemistad, \w o|strong="H3068"\w* \w le|strong="H5921"\w* arrojó algún objeto \w sin|strong="H3808"\w* estar \w al|strong="H5921"\w* acecho,  
\v 23 \w o|strong="H3068"\w* \w sin|strong="H3808"\w* verlo dejó \w caer|strong="H5307"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* una piedra \w con|strong="H5921"\w* \w la|strong="H1931"\w* \w que|strong="H1931"\w* un hombre puede \w morir|strong="H4191"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* consecuencia \w de|strong="H5921"\w* \w ello|strong="H1931"\w* \w murió|strong="H4191"\w*, \w no|strong="H3808"\w* \w siendo|strong="H1931"\w* enemigo \w suyo|strong="H1931"\w* \w ni|strong="H3808"\w* \w buscando|strong="H1245"\w* hacerle daño,  
\v 24 entonces \w la|strong="H5921"\w* congregación \w juzgará|strong="H8199"\w* \w entre|strong="H5921"\w* \w el|strong="H5921"\w* homicida \w y|strong="H5921"\w* \w el|strong="H5921"\w* vengador \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w de|strong="H5921"\w* acuerdo \w con|strong="H5921"\w* estas \w ordenanzas|strong="H4941"\w*.  
\v 25 La congregación \w librará|strong="H5337"\w* \w al|strong="H5704"\w* \w homicida|strong="H7523"\w* \w de|strong="H5704"\w* la \w mano|strong="H3027"\w* del vengador \w de|strong="H5704"\w* la \w sangre|strong="H1818"\w*, \w y|strong="H5704"\w* la congregación \w lo|strong="H5704"\w* hará \w volver|strong="H7725"\w* \w a|strong="H3068"\w* su \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* refugio, \w a|strong="H3068"\w* la \w que|strong="H5704"\w* había huido. \w Allí|strong="H8033"\w* \w habitará|strong="H3427"\w* \w hasta|strong="H5704"\w* la \w muerte|strong="H4194"\w* del \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w*, \w que|strong="H5704"\w* fue \w ungido|strong="H4886"\w* \w con|strong="H5704"\w* \w el|strong="H3427"\w* \w aceite|strong="H8081"\w* \w santo|strong="H6944"\w*.   
\p
\v 26 “‘Pero si el \w homicida|strong="H7523"\w* \w sale|strong="H3318"\w* \w en|strong="H3318"\w* algún momento de los límites de \w la|strong="H1366"\w* \w ciudad|strong="H5892"\w* de refugio \w a|strong="H3068"\w* \w la|strong="H1366"\w* que había huido,  
\v 27 y el vengador \w de|strong="H1818"\w* \w la|strong="H1366"\w* \w sangre|strong="H1818"\w* lo encuentra \w fuera|strong="H2351"\w* \w de|strong="H1818"\w* los límites \w de|strong="H1818"\w* su \w ciudad|strong="H5892"\w* \w de|strong="H1818"\w* refugio, y el vengador \w de|strong="H1818"\w* \w la|strong="H1366"\w* \w sangre|strong="H1818"\w* \w mata|strong="H7523"\w* al \w homicida|strong="H7523"\w*, no será culpable \w de|strong="H1818"\w* \w sangre|strong="H1818"\w*,  
\v 28 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w homicida|strong="H7523"\w* debería haber permanecido \w en|strong="H5704"\w* \w su|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w de|strong="H3588"\w* refugio \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* del \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w*. \w Pero|strong="H3588"\w* \w después|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* del \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w*, \w el|strong="H3588"\w* \w homicida|strong="H7523"\w* podrá regresar \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w su|strong="H3588"\w* posesión.   
\p
\v 29 “‘Estas cosas \w serán|strong="H1961"\w* \w para|strong="H1961"\w* vosotros un \w estatuto|strong="H2708"\w* y una \w ordenanza|strong="H4941"\w* \w a|strong="H3068"\w* \w lo|strong="H3605"\w* largo de vuestras \w generaciones|strong="H1755"\w*, en \w todas|strong="H3605"\w* vuestras moradas.   
\p
\v 30 “‘\w Cualquiera|strong="H3605"\w* \w que|strong="H3808"\w* \w mate|strong="H4191"\w* \w a|strong="H3068"\w* una \w persona|strong="H5315"\w*, \w el|strong="H3605"\w* asesino \w será|strong="H3808"\w* \w muerto|strong="H4191"\w* por \w el|strong="H3605"\w* \w testimonio|strong="H5707"\w* de \w testigos|strong="H5707"\w*; pero un solo \w testigo|strong="H5707"\w* \w no|strong="H3808"\w* bastará para condenar \w a|strong="H3068"\w* \w muerte|strong="H4191"\w* \w a|strong="H3068"\w* una \w persona|strong="H5315"\w*.   
\p
\v 31 “‘\w Además|strong="H3588"\w*, \w no|strong="H3808"\w* aceptaréis \w rescate|strong="H3724"\w* \w por|strong="H3588"\w* \w la|strong="H1931"\w* \w vida|strong="H5315"\w* \w de|strong="H3588"\w* un asesino \w que|strong="H3588"\w* \w ha|strong="H3808"\w* sido condenado \w a|strong="H3068"\w* \w muerte|strong="H4191"\w*. \w Ciertamente|strong="H3588"\w* \w morirá|strong="H4191"\w*.   
\p
\v 32 “‘\w Tampoco|strong="H3808"\w* aceptaréis \w rescate|strong="H3724"\w* \w por|strong="H5704"\w* \w el|strong="H3427"\w* \w que|strong="H3808"\w* \w ha|strong="H3808"\w* huido \w a|strong="H3068"\w* su \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* refugio, \w para|strong="H5704"\w* permitirle \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w habitar|strong="H3427"\w* \w en|strong="H5704"\w* su tierra \w antes|strong="H5704"\w* \w de|strong="H5704"\w* la \w muerte|strong="H4194"\w* del sumo \w sacerdote|strong="H3548"\w*.   
\p
\v 33 “‘\w Así|strong="H3588"\w* \w no|strong="H3808"\w* \w contaminaréis|strong="H2610"\w* \w la|strong="H1931"\w* tierra \w donde|strong="H1931"\w* habitáis, \w porque|strong="H3588"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* contamina \w la|strong="H1931"\w* tierra. \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* puede hacer \w expiación|strong="H3722"\w* \w por|strong="H3588"\w* \w la|strong="H1931"\w* tierra \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* derramada \w en|strong="H3588"\w* \w ella|strong="H1931"\w*, \w sino|strong="H3588"\w* \w con|strong="H3588"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* del \w que|strong="H3588"\w* \w la|strong="H1931"\w* \w derramó|strong="H8210"\w*.  
\v 34 \w No|strong="H3808"\w* contaminaréis \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* \w habitáis|strong="H3427"\w*, \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w yo|strong="H3588"\w* \w habito|strong="H3427"\w*; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, \w habito|strong="H3427"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*’”.   
\c 36
\p
\v 1 \w Los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H6440"\w* las \w familias|strong="H4940"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Manasés|strong="H4519"\w*, \w de|strong="H6440"\w* las \w familias|strong="H4940"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w José|strong="H3130"\w*, se acercaron y \w hablaron|strong="H1696"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Moisés|strong="H4872"\w* y \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w príncipes|strong="H5387"\w*, \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H6440"\w* las \w familias|strong="H4940"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.  
\v 2 Ellos dijeron: «Yahvé \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* mi \w señor|strong="H3068"\w* \w que|strong="H1121"\w* \w diera|strong="H5414"\w* la tierra en \w herencia|strong="H5159"\w* \w por|strong="H5414"\w* sorteo \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. Mi \w señor|strong="H3068"\w* también recibió \w el|strong="H1121"\w* mandato \w de|strong="H1121"\w* Yahvé \w de|strong="H1121"\w* \w dar|strong="H5414"\w* la \w herencia|strong="H5159"\w* \w de|strong="H1121"\w* nuestro hermano Zelofehad \w a|strong="H3068"\w* sus \w hijas|strong="H1323"\w*.  
\v 3 \w Si|strong="H1961"\w* \w ellas|strong="H5921"\w* \w se|strong="H1961"\w* casan \w con|strong="H5921"\w* alguno \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* otras \w tribus|strong="H7626"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, su \w herencia|strong="H5159"\w* \w será|strong="H1961"\w* restada \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w herencia|strong="H5159"\w* \w de|strong="H5921"\w* nuestros padres, \w y|strong="H5921"\w* \w será|strong="H1961"\w* añadida \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w herencia|strong="H5159"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tribu|strong="H7626"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* cual \w se|strong="H1961"\w* unan. Así \w será|strong="H1961"\w* \w quitada|strong="H1639"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* porción \w de|strong="H5921"\w* nuestra \w herencia|strong="H5159"\w*.  
\v 4 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* llegue \w el|strong="H5921"\w* \w jubileo|strong="H3104"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w la|strong="H5921"\w* \w herencia|strong="H5159"\w* \w de|strong="H5921"\w* \w ellas|strong="H5921"\w* \w será|strong="H1961"\w* añadida \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w herencia|strong="H5159"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tribu|strong="H4294"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w que|strong="H5921"\w* pertenezcan. \w De|strong="H5921"\w* \w este|strong="H1961"\w* modo, su \w herencia|strong="H5159"\w* \w será|strong="H1961"\w* \w quitada|strong="H1639"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w herencia|strong="H5159"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tribu|strong="H4294"\w* \w de|strong="H5921"\w* nuestros padres».   
\p
\v 5 \w Moisés|strong="H4872"\w* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w palabra|strong="H1696"\w* \w de|strong="H5921"\w* Yahvé, \w diciendo|strong="H1696"\w*: “\w La|strong="H5921"\w* \w tribu|strong="H4294"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w* \w habla|strong="H1696"\w* \w con|strong="H5921"\w* razón.  
\v 6 \w Esto|strong="H2088"\w* \w es|strong="H1961"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* Yahvé \w manda|strong="H6680"\w* con respecto \w a|strong="H3068"\w* las \w hijas|strong="H1323"\w* \w de|strong="H1697"\w* Zelofehad, diciendo: ‘\w Que|strong="H1697"\w* \w se|strong="H1961"\w* casen con quien \w les|strong="H6680"\w* parezca \w mejor|strong="H2896"\w*, pero \w se|strong="H1961"\w* casarán dentro \w de|strong="H1697"\w* la \w familia|strong="H4940"\w* \w de|strong="H1697"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1697"\w* su padre.  
\v 7 \w Así|strong="H3588"\w*, \w ninguna|strong="H3808"\w* \w herencia|strong="H5159"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* pasará \w de|strong="H3588"\w* una \w tribu|strong="H4294"\w* \w a|strong="H3068"\w* otra, \w pues|strong="H3588"\w* cada uno \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* conservará \w la|strong="H3588"\w* \w herencia|strong="H5159"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w tribu|strong="H4294"\w* \w de|strong="H3588"\w* sus padres.  
\v 8 \w Toda|strong="H3605"\w* \w hija|strong="H1323"\w* \w que|strong="H1121"\w* \w posea|strong="H3423"\w* una \w herencia|strong="H5159"\w* en \w cualquier|strong="H3605"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w se|strong="H1961"\w* casará con uno \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w familia|strong="H4940"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* su padre, \w para|strong="H4616"\w* \w que|strong="H1121"\w* \w cada|strong="H3605"\w* uno \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* conserve \w la|strong="H3605"\w* \w herencia|strong="H5159"\w* \w de|strong="H1121"\w* sus padres.  
\v 9 \w Así|strong="H3588"\w*, \w ninguna|strong="H3808"\w* \w herencia|strong="H5159"\w* pasará \w de|strong="H3588"\w* una \w tribu|strong="H4294"\w* \w a|strong="H3068"\w* otra, \w pues|strong="H3588"\w* cada una \w de|strong="H3588"\w* las \w tribus|strong="H4294"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* conservará \w su|strong="H3588"\w* propia \w herencia|strong="H5159"\w*’”.   
\p
\v 10 Las \w hijas|strong="H1323"\w* de Zelofehad \w hicieron|strong="H6213"\w* \w tal|strong="H3651"\w* \w como|strong="H3651"\w* Yahvé \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*;  
\v 11 porque \w Maala|strong="H4244"\w*, Tirsa, \w Hogla|strong="H2295"\w*, \w Milca|strong="H4435"\w* y \w Noa|strong="H5270"\w*, las \w hijas|strong="H1323"\w* \w de|strong="H1121"\w* Zelofehad, \w se|strong="H1961"\w* casaron con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* hermanos \w de|strong="H1121"\w* su padre.  
\v 12 \w Se|strong="H1961"\w* casaron \w dentro|strong="H5921"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w familias|strong="H4940"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* descendientes \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*, \w y|strong="H5921"\w* su \w herencia|strong="H5159"\w* permaneció \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w tribu|strong="H4294"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w familia|strong="H4940"\w* \w de|strong="H5921"\w* su padre.   
\p
\v 13 Estos son \w los|strong="H1121"\w* \w mandamientos|strong="H4687"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w ordenanzas|strong="H4941"\w* \w que|strong="H5921"\w* Yahvé \w ordenó|strong="H6680"\w* \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* llanuras \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*, frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*.   