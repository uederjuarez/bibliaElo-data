\v 30 \w Balac|strong="H1111"\w* \w hizo|strong="H6213"\w* como \w Balaam|strong="H1109"\w* le \w había|strong="H6213"\w* dicho, y \w ofreció|strong="H5927"\w* un \w novillo|strong="H6499"\w* y un carnero en cada \w altar|strong="H4196"\w*.   
\c 24
\p
\v 1 \w Cuando|strong="H3588"\w* \w Balaam|strong="H1109"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* Yahvé \w le|strong="H5869"\w* agradaba bendecir \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w no|strong="H3808"\w* \w fue|strong="H1980"\w*, \w como|strong="H3588"\w* las otras \w veces|strong="H6471"\w*, \w en|strong="H3588"\w* busca \w de|strong="H3588"\w* agüeros, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* volvió \w su|strong="H3588"\w* \w rostro|strong="H6440"\w* \w hacia|strong="H6440"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*.  
\v 2 \w Balaam|strong="H1109"\w* \w alzó|strong="H5375"\w* sus \w ojos|strong="H5869"\w* \w y|strong="H5921"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* acampado \w por|strong="H5921"\w* sus \w tribus|strong="H7626"\w*; \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Dios \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 3 \w Pronunció|strong="H5375"\w* su oráculo, y \w dijo|strong="H5002"\w*:  
\q1 «Oráculo \w de|strong="H1121"\w* \w Balaam|strong="H1109"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Beor,  
\q2 oráculo del \w hombre|strong="H1397"\w* \w de|strong="H1121"\w* \w ojos|strong="H5869"\w* \w abiertos|strong="H8365"\w*;   
\q1
\v 4 oráculo del que \w oye|strong="H8085"\w* las palabras \w de|strong="H5869"\w* Dios,  
\q2 del que \w ve|strong="H2372"\w* la \w visión|strong="H4236"\w* del \w Todopoderoso|strong="H7706"\w*,  
\q2 \w cayendo|strong="H5307"\w* en éxtasis y con los \w ojos|strong="H5869"\w* abiertos:   
\q1
\v 5 ¡\w Cuán|strong="H4100"\w* hermosas son tus \w tiendas|strong="H4908"\w*, \w oh|strong="H4100"\w* \w Jacob|strong="H3290"\w*,  
\q2 tus \w moradas|strong="H4908"\w*, \w oh|strong="H4100"\w* \w Israel|strong="H3478"\w*!   
\q1
\v 6 \w Como|strong="H5921"\w* valles \w que|strong="H5921"\w* \w se|strong="H5921"\w* extienden,  
\q2 \w como|strong="H5921"\w* jardines \w a|strong="H3068"\w* \w la|strong="H5921"\w* orilla \w del|strong="H5921"\w* \w río|strong="H5104"\w*,  
\q2 \w como|strong="H5921"\w* áloes \w que|strong="H5921"\w* Yahvé ha \w plantado|strong="H5193"\w*,  
\q2 \w como|strong="H5921"\w* cedros \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*.   
\q1
\v 7 El \w agua|strong="H4325"\w* fluirá \w de|strong="H4325"\w* sus cántaros,  
\q2 y su \w descendencia|strong="H2233"\w* estará en \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*.  
\q1 Su \w rey|strong="H4428"\w* será \w más|strong="H7227"\w* \w alto|strong="H7311"\w* \w que|strong="H4325"\w* Agag,  
\q2 y su \w reino|strong="H4438"\w* será exaltado.   
\q1
\v 8 Dios lo \w saca|strong="H3318"\w* de \w Egipto|strong="H4714"\w*;  
\q2 tiene fuerzas como de un búfalo salvaje.  
\q1 Devorará \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w* enemigas,  
\q2 desmenuzará sus \w huesos|strong="H6106"\w*,  
\q2 y los atravesará con sus flechas.   
\q1
\v 9 Se encorva, se echa como un león,  
\q2 y como una leona; ¿\w quién|strong="H4310"\w* lo despertará?  
\q1 \w Bendito|strong="H1288"\w* \w el|strong="H4310"\w* \w que|strong="H4310"\w* te \w bendiga|strong="H1288"\w*,  
\q2 y maldito \w el|strong="H4310"\w* \w que|strong="H4310"\w* te maldiga».   
\p
\v 10 La ira de \w Balac|strong="H1111"\w* se encendió contra \w Balaam|strong="H1109"\w*, y batió sus \w palmas|strong="H3709"\w*. \w Balac|strong="H1111"\w* \w dijo|strong="H1109"\w* \w a|strong="H3068"\w* \w Balaam|strong="H1109"\w*: «Te \w llamé|strong="H7121"\w* para maldecir \w a|strong="H3068"\w* mis enemigos, y he \w aquí|strong="H2009"\w* \w que|strong="H2088"\w* los has bendecido \w por|strong="H2088"\w* completo \w estas|strong="H2088"\w* \w tres|strong="H7969"\w* \w veces|strong="H6471"\w*.  
\v 11 Por tanto, ¡huye \w ahora|strong="H6258"\w* \w a|strong="H3068"\w* tu \w lugar|strong="H4725"\w*! \w Yo|strong="H2009"\w* pensaba colmarte de honores; pero he \w aquí|strong="H2009"\w* \w que|strong="H6258"\w* Yahvé te ha privado de honor».   
\p
\v 12 \w Balaam|strong="H1109"\w* \w respondió|strong="H1109"\w* \w a|strong="H3068"\w* \w Balac|strong="H1111"\w*: “¿Acaso \w no|strong="H3808"\w* les \w dije|strong="H1696"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* los \w mensajeros|strong="H4397"\w* \w que|strong="H3808"\w* me \w enviaste|strong="H7971"\w*:  
\v 13 ‘\w Aunque|strong="H3808"\w* \w Balac|strong="H1111"\w* me \w diera|strong="H5414"\w* su \w casa|strong="H1004"\w* \w llena|strong="H4393"\w* \w de|strong="H5414"\w* \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w*, \w no|strong="H3808"\w* \w podré|strong="H3201"\w* \w traspasar|strong="H5674"\w* \w el|strong="H6213"\w* \w mandato|strong="H6310"\w* \w de|strong="H5414"\w* Yahvé, \w para|strong="H5414"\w* \w hacer|strong="H6213"\w* \w el|strong="H6213"\w* \w bien|strong="H2896"\w* \w o|strong="H3068"\w* \w el|strong="H6213"\w* \w mal|strong="H7451"\w* \w por|strong="H5414"\w* mi propia voluntad; \w lo|strong="H3808"\w* \w que|strong="H3808"\w* Yahvé \w diga|strong="H1696"\w*, eso \w diré|strong="H1696"\w*’?  
\v 14 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, he \w aquí|strong="H2088"\w* \w que|strong="H6258"\w* vuelvo \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w*. \w Ven|strong="H3212"\w*, te anunciaré \w lo|strong="H2088"\w* \w que|strong="H6258"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w hará|strong="H6213"\w* \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w* \w en|strong="H3212"\w* los \w días|strong="H3117"\w* venideros”.   
\p
\v 15 \w Pronunció|strong="H5375"\w* su oráculo, y \w dijo|strong="H5002"\w*:  
\q1 «Oráculo \w de|strong="H1121"\w* \w Balaam|strong="H1109"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Beor,  
\q2 oráculo del \w hombre|strong="H1397"\w* \w de|strong="H1121"\w* \w ojos|strong="H5869"\w* \w abiertos|strong="H8365"\w*;   
\q2
\v 16 oráculo del \w que|strong="H3045"\w* \w oye|strong="H8085"\w* las palabras \w de|strong="H5869"\w* Dios,  
\q2 y \w conoce|strong="H3045"\w* la \w ciencia|strong="H1847"\w* del \w Altísimo|strong="H5945"\w*,  
\q2 \w que|strong="H3045"\w* \w ve|strong="H2372"\w* la \w visión|strong="H4236"\w* del \w Todopoderoso|strong="H7706"\w*,  
\q2 \w cayendo|strong="H5307"\w* en éxtasis y con los \w ojos|strong="H5869"\w* abiertos:   
\q1
\v 17 \w Lo|strong="H3808"\w* \w veo|strong="H7200"\w*, pero \w no|strong="H3808"\w* \w ahora|strong="H6258"\w*;  
\q2 \w lo|strong="H3808"\w* contemplo, pero \w no|strong="H3808"\w* \w de|strong="H1121"\w* \w cerca|strong="H7138"\w*.  
\q1 \w Saldrá|strong="H1869"\w* una \w estrella|strong="H3556"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w*,  
\q2 \w se|strong="H3808"\w* \w levantará|strong="H6965"\w* un \w cetro|strong="H7626"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*,  
\q1 y \w herirá|strong="H4272"\w* las sienes \w de|strong="H1121"\w* \w Moab|strong="H4124"\w*,  
\q2 y destruirá \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Set.   
\q1
\v 18 Edom \w será|strong="H1961"\w* su posesión;  
\q2 \w Seir|strong="H8165"\w*, su enemigo, también \w será|strong="H1961"\w* posesión suya,  
\q2 mientras \w que|strong="H1961"\w* \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* \w hará|strong="H6213"\w* \w fuerte|strong="H2428"\w*.   
\q1
\v 19 De \w Jacob|strong="H3290"\w* saldrá un dominador,  
\q2 y destruirá \w a|strong="H3068"\w* los sobrevivientes de la \w ciudad|strong="H5892"\w*».   
\p
\v 20 \w Miró|strong="H7200"\w* \w a|strong="H3068"\w* \w Amalec|strong="H6002"\w*, \w pronunció|strong="H5375"\w* su oráculo y dijo:  
\q1 «\w Amalec|strong="H6002"\w* fue la primera de las \w naciones|strong="H1471"\w*,  
\q2 pero su fin será la destrucción».   
\p
\v 21 \w Miró|strong="H7200"\w* al ceneo, \w pronunció|strong="H5375"\w* su oráculo y dijo:  
\q1 «Firme es tu \w morada|strong="H4186"\w*,  
\q2 y has puesto tu \w nido|strong="H7064"\w* en la \w roca|strong="H5553"\w*.   
\q1
\v 22 Sin embargo, \w el|strong="H3588"\w* ceneo \w será|strong="H1961"\w* consumido,  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* Asiria \w te|strong="H3588"\w* lleve \w cautivo|strong="H7617"\w*».   
\p
\v 23 \w Pronunció|strong="H5375"\w* su oráculo una vez \w más|strong="H2421"\w*, y dijo:  
\q1 «¡Ay! ¿\w Quién|strong="H4310"\w* \w vivirá|strong="H2421"\w* cuando Dios disponga esto?   
\q2
\v 24 Pero vendrán naves de las costas de Quitim,  
\q1 \w y|strong="H1571"\w* \w afligirán|strong="H6031"\w* \w a|strong="H3068"\w* Asiria, \w y|strong="H1571"\w* \w afligirán|strong="H6031"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w*,  
\q2 \w y|strong="H1571"\w* \w él|strong="H1931"\w* \w también|strong="H1571"\w* perecerá \w para|strong="H5703"\w* \w siempre|strong="H5703"\w*».   
\p
\v 25 \w Entonces|strong="H1571"\w* \w Balaam|strong="H1109"\w* se \w levantó|strong="H6965"\w*, se \w fue|strong="H3212"\w* \w y|strong="H1571"\w* regresó \w a|strong="H3068"\w* su tierra; \w y|strong="H1571"\w* \w Balac|strong="H1111"\w* \w también|strong="H1571"\w* se \w fue|strong="H3212"\w* \w por|strong="H1870"\w* su \w camino|strong="H1870"\w*.   
\c 25
\p
\v 1 \w Israel|strong="H3478"\w* \w se|strong="H5971"\w* \w quedó|strong="H3427"\w* en Sitim, y \w el|strong="H3427"\w* \w pueblo|strong="H5971"\w* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* prostituirse con las \w hijas|strong="H1323"\w* \w de|strong="H5971"\w* \w Moab|strong="H4124"\w*;  
\v 2 pues ellas invitaron al \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* los \w sacrificios|strong="H2077"\w* \w de|strong="H5971"\w* sus dioses. El \w pueblo|strong="H5971"\w* comió y \w se|strong="H5971"\w* inclinó ante sus dioses.  
\v 3 \w Israel|strong="H3478"\w* se unió \w a|strong="H3068"\w* Baal Peor, y la ira de Yahvé se encendió \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w*.  
\v 4 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «\w Toma|strong="H3947"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w jefes|strong="H7218"\w* del \w pueblo|strong="H5971"\w* y ahorcadlos \w delante|strong="H5048"\w* \w de|strong="H5048"\w* Yahvé \w a|strong="H3068"\w* plena luz del \w sol|strong="H8121"\w*, \w para|strong="H5971"\w* \w que|strong="H5971"\w* \w el|strong="H3605"\w* \w furor|strong="H2740"\w* \w de|strong="H5048"\w* \w la|strong="H3605"\w* \w ira|strong="H2740"\w* \w de|strong="H5048"\w* Yahvé \w se|strong="H5971"\w* aparte \w de|strong="H5048"\w* \w Israel|strong="H3478"\w*».   
\p
\v 5 \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* los \w jueces|strong="H8199"\w* de \w Israel|strong="H3478"\w*: «\w Matad|strong="H2026"\w* cada uno \w a|strong="H3068"\w* los suyos que se han unido \w a|strong="H3068"\w* Baal Peor».   
\p
\v 6 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H1121"\w* uno \w de|strong="H1121"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* vino y trajo \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanos \w a|strong="H3068"\w* una mujer \w madianita|strong="H4084"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* vista \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w* y \w de|strong="H1121"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w de|strong="H1121"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w mientras|strong="H3605"\w* \w ellos|strong="H1992"\w* \w lloraban|strong="H1058"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w puerta|strong="H6607"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* Tienda del Encuentro.  
\v 7 Cuando Finees, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Eleazar, \w hijo|strong="H1121"\w* del \w sacerdote|strong="H3548"\w* Aarón, lo \w vio|strong="H7200"\w*, se \w levantó|strong="H6965"\w* \w de|strong="H1121"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* la congregación y \w tomó|strong="H3947"\w* una \w lanza|strong="H7420"\w* \w en|strong="H8432"\w* su \w mano|strong="H3027"\w*.  
\v 8 Fue tras \w el|strong="H5921"\w* \w hombre|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* alcoba, \w y|strong="H5921"\w* \w los|strong="H1121"\w* atravesó \w a|strong="H3068"\w* \w ambos|strong="H8147"\w*, \w al|strong="H5921"\w* \w hombre|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* mujer \w por|strong="H5921"\w* \w el|strong="H5921"\w* vientre. Así \w se|strong="H5921"\w* detuvo \w la|strong="H5921"\w* \w plaga|strong="H4046"\w* \w entre|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 9 \w Los|strong="H1961"\w* \w que|strong="H1961"\w* \w murieron|strong="H4191"\w* por la \w plaga|strong="H4046"\w* \w fueron|strong="H1961"\w* \w veinticuatro|strong="H6242"\w* mil.   
\p
\v 10 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 11 “Finees, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Eleazar, \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Aarón, \w ha|strong="H3808"\w* apartado \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w porque|strong="H5921"\w* \w se|strong="H5921"\w* llenó \w de|strong="H5921"\w* \w celo|strong="H7068"\w* \w por|strong="H5921"\w* \w mí|strong="H5921"\w* \w entre|strong="H8432"\w* \w ellos|strong="H5921"\w*, \w de|strong="H5921"\w* modo \w que|strong="H3808"\w* \w no|strong="H3808"\w* consumí \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w celo|strong="H7068"\w*.  
\v 12 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, diles: ‘He \w aquí|strong="H2005"\w* que yo le concedo mi \w pacto|strong="H1285"\w* \w de|strong="H5414"\w* \w paz|strong="H7965"\w*.  
\v 13 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w para|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w para|strong="H5921"\w* su \w descendencia|strong="H2233"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w el|strong="H5921"\w* \w pacto|strong="H1285"\w* \w de|strong="H5921"\w* un \w sacerdocio|strong="H3550"\w* \w perpetuo|strong="H5769"\w*, \w porque|strong="H5921"\w* \w tuvo|strong="H1961"\w* \w celo|strong="H7065"\w* \w por|strong="H5921"\w* su Dios \w e|strong="H3068"\w* hizo \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*’”.   
\p
\v 14 \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* del \w hombre|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* fue \w muerto|strong="H5221"\w* junto con la mujer \w madianita|strong="H4084"\w* \w era|strong="H1121"\w* \w Zimri|strong="H2174"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Salu|strong="H5543"\w*, \w príncipe|strong="H5387"\w* \w de|strong="H1121"\w* una \w casa|strong="H1004"\w* paterna entre \w los|strong="H1121"\w* simeonitas.  
\v 15 \w El|strong="H1931"\w* \w nombre|strong="H8034"\w* de \w la|strong="H1931"\w* mujer \w madianita|strong="H4084"\w* \w que|strong="H1931"\w* \w fue|strong="H1931"\w* \w muerta|strong="H5221"\w* \w era|strong="H1931"\w* Cozbi, \w hija|strong="H1323"\w* de Zur. \w Él|strong="H1931"\w* \w era|strong="H1931"\w* \w cabeza|strong="H7218"\w* del pueblo de una \w casa|strong="H1004"\w* paterna \w en|strong="H5221"\w* \w Madián|strong="H4080"\w*.   
\p
\v 16 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 17 «Hostigad \w a|strong="H3068"\w* los madianitas y atacadlos;  
\v 18 \w porque|strong="H3588"\w* \w ellos|strong="H1992"\w* \w os|strong="H5921"\w* han hostigado \w a|strong="H3068"\w* vosotros \w con|strong="H5921"\w* \w sus|strong="H1992"\w* artimañas, \w con|strong="H5921"\w* \w las|strong="H1992"\w* \w que|strong="H3588"\w* \w os|strong="H5921"\w* han engañado \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w asunto|strong="H1697"\w* \w de|strong="H5921"\w* Peor, \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* incidente \w de|strong="H5921"\w* Cozbi, \w hija|strong="H1323"\w* \w del|strong="H5921"\w* \w príncipe|strong="H5387"\w* \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*, \w su|strong="H1992"\w* hermana, \w que|strong="H3588"\w* fue \w muerta|strong="H5221"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w plaga|strong="H4046"\w* \w por|strong="H5921"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* Peor».   
\c 26
\p
\v 1 Después \w de|strong="H1121"\w* la plaga, Yahvé habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y al \w sacerdote|strong="H3548"\w* Eleazar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, diciendo:  
\v 2 «Haced un censo \w de|strong="H1121"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w de|strong="H1121"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* \w en|strong="H3318"\w* adelante, por las \w casas|strong="H1004"\w* \w de|strong="H1121"\w* sus padres, \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* puedan \w salir|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w guerra|strong="H6635"\w* \w en|strong="H3318"\w* \w Israel|strong="H3478"\w*».  
\v 3 \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Eleazar \w hablaron|strong="H1696"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* llanuras \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*, frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*, \w diciendo|strong="H1696"\w*:  
\v 4 «Haced un censo del pueblo, \w de|strong="H1121"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* \w en|strong="H3318"\w* adelante, como Yahvé \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* \w salieron|strong="H3318"\w* \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*».   
\p
