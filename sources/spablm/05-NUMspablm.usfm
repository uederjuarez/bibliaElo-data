\p \w Él|strong="H5921"\w* \w respondió|strong="H1109"\w*: «\w No|strong="H3808"\w*».   
\p
\v 31 Entonces Yahvé \w abrió|strong="H1540"\w* los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w Balaam|strong="H1109"\w*, y \w vio|strong="H7200"\w* al \w ángel|strong="H4397"\w* \w de|strong="H5869"\w* Yahvé parado en el \w camino|strong="H1870"\w*, con su \w espada|strong="H2719"\w* desenvainada en la \w mano|strong="H3027"\w*; y él \w inclinó|strong="H6915"\w* la cabeza y se postró sobre su rostro.  
\v 32 \w El|strong="H5921"\w* \w ángel|strong="H4397"\w* \w de|strong="H5921"\w* Yahvé \w le|strong="H5921"\w* dijo: «¿\w Por|strong="H5921"\w* \w qué|strong="H3588"\w* has golpeado \w a|strong="H3068"\w* tu asna \w estas|strong="H2088"\w* \w tres|strong="H7969"\w* \w veces|strong="H7272"\w*? He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* he \w salido|strong="H3318"\w* \w como|strong="H4100"\w* adversario, \w porque|strong="H3588"\w* tu \w camino|strong="H1870"\w* \w es|strong="H2088"\w* perverso \w delante|strong="H5048"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.  
\v 33 \w El|strong="H3588"\w* asna \w me|strong="H3588"\w* \w vio|strong="H7200"\w* \w y|strong="H1571"\w* se apartó \w de|strong="H3588"\w* mi \w presencia|strong="H6440"\w* \w estas|strong="H2088"\w* \w tres|strong="H7969"\w* \w veces|strong="H7272"\w*. \w Si|strong="H3588"\w* \w no|strong="H3588"\w* se hubiera apartado \w de|strong="H3588"\w* mí, \w ciertamente|strong="H3588"\w* \w ahora|strong="H6258"\w* \w te|strong="H3588"\w* habría matado \w a|strong="H3068"\w* ti, \w y|strong="H1571"\w* \w a|strong="H3068"\w* ella \w la|strong="H1571"\w* habría dejado \w con|strong="H3588"\w* \w vida|strong="H2421"\w*».   
