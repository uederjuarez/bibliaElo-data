\v 41 \w Tomarás|strong="H3947"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* para mí, yo soy Yahvé, \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w primogénitos|strong="H1060"\w* \w de|strong="H8478"\w* \w entre|strong="H8478"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w*; y \w el|strong="H3605"\w* \w ganado|strong="H1121"\w* \w de|strong="H8478"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w primogénitos|strong="H1060"\w* \w de|strong="H8478"\w* \w entre|strong="H8478"\w* \w el|strong="H3605"\w* \w ganado|strong="H1121"\w* \w de|strong="H8478"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w*».   
\p
