\p
\v 52 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 53 «\w A|strong="H3068"\w* estos se les \w repartirá|strong="H2505"\w* la tierra en \w herencia|strong="H5159"\w* según el \w número|strong="H4557"\w* de los \w nombres|strong="H8034"\w*.  
\v 54 \w A|strong="H3068"\w* la tribu \w más|strong="H7227"\w* numerosa le \w darás|strong="H5414"\w* \w mayor|strong="H7227"\w* \w herencia|strong="H5159"\w*, y \w a|strong="H3068"\w* la menos numerosa le \w darás|strong="H5414"\w* \w menor|strong="H4591"\w* \w herencia|strong="H5159"\w*. \w A|strong="H3068"\w* cada uno se le \w dará|strong="H5414"\w* su \w herencia|strong="H5159"\w* en proporción \w a|strong="H3068"\w* sus contados.  
\v 55 Sin embargo, la tierra se dividirá por sorteo. \w Heredarán|strong="H5157"\w* según los \w nombres|strong="H8034"\w* de las \w tribus|strong="H4294"\w* de sus padres.  
\v 56 \w Conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w suerte|strong="H1486"\w* \w se|strong="H5921"\w* \w repartirá|strong="H2505"\w* su \w herencia|strong="H5159"\w* \w entre|strong="H5921"\w* \w las|strong="H5921"\w* tribus \w grandes|strong="H7227"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* pequeñas».   
\p
\v 57 Estos son los contados de los \w levitas|strong="H3881"\w* según sus \w familias|strong="H4940"\w*: de \w Gersón|strong="H1648"\w*, la \w familia|strong="H4940"\w* de los gersonitas; de Coat, la \w familia|strong="H4940"\w* de los coatitas; de \w Merari|strong="H4847"\w*, la \w familia|strong="H4940"\w* de los meraritas.  
\v 58 Estas son las \w familias|strong="H4940"\w* de \w Leví|strong="H3881"\w*: la \w familia|strong="H4940"\w* de los libnitas, la \w familia|strong="H4940"\w* de los hebronitas, la \w familia|strong="H4940"\w* de los mahlitas, la \w familia|strong="H4940"\w* de los musitas y la \w familia|strong="H4940"\w* de los coreítas. Coat \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Amram|strong="H6019"\w*.  
\v 59 El \w nombre|strong="H8034"\w* de la mujer de \w Amram|strong="H6019"\w* era Jocabed, \w hija|strong="H1323"\w* de \w Leví|strong="H3878"\w*, la cual \w nació|strong="H3205"\w* \w a|strong="H3068"\w* \w Leví|strong="H3878"\w* en \w Egipto|strong="H4714"\w*. Ella le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Amram|strong="H6019"\w*, \w a|strong="H3068"\w* Aarón, \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* su hermana Miriam.  
\v 60 \w A|strong="H3068"\w* Aarón le \w nacieron|strong="H3205"\w* \w Nadab|strong="H5070"\w*, Abiú, Eleazar \w e|strong="H3068"\w* Itamar.  
\v 61 Pero \w Nadab|strong="H5070"\w* y Abiú \w murieron|strong="H4191"\w* cuando ofrecieron fuego \w extraño|strong="H2114"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.  
\v 62 \w Los|strong="H1992"\w* contados \w de|strong="H3588"\w* \w ellos|strong="H1992"\w* \w fueron|strong="H1961"\w* \w veintitrés|strong="H6242"\w* mil, \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w varones|strong="H2145"\w* \w de|strong="H3588"\w* un \w mes|strong="H2320"\w* \w en|strong="H8432"\w* adelante; \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w fueron|strong="H1961"\w* contados \w entre|strong="H8432"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* \w les|strong="H1992"\w* \w dio|strong="H5414"\w* \w herencia|strong="H5159"\w* \w entre|strong="H8432"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.  
\v 63 Estos son \w los|strong="H1121"\w* contados \w por|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Eleazar, quienes \w contaron|strong="H6485"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* llanuras \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*, frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*.  
\v 64 Pero \w entre|strong="H3808"\w* estos \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w ninguno|strong="H3808"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w que|strong="H3808"\w* \w fueron|strong="H1961"\w* contados por \w Moisés|strong="H4872"\w* y \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Aarón, \w cuando|strong="H1961"\w* \w contaron|strong="H6485"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* en \w el|strong="H1121"\w* \w desierto|strong="H4057"\w* del \w Sinaí|strong="H5514"\w*.  
\v 65 \w Porque|strong="H3588"\w* Yahvé \w había|strong="H3588"\w* dicho \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*: «\w Ciertamente|strong="H3588"\w* \w morirán|strong="H4191"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*». \w No|strong="H3808"\w* \w quedó|strong="H3498"\w* \w ningún|strong="H3808"\w* \w hombre|strong="H1121"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*, \w a|strong="H3068"\w* excepción \w de|strong="H3588"\w* \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Jefone, \w y|strong="H3588"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Nun|strong="H5126"\w*.   
\c 27
\p
\v 1 Entonces se acercaron las \w hijas|strong="H1323"\w* \w de|strong="H1121"\w* Zelofehad, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hefer, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w de|strong="H1121"\w* las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*. Estos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* sus \w hijas|strong="H1323"\w*: \w Maala|strong="H4244"\w*, \w Noa|strong="H5270"\w*, \w Hogla|strong="H2295"\w*, \w Milca|strong="H4435"\w* y Tirsa.  
\v 2 Se presentaron \w ante|strong="H6440"\w* \w Moisés|strong="H4872"\w*, \w ante|strong="H6440"\w* \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* Eleazar, \w ante|strong="H6440"\w* \w los|strong="H3605"\w* \w príncipes|strong="H5387"\w* y \w ante|strong="H6440"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación, \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w puerta|strong="H6607"\w* \w de|strong="H6440"\w* \w la|strong="H3605"\w* Tienda del Encuentro, diciendo:  
\v 3 «Nuestro padre \w murió|strong="H4191"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w desierto|strong="H4057"\w*. \w Él|strong="H1931"\w* \w no|strong="H3808"\w* \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* compañía \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* agruparon \w contra|strong="H5921"\w* Yahvé \w en|strong="H5921"\w* \w la|strong="H1931"\w* rebelión \w de|strong="H5921"\w* \w Coré|strong="H7141"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w murió|strong="H4191"\w* \w por|strong="H5921"\w* \w su|strong="H1931"\w* propio \w pecado|strong="H2399"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w*.  
\v 4 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* ha \w de|strong="H3588"\w* ser borrado \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* nuestro padre \w de|strong="H3588"\w* \w entre|strong="H8432"\w* \w su|strong="H3588"\w* \w familia|strong="H4940"\w* \w por|strong="H3588"\w* \w no|strong="H3588"\w* haber tenido un \w hijo|strong="H1121"\w* varón? \w Dadnos|strong="H5414"\w* una posesión \w entre|strong="H8432"\w* \w los|strong="H1121"\w* hermanos \w de|strong="H3588"\w* nuestro padre».   
\p
\v 5 \w Moisés|strong="H4872"\w* \w llevó|strong="H7126"\w* su \w causa|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.  
\v 6 \w Y|strong="H3068"\w* Yahvé habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, diciendo:  
\v 7 “Las \w hijas|strong="H1323"\w* \w de|strong="H5414"\w* Zelofehad \w hablan|strong="H1696"\w* con razón. \w Ciertamente|strong="H5414"\w* les \w darás|strong="H5414"\w* \w posesión|strong="H5159"\w* \w de|strong="H5414"\w* una \w herencia|strong="H5159"\w* \w entre|strong="H8432"\w* los hermanos \w de|strong="H5414"\w* su padre. Harás \w que|strong="H1323"\w* la \w herencia|strong="H5159"\w* \w de|strong="H5414"\w* su padre \w pase|strong="H5674"\w* \w a|strong="H3068"\w* ellas.  
\v 8 \w Y|strong="H3068"\w* \w hablarás|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w diciendo|strong="H1696"\w*: ‘\w Si|strong="H3588"\w* un \w hombre|strong="H1121"\w* muere \w y|strong="H3588"\w* \w no|strong="H3588"\w* tiene \w hijo|strong="H1121"\w*, \w entonces|strong="H3588"\w* haréis \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w herencia|strong="H5159"\w* \w pase|strong="H5674"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hija|strong="H1323"\w*.  
\v 9 Si no tiene \w hija|strong="H1323"\w*, \w daréis|strong="H5414"\w* su \w herencia|strong="H5159"\w* \w a|strong="H3068"\w* sus hermanos.  
\v 10 Si no tiene hermanos, \w daréis|strong="H5414"\w* su \w herencia|strong="H5159"\w* \w a|strong="H3068"\w* los hermanos \w de|strong="H5414"\w* su padre.  
\v 11 \w Y|strong="H3068"\w* \w si|strong="H1961"\w* su padre \w no|strong="H1961"\w* \w tiene|strong="H1961"\w* hermanos, entonces \w daréis|strong="H5414"\w* su \w herencia|strong="H5159"\w* \w a|strong="H3068"\w* su pariente más \w cercano|strong="H7138"\w* \w de|strong="H1121"\w* su \w familia|strong="H4940"\w*, y \w él|strong="H1121"\w* la \w poseerá|strong="H3423"\w*. Esto \w será|strong="H1961"\w* un \w estatuto|strong="H2708"\w* y una \w ordenanza|strong="H4941"\w* \w para|strong="H5414"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, tal \w como|strong="H1961"\w* Yahvé le \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*’”.   
\p
\v 12 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «\w Sube|strong="H5927"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w monte|strong="H2022"\w* \w de|strong="H1121"\w* \w Abarim|strong="H5682"\w* y contempla la tierra \w que|strong="H1121"\w* he \w dado|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.  
\v 13 \w Cuando|strong="H1571"\w* \w la|strong="H1571"\w* hayas \w visto|strong="H7200"\w*, tú \w también|strong="H1571"\w* serás reunido \w con|strong="H1571"\w* tu \w pueblo|strong="H5971"\w*, tal \w como|strong="H1571"\w* \w fue|strong="H1571"\w* reunido tu hermano Aarón;  
\v 14 porque en la contienda \w de|strong="H4325"\w* la congregación \w os|strong="H5869"\w* rebelasteis contra mi \w mandato|strong="H6310"\w* en \w el|strong="H1992"\w* \w desierto|strong="H4057"\w* \w de|strong="H4325"\w* Zin, al no santificarme ante \w sus|strong="H1992"\w* \w ojos|strong="H5869"\w* junto \w a|strong="H3068"\w* \w las|strong="H1992"\w* \w aguas|strong="H4325"\w*». (\w Estas|strong="H1992"\w* \w son|strong="H6310"\w* \w las|strong="H1992"\w* \w aguas|strong="H4325"\w* \w de|strong="H4325"\w* Meribá \w de|strong="H4325"\w* \w Cades|strong="H6946"\w*, en \w el|strong="H1992"\w* \w desierto|strong="H4057"\w* \w de|strong="H4325"\w* Zin).   
\p
\v 15 \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* Yahvé, \w diciendo|strong="H1696"\w*:  
\v 16 «\w Que|strong="H5921"\w* Yahvé, \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w espíritus|strong="H7307"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w carne|strong="H1320"\w*, \w ponga|strong="H6485"\w* \w a|strong="H3068"\w* un hombre \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* congregación,  
\v 17 \w que|strong="H3808"\w* \w salga|strong="H3318"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos y \w que|strong="H3808"\w* \w entre|strong="H3808"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos, \w que|strong="H3808"\w* \w los|strong="H1961"\w* \w saque|strong="H3318"\w* y \w los|strong="H1961"\w* introduzca, \w para|strong="H1961"\w* \w que|strong="H3808"\w* la congregación \w de|strong="H6440"\w* Yahvé \w no|strong="H3808"\w* \w sea|strong="H1961"\w* \w como|strong="H1961"\w* \w ovejas|strong="H6629"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w tienen|strong="H1961"\w* \w pastor|strong="H7462"\w*».   
\p
\v 18 Yahvé dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «\w Toma|strong="H3947"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Nun|strong="H5126"\w*, un \w hombre|strong="H1121"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* cual hay \w espíritu|strong="H7307"\w*, \w y|strong="H5921"\w* pon tu \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 19 Preséntalo \w delante|strong="H6440"\w* del \w sacerdote|strong="H3548"\w* Eleazar y \w de|strong="H6440"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación, y dale \w el|strong="H3605"\w* cargo \w en|strong="H5975"\w* \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H3605"\w*.  
\v 20 \w Pondrás|strong="H5414"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* parte \w de|strong="H5921"\w* tu autoridad, \w para|strong="H4616"\w* \w que|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w le|strong="H5921"\w* obedezca.  
\v 21 \w Él|strong="H1931"\w* \w se|strong="H1931"\w* \w presentará|strong="H5975"\w* \w ante|strong="H6440"\w* \w el|strong="H1931"\w* \w sacerdote|strong="H3548"\w* Eleazar, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* consultará \w por|strong="H5921"\w* \w él|strong="H1931"\w* \w el|strong="H1931"\w* \w juicio|strong="H4941"\w* \w del|strong="H5921"\w* Urim \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé. \w A|strong="H3068"\w* \w la|strong="H1931"\w* \w palabra|strong="H6310"\w* \w de|strong="H5921"\w* Eleazar \w saldrán|strong="H3318"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w palabra|strong="H6310"\w* entrarán, \w él|strong="H1931"\w* \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w con|strong="H5921"\w* \w él|strong="H1931"\w*, \w toda|strong="H3605"\w* \w la|strong="H1931"\w* congregación».   
\p
\v 22 \w Moisés|strong="H4872"\w* \w hizo|strong="H6213"\w* tal como Yahvé le \w había|strong="H5975"\w* \w ordenado|strong="H6680"\w*. \w Tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* y \w lo|strong="H6213"\w* presentó \w ante|strong="H6440"\w* \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* Eleazar y \w ante|strong="H6440"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación.  
\v 23 \w Le|strong="H5921"\w* impuso \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* dio \w el|strong="H5921"\w* \w cargo|strong="H3027"\w*, tal \w como|strong="H5921"\w* Yahvé había \w hablado|strong="H1696"\w* \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*.   
\c 28
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Ordena|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y diles: ‘\w Tendréis|strong="H8104"\w* cuidado \w de|strong="H1121"\w* presentarme \w a|strong="H3068"\w* su debido \w tiempo|strong="H4150"\w* mi \w ofrenda|strong="H7133"\w*, mi alimento para mis \w ofrendas|strong="H7133"\w* encendidas como aroma agradable para mí’.  
\v 3 Les dirás: ‘\w Esta|strong="H2088"\w* \w es|strong="H2088"\w* la ofrenda encendida \w que|strong="H3117"\w* \w ofreceréis|strong="H7126"\w* \w a|strong="H3068"\w* Yahvé: \w dos|strong="H8147"\w* \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w*, sin defecto, \w cada|strong="H3117"\w* \w día|strong="H3117"\w*, como \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*.  
\v 4 \w Ofrecerás|strong="H6213"\w* un \w cordero|strong="H3532"\w* por la \w mañana|strong="H1242"\w*, y \w el|strong="H6213"\w* \w otro|strong="H8145"\w* \w cordero|strong="H3532"\w* \w lo|strong="H6213"\w* \w ofrecerás|strong="H6213"\w* al atardecer,  
\v 5 junto con la décima parte de un efa\f + \fr 28:5 \ft 1 efa equivale a unos 22 litros o unos 2/3 de una fanega.\f* de harina fina como \w ofrenda|strong="H4503"\w* vegetal, \w amasada|strong="H1101"\w* con la cuarta parte de un \w hin|strong="H1969"\w*\f + \fr 28:5 \ft Un hin equivale a unos 6,5 litros, por lo que 1/4 de hin es alrededor de 1,6 litros.\f* de \w aceite|strong="H8081"\w* de olivas machacadas.  
\v 6 Es \w el|strong="H6213"\w* \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w* que fue ordenado en \w el|strong="H6213"\w* \w monte|strong="H2022"\w* \w Sinaí|strong="H5514"\w* como aroma agradable, una ofrenda encendida \w a|strong="H3068"\w* Yahvé.  
\v 7 Su \w libación|strong="H5262"\w* será la cuarta parte de un \w hin|strong="H1969"\w* por cada \w cordero|strong="H3532"\w*. \w Derramarás|strong="H5258"\w* una \w libación|strong="H5262"\w* de \w bebida|strong="H7941"\w* fermentada \w a|strong="H3068"\w* Yahvé en el lugar \w santo|strong="H6944"\w*.  
\v 8 \w El|strong="H6213"\w* \w segundo|strong="H8145"\w* \w cordero|strong="H3532"\w* \w lo|strong="H6213"\w* \w ofrecerás|strong="H6213"\w* al atardecer. \w Lo|strong="H6213"\w* \w ofrecerás|strong="H6213"\w* con la misma \w ofrenda|strong="H4503"\w* vegetal de la \w mañana|strong="H1242"\w* y con su misma \w libación|strong="H5262"\w*, como \w ofrenda|strong="H4503"\w* encendida de aroma agradable \w a|strong="H3068"\w* Yahvé.   
\p
\v 9 “‘\w En|strong="H8549"\w* \w el|strong="H1121"\w* \w día|strong="H3117"\w* \w de|strong="H1121"\w* reposo, ofreceréis \w dos|strong="H8147"\w* \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto, y \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* \w de|strong="H1121"\w* efa\f + \fr 28:9 \ft 1 efa equivale a unos 22 litros.\f* \w de|strong="H1121"\w* harina fina como \w ofrenda|strong="H4503"\w* vegetal \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w*, junto con su \w libación|strong="H5262"\w*.  
\v 10 Este es \w el|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w de|strong="H5921"\w* cada \w sábado|strong="H7676"\w*, \w además|strong="H5921"\w* \w del|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w* \w y|strong="H5921"\w* su \w libación|strong="H5262"\w*.   
\p
\v 11 “‘\w En|strong="H8549"\w* \w los|strong="H1121"\w* principios \w de|strong="H1121"\w* vuestros \w meses|strong="H2320"\w*, \w ofreceréis|strong="H7126"\w* como \w holocausto|strong="H5930"\w* \w a|strong="H3068"\w* Yahvé \w dos|strong="H8147"\w* \w novillos|strong="H6499"\w*, un carnero \w y|strong="H1241"\w* \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto;  
\v 12 y \w tres|strong="H7969"\w* \w décimas|strong="H6241"\w* de un efa\f + \fr 28:12 \ft 1 efa equivale a unos 22 litros.\f* de harina fina como \w ofrenda|strong="H4503"\w* vegetal \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w*, por cada \w novillo|strong="H6499"\w*; y \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* de harina fina como \w ofrenda|strong="H4503"\w* vegetal \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w*, por el único carnero;  
\v 13 y una \w décima|strong="H6241"\w* de harina fina \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w* como \w ofrenda|strong="H4503"\w* vegetal por cada \w cordero|strong="H3532"\w*, como \w holocausto|strong="H5930"\w* de aroma agradable, \w ofrenda|strong="H4503"\w* encendida \w a|strong="H3068"\w* Yahvé.  
\v 14 Sus \w libaciones|strong="H5262"\w* \w serán|strong="H1961"\w* \w medio|strong="H2677"\w* \w hin|strong="H1969"\w* de \w vino|strong="H3196"\w* por el \w novillo|strong="H6499"\w*, \w la|strong="H2063"\w* \w tercera|strong="H7992"\w* \w parte|strong="H2677"\w* de un \w hin|strong="H1969"\w* por el carnero y \w la|strong="H2063"\w* cuarta \w parte|strong="H2677"\w* de un \w hin|strong="H1969"\w* por el \w cordero|strong="H3532"\w*. \w Este|strong="H2063"\w* \w es|strong="H1961"\w* el \w holocausto|strong="H5930"\w* de \w cada|strong="H8141"\w* \w mes|strong="H2320"\w*, por \w todos|strong="H8141"\w* \w los|strong="H1961"\w* \w meses|strong="H2320"\w* \w del|strong="H2677"\w* \w año|strong="H8141"\w*.  
\v 15 También \w se|strong="H5921"\w* \w ofrecerá|strong="H6213"\w* un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w* \w como|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w a|strong="H3068"\w* Yahvé, \w además|strong="H5921"\w* \w del|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w* \w y|strong="H5921"\w* su \w libación|strong="H5262"\w*.   
\p
\v 16 “‘En el \w primer|strong="H7223"\w* \w mes|strong="H2320"\w*, \w a|strong="H3068"\w* los catorce \w días|strong="H3117"\w* del \w mes|strong="H2320"\w*, es la \w Pascua|strong="H6453"\w* de Yahvé.  
\v 17 El \w día|strong="H3117"\w* \w quince|strong="H2568"\w* \w de|strong="H2568"\w* \w este|strong="H2088"\w* \w mes|strong="H2320"\w* será \w de|strong="H2568"\w* \w fiesta|strong="H2282"\w*. Se comerá pan sin levadura durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.  
\v 18 \w El|strong="H3605"\w* \w primer|strong="H7223"\w* \w día|strong="H3117"\w* \w habrá|strong="H3117"\w* una \w santa|strong="H6944"\w* \w convocación|strong="H4744"\w*. \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ninguna|strong="H3605"\w* clase de trabajo \w servil|strong="H5656"\w*,  
\v 19 sino \w que|strong="H1121"\w* \w ofreceréis|strong="H7126"\w* una ofrenda encendida, un \w holocausto|strong="H5930"\w* \w a|strong="H3068"\w* Yahvé: \w dos|strong="H8147"\w* \w novillos|strong="H6499"\w*, un carnero \w y|strong="H1241"\w* \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w*; aseguraros \w de|strong="H1121"\w* \w que|strong="H1121"\w* \w sean|strong="H1961"\w* sin defecto.  
\v 20 Con su \w ofrenda|strong="H4503"\w* vegetal de harina fina \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w*, \w ofreceréis|strong="H6213"\w* \w tres|strong="H7969"\w* \w décimas|strong="H6241"\w* por cada \w novillo|strong="H6499"\w*, y \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* por \w el|strong="H6213"\w* carnero.  
\v 21 \w Ofrecerás|strong="H6213"\w* una \w décima|strong="H6241"\w* por cada uno de los \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w*;  
\v 22 \w y|strong="H5921"\w* un \w macho|strong="H8163"\w* cabrío \w como|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w*, \w para|strong="H5921"\w* hacer \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* vosotros.  
\v 23 \w Ofreceréis|strong="H6213"\w* estos además del \w holocausto|strong="H5930"\w* de la \w mañana|strong="H1242"\w*, que forma parte del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*.  
\v 24 \w De|strong="H5921"\w* \w esta|strong="H5921"\w* manera \w ofreceréis|strong="H6213"\w* \w cada|strong="H3117"\w* \w día|strong="H3117"\w*, durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*, \w el|strong="H5921"\w* alimento \w de|strong="H5921"\w* \w la|strong="H5921"\w* ofrenda encendida, \w de|strong="H5921"\w* aroma agradable \w a|strong="H3068"\w* Yahvé. \w Se|strong="H5921"\w* \w ofrecerá|strong="H6213"\w* \w además|strong="H5921"\w* \w del|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w* \w y|strong="H5921"\w* su \w libación|strong="H5262"\w*.  
\v 25 \w El|strong="H3605"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w tendréis|strong="H1961"\w* una \w santa|strong="H6944"\w* \w convocación|strong="H4744"\w*. \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo \w servil|strong="H5656"\w*.   
\p
\v 26 “‘También en \w el|strong="H3605"\w* \w día|strong="H3117"\w* de las primicias, \w cuando|strong="H3117"\w* presentéis una \w ofrenda|strong="H4503"\w* \w nueva|strong="H2319"\w* \w a|strong="H3068"\w* Yahvé en \w vuestra|strong="H1961"\w* fiesta de las \w Semanas|strong="H7620"\w*, \w tendréis|strong="H1961"\w* una \w santa|strong="H6944"\w* \w convocación|strong="H4744"\w*. \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo \w servil|strong="H5656"\w*;  
\v 27 sino \w que|strong="H1121"\w* \w ofreceréis|strong="H7126"\w* un \w holocausto|strong="H5930"\w* como aroma agradable \w a|strong="H3068"\w* Yahvé: \w dos|strong="H8147"\w* \w novillos|strong="H6499"\w*, un carnero \w y|strong="H1241"\w* \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w*;  
\v 28 y su \w ofrenda|strong="H4503"\w* vegetal de harina fina \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w*: \w tres|strong="H7969"\w* \w décimas|strong="H6241"\w* por cada \w novillo|strong="H6499"\w*, \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* por el carnero,  
\v 29 y una \w décima|strong="H6241"\w* por cada uno de los \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w*;  
\v 30 \w junto|strong="H5921"\w* \w con|strong="H5921"\w* un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w*, \w para|strong="H5921"\w* hacer \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* vosotros.  
\v 31 \w Los|strong="H1961"\w* \w ofreceréis|strong="H6213"\w*, junto con sus \w libaciones|strong="H5262"\w*, además del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w* y de su \w ofrenda|strong="H4503"\w* vegetal. Aseguraos de \w que|strong="H1961"\w* \w sean|strong="H1961"\w* animales sin defecto’”.   
\c 29
\p
\v 1 “‘En \w el|strong="H3605"\w* \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w*, \w el|strong="H3605"\w* primer \w día|strong="H3117"\w* del \w mes|strong="H2320"\w*, \w tendréis|strong="H1961"\w* una \w santa|strong="H6944"\w* \w convocación|strong="H4744"\w*; \w no|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo \w servil|strong="H5656"\w*. \w Es|strong="H1961"\w* un \w día|strong="H3117"\w* de toque de trompetas \w para|strong="H1961"\w* vosotros.  
\v 2 \w Ofreceréis|strong="H6213"\w* un \w holocausto|strong="H5930"\w* como aroma agradable \w a|strong="H3068"\w* Yahvé: un \w novillo|strong="H1121"\w*, un carnero, \w y|strong="H1241"\w* \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto;  
\v 3 y su \w ofrenda|strong="H4503"\w* vegetal de harina fina \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w*: \w tres|strong="H7969"\w* \w décimas|strong="H6241"\w* por el \w novillo|strong="H6499"\w*, \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* por el carnero,  
\v 4 y una \w décima|strong="H6241"\w* por cada uno de los \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w*;  
\v 5 \w y|strong="H5921"\w* un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w* \w como|strong="H5921"\w* ofrenda \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pecado|strong="H2403"\w*, \w para|strong="H5921"\w* hacer \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* vosotros;  
\v 6 además del \w holocausto|strong="H5930"\w* de la luna nueva con su \w ofrenda|strong="H4503"\w* vegetal, y el \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w* con su \w ofrenda|strong="H4503"\w* vegetal, y sus \w libaciones|strong="H5262"\w*, según su \w ordenanza|strong="H4941"\w*, como aroma agradable, \w ofrenda|strong="H4503"\w* encendida \w a|strong="H3068"\w* Yahvé.   
\p
\v 7 “‘En \w el|strong="H3605"\w* décimo día de \w este|strong="H2088"\w* \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w* \w tendréis|strong="H1961"\w* una \w santa|strong="H6944"\w* \w convocación|strong="H4744"\w*, y \w afligiréis|strong="H6031"\w* vuestras \w almas|strong="H5315"\w*. \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ninguna|strong="H3605"\w* clase de trabajo;  
\v 8 sino \w que|strong="H1121"\w* \w ofreceréis|strong="H7126"\w* \w a|strong="H3068"\w* Yahvé un \w holocausto|strong="H5930"\w* \w como|strong="H1961"\w* aroma agradable: un \w novillo|strong="H1121"\w*, un carnero, \w y|strong="H1241"\w* \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w*, \w todos|strong="H8141"\w* sin defecto;  
\v 9 y su \w ofrenda|strong="H4503"\w* vegetal de harina fina \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w*: \w tres|strong="H7969"\w* \w décimas|strong="H6241"\w* por el \w novillo|strong="H6499"\w*, \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* por el carnero,  
\v 10 y una \w décima|strong="H6241"\w* por cada uno de los \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w*;  
\v 11 y un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w* como \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w*, además de la \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w* de la \w expiación|strong="H2403"\w*, y del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w* con su \w ofrenda|strong="H4503"\w* vegetal, y sus \w libaciones|strong="H5262"\w*.   
\p
\v 12 “‘\w El|strong="H3605"\w* \w decimoquinto|strong="H6240"\w* \w día|strong="H3117"\w* del \w séptimo|strong="H7637"\w* \w mes|strong="H2320"\w* \w tendréis|strong="H1961"\w* una \w santa|strong="H6944"\w* \w convocación|strong="H4744"\w*. \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo \w servil|strong="H5656"\w*. Celebraréis una \w fiesta|strong="H2282"\w* \w a|strong="H3068"\w* Yahvé durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.  
\v 13 \w Ofreceréis|strong="H7126"\w* un \w holocausto|strong="H5930"\w*, una ofrenda encendida, \w de|strong="H1121"\w* aroma agradable \w a|strong="H3068"\w* Yahvé: \w trece|strong="H7969"\w* \w novillos|strong="H6499"\w*, \w dos|strong="H8147"\w* carneros, \w y|strong="H1241"\w* catorce \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w*, \w todos|strong="H8141"\w* sin defecto;  
\v 14 y su \w ofrenda|strong="H4503"\w* vegetal de harina fina \w amasada|strong="H1101"\w* con \w aceite|strong="H8081"\w*: \w tres|strong="H7969"\w* \w décimas|strong="H6241"\w* por cada \w novillo|strong="H6499"\w* de los \w trece|strong="H7969"\w* \w novillos|strong="H6499"\w*, \w dos|strong="H8147"\w* \w décimas|strong="H6241"\w* por cada carnero de los \w dos|strong="H8147"\w* carneros,  
\v 15 y una \w décima|strong="H6241"\w* por cada \w cordero|strong="H3532"\w* de los catorce \w corderos|strong="H3532"\w*;  
\v 16 y un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w* como \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w*, además del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, con su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w*.   
\p
\v 17 “‘\w El|strong="H1121"\w* \w segundo|strong="H8145"\w* \w día|strong="H3117"\w* ofreceréis \w doce|strong="H8147"\w* \w novillos|strong="H6499"\w*, \w dos|strong="H8147"\w* carneros \w y|strong="H1241"\w* catorce \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto;  
\v 18 y su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w* por los \w novillos|strong="H6499"\w*, por los carneros y por los \w corderos|strong="H3532"\w*, según su \w número|strong="H4557"\w*, conforme \w a|strong="H3068"\w* la \w ordenanza|strong="H4941"\w*;  
\v 19 y un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w* como \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w*, además del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, con su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w*.   
\p
\v 20 “‘\w El|strong="H1121"\w* tercer \w día|strong="H3117"\w*: \w once|strong="H6249"\w* \w novillos|strong="H6499"\w*, \w dos|strong="H8147"\w* carneros, y catorce \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto;  
\v 21 y su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w* por los \w novillos|strong="H6499"\w*, por los carneros y por los \w corderos|strong="H3532"\w*, según su \w número|strong="H4557"\w*, conforme \w a|strong="H3068"\w* la \w ordenanza|strong="H4941"\w*;  
\v 22 y un \w macho|strong="H8163"\w* cabrío como \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w*, además del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, con su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w*.   
\p
\v 23 “‘\w El|strong="H1121"\w* \w cuarto|strong="H7243"\w* \w día|strong="H3117"\w*: \w diez|strong="H6235"\w* \w novillos|strong="H6499"\w*, \w dos|strong="H8147"\w* carneros, y catorce \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto;  
\v 24 su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w* por los \w novillos|strong="H6499"\w*, por los carneros y por los \w corderos|strong="H3532"\w*, según su \w número|strong="H4557"\w*, conforme \w a|strong="H3068"\w* la \w ordenanza|strong="H4941"\w*;  
\v 25 y un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w* como \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w*, además del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, con su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w*.   
\p
\v 26 “‘\w El|strong="H1121"\w* \w quinto|strong="H2549"\w* \w día|strong="H3117"\w*: \w nueve|strong="H8672"\w* \w novillos|strong="H6499"\w*, \w dos|strong="H8147"\w* carneros, y catorce \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto;  
\v 27 y su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w* por los \w novillos|strong="H6499"\w*, por los carneros y por los \w corderos|strong="H3532"\w*, según su \w número|strong="H4557"\w*, conforme \w a|strong="H3068"\w* la \w ordenanza|strong="H4941"\w*;  
\v 28 y un \w macho|strong="H8163"\w* cabrío como \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w*, además del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, con su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w*.   
\p
\v 29 “‘\w El|strong="H1121"\w* \w sexto|strong="H8345"\w* \w día|strong="H3117"\w*: \w ocho|strong="H8083"\w* \w novillos|strong="H6499"\w*, \w dos|strong="H8147"\w* carneros, y catorce \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto;  
\v 30 y su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w* por los \w novillos|strong="H6499"\w*, por los carneros y por los \w corderos|strong="H3532"\w*, según su \w número|strong="H4557"\w*, conforme \w a|strong="H3068"\w* la \w ordenanza|strong="H4941"\w*;  
\v 31 y un \w macho|strong="H8163"\w* cabrío como \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w*, además del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, con su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w*.   
\p
\v 32 “‘\w El|strong="H1121"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w*: \w siete|strong="H7651"\w* \w novillos|strong="H6499"\w*, \w dos|strong="H8147"\w* carneros, y catorce \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto;  
\v 33 y su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w* por los \w novillos|strong="H6499"\w*, por los carneros y por los \w corderos|strong="H3532"\w*, según su \w número|strong="H4557"\w*, conforme \w a|strong="H3068"\w* la \w ordenanza|strong="H4941"\w*;  
\v 34 y un \w macho|strong="H8163"\w* cabrío como \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w*, además del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, con su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w*.   
\p
\v 35 “‘\w El|strong="H3605"\w* \w octavo|strong="H8066"\w* \w día|strong="H3117"\w* \w tendréis|strong="H1961"\w* una asamblea solemne. \w No|strong="H3808"\w* \w haréis|strong="H6213"\w* \w ningún|strong="H3605"\w* trabajo \w servil|strong="H5656"\w*;  
\v 36 sino \w que|strong="H1121"\w* \w ofreceréis|strong="H7126"\w* un \w holocausto|strong="H5930"\w*, una ofrenda encendida, \w de|strong="H1121"\w* aroma agradable \w a|strong="H3068"\w* Yahvé: un \w novillo|strong="H1121"\w*, un carnero, y \w siete|strong="H7651"\w* \w corderos|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w* sin defecto;  
\v 37 su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w* por el \w novillo|strong="H6499"\w*, por el carnero y por los \w corderos|strong="H3532"\w*, \w serán|strong="H4941"\w* según su \w número|strong="H4557"\w*, conforme \w a|strong="H3068"\w* la \w ordenanza|strong="H4941"\w*;  
\v 38 y un \w macho|strong="H8163"\w* cabrío como \w ofrenda|strong="H4503"\w* por el \w pecado|strong="H2403"\w*, además del \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, con su \w ofrenda|strong="H4503"\w* vegetal y su \w libación|strong="H5262"\w*.   
\p
\v 39 “‘\w Estas|strong="H6213"\w* cosas \w ofreceréis|strong="H6213"\w* \w a|strong="H3068"\w* Yahvé en vuestras fiestas señaladas, además de vuestros \w votos|strong="H5088"\w* y de vuestras ofrendas \w voluntarias|strong="H5071"\w*, para vuestros \w holocaustos|strong="H5930"\w*, para vuestras ofrendas vegetales, para vuestras \w libaciones|strong="H5262"\w* y para vuestros sacrificios de paz’”.   
\p
\v 40 Moisés dijo \w a|strong="H3068"\w* los hijos de Israel todo lo que Yahvé le había ordenado.   
\c 30
\p
\v 1 \w Moisés|strong="H4872"\w* habló \w a|strong="H3068"\w* \w los|strong="H1121"\w* jefes \w de|strong="H1121"\w* las tribus \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, diciendo: “Esto es \w lo|strong="H3605"\w* \w que|strong="H1121"\w* Yahvé ha \w ordenado|strong="H6680"\w*.  
\v 2 Cuando un \w hombre|strong="H1121"\w* haga un voto \w a|strong="H3068"\w* Yahvé, \w o|strong="H3068"\w* haga un juramento para ligar su alma con un compromiso, no violará su \w palabra|strong="H1697"\w*. Hará conforme \w a|strong="H3068"\w* todo \w lo|strong="H1697"\w* \w que|strong="H1697"\w* salga \w de|strong="H1121"\w* su boca.   
\p
\v 3 “\w Además|strong="H5921"\w*, \w cuando|strong="H3588"\w* una mujer joven, \w que|strong="H3588"\w* \w aún|strong="H3808"\w* vive \w en|strong="H5921"\w* \w la|strong="H5921"\w* casa \w de|strong="H5921"\w* \w su|strong="H3588"\w* padre, \w hace|strong="H6213"\w* un \w voto|strong="H5087"\w* \w a|strong="H3068"\w* Yahvé \w y|strong="H3588"\w* \w se|strong="H5921"\w* liga \w con|strong="H5921"\w* una \w promesa|strong="H5087"\w*,  
\v 4 \w y|strong="H3588"\w* \w su|strong="H3588"\w* padre oye \w su|strong="H3588"\w* \w voto|strong="H5087"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w promesa|strong="H5087"\w* \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w que|strong="H3588"\w* ha ligado \w su|strong="H3588"\w* alma, \w y|strong="H3588"\w* \w su|strong="H3588"\w* padre calla, \w entonces|strong="H3588"\w* todos sus \w votos|strong="H5087"\w* serán válidos, \w y|strong="H3588"\w* todo compromiso \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* haya ligado \w su|strong="H3588"\w* alma será válido.  
\v 5 Pero \w si|strong="H5921"\w* su padre \w se|strong="H5921"\w* \w lo|strong="H5921"\w* prohíbe \w el|strong="H5921"\w* día \w que|strong="H5921"\w* \w se|strong="H5921"\w* entera, \w ninguno|strong="H3605"\w* \w de|strong="H5921"\w* sus \w votos|strong="H5088"\w* ni \w de|strong="H5921"\w* sus compromisos \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* haya ligado su \w alma|strong="H5315"\w* tendrán validez. Yahvé \w la|strong="H5921"\w* perdonará, \w porque|strong="H5921"\w* su padre \w se|strong="H5921"\w* \w lo|strong="H5921"\w* ha prohibido.   
\p
\v 6 “\w Si|strong="H3588"\w* \w se|strong="H5921"\w* casa \w mientras|strong="H3588"\w* recaen \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* sus \w votos|strong="H5088"\w*, \w o|strong="H3068"\w* \w la|strong="H5921"\w* promesa irreflexiva \w de|strong="H5921"\w* sus labios \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H3588"\w* \w ha|strong="H3808"\w* ligado \w su|strong="H3588"\w* \w alma|strong="H5315"\w*,  
\v 7 \w y|strong="H5921"\w* su marido \w lo|strong="H5921"\w* oye, \w y|strong="H5921"\w* calla \w el|strong="H5921"\w* día \w que|strong="H5921"\w* \w lo|strong="H5921"\w* oye, entonces sus \w votos|strong="H5088"\w* \w serán|strong="H1961"\w* válidos, \w y|strong="H5921"\w* sus compromisos \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* ha ligado su \w alma|strong="H5315"\w* \w serán|strong="H1961"\w* firmes.  
\v 8 Pero \w si|strong="H5921"\w* su marido \w se|strong="H5921"\w* \w lo|strong="H5921"\w* prohíbe \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w que|strong="H5921"\w* \w lo|strong="H5921"\w* \w oye|strong="H8085"\w*, \w entonces|strong="H3117"\w* anulará \w el|strong="H5921"\w* \w voto|strong="H5088"\w* \w que|strong="H5921"\w* recae \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* promesa irreflexiva \w de|strong="H5921"\w* sus labios, \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H5921"\w* ha ligado su \w alma|strong="H5315"\w*. Yahvé \w la|strong="H5921"\w* perdonará.   
\p
\v 9 “Pero \w el|strong="H5921"\w* \w voto|strong="H5088"\w* \w de|strong="H5921"\w* una viuda \w o|strong="H3068"\w* \w de|strong="H5921"\w* una divorciada, todo aquello \w con|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* haya ligado su \w alma|strong="H5315"\w*, será válido \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*.   
\p
\v 10 «\w Si|strong="H5921"\w* una mujer \w hizo|strong="H5088"\w* un \w voto|strong="H5088"\w* \w en|strong="H5921"\w* casa \w de|strong="H5921"\w* su marido \w o|strong="H3068"\w* ligó su \w alma|strong="H5315"\w* \w con|strong="H5921"\w* un juramento,  
\v 11 \w y|strong="H5921"\w* su marido \w lo|strong="H5921"\w* oyó, calló ante \w ella|strong="H5921"\w* \w y|strong="H5921"\w* \w no|strong="H5921"\w* \w se|strong="H5921"\w* \w lo|strong="H5921"\w* prohibió, entonces todos sus \w votos|strong="H5087"\w* serán válidos, \w y|strong="H5921"\w* todo compromiso \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* ligó su \w alma|strong="H5315"\w* será firme.  
\v 12 Pero \w si|strong="H3808"\w* su marido \w los|strong="H5921"\w* anuló \w por|strong="H5921"\w* completo \w el|strong="H5921"\w* día \w que|strong="H3808"\w* \w los|strong="H5921"\w* \w oyó|strong="H8085"\w*, entonces \w nada|strong="H3808"\w* \w de|strong="H5921"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* haya salido \w de|strong="H5921"\w* sus labios \w en|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w a|strong="H3068"\w* sus \w votos|strong="H5088"\w*, \w o|strong="H3068"\w* \w en|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w al|strong="H5921"\w* compromiso \w de|strong="H5921"\w* su \w alma|strong="H5315"\w*, \w será|strong="H3808"\w* válido. Su marido \w los|strong="H5921"\w* \w ha|strong="H3808"\w* anulado, \w y|strong="H5921"\w* Yahvé \w la|strong="H5921"\w* perdonará.  
\v 13 \w Todo|strong="H3605"\w* \w voto|strong="H5088"\w* y \w todo|strong="H3605"\w* juramento \w que|strong="H3808"\w* obligue \w a|strong="H3068"\w* afligir \w el|strong="H3605"\w* \w alma|strong="H5315"\w*, su marido puede confirmarlo \w o|strong="H3068"\w* su marido puede anularlo.  
\v 14 Pero \w si|strong="H5315"\w* su marido calla de un día para otro, entonces \w él|strong="H3605"\w* \w confirma|strong="H6965"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w votos|strong="H5088"\w* \w o|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* compromisos \w que|strong="H3605"\w* recaen sobre \w ella|strong="H3605"\w*. \w Los|strong="H3605"\w* \w confirma|strong="H6965"\w*, porque calló \w el|strong="H3605"\w* día \w que|strong="H3605"\w* \w los|strong="H3605"\w* oyó.  
\v 15 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w los|strong="H5921"\w* anula \w después|strong="H5921"\w* \w de|strong="H5921"\w* haberlos \w oído|strong="H8085"\w*, \w entonces|strong="H3117"\w* \w él|strong="H5921"\w* cargará \w con|strong="H5921"\w* \w la|strong="H5921"\w* iniquidad \w de|strong="H5921"\w* \w ella|strong="H5921"\w*».   
\p
\v 16 Estos son los estatutos que Yahvé ordenó \w a|strong="H3068"\w* Moisés entre un hombre y su mujer, y entre un padre y su hija joven que aún vive en la casa de su padre.   
\c 31
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 «Toma \w venganza|strong="H5360"\w* por \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w contra|strong="H3478"\w* \w los|strong="H1121"\w* madianitas. Después serás reunido con tu \w pueblo|strong="H5971"\w*».   
\p
\v 3 \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w diciendo|strong="H1696"\w*: «Armad \w a|strong="H3068"\w* algunos \w de|strong="H5921"\w* vosotros \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H6635"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* vayan \w contra|strong="H5921"\w* \w Madián|strong="H4080"\w* \w y|strong="H5921"\w* ejecuten \w la|strong="H5921"\w* \w venganza|strong="H5360"\w* \w de|strong="H5921"\w* Yahvé \w contra|strong="H5921"\w* \w Madián|strong="H4080"\w*.  
\v 4 \w Enviaréis|strong="H7971"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w guerra|strong="H6635"\w* \w a|strong="H3068"\w* mil hombres de \w cada|strong="H3605"\w* \w tribu|strong="H4294"\w*, de \w todas|strong="H3605"\w* las \w tribus|strong="H4294"\w* de \w Israel|strong="H3478"\w*».  
\v 5 Así fueron reclutados de entre los millares de \w Israel|strong="H3478"\w*, mil de cada \w tribu|strong="H4294"\w*: \w doce|strong="H8147"\w* mil \w hombres|strong="H8147"\w* \w armados|strong="H2502"\w* para la \w guerra|strong="H6635"\w*.  
\v 6 \w Moisés|strong="H4872"\w* \w los|strong="H1121"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* la \w guerra|strong="H6635"\w*, mil \w de|strong="H1121"\w* cada \w tribu|strong="H4294"\w*, \w junto|strong="H3027"\w* con Finees, \w hijo|strong="H1121"\w* del \w sacerdote|strong="H3548"\w* Eleazar, quien llevaba consigo \w a|strong="H3068"\w* la \w guerra|strong="H6635"\w* \w los|strong="H1121"\w* utensilios \w santos|strong="H6944"\w* del \w santuario|strong="H6944"\w* y las \w trompetas|strong="H2689"\w* \w de|strong="H1121"\w* \w alarma|strong="H8643"\w*.  
\v 7 Lucharon \w contra|strong="H5921"\w* \w Madián|strong="H4080"\w*, tal \w como|strong="H5921"\w* Yahvé \w le|strong="H5921"\w* había \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w y|strong="H5921"\w* \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w varones|strong="H2145"\w*.  
\v 8 \w Junto|strong="H5921"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* resto \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w muertos|strong="H2491"\w*, \w mataron|strong="H2026"\w* también \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*: Evi, Requem, Zur, \w Hur|strong="H2354"\w* \w y|strong="H5921"\w* Reba, \w los|strong="H1121"\w* \w cinco|strong="H2568"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*. También \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w Balaam|strong="H1109"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Beor.  
\v 9 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* tomaron cautivas \w a|strong="H3068"\w* las mujeres \w de|strong="H1121"\w* \w Madián|strong="H4080"\w* y \w a|strong="H3068"\w* sus \w niños|strong="H2945"\w*, y tomaron como botín \w todo|strong="H3605"\w* su \w ganado|strong="H4735"\w*, \w todos|strong="H3605"\w* sus rebaños y \w todos|strong="H3605"\w* sus bienes.  
\v 10 Quemaron \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* en las \w que|strong="H3605"\w* habitaban y \w todos|strong="H3605"\w* sus \w campamentos|strong="H2918"\w*.  
\v 11 \w Tomaron|strong="H3947"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* botín y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w despojo|strong="H7998"\w*, tanto de personas como de animales.  
\v 12 Llevaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w cautivos|strong="H7628"\w*, \w la|strong="H5921"\w* \w presa|strong="H7998"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* botín ante \w Moisés|strong="H4872"\w*, ante \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Eleazar \w y|strong="H5921"\w* ante \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w al|strong="H5921"\w* \w campamento|strong="H4264"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* llanuras \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*, frente \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*.  
\v 13 \w Moisés|strong="H4872"\w*, \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* Eleazar y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* jefes de \w la|strong="H3605"\w* congregación \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* recibirlos \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w*.  
\v 14 \w Moisés|strong="H4872"\w* \w se|strong="H5921"\w* enojó \w con|strong="H5921"\w* \w los|strong="H5921"\w* oficiales \w del|strong="H5921"\w* \w ejército|strong="H2428"\w*, \w los|strong="H5921"\w* \w capitanes|strong="H8269"\w* \w de|strong="H5921"\w* millares \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w capitanes|strong="H8269"\w* \w de|strong="H5921"\w* centenas, \w que|strong="H5921"\w* regresaban \w de|strong="H5921"\w* \w la|strong="H5921"\w* campaña militar.  
\v 15 \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* les dijo: “¿Habéis dejado con \w vida|strong="H2421"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las mujeres?  
\v 16 He \w aquí|strong="H2005"\w* \w que|strong="H5921"\w* \w estas|strong="H2007"\w*, \w por|strong="H5921"\w* \w consejo|strong="H1697"\w* \w de|strong="H5921"\w* \w Balaam|strong="H1109"\w*, \w fueron|strong="H1961"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w que|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* cometieran \w transgresión|strong="H4604"\w* \w contra|strong="H5921"\w* Yahvé \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w asunto|strong="H1697"\w* \w de|strong="H5921"\w* Peor, \w por|strong="H5921"\w* \w lo|strong="H1697"\w* \w que|strong="H5921"\w* \w vino|strong="H1961"\w* \w la|strong="H5921"\w* \w plaga|strong="H4046"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* Yahvé.  
\v 17 \w Matad|strong="H2026"\w*, \w pues|strong="H6258"\w*, \w ahora|strong="H6258"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w varón|strong="H2145"\w* entre \w los|strong="H3605"\w* \w niños|strong="H2945"\w*, y \w matad|strong="H2026"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* mujer \w que|strong="H6258"\w* haya \w conocido|strong="H3045"\w* \w varón|strong="H2145"\w* \w carnalmente|strong="H4904"\w*.  
\v 18 Pero \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las niñas \w que|strong="H3808"\w* \w no|strong="H3808"\w* hayan \w conocido|strong="H3045"\w* \w varón|strong="H2145"\w* \w carnalmente|strong="H4904"\w*, dejadlas \w con|strong="H4904"\w* \w vida|strong="H2421"\w* para vosotros.   
\p
\v 19 «Acampad \w fuera|strong="H2351"\w* del \w campamento|strong="H4264"\w* durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*. \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3117"\w* haya matado \w a|strong="H3068"\w* \w alguna|strong="H3605"\w* \w persona|strong="H5315"\w*, y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3117"\w* haya tocado \w a|strong="H3068"\w* algún \w muerto|strong="H2491"\w*, purificaos vosotros y vuestros \w cautivos|strong="H7628"\w* al tercer \w día|strong="H3117"\w* y al \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w*.  
\v 20 Purificaréis también \w todo|strong="H3605"\w* vestido, \w todo|strong="H3605"\w* artículo de \w piel|strong="H5785"\w*, \w toda|strong="H3605"\w* \w obra|strong="H4639"\w* de pelo de \w cabra|strong="H5795"\w* y \w todo|strong="H3605"\w* utensilio de \w madera|strong="H6086"\w*».   
\p
\v 21 El \w sacerdote|strong="H3548"\w* Eleazar dijo \w a|strong="H3068"\w* los hombres de \w guerra|strong="H4421"\w* que habían ido \w a|strong="H3068"\w* \w la|strong="H2063"\w* \w batalla|strong="H4421"\w*: «\w Este|strong="H2063"\w* \w es|strong="H2063"\w* el \w estatuto|strong="H2708"\w* de \w la|strong="H2063"\w* \w ley|strong="H8451"\w* que Yahvé ha \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 22 El \w oro|strong="H2091"\w*, la \w plata|strong="H3701"\w*, el bronce, el \w hierro|strong="H1270"\w*, el estaño y el plomo,  
\v 23 \w es|strong="H1697"\w* decir, \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* resiste \w el|strong="H3605"\w* fuego, \w lo|strong="H1697"\w* haréis \w pasar|strong="H5674"\w* \w por|strong="H1697"\w* \w el|strong="H3605"\w* fuego y quedará \w limpio|strong="H2891"\w*; \w sin|strong="H3808"\w* embargo, también \w será|strong="H3808"\w* purificado con \w el|strong="H3605"\w* \w agua|strong="H4325"\w* \w de|strong="H1697"\w* purificación. \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* resista \w el|strong="H3605"\w* fuego, \w lo|strong="H1697"\w* haréis \w pasar|strong="H5674"\w* \w por|strong="H1697"\w* \w el|strong="H3605"\w* \w agua|strong="H4325"\w*.  
\v 24 \w El|strong="H4264"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* lavaréis vuestros vestidos y quedaréis limpios. Después podréis entrar en \w el|strong="H4264"\w* \w campamento|strong="H4264"\w*».   
\p
\v 25 Yahvé habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, diciendo:  
\v 26 «Haz la cuenta del botín capturado, tanto de personas como de animales, tú, el \w sacerdote|strong="H3548"\w* Eleazar y los \w jefes|strong="H7218"\w* de las casas paternas de la congregación;  
\v 27 y divide \w el|strong="H3605"\w* botín \w en|strong="H3318"\w* dos partes: \w la|strong="H3605"\w* mitad para \w los|strong="H3605"\w* hombres diestros \w en|strong="H3318"\w* \w la|strong="H3605"\w* \w guerra|strong="H4421"\w* \w que|strong="H5712"\w* \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w batalla|strong="H4421"\w*, y \w la|strong="H3605"\w* otra mitad para \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación.  
\v 28 Recauda un tributo \w para|strong="H4480"\w* Yahvé \w de|strong="H4480"\w* los hombres \w de|strong="H4480"\w* \w guerra|strong="H4421"\w* \w que|strong="H4480"\w* \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* la \w batalla|strong="H4421"\w*: uno \w de|strong="H4480"\w* cada \w quinientos|strong="H2568"\w*, tanto \w de|strong="H4480"\w* las \w personas|strong="H5315"\w* como \w de|strong="H4480"\w* las \w vacas|strong="H1241"\w*, \w de|strong="H4480"\w* los \w asnos|strong="H2543"\w* \w y|strong="H1241"\w* \w de|strong="H4480"\w* las \w ovejas|strong="H6629"\w*.  
\v 29 \w Tómalo|strong="H3947"\w* \w de|strong="H5414"\w* la mitad que les corresponde \w a|strong="H3068"\w* ellos y dáselo al \w sacerdote|strong="H3548"\w* Eleazar, como \w ofrenda|strong="H8641"\w* \w elevada|strong="H8641"\w* \w a|strong="H3068"\w* Yahvé.  
\v 30 \w De|strong="H4480"\w* \w la|strong="H8104"\w* mitad \w que|strong="H4480"\w* corresponde \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w tomarás|strong="H3947"\w* uno \w de|strong="H4480"\w* \w cada|strong="H3605"\w* \w cincuenta|strong="H2572"\w*, tanto \w de|strong="H4480"\w* las personas como \w de|strong="H4480"\w* las \w vacas|strong="H1241"\w*, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w asnos|strong="H2543"\w* \w y|strong="H1241"\w* \w de|strong="H4480"\w* las \w ovejas|strong="H6629"\w*, \w de|strong="H4480"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ganado|strong="H6629"\w*, \w y|strong="H1241"\w* \w se|strong="H4480"\w* \w los|strong="H1121"\w* \w darás|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, \w que|strong="H4480"\w* \w tienen|strong="H8104"\w* \w a|strong="H3068"\w* su cargo \w el|strong="H3605"\w* cuidado \w del|strong="H4480"\w* \w tabernáculo|strong="H4908"\w* \w de|strong="H4480"\w* Yahvé».   
\p
\v 31 \w Moisés|strong="H4872"\w* y \w el|strong="H6213"\w* \w sacerdote|strong="H3548"\w* Eleazar \w hicieron|strong="H6213"\w* tal como Yahvé le \w había|strong="H6213"\w* \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 32 El botín restante \w de|strong="H2568"\w* la presa \w que|strong="H5971"\w* tomaron \w los|strong="H1961"\w* hombres \w de|strong="H2568"\w* \w guerra|strong="H6635"\w*, \w fue|strong="H1961"\w* \w de|strong="H2568"\w* \w seiscientas|strong="H8337"\w* \w setenta|strong="H7657"\w* y \w cinco|strong="H2568"\w* \w mil|strong="H3967"\w* \w ovejas|strong="H6629"\w*,  
\v 33 \w setenta|strong="H7657"\w* \w y|strong="H1241"\w* \w dos|strong="H8147"\w* mil \w vacas|strong="H1241"\w*,  
\v 34 \w sesenta|strong="H8346"\w* y un mil \w asnos|strong="H2543"\w*,  
\v 35 y \w treinta|strong="H7970"\w* y \w dos|strong="H8147"\w* mil \w personas|strong="H5315"\w* \w en|strong="H4480"\w* total, mujeres \w que|strong="H4480"\w* \w no|strong="H3808"\w* habían \w conocido|strong="H3045"\w* \w varón|strong="H2145"\w* \w carnalmente|strong="H4904"\w*.  
\v 36 La mitad, \w que|strong="H1961"\w* \w era|strong="H1961"\w* la porción \w de|strong="H2568"\w* \w los|strong="H1961"\w* \w que|strong="H1961"\w* \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* la \w guerra|strong="H6635"\w*, \w fue|strong="H1961"\w* \w de|strong="H2568"\w* \w trescientas|strong="H7969"\w* \w treinta|strong="H7970"\w* y \w siete|strong="H7651"\w* \w mil|strong="H3967"\w* \w quinientas|strong="H2568"\w* \w ovejas|strong="H6629"\w*;  
\v 37 y el tributo \w para|strong="H4480"\w* Yahvé \w de|strong="H4480"\w* las \w ovejas|strong="H6629"\w* \w fue|strong="H1961"\w* \w de|strong="H4480"\w* \w seiscientas|strong="H8337"\w* \w setenta|strong="H7657"\w* y \w cinco|strong="H2568"\w*.  
\v 38 Las \w vacas|strong="H1241"\w* fueron \w treinta|strong="H7970"\w* \w y|strong="H1241"\w* \w seis|strong="H8337"\w* mil, de las cuales el tributo para Yahvé fue de \w setenta|strong="H7657"\w* \w y|strong="H1241"\w* \w dos|strong="H8147"\w*.  
\v 39 Los \w asnos|strong="H2543"\w* fueron \w treinta|strong="H7970"\w* \w mil|strong="H3967"\w* \w quinientos|strong="H2568"\w*, \w de|strong="H2568"\w* los cuales el tributo para Yahvé fue \w de|strong="H2568"\w* \w sesenta|strong="H8346"\w* y uno.  
\v 40 Las \w personas|strong="H5315"\w* fueron \w dieciséis|strong="H8337"\w* mil, de las cuales el tributo para Yahvé fue de \w treinta|strong="H7970"\w* y \w dos|strong="H8147"\w* \w personas|strong="H5315"\w*.  
\v 41 \w Moisés|strong="H4872"\w* \w entregó|strong="H5414"\w* el tributo, que era la \w ofrenda|strong="H8641"\w* \w elevada|strong="H8641"\w* \w para|strong="H5414"\w* Yahvé, al \w sacerdote|strong="H3548"\w* Eleazar, tal como Yahvé se lo había \w ordenado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.  
\v 42 \w De|strong="H4480"\w* la mitad correspondiente \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w que|strong="H4480"\w* \w Moisés|strong="H4872"\w* separó \w de|strong="H4480"\w* la \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w que|strong="H4480"\w* combatieron  
\v 43 (la mitad \w que|strong="H4480"\w* correspondió \w a|strong="H3068"\w* la congregación \w fue|strong="H1961"\w* \w de|strong="H4480"\w* \w trescientas|strong="H7969"\w* \w treinta|strong="H7970"\w* y \w siete|strong="H7651"\w* \w mil|strong="H3967"\w* \w quinientas|strong="H2568"\w* \w ovejas|strong="H6629"\w*,  
\v 44 \w treinta|strong="H7970"\w* \w y|strong="H1241"\w* \w seis|strong="H8337"\w* mil \w vacas|strong="H1241"\w*,  
\v 45 \w treinta|strong="H7970"\w* \w mil|strong="H3967"\w* \w quinientos|strong="H2568"\w* \w asnos|strong="H2543"\w*,  
\v 46 y \w dieciséis|strong="H8337"\w* mil \w personas|strong="H5315"\w*),  
\v 47 \w de|strong="H4480"\w* esta mitad \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w Moisés|strong="H4872"\w* \w tomó|strong="H3947"\w* uno \w de|strong="H4480"\w* cada \w cincuenta|strong="H2572"\w*, tanto \w de|strong="H4480"\w* personas como \w de|strong="H4480"\w* \w animales|strong="H1121"\w*, y \w se|strong="H4480"\w* \w los|strong="H1121"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w que|strong="H4480"\w* \w tenían|strong="H8104"\w* \w a|strong="H3068"\w* su cargo \w el|strong="H1121"\w* cuidado \w del|strong="H4480"\w* \w tabernáculo|strong="H4908"\w* \w de|strong="H4480"\w* Yahvé, tal como Yahvé le había \w ordenado|strong="H6680"\w*.   
\p
\v 48 Entonces se acercaron \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* los oficiales que estaban al mando \w de|strong="H8269"\w* los millares del \w ejército|strong="H6635"\w*, es decir, los \w capitanes|strong="H8269"\w* \w de|strong="H8269"\w* millares y los \w capitanes|strong="H8269"\w* \w de|strong="H8269"\w* centenas,  
\v 49 y le dijeron \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: «Tus \w siervos|strong="H5650"\w* han hecho la \w cuenta|strong="H6485"\w* \w de|strong="H4480"\w* los hombres \w de|strong="H4480"\w* \w guerra|strong="H4421"\w* \w que|strong="H4480"\w* están bajo nuestro mando, y \w no|strong="H3808"\w* falta \w ni|strong="H3808"\w* uno solo \w de|strong="H4480"\w* nosotros.  
\v 50 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, hemos traído \w como|strong="H5921"\w* \w ofrenda|strong="H7133"\w* \w a|strong="H3068"\w* Yahvé \w lo|strong="H5921"\w* \w que|strong="H5921"\w* cada uno \w halló|strong="H4672"\w* \w de|strong="H5921"\w* objetos \w de|strong="H5921"\w* \w oro|strong="H2091"\w*: \w brazaletes|strong="H6781"\w*, pulseras, \w anillos|strong="H2885"\w* \w de|strong="H5921"\w* sello, pendientes \w y|strong="H5921"\w* collares, \w para|strong="H5921"\w* hacer \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* nuestras \w almas|strong="H5315"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé».   
\p
\v 51 \w Moisés|strong="H4872"\w* y \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* Eleazar \w recibieron|strong="H3947"\w* de \w ellos|strong="H3605"\w* \w el|strong="H3605"\w* \w oro|strong="H2091"\w*, en \w toda|strong="H3605"\w* clase de joyas labradas.  
\v 52 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w oro|strong="H2091"\w* \w de|strong="H8269"\w* \w la|strong="H3605"\w* \w ofrenda|strong="H8641"\w* \w elevada|strong="H8641"\w* \w que|strong="H1961"\w* \w ofrecieron|strong="H7311"\w* \w a|strong="H3068"\w* Yahvé \w los|strong="H3605"\w* \w capitanes|strong="H8269"\w* \w de|strong="H8269"\w* millares y \w los|strong="H3605"\w* \w capitanes|strong="H8269"\w* \w de|strong="H8269"\w* centenas \w fue|strong="H1961"\w* \w de|strong="H8269"\w* \w dieciséis|strong="H8337"\w* \w mil|strong="H3967"\w* \w setecientos|strong="H7651"\w* \w cincuenta|strong="H2572"\w* \w siclos|strong="H8255"\w*. \f + \fr 31:52 \ft Un siclo equivale a unos 10 gramos o a unas 0,35 onzas, por lo que 16.750 siclos equivalen a unos 167,5 kilogramos.\f*  
\v 53 (Pues los hombres de \w guerra|strong="H6635"\w* habían tomado botín, cada uno para sí mismo).  
\v 54 \w Moisés|strong="H4872"\w* y \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Eleazar \w tomaron|strong="H3947"\w* \w el|strong="H1121"\w* \w oro|strong="H2091"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w capitanes|strong="H8269"\w* \w de|strong="H6440"\w* millares y \w de|strong="H6440"\w* centenas, y lo \w llevaron|strong="H3947"\w* \w a|strong="H3068"\w* la Tienda del Encuentro como un recordatorio \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.   
\c 32
\p
\v 1 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* \w tenían|strong="H1961"\w* una inmensa cantidad \w de|strong="H1121"\w* \w ganado|strong="H4735"\w*. \w Vieron|strong="H7200"\w* \w que|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Jazer|strong="H3270"\w* y la tierra \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w* \w eran|strong="H1961"\w* un \w lugar|strong="H4725"\w* ideal \w para|strong="H1961"\w* \w el|strong="H1121"\w* \w ganado|strong="H4735"\w*.  
\v 2 Entonces \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* vinieron y hablaron \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, al \w sacerdote|strong="H3548"\w* Eleazar y \w a|strong="H3068"\w* \w los|strong="H1121"\w* jefes \w de|strong="H1121"\w* la congregación, diciendo:  
\v 3 «Atarot, \w Dibón|strong="H1769"\w*, \w Jazer|strong="H3270"\w*, Nimra, \w Hesbón|strong="H2809"\w*, Eleale, Sebam, \w Nebo|strong="H5015"\w* y Beón,  
\v 4 \w la|strong="H1931"\w* tierra \w que|strong="H1931"\w* Yahvé conquistó \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* congregación \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w es|strong="H1931"\w* tierra buena para \w el|strong="H1931"\w* \w ganado|strong="H4735"\w*; y vuestros \w siervos|strong="H5650"\w* tienen \w ganado|strong="H4735"\w*».  
\v 5 \w Y|strong="H3068"\w* añadieron: «Si hemos \w hallado|strong="H4672"\w* \w gracia|strong="H2580"\w* \w a|strong="H3068"\w* tus \w ojos|strong="H5869"\w*, que se \w dé|strong="H5414"\w* \w esta|strong="H2063"\w* tierra \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w* como posesión. No nos hagas cruzar \w el|strong="H5674"\w* \w Jordán|strong="H3383"\w*».   
\p
\v 6 \w Moisés|strong="H4872"\w* respondió \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*: “¿Acaso irán vuestros hermanos \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w* mientras vosotros os quedáis \w sentados|strong="H3427"\w* \w aquí|strong="H6311"\w*?  
\v 7 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* desanimáis \w el|strong="H1121"\w* \w corazón|strong="H3820"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w para|strong="H5414"\w* \w que|strong="H4100"\w* \w no|strong="H4100"\w* crucen \w a|strong="H3068"\w* la tierra \w que|strong="H4100"\w* Yahvé les ha \w dado|strong="H5414"\w*?  
\v 8 \w Así|strong="H3541"\w* \w hicieron|strong="H6213"\w* vuestros padres cuando los \w envié|strong="H7971"\w* desde Cades Barnea \w a|strong="H3068"\w* explorar la tierra.  
\v 9 \w Pues|strong="H7200"\w* \w cuando|strong="H5704"\w* \w subieron|strong="H5927"\w* \w hasta|strong="H5704"\w* \w el|strong="H1121"\w* valle \w de|strong="H5704"\w* Escol \w y|strong="H5704"\w* \w vieron|strong="H7200"\w* la tierra, desanimaron \w el|strong="H1121"\w* \w corazón|strong="H3820"\w* \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* \w para|strong="H5704"\w* \w que|strong="H5704"\w* \w no|strong="H1115"\w* entraran \w en|strong="H5704"\w* la tierra \w que|strong="H5704"\w* Yahvé les había \w dado|strong="H5414"\w*.  
\v 10 \w Y|strong="H3068"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* encendió \w la|strong="H1931"\w* ira de Yahvé, y \w juró|strong="H7650"\w* diciendo:  
\v 11 ‘\w Ciertamente|strong="H3588"\w* \w ninguno|strong="H3808"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w que|strong="H3588"\w* \w subieron|strong="H5927"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w de|strong="H3588"\w* \w veinte|strong="H6242"\w* \w años|strong="H8141"\w* \w en|strong="H3588"\w* adelante, \w verá|strong="H7200"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* \w juré|strong="H7650"\w* dar \w a|strong="H3068"\w* Abraham, \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*; \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* siguieron fielmente,  
\v 12 \w a|strong="H3068"\w* excepción \w de|strong="H3588"\w* \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Jefone \w el|strong="H3588"\w* \w cenezeo|strong="H7074"\w*, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Nun|strong="H5126"\w*, \w porque|strong="H3588"\w* ellos \w sí|strong="H3588"\w* siguieron fielmente \w a|strong="H3068"\w* Yahvé’.  
\v 13 \w La|strong="H3605"\w* ira \w de|strong="H5704"\w* Yahvé se encendió \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5704"\w* \w los|strong="H3605"\w* \w hizo|strong="H6213"\w* vagar \w por|strong="H5704"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w* durante cuarenta \w años|strong="H8141"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* se consumió \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w generación|strong="H1755"\w* \w que|strong="H5704"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5704"\w* Yahvé.   
\p
\v 14 «\w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w*, vosotros \w os|strong="H5921"\w* habéis levantado \w en|strong="H5921"\w* \w lugar|strong="H8478"\w* \w de|strong="H5921"\w* vuestros padres, una \w prole|strong="H8635"\w* \w de|strong="H5921"\w* hombres \w pecadores|strong="H2400"\w*, \w para|strong="H5921"\w* aumentar \w aún|strong="H5750"\w* \w más|strong="H5750"\w* \w la|strong="H5921"\w* ardiente \w ira|strong="H2740"\w* \w de|strong="H5921"\w* Yahvé \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 15 \w Porque|strong="H3588"\w* \w si|strong="H3588"\w* os apartáis \w de|strong="H3588"\w* seguirle, \w él|strong="H3588"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* dejarlos \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*, \w y|strong="H3588"\w* seréis \w la|strong="H3605"\w* causa \w de|strong="H3588"\w* \w la|strong="H3605"\w* destrucción \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*».   
\p
\v 16 Ellos se acercaron \w a|strong="H3068"\w* Moisés y le dijeron: «\w Edificaremos|strong="H1129"\w* \w aquí|strong="H6311"\w* apriscos para nuestros \w ganados|strong="H4735"\w* y \w ciudades|strong="H5892"\w* para nuestros pequeños;  
\v 17 pero nosotros mismos nos armaremos \w y|strong="H5704"\w* marcharemos \w en|strong="H5704"\w* la vanguardia \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w los|strong="H3427"\w* hayamos llevado \w a|strong="H3068"\w* su \w lugar|strong="H4725"\w*. \w Mientras|strong="H5704"\w* tanto, nuestros pequeños vivirán \w en|strong="H5704"\w* las \w ciudades|strong="H5892"\w* fortificadas \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H6440"\w* la tierra.  
\v 18 \w No|strong="H3808"\w* \w volveremos|strong="H7725"\w* \w a|strong="H3068"\w* nuestras \w casas|strong="H1004"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* cada uno \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* haya tomado \w posesión|strong="H5159"\w* \w de|strong="H5704"\w* su \w herencia|strong="H5159"\w*.  
\v 19 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* buscaremos \w herencia|strong="H5159"\w* \w con|strong="H3588"\w* ellos al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w* \w ni|strong="H3808"\w* \w más|strong="H3588"\w* \w allá|strong="H1973"\w*, \w puesto|strong="H3588"\w* \w que|strong="H3588"\w* nuestra \w herencia|strong="H5159"\w* nos \w ha|strong="H3808"\w* tocado \w a|strong="H3068"\w* \w este|strong="H4217"\w* \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, hacia \w el|strong="H3588"\w* \w oriente|strong="H4217"\w*».   
\p
\v 20 \w Moisés|strong="H4872"\w* les dijo: “\w Si|strong="H6440"\w* \w hacéis|strong="H6213"\w* \w esto|strong="H2088"\w*, \w si|strong="H6440"\w* os armáis para ir \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé,  
\v 21 \w y|strong="H5704"\w* \w todos|strong="H3605"\w* vuestros hombres \w armados|strong="H2502"\w* cruzan \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w él|strong="H3605"\w* haya expulsado \w a|strong="H3068"\w* sus enemigos \w de|strong="H6440"\w* su \w presencia|strong="H6440"\w*,  
\v 22 \w y|strong="H5355"\w* \w la|strong="H2063"\w* tierra \w sea|strong="H1961"\w* sometida \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé; \w entonces|strong="H7725"\w*, \w después|strong="H1961"\w* \w podréis|strong="H1961"\w* regresar, \w y|strong="H5355"\w* quedaréis \w libres|strong="H5355"\w* \w de|strong="H6440"\w* obligación \w hacia|strong="H6440"\w* Yahvé \w y|strong="H5355"\w* \w hacia|strong="H6440"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* \w esta|strong="H2063"\w* tierra \w será|strong="H1961"\w* \w vuestra|strong="H2063"\w* posesión \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.   
\p
\v 23 «Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w hacéis|strong="H6213"\w* \w así|strong="H3651"\w*, he \w aquí|strong="H2009"\w* habréis \w pecado|strong="H2403"\w* contra Yahvé; y \w sabed|strong="H3045"\w* \w que|strong="H3808"\w* vuestro \w pecado|strong="H2403"\w* os \w alcanzará|strong="H4672"\w*.  
\v 24 \w Edificad|strong="H1129"\w* \w ciudades|strong="H5892"\w* para vuestros pequeños y rediles para vuestras \w ovejas|strong="H6792"\w*, pero cumplid \w lo|strong="H6213"\w* \w que|strong="H6310"\w* ha \w salido|strong="H3318"\w* de vuestra \w boca|strong="H6310"\w*».   
\p
\v 25 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* hablaron \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y le dijeron: «Tus \w siervos|strong="H5650"\w* \w harán|strong="H6213"\w* tal como \w ordena|strong="H6680"\w* mi señor.  
\v 26 Nuestros pequeños, nuestras mujeres, nuestros rebaños y \w todo|strong="H3605"\w* nuestro \w ganado|strong="H4735"\w* \w se|strong="H1961"\w* quedarán \w allí|strong="H8033"\w* en las \w ciudades|strong="H5892"\w* de \w Galaad|strong="H1568"\w*;  
\v 27 pero tus \w siervos|strong="H5650"\w* cruzarán, \w cada|strong="H3605"\w* uno \w de|strong="H6440"\w* \w ellos|strong="H3605"\w* armado para \w la|strong="H3605"\w* \w guerra|strong="H4421"\w*, \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé para \w la|strong="H3605"\w* \w batalla|strong="H4421"\w*, tal como \w dice|strong="H1696"\w* mi \w señor|strong="H3068"\w*».   
\p
\v 28 Entonces \w Moisés|strong="H4872"\w* dio órdenes acerca \w de|strong="H1121"\w* ellos al \w sacerdote|strong="H3548"\w* Eleazar, \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las casas paternas \w de|strong="H1121"\w* las \w tribus|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.  
\v 29 \w Moisés|strong="H4872"\w* les dijo: «\w Si|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Gad|strong="H1410"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Rubén|strong="H7205"\w* cruzan con vosotros \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w*, \w cada|strong="H3605"\w* uno armado \w para|strong="H5414"\w* \w la|strong="H3605"\w* \w batalla|strong="H4421"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, y \w la|strong="H3605"\w* tierra es sometida \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros, les \w daréis|strong="H5414"\w* \w la|strong="H3605"\w* tierra \w de|strong="H6440"\w* \w Galaad|strong="H1568"\w* en posesión;  
\v 30 pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* cruzan \w armados|strong="H2502"\w* con vosotros, tendrán posesión \w entre|strong="H8432"\w* vosotros \w en|strong="H8432"\w* la tierra de \w Canaán|strong="H3667"\w*».   
\p
\v 31 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* \w respondieron|strong="H6030"\w* \w diciendo|strong="H1696"\w*: «\w Lo|strong="H6213"\w* \w que|strong="H1121"\w* Yahvé ha \w dicho|strong="H1696"\w* \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w*, \w eso|strong="H3651"\w* \w haremos|strong="H6213"\w*.  
\v 32 Cruzaremos \w armados|strong="H2502"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w a|strong="H3068"\w* la tierra \w de|strong="H6440"\w* \w Canaán|strong="H3667"\w*, pero la \w posesión|strong="H5159"\w* \w de|strong="H6440"\w* nuestra \w herencia|strong="H5159"\w* permanecerá con \w nosotros|strong="H5168"\w* \w a|strong="H3068"\w* este \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*».   
\p
\v 33 Así, \w Moisés|strong="H4872"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* y \w a|strong="H3068"\w* la media \w tribu|strong="H7626"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*, \w el|strong="H1121"\w* \w reino|strong="H4467"\w* \w de|strong="H1121"\w* \w Sehón|strong="H5511"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* amorreos, y \w el|strong="H1121"\w* \w reino|strong="H4467"\w* \w de|strong="H1121"\w* \w Og|strong="H5747"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Basán|strong="H1316"\w*: la tierra con sus \w ciudades|strong="H5892"\w* y sus territorios correspondientes, las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* la tierra circundante.  
\v 34 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* \w edificaron|strong="H1129"\w* \w Dibón|strong="H1769"\w*, Atarot, \w Aroer|strong="H6177"\w*,  
\v 35 Atarot Sofán, \w Jazer|strong="H3270"\w*, Jogbehá,  
\v 36 Bet Nimra y Bet Harán: \w ciudades|strong="H5892"\w* fortificadas y rediles para \w ovejas|strong="H6629"\w*.  
\v 37 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* \w edificaron|strong="H1129"\w* \w Hesbón|strong="H2809"\w*, Eleale, Quiriatáim,  
\v 38 \w Nebo|strong="H5015"\w* y Baal Meón (cuyos \w nombres|strong="H8034"\w* fueron cambiados), y Sibma. \w Y|strong="H3068"\w* dieron otros \w nombres|strong="H8034"\w* \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w* que reedificaron.  
\v 39 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w fueron|strong="H3212"\w* \w a|strong="H3068"\w* \w Galaad|strong="H1568"\w*, la \w tomaron|strong="H3920"\w* y expulsaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* amorreos \w que|strong="H1121"\w* estaban allí.  
\v 40 \w Moisés|strong="H4872"\w* \w dio|strong="H5414"\w* \w Galaad|strong="H1568"\w* \w a|strong="H3068"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, y este \w habitó|strong="H3427"\w* allí.  
\v 41 \w Y|strong="H3068"\w* \w Jair|strong="H2971"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w fue|strong="H1980"\w* y \w tomó|strong="H3920"\w* las aldeas \w de|strong="H1121"\w* ellos, y las \w llamó|strong="H7121"\w* Havot \w Jair|strong="H2971"\w*.  
\v 42 \w Noba|strong="H5025"\w* \w fue|strong="H1980"\w* y \w tomó|strong="H3920"\w* Kenat y sus \w aldeas|strong="H1323"\w*, y la \w llamó|strong="H7121"\w* \w Noba|strong="H5025"\w*, según su propio \w nombre|strong="H8034"\w*.   
\c 33
\p
\v 1 Estos son \w los|strong="H1121"\w* viajes \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, cuando \w salieron|strong="H3318"\w* \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w* \w por|strong="H3027"\w* sus escuadrones bajo \w el|strong="H1121"\w* mando \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w* y Aarón.  
\v 2 \w Moisés|strong="H4872"\w* \w escribió|strong="H3789"\w* \w los|strong="H5921"\w* puntos \w de|strong="H5921"\w* partida \w de|strong="H5921"\w* sus etapas \w por|strong="H5921"\w* \w mandato|strong="H6310"\w* \w de|strong="H5921"\w* Yahvé. Estos \w son|strong="H6310"\w* sus viajes \w según|strong="H5921"\w* sus puntos \w de|strong="H5921"\w* partida.  
