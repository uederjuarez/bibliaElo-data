\p
\v 22 \w Entonces|strong="H3588"\w* \w la|strong="H2063"\w* otra mujer \w dijo|strong="H1696"\w*: «\w No|strong="H3808"\w*; mi \w hijo|strong="H1121"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w vive|strong="H2416"\w*, \w y|strong="H3588"\w* tu \w hijo|strong="H1121"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w muerto|strong="H4191"\w*».  
\p \w Y|strong="H3068"\w* \w la|strong="H2063"\w* otra volvió \w a|strong="H3068"\w* decir: «\w No|strong="H3808"\w*; tu \w hijo|strong="H1121"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w muerto|strong="H4191"\w*, \w y|strong="H3588"\w* mi \w hijo|strong="H1121"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w vive|strong="H2416"\w*». \w Así|strong="H2063"\w* \w hablaban|strong="H1696"\w* \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w*.   
\p
\v 23 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w entonces|strong="H3588"\w* dijo: «\w Esta|strong="H2063"\w* dice: «Mi \w hijo|strong="H1121"\w* \w es|strong="H2088"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w vive|strong="H2416"\w*, \w y|strong="H3588"\w* tu \w hijo|strong="H1121"\w* \w es|strong="H2088"\w* \w el|strong="H3588"\w* \w muerto|strong="H4191"\w*»; \w y|strong="H3588"\w* \w la|strong="H3588"\w* otra dice: «\w No|strong="H3808"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* tu \w hijo|strong="H1121"\w* \w es|strong="H2088"\w* \w el|strong="H3588"\w* \w muerto|strong="H4191"\w*, \w y|strong="H3588"\w* mi \w hijo|strong="H1121"\w* \w es|strong="H2088"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w vive|strong="H2416"\w*»».   
\p
\v 24 \w Y|strong="H3068"\w* dijo el \w rey|strong="H4428"\w*: «\w Traedme|strong="H3947"\w* una \w espada|strong="H2719"\w*».  
\p \w Y|strong="H3068"\w* trajeron una \w espada|strong="H2719"\w* \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w*.   
\p
\v 25 En seguida el \w rey|strong="H4428"\w* dijo: «\w Partid|strong="H1504"\w* en \w dos|strong="H8147"\w* \w al|strong="H4428"\w* niño \w vivo|strong="H2416"\w*, y \w dad|strong="H5414"\w* la mitad \w a|strong="H3068"\w* la una, y la otra mitad \w a|strong="H3068"\w* la otra».   
\p
\v 26 \w Entonces|strong="H3588"\w* \w la|strong="H5921"\w* mujer \w de|strong="H5921"\w* quien \w era|strong="H1961"\w* \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w vivo|strong="H2416"\w* habló \w al|strong="H5921"\w* \w rey|strong="H4428"\w* (\w porque|strong="H3588"\w* sus entrañas \w se|strong="H1961"\w* conmovieron \w por|strong="H5921"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*), \w y|strong="H1571"\w* dijo: «¡Ah, señor \w mío|strong="H5921"\w*! \w Dad|strong="H5414"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w el|strong="H5921"\w* niño \w vivo|strong="H2416"\w*, \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w matéis|strong="H4191"\w*».  
\p \w Mas|strong="H3588"\w* \w la|strong="H5921"\w* otra dijo: «\w Ni|strong="H3808"\w* \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*; \w partidlo|strong="H1504"\w*».   
\p
\v 27 Entonces \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w respondió|strong="H6030"\w* y dijo: «\w Dad|strong="H5414"\w* \w a|strong="H3068"\w* \w aquella|strong="H1931"\w* \w el|strong="H1931"\w* \w hijo|strong="H3205"\w* \w vivo|strong="H2416"\w*, y \w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w matéis|strong="H4191"\w*; \w ella|strong="H1931"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* madre».   
\p
\v 28 \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w oyó|strong="H8085"\w* \w aquel|strong="H3605"\w* \w juicio|strong="H4941"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* dado \w el|strong="H3588"\w* \w rey|strong="H4428"\w*; \w y|strong="H3588"\w* \w temieron|strong="H3372"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, \w porque|strong="H3588"\w* \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* \w en|strong="H3588"\w* \w él|strong="H3588"\w* \w sabiduría|strong="H2451"\w* \w de|strong="H3588"\w* Dios \w para|strong="H3588"\w* juzgar.   
\c 4
\p
\v 1 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, \w pues|strong="H1961"\w*, \w fue|strong="H1961"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*.  
\v 2 \w Y|strong="H3068"\w* estos fueron \w los|strong="H1121"\w* \w príncipes|strong="H8269"\w* \w que|strong="H1121"\w* tuvo: \w Azarías|strong="H5838"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Sadoc|strong="H6659"\w*, \w sacerdote|strong="H3548"\w*;  
\v 3 Elihoref y Ahías, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Sisá, \w escribas|strong="H5608"\w*; Josafat \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahilud, \w canciller|strong="H2142"\w*;  
\v 4 \w Benaía|strong="H1141"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Joiada|strong="H3077"\w* estaba \w al|strong="H5921"\w* frente \w del|strong="H5921"\w* \w ejército|strong="H6635"\w*; \w Sadoc|strong="H6659"\w* \w y|strong="H5921"\w* Abiatar eran \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*;  
\v 5 \w Azarías|strong="H5838"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Natán \w estaba|strong="H5324"\w* \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w gobernadores|strong="H5324"\w*; \w Zabud|strong="H2071"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Natán \w era|strong="H1121"\w* ministro principal, \w amigo|strong="H7463"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*;  
\v 6 Ahisar \w estaba|strong="H1004"\w* \w al|strong="H5921"\w* frente \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*; \w y|strong="H5921"\w* Adoniram \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Abda \w estaba|strong="H1004"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w tributo|strong="H4522"\w* laboral.   
\p
\v 7 \w Tenía|strong="H1961"\w* \w Salomón|strong="H8010"\w* \w doce|strong="H8147"\w* \w oficiales|strong="H5324"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w los|strong="H5921"\w* cuales abastecían \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*. \w Cada|strong="H3605"\w* uno \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* suministraba provisiones un \w mes|strong="H2320"\w* \w al|strong="H5921"\w* \w año|strong="H8141"\w*.  
\v 8 \w Y|strong="H3068"\w* estos son sus \w nombres|strong="H8034"\w*: el hijo de Hur, en la región montañosa de Efraín;  
\v 9 el hijo de Deker, en Macaz, en Saalbim, en Bet-semes y en Elón-bet-hanán;  
\v 10 \w el|strong="H3605"\w* hijo de Hesed, en Arubot; suyos eran Soco y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra de Hefer;  
\v 11 \w el|strong="H3605"\w* hijo de Abinadab, en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* región de \w Dor|strong="H1756"\w*; \w este|strong="H1961"\w* \w tenía|strong="H1961"\w* por mujer \w a|strong="H3068"\w* Tafat, \w hija|strong="H1323"\w* de \w Salomón|strong="H8010"\w*;  
\v 12 Baana \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Ahilud, \w en|strong="H5704"\w* Taanac \w y|strong="H5704"\w* Meguido, \w y|strong="H5704"\w* \w en|strong="H5704"\w* \w toda|strong="H3605"\w* Bet-seán, \w que|strong="H5704"\w* está \w al|strong="H5704"\w* \w lado|strong="H5676"\w* \w de|strong="H8478"\w* Zaretán, \w abajo|strong="H8478"\w* \w de|strong="H8478"\w* \w Jezreel|strong="H3157"\w*, \w desde|strong="H5704"\w* Bet-seán \w hasta|strong="H5704"\w* Abel-mejolá, \w hasta|strong="H5704"\w* \w más|strong="H5704"\w* allá \w de|strong="H8478"\w* Jocmeam;  
\v 13 \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Geber, en Ramot \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*; suyas eran las aldeas \w de|strong="H1121"\w* \w Jair|strong="H2971"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, las cuales están en \w Galaad|strong="H1568"\w*; suya \w era|strong="H1121"\w* también la región \w de|strong="H1121"\w* Argob, \w que|strong="H1121"\w* está en \w Basán|strong="H1316"\w*: \w sesenta|strong="H8346"\w* \w grandes|strong="H1419"\w* \w ciudades|strong="H5892"\w* con \w muros|strong="H2346"\w* y \w cerrojos|strong="H1280"\w* \w de|strong="H1121"\w* bronce;  
\v 14 Ahinadab \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Iddo|strong="H5714"\w*, en \w Mahanaim|strong="H4266"\w*;  
\v 15 Ahimaas, en Neftalí; \w este|strong="H1931"\w* \w también|strong="H1571"\w* \w tomó|strong="H3947"\w* por mujer \w a|strong="H3068"\w* Basemat, \w hija|strong="H1323"\w* de \w Salomón|strong="H8010"\w*;  
\v 16 Baana \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Husai|strong="H2365"\w*, en Aser y en Alot;  
\v 17 Josafat \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Parúa, en Isacar;  
\v 18 Simei \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ela, en \w Benjamín|strong="H1144"\w*;  
\v 19 \w Geber|strong="H1398"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uri, en la tierra \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, la tierra \w de|strong="H1121"\w* \w Sehón|strong="H5511"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* amorreos, y \w de|strong="H1121"\w* \w Og|strong="H5747"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Basán|strong="H1316"\w*; este \w era|strong="H1121"\w* \w el|strong="H1121"\w* único oficial en aquella tierra.   
\p
\v 20 \w Judá|strong="H3063"\w* \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* eran tan \w numerosos|strong="H7227"\w* \w como|strong="H5921"\w* \w la|strong="H5921"\w* arena \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w mar|strong="H3220"\w* \w en|strong="H5921"\w* \w multitud|strong="H7230"\w*, \w y|strong="H5921"\w* comían, \w bebían|strong="H8354"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* alegraban.  
\v 21 \w Y|strong="H3068"\w* Salomón señoreaba sobre todos los reinos desde el Río hasta la tierra de los filisteos y hasta la frontera de Egipto; y traían presentes y sirvieron \w a|strong="H3068"\w* Salomón todos los días de su vida.  
\v 22 La provisión de Salomón para cada día era de treinta coros de flor de harina y sesenta coros de harina,  
\v 23 diez bueyes gordos, veinte bueyes de pasto y cien ovejas; sin contar los ciervos, gacelas, corzos y aves engordadas.  
\v 24 Porque él dominaba en toda la región de este lado del Río, desde Tifsa hasta Gaza, sobre todos los reyes de este lado del Río; y tuvo paz por todos lados en derredor suyo.  
\v 25 \w Y|strong="H3068"\w* Judá \w e|strong="H3068"\w* Israel vivieron seguros, cada uno debajo de su parra y debajo de su higuera, desde Dan hasta Beerseba, todos los días de Salomón.  
\v 26 Tenía además Salomón cuarenta mil caballerizas de caballos para sus carros, y doce mil jinetes.  
\v 27 \w Y|strong="H3068"\w* aquellos oficiales abastecían al rey Salomón y \w a|strong="H3068"\w* todos los que \w a|strong="H3068"\w* la mesa del rey Salomón venían, cada uno en su mes; hacían que no faltase nada.  
\v 28 Llevaban también la cebada y la paja para los caballos y para las bestias de carga al lugar donde estaba el rey, cada uno conforme al turno que le correspondía.  
\v 29 \w Y|strong="H3068"\w* dio Dios \w a|strong="H3068"\w* Salomón sabiduría y prudencia muy grandes, y anchura de corazón como la arena que está \w a|strong="H3068"\w* la orilla del mar.  
\v 30 Era la sabiduría de Salomón mayor que la de todos los orientales, y mayor que toda la sabiduría de los egipcios.  
\v 31 Aun fue más sabio que todos los hombres: más que Etán ezraíta, y que Hemán, Calcol y Darda, hijos de Mahol; y fue conocido entre todas las naciones de alrededor.  
\v 32 \w Y|strong="H3068"\w* compuso tres mil proverbios, y sus cantares fueron mil cinco.  
\v 33 También disertó sobre los árboles, desde el cedro del Líbano hasta el hisopo que nace en la pared. Asimismo disertó sobre los animales, sobre las aves, sobre los reptiles y sobre los peces.  
\v 34 \w Y|strong="H3068"\w* para oír la sabiduría de Salomón venían de todos los pueblos y de parte de todos los reyes de la tierra, donde se había oído de su sabiduría.   
\c 5
\p
\v 1 Hiram, rey \w de|strong="H4480"\w* Tiro, envió \w a|strong="H3068"\w* sus \w siervos|strong="H5647"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*, tras oír \w que|strong="H4480"\w* \w lo|strong="H5704"\w* \w habían|strong="H1961"\w* ungido \w por|strong="H4480"\w* rey \w en|strong="H4480"\w* lugar \w de|strong="H4480"\w* su padre; porque Hiram \w siempre|strong="H3605"\w* \w había|strong="H1961"\w* amado \w a|strong="H3068"\w* David.  
\v 2 \w Salomón|strong="H8010"\w* envió \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Hiram:  
\v 3 “Vos sabéis que mi padre David no pudo edificar casa al nombre de Yahvé su Dios por las guerras que le rodearon, hasta que Yahvé puso \w a|strong="H3068"\w* sus enemigos bajo las plantas de sus pies.  
\v 4 \w Pero|strong="H3588"\w* ahora Yahvé \w mi|strong="H1961"\w* Dios \w me|strong="H3588"\w* ha dado reposo \w por|strong="H3588"\w* \w todas|strong="H3605"\w* \w partes|strong="H5439"\w*; \w pues|strong="H3588"\w* \w no|strong="H3588"\w* \w hay|strong="H1961"\w* adversario \w ni|strong="H5704"\w* mal \w que|strong="H3588"\w* temer.  
\v 5 Yo, \w por|strong="H8478"\w* tanto, he determinado edificar casa \w al|strong="H5704"\w* nombre \w de|strong="H8478"\w* Yahvé mi Dios, \w conforme|strong="H5704"\w* \w a|strong="H3068"\w* \w lo|strong="H5704"\w* \w que|strong="H5704"\w* Yahvé habló \w a|strong="H3068"\w* mi padre David, diciendo: «Tu hijo, \w a|strong="H3068"\w* \w quien|strong="H3605"\w* yo \w pondré|strong="H3427"\w* \w en|strong="H5704"\w* tu trono \w en|strong="H5704"\w* tu \w lugar|strong="H8478"\w*, \w él|strong="H3605"\w* edificará casa \w a|strong="H3068"\w* mi nombre».  
\v 6 Mandad, \w pues|strong="H1961"\w*, ahora \w que|strong="H1961"\w* me corten cedros del Líbano; y mis siervos \w estarán|strong="H1961"\w* con \w los|strong="H1961"\w* vuestros, y yo os daré por vuestros siervos el salario \w que|strong="H1961"\w* vos dijereis; porque sabéis bien \w que|strong="H1961"\w* \w no|strong="H1961"\w* \w hay|strong="H1961"\w* entre \w nosotros|strong="H8147"\w* quien sepa labrar madera \w como|strong="H1961"\w* \w los|strong="H1961"\w* sidonios”.   
\p
\v 7 Cuando Hiram oyó las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w Salomón|strong="H8010"\w*, \w se|strong="H3808"\w* alegró en gran \w manera|strong="H1697"\w* y dijo: «Bendito sea hoy Yahvé, \w que|strong="H3808"\w* dio \w a|strong="H3068"\w* \w David|strong="H4428"\w* hijo sabio sobre este pueblo tan grande».  
\v 8 \w E|strong="H3068"\w* envió Hiram \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Salomón: «He oído lo \w que|strong="H1961"\w* me mandasteis \w a|strong="H3068"\w* decir; yo haré todo lo \w que|strong="H1961"\w* os plazca acerca de la madera de cedro y la madera de ciprés.  
\v 9 \w Mis|strong="H5414"\w* siervos \w las|strong="H5921"\w* llevarán \w desde|strong="H5921"\w* \w el|strong="H5921"\w* Líbano \w al|strong="H5921"\w* \w mar|strong="H3220"\w*, \w y|strong="H5921"\w* yo \w las|strong="H5921"\w* \w pondré|strong="H5414"\w* \w en|strong="H5921"\w* almadías \w para|strong="H5921"\w* llevarlas \w por|strong="H5921"\w* \w mar|strong="H3220"\w* \w hasta|strong="H5921"\w* \w el|strong="H5921"\w* lugar \w que|strong="H5921"\w* vos \w me|strong="H5921"\w* señaléis, \w y|strong="H5921"\w* allí \w las|strong="H5921"\w* \w haré|strong="H5414"\w* desatar \w y|strong="H5921"\w* vos \w las|strong="H5921"\w* recibiréis; \w y|strong="H5921"\w* vos cumpliréis \w mi|strong="H5921"\w* deseo dando \w de|strong="H5921"\w* comer \w a|strong="H3068"\w* \w mi|strong="H5921"\w* familia».   
\p
\v 10 Dio, pues, Hiram \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* madera \w de|strong="H1121"\w* cedro y madera \w de|strong="H1121"\w* ciprés, \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w que|strong="H1121"\w* quiso.  
\v 11 \w Y|strong="H3068"\w* Salomón daba \w a|strong="H3068"\w* Hiram veinte mil coros \w de|strong="H1121"\w* trigo \w para|strong="H1961"\w* \w el|strong="H3605"\w* sustento \w de|strong="H1121"\w* su familia, y veinte coros \w de|strong="H1121"\w* aceite puro; esto daba Salomón \w a|strong="H3068"\w* Hiram \w cada|strong="H3605"\w* año.  
\v 12 Yahvé, \w pues|strong="H1961"\w*, dio \w a|strong="H3068"\w* Salomón sabiduría, \w como|strong="H1961"\w* le \w había|strong="H1961"\w* prometido; y \w hubo|strong="H1961"\w* paz entre Hiram y Salomón, \w e|strong="H3068"\w* hicieron pacto entre ambos.   
\p
\v 13 \w El|strong="H5921"\w* rey Salomón decretó una leva \w en|strong="H5921"\w* todo Israel, \w y|strong="H5921"\w* \w la|strong="H5921"\w* leva fue \w de|strong="H4480"\w* treinta mil hombres.  
\v 14 \w Los|strong="H3605"\w* enviaba \w al|strong="H4428"\w* Líbano \w por|strong="H4428"\w* turnos \w de|strong="H5971"\w* diez mil \w cada|strong="H3605"\w* mes; \w estaban|strong="H5971"\w* un mes en \w el|strong="H3605"\w* Líbano y dos meses en sus casas; y Adoniram estaba encargado \w de|strong="H5971"\w* aquella leva.  
\v 15 \w Tenía|strong="H1961"\w* también \w Salomón|strong="H8010"\w* setenta mil \w que|strong="H3588"\w* \w llevaban|strong="H1961"\w* las cargas, \w y|strong="H3588"\w* ochenta mil canteros \w en|strong="H3588"\w* \w el|strong="H3588"\w* monte;  
\v 16 sin contar los principales oficiales de \w Salomón|strong="H8010"\w* que estaban sobre la obra, tres mil trescientos, los cuales tenían \w a|strong="H3068"\w* cargo el pueblo que hacía la obra.  
\v 17 \w Y|strong="H3068"\w* mandó \w el|strong="H3588"\w* rey \w que|strong="H3588"\w* trajesen piedras grandes, piedras costosas, \w para|strong="H5704"\w* \w los|strong="H3588"\w* cimientos \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w*, piedras \w de|strong="H3588"\w* cantería.  
\v 18 Los albañiles \w de|strong="H7451"\w* Salomón y los \w de|strong="H7451"\w* Hiram, y los gebalitas, labraron y prepararon la madera y la piedra \w para|strong="H6258"\w* edificar la casa.   
\c 6
\p
