\v 6 \w El|strong="H3588"\w* piso bajo tenía \w cinco|strong="H2568"\w* codos \w de|strong="H3588"\w* ancho, \w el|strong="H3588"\w* \w de|strong="H3588"\w* \w en|strong="H3588"\w* medio \w seis|strong="H8337"\w* codos \w de|strong="H3588"\w* ancho, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w tercero|strong="H7992"\w* \w siete|strong="H7651"\w* codos \w de|strong="H3588"\w* ancho; \w porque|strong="H3588"\w* \w por|strong="H3588"\w* \w fuera|strong="H2351"\w* \w había|strong="H3588"\w* hecho retranqueos \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w pared|strong="H7023"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w alrededor|strong="H5439"\w*, \w para|strong="H3588"\w* \w no|strong="H3588"\w* introducir las vigas \w en|strong="H3588"\w* las paredes \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w*.  
