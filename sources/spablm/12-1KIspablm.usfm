\v 10 \w Edificó|strong="H1129"\w* asimismo \w los|strong="H5921"\w* pisos laterales \w contra|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, \w de|strong="H5921"\w* \w cinco|strong="H2568"\w* codos \w de|strong="H5921"\w* \w altura|strong="H6967"\w* \w cada|strong="H3605"\w* uno, \w los|strong="H5921"\w* cuales estaban sujetos \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w con|strong="H5921"\w* \w madera|strong="H6086"\w* \w de|strong="H5921"\w* cedro.   
\p
\v 11 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*, diciendo:  
\v 12 «\w En|strong="H3212"\w* cuanto \w a|strong="H3068"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w* \w que|strong="H1697"\w* \w tú|strong="H6213"\w* \w edificas|strong="H1129"\w*, si \w anduvieres|strong="H3212"\w* \w en|strong="H3212"\w* mis \w estatutos|strong="H2708"\w* y pusieres \w por|strong="H1697"\w* \w obra|strong="H6213"\w* mis decretos, y \w guardares|strong="H8104"\w* \w todos|strong="H3605"\w* mis \w mandamientos|strong="H4687"\w* \w andando|strong="H3212"\w* \w en|strong="H3212"\w* \w ellos|strong="H2708"\w*, \w yo|strong="H6213"\w* cumpliré contigo mi \w palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w hablé|strong="H1696"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w tu|strong="H6213"\w* padre;  
\v 13 y \w habitaré|strong="H7931"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w no|strong="H3808"\w* \w dejaré|strong="H5800"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*».   
\p
\v 14 Así, pues, \w Salomón|strong="H8010"\w* \w edificó|strong="H1129"\w* la \w casa|strong="H1004"\w* y la terminó.  
\v 15 \w Cubrió|strong="H6823"\w* las paredes \w de|strong="H5704"\w* la \w casa|strong="H1004"\w* \w por|strong="H5704"\w* dentro \w con|strong="H5704"\w* tablas \w de|strong="H5704"\w* cedro; \w desde|strong="H5704"\w* el pavimento \w de|strong="H5704"\w* la \w casa|strong="H1004"\w* \w hasta|strong="H5704"\w* las paredes del techo, las entabló \w por|strong="H5704"\w* dentro \w con|strong="H5704"\w* \w madera|strong="H6086"\w*; \w y|strong="H5704"\w* \w cubrió|strong="H6823"\w* el suelo \w de|strong="H5704"\w* la \w casa|strong="H1004"\w* \w con|strong="H5704"\w* tablas \w de|strong="H5704"\w* ciprés.  
