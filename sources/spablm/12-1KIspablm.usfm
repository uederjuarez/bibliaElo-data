\p
\v 6 \w Cuando|strong="H4100"\w* \w Ahías|strong="H3379"\w* \w oyó|strong="H8085"\w* el estrépito de sus \w pies|strong="H7272"\w* al entrar \w por|strong="H2088"\w* la \w puerta|strong="H6607"\w*, dijo: “¡Entra, mujer de \w Jeroboam|strong="H3379"\w*! ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* te haces pasar \w por|strong="H2088"\w* otra? \w Pues|strong="H2088"\w* yo he \w sido|strong="H1961"\w* \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* ti con noticias aciagas.  
\v 7 \w Ve|strong="H3212"\w* \w y|strong="H5921"\w* \w di|strong="H5414"\w* \w a|strong="H3068"\w* \w Jeroboam|strong="H3379"\w*: «\w Así|strong="H3541"\w* \w ha|strong="H3541"\w* dicho Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: \w Por|strong="H5921"\w* \w cuanto|strong="H3282"\w* yo \w te|strong="H5921"\w* exalté \w de|strong="H5921"\w* \w entre|strong="H8432"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w puse|strong="H5414"\w* \w por|strong="H5921"\w* \w príncipe|strong="H5057"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*,  
