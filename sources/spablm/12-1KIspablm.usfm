\toc1 PRIMER LIBRO DE LOS REYES 
\toc2 1 REYES 
\mt2 Primer libro de los  
\mt1 Reyes  
\c 1
\p
\v 1 El \w rey|strong="H4428"\w* \w David|strong="H1732"\w* era ya \w viejo|strong="H2204"\w* y entrado en \w años|strong="H3117"\w*; y \w por|strong="H4428"\w* \w más|strong="H3808"\w* \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w cubrían|strong="H3680"\w* con ropas, \w no|strong="H3808"\w* \w podía|strong="H3808"\w* calentarse.  
\v 2 \w Por|strong="H6440"\w* lo tanto, sus \w siervos|strong="H5650"\w* le dijeron: «Búsquese una joven \w virgen|strong="H1330"\w* \w para|strong="H1961"\w* \w mi|strong="H1961"\w* señor el \w rey|strong="H4428"\w*, \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w esté|strong="H1961"\w* \w en|strong="H5975"\w* \w presencia|strong="H6440"\w* del \w rey|strong="H4428"\w* y lo abrigue, y duerma \w en|strong="H5975"\w* su \w seno|strong="H2436"\w*; así \w mi|strong="H1961"\w* señor el \w rey|strong="H4428"\w* entrará \w en|strong="H5975"\w* calor».  
\v 3 \w Buscaron|strong="H1245"\w*, pues, \w a|strong="H3068"\w* \w una|strong="H4672"\w* joven \w hermosa|strong="H3303"\w* \w por|strong="H4428"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* confines de \w Israel|strong="H3478"\w*, y \w hallaron|strong="H4672"\w* \w a|strong="H3068"\w* Abisag \w la|strong="H1366"\w* \w sunamita|strong="H7767"\w*, y \w la|strong="H1366"\w* llevaron ante \w el|strong="H3605"\w* \w rey|strong="H4428"\w*.  
\v 4 La joven \w era|strong="H1961"\w* \w muy|strong="H3966"\w* \w hermosa|strong="H3303"\w*, \w y|strong="H5704"\w* \w se|strong="H3045"\w* puso \w al|strong="H5704"\w* servicio del \w rey|strong="H4428"\w* \w para|strong="H5704"\w* cuidarlo, \w mas|strong="H5704"\w* el \w rey|strong="H4428"\w* \w no|strong="H3808"\w* la \w conoció|strong="H3045"\w* íntimamente.   
\p
\v 5 Entonces Adonías, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Haggit, se enalteció diciendo: «\w Yo|strong="H6213"\w* seré \w el|strong="H1121"\w* \w rey|strong="H4427"\w*». \w Y|strong="H3068"\w* se \w hizo|strong="H6213"\w* \w de|strong="H6440"\w* \w carros|strong="H7393"\w* y \w jinetes|strong="H6571"\w*, y \w de|strong="H6440"\w* \w cincuenta|strong="H2572"\w* \w hombres|strong="H6571"\w* \w que|strong="H1121"\w* corrieran \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H1121"\w*.  
\v 6 \w Su|strong="H1931"\w* padre \w nunca|strong="H3808"\w* \w le|strong="H1931"\w* \w había|strong="H6213"\w* recriminado \w nada|strong="H3808"\w* \w ni|strong="H3808"\w* \w le|strong="H1931"\w* \w había|strong="H6213"\w* dicho: «¿\w Por|strong="H4069"\w* \w qué|strong="H1931"\w* \w haces|strong="H6213"\w* \w esto|strong="H1931"\w*?». \w Además|strong="H1571"\w*, \w era|strong="H1931"\w* un hombre \w muy|strong="H3966"\w* apuesto \w y|strong="H1571"\w* \w había|strong="H6213"\w* \w nacido|strong="H3205"\w* después de Absalón.  
\v 7 \w Se|strong="H1961"\w* puso \w de|strong="H5973"\w* acuerdo \w con|strong="H5973"\w* \w Joab|strong="H3097"\w* \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Sarvia y \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w sacerdote|strong="H3548"\w* Abiatar, \w los|strong="H1121"\w* cuales \w seguían|strong="H1961"\w* \w a|strong="H3068"\w* Adonías y \w le|strong="H5973"\w* prestaban su apoyo.  
\v 8 Pero \w ni|strong="H3808"\w* \w el|strong="H5973"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w ni|strong="H3808"\w* \w Benaía|strong="H1141"\w* \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Joiada|strong="H3077"\w*, \w ni|strong="H3808"\w* \w el|strong="H5973"\w* \w profeta|strong="H5030"\w* Natán, \w ni|strong="H3808"\w* Simei, \w ni|strong="H3808"\w* Rei, \w ni|strong="H3808"\w* \w los|strong="H1121"\w* \w valientes|strong="H1368"\w* \w de|strong="H5973"\w* \w David|strong="H1732"\w* \w estaban|strong="H1961"\w* \w con|strong="H5973"\w* Adonías.   
\p
\v 9 Adonías \w sacrificó|strong="H2076"\w* \w ovejas|strong="H6629"\w*, \w bueyes|strong="H1241"\w* \w y|strong="H1241"\w* \w animales|strong="H1121"\w* cebados \w junto|strong="H5973"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* piedra \w de|strong="H5973"\w* Zohelet, \w que|strong="H1121"\w* está \w cerca|strong="H5973"\w* \w de|strong="H5973"\w* En-Rogel; \w e|strong="H3068"\w* invitó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*, \w y|strong="H1241"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w*, \w siervos|strong="H5650"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*;  
\v 10 pero \w no|strong="H3808"\w* invitó al \w profeta|strong="H5030"\w* Natán, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w Benaía|strong="H1141"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* los \w valientes|strong="H1368"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* su hermano \w Salomón|strong="H8010"\w*.   
\p
\v 11 \w Entonces|strong="H3588"\w* Natán habló \w a|strong="H3068"\w* Betsabé, madre \w de|strong="H3588"\w* \w Salomón|strong="H8010"\w*, diciendo: “¿\w No|strong="H3808"\w* \w has|strong="H4427"\w* \w oído|strong="H8085"\w* \w que|strong="H3588"\w* Adonías \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Haggit \w se|strong="H3045"\w* \w ha|strong="H3808"\w* proclamado \w rey|strong="H4427"\w*, \w sin|strong="H3808"\w* \w que|strong="H3588"\w* nuestro señor \w David|strong="H1732"\w* \w lo|strong="H3808"\w* \w sepa|strong="H3045"\w*?  
\v 12 \w Ven|strong="H3212"\w*, \w pues|strong="H4994"\w*, \w ahora|strong="H6258"\w*, y permite \w que|strong="H6258"\w* \w te|strong="H5315"\w* \w dé|strong="H1121"\w* un \w consejo|strong="H6098"\w* \w para|strong="H6258"\w* \w que|strong="H6258"\w* salves tu \w vida|strong="H5315"\w* y la \w de|strong="H1121"\w* tu \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w*.  
\v 13 \w Ve|strong="H3212"\w*, entra \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w y|strong="H3588"\w* dile: ‘¿\w No|strong="H3808"\w* jurasteis vos, \w mi|strong="H5921"\w* señor \w el|strong="H1931"\w* \w rey|strong="H4428"\w*, \w a|strong="H3068"\w* vuestra sierva, diciendo: «\w Ciertamente|strong="H3588"\w* tu \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w reinará|strong="H4427"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* \w se|strong="H1931"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w*»? ¿\w Por|strong="H5921"\w* \w qué|strong="H3588"\w*, \w pues|strong="H3588"\w*, \w reina|strong="H4427"\w* Adonías?’.  
\v 14 \w Mira|strong="H2009"\w*,\f + \fr 1:14 \ft «He aquí», de «הִנֵּה», significa mirar, fijarse, observar, ver o contemplar. Se utiliza a menudo como interjección.\f* \w mientras|strong="H5750"\w* \w aún|strong="H5750"\w* estés \w hablando|strong="H1696"\w* \w allí|strong="H8033"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w*, \w yo|strong="H2009"\w* entraré \w tras|strong="H5973"\w* \w de|strong="H5973"\w* \w ti|strong="H5973"\w* y confirmaré tus \w palabras|strong="H1697"\w*”.   
\p
\v 15 Betsabé entró en la \w cámara|strong="H2315"\w* del \w rey|strong="H4428"\w*. El \w rey|strong="H4428"\w* era ya \w muy|strong="H3966"\w* anciano, y Abisag la \w sunamita|strong="H7767"\w* \w servía|strong="H8334"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*.  
\v 16 Betsabé \w se|strong="H4100"\w* \w inclinó|strong="H6915"\w* y rindió homenaje \w al|strong="H4428"\w* \w rey|strong="H4428"\w*. El \w rey|strong="H4428"\w* preguntó: «¿\w Qué|strong="H4100"\w* deseas?».   
\p
\v 17 \w Ella|strong="H1931"\w* respondió: “\w Señor|strong="H3068"\w* \w mío|strong="H5921"\w*, vos jurasteis \w por|strong="H5921"\w* Yahvé\f + \fr 1:17 \ft «Yahvé» es el nombre propio de Dios, a veces traducido como «SEÑOR» (en mayúsculas) en otras traducciones. \f* vuestro \w Dios|strong="H3068"\w*\f + \fr 1:17 \ft Un talento equivale a unos 30 kilogramos o 66 libras o 965 onzas troy, por lo que 666 talentos son unas 20 toneladas métricas\f* \w a|strong="H3068"\w* vuestra sierva: ‘\w Ciertamente|strong="H3588"\w* tu \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w reinará|strong="H4427"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* \w se|strong="H1931"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w*’.  
\v 18 \w Y|strong="H3068"\w* ved \w que|strong="H3808"\w* \w ahora|strong="H6258"\w* Adonías \w reina|strong="H4427"\w*, y vos, \w mi|strong="H2009"\w* señor el \w rey|strong="H4428"\w*, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w sabéis|strong="H3045"\w*.  
\v 19 \w Ha|strong="H3808"\w* sacrificado \w bueyes|strong="H7794"\w*, \w animales|strong="H1121"\w* cebados \w y|strong="H7794"\w* \w ovejas|strong="H6629"\w* en \w abundancia|strong="H7230"\w*, \w y|strong="H7794"\w* \w ha|strong="H3808"\w* invitado \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w*, \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* Abiatar \w y|strong="H7794"\w* \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*, \w general|strong="H8269"\w* del \w ejército|strong="H6635"\w*; pero \w no|strong="H3808"\w* \w ha|strong="H3808"\w* invitado \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*, vuestro \w siervo|strong="H5650"\w*.  
\v 20 \w En|strong="H5921"\w* vos, \w mi|strong="H5921"\w* señor \w el|strong="H5921"\w* \w rey|strong="H4428"\w*, \w están|strong="H3427"\w* puestos \w los|strong="H3427"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w para|strong="H5921"\w* \w que|strong="H4310"\w* \w les|strong="H5921"\w* declaréis \w quién|strong="H4310"\w* ha \w de|strong="H5921"\w* sentarse \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* señor \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 21 \w De|strong="H5973"\w* lo contrario, \w sucederá|strong="H1961"\w* \w que|strong="H1121"\w* \w cuando|strong="H1961"\w* \w mi|strong="H1961"\w* señor \w el|strong="H5973"\w* \w rey|strong="H4428"\w* duerma \w con|strong="H5973"\w* sus padres, yo y \w mi|strong="H1961"\w* \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w seremos|strong="H1961"\w* tenidos \w por|strong="H4428"\w* culpables”.   
\p
\v 22 \w Mientras|strong="H5750"\w* ella \w aún|strong="H5750"\w* \w hablaba|strong="H1696"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w*, entró \w el|strong="H5973"\w* \w profeta|strong="H5030"\w* Natán.  
\v 23 Avisaron \w al|strong="H5921"\w* \w rey|strong="H4428"\w*, diciendo: «He \w aquí|strong="H2009"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* Natán».  
\p \w Al|strong="H5921"\w* entrar \w ante|strong="H6440"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*, \w se|strong="H5921"\w* postró \w rostro|strong="H6440"\w* \w en|strong="H5921"\w* tierra.  
\v 24 \w Y|strong="H3068"\w* Natán dijo: “\w Rey|strong="H4428"\w*, señor \w mío|strong="H5921"\w*, ¿habéis dicho vos: ‘Adonías \w reinará|strong="H4427"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w se|strong="H1931"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w*’?  
\v 25 \w Porque|strong="H3588"\w* \w hoy|strong="H3117"\w* ha bajado \w y|strong="H3588"\w* ha sacrificado \w bueyes|strong="H7794"\w*, \w animales|strong="H1121"\w* cebados \w y|strong="H3588"\w* \w ovejas|strong="H6629"\w* \w en|strong="H3588"\w* \w abundancia|strong="H7230"\w*, \w y|strong="H3588"\w* ha invitado \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H8354"\w* \w rey|strong="H4428"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w capitanes|strong="H8269"\w* \w del|strong="H8354"\w* \w ejército|strong="H6635"\w* \w y|strong="H3588"\w* \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* Abiatar; \w y|strong="H3588"\w* ved \w que|strong="H3588"\w* \w están|strong="H2009"\w* comiendo \w y|strong="H3588"\w* \w bebiendo|strong="H8354"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*, \w y|strong="H3588"\w* dicen: ‘¡\w Viva|strong="H2421"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* Adonías!’.  
\v 26 Pero \w a|strong="H3068"\w* mí, vuestro \w siervo|strong="H5650"\w*, \w ni|strong="H3808"\w* al \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w Benaía|strong="H1141"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joiada|strong="H3077"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* vuestro \w siervo|strong="H5650"\w* \w Salomón|strong="H8010"\w*, nos \w ha|strong="H3808"\w* invitado.  
\v 27 ¿\w Ha|strong="H3808"\w* emanado \w esta|strong="H2088"\w* orden \w de|strong="H5921"\w* \w mi|strong="H5921"\w* señor \w el|strong="H5921"\w* \w rey|strong="H4428"\w*, \w sin|strong="H3808"\w* \w haber|strong="H1961"\w* declarado \w a|strong="H3068"\w* vuestros \w siervos|strong="H5650"\w* \w quién|strong="H4310"\w* \w se|strong="H3045"\w* sentaría \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* señor \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*?”.   
\p
\v 28 El \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w respondió|strong="H6030"\w*: «\w Llamadme|strong="H7121"\w* \w a|strong="H3068"\w* Betsabé». Ella entró \w a|strong="H3068"\w* la \w presencia|strong="H6440"\w* del \w rey|strong="H4428"\w* y se \w puso|strong="H5975"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w ante|strong="H6440"\w* él.  
\v 29 Entonces \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w juró|strong="H7650"\w* diciendo: “\w Vive|strong="H2416"\w* Yahvé, \w que|strong="H3605"\w* ha redimido \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* de \w toda|strong="H3605"\w* \w angustia|strong="H6869"\w*,  
\v 30 \w que|strong="H3588"\w* \w tal|strong="H3651"\w* \w como|strong="H3588"\w* \w os|strong="H5921"\w* \w juré|strong="H7650"\w* \w por|strong="H5921"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, diciendo: ‘\w Ciertamente|strong="H3588"\w* \w tu|strong="H6213"\w* \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w reinará|strong="H4427"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* \w se|strong="H1931"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w lugar|strong="H8478"\w*’, \w así|strong="H3651"\w* \w lo|strong="H1931"\w* \w haré|strong="H6213"\w* \w hoy|strong="H3117"\w* \w mismo|strong="H1931"\w*”.   
\p
\v 31 Entonces Betsabé se \w inclinó|strong="H6915"\w* rostro en tierra, rindió homenaje \w al|strong="H4428"\w* \w rey|strong="H4428"\w* y dijo: «¡\w Viva|strong="H2421"\w* mi señor el \w rey|strong="H4428"\w* \w David|strong="H1732"\w* para \w siempre|strong="H5769"\w*!».   
\p
\v 32 \w El|strong="H1121"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* ordenó: «\w Llamadme|strong="H7121"\w* \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w al|strong="H4428"\w* \w profeta|strong="H5030"\w* Natán y \w a|strong="H3068"\w* \w Benaía|strong="H1141"\w* \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Joiada|strong="H3077"\w*». Ellos se presentaron \w ante|strong="H6440"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w*.  
\v 33 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w les|strong="H5921"\w* dijo: “Llevad \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w siervos|strong="H5650"\w* \w de|strong="H5921"\w* vuestro señor, haced montar \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* propia mula \w y|strong="H5921"\w* llevadlo \w a|strong="H3068"\w* Gihón.  
\v 34 \w Que|strong="H5921"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* Natán \w lo|strong="H5921"\w* unjan \w allí|strong="H8033"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Tocad|strong="H8628"\w* \w la|strong="H5921"\w* \w trompeta|strong="H7782"\w* \w y|strong="H5921"\w* decid: ‘¡\w Viva|strong="H2421"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*!’.  
\v 35 \w Subid|strong="H5927"\w* tras \w él|strong="H1931"\w*, \w y|strong="H5921"\w* \w vendrá|strong="H1961"\w* \w y|strong="H5921"\w* \w se|strong="H1961"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w*, \w pues|strong="H1931"\w* \w él|strong="H1931"\w* \w reinará|strong="H4427"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w lugar|strong="H8478"\w*; \w porque|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w lo|strong="H1931"\w* he designado \w para|strong="H5921"\w* \w que|strong="H1931"\w* \w sea|strong="H1961"\w* \w príncipe|strong="H5057"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w Judá|strong="H3063"\w*”.   
\p
\v 36 \w Benaía|strong="H1141"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joiada|strong="H3077"\w* \w respondió|strong="H6030"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: «¡Amén! \w Así|strong="H3651"\w* lo diga Yahvé, \w el|strong="H1121"\w* \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* \w mi|strong="H6030"\w* \w señor|strong="H3068"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w*.  
\v 37 \w Como|strong="H5973"\w* Yahvé ha \w estado|strong="H1961"\w* \w con|strong="H5973"\w* \w mi|strong="H1431"\w* \w señor|strong="H3068"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w*, \w así|strong="H3651"\w* \w esté|strong="H1961"\w* \w con|strong="H5973"\w* \w Salomón|strong="H8010"\w*, y haga su \w trono|strong="H3678"\w* más \w grande|strong="H1431"\w* \w que|strong="H1961"\w* \w el|strong="H5973"\w* \w trono|strong="H3678"\w* \w de|strong="H5973"\w* \w mi|strong="H1431"\w* \w señor|strong="H3068"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w*».   
\p
\v 38 \w Bajaron|strong="H3381"\w*, \w pues|strong="H3381"\w*, \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* Natán, \w Benaía|strong="H1141"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Joiada|strong="H3077"\w*, \w y|strong="H5921"\w* \w los|strong="H1121"\w* cereteos \w y|strong="H5921"\w* \w los|strong="H1121"\w* peleteos, \w e|strong="H3068"\w* hicieron montar \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* mula \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* llevaron \w a|strong="H3068"\w* Gihón.  
\v 39 \w El|strong="H3605"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w* \w tomó|strong="H3947"\w* \w el|strong="H3605"\w* \w cuerno|strong="H7161"\w* \w de|strong="H4480"\w* \w aceite|strong="H8081"\w* \w del|strong="H4480"\w* Tabernáculo y \w ungió|strong="H4886"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*. \w Tocaron|strong="H8628"\w* \w la|strong="H3605"\w* \w trompeta|strong="H7782"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* exclamó: «¡\w Viva|strong="H2421"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*!».   
\p
\v 40 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w subió|strong="H5927"\w* tras \w él|strong="H3605"\w*; y \w la|strong="H3605"\w* \w gente|strong="H5971"\w* tocaba \w flautas|strong="H2485"\w* y \w se|strong="H5971"\w* regocijaba con \w gran|strong="H1419"\w* \w alegría|strong="H8057"\w*, \w de|strong="H5971"\w* tal modo \w que|strong="H5971"\w* \w la|strong="H3605"\w* tierra \w se|strong="H5971"\w* estremecía con \w el|strong="H3605"\w* \w estruendo|strong="H6963"\w*.  
\v 41 \w Lo|strong="H1992"\w* \w oyeron|strong="H8085"\w* Adonías y \w todos|strong="H3605"\w* \w los|strong="H1992"\w* invitados \w que|strong="H1992"\w* estaban con \w él|strong="H3605"\w*, cuando ya habían \w acabado|strong="H3615"\w* de comer. Al \w oír|strong="H8085"\w* \w Joab|strong="H3097"\w* \w el|strong="H3605"\w* \w sonido|strong="H6963"\w* de \w la|strong="H3605"\w* \w trompeta|strong="H7782"\w*, preguntó: «¿\w A|strong="H3068"\w* \w qué|strong="H1992"\w* viene ese alboroto en \w la|strong="H3605"\w* \w ciudad|strong="H7151"\w*?».   
\p
\v 42 \w Mientras|strong="H3588"\w* \w aún|strong="H5750"\w* \w hablaba|strong="H1696"\w*, llegó Jonatán, \w hijo|strong="H1121"\w* del \w sacerdote|strong="H3548"\w* Abiatar, \w a|strong="H3068"\w* quien Adonías \w dijo|strong="H1696"\w*: «Entra, \w porque|strong="H3588"\w* eres \w hombre|strong="H1121"\w* \w de|strong="H3588"\w* valía \w y|strong="H3588"\w* traes \w buenas|strong="H2896"\w* noticias».   
\p
\v 43 Jonatán \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Adonías: “\w Al|strong="H4428"\w* contrario; nuestro señor el \w rey|strong="H4428"\w* \w David|strong="H1732"\w* ha hecho \w rey|strong="H4428"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*.  
\v 44 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* ha \w enviado|strong="H7971"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* Natán, \w a|strong="H3068"\w* \w Benaía|strong="H1141"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Joiada|strong="H3077"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* cereteos \w y|strong="H5921"\w* \w los|strong="H1121"\w* peleteos, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* han \w montado|strong="H7392"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* mula \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.  
\v 45 \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w* y \w el|strong="H1931"\w* \w profeta|strong="H5030"\w* Natán \w lo|strong="H1931"\w* han \w ungido|strong="H4886"\w* \w rey|strong="H4428"\w* en Gihón; de \w allí|strong="H8033"\w* han \w subido|strong="H5927"\w* con gran júbilo, y \w la|strong="H1931"\w* \w ciudad|strong="H7151"\w* \w está|strong="H1931"\w* alborotada. \w Ese|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w estruendo|strong="H6963"\w* \w que|strong="H1931"\w* habéis \w oído|strong="H8085"\w*.  
\v 46 \w Además|strong="H5921"\w*, \w Salomón|strong="H8010"\w* \w ya|strong="H1571"\w* \w se|strong="H5921"\w* ha \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w del|strong="H5921"\w* \w reino|strong="H4410"\w*.  
\v 47 \w Y|strong="H3068"\w* \w también|strong="H1571"\w* \w los|strong="H5921"\w* \w siervos|strong="H5650"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* han ido \w a|strong="H3068"\w* felicitar \w a|strong="H3068"\w* nuestro señor \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w*, diciendo: ‘Haga vuestro Dios \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* \w Salomón|strong="H8010"\w* sea \w más|strong="H1571"\w* ilustre \w que|strong="H5921"\w* \w el|strong="H5921"\w* vuestro, \w y|strong="H1571"\w* su \w trono|strong="H3678"\w* \w más|strong="H1571"\w* \w grande|strong="H1431"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* vuestro’. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w se|strong="H5921"\w* ha inclinado \w en|strong="H5921"\w* su lecho.  
\v 48 \w Asimismo|strong="H1571"\w*, \w el|strong="H5921"\w* \w rey|strong="H4428"\w* ha dicho: ‘\w Bendito|strong="H1288"\w* sea Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H5921"\w* ha concedido \w hoy|strong="H3117"\w* \w que|strong="H5921"\w* uno \w se|strong="H5921"\w* siente \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w*, \w y|strong="H1571"\w* \w que|strong="H5921"\w* \w mis|strong="H5414"\w* \w ojos|strong="H5869"\w* \w lo|strong="H5921"\w* \w vean|strong="H7200"\w*’”.   
\p
\v 49 Entonces \w todos|strong="H3605"\w* \w los|strong="H3605"\w* invitados de Adonías se llenaron de pavor, y se \w levantaron|strong="H6965"\w* y se \w fue|strong="H3212"\w* \w cada|strong="H3605"\w* uno \w por|strong="H1870"\w* su \w camino|strong="H1870"\w*.  
\v 50 Adonías, \w temeroso|strong="H3372"\w* \w de|strong="H6440"\w* \w Salomón|strong="H8010"\w*, se \w levantó|strong="H6965"\w* y \w fue|strong="H3212"\w* \w a|strong="H3068"\w* asirse \w de|strong="H6440"\w* los \w cuernos|strong="H7161"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*.  
\v 51 Informaron \w de|strong="H3372"\w* ello \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*, diciendo: “He \w aquí|strong="H2009"\w* \w que|strong="H3117"\w* Adonías tiene \w miedo|strong="H3372"\w* \w del|strong="H4196"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, pues se ha asido \w de|strong="H3372"\w* los \w cuernos|strong="H7161"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*, diciendo: ‘\w Que|strong="H3117"\w* el \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* me \w jure|strong="H7650"\w* \w hoy|strong="H3117"\w* mismo \w que|strong="H3117"\w* no \w matará|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* su \w siervo|strong="H5650"\w*’”.   
\p
\v 52 \w Salomón|strong="H8010"\w* respondió: «\w Si|strong="H3808"\w* \w se|strong="H1961"\w* comporta \w como|strong="H1961"\w* un \w hombre|strong="H1121"\w* \w de|strong="H1121"\w* bien, \w ni|strong="H3808"\w* un solo cabello suyo \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* tierra; pero \w si|strong="H3808"\w* \w se|strong="H1961"\w* \w halla|strong="H4672"\w* \w maldad|strong="H7451"\w* en \w él|strong="H5307"\w*, \w morirá|strong="H4191"\w*».   
\p
\v 53 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w que|strong="H5921"\w* \w lo|strong="H5921"\w* hicieran bajar \w del|strong="H5921"\w* \w altar|strong="H4196"\w*. \w Él|strong="H5921"\w* \w vino|strong="H3212"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* postró ante \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, \w y|strong="H5921"\w* \w Salomón|strong="H8010"\w* \w le|strong="H5921"\w* dijo: «\w Vete|strong="H3212"\w* \w a|strong="H3068"\w* tu \w casa|strong="H1004"\w*».   
\c 2
\p
\v 1 Se acercaban \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w* para \w morir|strong="H4191"\w*; y \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* su \w hijo|strong="H1121"\w*, diciendo:  
\v 2 “Yo \w voy|strong="H1980"\w* \w por|strong="H1870"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* de \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra; \w esfuérzate|strong="H2388"\w* y muéstrate hombre.  
\v 3 \w Guarda|strong="H8104"\w* las \w ordenanzas|strong="H4941"\w* de Yahvé \w tu|strong="H6213"\w* \w Dios|strong="H3068"\w*, \w andando|strong="H3212"\w* \w en|strong="H3212"\w* sus \w caminos|strong="H1870"\w* y \w observando|strong="H8104"\w* sus \w estatutos|strong="H2708"\w*, sus \w mandamientos|strong="H4687"\w*, sus decretos y sus testimonios, de \w la|strong="H8104"\w* manera \w que|strong="H4616"\w* \w está|strong="H8033"\w* \w escrito|strong="H3789"\w* \w en|strong="H3212"\w* \w la|strong="H8104"\w* \w ley|strong="H8451"\w* de \w Moisés|strong="H4872"\w*, \w para|strong="H4616"\w* \w que|strong="H4616"\w* prosperes \w en|strong="H3212"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H4616"\w* \w hagas|strong="H6213"\w* y \w en|strong="H3212"\w* \w todo|strong="H3605"\w* aquello \w que|strong="H4616"\w* emprendas;  
\v 4 \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H3808"\w* Yahvé \w confirme|strong="H6965"\w* \w la|strong="H5921"\w* promesa \w que|strong="H3808"\w* \w me|strong="H5921"\w* \w hizo|strong="H3772"\w*, \w diciendo|strong="H1696"\w*: «\w Si|strong="H3808"\w* tus \w hijos|strong="H1121"\w* \w guardaren|strong="H8104"\w* su \w camino|strong="H1870"\w*, \w andando|strong="H3212"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w con|strong="H5921"\w* verdad, \w de|strong="H5921"\w* \w todo|strong="H3605"\w* su \w corazón|strong="H3824"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* su \w alma|strong="H5315"\w*, \w jamás|strong="H3808"\w* \w te|strong="H5921"\w* \w faltará|strong="H3772"\w* —\w dijo|strong="H1696"\w*— varón \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*».   
\p
\v 5 “\w Bien|strong="H7965"\w* \w sabes|strong="H3045"\w* \w tú|strong="H6213"\w* \w también|strong="H1571"\w* \w lo|strong="H6213"\w* \w que|strong="H1571"\w* me \w hizo|strong="H6213"\w* \w Joab|strong="H3097"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia, \w y|strong="H1571"\w* \w lo|strong="H6213"\w* \w que|strong="H1571"\w* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w dos|strong="H8147"\w* \w generales|strong="H8269"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w ejércitos|strong="H6635"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* Abner \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ner|strong="H5369"\w* \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w Amasa|strong="H6021"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeter|strong="H3500"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* cuales \w mató|strong="H2026"\w*, \w derramando|strong="H7760"\w* en tiempo \w de|strong="H1121"\w* \w paz|strong="H7965"\w* \w sangre|strong="H1818"\w* \w de|strong="H1121"\w* \w guerra|strong="H4421"\w*, manchando \w con|strong="H1571"\w* \w sangre|strong="H1818"\w* \w de|strong="H1121"\w* \w guerra|strong="H4421"\w* \w el|strong="H1121"\w* \w talabarte|strong="H2290"\w* \w que|strong="H1571"\w* rodeaba su cintura \w y|strong="H1571"\w* las sandalias \w de|strong="H1121"\w* sus \w pies|strong="H7272"\w*.  
\v 6 \w Haz|strong="H6213"\w*, \w pues|strong="H3381"\w*, conforme \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w sabiduría|strong="H2451"\w*; \w no|strong="H3808"\w* permitas \w que|strong="H3808"\w* sus canas \w desciendan|strong="H3381"\w* al Seol en \w paz|strong="H7965"\w*.  
\v 7 \w Mas|strong="H3588"\w* \w con|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Barzilai \w galaadita|strong="H1569"\w* mostrarás bondad, \w que|strong="H3588"\w* \w sean|strong="H1961"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* comen \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w mesa|strong="H7979"\w*; \w porque|strong="H3588"\w* ellos \w me|strong="H3588"\w* acogieron \w así|strong="H3651"\w* \w cuando|strong="H3588"\w* \w yo|strong="H3588"\w* \w huía|strong="H1272"\w* \w de|strong="H3588"\w* \w tu|strong="H6213"\w* hermano Absalón.   
\p
\v 8 “También tienes \w contigo|strong="H5973"\w* \w a|strong="H3068"\w* Simei \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Gera|strong="H1617"\w*, \w benjamita|strong="H1121"\w* \w de|strong="H5973"\w* Bahurim, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w me|strong="H5973"\w* \w maldijo|strong="H7043"\w* \w con|strong="H5973"\w* una \w maldición|strong="H7045"\w* fidedigna \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H1931"\w* \w yo|strong="H2009"\w* \w iba|strong="H3212"\w* \w a|strong="H3068"\w* \w Mahanaim|strong="H4266"\w*. Pero \w él|strong="H1931"\w* bajó \w a|strong="H3068"\w* recibirme al \w Jordán|strong="H3383"\w*, y \w yo|strong="H2009"\w* \w le|strong="H1931"\w* \w juré|strong="H7650"\w* por Yahvé, diciendo: «No \w te|strong="H5973"\w* \w mataré|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*».  
