\v 20 \w Los|strong="H5921"\w* \w capiteles|strong="H3805"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w* tenían \w también|strong="H1571"\w* grabados \w por|strong="H5921"\w* \w encima|strong="H4605"\w*, \w cerca|strong="H5921"\w* \w del|strong="H5921"\w* saliente \w que|strong="H5921"\w* estaba \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* red; \w y|strong="H1571"\w* \w había|strong="H3805"\w* \w doscientas|strong="H3967"\w* \w granadas|strong="H7416"\w* \w en|strong="H5921"\w* \w dos|strong="H8147"\w* hileras \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* cada \w capitel|strong="H3805"\w*.  
\v 21 \w Erigió|strong="H6965"\w*, pues, las \w columnas|strong="H5982"\w* en el pórtico del \w templo|strong="H1964"\w*; \w erigió|strong="H6965"\w* la \w columna|strong="H5982"\w* de la \w derecha|strong="H3233"\w* y la \w llamó|strong="H7121"\w* \w Jachín|strong="H3199"\w*, y \w erigió|strong="H6965"\w* la \w columna|strong="H5982"\w* de la \w izquierda|strong="H8042"\w* y la \w llamó|strong="H7121"\w* \w Boaz|strong="H1162"\w*.  
