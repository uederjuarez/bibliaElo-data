\v 23 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, he \w aquí|strong="H2009"\w* Yahvé ha \w puesto|strong="H5414"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w mentira|strong="H8267"\w* \w en|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* tus \w profetas|strong="H5030"\w*, \w y|strong="H5921"\w* Yahvé ha decretado \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*”.   
