\v 10 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* \w los|strong="H1961"\w* \w sacerdotes|strong="H3548"\w* \w salieron|strong="H3318"\w* \w del|strong="H4480"\w* \w santuario|strong="H6944"\w*, la \w nube|strong="H6051"\w* \w llenó|strong="H4390"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* Yahvé.  
\v 11 \w Y|strong="H3068"\w* \w los|strong="H3588"\w* \w sacerdotes|strong="H3548"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* permanecer \w en|strong="H3588"\w* \w pie|strong="H5975"\w* \w para|strong="H3588"\w* ministrar \w por|strong="H3588"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w nube|strong="H6051"\w*; \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w gloria|strong="H3519"\w* \w de|strong="H3588"\w* Yahvé \w había|strong="H5975"\w* llenado \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé.   
\p
\v 12 Entonces dijo \w Salomón|strong="H8010"\w*: «Yahvé ha dicho que él habitaría en la \w oscuridad|strong="H6205"\w*.  
\v 13 Yo, ciertamente, te he \w edificado|strong="H1129"\w* una \w casa|strong="H1004"\w* \w por|strong="H5769"\w* \w morada|strong="H3427"\w*, un lugar en que habites para \w siempre|strong="H5769"\w*».   
\p
\v 14 \w Y|strong="H3068"\w* volviendo \w el|strong="H3605"\w* \w rey|strong="H4428"\w* su \w rostro|strong="H6440"\w*, \w bendijo|strong="H1288"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w congregación|strong="H6951"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*; y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w congregación|strong="H6951"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w estaba|strong="H5975"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w*.  
\v 15 \w Y|strong="H3068"\w* \w dijo|strong="H1696"\w*: “\w Bendito|strong="H1288"\w* sea Yahvé, \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*, \w que|strong="H6310"\w* \w habló|strong="H1696"\w* con su \w boca|strong="H6310"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* mi padre, y con su \w mano|strong="H3027"\w* lo ha cumplido, \w diciendo|strong="H1696"\w*:  
\v 16 «\w Desde|strong="H4480"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w que|strong="H4480"\w* \w saqué|strong="H3318"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w* \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*, \w no|strong="H3808"\w* he escogido \w ciudad|strong="H5892"\w* \w de|strong="H4480"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w tribus|strong="H7626"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w para|strong="H5921"\w* \w edificar|strong="H1129"\w* \w casa|strong="H1004"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* cual estuviese \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w*; \w mas|strong="H4480"\w* escogí \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w para|strong="H5921"\w* \w que|strong="H4480"\w* \w fuese|strong="H1961"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*».   
\p
\v 17 “\w Y|strong="H3068"\w* \w David|strong="H1732"\w* \w mi|strong="H1961"\w* padre \w tuvo|strong="H1961"\w* \w en|strong="H5973"\w* su \w corazón|strong="H3824"\w* \w el|strong="H5973"\w* \w edificar|strong="H1129"\w* \w casa|strong="H1004"\w* al \w nombre|strong="H8034"\w* \w de|strong="H5973"\w* Yahvé \w Dios|strong="H3068"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*.  
