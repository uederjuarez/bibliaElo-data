\c 16
\p
\v 1 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w a|strong="H3068"\w* \w Jehú|strong="H3058"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Hananí|strong="H2607"\w* \w contra|strong="H5921"\w* \w Baasa|strong="H1201"\w*, diciendo:  
\v 2 «\w Por|strong="H5921"\w* \w cuanto|strong="H3282"\w* \w yo|strong="H4480"\w* \w te|strong="H5921"\w* exalté \w del|strong="H4480"\w* \w polvo|strong="H6083"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w puse|strong="H5414"\w* \w por|strong="H5921"\w* \w príncipe|strong="H5057"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w has|strong="H5414"\w* andado \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w de|strong="H4480"\w* \w Jeroboam|strong="H3379"\w* \w y|strong="H5921"\w* \w has|strong="H5414"\w* hecho \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, provocándome \w a|strong="H3068"\w* \w ira|strong="H3212"\w* \w con|strong="H5921"\w* sus \w pecados|strong="H2403"\w*;  
\v 3 he \w aquí|strong="H2005"\w* \w que|strong="H1121"\w* yo barreré \w la|strong="H1197"\w* posteridad \w de|strong="H1121"\w* \w Baasa|strong="H1201"\w* \w y|strong="H1197"\w* \w la|strong="H1197"\w* \w de|strong="H1121"\w* su \w casa|strong="H1004"\w*; \w y|strong="H1197"\w* \w pondré|strong="H5414"\w* tu \w casa|strong="H1004"\w* como \w la|strong="H1197"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nabat|strong="H5028"\w*.  
\v 4 Al que de \w Baasa|strong="H1201"\w* \w muriere|strong="H4191"\w* en la \w ciudad|strong="H5892"\w*, lo comerán los \w perros|strong="H3611"\w*; y al que de los suyos \w muriere|strong="H4191"\w* en el \w campo|strong="H7704"\w*, lo comerán las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w*».   
