\v 38 \w Y|strong="H3068"\w* en \w el|strong="H1931"\w* undécimo \w año|strong="H8141"\w*, en \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w de|strong="H1697"\w* Bul, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w octavo|strong="H8066"\w*, \w fue|strong="H1931"\w* acabada \w la|strong="H1931"\w* \w casa|strong="H1004"\w* con \w todas|strong="H3605"\w* \w sus|strong="H1931"\w* dependencias y \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w su|strong="H1931"\w* diseño. \w La|strong="H1931"\w* \w edificó|strong="H1129"\w*, \w pues|strong="H1931"\w*, en \w siete|strong="H7651"\w* \w años|strong="H8141"\w*.   
\c 7
\p
\v 1 \w Salomón|strong="H8010"\w* estuvo \w edificando|strong="H1129"\w* su propia \w casa|strong="H1004"\w* durante \w trece|strong="H7969"\w* \w años|strong="H8141"\w*, hasta \w que|strong="H3605"\w* terminó \w toda|strong="H3605"\w* su \w casa|strong="H1004"\w*.  
