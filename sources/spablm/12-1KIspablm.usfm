\v 3 \w Y|strong="H3068"\w* estaba cubierta \w de|strong="H5921"\w* cedro \w por|strong="H5921"\w* \w encima|strong="H4605"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w cámaras|strong="H6763"\w* laterales, \w que|strong="H5921"\w* \w se|strong="H5921"\w* apoyaban \w en|strong="H5921"\w* cuarenta \w y|strong="H5921"\w* \w cinco|strong="H2568"\w* \w columnas|strong="H5982"\w*, \w quince|strong="H2568"\w* \w en|strong="H5921"\w* cada hilera.  
\v 4 Había \w tres|strong="H7969"\w* hileras de ventanas, \w una|strong="H6471"\w* ventana frente \w a|strong="H3068"\w* la otra en \w tres|strong="H7969"\w* filas.  
\v 5 \w Todas|strong="H3605"\w* las \w puertas|strong="H6607"\w* y \w los|strong="H3605"\w* \w postes|strong="H4201"\w* eran cuadrados, de madera de cedro, con las ventanas \w una|strong="H6471"\w* frente \w a|strong="H3068"\w* \w la|strong="H3605"\w* otra en \w tres|strong="H7969"\w* filas.  
\v 6 \w Hizo|strong="H6213"\w* también un pórtico \w de|strong="H5921"\w* \w columnas|strong="H5982"\w* \w de|strong="H5921"\w* \w cincuenta|strong="H2572"\w* codos \w de|strong="H5921"\w* largo \w y|strong="H5921"\w* \w treinta|strong="H7970"\w* codos \w de|strong="H5921"\w* ancho; \w y|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ellas|strong="H5921"\w* \w había|strong="H6213"\w* otro pórtico \w con|strong="H5921"\w* sus \w columnas|strong="H5982"\w* \w y|strong="H5921"\w* sus respectivos peldaños.  
\v 7 \w Hizo|strong="H6213"\w* asimismo \w el|strong="H6213"\w* pórtico del \w trono|strong="H3678"\w* \w donde|strong="H8033"\w* \w había|strong="H6213"\w* \w de|strong="H5704"\w* juzgar, \w el|strong="H6213"\w* pórtico del \w juicio|strong="H4941"\w*, \w el|strong="H6213"\w* cual estaba cubierto \w de|strong="H5704"\w* cedro \w desde|strong="H5704"\w* \w el|strong="H6213"\w* suelo \w hasta|strong="H5704"\w* \w el|strong="H6213"\w* techo.  
\v 8 \w Y|strong="H3068"\w* la \w casa|strong="H1004"\w* \w donde|strong="H8033"\w* \w él|strong="H6213"\w* \w había|strong="H1961"\w* de \w morar|strong="H3427"\w*, en \w otro|strong="H2088"\w* \w atrio|strong="H2691"\w* \w dentro|strong="H8033"\w* del pórtico, \w era|strong="H1961"\w* de la misma \w obra|strong="H4639"\w*. \w Salomón|strong="H8010"\w* \w edificó|strong="H6213"\w* \w también|strong="H2088"\w*, de la misma traza \w que|strong="H1961"\w* \w este|strong="H2088"\w* pórtico, una \w casa|strong="H1004"\w* \w para|strong="H1961"\w* la \w hija|strong="H1323"\w* de \w Faraón|strong="H6547"\w*, \w a|strong="H3068"\w* \w quien|strong="H6213"\w* \w había|strong="H1961"\w* \w tomado|strong="H3947"\w* \w por|strong="H2088"\w* mujer.  
\v 9 \w Todas|strong="H3605"\w* estas obras fueron \w de|strong="H5704"\w* piedras costosas, \w cortadas|strong="H1496"\w* \w a|strong="H3068"\w* \w medida|strong="H4060"\w* \w y|strong="H5704"\w* aserradas \w con|strong="H5704"\w* sierras \w por|strong="H5704"\w* dentro \w y|strong="H5704"\w* \w por|strong="H5704"\w* \w fuera|strong="H2351"\w*, \w desde|strong="H5704"\w* \w los|strong="H3605"\w* cimientos \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* albardilla, \w y|strong="H5704"\w* \w por|strong="H5704"\w* \w fuera|strong="H2351"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w gran|strong="H1419"\w* \w atrio|strong="H2691"\w*.  
\v 10 Los \w cimientos|strong="H3245"\w* eran de piedras costosas, piedras \w grandes|strong="H1419"\w* de \w diez|strong="H6235"\w* y de \w ocho|strong="H8083"\w* codos.  
