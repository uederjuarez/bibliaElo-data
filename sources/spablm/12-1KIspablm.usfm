\v 41 \w Luego|strong="H7725"\w* se le \w dijo|strong="H5046"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* \w que|strong="H3588"\w* Simei \w había|strong="H3588"\w* ido \w de|strong="H3588"\w* Jerusalén \w a|strong="H3068"\w* Gat, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* \w vuelto|strong="H7725"\w*.   
\p
\v 42 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w mandó|strong="H7971"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* Simei \w y|strong="H3588"\w* le dijo: “¿\w No|strong="H3808"\w* \w te|strong="H3588"\w* \w hice|strong="H7650"\w* jurar \w yo|strong="H3588"\w* \w por|strong="H3588"\w* Yahvé \w y|strong="H3588"\w* \w te|strong="H3588"\w* \w protesté|strong="H5749"\w* diciendo: «\w Sabe|strong="H3045"\w* \w de|strong="H3588"\w* \w cierto|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w que|strong="H3588"\w* \w salieres|strong="H3318"\w* \w para|strong="H3588"\w* \w ir|strong="H7971"\w* \w a|strong="H3068"\w* alguna otra parte, \w ciertamente|strong="H3588"\w* \w morirás|strong="H4191"\w*»?  
