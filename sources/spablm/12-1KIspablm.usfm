\v 3 Vinieron, pues, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de \w Israel|strong="H3478"\w*, y \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w tomaron|strong="H5375"\w* \w el|strong="H3605"\w* arca.  
\v 4 \w Y|strong="H3068"\w* llevaron \w el|strong="H3605"\w* arca de Yahvé, y \w el|strong="H3605"\w* Tabernáculo de \w la|strong="H3605"\w* Reunión y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w sagrados|strong="H6944"\w* \w que|strong="H3605"\w* estaban en \w el|strong="H3605"\w* Tabernáculo; \w los|strong="H3605"\w* cuales llevaron \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w los|strong="H3605"\w* \w levitas|strong="H3881"\w*.  
\v 5 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* había reunido \w con|strong="H5921"\w* \w él|strong="H5921"\w*, estaban \w ante|strong="H6440"\w* \w el|strong="H5921"\w* arca, \w sacrificando|strong="H2076"\w* \w ovejas|strong="H6629"\w* \w y|strong="H5921"\w* \w bueyes|strong="H1241"\w*, \w que|strong="H3808"\w* \w por|strong="H5921"\w* su \w multitud|strong="H7230"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* podían \w contar|strong="H5608"\w* \w ni|strong="H3808"\w* \w numerar|strong="H4487"\w*.  
\v 6 \w Y|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* metieron el arca \w de|strong="H8478"\w* la \w alianza|strong="H1285"\w* \w de|strong="H8478"\w* Yahvé \w en|strong="H8478"\w* su \w lugar|strong="H4725"\w*, \w en|strong="H8478"\w* el \w santuario|strong="H6944"\w* \w de|strong="H8478"\w* la \w casa|strong="H1004"\w*, \w en|strong="H8478"\w* el \w lugar|strong="H4725"\w* \w santísimo|strong="H6944"\w*, \w bajo|strong="H8478"\w* las \w alas|strong="H3671"\w* \w de|strong="H8478"\w* los \w querubines|strong="H3742"\w*.  
