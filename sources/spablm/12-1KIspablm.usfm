\c 8
\p
\v 1 Entonces \w Salomón|strong="H8010"\w* reunió ante \w sí|strong="H1931"\w* en Jerusalén \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las \w tribus|strong="H4294"\w* y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w principales|strong="H7218"\w* \w de|strong="H1121"\w* las familias \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, para hacer \w subir|strong="H5927"\w* \w el|strong="H1931"\w* arca \w de|strong="H1121"\w* \w la|strong="H1931"\w* \w alianza|strong="H1285"\w* \w de|strong="H1121"\w* Yahvé \w de|strong="H1121"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Sión|strong="H6726"\w*.  
