\v 34 En \w su|strong="H7687"\w* \w tiempo|strong="H3117"\w* \w Hiel|strong="H2419"\w* \w de|strong="H1121"\w* Betel \w reedificó|strong="H1129"\w* \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*. \w A|strong="H3068"\w* precio \w de|strong="H1121"\w* la \w vida|strong="H3117"\w* \w de|strong="H1121"\w* Abiram \w su|strong="H7687"\w* \w primogénito|strong="H1060"\w* echó \w el|strong="H1121"\w* \w cimiento|strong="H3245"\w*, y \w a|strong="H3068"\w* precio \w de|strong="H1121"\w* la \w vida|strong="H3117"\w* \w de|strong="H1121"\w* Segub \w su|strong="H7687"\w* \w hijo|strong="H1121"\w* \w menor|strong="H6810"\w* puso sus \w puertas|strong="H1817"\w*, \w conforme|strong="H5324"\w* \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w que|strong="H1697"\w* Yahvé \w había|strong="H5324"\w* \w hablado|strong="H1696"\w* \w por|strong="H1697"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*.   
\c 17
\p
\v 1 Elías tisbita, \w que|strong="H3588"\w* \w era|strong="H1961"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* moradores \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w*, dijo \w a|strong="H3068"\w* Acab: «\w Vive|strong="H2416"\w* Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w en|strong="H3588"\w* cuya \w presencia|strong="H6440"\w* \w estoy|strong="H1961"\w*, \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w habrá|strong="H1961"\w* \w rocío|strong="H2919"\w* ni \w lluvia|strong="H4306"\w* \w en|strong="H3588"\w* estos \w años|strong="H8141"\w*, \w sino|strong="H3588"\w* \w por|strong="H3588"\w* \w mi|strong="H1961"\w* \w palabra|strong="H1697"\w*».   
\p
\v 2 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* él \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 3 «\w Apártate|strong="H3212"\w* \w de|strong="H5921"\w* \w aquí|strong="H2088"\w*, \w y|strong="H5921"\w* vuélvete \w al|strong="H5921"\w* \w oriente|strong="H6924"\w*, \w y|strong="H5921"\w* escóndete \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w arroyo|strong="H5158"\w* \w de|strong="H5921"\w* Querit, \w que|strong="H5921"\w* \w está|strong="H2088"\w* frente \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*.  
\v 4 \w Beberás|strong="H8354"\w* \w del|strong="H8354"\w* \w arroyo|strong="H5158"\w*; y \w yo|strong="H6680"\w* he \w mandado|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* cuervos \w que|strong="H1961"\w* te den \w allí|strong="H8033"\w* de comer».  
\v 5 \w Él|strong="H5921"\w* \w fue|strong="H3212"\w* \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé; pues \w se|strong="H5921"\w* \w fue|strong="H3212"\w* \w y|strong="H5921"\w* vivió \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w arroyo|strong="H5158"\w* \w de|strong="H5921"\w* Querit, \w que|strong="H5921"\w* \w está|strong="H3427"\w* frente \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*.  
\v 6 \w Y|strong="H3068"\w* los cuervos \w le|strong="H1242"\w* traían \w pan|strong="H3899"\w* y \w carne|strong="H1320"\w* \w por|strong="H4480"\w* la \w mañana|strong="H1242"\w*, y \w pan|strong="H3899"\w* y \w carne|strong="H1320"\w* \w por|strong="H4480"\w* la \w tarde|strong="H6153"\w*; y bebía \w del|strong="H4480"\w* \w arroyo|strong="H5158"\w*.  
\v 7 \w Pasados|strong="H1961"\w* algunos \w días|strong="H3117"\w*, \w se|strong="H1961"\w* \w secó|strong="H3001"\w* \w el|strong="H3588"\w* \w arroyo|strong="H5158"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w había|strong="H1961"\w* \w llovido|strong="H1653"\w* \w sobre|strong="H1961"\w* \w la|strong="H3588"\w* tierra.   
\p
\v 8 \w Vino|strong="H1961"\w* luego \w a|strong="H3068"\w* él \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 9 «\w Levántate|strong="H6965"\w*, \w vete|strong="H3212"\w* \w a|strong="H3068"\w* \w Sarepta|strong="H6886"\w* de \w Sidón|strong="H6721"\w*, y \w mora|strong="H3427"\w* \w allí|strong="H8033"\w*; he \w aquí|strong="H2009"\w* \w yo|strong="H2009"\w* he \w mandado|strong="H6680"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* una mujer viuda que te sustente».   
\p
\v 10 Él se \w levantó|strong="H6965"\w* y se \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Sarepta|strong="H6886"\w*. \w Y|strong="H3068"\w* cuando \w llegó|strong="H3212"\w* \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* \w de|strong="H4325"\w* la \w ciudad|strong="H5892"\w*, he \w aquí|strong="H2009"\w* una mujer viuda \w que|strong="H4994"\w* \w estaba|strong="H2009"\w* \w allí|strong="H8033"\w* \w recogiendo|strong="H7197"\w* \w leña|strong="H6086"\w*; y él la \w llamó|strong="H7121"\w* y le dijo: «Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me traigas un \w poco|strong="H4592"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w* \w en|strong="H3212"\w* un \w vaso|strong="H3627"\w*, para \w que|strong="H4994"\w* beba».   
\p
\v 11 \w Y|strong="H3068"\w* \w yendo|strong="H3212"\w* ella para traérsela, él la volvió \w a|strong="H3068"\w* \w llamar|strong="H7121"\w*, y le dijo: «Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me traigas también un bocado de \w pan|strong="H3899"\w* \w en|strong="H3212"\w* tu \w mano|strong="H3027"\w*».   
\p
\v 12 \w Y|strong="H3068"\w* ella respondió: «\w Vive|strong="H2416"\w* Yahvé \w tu|strong="H6213"\w* \w Dios|strong="H3068"\w*, \w que|strong="H3588"\w* \w no|strong="H6213"\w* \w tengo|strong="H3426"\w* pan cocido; \w solamente|strong="H3588"\w* \w tengo|strong="H3426"\w* un puñado \w de|strong="H3588"\w* \w harina|strong="H7058"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tinaja, \w y|strong="H3588"\w* un \w poco|strong="H4592"\w* \w de|strong="H3588"\w* \w aceite|strong="H8081"\w* \w en|strong="H3588"\w* una aceitera; \w y|strong="H3588"\w* ahora recogía \w dos|strong="H8147"\w* leños, \w para|strong="H3588"\w* entrar \w y|strong="H3588"\w* prepararlo \w para|strong="H3588"\w* mí \w y|strong="H3588"\w* \w para|strong="H3588"\w* mi \w hijo|strong="H1121"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w lo|strong="H6213"\w* comamos, \w y|strong="H3588"\w* nos dejemos \w morir|strong="H4191"\w*».   
\p
\v 13 Elías le dijo: “\w No|strong="H6213"\w* tengas \w temor|strong="H3372"\w*; ve, \w haz|strong="H6213"\w* como has \w dicho|strong="H1697"\w*; pero \w hazme|strong="H6213"\w* \w a|strong="H3068"\w* mí \w primero|strong="H7223"\w* \w de|strong="H1121"\w* ello una \w pequeña|strong="H6996"\w* \w torta|strong="H5692"\w* cocida debajo \w de|strong="H1121"\w* la ceniza, y tráemela; y después \w harás|strong="H6213"\w* para ti y para \w tu|strong="H6213"\w* \w hijo|strong="H1121"\w*.  
\v 14 \w Porque|strong="H3588"\w* Yahvé \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w ha|strong="H3541"\w* dicho \w así|strong="H3541"\w*: «\w La|strong="H5921"\w* tinaja \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w harina|strong="H7058"\w* \w no|strong="H3808"\w* \w escaseará|strong="H3615"\w*, \w ni|strong="H3808"\w* \w la|strong="H5921"\w* aceitera \w del|strong="H5921"\w* \w aceite|strong="H8081"\w* disminuirá, \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w en|strong="H5921"\w* \w que|strong="H3588"\w* Yahvé \w haga|strong="H5414"\w* llover \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra»».   
\p
\v 15 \w Entonces|strong="H3117"\w* \w ella|strong="H1931"\w* \w fue|strong="H3212"\w* \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w como|strong="H1931"\w* \w le|strong="H1931"\w* dijo Elías; y comió \w él|strong="H1931"\w*, y \w ella|strong="H1931"\w* y \w su|strong="H1931"\w* \w casa|strong="H1004"\w*, muchos \w días|strong="H3117"\w*.  
\v 16 \w Y|strong="H3068"\w* la tinaja \w de|strong="H1697"\w* la \w harina|strong="H7058"\w* \w no|strong="H3808"\w* \w escaseó|strong="H3615"\w*, \w ni|strong="H3808"\w* la aceitera del \w aceite|strong="H8081"\w* \w menguó|strong="H2638"\w*, conforme \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w que|strong="H3808"\w* Yahvé había \w dicho|strong="H1696"\w* \w por|strong="H1697"\w* \w medio|strong="H3027"\w* \w de|strong="H1697"\w* Elías.   
\p
\v 17 \w Después|strong="H1961"\w* \w de|strong="H5704"\w* estas \w cosas|strong="H1697"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3808"\w* cayó \w enfermo|strong="H2470"\w* \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* del ama \w de|strong="H5704"\w* la \w casa|strong="H1004"\w*; \w y|strong="H5704"\w* la \w enfermedad|strong="H2483"\w* \w fue|strong="H1961"\w* \w tan|strong="H3966"\w* \w grave|strong="H2389"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w quedó|strong="H3498"\w* \w en|strong="H5704"\w* \w él|strong="H1121"\w* aliento.  
\v 18 \w Y|strong="H3068"\w* ella dijo \w a|strong="H3068"\w* Elías: «¿\w Qué|strong="H4100"\w* tengo yo contigo, varón \w de|strong="H1121"\w* Dios? ¿\w Has|strong="H4191"\w* venido \w a|strong="H3068"\w* mí para traer \w a|strong="H3068"\w* \w memoria|strong="H2142"\w* mis ínfulas y para hacer \w morir|strong="H4191"\w* \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w*?».   
\p
\v 19 \w Él|strong="H1931"\w* \w le|strong="H1931"\w* dijo: «\w Dame|strong="H5414"\w* \w acá|strong="H8033"\w* \w a|strong="H3068"\w* tu \w hijo|strong="H1121"\w*». Entonces \w él|strong="H1931"\w* \w lo|strong="H1931"\w* \w tomó|strong="H3947"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w regazo|strong="H2436"\w*, \w y|strong="H5921"\w* \w lo|strong="H1931"\w* \w subió|strong="H5927"\w* \w al|strong="H5921"\w* aposento \w donde|strong="H8033"\w* \w él|strong="H1931"\w* \w estaba|strong="H3427"\w*, \w y|strong="H5921"\w* \w lo|strong="H1931"\w* \w puso|strong="H5414"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* \w cama|strong="H4296"\w*.  
\v 20 \w Y|strong="H3068"\w* clamando \w a|strong="H3068"\w* Yahvé, dijo: «Yahvé \w Dios|strong="H3068"\w* \w mío|strong="H5921"\w*, ¿\w aun|strong="H1571"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* viuda \w en|strong="H5921"\w* cuya casa estoy hospedado \w has|strong="H4191"\w* afligido \w matándole|strong="H4191"\w* su \w hijo|strong="H1121"\w*?».   
\p
\v 21 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* tendió \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* niño \w tres|strong="H7969"\w* \w veces|strong="H6471"\w*, \w y|strong="H5921"\w* \w clamó|strong="H7121"\w* \w a|strong="H3068"\w* Yahvé diciendo: «Yahvé \w Dios|strong="H3068"\w* \w mío|strong="H5921"\w*, \w te|strong="H5921"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* hagas \w volver|strong="H7725"\w* \w el|strong="H5921"\w* \w alma|strong="H5315"\w* \w de|strong="H5921"\w* \w este|strong="H2088"\w* niño \w a|strong="H3068"\w* \w él|strong="H5921"\w*».   
\p
\v 22 \w Y|strong="H3068"\w* Yahvé \w oyó|strong="H8085"\w* \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* Elías, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w alma|strong="H5315"\w* \w del|strong="H5921"\w* niño \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w revivió|strong="H2421"\w*.  
\v 23 \w Tomando|strong="H3947"\w* luego Elías \w al|strong="H4480"\w* niño, lo trajo \w del|strong="H4480"\w* \w aposento|strong="H1004"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w*, y lo \w dio|strong="H5414"\w* \w a|strong="H3068"\w* su madre, y le dijo Elías: «\w Mira|strong="H7200"\w*, tu \w hijo|strong="H1121"\w* \w vive|strong="H2416"\w*».   
\p
\v 24 \w Entonces|strong="H3588"\w* \w la|strong="H3588"\w* mujer dijo \w a|strong="H3068"\w* Elías: «\w Ahora|strong="H6258"\w* \w conozco|strong="H3045"\w* \w que|strong="H3588"\w* tú eres varón \w de|strong="H3588"\w* \w Dios|strong="H3068"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé \w es|strong="H2088"\w* verdad \w en|strong="H3588"\w* tu \w boca|strong="H6310"\w*».   
\c 18
\p
\v 1 \w Pasados|strong="H6440"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*, \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w a|strong="H3068"\w* Elías \w en|strong="H5921"\w* \w el|strong="H5921"\w* tercer \w año|strong="H8141"\w*, diciendo: «\w Ve|strong="H3212"\w*, \w muéstrate|strong="H7200"\w* \w a|strong="H3068"\w* Acab, \w y|strong="H5921"\w* yo enviaré \w lluvia|strong="H4306"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra».   
\p
\v 2 \w Fue|strong="H3212"\w*, \w pues|strong="H7200"\w*, Elías \w a|strong="H3068"\w* \w mostrarse|strong="H7200"\w* \w a|strong="H3068"\w* Acab. \w Y|strong="H3068"\w* el \w hambre|strong="H7458"\w* era \w grave|strong="H2389"\w* \w en|strong="H3212"\w* \w Samaria|strong="H8111"\w*.  
\v 3 \w Y|strong="H3068"\w* Acab \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Abdías|strong="H5662"\w*, su \w mayordomo|strong="H5921"\w*. (\w Abdías|strong="H5662"\w* \w era|strong="H1961"\w* \w en|strong="H5921"\w* \w gran|strong="H3966"\w* \w manera|strong="H3966"\w* \w temeroso|strong="H3373"\w* \w de|strong="H5921"\w* Yahvé;  
\v 4 porque \w cuando|strong="H1961"\w* Jezabel \w destruía|strong="H3772"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w profetas|strong="H5030"\w* \w de|strong="H4325"\w* Yahvé, \w Abdías|strong="H5662"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w cien|strong="H3967"\w* \w profetas|strong="H5030"\w* y \w los|strong="H1961"\w* escondió \w de|strong="H4325"\w* \w cincuenta|strong="H2572"\w* en \w cincuenta|strong="H2572"\w* en \w cuevas|strong="H4631"\w*, y \w los|strong="H1961"\w* sustentó con \w pan|strong="H3899"\w* y \w agua|strong="H4325"\w*).  
\v 5 \w Y|strong="H3068"\w* dijo Acab \w a|strong="H3068"\w* \w Abdías|strong="H5662"\w*: «\w Ve|strong="H3212"\w* por \w la|strong="H3605"\w* tierra \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las fuentes \w de|strong="H4325"\w* \w aguas|strong="H4325"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w arroyos|strong="H5158"\w*; quizá \w hallemos|strong="H4672"\w* \w hierba|strong="H2682"\w* con \w que|strong="H3808"\w* conservemos \w la|strong="H3605"\w* \w vida|strong="H2421"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w caballos|strong="H5483"\w* y \w a|strong="H3068"\w* las mulas, para \w que|strong="H3808"\w* \w no|strong="H3808"\w* perdamos \w todos|strong="H3605"\w* \w los|strong="H3605"\w* animales».   
\p
\v 6 \w Y|strong="H3068"\w* dividieron entre sí la tierra para recorrerla; Acab \w fue|strong="H1980"\w* \w por|strong="H1870"\w* un \w camino|strong="H1870"\w*, y \w Abdías|strong="H5662"\w* \w fue|strong="H1980"\w* solo \w por|strong="H1870"\w* otro.  
\v 7 \w Y|strong="H3068"\w* yendo \w Abdías|strong="H5662"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*, \w se|strong="H1961"\w* encontró \w con|strong="H5921"\w* Elías; \w y|strong="H5921"\w* \w cuando|strong="H1961"\w* \w lo|strong="H2088"\w* reconoció, \w se|strong="H1961"\w* postró \w sobre|strong="H5921"\w* su \w rostro|strong="H6440"\w* \w y|strong="H5921"\w* dijo: «¿\w No|strong="H1961"\w* \w eres|strong="H1961"\w* tú \w mi|strong="H5921"\w* señor Elías?».   
\p
\v 8 Él respondió: «\w Yo|strong="H2009"\w* soy; \w ve|strong="H3212"\w*, di \w a|strong="H3068"\w* tu señor: «He \w aquí|strong="H2009"\w* Elías»».   
\p
\v 9 \w Pero|strong="H3588"\w* \w él|strong="H3588"\w* dijo: “¿\w En|strong="H3588"\w* \w qué|strong="H3588"\w* he \w pecado|strong="H2398"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w entregues|strong="H5414"\w* \w a|strong="H3068"\w* tu \w siervo|strong="H5650"\w* \w en|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* Acab \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w mate|strong="H4191"\w*?  
