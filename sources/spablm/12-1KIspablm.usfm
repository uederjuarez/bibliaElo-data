\v 22 Pero \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Dios \w a|strong="H3068"\w* \w Semaías|strong="H8098"\w*, varón \w de|strong="H1697"\w* Dios, diciendo:  
\v 23 “Hablad \w a|strong="H3068"\w* \w Roboam|strong="H7346"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, y \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* y \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w*, y \w al|strong="H4428"\w* \w resto|strong="H3499"\w* del \w pueblo|strong="H5971"\w*, diciendo:  
\v 24 «\w Así|strong="H3541"\w* \w ha|strong="H3541"\w* \w dicho|strong="H1697"\w* Yahvé: \w No|strong="H3808"\w* \w subáis|strong="H5927"\w* \w ni|strong="H3808"\w* \w peleéis|strong="H3898"\w* \w contra|strong="H5973"\w* vuestros hermanos \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*; \w volveos|strong="H7725"\w* \w cada|strong="H1697"\w* uno \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*, \w porque|strong="H3588"\w* \w esto|strong="H2088"\w* \w lo|strong="H1697"\w* he \w hecho|strong="H1961"\w* \w yo|strong="H3588"\w*»». \w Y|strong="H3068"\w* ellos \w oyeron|strong="H8085"\w* \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé, \w y|strong="H3588"\w* \w volvieron|strong="H7725"\w* \w y|strong="H3588"\w* \w se|strong="H1961"\w* \w fueron|strong="H1961"\w*, conforme \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé.   
\p
\v 25 Entonces \w edificó|strong="H1129"\w* \w Jeroboam|strong="H3379"\w* \w a|strong="H3068"\w* Siquem \w en|strong="H3318"\w* \w el|strong="H3427"\w* \w monte|strong="H2022"\w* de Efraín, y \w habitó|strong="H3427"\w* \w en|strong="H3318"\w* \w ella|strong="H8033"\w*; y \w saliendo|strong="H3318"\w* de \w allí|strong="H8033"\w*, \w edificó|strong="H1129"\w* \w a|strong="H3068"\w* Penuel.  
\v 26 \w Y|strong="H3068"\w* dijo \w Jeroboam|strong="H3379"\w* en su \w corazón|strong="H3820"\w*: «\w Ahora|strong="H6258"\w* se \w volverá|strong="H7725"\w* el \w reino|strong="H4467"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de \w David|strong="H1732"\w*,  
\v 27 si \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w subiere|strong="H5927"\w* \w a|strong="H3068"\w* ofrecer \w sacrificios|strong="H2077"\w* en la \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Yahvé en Jerusalén; \w porque|strong="H4428"\w* \w el|strong="H6213"\w* \w corazón|strong="H3820"\w* \w de|strong="H5971"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* su \w señor|strong="H3068"\w* \w Roboam|strong="H7346"\w* \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Judá|strong="H3063"\w*, y me \w matarán|strong="H2026"\w* \w a|strong="H3068"\w* \w mí|strong="H3389"\w*, y \w se|strong="H5971"\w* \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* \w Roboam|strong="H7346"\w* \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Judá|strong="H3063"\w*».  
\v 28 \w Y|strong="H3068"\w* habiendo tomado \w consejo|strong="H3289"\w*, \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w rey|strong="H4428"\w* \w dos|strong="H8147"\w* \w becerros|strong="H5695"\w* de \w oro|strong="H2091"\w*, y dijo \w al|strong="H4428"\w* \w pueblo|strong="H7227"\w*: «Bastante habéis \w subido|strong="H5927"\w* \w a|strong="H3068"\w* Jerusalén; ved \w aquí|strong="H2009"\w* vuestros dioses, oh \w Israel|strong="H3478"\w*, los cuales te \w hicieron|strong="H6213"\w* \w subir|strong="H5927"\w* de la tierra de \w Egipto|strong="H4714"\w*».  
\v 29 \w Y|strong="H3068"\w* \w puso|strong="H7760"\w* uno en Betel, y \w el|strong="H1008"\w* otro en \w Dan|strong="H1835"\w*.  
\v 30 \w Y|strong="H3068"\w* \w esto|strong="H2088"\w* \w fue|strong="H1961"\w* \w causa|strong="H1697"\w* \w de|strong="H6440"\w* \w pecado|strong="H2403"\w*; \w porque|strong="H6440"\w* el \w pueblo|strong="H5971"\w* \w iba|strong="H3212"\w* \w a|strong="H3068"\w* adorar \w delante|strong="H6440"\w* \w de|strong="H6440"\w* uno \w de|strong="H6440"\w* ellos \w hasta|strong="H5704"\w* \w Dan|strong="H1835"\w*.  
\v 31 \w Hizo|strong="H6213"\w* también \w casas|strong="H1004"\w* \w sobre|strong="H1961"\w* \w los|strong="H1121"\w* lugares \w altos|strong="H1116"\w*, \w e|strong="H3068"\w* instituyó \w sacerdotes|strong="H3548"\w* \w de|strong="H1121"\w* \w entre|strong="H3808"\w* \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w eran|strong="H1961"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w*.  
\v 32 \w Entonces|strong="H3117"\w* instituyó \w Jeroboam|strong="H3379"\w* \w fiesta|strong="H2282"\w* solemne \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w mes|strong="H2320"\w* \w octavo|strong="H8066"\w*, \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w quince|strong="H2568"\w* \w días|strong="H3117"\w* \w del|strong="H5921"\w* \w mes|strong="H2320"\w*, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w fiesta|strong="H2282"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* celebraba \w en|strong="H5921"\w* \w Judá|strong="H3063"\w*; \w y|strong="H5921"\w* \w sacrificó|strong="H2076"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*. \w Así|strong="H3651"\w* \w hizo|strong="H6213"\w* \w en|strong="H5921"\w* Betel, \w ofreciendo|strong="H2076"\w* \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w becerros|strong="H5695"\w* \w que|strong="H5921"\w* \w había|strong="H5975"\w* \w hecho|strong="H6213"\w*; \w y|strong="H5921"\w* \w puso|strong="H5975"\w* \w también|strong="H3651"\w* \w en|strong="H5921"\w* Betel \w sacerdotes|strong="H3548"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* lugares \w altos|strong="H1116"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w había|strong="H5975"\w* instituido.  
\v 33 \w Sacrificó|strong="H5927"\w*, pues, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* \w en|strong="H5921"\w* Betel, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w quince|strong="H2568"\w* \w días|strong="H3117"\w* \w del|strong="H5921"\w* \w mes|strong="H2320"\w* \w octavo|strong="H8066"\w*, \w el|strong="H5921"\w* \w mes|strong="H2320"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w había|strong="H6213"\w* inventado \w en|strong="H5921"\w* su propio corazón; \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w fiesta|strong="H2282"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w subió|strong="H5927"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w para|strong="H5921"\w* quemar incienso.   
\c 13
\p
\v 1 He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* un hombre \w de|strong="H5921"\w* \w Dios|strong="H3068"\w* vino \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* Betel \w por|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé; \w y|strong="H5921"\w* \w Jeroboam|strong="H3379"\w* \w estaba|strong="H5975"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w para|strong="H5921"\w* quemar incienso.  
\v 2 \w Y|strong="H3068"\w* \w clamó|strong="H7121"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w por|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé, diciendo: «¡\w Altar|strong="H4196"\w*, \w altar|strong="H4196"\w*! \w Así|strong="H3541"\w* \w ha|strong="H3541"\w* \w dicho|strong="H1697"\w* Yahvé: «He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w nacerá|strong="H3205"\w* un \w hijo|strong="H1121"\w* \w llamado|strong="H8034"\w* \w Josías|strong="H2977"\w*, \w el|strong="H5921"\w* cual sacrificará \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* lugares \w altos|strong="H1116"\w* \w que|strong="H5921"\w* queman \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* incienso, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w quemarán|strong="H8313"\w* \w huesos|strong="H6106"\w* \w de|strong="H5921"\w* \w hombres|strong="H1121"\w*»».  
\v 3 \w Y|strong="H3068"\w* \w aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w* \w dio|strong="H5414"\w* una señal, \w diciendo|strong="H1696"\w*: «\w Esta|strong="H2088"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* señal \w de|strong="H5921"\w* \w que|strong="H1931"\w* Yahvé ha \w hablado|strong="H1696"\w*: He \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w altar|strong="H4196"\w* \w se|strong="H1931"\w* hendirá, \w y|strong="H5921"\w* \w la|strong="H1931"\w* ceniza \w que|strong="H1931"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* \w está|strong="H2088"\w* \w se|strong="H1931"\w* \w derramará|strong="H8210"\w*».   
\p
\v 4 \w Cuando|strong="H1961"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w oyó|strong="H8085"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w del|strong="H5921"\w* hombre \w de|strong="H5921"\w* Dios, \w que|strong="H3808"\w* \w había|strong="H1961"\w* \w clamado|strong="H7121"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* Betel, \w extendiendo|strong="H7971"\w* su \w mano|strong="H3027"\w* \w desde|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*, dijo: «¡\w Prendedle|strong="H8610"\w*!». \w Mas|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w que|strong="H3808"\w* \w había|strong="H1961"\w* extendido \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w se|strong="H1961"\w* \w le|strong="H5921"\w* \w secó|strong="H3001"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w la|strong="H5921"\w* \w pudo|strong="H3201"\w* \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w sí|strong="H3808"\w*.  
\v 5 \w Y|strong="H3068"\w* el \w altar|strong="H4196"\w* \w se|strong="H4480"\w* hendió, y \w se|strong="H4480"\w* \w derramó|strong="H8210"\w* la ceniza \w del|strong="H4480"\w* \w altar|strong="H4196"\w*, conforme \w a|strong="H3068"\w* la señal \w que|strong="H4480"\w* el hombre \w de|strong="H4480"\w* \w Dios|strong="H3068"\w* había \w dado|strong="H5414"\w* \w por|strong="H4480"\w* \w palabra|strong="H1697"\w* \w de|strong="H4480"\w* Yahvé.  
\v 6 \w Entonces|strong="H7725"\w* el \w rey|strong="H4428"\w*, hablando \w al|strong="H4428"\w* hombre \w de|strong="H6440"\w* \w Dios|strong="H3068"\w*, dijo: «Suplica \w ahora|strong="H4994"\w* \w al|strong="H4428"\w* favor \w de|strong="H6440"\w* Yahvé tu \w Dios|strong="H3068"\w*, y \w ruega|strong="H6419"\w* \w por|strong="H1157"\w* \w mí|strong="H1961"\w* \w para|strong="H1961"\w* \w que|strong="H4994"\w* \w mi|strong="H1961"\w* \w mano|strong="H3027"\w* me \w sea|strong="H1961"\w* restituida».  
\p El hombre \w de|strong="H6440"\w* \w Dios|strong="H3068"\w* suplicó \w a|strong="H3068"\w* Yahvé, y la \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w se|strong="H1961"\w* \w le|strong="H1157"\w* \w restituyó|strong="H7725"\w*, y \w quedó|strong="H1961"\w* \w como|strong="H1961"\w* \w antes|strong="H6440"\w*.   
\p
\v 7 \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* \w dijo|strong="H1696"\w* \w al|strong="H4428"\w* hombre \w de|strong="H5414"\w* Dios: «Ven conmigo \w a|strong="H3068"\w* \w casa|strong="H1004"\w* y reponed fuerzas, y yo te \w daré|strong="H5414"\w* un presente».   
\p
\v 8 Pero \w el|strong="H5973"\w* hombre \w de|strong="H5973"\w* Dios dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: “\w Aunque|strong="H3808"\w* \w me|strong="H5973"\w* dieras la mitad \w de|strong="H5973"\w* tu \w casa|strong="H1004"\w*, \w no|strong="H3808"\w* iría \w contigo|strong="H5973"\w*, \w ni|strong="H3808"\w* comería \w pan|strong="H3899"\w* \w ni|strong="H3808"\w* \w bebería|strong="H8354"\w* \w agua|strong="H4325"\w* \w en|strong="H5973"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*;  
\v 9 \w porque|strong="H3588"\w* \w así|strong="H3651"\w* \w me|strong="H3588"\w* \w fue|strong="H1980"\w* \w ordenado|strong="H6680"\w* \w por|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé, diciendo: «\w No|strong="H3808"\w* \w comas|strong="H3899"\w* \w pan|strong="H3899"\w*, \w ni|strong="H3808"\w* \w bebas|strong="H8354"\w* \w agua|strong="H4325"\w*, \w ni|strong="H3808"\w* regreses \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w por|strong="H3588"\w* donde \w fueres|strong="H1980"\w*»».  
\v 10 \w Se|strong="H3808"\w* \w fue|strong="H3212"\w*, pues, \w por|strong="H1870"\w* otro \w camino|strong="H1870"\w*, y \w no|strong="H3808"\w* \w volvió|strong="H7725"\w* \w por|strong="H1870"\w* \w el|strong="H1008"\w* \w camino|strong="H1870"\w* \w por|strong="H1870"\w* donde había venido \w a|strong="H3068"\w* Betel.   
\p
\v 11 \w Moraba|strong="H3427"\w* \w entonces|strong="H3117"\w* en Betel un \w viejo|strong="H2205"\w* \w profeta|strong="H5030"\w*, \w al|strong="H4428"\w* cual vino uno \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* y le \w contó|strong="H5608"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w el|strong="H1008"\w* \w hombre|strong="H1121"\w* \w de|strong="H1121"\w* Dios \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* \w aquel|strong="H3605"\w* \w día|strong="H3117"\w* en Betel; las \w palabras|strong="H1697"\w* también \w que|strong="H1697"\w* \w había|strong="H6213"\w* \w hablado|strong="H1696"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, las \w contaron|strong="H1697"\w* \w a|strong="H3068"\w* su padre.   
\p
\v 12 \w Y|strong="H3068"\w* su padre les \w dijo|strong="H1696"\w*: «¿\w Por|strong="H1870"\w* \w qué|strong="H1121"\w* \w camino|strong="H1870"\w* se \w fue|strong="H1980"\w*?». \w Y|strong="H3068"\w* sus \w hijos|strong="H1121"\w* le mostraron \w el|strong="H1121"\w* \w camino|strong="H1870"\w* \w por|strong="H1870"\w* donde había vuelto \w el|strong="H1121"\w* \w hombre|strong="H1121"\w* \w de|strong="H1121"\w* Dios \w que|strong="H1121"\w* había venido \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 13 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* dijo \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*: «Ensilladme \w el|strong="H5921"\w* \w asno|strong="H2543"\w*». \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* \w le|strong="H5921"\w* ensillaron \w el|strong="H5921"\w* \w asno|strong="H2543"\w*, \w y|strong="H5921"\w* \w él|strong="H5921"\w* montó \w en|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 14 \w Y|strong="H3068"\w* \w yendo|strong="H3212"\w* tras \w el|strong="H3427"\w* hombre \w de|strong="H8478"\w* Dios, lo \w halló|strong="H4672"\w* \w sentado|strong="H3427"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w una|strong="H4672"\w* encina; y le dijo: «¿Eres tú \w el|strong="H3427"\w* hombre \w de|strong="H8478"\w* Dios que \w vino|strong="H3212"\w* \w de|strong="H8478"\w* \w Judá|strong="H3063"\w*?».  
\p \w Él|strong="H3427"\w* dijo: «Yo soy».   
\p
\v 15 Entonces le dijo: «\w Ven|strong="H3212"\w* conmigo \w a|strong="H3068"\w* \w casa|strong="H1004"\w* y come \w pan|strong="H3899"\w*».   
\p
\v 16 \w Mas|strong="H3899"\w* él \w respondió|strong="H7725"\w*: “\w No|strong="H3808"\w* \w podré|strong="H3201"\w* \w volver|strong="H7725"\w* con vuestra merced, \w ni|strong="H3808"\w* entraré contigo; \w ni|strong="H3808"\w* comeré \w pan|strong="H3899"\w* \w ni|strong="H3808"\w* \w beberé|strong="H8354"\w* \w agua|strong="H4325"\w* contigo en \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.  
\v 17 \w Porque|strong="H3588"\w* \w por|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé \w me|strong="H3588"\w* \w ha|strong="H3808"\w* sido \w dicho|strong="H1697"\w*: «\w No|strong="H3808"\w* \w comas|strong="H3899"\w* \w pan|strong="H3899"\w* \w ni|strong="H3808"\w* \w bebas|strong="H8354"\w* \w agua|strong="H4325"\w* \w allí|strong="H8033"\w*, \w ni|strong="H3808"\w* \w vuelvas|strong="H7725"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w por|strong="H3588"\w* \w donde|strong="H8033"\w* \w fueres|strong="H3212"\w*»».   
\p
