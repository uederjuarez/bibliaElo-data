\p
\v 40 Entonces Elías \w les|strong="H1992"\w* dijo: «\w Prended|strong="H8610"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* de \w Baal|strong="H1168"\w*, para \w que|strong="H1992"\w* no \w escape|strong="H4422"\w* ninguno».  
\p \w Y|strong="H3068"\w* \w ellos|strong="H1992"\w* \w los|strong="H1992"\w* prendieron; y \w los|strong="H1992"\w* llevó Elías al \w arroyo|strong="H5158"\w* de Cisón, y \w allí|strong="H8033"\w* \w los|strong="H1992"\w* \w degolló|strong="H7819"\w*.   
\p
\v 41 \w Y|strong="H3068"\w* dijo Elías \w a|strong="H3068"\w* Acab: «\w Sube|strong="H5927"\w*, come \w y|strong="H3588"\w* \w bebe|strong="H8354"\w*; \w porque|strong="H3588"\w* una \w lluvia|strong="H1653"\w* grande se oye».   
\p
\v 42 Acab \w subió|strong="H5927"\w* \w a|strong="H3068"\w* comer y \w a|strong="H3068"\w* \w beber|strong="H8354"\w*. \w Y|strong="H3068"\w* Elías \w subió|strong="H5927"\w* \w a|strong="H3068"\w* la \w cumbre|strong="H7218"\w* \w del|strong="H8354"\w* Carmelo, y postrándose en tierra, \w puso|strong="H7760"\w* su \w rostro|strong="H6440"\w* entre las \w rodillas|strong="H1290"\w*.  
\v 43 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* su \w criado|strong="H5288"\w*: «\w Sube|strong="H5927"\w* \w ahora|strong="H4994"\w*, y \w mira|strong="H5027"\w* \w hacia|strong="H1870"\w* el \w mar|strong="H3220"\w*».  
\p \w Y|strong="H3068"\w* él \w subió|strong="H5927"\w*, y \w miró|strong="H5027"\w*, y dijo: «\w No|strong="H1870"\w* hay \w nada|strong="H3972"\w*».  
\p \w Y|strong="H3068"\w* él le \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* decir: «\w Vuelve|strong="H7725"\w* \w siete|strong="H7651"\w* \w veces|strong="H6471"\w*».   
\p
\v 44 \w A|strong="H3068"\w* la séptima vez dijo: «\w Yo|strong="H2009"\w* veo una \w pequeña|strong="H6996"\w* \w nube|strong="H6996"\w* \w como|strong="H1961"\w* la palma de la \w mano|strong="H3709"\w* de un hombre, \w que|strong="H3808"\w* \w sube|strong="H5927"\w* del \w mar|strong="H3220"\w*».  
\p \w Y|strong="H3068"\w* él dijo: «\w Sube|strong="H5927"\w*, y di \w a|strong="H3068"\w* Acab: «Unce tu carro y \w desciende|strong="H3381"\w*, \w para|strong="H1961"\w* \w que|strong="H3808"\w* la \w lluvia|strong="H1653"\w* \w no|strong="H3808"\w* \w te|strong="H3220"\w* ataje»».   
\p
\v 45 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w*, \w estando|strong="H1961"\w* \w en|strong="H5704"\w* \w esto|strong="H3541"\w*, \w que|strong="H5704"\w* \w los|strong="H1961"\w* \w cielos|strong="H8064"\w* \w se|strong="H1961"\w* oscurecieron \w con|strong="H5704"\w* \w nubes|strong="H5645"\w* \w y|strong="H5704"\w* \w viento|strong="H7307"\w*, \w y|strong="H5704"\w* \w hubo|strong="H1961"\w* una \w gran|strong="H1419"\w* \w lluvia|strong="H1653"\w*. \w Y|strong="H3068"\w* subiendo Acab \w al|strong="H5704"\w* \w carro|strong="H7392"\w*, \w se|strong="H1961"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w Jezreel|strong="H3157"\w*.  
\v 46 \w Y|strong="H3068"\w* la \w mano|strong="H3027"\w* \w de|strong="H6440"\w* Yahvé \w estuvo|strong="H1961"\w* \w sobre|strong="H1961"\w* Elías, el cual ciñó sus \w lomos|strong="H4975"\w*, \w y|strong="H5704"\w* \w corrió|strong="H7323"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Acab \w hasta|strong="H5704"\w* llegar \w a|strong="H3068"\w* \w Jezreel|strong="H3157"\w*.   
\c 19
\p
\v 1 Acab dio \w a|strong="H3068"\w* Jezabel \w la|strong="H3605"\w* nueva de \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* Elías \w había|strong="H6213"\w* \w hecho|strong="H6213"\w*, y de cómo \w había|strong="H6213"\w* muerto \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w*.  
\v 2 \w Entonces|strong="H3588"\w* \w envió|strong="H7971"\w* Jezabel un \w mensajero|strong="H4397"\w* \w a|strong="H3068"\w* Elías, diciendo: «¡\w Así|strong="H3541"\w* \w me|strong="H3588"\w* \w hagan|strong="H6213"\w* \w los|strong="H1992"\w* dioses, \w y|strong="H3588"\w* \w aun|strong="H3254"\w* \w me|strong="H3588"\w* \w añadan|strong="H3254"\w*, \w si|strong="H3588"\w* \w para|strong="H3588"\w* \w mañana|strong="H4279"\w* \w a|strong="H3068"\w* \w estas|strong="H1992"\w* horas \w yo|strong="H3588"\w* \w no|strong="H6213"\w* he \w puesto|strong="H3588"\w* \w tu|strong="H6213"\w* \w vida|strong="H5315"\w* \w como|strong="H3588"\w* \w la|strong="H3588"\w* \w de|strong="H3588"\w* uno \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*!».   
\p
\v 3 \w Viendo|strong="H7200"\w*, \w pues|strong="H7200"\w*, el peligro, se \w levantó|strong="H6965"\w* y huyó para salvar su \w vida|strong="H5315"\w*, y \w llegó|strong="H3212"\w* \w a|strong="H3068"\w* Beerseba, que pertenece \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*, y dejó \w allí|strong="H8033"\w* \w a|strong="H3068"\w* su \w criado|strong="H5288"\w*.  
\v 4 \w Y|strong="H3068"\w* \w él|strong="H1931"\w* \w se|strong="H1931"\w* \w fue|strong="H1980"\w* \w por|strong="H3588"\w* \w el|strong="H1931"\w* \w desierto|strong="H4057"\w* un \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w camino|strong="H1870"\w*, \w y|strong="H3588"\w* \w vino|strong="H1870"\w* \w y|strong="H3588"\w* \w se|strong="H1931"\w* sentó \w debajo|strong="H8478"\w* \w de|strong="H3588"\w* una retama; \w y|strong="H3588"\w* deseando \w morir|strong="H4191"\w*, dijo: «\w Basta|strong="H7227"\w* \w ya|strong="H6258"\w*, oh Yahvé, \w quita|strong="H3947"\w* \w mi|strong="H5315"\w* \w vida|strong="H5315"\w*, \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w soy|strong="H1931"\w* \w yo|strong="H3588"\w* \w mejor|strong="H2896"\w* \w que|strong="H3588"\w* mis padres».   
\p
\v 5 \w Y|strong="H3068"\w* \w echándose|strong="H7901"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* la retama, se quedó dormido; y he \w aquí|strong="H2088"\w* \w luego|strong="H2088"\w* un \w ángel|strong="H4397"\w* le \w tocó|strong="H5060"\w*, y le dijo: «\w Levántate|strong="H6965"\w*, come».   
\p
\v 6 \w Entonces|strong="H7725"\w* él \w miró|strong="H5027"\w*, y he \w aquí|strong="H2009"\w* \w a|strong="H3068"\w* su \w cabecera|strong="H4763"\w* una \w torta|strong="H5692"\w* cocida sobre las ascuas, y una vasija \w de|strong="H4325"\w* \w agua|strong="H4325"\w*; y comió y \w bebió|strong="H8354"\w*, y \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* dormirse.  
\v 7 \w Y|strong="H3068"\w* \w volviendo|strong="H7725"\w* \w el|strong="H3588"\w* \w ángel|strong="H4397"\w* \w de|strong="H4480"\w* Yahvé \w la|strong="H3588"\w* \w segunda|strong="H8145"\w* vez, le \w tocó|strong="H5060"\w*, diciendo: «\w Levántate|strong="H6965"\w* \w y|strong="H3588"\w* come, \w porque|strong="H3588"\w* largo \w camino|strong="H1870"\w* \w te|strong="H4480"\w* resta».   
\p
\v 8 \w Se|strong="H1931"\w* \w levantó|strong="H6965"\w*, \w pues|strong="H1931"\w*, \w y|strong="H5704"\w* comió \w y|strong="H5704"\w* \w bebió|strong="H8354"\w*; \w y|strong="H5704"\w* fortalecido \w con|strong="H5704"\w* \w aquella|strong="H1931"\w* comida caminó cuarenta \w días|strong="H3117"\w* \w y|strong="H5704"\w* cuarenta \w noches|strong="H3915"\w* \w hasta|strong="H5704"\w* \w Horeb|strong="H2722"\w*, \w el|strong="H1931"\w* \w monte|strong="H2022"\w* \w de|strong="H5704"\w* Dios.  
\v 9 \w Y|strong="H3068"\w* \w allí|strong="H8033"\w* \w se|strong="H4100"\w* metió en una \w cueva|strong="H4631"\w*, \w donde|strong="H8033"\w* pasó la noche. \w Y|strong="H3068"\w* \w vino|strong="H4100"\w* \w a|strong="H3068"\w* \w él|strong="H3885"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, \w el|strong="H3885"\w* \w cual|strong="H4100"\w* le dijo: «¿\w Qué|strong="H4100"\w* haces \w aquí|strong="H6311"\w*, Elías?».   
\p
\v 10 \w Él|strong="H3588"\w* respondió: «He sentido un vivo \w celo|strong="H7065"\w* \w por|strong="H3588"\w* Yahvé \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w*; \w porque|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* han dejado vuestro \w pacto|strong="H1285"\w*, han derribado vuestros \w altares|strong="H4196"\w*, \w y|strong="H3588"\w* han matado \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* vuestros \w profetas|strong="H5030"\w*; \w y|strong="H3588"\w* solo \w yo|strong="H3588"\w* he quedado, \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w buscan|strong="H1245"\w* \w para|strong="H3588"\w* \w quitarme|strong="H3947"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w*».   
\p
\v 11 \w Él|strong="H5674"\w* le dijo: «\w Sal|strong="H3318"\w* \w fuera|strong="H3318"\w*, y \w ponte|strong="H5975"\w* \w en|strong="H3318"\w* \w el|strong="H5674"\w* \w monte|strong="H2022"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé».  
\p \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* Yahvé \w pasaba|strong="H5674"\w*, y un \w grande|strong="H1419"\w* y poderoso \w viento|strong="H7307"\w* rompía los \w montes|strong="H2022"\w*, y quebraba las peñas \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé; pero Yahvé \w no|strong="H3808"\w* \w estaba|strong="H5975"\w* \w en|strong="H3318"\w* \w el|strong="H5674"\w* \w viento|strong="H7307"\w*. \w Y|strong="H3068"\w* tras \w el|strong="H5674"\w* \w viento|strong="H7307"\w* un terremoto; pero Yahvé \w no|strong="H3808"\w* \w estaba|strong="H5975"\w* \w en|strong="H3318"\w* \w el|strong="H5674"\w* terremoto.  
\v 12 \w Y|strong="H3068"\w* tras el terremoto un fuego; pero Yahvé \w no|strong="H3808"\w* estaba en el fuego. \w Y|strong="H3068"\w* tras el fuego un silbo \w apacible|strong="H1827"\w* y delicado.  
\v 13 \w Y|strong="H3068"\w* \w cuando|strong="H4100"\w* \w lo|strong="H4100"\w* \w oyó|strong="H8085"\w* Elías, cubrió su \w rostro|strong="H6440"\w* con su manto, y \w salió|strong="H3318"\w* y \w se|strong="H1961"\w* \w puso|strong="H5975"\w* \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* \w de|strong="H6440"\w* la \w cueva|strong="H4631"\w*. \w Y|strong="H3068"\w* he \w aquí|strong="H6311"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* él una \w voz|strong="H6963"\w*, diciendo: «¿\w Qué|strong="H4100"\w* haces \w aquí|strong="H6311"\w*, Elías?».   
\p
\v 14 \w Él|strong="H3588"\w* respondió: «He sentido un vivo \w celo|strong="H7065"\w* \w por|strong="H3588"\w* Yahvé \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w Ejércitos|strong="H6635"\w*; \w porque|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* han dejado vuestro \w pacto|strong="H1285"\w*, han derribado vuestros \w altares|strong="H4196"\w*, \w y|strong="H3588"\w* han matado \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* vuestros \w profetas|strong="H5030"\w*; \w y|strong="H3588"\w* solo \w yo|strong="H3588"\w* he quedado, \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w buscan|strong="H1245"\w* \w para|strong="H3588"\w* \w quitarme|strong="H3947"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w*».   
\p
\v 15 \w Y|strong="H3068"\w* \w le|strong="H5921"\w* dijo Yahvé: «\w Ve|strong="H3212"\w*, \w vuelve|strong="H7725"\w* \w por|strong="H5921"\w* tu \w camino|strong="H1870"\w*, \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w* \w de|strong="H5921"\w* \w Damasco|strong="H1834"\w*; \w y|strong="H5921"\w* llegarás, \w y|strong="H5921"\w* \w ungirás|strong="H4886"\w* \w a|strong="H3068"\w* \w Hazael|strong="H2371"\w* \w por|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria.  
\v 16 \w A|strong="H3068"\w* \w Jehú|strong="H3058"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nimsí \w ungirás|strong="H4886"\w* \w por|strong="H5921"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*; \w y|strong="H5921"\w* \w a|strong="H3068"\w* Eliseo \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Safat, \w de|strong="H5921"\w* Abel-mejolá, \w ungirás|strong="H4886"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* sea \w profeta|strong="H5030"\w* \w en|strong="H5921"\w* tu \w lugar|strong="H8478"\w*.  
\v 17 \w Y|strong="H3068"\w* el \w que|strong="H1961"\w* escapare de la \w espada|strong="H2719"\w* de \w Hazael|strong="H2371"\w*, \w Jehú|strong="H3058"\w* lo \w matará|strong="H4191"\w*; y el \w que|strong="H1961"\w* escapare de la \w espada|strong="H2719"\w* de \w Jehú|strong="H3058"\w*, Eliseo lo \w matará|strong="H4191"\w*.  
\v 18 \w Y|strong="H3068"\w* yo haré \w que|strong="H3808"\w* queden en \w Israel|strong="H3478"\w* \w siete|strong="H7651"\w* mil, cuyas \w rodillas|strong="H1290"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* doblaron ante \w Baal|strong="H1168"\w*, y cuyas \w bocas|strong="H6310"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* besaron».   
\p
\v 19 Partiendo \w él|strong="H1931"\w* \w de|strong="H6440"\w* \w allí|strong="H8033"\w*, \w halló|strong="H4672"\w* \w a|strong="H3068"\w* Eliseo \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Safat, \w que|strong="H1931"\w* araba con \w doce|strong="H8147"\w* \w yuntas|strong="H6776"\w* \w de|strong="H6440"\w* bueyes \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w sí|strong="H1931"\w*, y \w él|strong="H1931"\w* \w tenía|strong="H1931"\w* \w la|strong="H1931"\w* última. \w Y|strong="H3068"\w* \w pasando|strong="H5674"\w* Elías \w por|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H1931"\w*, \w echó|strong="H7993"\w* \w sobre|strong="H5674"\w* \w él|strong="H1931"\w* \w su|strong="H1931"\w* manto.  
\v 20 \w Entonces|strong="H3588"\w* \w dejando|strong="H5800"\w* \w él|strong="H3588"\w* \w los|strong="H3588"\w* \w bueyes|strong="H1241"\w*, \w vino|strong="H3212"\w* \w corriendo|strong="H7323"\w* tras Elías, \w y|strong="H3588"\w* dijo: «\w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w dejes|strong="H5800"\w* \w besar|strong="H5401"\w* \w a|strong="H3068"\w* \w mi|strong="H4994"\w* padre \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w mi|strong="H4994"\w* madre, \w y|strong="H3588"\w* \w luego|strong="H4994"\w* \w te|strong="H3588"\w* seguiré».  
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* le dijo: «\w Vuelve|strong="H7725"\w*, ¿\w qué|strong="H3588"\w* \w te|strong="H3588"\w* he \w hecho|strong="H6213"\w* \w yo|strong="H3588"\w*?».   
\p
\v 21 \w Y|strong="H3068"\w* \w se|strong="H5971"\w* \w volvió|strong="H7725"\w*, \w y|strong="H1241"\w* \w tomó|strong="H3947"\w* un \w par|strong="H6776"\w* \w de|strong="H5971"\w* \w bueyes|strong="H1241"\w* \w y|strong="H1241"\w* los \w mató|strong="H2076"\w*, \w y|strong="H1241"\w* con \w el|strong="H1310"\w* arreo \w de|strong="H5971"\w* los \w bueyes|strong="H1241"\w* \w coció|strong="H1310"\w* la \w carne|strong="H1320"\w*, \w y|strong="H1241"\w* la \w dio|strong="H5414"\w* al \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* comiese. Después \w se|strong="H5971"\w* \w levantó|strong="H6965"\w* \w y|strong="H1241"\w* \w fue|strong="H3212"\w* tras Elías, \w y|strong="H1241"\w* le \w servía|strong="H8334"\w*.   
\c 20
\p
\v 1 \w Ben-adad|strong="H1130"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria, reunió \w a|strong="H3068"\w* \w todo|strong="H3605"\w* su \w ejército|strong="H2426"\w*, \w y|strong="H5921"\w* había \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w treinta|strong="H7970"\w* \w y|strong="H5921"\w* \w dos|strong="H8147"\w* \w reyes|strong="H4428"\w*, \w con|strong="H5921"\w* \w caballos|strong="H5483"\w* \w y|strong="H5921"\w* \w carros|strong="H7393"\w*; \w y|strong="H5921"\w* \w subió|strong="H5927"\w* \w y|strong="H5921"\w* sitió \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* combatió.  
\v 2 \w Y|strong="H3068"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w*, \w a|strong="H3068"\w* Acab \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*, diciéndole: “Así ha dicho Ben-adad:  
\v 3 «Tu \w plata|strong="H3701"\w* \w y|strong="H3541"\w* tu \w oro|strong="H2091"\w* son \w míos|strong="H1992"\w*, \w y|strong="H3541"\w* tus mujeres \w y|strong="H3541"\w* tus \w hijos|strong="H1121"\w* más \w hermosos|strong="H2896"\w* son \w míos|strong="H1992"\w*»».   
\p
\v 4 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w* \w respondió|strong="H6030"\w* y dijo: «Como tú \w dices|strong="H1697"\w*, \w rey|strong="H4428"\w* señor mío, yo soy tuyo, y \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* tengo».   
\p
