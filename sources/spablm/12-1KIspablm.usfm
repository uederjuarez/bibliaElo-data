\v 31 \w Entonces|strong="H3588"\w* \w sus|strong="H1992"\w* \w siervos|strong="H5650"\w* le dijeron: «He \w aquí|strong="H2009"\w*, hemos \w oído|strong="H8085"\w* \w que|strong="H3588"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w son|strong="H3588"\w* \w reyes|strong="H4428"\w* \w clementes|strong="H2617"\w*; \w pongamos|strong="H7760"\w*, \w pues|strong="H3588"\w*, \w ahora|strong="H4994"\w* \w sacos|strong="H8242"\w* \w en|strong="H3588"\w* nuestros \w lomos|strong="H4975"\w*, \w y|strong="H3588"\w* \w sogas|strong="H2256"\w* \w a|strong="H3068"\w* nuestros cuellos, \w y|strong="H3588"\w* \w salgamos|strong="H3318"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* ver \w si|strong="H3588"\w* \w por|strong="H3588"\w* ventura \w te|strong="H3588"\w* salva \w la|strong="H3588"\w* \w vida|strong="H5315"\w*».   
\p
\v 32 \w Ciñeron|strong="H2296"\w*, \w pues|strong="H4994"\w*, \w sus|strong="H1931"\w* \w lomos|strong="H4975"\w* con \w sacos|strong="H8242"\w*, y pusieron \w sogas|strong="H2256"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* cuellos, y vinieron \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w* y \w le|strong="H1931"\w* dijeron: «Tu \w siervo|strong="H5650"\w* \w Ben-adad|strong="H1130"\w* dice: «\w Te|strong="H5315"\w* \w ruego|strong="H4994"\w* \w que|strong="H1931"\w* dejes \w vivir|strong="H2421"\w* \w mi|strong="H4994"\w* \w alma|strong="H5315"\w*»». \w Y|strong="H3068"\w* \w él|strong="H1931"\w* respondió: «\w Si|strong="H1931"\w* \w él|strong="H1931"\w* \w vive|strong="H2416"\w* \w aún|strong="H5750"\w*, \w mi|strong="H4994"\w* hermano \w es|strong="H1931"\w*».   
\p
\v 33 Esto \w tomaron|strong="H3947"\w* aquellos hombres \w por|strong="H5921"\w* buena señal, \w y|strong="H5921"\w* \w se|strong="H5921"\w* apresuraron \w a|strong="H3068"\w* \w tomar|strong="H3947"\w* \w la|strong="H5921"\w* palabra \w de|strong="H4480"\w* su boca, \w y|strong="H5921"\w* dijeron: «¡Tu hermano \w Ben-adad|strong="H1130"\w*!». \w Y|strong="H3068"\w* \w él|strong="H5921"\w* dijo: «\w Id|strong="H5927"\w*, traedle». \w Ben-adad|strong="H1130"\w* entonces \w salió|strong="H3318"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w él|strong="H5921"\w* \w le|strong="H5921"\w* \w hizo|strong="H5927"\w* \w subir|strong="H5927"\w* \w en|strong="H5921"\w* su \w carro|strong="H4818"\w*.  
\v 34 \w Y|strong="H3068"\w* le dijo Ben-adad: «Las \w ciudades|strong="H5892"\w* que mi padre \w tomó|strong="H3947"\w* al tuyo, yo las restituiré; y hazte \w plazas|strong="H2351"\w* en \w Damasco|strong="H1834"\w*, como mi padre las \w hizo|strong="H3772"\w* en \w Samaria|strong="H8111"\w*». «\w Y|strong="H3068"\w* yo —dijo Acab— te \w dejaré|strong="H7971"\w* partir con esta \w alianza|strong="H1285"\w*». \w Hizo|strong="H3772"\w*, \w pues|strong="H7971"\w*, \w alianza|strong="H1285"\w* con él, y le \w dejó|strong="H7971"\w* \w ir|strong="H7971"\w*.   
\p
\v 35 Entonces un varón \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w profetas|strong="H5030"\w* dijo \w a|strong="H3068"\w* su \w compañero|strong="H7453"\w* \w por|strong="H1697"\w* \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé: «\w Hiéreme|strong="H5221"\w* \w ahora|strong="H4994"\w*, te \w ruego|strong="H4994"\w*». \w Mas|strong="H7453"\w* \w el|strong="H1121"\w* \w otro|strong="H7453"\w* \w no|strong="H3985"\w* quiso \w herirle|strong="H5221"\w*.  
\v 36 Él le dijo: «\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w no|strong="H3808"\w* has obedecido \w a|strong="H3068"\w* la \w voz|strong="H6963"\w* de Yahvé, he \w aquí|strong="H2005"\w* \w que|strong="H3808"\w* cuando te apartes de mí, te \w herirá|strong="H5221"\w* un león». \w Y|strong="H3068"\w* cuando \w se|strong="H3808"\w* apartó de él, le \w salió|strong="H3212"\w* al encuentro un león y le \w mató|strong="H5221"\w*.   
\p
\v 37 Se encontró \w luego|strong="H4994"\w* con otro hombre, y le dijo: «\w Hiéreme|strong="H5221"\w* \w ahora|strong="H4994"\w*, te \w ruego|strong="H4994"\w*». \w Y|strong="H3068"\w* el hombre le dio un golpe, y le hizo \w una|strong="H4672"\w* herida.  
\v 38 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w se|strong="H5921"\w* \w fue|strong="H3212"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w puso|strong="H5975"\w* \w delante|strong="H5869"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*, disfrazado \w con|strong="H5921"\w* un vendaje \w sobre|strong="H5921"\w* sus \w ojos|strong="H5869"\w*.  
\v 39 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w pasaba|strong="H5674"\w*, \w él|strong="H1931"\w* \w clamó|strong="H6817"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, diciendo: “Tu \w siervo|strong="H5650"\w* \w salió|strong="H3318"\w* \w en|strong="H3318"\w* \w medio|strong="H7130"\w* \w de|strong="H8478"\w* \w la|strong="H1931"\w* \w batalla|strong="H4421"\w*; y he \w aquí|strong="H2009"\w* \w se|strong="H1961"\w* me acercó un hombre y me \w trajo|strong="H5493"\w* \w a|strong="H3068"\w* \w otro|strong="H2088"\w*, diciéndome: «\w Guarda|strong="H8104"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* hombre, y \w si|strong="H1931"\w* llegare \w a|strong="H3068"\w* faltar, tu \w vida|strong="H5315"\w* \w será|strong="H1961"\w* \w por|strong="H8478"\w* \w la|strong="H1931"\w* \w suya|strong="H1931"\w*, \w o|strong="H3068"\w* \w pagarás|strong="H8254"\w* un talento\f + \fr 20:39 \ft Un talento son unos 30 kilos o 66 libras\f* \w de|strong="H8478"\w* \w plata|strong="H3701"\w*».  
\v 40 \w Y|strong="H3068"\w* mientras \w tu|strong="H6213"\w* \w siervo|strong="H5650"\w* \w estaba|strong="H1961"\w* ocupado en una y \w otra|strong="H6213"\w* cosa, \w el|strong="H1931"\w* hombre desapareció”. \w Entonces|strong="H3651"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w* \w le|strong="H1931"\w* dijo: «\w Esa|strong="H1931"\w* \w será|strong="H1961"\w* \w tu|strong="H6213"\w* \w sentencia|strong="H4941"\w*; \w tú|strong="H6213"\w* \w la|strong="H1931"\w* has pronunciado».   
\p
\v 41 \w Pero|strong="H3588"\w* \w él|strong="H1931"\w* \w se|strong="H1931"\w* \w quitó|strong="H5493"\w* \w de|strong="H5921"\w* \w pronto|strong="H4116"\w* \w el|strong="H1931"\w* vendaje \w de|strong="H5921"\w* \w sus|strong="H1931"\w* \w ojos|strong="H5869"\w*, \w y|strong="H3588"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w conoció|strong="H5234"\w* \w que|strong="H3588"\w* \w era|strong="H1931"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w*.  
\v 42 \w Y|strong="H3068"\w* él le dijo: «\w Así|strong="H3541"\w* \w ha|strong="H3541"\w* dicho Yahvé: «\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* dejaste escapar \w de|strong="H8478"\w* tu \w mano|strong="H3027"\w* \w al|strong="H8478"\w* hombre \w que|strong="H5971"\w* \w yo|strong="H5315"\w* \w había|strong="H1961"\w* consagrado \w a|strong="H3068"\w* la muerte, tu \w vida|strong="H5315"\w* \w será|strong="H1961"\w* \w por|strong="H3282"\w* la suya, \w y|strong="H3541"\w* tu \w pueblo|strong="H5971"\w* \w por|strong="H3282"\w* el \w suyo|strong="H5971"\w*»».   
\p
\v 43 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w se|strong="H5921"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* abatido \w y|strong="H5921"\w* colérico, \w y|strong="H5921"\w* \w llegó|strong="H3212"\w* \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*.   
\c 21
\p
\v 1 Pasadas estas \w cosas|strong="H1697"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H1697"\w* Nabot \w de|strong="H1697"\w* \w Jezreel|strong="H3157"\w* \w tenía|strong="H1961"\w* allí una \w viña|strong="H3754"\w* junto \w al|strong="H4428"\w* palacio \w de|strong="H1697"\w* Acab, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Samaria|strong="H8111"\w*.  
\v 2 \w Y|strong="H3068"\w* Acab \w habló|strong="H1696"\w* \w a|strong="H3068"\w* Nabot, \w diciendo|strong="H1696"\w*: «\w Dadme|strong="H5414"\w* tu \w viña|strong="H3754"\w* \w para|strong="H3588"\w* tenerla \w por|strong="H3588"\w* huerta \w de|strong="H4480"\w* hortalizas, \w porque|strong="H3588"\w* \w está|strong="H2088"\w* \w cerca|strong="H7138"\w* \w de|strong="H4480"\w* \w mi|strong="H1961"\w* \w casa|strong="H1004"\w*, \w y|strong="H3588"\w* \w yo|strong="H4480"\w* \w te|strong="H5869"\w* \w daré|strong="H5414"\w* \w por|strong="H3588"\w* \w ella|strong="H1931"\w* otra \w viña|strong="H3754"\w* \w mejor|strong="H2896"\w* \w que|strong="H3588"\w* \w esta|strong="H2088"\w*; \w o|strong="H3068"\w* \w si|strong="H3588"\w* \w mejor|strong="H2896"\w* \w te|strong="H5869"\w* \w pareciere|strong="H5869"\w*, \w te|strong="H5869"\w* \w pagaré|strong="H5414"\w* \w su|strong="H1931"\w* valor \w en|strong="H4480"\w* \w dinero|strong="H3701"\w*».   
\p
\v 3 Nabot respondió \w a|strong="H3068"\w* Acab: «¡Líbeme Yahvé \w de|strong="H5414"\w* daros yo la \w heredad|strong="H5159"\w* \w de|strong="H5414"\w* \w mis|strong="H5414"\w* padres!».   
\p
\v 4 \w Y|strong="H3068"\w* vino Acab \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* \w triste|strong="H5620"\w* \w y|strong="H5921"\w* enojado \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w que|strong="H3808"\w* Nabot \w de|strong="H5921"\w* Jezreel \w le|strong="H5921"\w* había respondido, \w diciendo|strong="H1696"\w*: «\w No|strong="H3808"\w* \w te|strong="H5921"\w* \w daré|strong="H5414"\w* \w la|strong="H5921"\w* \w heredad|strong="H5159"\w* \w de|strong="H5921"\w* \w mis|strong="H5414"\w* padres». \w Y|strong="H3068"\w* \w se|strong="H5921"\w* echó \w en|strong="H5921"\w* su lecho, \w y|strong="H5921"\w* \w volvió|strong="H5414"\w* su \w rostro|strong="H6440"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* comió \w pan|strong="H3899"\w*.  
\v 5 \w Vino|strong="H4100"\w* \w a|strong="H3068"\w* él su mujer Jezabel, y le \w dijo|strong="H1696"\w*: «¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* \w está|strong="H2088"\w* tan decaído tu \w espíritu|strong="H7307"\w*, y \w no|strong="H4100"\w* comes \w pan|strong="H3899"\w*?».   
\p
\v 6 \w Él|strong="H3588"\w* respondió: «\w Porque|strong="H3588"\w* \w hablé|strong="H1696"\w* \w con|strong="H3588"\w* Nabot \w de|strong="H3588"\w* Jezreel, \w y|strong="H3588"\w* le \w dije|strong="H1696"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w diera|strong="H5414"\w* \w su|strong="H3588"\w* \w viña|strong="H3754"\w* \w por|strong="H3588"\w* \w dinero|strong="H3701"\w*, \w o|strong="H3068"\w* \w que|strong="H3588"\w* \w si|strong="H3588"\w* prefería, le \w daría|strong="H5414"\w* otra \w viña|strong="H3754"\w* \w por|strong="H3588"\w* ella; \w y|strong="H3588"\w* \w él|strong="H3588"\w* respondió: «\w Yo|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w daré|strong="H5414"\w* mi \w viña|strong="H3754"\w*»».   
\p
\v 7 \w Y|strong="H3068"\w* su mujer Jezabel \w le|strong="H5921"\w* dijo: «¿Eres \w tú|strong="H6213"\w* \w ahora|strong="H6258"\w* \w el|strong="H5921"\w* \w que|strong="H6258"\w* gobierna \w el|strong="H5921"\w* \w reino|strong="H4410"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*? \w Levántate|strong="H6965"\w*, \w y|strong="H5921"\w* come \w pan|strong="H3899"\w* \w y|strong="H5921"\w* alégrate; \w yo|strong="H6213"\w* \w te|strong="H5921"\w* \w daré|strong="H5414"\w* \w la|strong="H5921"\w* \w viña|strong="H3754"\w* \w de|strong="H5921"\w* Nabot \w de|strong="H5921"\w* Jezreel».  
\v 8 Entonces ella \w escribió|strong="H3789"\w* \w cartas|strong="H5612"\w* en \w nombre|strong="H8034"\w* de Acab, y las selló con su anillo, y las \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* y \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w principales|strong="H2715"\w* que \w moraban|strong="H3427"\w* en la \w ciudad|strong="H5892"\w* con Nabot.  
\v 9 \w Y|strong="H3068"\w* \w escribió|strong="H3789"\w* en las \w cartas|strong="H5612"\w*, diciendo: “\w Proclamad|strong="H7121"\w* \w ayuno|strong="H6685"\w*, y poned \w a|strong="H3068"\w* Nabot \w a|strong="H3068"\w* la \w cabeza|strong="H7218"\w* del \w pueblo|strong="H5971"\w*;  
\v 10 y poned \w a|strong="H3068"\w* \w dos|strong="H8147"\w* \w hombres|strong="H1121"\w* \w perversos|strong="H1121"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* \w él|strong="H1121"\w*, \w que|strong="H1121"\w* atestigüen \w contra|strong="H5048"\w* \w él|strong="H1121"\w* y digan: «Tú \w has|strong="H4191"\w* \w blasfemado|strong="H1288"\w* \w contra|strong="H5048"\w* Dios y \w contra|strong="H5048"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w*». \w Y|strong="H3068"\w* entonces sacadle, y apedreadle para \w que|strong="H1121"\w* \w muera|strong="H4191"\w*”.   
\p
\v 11 \w Y|strong="H3068"\w* \w los|strong="H3427"\w* de su \w ciudad|strong="H5892"\w*, \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* y \w los|strong="H3427"\w* \w principales|strong="H2715"\w* que \w moraban|strong="H3427"\w* en su \w ciudad|strong="H5892"\w*, \w lo|strong="H5612"\w* \w hicieron|strong="H6213"\w* como Jezabel les \w mandó|strong="H7971"\w*, conforme \w a|strong="H3068"\w* \w lo|strong="H5612"\w* \w escrito|strong="H3789"\w* en las \w cartas|strong="H5612"\w* que ella les \w había|strong="H6213"\w* \w enviado|strong="H7971"\w*.  
\v 12 Proclamaron \w ayuno|strong="H6685"\w*, y pusieron \w a|strong="H3068"\w* Nabot \w a|strong="H3068"\w* la \w cabeza|strong="H7218"\w* del \w pueblo|strong="H5971"\w*.  
\v 13 Vinieron entonces \w dos|strong="H8147"\w* \w hombres|strong="H1121"\w* \w perversos|strong="H1121"\w*, y \w se|strong="H5971"\w* \w sentaron|strong="H3427"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* \w él|strong="H1121"\w*; y aquellos \w hombres|strong="H1121"\w* \w perversos|strong="H1121"\w* \w atestiguaron|strong="H5749"\w* \w contra|strong="H5048"\w* Nabot \w delante|strong="H5048"\w* del \w pueblo|strong="H5971"\w*, diciendo: «Nabot ha \w blasfemado|strong="H1288"\w* \w contra|strong="H5048"\w* Dios y \w contra|strong="H5048"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w*». \w Y|strong="H3068"\w* lo llevaron \w fuera|strong="H2351"\w* \w de|strong="H5048"\w* la \w ciudad|strong="H5892"\w* y lo apedrearon con piedras, y \w murió|strong="H4191"\w*.  
\v 14 Después \w enviaron|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Jezabel: «Nabot ha sido \w apedreado|strong="H5619"\w* y ha \w muerto|strong="H4191"\w*».   
\p
\v 15 \w Cuando|strong="H3588"\w* Jezabel \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* Nabot \w había|strong="H1961"\w* \w sido|strong="H1961"\w* \w apedreado|strong="H5619"\w* \w y|strong="H3588"\w* \w muerto|strong="H4191"\w*, dijo \w a|strong="H3068"\w* Acab: «\w Levántate|strong="H6965"\w* \w y|strong="H3588"\w* toma posesión \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w viña|strong="H3754"\w* \w de|strong="H3588"\w* Nabot \w de|strong="H3588"\w* Jezreel, \w que|strong="H3588"\w* \w no|strong="H3985"\w* \w te|strong="H3588"\w* \w la|strong="H3588"\w* quiso \w dar|strong="H5414"\w* \w por|strong="H3588"\w* \w dinero|strong="H3701"\w*; \w porque|strong="H3588"\w* Nabot \w no|strong="H3985"\w* \w vive|strong="H2416"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w ha|strong="H3423"\w* \w muerto|strong="H4191"\w*».   
\p
\v 16 \w Y|strong="H3068"\w* \w oyendo|strong="H8085"\w* Acab \w que|strong="H3588"\w* Nabot \w era|strong="H1961"\w* \w muerto|strong="H4191"\w*, \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* \w para|strong="H3588"\w* descender \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w viña|strong="H3754"\w* \w de|strong="H3588"\w* Nabot \w de|strong="H3588"\w* Jezreel, \w para|strong="H3588"\w* tomar posesión \w de|strong="H3588"\w* ella.   
\p
\v 17 Entonces \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* Elías tisbita, diciendo:  
\v 18 «\w Levántate|strong="H6965"\w*, \w desciende|strong="H3381"\w* \w a|strong="H3068"\w* encontrarte con Acab \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*, que \w está|strong="H6965"\w* en \w Samaria|strong="H8111"\w*; he \w aquí|strong="H2009"\w* él \w está|strong="H6965"\w* en la \w viña|strong="H3754"\w* de Nabot, \w a|strong="H3068"\w* la cual \w ha|strong="H3423"\w* descendido para tomar posesión de \w ella|strong="H8033"\w*.  
\v 19 \w Y|strong="H3068"\w* le \w hablarás|strong="H1696"\w* \w diciendo|strong="H1696"\w*: «\w Así|strong="H3541"\w* \w ha|strong="H3541"\w* \w dicho|strong="H1696"\w* Yahvé: ¿Has asesinado \w y|strong="H1571"\w* \w también|strong="H1571"\w* has tomado posesión?». \w Y|strong="H3068"\w* volverás \w a|strong="H3068"\w* \w hablarle|strong="H1696"\w*, \w diciendo|strong="H1696"\w*: «\w Así|strong="H3541"\w* \w ha|strong="H3541"\w* \w dicho|strong="H1696"\w* Yahvé: En \w el|strong="H1571"\w* \w mismo|strong="H1571"\w* \w lugar|strong="H4725"\w* \w donde|strong="H4725"\w* \w lamieron|strong="H3952"\w* los \w perros|strong="H3611"\w* \w la|strong="H1571"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* Nabot, los \w perros|strong="H3611"\w* \w lamerán|strong="H3952"\w* \w también|strong="H1571"\w* tu \w sangre|strong="H1818"\w*, tu misma \w sangre|strong="H1818"\w*»».   
\p
\v 20 \w Y|strong="H3068"\w* Acab dijo \w a|strong="H3068"\w* Elías: «¿Me has \w hallado|strong="H4672"\w*, enemigo mío?». \w Él|strong="H6213"\w* respondió: «\w Te|strong="H5869"\w* he \w hallado|strong="H4672"\w*, \w porque|strong="H3282"\w* \w te|strong="H5869"\w* has vendido \w para|strong="H3282"\w* \w hacer|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Yahvé.  
\v 21 He \w aquí|strong="H2005"\w* yo traigo \w mal|strong="H7451"\w* sobre ti, \w y|strong="H1197"\w* barreré tu posteridad \w y|strong="H1197"\w* \w destruiré|strong="H3772"\w* \w de|strong="H7451"\w* Acab \w a|strong="H3068"\w* todo el que meare \w a|strong="H3068"\w* \w la|strong="H1197"\w* \w pared|strong="H7023"\w*,\f + \fr 21:21 \ft o, hombre \f* tanto al siervo como al libre en \w Israel|strong="H3478"\w*.  
\v 22 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* tu \w casa|strong="H1004"\w* como la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nabat|strong="H5028"\w*, y como la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Baasa|strong="H1201"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ahías|strong="H3379"\w*, \w por|strong="H5414"\w* la provocación con \w que|strong="H1121"\w* me provocaste \w a|strong="H3068"\w* ira, y con \w que|strong="H1121"\w* hiciste \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*».  
\v 23 De Jezabel \w también|strong="H1571"\w* ha \w hablado|strong="H1696"\w* Yahvé, \w diciendo|strong="H1696"\w*: «Los \w perros|strong="H3611"\w* comerán \w a|strong="H3068"\w* Jezabel junto al muro de \w Jezreel|strong="H3157"\w*.  
\v 24 Al que de Acab \w muriere|strong="H4191"\w* en la \w ciudad|strong="H5892"\w*, los \w perros|strong="H3611"\w* lo comerán; y al que \w muriere|strong="H4191"\w* en el \w campo|strong="H7704"\w*, lo comerán las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w*».   
\p
\v 25 (\w A|strong="H3068"\w* la verdad \w ninguno|strong="H3808"\w* \w hubo|strong="H1961"\w* \w como|strong="H1961"\w* Acab, \w que|strong="H3808"\w* \w se|strong="H1961"\w* vendiese \w para|strong="H7535"\w* \w hacer|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante \w los|strong="H1961"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Yahvé; \w porque|strong="H3808"\w* su mujer Jezabel \w lo|strong="H3808"\w* incitaba.  
\v 26 \w Él|strong="H3605"\w* \w fue|strong="H3212"\w* \w en|strong="H3212"\w* \w gran|strong="H3966"\w* \w manera|strong="H3966"\w* \w abominable|strong="H8581"\w*, \w caminando|strong="H3212"\w* \w en|strong="H3212"\w* pos \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w ídolos|strong="H1544"\w*, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* \w hicieron|strong="H6213"\w* \w los|strong="H1121"\w* amorreos, \w a|strong="H3068"\w* \w los|strong="H1121"\w* cuales \w lanzó|strong="H3423"\w* Yahvé \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*).   
\p
\v 27 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H5921"\w* \w cuando|strong="H1961"\w* Acab \w oyó|strong="H8085"\w* estas \w palabras|strong="H1697"\w*, \w rasgó|strong="H7167"\w* sus vestidos \w y|strong="H5921"\w* \w puso|strong="H7760"\w* cilicio \w sobre|strong="H5921"\w* su \w carne|strong="H1320"\w*, ayunó, \w y|strong="H5921"\w* \w durmió|strong="H7901"\w* \w en|strong="H5921"\w* cilicio, \w y|strong="H5921"\w* \w anduvo|strong="H1980"\w* humillado.   
\p
\v 28 Entonces \w vino|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w a|strong="H3068"\w* Elías tisbita, diciendo:  
\v 29 «¿Has \w visto|strong="H7200"\w* \w cómo|strong="H3588"\w* Acab \w se|strong="H5921"\w* \w ha|strong="H3808"\w* \w humillado|strong="H3665"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*? \w Por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w se|strong="H5921"\w* \w ha|strong="H3808"\w* \w humillado|strong="H3665"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w no|strong="H3808"\w* traeré \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w en|strong="H5921"\w* sus \w días|strong="H3117"\w*; \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* traeré \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*».   
\c 22
\p
\v 1 \w Pasaron|strong="H3427"\w* \w tres|strong="H7969"\w* \w años|strong="H8141"\w* sin que hubiera \w guerra|strong="H4421"\w* entre Siria \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*.  
\v 2 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w al|strong="H4428"\w* tercer \w año|strong="H8141"\w*, \w que|strong="H1961"\w* Josafat \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w* \w descendió|strong="H3381"\w* \w a|strong="H3068"\w* visitar \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*.  
\v 3 \w Y|strong="H3068"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* sus \w siervos|strong="H5650"\w*: «¿\w No|strong="H3588"\w* \w sabéis|strong="H3045"\w* \w que|strong="H3588"\w* Ramot \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* \w es|strong="H3027"\w* nuestra, \w y|strong="H3588"\w* nosotros \w no|strong="H3588"\w* hacemos nada \w para|strong="H3588"\w* quitarla \w de|strong="H3588"\w* \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Siria?».  
\v 4 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* Josafat: «¿Quieres \w venir|strong="H3212"\w* conmigo \w a|strong="H3068"\w* pelear \w contra|strong="H3478"\w* Ramot \w de|strong="H5971"\w* \w Galaad|strong="H1568"\w*?».  
\p Josafat respondió \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*: «Yo soy \w como|strong="H3644"\w* tú, y mi \w pueblo|strong="H5971"\w* \w como|strong="H3644"\w* tu \w pueblo|strong="H5971"\w*, y mis \w caballos|strong="H5483"\w* \w como|strong="H3644"\w* tus \w caballos|strong="H5483"\w*».  
\v 5 Dijo también Josafat \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*: «Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* consultes \w hoy|strong="H3117"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé».   
\p
\v 6 Entonces \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* reunió \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w*, unos cuatrocientos hombres, \w y|strong="H5921"\w* \w les|strong="H5921"\w* dijo: «¿\w Iré|strong="H3212"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w* \w contra|strong="H5921"\w* Ramot \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*, \w o|strong="H3068"\w* desistiré?».  
\p \w Y|strong="H3068"\w* \w ellos|strong="H3027"\w* dijeron: «\w Sube|strong="H5927"\w*, \w porque|strong="H5921"\w* \w el|strong="H5921"\w* Señor \w la|strong="H5921"\w* \w entregará|strong="H5414"\w* \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*».   
\p
\v 7 \w Y|strong="H3068"\w* dijo Josafat: «¿No \w hay|strong="H5750"\w* \w aún|strong="H5750"\w* \w aquí|strong="H6311"\w* \w algún|strong="H5750"\w* \w profeta|strong="H5030"\w* \w de|strong="H5750"\w* Yahvé, \w por|strong="H5750"\w* quien \w consultemos|strong="H1875"\w*?».  
\v 8 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* respondió \w a|strong="H3068"\w* Josafat: «\w Aún|strong="H5750"\w* \w hay|strong="H5750"\w* un \w hombre|strong="H1121"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w cual|strong="H3588"\w* podríamos consultar \w a|strong="H3068"\w* Yahvé, Micaías \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Imla; \w mas|strong="H5750"\w* \w yo|strong="H3588"\w* \w le|strong="H5921"\w* \w aborrezco|strong="H8130"\w*, \w porque|strong="H3588"\w* \w nunca|strong="H3808"\w* \w me|strong="H5921"\w* \w profetiza|strong="H5012"\w* \w bien|strong="H2896"\w*, \w sino|strong="H3588"\w* \w solamente|strong="H3588"\w* \w mal|strong="H7451"\w*».  
\p \w Y|strong="H3068"\w* Josafat dijo: «\w No|strong="H3808"\w* hable \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w así|strong="H3651"\w*».   
\p
\v 9 Entonces \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* un oficial, y le dijo: «Haz venir \w pronto|strong="H4116"\w* \w a|strong="H3068"\w* Micaías \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Imla».   
\p
\v 10 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* Josafat \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w estaban|strong="H3427"\w* \w sentados|strong="H3427"\w* \w cada|strong="H3605"\w* uno \w en|strong="H5921"\w* su \w trono|strong="H3678"\w*, \w vestidos|strong="H3847"\w* \w de|strong="H5921"\w* sus ropas \w reales|strong="H4428"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* era \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w Samaria|strong="H8111"\w*; \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w profetas|strong="H5030"\w* \w profetizaban|strong="H5012"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 11 \w Y|strong="H3068"\w* Sedequías \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Quenaana se \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* unos \w cuernos|strong="H7161"\w* \w de|strong="H5704"\w* \w hierro|strong="H1270"\w*, \w y|strong="H5704"\w* dijo: «\w Así|strong="H3541"\w* \w ha|strong="H3541"\w* dicho Yahvé: \w Con|strong="H5704"\w* estos \w acornearás|strong="H5055"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* sirios \w hasta|strong="H5704"\w* \w acabarlos|strong="H3615"\w*».  
\v 12 \w Y|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w* \w profetizaban|strong="H5012"\w* \w de|strong="H5414"\w* \w la|strong="H3605"\w* misma manera, diciendo: «\w Sube|strong="H5927"\w* \w a|strong="H3068"\w* Ramot \w de|strong="H5414"\w* \w Galaad|strong="H1568"\w*, y serás \w prosperado|strong="H6743"\w*; \w porque|strong="H4428"\w* Yahvé \w la|strong="H3605"\w* \w entregará|strong="H5414"\w* en \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w*».   
\p
\v 13 \w Y|strong="H3068"\w* \w el|strong="H5030"\w* \w mensajero|strong="H4397"\w* \w que|strong="H4994"\w* \w había|strong="H1961"\w* ido \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* Micaías, le \w habló|strong="H1696"\w* \w diciendo|strong="H1696"\w*: «\w Mira|strong="H2009"\w* \w que|strong="H4994"\w* \w las|strong="H1992"\w* \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* \w a|strong="H3068"\w* una voz anuncian \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w cosas|strong="H1697"\w* \w buenas|strong="H2896"\w*; \w sea|strong="H1961"\w* \w ahora|strong="H4994"\w* tu \w palabra|strong="H1697"\w* \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* la \w de|strong="H1697"\w* uno \w de|strong="H1697"\w* \w ellos|strong="H1992"\w*, y \w habla|strong="H1696"\w* \w bien|strong="H2896"\w*».  
\v 14 Micaías respondió: «\w Vive|strong="H2416"\w* Yahvé, \w que|strong="H3588"\w* lo \w que|strong="H3588"\w* Yahvé \w me|strong="H3588"\w* \w dijere|strong="H1696"\w*, eso \w hablaré|strong="H1696"\w*».   
\p
\v 15 \w Vino|strong="H3212"\w*, pues, \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, y el \w rey|strong="H4428"\w* le dijo: «Micaías, ¿\w iremos|strong="H3212"\w* \w a|strong="H3068"\w* pelear contra Ramot \w de|strong="H5414"\w* \w Galaad|strong="H1568"\w*, \w o|strong="H3068"\w* desistiremos?».  
\p Él le respondió: «\w Sube|strong="H5927"\w*, y serás \w prosperado|strong="H6743"\w*, y Yahvé la \w entregará|strong="H5414"\w* \w en|strong="H3212"\w* \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w*».   
\p
\v 16 \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* le \w dijo|strong="H1696"\w*: «¿\w Hasta|strong="H5704"\w* \w cuántas|strong="H4100"\w* \w veces|strong="H6471"\w* te he \w de|strong="H5704"\w* conjurar \w que|strong="H4100"\w* \w no|strong="H3808"\w* me \w digas|strong="H1696"\w* \w sino|strong="H7535"\w* la verdad \w en|strong="H5704"\w* el \w nombre|strong="H8034"\w* \w de|strong="H5704"\w* Yahvé?».   
\p
\v 17 \w Entonces|strong="H7725"\w* \w él|strong="H3605"\w* dijo: «\w Vi|strong="H7200"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w esparcido|strong="H6327"\w* por \w los|strong="H1992"\w* \w montes|strong="H2022"\w*, como \w ovejas|strong="H6629"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w tienen|strong="H1992"\w* \w pastor|strong="H7462"\w*; y Yahvé dijo: «\w Estos|strong="H1992"\w* \w no|strong="H3808"\w* \w tienen|strong="H1992"\w* \w señor|strong="H3068"\w*; \w vuélvase|strong="H7725"\w* \w cada|strong="H3605"\w* uno \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w casa|strong="H1004"\w* en \w paz|strong="H7965"\w*»».  
\v 18 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* Josafat: «¿\w No|strong="H3808"\w* \w te|strong="H5921"\w* \w lo|strong="H3808"\w* \w había|strong="H3588"\w* \w yo|strong="H3588"\w* dicho? \w Ninguna|strong="H3808"\w* cosa \w buena|strong="H2896"\w* \w profetiza|strong="H5012"\w* \w él|strong="H5921"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w sino|strong="H3588"\w* \w solamente|strong="H3588"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w*».   
\p
\v 19 \w Entonces|strong="H3651"\w* \w él|strong="H5921"\w* dijo: “\w Oíd|strong="H8085"\w*, \w pues|strong="H3651"\w*, \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé: Yo \w vi|strong="H7200"\w* \w a|strong="H3068"\w* Yahvé \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* su \w trono|strong="H3678"\w*, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w ejército|strong="H6635"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w cielos|strong="H8064"\w* \w estaba|strong="H5975"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w a|strong="H3068"\w* su \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* su \w izquierda|strong="H8040"\w*.  
\v 20 \w Y|strong="H3068"\w* Yahvé dijo: «¿\w Quién|strong="H4310"\w* \w inducirá|strong="H6601"\w* \w a|strong="H3068"\w* Acab, para \w que|strong="H4310"\w* \w suba|strong="H5927"\w* \w y|strong="H3541"\w* \w caiga|strong="H5307"\w* en Ramot de \w Galaad|strong="H1568"\w*?». \w Y|strong="H3068"\w* uno decía de una manera, \w y|strong="H3541"\w* \w otro|strong="H2088"\w* decía de otra.   
\p
\v 21 \w Y|strong="H3068"\w* \w salió|strong="H3318"\w* un \w espíritu|strong="H7307"\w* y se \w puso|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, y dijo: «Yo le induciré».   
