\c 14
\p
\v 1 Por \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w*, Abías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w*, cayó \w enfermo|strong="H2470"\w*.  
