\c 3
\p
\v 1 \w Salomón|strong="H8010"\w* emparentó \w con|strong="H5704"\w* el \w faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Egipto|strong="H4714"\w*, pues \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* del \w faraón|strong="H6547"\w* \w y|strong="H5704"\w* la trajo \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* \w David|strong="H1732"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* hubo \w acabado|strong="H3615"\w* \w de|strong="H5704"\w* \w edificar|strong="H1129"\w* su propia \w casa|strong="H1004"\w*, la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Yahvé \w y|strong="H5704"\w* los \w muros|strong="H2346"\w* \w alrededor|strong="H5439"\w* \w de|strong="H5704"\w* Jerusalén.  
