\h HABACUC 
\toc3 Habacuc 
\toc1 HABACUC 
\toc2 HABACUC 
\mt1 Habacuc  
\c 1
\p
\v 1 \w El|strong="H5030"\w* oráculo que tuvo en visión \w el|strong="H5030"\w* \w profeta|strong="H5030"\w* \w Habacuc|strong="H2265"\w*.  
\v 2 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w*, Yahvé, \w clamaré|strong="H2199"\w* \w sin|strong="H3808"\w* \w que|strong="H3808"\w* tú escuches? ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* te gritaré: «¡\w Violencia|strong="H2555"\w*!», \w sin|strong="H3808"\w* \w que|strong="H3808"\w* tú \w salves|strong="H3467"\w*?  
\v 3 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* me haces \w ver|strong="H7200"\w* la \w iniquidad|strong="H2555"\w* \w y|strong="H4066"\w* te quedas mirando el \w agravio|strong="H2555"\w*? \w Pues|strong="H7200"\w* la \w destrucción|strong="H7701"\w* \w y|strong="H4066"\w* la \w violencia|strong="H2555"\w* \w están|strong="H1961"\w* ante \w mí|strong="H1961"\w*; \w hay|strong="H1961"\w* \w contienda|strong="H7379"\w* \w y|strong="H4066"\w* \w se|strong="H1961"\w* \w levanta|strong="H5375"\w* la discordia.  
\v 4 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w se|strong="H5921"\w* debilita \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w justicia|strong="H4941"\w* \w no|strong="H3808"\w* prevalece \w nunca|strong="H3808"\w*; \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w impío|strong="H7563"\w* acosa \w al|strong="H5921"\w* \w justo|strong="H6662"\w*, \w y|strong="H3588"\w* \w así|strong="H3651"\w* \w sale|strong="H3318"\w* torcida \w la|strong="H5921"\w* \w justicia|strong="H4941"\w*.   
\p
\v 5 «\w Mirad|strong="H7200"\w* \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w*, observad \w y|strong="H3588"\w* asombraos maravillosamente; \w porque|strong="H3588"\w* voy \w a|strong="H3068"\w* realizar una \w obra|strong="H6466"\w* \w en|strong="H3588"\w* vuestros \w días|strong="H3117"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* creeríais \w aunque|strong="H3588"\w* os \w la|strong="H3588"\w* contasen.  
\v 6 \w Porque|strong="H3588"\w* he \w aquí|strong="H2005"\w*, \w yo|strong="H3588"\w* \w levanto|strong="H6965"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w caldeos|strong="H3778"\w*, \w nación|strong="H1471"\w* cruel \w e|strong="H3068"\w* impetuosa, \w que|strong="H3588"\w* recorre \w la|strong="H3588"\w* anchura \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w para|strong="H3588"\w* apoderarse \w de|strong="H3588"\w* \w moradas|strong="H4908"\w* \w ajenas|strong="H3808"\w*.  
\v 7 Son temibles y terribles; \w su|strong="H1931"\w* \w justicia|strong="H4941"\w* y \w su|strong="H1931"\w* dignidad emanan \w de|strong="H4480"\w* \w ellos|strong="H1931"\w* mismos.  
\v 8 Sus \w caballos|strong="H5483"\w* son más veloces que leopardos y más feroces que \w lobos|strong="H2061"\w* al anochecer. Sus \w jinetes|strong="H6571"\w* galopan con orgullo; sí, sus \w jinetes|strong="H6571"\w* vienen de \w lejos|strong="H7350"\w* y vuelan como águila que se apresura \w a|strong="H3068"\w* devorar.  
\v 9 Vienen \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* para ejercer \w la|strong="H3605"\w* \w violencia|strong="H2555"\w*; su \w rostro|strong="H6440"\w* avanza como \w el|strong="H3605"\w* viento del este y recogen \w cautivos|strong="H7628"\w* como \w la|strong="H3605"\w* arena.  
\v 10 \w Se|strong="H1931"\w* mofan de \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* y \w los|strong="H3605"\w* príncipes les sirven de burla; \w se|strong="H1931"\w* ríen de \w toda|strong="H3605"\w* \w fortaleza|strong="H4013"\w*, \w pues|strong="H1931"\w* levantan terraplenes y las conquistan.  
\v 11 \w Luego|strong="H5674"\w* \w pasan|strong="H5674"\w* como \w el|strong="H5674"\w* \w viento|strong="H7307"\w* y siguen adelante; pero son culpables, porque hacen de su \w fuerza|strong="H3581"\w* su dios».   
\p
\v 12 ¿\w No|strong="H3808"\w* eres tú desde la eternidad, Yahvé, \w Dios|strong="H3068"\w* mío, \w Santo|strong="H6918"\w* mío? \w No|strong="H3808"\w* \w moriremos|strong="H4191"\w*. Yahvé, para \w juicio|strong="H4941"\w* los \w has|strong="H4191"\w* puesto; y tú, oh \w Roca|strong="H6697"\w*, los \w has|strong="H4191"\w* establecido para castigar.  
\v 13 Tú, \w que|strong="H4100"\w* eres \w de|strong="H4480"\w* \w ojos|strong="H5869"\w* demasiado puros \w para|strong="H4480"\w* \w ver|strong="H7200"\w* el \w mal|strong="H7451"\w* y \w no|strong="H3808"\w* \w puedes|strong="H3201"\w* \w mirar|strong="H7200"\w* el \w agravio|strong="H7451"\w*, ¿\w por|strong="H4480"\w* \w qué|strong="H4100"\w* toleras \w a|strong="H3068"\w* los traidores y callas \w cuando|strong="H4100"\w* el \w impío|strong="H7563"\w* devora \w al|strong="H4480"\w* \w que|strong="H4100"\w* es \w más|strong="H4480"\w* \w justo|strong="H6662"\w* \w que|strong="H4100"\w* él?  
\v 14 ¿Por \w qué|strong="H3808"\w* \w haces|strong="H6213"\w* \w a|strong="H3068"\w* los hombres como \w a|strong="H3068"\w* los peces del \w mar|strong="H3220"\w*, como \w a|strong="H3068"\w* \w reptiles|strong="H7431"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* tienen dueño?  
\v 15 \w A|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w saca|strong="H5927"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* anzuelo, \w los|strong="H5921"\w* atrapa \w en|strong="H5921"\w* su red \w y|strong="H5921"\w* \w los|strong="H5921"\w* recoge \w en|strong="H5921"\w* su malla; \w por|strong="H5921"\w* \w eso|strong="H3651"\w* \w se|strong="H5921"\w* regocija \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w alegra|strong="H8055"\w*.  
\v 16 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* ofrece \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* red \w y|strong="H3588"\w* quema incienso \w a|strong="H3068"\w* \w su|strong="H1992"\w* malla, \w porque|strong="H3588"\w* gracias \w a|strong="H3068"\w* \w ellas|strong="H1992"\w* \w su|strong="H1992"\w* porción \w es|strong="H3588"\w* \w pingüe|strong="H8082"\w* \w y|strong="H3588"\w* \w su|strong="H1992"\w* \w comida|strong="H3978"\w* suculenta.  
\v 17 ¿Continuará, \w pues|strong="H3651"\w*, vaciando su red \w y|strong="H5921"\w* \w matando|strong="H2026"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w sin|strong="H3808"\w* piedad?   
\c 2
\p
\v 1 \w Me|strong="H5921"\w* pondré \w en|strong="H5921"\w* \w mi|strong="H5921"\w* torre \w de|strong="H5921"\w* vigilia \w y|strong="H5921"\w* \w me|strong="H5921"\w* situaré \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* muralla; \w estaré|strong="H5975"\w* atento \w para|strong="H5921"\w* \w ver|strong="H7200"\w* \w qué|strong="H4100"\w* \w me|strong="H5921"\w* dirá Yahvé \w y|strong="H5921"\w* \w qué|strong="H4100"\w* he \w de|strong="H5921"\w* \w responder|strong="H7725"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* queja.   
\p
\v 2 \w El|strong="H5921"\w* \w Señor|strong="H3068"\w* \w me|strong="H5921"\w* \w respondió|strong="H6030"\w*: “\w Escribe|strong="H3789"\w* \w la|strong="H5921"\w* \w visión|strong="H2377"\w* \w y|strong="H5921"\w* grábala claramente \w en|strong="H5921"\w* tablillas, \w para|strong="H4616"\w* \w que|strong="H5921"\w* pueda leerla \w el|strong="H5921"\w* \w que|strong="H5921"\w* pase \w corriendo|strong="H7323"\w*.  
\v 3 \w Aunque|strong="H3588"\w* \w la|strong="H3588"\w* \w visión|strong="H2377"\w* \w es|strong="H3588"\w* \w todavía|strong="H5750"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w tiempo|strong="H4150"\w* \w señalado|strong="H4150"\w*, \w se|strong="H3808"\w* apresura hacia \w el|strong="H3588"\w* \w fin|strong="H7093"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w mentirá|strong="H3576"\w*. \w Aunque|strong="H3588"\w* \w se|strong="H3808"\w* demore, espérala, \w porque|strong="H3588"\w* \w sin|strong="H3808"\w* duda vendrá; \w no|strong="H3808"\w* tardará.  
\v 4 He \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* aquel cuya \w alma|strong="H5315"\w* es soberbia \w no|strong="H3808"\w* es recto en su interior; \w mas|strong="H2421"\w* el \w justo|strong="H6662"\w* por su fe \w vivirá|strong="H2421"\w*.  
\v 5 \w Y|strong="H3068"\w* \w además|strong="H3588"\w*, \w el|strong="H1931"\w* \w vino|strong="H3196"\w* \w es|strong="H1931"\w* traicionero; \w el|strong="H1931"\w* \w hombre|strong="H1397"\w* arrogante \w no|strong="H3808"\w* halla reposo. \w Ensancha|strong="H7337"\w* \w su|strong="H1931"\w* garganta \w como|strong="H3588"\w* \w el|strong="H1931"\w* Seol \w y|strong="H3588"\w* \w es|strong="H1931"\w* insaciable \w como|strong="H3588"\w* \w la|strong="H1931"\w* \w muerte|strong="H4194"\w*; reúne \w para|strong="H3588"\w* \w sí|strong="H3588"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* \w y|strong="H3588"\w* amontona \w para|strong="H3588"\w* \w sí|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*.   
\p
\v 6 ¿\w No|strong="H3808"\w* entonarán \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* un proverbio \w y|strong="H5921"\w* una burla punzante? Dirán: ‘¡\w Ay|strong="H1945"\w* \w del|strong="H5921"\w* \w que|strong="H3808"\w* amontona \w lo|strong="H3808"\w* ajeno! ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* habrá \w de|strong="H5921"\w* enriquecerse \w con|strong="H5921"\w* prendas empeñadas?’.  
\v 7 ¿\w No|strong="H3808"\w* \w se|strong="H1961"\w* levantarán de repente vuestros acreedores y despertarán \w los|strong="H1961"\w* \w que|strong="H3808"\w* os hacen temblar? ¡\w Y|strong="H3068"\w* \w seréis|strong="H1961"\w* \w para|strong="H1961"\w* ellos objeto de rapiña!  
\v 8 \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* habéis saqueado \w a|strong="H3068"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w*, \w todos|strong="H3605"\w* \w los|strong="H3427"\w* demás \w pueblos|strong="H5971"\w* os saquearán \w a|strong="H3068"\w* vosotros, \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w sangre|strong="H1818"\w* humana \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w violencia|strong="H2555"\w* hecha \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra, \w a|strong="H3068"\w* las ciudades \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w moradores|strong="H3427"\w*.   
\p
\v 9 ¡\w Ay|strong="H1945"\w* del que obtiene ganancias injustas para su \w casa|strong="H1004"\w*, \w poniendo|strong="H7760"\w* su \w nido|strong="H7064"\w* en \w alto|strong="H4791"\w* para librarse del poder del \w mal|strong="H7451"\w*!  
\v 10 Habéis maquinado la vergüenza \w para|strong="H5971"\w* vuestra \w casa|strong="H1004"\w* al destruir \w a|strong="H3068"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*, pecando contra vuestra propia \w alma|strong="H5315"\w*.  
\v 11 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* piedra \w clamará|strong="H2199"\w* desde \w el|strong="H3588"\w* muro \w y|strong="H3588"\w* \w la|strong="H3588"\w* viga del maderamen le \w responderá|strong="H6030"\w*.   
\p
\v 12 ¡\w Ay|strong="H1945"\w* del que \w edifica|strong="H1129"\w* la \w ciudad|strong="H5892"\w* con \w sangre|strong="H1818"\w* y la establece sobre la \w iniquidad|strong="H5766"\w*!  
\v 13 ¿\w No|strong="H3808"\w* proviene \w de|strong="H5971"\w* Yahvé \w de|strong="H5971"\w* los \w Ejércitos|strong="H6635"\w* \w que|strong="H3808"\w* los \w pueblos|strong="H5971"\w* trabajen \w para|strong="H5971"\w* el fuego y las naciones \w se|strong="H3808"\w* fatiguen en vano?  
\v 14 \w Porque|strong="H3588"\w* \w la|strong="H5921"\w* tierra \w se|strong="H3045"\w* \w llenará|strong="H4390"\w* \w del|strong="H5921"\w* \w conocimiento|strong="H3045"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* Yahvé, \w como|strong="H3588"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w cubren|strong="H3680"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*.   
\p
\v 15 ¡\w Ay|strong="H1945"\w* \w del|strong="H5921"\w* \w que|strong="H5921"\w* da \w de|strong="H5921"\w* \w beber|strong="H8248"\w* \w a|strong="H3068"\w* su \w prójimo|strong="H7453"\w*, añadiendo su ponzoña \w hasta|strong="H5921"\w* embriagarlo \w para|strong="H4616"\w* contemplar su desnudez!  
\v 16 \w Os|strong="H5921"\w* \w habéis|strong="H8354"\w* llenado \w de|strong="H5921"\w* ignominia \w en|strong="H5921"\w* lugar \w de|strong="H5921"\w* \w gloria|strong="H3519"\w*. ¡\w Bebed|strong="H8354"\w* \w también|strong="H1571"\w* vosotros \w y|strong="H1571"\w* quedad \w al|strong="H5921"\w* descubierto! \w La|strong="H5921"\w* copa \w de|strong="H5921"\w* \w la|strong="H5921"\w* mano \w derecha|strong="H3225"\w* \w de|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* volverá \w contra|strong="H5921"\w* vosotros, \w y|strong="H1571"\w* \w la|strong="H5921"\w* deshonra cubrirá vuestra \w gloria|strong="H3519"\w*.  
\v 17 \w Porque|strong="H3588"\w* \w la|strong="H3605"\w* \w violencia|strong="H2555"\w* contra \w el|strong="H3588"\w* \w Líbano|strong="H3844"\w* os agobiará, \w y|strong="H3588"\w* \w la|strong="H3605"\w* \w destrucción|strong="H7701"\w* \w de|strong="H3588"\w* las fieras os aterrará, \w por|strong="H3588"\w* \w la|strong="H3605"\w* \w sangre|strong="H1818"\w* humana \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3605"\w* \w violencia|strong="H2555"\w* contra \w la|strong="H3605"\w* tierra, contra \w la|strong="H3605"\w* \w ciudad|strong="H7151"\w* \w y|strong="H3588"\w* contra \w todos|strong="H3605"\w* sus \w moradores|strong="H3427"\w*.   
\p
\v 18 ¿\w De|strong="H5921"\w* \w qué|strong="H3588"\w* \w sirve|strong="H6213"\w* \w la|strong="H5921"\w* \w imagen|strong="H6459"\w* tallada \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* artífice \w la|strong="H5921"\w* haya esculpido, \w o|strong="H3068"\w* \w la|strong="H5921"\w* \w imagen|strong="H6459"\w* \w de|strong="H5921"\w* \w fundición|strong="H4541"\w* \w que|strong="H3588"\w* \w enseña|strong="H3384"\w* \w mentiras|strong="H8267"\w*, \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w hacedor|strong="H6213"\w* confíe \w en|strong="H5921"\w* \w ella|strong="H5921"\w* fabricando ídolos mudos?  
\v 19 ¡\w Ay|strong="H1945"\w* del \w que|strong="H1931"\w* dice \w al|strong="H7130"\w* \w madero|strong="H6086"\w*: «\w Despierta|strong="H5782"\w*», y \w a|strong="H3068"\w* \w la|strong="H1931"\w* piedra \w muda|strong="H1748"\w*: «\w Levántate|strong="H5782"\w*»! ¿Podrá \w eso|strong="H1931"\w* \w enseñar|strong="H3384"\w*? He \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* cubierto de \w oro|strong="H2091"\w* y \w plata|strong="H3701"\w*, pero no hay aliento \w alguno|strong="H3605"\w* en \w su|strong="H1931"\w* interior.  
\v 20 Mas Yahvé está en su \w santo|strong="H6944"\w* \w templo|strong="H1964"\w*; \w calle|strong="H2013"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H3605"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra”.   
\c 3
\p
\v 1 \w Oración|strong="H8605"\w* \w del|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Habacuc|strong="H2265"\w*, \w sobre|strong="H5921"\w* Shigionoth.   
\q1
\v 2 Yahvé, he \w oído|strong="H8085"\w* tu fama;  
\q2 me asombro, Yahvé, \w de|strong="H3372"\w* tus \w obras|strong="H6467"\w*.  
\q1 Renuévalas en \w medio|strong="H7130"\w* \w de|strong="H3372"\w* los \w tiempos|strong="H8141"\w*,  
\q2 en \w medio|strong="H7130"\w* \w de|strong="H3372"\w* los \w tiempos|strong="H8141"\w* hazlas conocer;  
\q2 en la ira, \w acuérdate|strong="H2142"\w* \w de|strong="H3372"\w* la \w misericordia|strong="H7355"\w*.   
\q1
\v 3 Dios vino de \w Temán|strong="H8487"\w*,  
\q2 el \w Santo|strong="H6918"\w* desde el \w monte|strong="H2022"\w* \w Parán|strong="H6290"\w*. \w Selah|strong="H5542"\w*.  
\b  
\q1 Su \w gloria|strong="H1935"\w* \w cubrió|strong="H3680"\w* los \w cielos|strong="H8064"\w*,  
\q2 y su \w alabanza|strong="H8416"\w* \w llenó|strong="H4390"\w* la tierra.   
\q1
\v 4 Su esplendor \w fue|strong="H1961"\w* \w como|strong="H1961"\w* la luz del sol;  
\q2 \w rayos|strong="H7161"\w* brillantes salían de su \w mano|strong="H3027"\w*, \w donde|strong="H8033"\w* \w se|strong="H1961"\w* escondía su \w poder|strong="H3027"\w*.   
\q1
\v 5 \w Delante|strong="H6440"\w* \w de|strong="H6440"\w* su \w rostro|strong="H6440"\w* \w iba|strong="H3212"\w* la peste,  
\q2 y la plaga seguía sus pasos.   
\q1
\v 6 Se detuvo y sacudió la tierra;  
\q2 \w miró|strong="H7200"\w* \w e|strong="H3068"\w* hizo temblar \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*.  
\q2 Los montes \w antiguos|strong="H5769"\w* se desmoronaron,  
\q2 los \w collados|strong="H1389"\w* \w eternos|strong="H5769"\w* se hundieron.  
\q2 Sus caminos son los de \w siempre|strong="H5769"\w*.   
\q1
\v 7 \w Vi|strong="H7200"\w* las tiendas \w de|strong="H8478"\w* Cusán \w en|strong="H8478"\w* aflicción;  
\q2 las moradas \w de|strong="H8478"\w* la tierra \w de|strong="H8478"\w* \w Madián|strong="H4080"\w* temblaban.   
\q1
\v 8 ¿\w Te|strong="H5921"\w* airaste, Yahvé, \w contra|strong="H5921"\w* \w los|strong="H5921"\w* ríos?  
\q2 ¿Fue tu ira \w contra|strong="H5921"\w* \w los|strong="H5921"\w* ríos,  
\q2 \w o|strong="H3068"\w* tu furor \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*,  
\q2 \w cuando|strong="H3588"\w* montaste \w en|strong="H5921"\w* tus \w caballos|strong="H5483"\w*,  
\q2 \w en|strong="H5921"\w* tus \w carros|strong="H4818"\w* \w de|strong="H5921"\w* victoria?   
\q1
\v 9 Descubriste por completo tu \w arco|strong="H7198"\w*;  
\q2 las saetas fueron juradas según tu palabra. \w Selah|strong="H5542"\w*.  
\q1 \w Hendiste|strong="H1234"\w* la tierra con los ríos.   
\q1
\v 10 Te \w vieron|strong="H7200"\w* los \w montes|strong="H2022"\w* y tuvieron \w temor|strong="H2342"\w*;  
\q2 \w pasó|strong="H5674"\w* la inundación \w de|strong="H5414"\w* las \w aguas|strong="H4325"\w*.  
\q2 \w El|strong="H5674"\w* \w abismo|strong="H8415"\w* \w dio|strong="H5414"\w* su \w voz|strong="H6963"\w*,  
\q2 y \w levantó|strong="H5375"\w* sus \w manos|strong="H3027"\w* en lo alto.   
\q1
\v 11 El \w sol|strong="H8121"\w* y la \w luna|strong="H3394"\w* se detuvieron \w en|strong="H5975"\w* su morada;  
\q2 \w a|strong="H3068"\w* la luz de tus \w saetas|strong="H2671"\w* \w anduvieron|strong="H1980"\w*,  
\q2 y al \w resplandor|strong="H5051"\w* de tu reluciente \w lanza|strong="H2595"\w*.   
\q1
\v 12 Con indignación marchaste sobre la tierra;  
\q2 con ira trillaste \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*.   
\q1
\v 13 \w Saliste|strong="H3318"\w* \w para|strong="H5704"\w* la salvación \w de|strong="H5704"\w* tu \w pueblo|strong="H5971"\w*,  
\q2 \w para|strong="H5704"\w* la salvación \w de|strong="H5704"\w* tu \w ungido|strong="H4899"\w*.  
\q1 Aplastaste la \w cabeza|strong="H7218"\w* \w de|strong="H5704"\w* la \w casa|strong="H1004"\w* del \w impío|strong="H7563"\w*,  
\q2 descubriéndola \w desde|strong="H5704"\w* el cimiento \w hasta|strong="H5704"\w* la roca. \w Selah|strong="H5542"\w*.   
\b  
\q1
\v 14 \w Horadaste|strong="H5344"\w* con sus propios dardos las \w cabezas|strong="H7218"\w* de sus guerreros,  
\q2 que \w como|strong="H3644"\w* torbellino acometieron para dispersarme,  
\q2 regocijándose \w como|strong="H3644"\w* si devoraran al \w pobre|strong="H6041"\w* en secreto.   
\q1
\v 15 Pisaste el \w mar|strong="H3220"\w* con tus \w caballos|strong="H5483"\w*,  
\q2 sobre la masa \w de|strong="H4325"\w* las \w grandes|strong="H7227"\w* \w aguas|strong="H4325"\w*.   
\q1
\v 16 \w Oí|strong="H8085"\w*, y \w se|strong="H5971"\w* conmovieron mis entrañas;  
\q2 \w al|strong="H8478"\w* \w oír|strong="H8085"\w* tu \w voz|strong="H6963"\w*, \w temblaron|strong="H7264"\w* mis \w labios|strong="H8193"\w*.  
\q1 Entró la carcoma \w en|strong="H8478"\w* mis \w huesos|strong="H6106"\w*, y \w en|strong="H8478"\w* mi \w lugar|strong="H8478"\w* me estremecí;  
\q2 porque debo esperar \w en|strong="H8478"\w* silencio el \w día|strong="H3117"\w* \w de|strong="H8478"\w* la \w angustia|strong="H6869"\w*,  
\q2 \w cuando|strong="H3117"\w* \w suba|strong="H5927"\w* contra el \w pueblo|strong="H5971"\w* el \w que|strong="H5971"\w* lo ha \w de|strong="H8478"\w* invadir.   
\q1
\v 17 \w Aunque|strong="H3588"\w* \w la|strong="H3588"\w* higuera \w no|strong="H3808"\w* florezca,  
\q2 \w ni|strong="H3808"\w* \w en|strong="H3588"\w* las \w vides|strong="H1612"\w* haya frutos,  
\q2 \w aunque|strong="H3588"\w* falte \w el|strong="H3588"\w* producto del olivo,  
\q2 \w y|strong="H3588"\w* \w los|strong="H3588"\w* labrados \w no|strong="H3808"\w* den mantenimiento,  
\q2 \w y|strong="H3588"\w* las \w ovejas|strong="H6629"\w* sean quitadas \w de|strong="H3588"\w* \w la|strong="H3588"\w* majada,  
\q2 \w y|strong="H3588"\w* \w no|strong="H3808"\w* haya \w vacas|strong="H1241"\w* \w en|strong="H3588"\w* \w los|strong="H3588"\w* corrales;   
\q1
\v 18 con todo, yo me alegraré en Yahvé,  
\q2 y me gozaré en el \w Dios|strong="H3068"\w* de mi salvación.   
\q1
\v 19 Yahvé, \w el|strong="H5921"\w* Señor, es \w mi|strong="H5921"\w* \w fortaleza|strong="H2428"\w*;  
\q2 \w él|strong="H5921"\w* hace mis \w pies|strong="H7272"\w* \w como|strong="H5921"\w* \w de|strong="H5921"\w* ciervas,  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* mis alturas \w me|strong="H5921"\w* hace caminar.  
\p \w Al|strong="H5921"\w* jefe \w de|strong="H5921"\w* \w los|strong="H5921"\w* cantores, \w sobre|strong="H5921"\w* mis instrumentos \w de|strong="H5921"\w* cuerda.   