\h JONÁS 
\toc3 Jonás 
\toc1 JONÁS 
\toc2 JONÁS 
\mt1 Jonás  
\c 1
\p
\v 1 La \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé llegó \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amitai, diciendo:  
\v 2 «\w Levántate|strong="H6965"\w*, \w ve|strong="H3212"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, esa \w gran|strong="H1419"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H3588"\w* predica \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w maldad|strong="H7451"\w* ha \w subido|strong="H5927"\w* \w hasta|strong="H5921"\w* \w mi|strong="H5921"\w* \w presencia|strong="H6440"\w*».   
\p
\v 3 Pero \w Jonás|strong="H3124"\w* se \w levantó|strong="H6965"\w* \w para|strong="H5414"\w* huir \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*, \w lejos|strong="H1272"\w* \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé. Bajó \w a|strong="H3068"\w* Jope y encontró \w una|strong="H4672"\w* nave que iba \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*; \w pagó|strong="H5414"\w* \w el|strong="H5973"\w* pasaje y embarcó \w para|strong="H5414"\w* \w ir|strong="H3381"\w* \w con|strong="H5973"\w* ellos \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*, \w lejos|strong="H1272"\w* \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé.   
\p
\v 4 Pero Yahvé envió un fuerte \w viento|strong="H7307"\w* \w sobre|strong="H1961"\w* el \w mar|strong="H3220"\w*, y \w se|strong="H1961"\w* desató una \w tempestad|strong="H5591"\w* tan poderosa \w que|strong="H1961"\w* la nave corría el riesgo de romperse.  
\v 5 Entonces \w los|strong="H5921"\w* marineros tuvieron \w miedo|strong="H3372"\w* \w y|strong="H5921"\w* cada uno \w clamó|strong="H2199"\w* \w a|strong="H3068"\w* su dios. Arrojaron \w al|strong="H5921"\w* \w mar|strong="H3220"\w* \w la|strong="H5921"\w* carga \w que|strong="H5921"\w* había \w en|strong="H5921"\w* \w la|strong="H5921"\w* nave \w para|strong="H5921"\w* aligerarla. Pero \w Jonás|strong="H3124"\w* había bajado \w al|strong="H5921"\w* interior \w de|strong="H5921"\w* \w la|strong="H5921"\w* nave \w y|strong="H5921"\w* \w se|strong="H5921"\w* había \w acostado|strong="H7901"\w*, \w y|strong="H5921"\w* \w estaba|strong="H7901"\w* profundamente dormido.  
\v 6 El patrón de la nave \w se|strong="H3808"\w* le acercó y le dijo: «¿\w Qué|strong="H4100"\w* haces ahí dormido? ¡\w Levántate|strong="H6965"\w*, invoca \w a|strong="H3068"\w* tu Dios! Tal vez tu Dios \w se|strong="H3808"\w* fije en nosotros, para \w que|strong="H4100"\w* \w no|strong="H3808"\w* perezcamos».   
\p
\v 7 Todos \w se|strong="H3045"\w* dijeron: «¡\w Venid|strong="H3212"\w*! Echemos \w suertes|strong="H1486"\w* \w para|strong="H5921"\w* \w saber|strong="H3045"\w* \w por|strong="H5921"\w* culpa \w de|strong="H5921"\w* \w quién|strong="H4310"\w* \w nos|strong="H5921"\w* ha sobrevenido \w este|strong="H2063"\w* \w mal|strong="H7451"\w*». \w Así|strong="H2063"\w* \w que|strong="H4310"\w* \w echaron|strong="H5307"\w* \w suertes|strong="H1486"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w suerte|strong="H1486"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w Jonás|strong="H3124"\w*.  
\v 8 Entonces \w le|strong="H4310"\w* preguntaron: «Dinos, te rogamos, ¿\w por|strong="H2088"\w* causa \w de|strong="H5971"\w* \w quién|strong="H4310"\w* \w nos|strong="H4100"\w* ha venido \w este|strong="H2088"\w* \w mal|strong="H7451"\w*? ¿\w Cuál|strong="H4100"\w* \w es|strong="H2088"\w* tu \w oficio|strong="H4399"\w*? ¿\w De|strong="H5971"\w* dónde vienes? ¿\w Cuál|strong="H4100"\w* \w es|strong="H2088"\w* tu país? ¿\w De|strong="H5971"\w* \w qué|strong="H4100"\w* \w pueblo|strong="H5971"\w* eres?».   
\p
\v 9 \w Él|strong="H6213"\w* les respondió: «Soy \w hebreo|strong="H5680"\w* y temo \w a|strong="H3068"\w* Yahvé, \w el|strong="H6213"\w* \w Dios|strong="H3068"\w* del \w cielo|strong="H8064"\w*, que ha \w hecho|strong="H6213"\w* \w el|strong="H6213"\w* \w mar|strong="H3220"\w* y la \w tierra|strong="H3004"\w* firme».   
\p
\v 10 \w Entonces|strong="H3588"\w* \w aquellos|strong="H1992"\w* hombres sintieron un \w gran|strong="H1419"\w* \w temor|strong="H3372"\w* \w y|strong="H3588"\w* \w le|strong="H1931"\w* dijeron: «¿\w Qué|strong="H3588"\w* \w es|strong="H1931"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* has \w hecho|strong="H6213"\w*?». \w Pues|strong="H3588"\w* \w sabían|strong="H3045"\w* \w que|strong="H3588"\w* \w huía|strong="H1272"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w presencia|strong="H6440"\w* \w de|strong="H3588"\w* Yahvé, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w mismo|strong="H1931"\w* \w se|strong="H3045"\w* \w lo|strong="H1931"\w* \w había|strong="H3588"\w* dicho.  
\v 11 \w Le|strong="H5921"\w* preguntaron: «¿\w Qué|strong="H3588"\w* \w haremos|strong="H6213"\w* \w contigo|strong="H5921"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H5921"\w* \w nos|strong="H5921"\w* calme?». \w Pues|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H5921"\w* embravecía cada vez \w más|strong="H3588"\w*.   
\p
\v 12 \w Él|strong="H5921"\w* \w les|strong="H5921"\w* respondió: «Levantadme \w y|strong="H3588"\w* arrojadme \w al|strong="H5921"\w* \w mar|strong="H3220"\w*. \w Entonces|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H3045"\w* \w os|strong="H5921"\w* calmará; \w porque|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w por|strong="H5921"\w* \w mi|strong="H5921"\w* culpa \w os|strong="H5921"\w* ha sobrevenido \w esta|strong="H2088"\w* \w gran|strong="H1419"\w* \w tempestad|strong="H5591"\w*».   
\p
\v 13 \w Sin|strong="H3808"\w* embargo, \w los|strong="H5921"\w* hombres remaron \w con|strong="H5921"\w* ahínco \w para|strong="H5921"\w* alcanzar \w tierra|strong="H3004"\w* firme, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w*, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H5921"\w* \w volvía|strong="H7725"\w* cada vez \w más|strong="H3588"\w* tempestuoso \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 14 \w Entonces|strong="H3588"\w* clamaron \w a|strong="H3068"\w* Yahvé \w y|strong="H3588"\w* dijeron: «\w Te|strong="H5921"\w* rogamos, Yahvé, \w que|strong="H3588"\w* \w no|strong="H6213"\w* \w nos|strong="H5921"\w* dejes morir \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w vida|strong="H5315"\w* \w de|strong="H5921"\w* \w este|strong="H2088"\w* hombre, \w ni|strong="H5355"\w* \w nos|strong="H5921"\w* \w hagas|strong="H6213"\w* responsables \w de|strong="H5921"\w* \w sangre|strong="H1818"\w* \w inocente|strong="H5355"\w*; \w porque|strong="H3588"\w* \w tú|strong="H6213"\w*, Yahvé, \w has|strong="H5414"\w* \w hecho|strong="H6213"\w* \w lo|strong="H2088"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* ha parecido».  
\v 15 \w Tomaron|strong="H5375"\w*, pues, \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w* y lo arrojaron al \w mar|strong="H3220"\w*; y el \w mar|strong="H3220"\w* detuvo su furia.  
\v 16 Entonces aquellos hombres \w temieron|strong="H3372"\w* \w mucho|strong="H1419"\w* \w a|strong="H3068"\w* Yahvé, ofrecieron un \w sacrificio|strong="H2077"\w* \w a|strong="H3068"\w* Yahvé \w e|strong="H3068"\w* hicieron \w votos|strong="H5087"\w*.   
\p
\v 17 Yahvé preparó un gran pez para que se tragara \w a|strong="H3068"\w* Jonás; y Jonás estuvo en el vientre del pez tres días y tres noches.   
\c 2
\p
\v 1 \w Entonces|strong="H3117"\w* \w Jonás|strong="H3124"\w* oró \w a|strong="H3068"\w* Yahvé, su \w Dios|strong="H3068"\w*, desde el vientre del \w pez|strong="H1709"\w*.  
\v 2 Dijo:  
\q1 “En mi angustia clamé \w a|strong="H3068"\w* Yahvé,  
\q2 y él me respondió.  
\q1 Desde el seno del Seol pedí auxilio,  
\q2 y tú oíste mi voz.   
\q1
\v 3 Porque me arrojaste \w a|strong="H3068"\w* lo profundo,  
\q2 en el corazón de los mares;  
\q1 la corriente me envolvió.  
\q2 Todas tus ondas y tus olas pasaron sobre \w mí|strong="H6030"\w*.   
\q1
\v 4 Entonces dije: ‘He sido expulsado \w de|strong="H5921"\w* tu presencia;  
\q2 sin embargo, volveré \w a|strong="H3068"\w* mirar \w hacia|strong="H5921"\w* tu santo templo’.   
\q1
\v 5 Las aguas me rodearon hasta el alma,  
\q2 el abismo me envolvió;  
\q1 las algas se enredaron en mi cabeza.   
\q1
\v 6 Descendí \w a|strong="H3068"\w* los cimientos \w de|strong="H5704"\w* los montes;  
\q2 los cerrojos \w de|strong="H5704"\w* la tierra se cerraron sobre \w mí|strong="H5315"\w* \w para|strong="H5704"\w* siempre;  
\q2 \w mas|strong="H5704"\w* tú sacaste \w mi|strong="H5315"\w* \w vida|strong="H5315"\w* \w de|strong="H5704"\w* la fosa, Yahvé, Dios mío.   
\b  
\q1
\v 7 «Cuando mi alma desfallecía en mí, me acordé de Yahvé,  
\q2 y mi oración \w llegó|strong="H5927"\w* hasta ti, \w a|strong="H3068"\w* tu santo templo.   
\q1
\v 8 \w Los|strong="H5921"\w* \w que|strong="H5921"\w* siguen \w a|strong="H3068"\w* \w los|strong="H5921"\w* ídolos vanos  
\q2 abandonan su propia fidelidad.   
\q1
\v 9 Mas yo, con voz de alabanza, te ofreceré sacrificios;  
\q2 cumpliré lo que prometí.  
\q1 \w La|strong="H8104"\w* salvación pertenece \w a|strong="H3068"\w* Yahvé».   
\p
\v 10 Entonces Yahvé habló al pez, y este vomitó \w a|strong="H3068"\w* Jonás en tierra firme.   
\c 3
\p
\v 1 La \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé llegó \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w* \w por|strong="H1697"\w* \w segunda|strong="H8145"\w* vez, diciendo:  
\v 2 «\w Levántate|strong="H6965"\w*, \w ve|strong="H3212"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, aquella \w gran|strong="H1419"\w* \w ciudad|strong="H5892"\w*, y proclama \w en|strong="H3212"\w* ella el mensaje que yo te daré».   
\p
\v 3 \w Jonás|strong="H3124"\w* \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* y \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, conforme \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé. \w Nínive|strong="H5210"\w* \w era|strong="H1961"\w* una \w ciudad|strong="H5892"\w* tan \w grande|strong="H1419"\w* \w que|strong="H1697"\w* \w se|strong="H1961"\w* requerían \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w para|strong="H1961"\w* recorrerla.  
\v 4 \w Jonás|strong="H3124"\w* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* entrar \w en|strong="H5750"\w* la \w ciudad|strong="H5892"\w* el primer \w día|strong="H3117"\w* \w de|strong="H5750"\w* \w camino|strong="H4109"\w*, y pregonaba diciendo: «¡\w Dentro|strong="H5750"\w* \w de|strong="H5750"\w* cuarenta \w días|strong="H3117"\w* \w Nínive|strong="H5210"\w* será destruida!».   
\p
\v 5 \w Y|strong="H3068"\w* los hombres \w de|strong="H5704"\w* \w Nínive|strong="H5210"\w* creyeron \w a|strong="H3068"\w* Dios, proclamaron \w ayuno|strong="H6685"\w* \w y|strong="H5704"\w* se vistieron \w de|strong="H5704"\w* cilicio \w desde|strong="H5704"\w* el \w mayor|strong="H1419"\w* \w hasta|strong="H5704"\w* el \w menor|strong="H6996"\w* \w de|strong="H5704"\w* ellos.  
\v 6 Cuando \w la|strong="H5921"\w* noticia \w llegó|strong="H5060"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Nínive|strong="H5210"\w*, este \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w de|strong="H5921"\w* su \w trono|strong="H3678"\w*, \w se|strong="H5921"\w* despojó \w de|strong="H5921"\w* su manto \w real|strong="H4428"\w*, \w se|strong="H5921"\w* \w cubrió|strong="H3680"\w* \w de|strong="H5921"\w* cilicio \w y|strong="H5921"\w* \w se|strong="H5921"\w* sentó \w sobre|strong="H5921"\w* ceniza.  
\v 7 \w E|strong="H3068"\w* hizo proclamar \w y|strong="H1241"\w* anunciar en \w Nínive|strong="H5210"\w*, \w por|strong="H4428"\w* decreto \w del|strong="H8354"\w* \w rey|strong="H4428"\w* \w y|strong="H1241"\w* \w de|strong="H4325"\w* sus \w grandes|strong="H1419"\w*, lo siguiente: «\w Que|strong="H4325"\w* hombres \w y|strong="H1241"\w* animales, \w bueyes|strong="H1241"\w* \w y|strong="H1241"\w* \w ovejas|strong="H6629"\w*, no \w gusten|strong="H2938"\w* \w cosa|strong="H3972"\w* \w alguna|strong="H3972"\w*; no se \w les|strong="H3972"\w* \w dé|strong="H4325"\w* alimento ni \w beban|strong="H8354"\w* \w agua|strong="H4325"\w*;  
\v 8 sino cúbranse \w de|strong="H4480"\w* cilicio hombres y animales, y clamen \w a|strong="H3068"\w* Dios fervientemente; y \w conviértase|strong="H7725"\w* cada uno \w de|strong="H4480"\w* su \w mal|strong="H7451"\w* \w camino|strong="H1870"\w* y \w de|strong="H4480"\w* la \w violencia|strong="H2555"\w* \w que|strong="H4480"\w* hay \w en|strong="H4480"\w* sus \w manos|strong="H3709"\w*.  
\v 9 ¿\w Quién|strong="H4310"\w* \w sabe|strong="H3045"\w* \w si|strong="H3808"\w* Dios \w se|strong="H3045"\w* \w volverá|strong="H7725"\w* y \w se|strong="H3045"\w* arrepentirá, y \w se|strong="H3045"\w* apartará del \w furor|strong="H2740"\w* de su \w ira|strong="H2740"\w*, de modo \w que|strong="H4310"\w* \w no|strong="H3808"\w* perezcamos?».   
\p
\v 10 \w Vio|strong="H7200"\w* Dios \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w hicieron|strong="H6213"\w*, \w cómo|strong="H3588"\w* \w se|strong="H5921"\w* convirtieron \w de|strong="H5921"\w* \w su|strong="H1992"\w* \w mal|strong="H7451"\w* \w camino|strong="H1870"\w*, \w y|strong="H3588"\w* \w se|strong="H5921"\w* arrepintió Dios \w del|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* \w dicho|strong="H1696"\w* \w que|strong="H3588"\w* \w les|strong="H1992"\w* \w haría|strong="H6213"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* llevó \w a|strong="H3068"\w* cabo.   
\c 4
\p
\v 1 Pero esto disgustó \w mucho|strong="H1419"\w* \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w*, y se enojó.  
\v 2 \w Oró|strong="H6419"\w* \w a|strong="H3068"\w* Yahvé \w y|strong="H3588"\w* dijo: «\w Te|strong="H5921"\w* ruego, Yahvé, ¿\w no|strong="H3808"\w* \w es|strong="H1961"\w* \w esto|strong="H2088"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* decía \w cuando|strong="H3588"\w* \w aún|strong="H5704"\w* \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* tierra? \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w me|strong="H5921"\w* apresuré \w a|strong="H3068"\w* huir \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*; \w porque|strong="H3588"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* \w eres|strong="H1961"\w* un \w Dios|strong="H3068"\w* \w clemente|strong="H2587"\w* \w y|strong="H3588"\w* \w misericordioso|strong="H7349"\w*, lento \w para|strong="H5704"\w* \w la|strong="H5921"\w* ira \w y|strong="H3588"\w* \w grande|strong="H7227"\w* \w en|strong="H5921"\w* \w misericordia|strong="H2617"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* arrepientes \w del|strong="H5921"\w* \w mal|strong="H7451"\w*.  
\v 3 \w Por|strong="H3588"\w* tanto \w ahora|strong="H6258"\w*, Yahvé, \w te|strong="H4480"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w me|strong="H4480"\w* \w quites|strong="H3947"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w*, \w porque|strong="H3588"\w* \w mejor|strong="H2896"\w* \w me|strong="H4480"\w* \w es|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w*».   
\p
\v 4 Yahvé le preguntó: «¿Haces \w bien|strong="H3190"\w* en enojarte tanto?».   
\p
\v 5 \w Jonás|strong="H3124"\w* \w salió|strong="H3318"\w* \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w* \w y|strong="H5704"\w* \w se|strong="H1961"\w* sentó \w al|strong="H4480"\w* \w oriente|strong="H6924"\w* \w de|strong="H4480"\w* \w ella|strong="H8033"\w*; \w allí|strong="H8033"\w* \w se|strong="H1961"\w* \w hizo|strong="H6213"\w* una enramada \w y|strong="H5704"\w* \w se|strong="H1961"\w* sentó \w bajo|strong="H8478"\w* su \w sombra|strong="H6738"\w*, esperando \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w qué|strong="H4100"\w* \w sería|strong="H1961"\w* \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w*.  
\v 6 Entonces \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* \w Dios|strong="H3068"\w* dispuso una planta, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w hizo|strong="H5927"\w* crecer \w sobre|strong="H5921"\w* \w Jonás|strong="H3124"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* hiciese \w sombra|strong="H6738"\w* \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* librase \w de|strong="H5921"\w* su malestar. \w Y|strong="H3068"\w* \w Jonás|strong="H3124"\w* \w se|strong="H1961"\w* alegró \w mucho|strong="H1419"\w* \w por|strong="H5921"\w* \w aquella|strong="H5921"\w* planta.  
\v 7 Pero al amanecer del día \w siguiente|strong="H4283"\w*, Dios dispuso un \w gusano|strong="H8438"\w*, el cual \w hirió|strong="H5221"\w* la planta y esta se \w secó|strong="H3001"\w*.  
\v 8 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H5921"\w*, \w al|strong="H5921"\w* salir \w el|strong="H5921"\w* \w sol|strong="H8121"\w*, Dios dispuso un recio \w viento|strong="H7307"\w* \w solano|strong="H6921"\w*; \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w sol|strong="H8121"\w* \w hirió|strong="H5221"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w Jonás|strong="H3124"\w*, \w de|strong="H5921"\w* modo \w que|strong="H5921"\w* \w se|strong="H1961"\w* desmayaba \w y|strong="H5921"\w* deseaba \w la|strong="H5921"\w* \w muerte|strong="H4191"\w*, diciendo: «\w Mejor|strong="H2896"\w* \w me|strong="H5921"\w* \w sería|strong="H1961"\w* \w morir|strong="H4191"\w* \w que|strong="H5921"\w* vivir».   
\p
\v 9 Entonces dijo Dios \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w*: «¿Haces \w bien|strong="H3190"\w* \w en|strong="H5921"\w* enojarte \w por|strong="H5921"\w* \w la|strong="H5921"\w* planta?». \w Y|strong="H3068"\w* \w él|strong="H5921"\w* respondió: «Hago \w bien|strong="H3190"\w* \w en|strong="H5921"\w* enojarme, \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* \w muerte|strong="H4194"\w*».   
\p
\v 10 \w Y|strong="H3068"\w* dijo Yahvé: «Tú \w te|strong="H5921"\w* compadeciste \w de|strong="H5921"\w* \w la|strong="H5921"\w* planta, \w por|strong="H5921"\w* \w la|strong="H5921"\w* cual \w no|strong="H3808"\w* \w trabajaste|strong="H5998"\w* \w ni|strong="H3808"\w* \w la|strong="H5921"\w* hiciste crecer; \w que|strong="H3808"\w* \w en|strong="H5921"\w* una \w noche|strong="H3915"\w* \w nació|strong="H1961"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* una \w noche|strong="H3915"\w* pereció.  
\v 11 ¿\w Y|strong="H3068"\w* \w no|strong="H3808"\w* habré yo \w de|strong="H5921"\w* tener piedad \w de|strong="H5921"\w* \w Nínive|strong="H5210"\w*, \w aquella|strong="H5921"\w* \w gran|strong="H1419"\w* \w ciudad|strong="H5892"\w* \w donde|strong="H5921"\w* \w hay|strong="H3426"\w* \w más|strong="H5921"\w* \w de|strong="H5921"\w* ciento \w veinte|strong="H8147"\w* mil personas \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w saben|strong="H3045"\w* distinguir \w entre|strong="H5921"\w* su mano \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* su mano \w izquierda|strong="H8040"\w*, \w y|strong="H5921"\w* \w muchos|strong="H7227"\w* animales?».   