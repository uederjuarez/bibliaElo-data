\v 12 Ahora, \w hijo|strong="H1121"\w* mío, \w a|strong="H3068"\w* \w más|strong="H7235"\w* \w de|strong="H1121"\w* \w esto|strong="H6213"\w*, acepta ser advertido: \w no|strong="H6213"\w* hay \w fin|strong="H7093"\w* \w de|strong="H1121"\w* \w hacer|strong="H6213"\w* \w muchos|strong="H7235"\w* \w libros|strong="H5612"\w*; y \w el|strong="H1121"\w* \w mucho|strong="H7235"\w* \w estudio|strong="H3854"\w* \w es|strong="H7235"\w* fatiga \w de|strong="H1121"\w* la \w carne|strong="H1320"\w*.   
\p
\v 13 \w El|strong="H3588"\w* fin \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* discurso \w oído|strong="H8085"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w*: \w Temed|strong="H3372"\w* \w a|strong="H3068"\w* Dios, \w y|strong="H3588"\w* \w guardad|strong="H8104"\w* sus \w mandamientos|strong="H4687"\w*; \w porque|strong="H3588"\w* \w esto|strong="H2088"\w* \w es|strong="H2088"\w* \w el|strong="H3588"\w* \w todo|strong="H3605"\w* del hombre.  
\v 14 \w Porque|strong="H3588"\w* Dios traerá \w toda|strong="H3605"\w* \w obra|strong="H4639"\w* \w a|strong="H3068"\w* \w juicio|strong="H4941"\w*, juntamente \w con|strong="H5921"\w* \w toda|strong="H3605"\w* \w cosa|strong="H3605"\w* oculta, sea \w buena|strong="H2896"\w* \w o|strong="H3068"\w* sea \w mala|strong="H7451"\w*.   