\mt1 Eclesiastés  
\mt2 o, El predicador  
\c 1
\p
\v 1 \w Palabras|strong="H1697"\w* del Predicador, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w rey|strong="H4428"\w* en Jerusalén:   
\p
\v 2 «\w Vanidad|strong="H1892"\w* de \w vanidades|strong="H1892"\w*», dice \w el|strong="H3605"\w* Predicador; «\w Vanidad|strong="H1892"\w* de \w vanidades|strong="H1892"\w*, \w todo|strong="H3605"\w* es \w vanidad|strong="H1892"\w*».  
\v 3 ¿\w Qué|strong="H4100"\w* \w provecho|strong="H3504"\w* saca \w el|strong="H3605"\w* hombre \w de|strong="H8478"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w trabajo|strong="H5999"\w* con \w que|strong="H4100"\w* \w se|strong="H4100"\w* afana \w bajo|strong="H8478"\w* \w el|strong="H3605"\w* \w sol|strong="H8121"\w*?  
\v 4 Una \w generación|strong="H1755"\w* \w va|strong="H3068"\w*, y otra \w viene|strong="H1980"\w*; pero la tierra \w permanece|strong="H5975"\w* para \w siempre|strong="H5769"\w*.  
\v 5 \w Sale|strong="H2224"\w* \w el|strong="H1931"\w* \w sol|strong="H8121"\w*, y \w se|strong="H1931"\w* pone \w el|strong="H1931"\w* \w sol|strong="H8121"\w*, y \w se|strong="H1931"\w* apresura \w a|strong="H3068"\w* volver al \w lugar|strong="H4725"\w* de \w donde|strong="H8033"\w* nace.  
\v 6 \w El|strong="H5921"\w* \w viento|strong="H7307"\w* sopla \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* sur, \w y|strong="H5921"\w* gira \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w norte|strong="H6828"\w*; \w va|strong="H3068"\w* \w girando|strong="H5437"\w* continuamente, \w y|strong="H5921"\w* \w a|strong="H3068"\w* sus giros \w vuelve|strong="H7725"\w* \w el|strong="H5921"\w* \w viento|strong="H7307"\w* \w de|strong="H5921"\w* nuevo.  
\v 7 \w Todos|strong="H3605"\w* \w los|strong="H1992"\w* ríos \w van|strong="H1980"\w* al \w mar|strong="H3220"\w*, y \w el|strong="H3605"\w* \w mar|strong="H3220"\w* no \w se|strong="H1992"\w* \w llena|strong="H4392"\w*; al \w lugar|strong="H4725"\w* de \w donde|strong="H8033"\w* \w los|strong="H1992"\w* ríos \w vinieron|strong="H1980"\w*, \w allí|strong="H8033"\w* \w vuelven|strong="H7725"\w* para correr de nuevo.  
\v 8 \w Todas|strong="H3605"\w* las \w cosas|strong="H1697"\w* \w son|strong="H3808"\w* fatigosas, \w más|strong="H3808"\w* \w de|strong="H1697"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w el|strong="H3605"\w* hombre \w puede|strong="H3201"\w* expresar; \w nunca|strong="H3808"\w* \w se|strong="H3808"\w* sacia \w el|strong="H3605"\w* \w ojo|strong="H5869"\w* \w de|strong="H1697"\w* \w ver|strong="H7200"\w*, \w ni|strong="H3808"\w* \w el|strong="H3605"\w* \w oído|strong="H8085"\w* \w se|strong="H3808"\w* harta \w de|strong="H1697"\w* \w oír|strong="H8085"\w*.  
\v 9 \w Lo|strong="H1931"\w* \w que|strong="H4100"\w* \w fue|strong="H1961"\w*, \w eso|strong="H1931"\w* \w mismo|strong="H1931"\w* \w será|strong="H1961"\w*; \w lo|strong="H1931"\w* \w que|strong="H4100"\w* \w se|strong="H1961"\w* ha \w hecho|strong="H6213"\w*, \w eso|strong="H1931"\w* \w mismo|strong="H1931"\w* \w se|strong="H1961"\w* \w hará|strong="H6213"\w*; y \w no|strong="H6213"\w* \w hay|strong="H1961"\w* \w nada|strong="H3605"\w* \w nuevo|strong="H2319"\w* \w bajo|strong="H8478"\w* \w el|strong="H1931"\w* \w sol|strong="H8121"\w*.  
\v 10 ¿Acaso \w hay|strong="H3426"\w* \w algo|strong="H1697"\w* \w de|strong="H6440"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w se|strong="H1961"\w* pueda decir: «\w Mirad|strong="H7200"\w*, \w esto|strong="H2088"\w* \w es|strong="H1931"\w* \w nuevo|strong="H2319"\w*»? \w Ya|strong="H3068"\w* existió en \w los|strong="H1931"\w* \w siglos|strong="H5769"\w* \w que|strong="H1931"\w* nos precedieron.  
\v 11 \w No|strong="H3808"\w* queda \w memoria|strong="H2146"\w* \w de|strong="H5973"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* precedió, \w ni|strong="H3808"\w* \w de|strong="H5973"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w ha|strong="H3808"\w* \w de|strong="H5973"\w* venir \w quedará|strong="H1961"\w* \w memoria|strong="H2146"\w* \w entre|strong="H5973"\w* \w los|strong="H1992"\w* \w que|strong="H3808"\w* vendrán \w después|strong="H1961"\w*.   
\p
\v 12 Yo, \w el|strong="H5921"\w* Predicador, \w fui|strong="H1961"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* Jerusalén.  
\v 13 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* \w propuse|strong="H8446"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w* buscar \w y|strong="H5921"\w* escudriñar \w con|strong="H5921"\w* \w sabiduría|strong="H2451"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* \w hace|strong="H6213"\w* \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*; \w este|strong="H1931"\w* \w penoso|strong="H7451"\w* afán ha \w dado|strong="H5414"\w* Dios\f + \fr 1:13 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w para|strong="H5921"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* ocupen \w en|strong="H5921"\w* \w él|strong="H1931"\w*.  
\v 14 He \w visto|strong="H7200"\w* \w todas|strong="H3605"\w* las \w obras|strong="H4639"\w* \w que|strong="H3605"\w* se \w hacen|strong="H6213"\w* \w debajo|strong="H8478"\w* del \w sol|strong="H8121"\w*; y \w ved|strong="H7200"\w* \w que|strong="H3605"\w* \w todo|strong="H3605"\w* es \w vanidad|strong="H1892"\w* y correr tras \w el|strong="H3605"\w* \w viento|strong="H7307"\w*.  
\v 15 \w Lo|strong="H3808"\w* torcido \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w puede|strong="H3201"\w* enderezar, y \w lo|strong="H3808"\w* \w que|strong="H3808"\w* falta \w no|strong="H3808"\w* \w puede|strong="H3201"\w* contarse.  
\v 16 \w Hablé|strong="H1696"\w* \w yo|strong="H2009"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w*, \w diciendo|strong="H1696"\w*: «He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w yo|strong="H2009"\w* \w me|strong="H5921"\w* he \w engrandecido|strong="H1431"\w*, \w y|strong="H5921"\w* he \w crecido|strong="H1431"\w* \w en|strong="H5921"\w* \w sabiduría|strong="H2451"\w* \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w fueron|strong="H1961"\w* \w antes|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w en|strong="H5921"\w* Jerusalén; \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w* ha percibido \w mucha|strong="H7235"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H5921"\w* \w conocimiento|strong="H1847"\w*».  
\v 17 \w Y|strong="H3068"\w* dediqué mi \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* conocer \w la|strong="H1931"\w* \w sabiduría|strong="H2451"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* conocer \w la|strong="H1931"\w* \w locura|strong="H5531"\w* \w y|strong="H1571"\w* \w el|strong="H1931"\w* desvarío; \w y|strong="H1571"\w* comprendí \w que|strong="H1931"\w* \w aun|strong="H1571"\w* \w esto|strong="H2088"\w* \w era|strong="H1931"\w* correr tras \w el|strong="H1931"\w* \w viento|strong="H7307"\w*.  
\v 18 \w Porque|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H2451"\w* \w mucha|strong="H7227"\w* \w sabiduría|strong="H2451"\w* hay \w mucha|strong="H7227"\w* \w molestia|strong="H3708"\w*; \w y|strong="H3588"\w* quien \w añade|strong="H3254"\w* \w ciencia|strong="H1847"\w*, \w añade|strong="H3254"\w* \w dolor|strong="H4341"\w*.   
\c 2
\p
\v 1 Dije \w yo|strong="H2009"\w* \w en|strong="H3212"\w* \w mi|strong="H2009"\w* \w corazón|strong="H3820"\w*: «\w Ven|strong="H3212"\w* \w ahora|strong="H4994"\w*, te \w probaré|strong="H5254"\w* \w con|strong="H1571"\w* \w la|strong="H1931"\w* \w alegría|strong="H8057"\w*; \w goza|strong="H7200"\w* de \w lo|strong="H1931"\w* \w bueno|strong="H2896"\w*»; \w y|strong="H1571"\w* he \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w también|strong="H1571"\w* \w esto|strong="H1931"\w* \w era|strong="H1931"\w* \w vanidad|strong="H1892"\w*.  
\v 2 De la risa dije: «Es una locura», y del placer: «¿De \w qué|strong="H4100"\w* \w sirve|strong="H6213"\w* \w esto|strong="H2090"\w*?»   
\p
\v 3 Decidí \w en|strong="H5704"\w* mi \w corazón|strong="H3820"\w* agasajar mi \w carne|strong="H1320"\w* \w con|strong="H5704"\w* \w el|strong="H1121"\w* \w vino|strong="H3196"\w*, manteniendo mi \w corazón|strong="H3820"\w* \w el|strong="H1121"\w* sentido \w de|strong="H8478"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*, \w y|strong="H5704"\w* entregarme \w a|strong="H3068"\w* \w la|strong="H2451"\w* necedad, \w hasta|strong="H5704"\w* \w ver|strong="H7200"\w* \w qué|strong="H5704"\w* \w era|strong="H1121"\w* \w lo|strong="H2088"\w* \w mejor|strong="H2896"\w* \w para|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w que|strong="H5704"\w* \w hiciesen|strong="H6213"\w* \w bajo|strong="H8478"\w* \w el|strong="H1121"\w* \w cielo|strong="H8064"\w* \w todos|strong="H4557"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H8478"\w* su \w vida|strong="H2416"\w*.  
\v 4 Emprendí \w grandes|strong="H1431"\w* \w obras|strong="H4639"\w*: me \w edifiqué|strong="H1129"\w* \w casas|strong="H1004"\w*, me \w planté|strong="H5193"\w* viñedos;  
\v 5 me \w hice|strong="H6213"\w* \w huertos|strong="H1593"\w* y jardines, y \w planté|strong="H5193"\w* en \w ellos|strong="H3605"\w* \w toda|strong="H3605"\w* suerte de \w árboles|strong="H6086"\w* frutales.  
\v 6 Me construí estanques \w de|strong="H4325"\w* \w aguas|strong="H4325"\w* para regar con \w ellos|strong="H1992"\w* \w el|strong="H6213"\w* \w bosque|strong="H3293"\w* donde \w crecían|strong="H6779"\w* \w los|strong="H1992"\w* \w árboles|strong="H6086"\w*.  
\v 7 Compré \w criados|strong="H5650"\w* \w y|strong="H1571"\w* criadas, \w y|strong="H1571"\w* \w tuve|strong="H1961"\w* \w criados|strong="H5650"\w* nacidos en \w casa|strong="H1004"\w*; \w poseí|strong="H7069"\w* \w también|strong="H1571"\w* \w muchos|strong="H7235"\w* rebaños \w de|strong="H6440"\w* \w vacas|strong="H1241"\w* \w y|strong="H1571"\w* \w de|strong="H6440"\w* \w ovejas|strong="H6629"\w*, \w más|strong="H1571"\w* \w que|strong="H1571"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1571"\w* \w fueron|strong="H1961"\w* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H3389"\w* en Jerusalén.  
\v 8 Amontoné \w también|strong="H1571"\w* \w plata|strong="H3701"\w* \w y|strong="H1571"\w* \w oro|strong="H2091"\w*, \w y|strong="H1571"\w* tesoros propios \w de|strong="H1121"\w* \w reyes|strong="H4428"\w* \w y|strong="H1571"\w* \w de|strong="H1121"\w* \w provincias|strong="H4082"\w*; me agencié \w cantores|strong="H7891"\w* \w y|strong="H1571"\w* cantoras, \w y|strong="H1571"\w* las delicias \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*: toda clase \w de|strong="H1121"\w* \w instrumentos|strong="H7705"\w* musicales.  
\v 9 Así me \w engrandecí|strong="H1431"\w* y medré \w más|strong="H3254"\w* \w que|strong="H1961"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H1961"\w* \w fueron|strong="H1961"\w* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H3389"\w* \w en|strong="H5975"\w* Jerusalén; y además \w de|strong="H6440"\w* esto, \w mi|strong="H3389"\w* \w sabiduría|strong="H2451"\w* \w permaneció|strong="H5975"\w* conmigo.  
\v 10 \w No|strong="H3808"\w* negué \w a|strong="H3068"\w* mis \w ojos|strong="H5869"\w* \w ninguna|strong="H3605"\w* \w cosa|strong="H3605"\w* \w que|strong="H3588"\w* \w desearan|strong="H7592"\w*, \w ni|strong="H3808"\w* \w aparté|strong="H4513"\w* \w mi|strong="H1961"\w* \w corazón|strong="H3820"\w* \w de|strong="H3588"\w* placer \w alguno|strong="H3605"\w*, \w porque|strong="H3588"\w* \w mi|strong="H1961"\w* \w corazón|strong="H3820"\w* \w gozó|strong="H8057"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w mi|strong="H1961"\w* arduo \w trabajo|strong="H5999"\w*; \w y|strong="H3588"\w* \w esta|strong="H2088"\w* \w fue|strong="H1961"\w* \w la|strong="H3588"\w* \w parte|strong="H2506"\w* \w que|strong="H3588"\w* saqué \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w mi|strong="H1961"\w* faena.  
\v 11 \w Miré|strong="H6437"\w* \w yo|strong="H2009"\w* luego \w todas|strong="H3605"\w* las \w obras|strong="H4639"\w* \w que|strong="H3605"\w* mis \w manos|strong="H3027"\w* habían \w hecho|strong="H6213"\w*, y \w el|strong="H3605"\w* \w trabajo|strong="H5999"\w* \w que|strong="H3605"\w* me tomó hacerlas; y he \w aquí|strong="H2009"\w*, \w todo|strong="H3605"\w* era \w vanidad|strong="H1892"\w* y correr tras \w el|strong="H3605"\w* \w viento|strong="H7307"\w*, y sin \w provecho|strong="H3504"\w* \w alguno|strong="H3605"\w* \w bajo|strong="H8478"\w* \w el|strong="H3605"\w* \w sol|strong="H8121"\w*.   
\p
\v 12 Volví \w entonces|strong="H3588"\w* mis ojos \w a|strong="H3068"\w* considerar \w la|strong="H3588"\w* \w sabiduría|strong="H2451"\w*, \w la|strong="H3588"\w* \w locura|strong="H5531"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* necedad; \w porque|strong="H3588"\w* ¿\w qué|strong="H3588"\w* podrá \w hacer|strong="H6213"\w* \w el|strong="H3588"\w* hombre \w que|strong="H3588"\w* suceda \w al|strong="H4428"\w* \w rey|strong="H4428"\w*? Nada \w sino|strong="H3588"\w* \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \w ya|strong="H3528"\w* \w ha|strong="H3528"\w* sido \w hecho|strong="H6213"\w*.  
\v 13 \w Y|strong="H3068"\w* \w vi|strong="H7200"\w* \w que|strong="H4480"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* aventaja \w a|strong="H3068"\w* \w la|strong="H2451"\w* necedad, como \w la|strong="H2451"\w* luz aventaja \w a|strong="H3068"\w* las \w tinieblas|strong="H2822"\w*.  
\v 14 \w El|strong="H3605"\w* \w sabio|strong="H2450"\w* tiene sus \w ojos|strong="H5869"\w* en su rostro, \w mas|strong="H1571"\w* \w el|strong="H3605"\w* \w necio|strong="H3684"\w* \w camina|strong="H1980"\w* en \w tinieblas|strong="H2822"\w*; pero \w también|strong="H1571"\w* comprendí \w que|strong="H1571"\w* un \w mismo|strong="H3605"\w* \w suceso|strong="H4745"\w* les ocurre \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w ellos|strong="H1571"\w*.  
\v 15 \w Entonces|strong="H1571"\w* \w dije|strong="H1696"\w* en mi \w corazón|strong="H3820"\w*: «\w Como|strong="H4100"\w* le sucede al \w necio|strong="H3684"\w*, me \w sucederá|strong="H7136"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* mí; ¿para \w qué|strong="H4100"\w*, \w pues|strong="H2088"\w*, me he hecho yo \w más|strong="H1571"\w* \w sabio|strong="H2449"\w*?». \w Y|strong="H3068"\w* \w dije|strong="H1696"\w* en mi \w corazón|strong="H3820"\w* \w que|strong="H4100"\w* \w también|strong="H1571"\w* \w esto|strong="H2088"\w* \w era|strong="H2088"\w* \w vanidad|strong="H1892"\w*.  
\v 16 \w Porque|strong="H3588"\w* \w no|strong="H3588"\w* hay \w memoria|strong="H2146"\w* duradera \w ni|strong="H5973"\w* \w del|strong="H5973"\w* \w sabio|strong="H2450"\w* \w ni|strong="H5973"\w* \w del|strong="H5973"\w* \w necio|strong="H3684"\w*; \w en|strong="H5973"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* venideros \w todo|strong="H3605"\w* será \w ya|strong="H3528"\w* olvidado, \w y|strong="H3588"\w* \w morirá|strong="H4191"\w* \w el|strong="H5973"\w* \w sabio|strong="H2450"\w* \w lo|strong="H3605"\w* \w mismo|strong="H3605"\w* \w que|strong="H3588"\w* \w el|strong="H5973"\w* \w necio|strong="H3684"\w*.   
\p
