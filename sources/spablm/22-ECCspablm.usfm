\v 13 \w También|strong="H1571"\w* \w vi|strong="H7200"\w* \w esta|strong="H1931"\w* \w sabiduría|strong="H2451"\w* \w debajo|strong="H8478"\w* del \w sol|strong="H8121"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* me \w pareció|strong="H7200"\w* \w grande|strong="H1419"\w*:  
\v 14 había una \w pequeña|strong="H6996"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H5921"\w* \w pocos|strong="H4592"\w* hombres \w en|strong="H5921"\w* \w ella|strong="H5921"\w*; \w y|strong="H5921"\w* vino \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* un \w gran|strong="H1419"\w* \w rey|strong="H4428"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* asedió \w y|strong="H5921"\w* levantó \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* \w grandes|strong="H1419"\w* \w baluartes|strong="H4685"\w*.  
\v 15 \w Y|strong="H3068"\w* \w se|strong="H1931"\w* hallaba en \w ella|strong="H1931"\w* un hombre \w pobre|strong="H4542"\w* y \w sabio|strong="H2450"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* libró \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* con \w su|strong="H1931"\w* \w sabiduría|strong="H2451"\w*; ¡y \w nadie|strong="H3808"\w* \w se|strong="H1931"\w* acordaba de \w aquel|strong="H1931"\w* hombre \w pobre|strong="H4542"\w*!  
\v 16 Entonces dije yo: «\w Mejor|strong="H2896"\w* \w es|strong="H1697"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* \w que|strong="H1697"\w* \w la|strong="H2451"\w* fuerza», aunque \w la|strong="H2451"\w* ciencia del \w pobre|strong="H4542"\w* sea menospreciada, y no sean escuchadas sus \w palabras|strong="H1697"\w*.  
\v 17 Las \w palabras|strong="H1697"\w* del \w sabio|strong="H2450"\w* escuchadas en quietud son mejores \w que|strong="H1697"\w* el \w clamor|strong="H2201"\w* del \w que|strong="H1697"\w* señorea entre \w los|strong="H2450"\w* necios.  
\v 18 \w Mejor|strong="H2896"\w* \w es|strong="H7235"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* que las \w armas|strong="H3627"\w* de guerra; pero un solo \w pecador|strong="H2398"\w* destruye \w mucho|strong="H7235"\w* \w bien|strong="H2896"\w*.   
\c 10
\q1
\v 1 Las moscas \w muertas|strong="H4194"\w* hacen que el \w ungüento|strong="H8081"\w* del perfumista hieda \w y|strong="H3519"\w* se corrompa;  
\q2 así un \w poco|strong="H4592"\w* de \w locura|strong="H5531"\w* pesa \w más|strong="H2451"\w* que \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H3519"\w* \w la|strong="H2451"\w* \w honra|strong="H3519"\w*.   
\q1
\v 2 El \w corazón|strong="H3820"\w* del \w sabio|strong="H2450"\w* está \w a|strong="H3068"\w* su mano \w derecha|strong="H3225"\w*,  
\q2 mas el \w corazón|strong="H3820"\w* del \w necio|strong="H3684"\w* \w a|strong="H3068"\w* su mano \w izquierda|strong="H8040"\w*.  
\v 3 \w Y|strong="H3068"\w* \w aun|strong="H1571"\w* \w cuando|strong="H1571"\w* \w el|strong="H1931"\w* \w necio|strong="H5530"\w* \w va|strong="H3068"\w* \w por|strong="H1870"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w*, \w le|strong="H1931"\w* \w falta|strong="H2638"\w* \w la|strong="H1931"\w* cordura, \w y|strong="H1571"\w* \w va|strong="H3068"\w* diciendo \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w que|strong="H1931"\w* \w es|strong="H1931"\w* un \w necio|strong="H5530"\w*.  
\v 4 \w Si|strong="H3588"\w* \w el|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w del|strong="H5921"\w* príncipe \w se|strong="H5921"\w* exaltare \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w no|strong="H3588"\w* abandones tu \w puesto|strong="H3588"\w*; \w porque|strong="H3588"\w* \w la|strong="H5921"\w* mansedumbre hace cesar \w grandes|strong="H1419"\w* \w ofensas|strong="H2399"\w*.   
\p
\v 5 \w Hay|strong="H3426"\w* un \w mal|strong="H7451"\w* que he \w visto|strong="H7200"\w* \w debajo|strong="H8478"\w* del \w sol|strong="H8121"\w*, \w a|strong="H3068"\w* manera \w de|strong="H8478"\w* error \w emanado|strong="H3318"\w* del soberano:  
\v 6 la necedad \w está|strong="H3427"\w* colocada en altos puestos, mientras que \w los|strong="H3427"\w* ricos se sientan en lugares bajos.  
\v 7 He \w visto|strong="H7200"\w* \w criados|strong="H5650"\w* \w a|strong="H3068"\w* \w caballo|strong="H5483"\w*, \w y|strong="H5921"\w* \w príncipes|strong="H8269"\w* \w que|strong="H5921"\w* caminaban \w a|strong="H3068"\w* pie \w como|strong="H5921"\w* \w criados|strong="H5650"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
\v 8 \w El|strong="H5307"\w* que hiciere un hoyo \w caerá|strong="H5307"\w* en \w él|strong="H5307"\w*; y al que traspasare \w el|strong="H5307"\w* \w vallado|strong="H1447"\w*, le \w morderá|strong="H5391"\w* la \w serpiente|strong="H5175"\w*.  
\v 9 El que corta piedras, se herirá con ellas; el que corta \w leña|strong="H6086"\w*, en ello peligra.  
\v 10 \w Si|strong="H3808"\w* \w el|strong="H1931"\w* hacha \w se|strong="H1931"\w* embota y \w su|strong="H1931"\w* filo \w no|strong="H3808"\w* \w se|strong="H1931"\w* afila, hay \w que|strong="H1931"\w* añadir \w más|strong="H2451"\w* \w fuerza|strong="H1396"\w*; \w mas|strong="H2451"\w* \w la|strong="H1931"\w* \w sabiduría|strong="H2451"\w* \w tiene|strong="H1931"\w* \w la|strong="H1931"\w* ventaja \w de|strong="H6440"\w* dar \w el|strong="H1931"\w* éxito.   
\p
\v 11 \w Si|strong="H3808"\w* \w muerde|strong="H5391"\w* la \w serpiente|strong="H5175"\w* antes de ser encantada, de \w nada|strong="H3808"\w* sirve el arte del encantador.  
\v 12 Las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* la \w boca|strong="H6310"\w* del \w sabio|strong="H2450"\w* \w son|strong="H6310"\w* llenas \w de|strong="H1697"\w* \w gracia|strong="H2580"\w*, mas \w los|strong="H2450"\w* \w labios|strong="H8193"\w* del \w necio|strong="H3684"\w* causan su propia ruina.  
\v 13 El comienzo \w de|strong="H1697"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* su \w boca|strong="H6310"\w* \w es|strong="H1697"\w* necedad, y el final \w de|strong="H1697"\w* su charla, \w locura|strong="H5531"\w* maligna.  
\v 14 \w El|strong="H4310"\w* \w necio|strong="H5530"\w* \w multiplica|strong="H7235"\w* las \w palabras|strong="H1697"\w*.  
\p \w No|strong="H3808"\w* \w sabe|strong="H3045"\w* \w el|strong="H4310"\w* hombre \w lo|strong="H1697"\w* \w que|strong="H4100"\w* \w ha|strong="H3808"\w* \w de|strong="H1697"\w* ser; y \w lo|strong="H1697"\w* \w que|strong="H4100"\w* \w ha|strong="H3808"\w* \w de|strong="H1697"\w* venir \w después|strong="H1961"\w* \w de|strong="H1697"\w* \w él|strong="H4310"\w*, ¿\w quién|strong="H4310"\w* \w se|strong="H3045"\w* \w lo|strong="H1697"\w* \w podrá|strong="H3808"\w* decir?  
\v 15 El \w trabajo|strong="H5999"\w* de los necios los fatiga, de tal manera \w que|strong="H3808"\w* \w ni|strong="H3808"\w* \w aun|strong="H3808"\w* \w saben|strong="H3045"\w* cómo \w ir|strong="H3212"\w* \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w*.   
\q1
\v 16 ¡Ay \w de|strong="H8269"\w* ti, tierra, cuando tu \w rey|strong="H4428"\w* es un \w muchacho|strong="H5288"\w*,  
\q2 y tus \w príncipes|strong="H8269"\w* banquetean \w de|strong="H8269"\w* \w mañana|strong="H1242"\w*!   
\q1
\v 17 ¡Dichosa tú, tierra, \w cuando|strong="H6256"\w* tu \w rey|strong="H4428"\w* es \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* nobles,  
\q2 y tus \w príncipes|strong="H8269"\w* comen \w a|strong="H3068"\w* su \w tiempo|strong="H6256"\w*,  
\q2 para reponer sus fuerzas y \w no|strong="H3808"\w* para la embriaguez!   
\q1
\v 18 \w Por|strong="H3027"\w* la pereza se hunde el techado,  
\q2 y \w por|strong="H3027"\w* la desidia de las \w manos|strong="H3027"\w* tiene goteras la \w casa|strong="H1004"\w*.   
\q1
\v 19 Por placer se \w hace|strong="H6213"\w* \w el|strong="H3605"\w* banquete,  
\q2 y \w el|strong="H3605"\w* \w vino|strong="H3196"\w* \w alegra|strong="H8055"\w* \w la|strong="H3605"\w* \w vida|strong="H2416"\w*;  
\q2 \w mas|strong="H6030"\w* \w el|strong="H3605"\w* \w dinero|strong="H3701"\w* \w responde|strong="H6030"\w* por \w todo|strong="H3605"\w*.   
\q1
\v 20 \w Ni|strong="H1571"\w* \w aun|strong="H1571"\w* \w en|strong="H3588"\w* tu \w pensamiento|strong="H1697"\w* maldigas \w al|strong="H4428"\w* \w rey|strong="H4428"\w*,  
\q2 \w ni|strong="H1571"\w* \w en|strong="H3588"\w* \w lo|strong="H1697"\w* secreto \w de|strong="H3588"\w* tu \w cámara|strong="H2315"\w* maldigas \w al|strong="H4428"\w* \w rico|strong="H6223"\w*;  
\q2 \w porque|strong="H3588"\w* las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w* \w llevarán|strong="H3212"\w* \w la|strong="H1571"\w* \w voz|strong="H6963"\w*,  
\q2 \w y|strong="H1571"\w* las \w que|strong="H3588"\w* tienen \w alas|strong="H3671"\w* contarán \w el|strong="H3588"\w* \w asunto|strong="H1697"\w*.   
\c 11
\p
\v 1 \w Echa|strong="H7971"\w* tu \w pan|strong="H3899"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*;  
\q2 \w porque|strong="H3588"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w muchos|strong="H7230"\w* \w días|strong="H3117"\w* \w lo|strong="H5921"\w* \w hallarás|strong="H4672"\w*.   
\q1
\v 2 \w Reparte|strong="H5414"\w* una \w parte|strong="H2506"\w* \w a|strong="H3068"\w* \w siete|strong="H7651"\w*, \w y|strong="H1571"\w* \w aun|strong="H1571"\w* \w a|strong="H3068"\w* \w ocho|strong="H8083"\w*;  
\q2 \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w sabes|strong="H3045"\w* \w qué|strong="H3588"\w* \w mal|strong="H7451"\w* \w ha|strong="H3808"\w* \w de|strong="H5921"\w* venir \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra.   
\q1
\v 3 \w Si|strong="H5921"\w* \w las|strong="H5921"\w* \w nubes|strong="H5645"\w* fueren \w llenas|strong="H4390"\w* \w de|strong="H5921"\w* agua, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w se|strong="H5921"\w* derramarán;  
\q2 \w y|strong="H5921"\w* \w si|strong="H5921"\w* \w el|strong="H5921"\w* \w árbol|strong="H6086"\w* \w cayere|strong="H5307"\w* \w al|strong="H5921"\w* sur, \w o|strong="H3068"\w* \w al|strong="H5921"\w* \w norte|strong="H6828"\w*,  
\q2 \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \w el|strong="H5921"\w* \w árbol|strong="H6086"\w* \w cayere|strong="H5307"\w*, \w allí|strong="H8033"\w* \w quedará|strong="H1933"\w*.   
\q1
\v 4 El \w que|strong="H3808"\w* al \w viento|strong="H7307"\w* observa, \w no|strong="H3808"\w* \w sembrará|strong="H2232"\w*;  
\q2 y el \w que|strong="H3808"\w* \w mira|strong="H7200"\w* \w a|strong="H3068"\w* las \w nubes|strong="H5645"\w*, \w no|strong="H3808"\w* \w segará|strong="H7114"\w*.   
\q1
\v 5 \w Como|strong="H4100"\w* \w tú|strong="H6213"\w* \w no|strong="H3808"\w* \w sabes|strong="H3045"\w* \w cuál|strong="H4100"\w* es \w el|strong="H3605"\w* \w camino|strong="H1870"\w* del \w viento|strong="H7307"\w*,  
\q2 \w ni|strong="H3808"\w* \w cómo|strong="H4100"\w* \w se|strong="H3045"\w* forman \w los|strong="H3605"\w* miembros en \w el|strong="H3605"\w* vientre de \w la|strong="H3605"\w* \w que|strong="H4100"\w* está encinta,  
\q2 \w así|strong="H3602"\w* \w ignoras|strong="H3808"\w* \w la|strong="H3605"\w* \w obra|strong="H4639"\w* de Dios, \w el|strong="H3605"\w* \w cual|strong="H4100"\w* \w hace|strong="H6213"\w* \w todas|strong="H3605"\w* las \w cosas|strong="H3045"\w*.   
\q1
\v 6 \w Por|strong="H3588"\w* \w la|strong="H3588"\w* \w mañana|strong="H1242"\w* \w siembra|strong="H2233"\w* tu semilla,  
\q2 \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w tarde|strong="H6153"\w* \w no|strong="H3588"\w* dejes reposar tu \w mano|strong="H3027"\w*;  
\q2 \w porque|strong="H3588"\w* \w no|strong="H3588"\w* \w sabes|strong="H3045"\w* \w qué|strong="H3588"\w* \w es|strong="H2088"\w* \w lo|strong="H2088"\w* \w que|strong="H3588"\w* prosperará, \w si|strong="H3588"\w* \w esto|strong="H2088"\w* \w o|strong="H3068"\w* aquello,  
\q2 \w o|strong="H3068"\w* \w si|strong="H3588"\w* \w ambas|strong="H8147"\w* \w cosas|strong="H3045"\w* \w son|strong="H3588"\w* igualmente \w buenas|strong="H2896"\w*.   
\q1
\v 7 \w Dulce|strong="H4966"\w* es ciertamente la luz,  
\q2 y agradable \w a|strong="H3068"\w* los \w ojos|strong="H5869"\w* \w ver|strong="H7200"\w* el \w sol|strong="H8121"\w*;   
\q1
\v 8 \w mas|strong="H3588"\w* \w si|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w viviere|strong="H2421"\w* \w muchos|strong="H7235"\w* \w años|strong="H8141"\w*, \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w hubiere|strong="H1961"\w* gozado,  
\q2 \w que|strong="H3588"\w* traiga también \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w memoria|strong="H2142"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* las \w tinieblas|strong="H2822"\w*, \w que|strong="H3588"\w* \w serán|strong="H1961"\w* \w muchos|strong="H7235"\w*.  
\q2 \w Todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3588"\w* \w habrá|strong="H1961"\w* pasado \w es|strong="H1961"\w* \w vanidad|strong="H1892"\w*.   
\q1
\v 9 \w Alégrate|strong="H8055"\w*, joven, \w en|strong="H5921"\w* tu juventud,  
\q2 \w y|strong="H3588"\w* tome placer tu \w corazón|strong="H3820"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* tu adolescencia;  
\q2 \w y|strong="H3588"\w* \w anda|strong="H1980"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w caminos|strong="H1870"\w* \w de|strong="H5921"\w* tu \w corazón|strong="H3820"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w vista|strong="H4758"\w* \w de|strong="H5921"\w* tus \w ojos|strong="H5869"\w*;  
\q2 \w mas|strong="H3588"\w* \w sabed|strong="H3045"\w* \w que|strong="H3588"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* estas \w cosas|strong="H3045"\w* \w os|strong="H5921"\w* juzgará Dios.   
\q1
\v 10 \w Quita|strong="H5493"\w*, \w pues|strong="H3588"\w*, \w el|strong="H3588"\w* enojo \w de|strong="H3588"\w* tu \w corazón|strong="H3820"\w*,  
\q2 \w y|strong="H3588"\w* \w aparta|strong="H5493"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w* \w de|strong="H3588"\w* tu \w carne|strong="H1320"\w*;  
\q2 \w porque|strong="H3588"\w* \w la|strong="H3588"\w* adolescencia \w y|strong="H3588"\w* \w la|strong="H3588"\w* aurora \w de|strong="H3588"\w* \w la|strong="H3588"\w* vida \w son|strong="H3588"\w* \w vanidad|strong="H1892"\w*.   
\c 12
\p
\v 1 \w Acuérdate|strong="H2142"\w* \w de|strong="H5704"\w* tu Creador \w en|strong="H5704"\w* los \w días|strong="H3117"\w* \w de|strong="H5704"\w* tu juventud,  
\q2 \w antes|strong="H5704"\w* \w de|strong="H5704"\w* \w que|strong="H3808"\w* vengan los \w días|strong="H3117"\w* \w malos|strong="H7451"\w* \w y|strong="H5704"\w* lleguen los \w años|strong="H8141"\w*  
\q2 \w en|strong="H5704"\w* los cuales digas: «\w No|strong="H3808"\w* tengo \w en|strong="H5704"\w* ellos \w contentamiento|strong="H2656"\w*;»   
\q1
\v 2 \w antes|strong="H5704"\w* \w de|strong="H5704"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* oscurezcan el \w sol|strong="H8121"\w* \w y|strong="H5704"\w* la luz, la \w luna|strong="H3394"\w* \w y|strong="H5704"\w* las \w estrellas|strong="H3556"\w*,  
\q2 \w y|strong="H5704"\w* \w vuelvan|strong="H7725"\w* las \w nubes|strong="H5645"\w* tras la \w lluvia|strong="H1653"\w*;   
\q1
\v 3 \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w en|strong="H3588"\w* \w que|strong="H3588"\w* \w temblarán|strong="H2111"\w* \w los|strong="H3588"\w* \w guardas|strong="H8104"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w*,  
\q2 \w y|strong="H3588"\w* se encorvarán \w los|strong="H3588"\w* hombres \w fuertes|strong="H2428"\w*,  
\q2 \w y|strong="H3588"\w* cesarán las muelas \w porque|strong="H3588"\w* han disminuido,  
\q2 \w y|strong="H3588"\w* se oscurecerán \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w miran|strong="H7200"\w* \w por|strong="H3588"\w* las ventanas;   
\q1
\v 4 y las \w puertas|strong="H1817"\w* de afuera se cerrarán,  
