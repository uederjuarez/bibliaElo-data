\p
\v 1 \w Entonces|strong="H7725"\w* me \w volví|strong="H7725"\w* y \w vi|strong="H7200"\w* \w todas|strong="H3605"\w* las \w opresiones|strong="H6217"\w* \w que|strong="H3581"\w* se cometen \w debajo|strong="H8478"\w* del \w sol|strong="H8121"\w*; y he \w aquí|strong="H2009"\w* las \w lágrimas|strong="H1832"\w* \w de|strong="H8478"\w* \w los|strong="H3605"\w* \w oprimidos|strong="H6231"\w*, y \w no|strong="H6213"\w* \w había|strong="H6213"\w* \w quien|strong="H3605"\w* \w los|strong="H3605"\w* \w consolara|strong="H5162"\w*; \w el|strong="H3605"\w* \w poder|strong="H3581"\w* \w estaba|strong="H2009"\w* \w en|strong="H8478"\w* \w mano|strong="H3027"\w* \w de|strong="H8478"\w* sus opresores, y para \w ellos|strong="H3027"\w* \w no|strong="H6213"\w* \w había|strong="H6213"\w* \w consolador|strong="H5162"\w*.  
\v 2 \w Por|strong="H4480"\w* \w lo|strong="H1992"\w* cual alabé \w yo|strong="H4480"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* finados \w que|strong="H4480"\w* \w ya|strong="H3528"\w* \w murieron|strong="H4191"\w*, \w más|strong="H4480"\w* \w que|strong="H4480"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w vivos|strong="H2416"\w* \w que|strong="H4480"\w* todavía \w viven|strong="H2416"\w*.  
\v 3 \w Y|strong="H3068"\w* \w tuve|strong="H1961"\w* \w por|strong="H8478"\w* \w mejor|strong="H2896"\w* \w que|strong="H3808"\w* unos y otros \w al|strong="H8478"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w sido|strong="H1961"\w* \w aún|strong="H5728"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w visto|strong="H7200"\w* las \w malas|strong="H7451"\w* \w obras|strong="H4639"\w* \w que|strong="H3808"\w* \w se|strong="H1961"\w* \w hacen|strong="H6213"\w* \w debajo|strong="H8478"\w* del \w sol|strong="H8121"\w*.  
\v 4 He \w visto|strong="H7200"\w* \w asimismo|strong="H1571"\w* \w que|strong="H3588"\w* \w todo|strong="H3605"\w* \w trabajo|strong="H5999"\w* \w y|strong="H1571"\w* \w toda|strong="H3605"\w* \w excelencia|strong="H3788"\w* \w de|strong="H3588"\w* \w obras|strong="H4639"\w* despierta \w la|strong="H1931"\w* \w envidia|strong="H7068"\w* del hombre contra \w su|strong="H1931"\w* \w prójimo|strong="H7453"\w*. \w También|strong="H1571"\w* \w esto|strong="H2088"\w* \w es|strong="H1931"\w* \w vanidad|strong="H1892"\w* \w y|strong="H1571"\w* correr tras \w el|strong="H1931"\w* \w viento|strong="H7307"\w*.   
\p
\v 5 El \w necio|strong="H3684"\w* cruza sus \w manos|strong="H3027"\w* y consume su propia \w carne|strong="H1320"\w*.  
\v 6 Más \w vale|strong="H2896"\w* un puñado con descanso, que ambos puños \w llenos|strong="H4393"\w* con \w trabajo|strong="H5999"\w* y correr tras el \w viento|strong="H7307"\w*.   
\p
\v 7 Yo me \w volví|strong="H7725"\w* otra vez y \w vi|strong="H7200"\w* \w vanidad|strong="H1892"\w* \w debajo|strong="H8478"\w* del \w sol|strong="H8121"\w*.  
\v 8 \w Está|strong="H2088"\w* un \w hombre|strong="H1121"\w* \w solo|strong="H1931"\w* \w y|strong="H1571"\w* \w sin|strong="H3808"\w* \w sucesor|strong="H8145"\w*, \w que|strong="H4310"\w* \w no|strong="H3808"\w* \w tiene|strong="H3426"\w* \w hijo|strong="H1121"\w* \w ni|strong="H3808"\w* hermano; \w y|strong="H1571"\w* \w nunca|strong="H3808"\w* cesa \w de|strong="H1121"\w* trabajar, \w ni|strong="H3808"\w* \w sus|strong="H1931"\w* \w ojos|strong="H5869"\w* \w se|strong="H1931"\w* sacian \w de|strong="H1121"\w* \w sus|strong="H1931"\w* \w riquezas|strong="H6239"\w*, \w ni|strong="H3808"\w* \w se|strong="H1931"\w* pregunta: «¿Para \w quién|strong="H4310"\w* \w trabajo|strong="H5999"\w* \w yo|strong="H5315"\w* \w y|strong="H1571"\w* privo \w a|strong="H3068"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* del bienestar?». \w También|strong="H1571"\w* \w esto|strong="H2088"\w* \w es|strong="H1931"\w* \w vanidad|strong="H1892"\w* \w y|strong="H1571"\w* tarea penosa.   
\p
\v 9 \w Mejores|strong="H2896"\w* son \w dos|strong="H8147"\w* \w que|strong="H4480"\w* uno; porque \w tienen|strong="H1992"\w* \w mejor|strong="H2896"\w* \w paga|strong="H7939"\w* \w por|strong="H4480"\w* \w su|strong="H1992"\w* \w trabajo|strong="H5999"\w*.  
\v 10 \w Porque|strong="H3588"\w* \w si|strong="H3588"\w* \w cayeren|strong="H5307"\w*, \w el|strong="H3588"\w* uno \w levantará|strong="H6965"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w compañero|strong="H2270"\w*; \w pero|strong="H3588"\w* ¡ay del solo! \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w cayere|strong="H5307"\w*, \w no|strong="H3588"\w* habrá \w segundo|strong="H8145"\w* \w que|strong="H3588"\w* lo levante.  
\v 11 \w También|strong="H1571"\w* \w si|strong="H1571"\w* \w dos|strong="H8147"\w* \w durmieren|strong="H7901"\w* juntos, se calentarán mutuamente; \w mas|strong="H1571"\w* ¿\w cómo|strong="H1571"\w* se calentará uno solo?  
\v 12 \w Y|strong="H3068"\w* \w si|strong="H3808"\w* alguno prevaleciere \w contra|strong="H5048"\w* uno, \w dos|strong="H8147"\w* le resistirán; y cordón \w de|strong="H5048"\w* tres dobleces \w no|strong="H3808"\w* \w se|strong="H3808"\w* rompe \w pronto|strong="H4120"\w*.   
\p
\v 13 \w Mejor|strong="H2896"\w* es el joven \w pobre|strong="H4542"\w* y \w sabio|strong="H2450"\w*, \w que|strong="H3808"\w* el \w rey|strong="H4428"\w* \w viejo|strong="H2205"\w* y \w necio|strong="H3684"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* admite ya consejos.  
\v 14 \w Porque|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H1571"\w* cárcel \w salió|strong="H3318"\w* \w para|strong="H3588"\w* reinar, \w aunque|strong="H3588"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w reino|strong="H4427"\w* \w nació|strong="H3205"\w* \w pobre|strong="H7326"\w*.  
\v 15 \w Vi|strong="H7200"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w vivientes|strong="H2416"\w* \w debajo|strong="H8478"\w* \w del|strong="H5973"\w* \w sol|strong="H8121"\w* \w caminando|strong="H1980"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* joven \w sucesor|strong="H8145"\w*, \w que|strong="H3605"\w* se levantó \w en|strong="H5973"\w* \w lugar|strong="H8478"\w* \w del|strong="H5973"\w* \w otro|strong="H8145"\w*.  
\v 16 \w No|strong="H3808"\w* \w tenía|strong="H1961"\w* \w fin|strong="H7093"\w* \w la|strong="H1571"\w* muchedumbre del \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* le \w seguía|strong="H1961"\w*; \w sin|strong="H3808"\w* embargo, \w los|strong="H3605"\w* \w que|strong="H3588"\w* vendrán \w después|strong="H1961"\w* \w no|strong="H3808"\w* \w estarán|strong="H1961"\w* \w contentos|strong="H8055"\w* \w con|strong="H3588"\w* \w él|strong="H3588"\w*. \w Y|strong="H3068"\w* \w esto|strong="H2088"\w* \w es|strong="H1961"\w* \w también|strong="H1571"\w* \w vanidad|strong="H1892"\w* \w y|strong="H1571"\w* correr tras \w el|strong="H3588"\w* \w viento|strong="H7307"\w*.   
\c 5
\p
\v 1 Guarda tu pie \w cuando|strong="H3588"\w* \w fueres|strong="H1961"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* casa \w de|strong="H5921"\w* Dios; \w porque|strong="H3588"\w* acercarse \w para|strong="H5921"\w* oír \w es|strong="H1961"\w* mejor \w que|strong="H3588"\w* ofrecer \w el|strong="H5921"\w* sacrificio \w de|strong="H5921"\w* \w los|strong="H5921"\w* necios, \w los|strong="H5921"\w* cuales \w no|strong="H3588"\w* saben \w que|strong="H3588"\w* hacen mal.  
\v 2 \w No|strong="H3588"\w* \w te|strong="H3588"\w* dejes llevar \w de|strong="H3588"\w* tu boca, ni tu corazón se apresure \w a|strong="H3068"\w* proferir \w palabra|strong="H1697"\w* alguna delante \w de|strong="H3588"\w* Dios; \w porque|strong="H3588"\w* Dios está \w en|strong="H3588"\w* \w el|strong="H3588"\w* cielo, \w y|strong="H3588"\w* tú sobre \w la|strong="H3588"\w* tierra; \w por|strong="H3588"\w* tanto, sean pocas tus \w palabras|strong="H1697"\w*.  
\v 3 \w Porque|strong="H3588"\w* \w de|strong="H3588"\w* las muchas ocupaciones vienen \w los|strong="H3588"\w* sueños, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* multitud \w de|strong="H3588"\w* las palabras \w la|strong="H3588"\w* voz del \w necio|strong="H3684"\w*.  
\v 4 Cuando \w a|strong="H3068"\w* Dios hicieres \w promesa|strong="H5087"\w*, \w no|strong="H3808"\w* tardes en cumplirla; \w porque|strong="H3808"\w* él \w no|strong="H3808"\w* \w se|strong="H3808"\w* complace en los insensatos. \w Cumple|strong="H7999"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* prometes.  
\v 5 Mejor \w es|strong="H1931"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* prometas, \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w que|strong="H3588"\w* prometas \w y|strong="H3588"\w* \w no|strong="H3588"\w* cumplas.  
\v 6 \w No|strong="H3588"\w* dejes \w que|strong="H3588"\w* tu boca \w te|strong="H3588"\w* haga pecar, ni digas ante \w el|strong="H3588"\w* mensajero \w que|strong="H3588"\w* fue \w por|strong="H3588"\w* error. ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* hacer \w que|strong="H3588"\w* Dios se enoje \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H3588"\w* tu voz, \w y|strong="H3588"\w* \w que|strong="H3588"\w* destruya \w la|strong="H3588"\w* obra \w de|strong="H3588"\w* tus manos?  
\v 7 \w Donde|strong="H5921"\w* abundan \w los|strong="H5921"\w* sueños, abundan también \w las|strong="H5921"\w* vanidades \w y|strong="H3588"\w* \w las|strong="H5921"\w* muchas palabras; \w mas|strong="H3588"\w* tú, teme \w a|strong="H3068"\w* Dios.   
\p
\v 8 \w Si|strong="H1931"\w* viereis en \w la|strong="H1931"\w* provincia opresión de pobres y perversión de derecho y de justicia, no os maravilléis de \w ello|strong="H1931"\w*; \w porque|strong="H4428"\w* sobre \w el|strong="H1931"\w* alto vigila otro más alto, y uno más alto \w está|strong="H1931"\w* sobre \w ellos|strong="H1931"\w*.  
\v 9 \w Además|strong="H1571"\w*, \w el|strong="H4310"\w* provecho \w de|strong="H7646"\w* \w la|strong="H1571"\w* tierra \w es|strong="H2088"\w* para todos; \w el|strong="H4310"\w* rey \w mismo|strong="H1571"\w* \w está|strong="H2088"\w* sujeto \w a|strong="H3068"\w* los campos.   
\p
\v 10 \w El|strong="H3588"\w* \w que|strong="H3588"\w* ama \w el|strong="H3588"\w* dinero, \w no|strong="H3588"\w* \w se|strong="H4100"\w* saciará \w de|strong="H3588"\w* dinero; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* ama \w el|strong="H3588"\w* \w mucho|strong="H7235"\w* tener, \w no|strong="H3588"\w* sacará provecho. También esto \w es|strong="H3588"\w* vanidad.  
\v 11 Cuando aumentan los bienes, aumentan también los que los consumen. ¿Qué provecho tiene, pues, su dueño, sino verlo con sus propios ojos?   
\p
\v 12 Dulce \w es|strong="H3426"\w* el sueño del trabajador, coma poco \w o|strong="H3068"\w* coma mucho; pero \w al|strong="H8478"\w* rico no le deja dormir \w la|strong="H8104"\w* abundancia.   
\p
\v 13 Hay un \w mal|strong="H7451"\w* doloroso \w que|strong="H1931"\w* he visto debajo del sol: las \w riquezas|strong="H6239"\w* guardadas \w por|strong="H3027"\w* \w sus|strong="H1931"\w* dueños para \w su|strong="H1931"\w* propio \w mal|strong="H7451"\w*;  
\v 14 las cuales \w se|strong="H3808"\w* pierden \w en|strong="H3318"\w* malas tareas, y al hijo \w que|strong="H3808"\w* engendraron \w nada|strong="H3808"\w* le queda \w en|strong="H3318"\w* la \w mano|strong="H3027"\w*.  
\v 15 \w Como|strong="H4100"\w* \w salió|strong="H3212"\w* del vientre \w de|strong="H7451"\w* su madre, desnudo, \w así|strong="H3651"\w* vuelve, yéndose \w tal|strong="H3651"\w* \w como|strong="H4100"\w* \w vino|strong="H3212"\w*, sin llevarse \w nada|strong="H3605"\w* \w de|strong="H7451"\w* su \w trabajo|strong="H5998"\w* \w que|strong="H4100"\w* pueda cargar \w en|strong="H3212"\w* su mano.  
\v 16 Este \w también|strong="H1571"\w* \w es|strong="H7235"\w* un \w gran|strong="H7235"\w* mal: \w que|strong="H1571"\w* tal \w como|strong="H1571"\w* vino, \w así|strong="H1571"\w* haya de volver. ¿\w Y|strong="H3068"\w* de \w qué|strong="H1571"\w* le aprovecha trabajar para \w el|strong="H3605"\w* viento?  
\v 17 \w Además|strong="H3588"\w* \w de|strong="H3588"\w* \w esto|strong="H1931"\w*, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w vida|strong="H2416"\w* come \w en|strong="H3588"\w* tinieblas, \w con|strong="H3588"\w* mucha \w molestia|strong="H5999"\w*, enfermedad \w y|strong="H3588"\w* enojo.   
\p
\v 18 He aquí, \w pues|strong="H1931"\w*, \w lo|strong="H1931"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* he visto: \w que|strong="H4480"\w* \w lo|strong="H1931"\w* bueno \w y|strong="H1571"\w* \w lo|strong="H1931"\w* decoroso \w es|strong="H1931"\w* comer \w y|strong="H1571"\w* beber, \w y|strong="H1571"\w* gozar \w de|strong="H4480"\w* \w los|strong="H3605"\w* frutos \w de|strong="H4480"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w trabajo|strong="H5999"\w* \w con|strong="H4480"\w* \w que|strong="H4480"\w* uno \w se|strong="H1931"\w* afana \w debajo|strong="H5375"\w* \w del|strong="H4480"\w* sol, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* días \w de|strong="H4480"\w* \w la|strong="H1931"\w* vida \w que|strong="H4480"\w* Dios \w le|strong="H1931"\w* ha \w dado|strong="H5414"\w*; porque \w esta|strong="H1931"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w parte|strong="H2506"\w*.  
\v 19 Asimismo, \w a|strong="H3068"\w* todo hombre \w a|strong="H3068"\w* quien Dios da riquezas \w y|strong="H3588"\w* bienes, \w y|strong="H3588"\w* le da también facultad \w para|strong="H3588"\w* \w que|strong="H3588"\w* coma \w de|strong="H3588"\w* ellos, \w y|strong="H3588"\w* tome \w su|strong="H3588"\w* parte \w y|strong="H3588"\w* goce \w de|strong="H3588"\w* \w su|strong="H3588"\w* trabajo, esto \w es|strong="H3588"\w* don \w de|strong="H3588"\w* Dios.  
\v 20 Porque no se acordará mucho de los días de su vida; pues Dios le llenará de alegría el corazón.   
\c 6
\p
\v 1 \w Hay|strong="H3426"\w* un \w mal|strong="H7451"\w* \w que|strong="H1931"\w* he \w visto|strong="H7200"\w* \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* \w sol|strong="H8121"\w*, \w y|strong="H5921"\w* \w que|strong="H1931"\w* muy \w de|strong="H5921"\w* común \w se|strong="H1931"\w* halla \w entre|strong="H5921"\w* \w los|strong="H5921"\w* hombres:  
\v 2 \w el|strong="H1931"\w* \w del|strong="H4480"\w* hombre \w a|strong="H3068"\w* \w quien|strong="H3605"\w* Dios \w da|strong="H5414"\w* \w riquezas|strong="H6239"\w*, bienes \w y|strong="H3588"\w* \w honra|strong="H3519"\w*, \w y|strong="H3588"\w* \w nada|strong="H3808"\w* \w le|strong="H1931"\w* \w falta|strong="H2638"\w* \w de|strong="H4480"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* \w su|strong="H1931"\w* \w alma|strong="H5315"\w* desea; \w pero|strong="H3588"\w* Dios \w no|strong="H3808"\w* \w le|strong="H1931"\w* \w da|strong="H5414"\w* facultad \w de|strong="H4480"\w* gozar \w de|strong="H4480"\w* \w ello|strong="H1931"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w lo|strong="H1931"\w* disfrutan \w los|strong="H3605"\w* extraños. \w Esto|strong="H2088"\w* \w es|strong="H1931"\w* \w vanidad|strong="H1892"\w* \w y|strong="H3588"\w* \w enfermedad|strong="H2483"\w* penosa.   
\p
\v 3 \w Si|strong="H1571"\w* un hombre engendra \w cien|strong="H3967"\w* hijos, \w y|strong="H1571"\w* \w vive|strong="H2421"\w* \w muchos|strong="H7227"\w* \w años|strong="H8141"\w*, \w de|strong="H4480"\w* modo \w que|strong="H4480"\w* \w los|strong="H1961"\w* \w días|strong="H3117"\w* \w de|strong="H4480"\w* su \w vida|strong="H5315"\w* \w sean|strong="H1961"\w* \w numerosos|strong="H7227"\w*, pero su \w alma|strong="H5315"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* sacia \w de|strong="H4480"\w* \w bien|strong="H2896"\w*, \w y|strong="H1571"\w* \w además|strong="H1571"\w* carece \w de|strong="H4480"\w* \w sepultura|strong="H6900"\w*, \w yo|strong="H4480"\w* digo \w que|strong="H4480"\w* un abortivo \w es|strong="H1961"\w* \w mejor|strong="H2896"\w* \w que|strong="H4480"\w* \w él|strong="H1571"\w*.  
\v 4 \w Porque|strong="H3588"\w* este viene \w en|strong="H3588"\w* \w vano|strong="H1892"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* las \w tinieblas|strong="H2822"\w* \w va|strong="H3068"\w*, \w y|strong="H3588"\w* \w con|strong="H3588"\w* \w tinieblas|strong="H2822"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w* \w es|strong="H3588"\w* cubierto.  
\v 5 \w Además|strong="H1571"\w*, \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w visto|strong="H7200"\w* \w el|strong="H1571"\w* \w sol|strong="H8121"\w*, \w ni|strong="H3808"\w* \w lo|strong="H2088"\w* \w ha|strong="H3808"\w* \w conocido|strong="H3045"\w*; \w más|strong="H1571"\w* reposo tiene \w este|strong="H2088"\w* \w que|strong="H3808"\w* \w aquel|strong="H2088"\w*.  
\v 6 \w Porque|strong="H3808"\w* \w aunque|strong="H3808"\w* viviera mil \w años|strong="H8141"\w* \w dos|strong="H6471"\w* \w veces|strong="H6471"\w* contados, \w si|strong="H3808"\w* \w no|strong="H3808"\w* gozó del \w bien|strong="H2896"\w*, ¿acaso \w no|strong="H3808"\w* \w van|strong="H1980"\w* \w todos|strong="H3605"\w* al \w mismo|strong="H3605"\w* \w lugar|strong="H4725"\w*?  
\v 7 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w trabajo|strong="H5999"\w* del hombre es para su \w boca|strong="H6310"\w*, \w y|strong="H1571"\w* \w con|strong="H1571"\w* \w todo|strong="H3605"\w*, su deseo \w no|strong="H3808"\w* \w se|strong="H3808"\w* sacia.  
