\q2 \w pero|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H1931"\w* \w mañana|strong="H1242"\w* arde \w como|strong="H3588"\w* fuego llameante.   
\q1
\v 7 \w Todos|strong="H3605"\w* \w ellos|strong="H3605"\w* arden como un \w horno|strong="H8574"\w*,  
\q2 y devoran \w a|strong="H3068"\w* sus \w jueces|strong="H8199"\w*.  
\q1 \w Todos|strong="H3605"\w* sus \w reyes|strong="H4428"\w* han \w caído|strong="H5307"\w*;  
\q2 no hay entre \w ellos|strong="H3605"\w* \w quien|strong="H3605"\w* \w clame|strong="H7121"\w* \w a|strong="H3068"\w* mí.   
\q1
\v 8 Efraín \w se|strong="H1961"\w* ha mezclado con \w los|strong="H1961"\w* \w pueblos|strong="H5971"\w*;  
\q2 Efraín \w es|strong="H1931"\w* \w como|strong="H1961"\w* una \w torta|strong="H5692"\w* \w no|strong="H1097"\w* volteada.   
\q1
\v 9 \w Los|strong="H1931"\w* extraños han devorado \w su|strong="H1931"\w* \w fuerza|strong="H3581"\w*,  
\q2 \w y|strong="H1571"\w* \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w sabe|strong="H3045"\w*.  
\q1 De hecho, las canas \w le|strong="H1931"\w* han brotado aquí \w y|strong="H1571"\w* allá,  
\q2 \w y|strong="H1571"\w* \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* da cuenta.   
\q1
\v 10 \w La|strong="H2063"\w* \w soberbia|strong="H1347"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* testifica en su \w rostro|strong="H6440"\w*;  
\q2 pero \w por|strong="H6440"\w* \w todo|strong="H3605"\w* \w esto|strong="H2063"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* han \w vuelto|strong="H7725"\w* \w a|strong="H3068"\w* Yahvé su \w Dios|strong="H3068"\w*,  
\q2 \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* han buscado.   
\b  
\q1
\v 11 “Efraín \w es|strong="H1961"\w* \w como|strong="H1961"\w* \w paloma|strong="H3123"\w* \w incauta|strong="H6601"\w*, sin \w entendimiento|strong="H3820"\w*.  
\q2 \w Llaman|strong="H7121"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*,  
\q2 acuden \w a|strong="H3068"\w* Asiria.   
\q1
\v 12 Cuando \w vayan|strong="H3212"\w*, \w extenderé|strong="H6566"\w* \w mi|strong="H5921"\w* \w red|strong="H7568"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*;  
\q2 \w los|strong="H5921"\w* haré caer \w como|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*.  
\q2 \w Los|strong="H5921"\w* \w castigaré|strong="H3256"\w*, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* ha anunciado \w a|strong="H3068"\w* su congregación.   
\q1
\v 13 ¡Ay \w de|strong="H4480"\w* \w ellos|strong="H1992"\w*!  
\q2 \w Porque|strong="H3588"\w* \w se|strong="H5921"\w* han alejado \w de|strong="H4480"\w* \w mí|strong="H5921"\w*.  
\q1 ¡\w Destrucción|strong="H7701"\w* \w para|strong="H5921"\w* \w ellos|strong="H1992"\w*!  
\q2 \w Porque|strong="H3588"\w* \w se|strong="H5921"\w* han rebelado \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*.  
\q1 \w Aunque|strong="H3588"\w* \w yo|strong="H4480"\w* \w los|strong="H1992"\w* redimiría,  
\q2 \w ellos|strong="H1992"\w* han \w dicho|strong="H1696"\w* \w mentiras|strong="H3577"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\q1
\v 14 \w No|strong="H3808"\w* han clamado \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w con|strong="H5921"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w*,  
\q2 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* aúllan \w en|strong="H5921"\w* sus lechos.  
\q1 \w Por|strong="H5921"\w* \w el|strong="H5921"\w* \w trigo|strong="H1715"\w* \w y|strong="H3588"\w* \w el|strong="H5921"\w* \w mosto|strong="H8492"\w* \w se|strong="H5921"\w* congregan,  
\q2 \w pero|strong="H3588"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w se|strong="H5921"\w* apartan.   
\q1
\v 15 Aunque yo enseñé y fortalecí sus \w brazos|strong="H2220"\w*,  
\q2 ellos traman el \w mal|strong="H7451"\w* contra mí.   
\q1
\v 16 \w Se|strong="H1961"\w* \w vuelven|strong="H7725"\w*, pero \w no|strong="H3808"\w* al Altísimo;  
\q2 \w son|strong="H1961"\w* \w como|strong="H1961"\w* un \w arco|strong="H7198"\w* \w engañoso|strong="H7423"\w*.  
\q2 Sus \w príncipes|strong="H8269"\w* \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* por la furia \w de|strong="H8269"\w* su \w lengua|strong="H3956"\w*.  
\q2 Esto \w será|strong="H1961"\w* motivo \w de|strong="H8269"\w* burla en la tierra \w de|strong="H8269"\w* \w Egipto|strong="H4714"\w*.   
\b  
\c 8
\p
\v 1 “¡Pon \w la|strong="H5921"\w* \w trompeta|strong="H7782"\w* \w a|strong="H3068"\w* tu boca!  
\q2 \w Como|strong="H5921"\w* águila viene \w el|strong="H5921"\w* enemigo \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé,  
\q2 \w porque|strong="H5921"\w* han quebrantado \w mi|strong="H5921"\w* \w pacto|strong="H1285"\w*  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* han rebelado \w contra|strong="H5921"\w* \w mi|strong="H5921"\w* \w ley|strong="H8451"\w*.   
\q1
\v 2 Claman \w a|strong="H3068"\w* mí: ‘¡Dios mío, nosotros, \w Israel|strong="H3478"\w*, te conocemos!’   
\q2
\v 3 \w Israel|strong="H3478"\w* ha desechado el \w bien|strong="H2896"\w*;  
\q2 el enemigo lo \w perseguirá|strong="H7291"\w*.   
\q1
\v 4 Han establecido reyes, pero \w no|strong="H3808"\w* \w por|strong="H4480"\w* mí.  
\q2 Han constituido príncipes, \w mas|strong="H4480"\w* \w yo|strong="H4480"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* he sabido.  
\q2 \w De|strong="H4480"\w* \w su|strong="H1992"\w* \w plata|strong="H3701"\w* y \w su|strong="H1992"\w* \w oro|strong="H2091"\w* \w se|strong="H3045"\w* han \w hecho|strong="H6213"\w* \w ídolos|strong="H6091"\w*,  
\q2 \w para|strong="H4616"\w* \w su|strong="H1992"\w* propia perdición.   
\q1
\v 5 Tu \w becerro|strong="H5695"\w*, oh \w Samaria|strong="H8111"\w*, es abominable.  
\q2 ¡Mi ira \w se|strong="H3808"\w* \w ha|strong="H3808"\w* encendido contra ellos!  
\q2 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* serán incapaces \w de|strong="H5704"\w* purificarse?   
\q1
\v 6 \w Porque|strong="H3588"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* procede \w esto|strong="H1931"\w* también:  
\q2 un \w artífice|strong="H2796"\w* \w lo|strong="H1931"\w* \w hizo|strong="H6213"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w es|strong="H1931"\w* Dios;  
\q2 \w por|strong="H3588"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w el|strong="H1931"\w* \w becerro|strong="H5695"\w* \w de|strong="H3588"\w* \w Samaria|strong="H8111"\w* \w será|strong="H1961"\w* deshecho \w en|strong="H3588"\w* pedazos.   
\q1
\v 7 \w Porque|strong="H3588"\w* \w sembraron|strong="H2232"\w* \w viento|strong="H7307"\w*,  
\q2 \w y|strong="H3588"\w* \w torbellino|strong="H5492"\w* \w segarán|strong="H7114"\w*.  
\q1 \w No|strong="H1097"\w* tendrán mies;  
\q2 \w la|strong="H3588"\w* espiga \w no|strong="H1097"\w* dará \w harina|strong="H7058"\w*.  
\q2 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w la|strong="H3588"\w* diere, \w los|strong="H3588"\w* extranjeros \w la|strong="H3588"\w* devorarán.   
\q1
\v 8 Devorado ha \w sido|strong="H1961"\w* \w Israel|strong="H3478"\w*.  
\q2 \w Ahora|strong="H6258"\w* \w están|strong="H1961"\w* entre las \w naciones|strong="H1471"\w* \w como|strong="H1961"\w* \w vasija|strong="H3627"\w* \w que|strong="H6258"\w* \w no|strong="H1961"\w* \w se|strong="H1961"\w* estima.   
\q1
\v 9 \w Porque|strong="H3588"\w* \w ellos|strong="H1992"\w* \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* Asiria,  
\q2 \w como|strong="H3588"\w* asno \w montés|strong="H6501"\w* \w que|strong="H3588"\w* vaga solitario.  
\q2 Efraín ha alquilado amantes \w para|strong="H3588"\w* \w sí|strong="H3588"\w*.   
\q1
\v 10 \w Aunque|strong="H3588"\w* \w los|strong="H3588"\w* \w alquilen|strong="H8566"\w* \w entre|strong="H3588"\w* las \w naciones|strong="H1471"\w*,  
\q2 \w ahora|strong="H6258"\w* \w yo|strong="H3588"\w* \w los|strong="H3588"\w* reuniré;  
\q2 \w y|strong="H1571"\w* comenzarán \w a|strong="H3068"\w* menguar \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w la|strong="H1571"\w* opresión del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w príncipes|strong="H8269"\w*.   
\q1
\v 11 \w Porque|strong="H3588"\w* Efraín ha multiplicado \w los|strong="H1961"\w* \w altares|strong="H4196"\w* \w para|strong="H3588"\w* \w pecar|strong="H2398"\w*,  
\q2 \w se|strong="H1961"\w* le han convertido \w en|strong="H3588"\w* \w altares|strong="H4196"\w* \w para|strong="H3588"\w* \w pecar|strong="H2398"\w*.   
\q1
\v 12 Le escribí las grandezas de mi \w ley|strong="H8451"\w*,  
\q2 pero fueron tenidas \w por|strong="H3789"\w* cosa extraña.   
\q1
\v 13 En cuanto \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w sacrificios|strong="H2077"\w* de mis ofrendas,  
\q2 \w sacrifican|strong="H2077"\w* \w carne|strong="H1320"\w* y la comen,  
\q2 pero Yahvé \w no|strong="H3808"\w* \w los|strong="H1992"\w* acepta.  
\q1 \w Ahora|strong="H6258"\w* \w se|strong="H3808"\w* acordará de \w su|strong="H1992"\w* \w iniquidad|strong="H5771"\w*,  
\q2 y castigará \w sus|strong="H1992"\w* \w pecados|strong="H2403"\w*.  
\q2 \w Ellos|strong="H1992"\w* \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.   
\q1
\v 14 Porque \w Israel|strong="H3478"\w* se ha olvidado \w de|strong="H7911"\w* su \w Hacedor|strong="H6213"\w* y ha \w edificado|strong="H1129"\w* palacios;  
\q2 y \w Judá|strong="H3063"\w* ha multiplicado las \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w*;  
\q2 pero \w yo|strong="H6213"\w* \w enviaré|strong="H7971"\w* fuego sobre sus \w ciudades|strong="H5892"\w*,  
\q2 \w el|strong="H6213"\w* cual devorará sus fortalezas”.   
\b  
\c 9
\p
\v 1 \w No|strong="H3588"\w* \w te|strong="H5921"\w* alegres, oh \w Israel|strong="H3478"\w*, \w con|strong="H5921"\w* \w el|strong="H5921"\w* júbilo \w de|strong="H5921"\w* \w las|strong="H5921"\w* naciones;  
\q2 \w porque|strong="H3588"\w* fuiste infiel \w a|strong="H3068"\w* tu Dios.  
\q2 Amas \w el|strong="H5921"\w* salario \w de|strong="H5921"\w* \w ramera|strong="H2181"\w* \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* eras \w de|strong="H5921"\w* \w grano|strong="H1715"\w*.   
\q1
\v 2 La era y el \w lagar|strong="H3342"\w* \w no|strong="H3808"\w* los alimentarán,  
\q2 y el \w mosto|strong="H8492"\w* les faltará.   
\q1
\v 3 \w No|strong="H3808"\w* \w habitarán|strong="H3427"\w* \w más|strong="H3808"\w* en la tierra de Yahvé;  
\q2 \w sino|strong="H3808"\w* \w que|strong="H3808"\w* Efraín \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*,  
\q2 y comerán alimentos \w inmundos|strong="H2931"\w* en Asiria.   
\q1
\v 4 \w No|strong="H3808"\w* derramarán \w libaciones|strong="H5258"\w* \w de|strong="H3588"\w* \w vino|strong="H3196"\w* \w a|strong="H3068"\w* Yahvé,  
\q2 \w ni|strong="H3808"\w* le serán agradables sus \w sacrificios|strong="H2077"\w*.  
\q2 Serán \w para|strong="H3588"\w* \w ellos|strong="H3605"\w* \w como|strong="H3588"\w* \w pan|strong="H3899"\w* \w de|strong="H3588"\w* enlutados;  
\q2 \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* coman \w de|strong="H3588"\w* \w él|strong="H3588"\w* \w se|strong="H3808"\w* contaminarán.  
\q2 \w Porque|strong="H3588"\w* \w su|strong="H3588"\w* \w pan|strong="H3899"\w* \w será|strong="H2930"\w* sólo \w para|strong="H3588"\w* saciar \w su|strong="H3588"\w* apetito;  
\q2 \w no|strong="H3808"\w* entrará \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Yahvé.   
\q1
\v 5 ¿\w Qué|strong="H4100"\w* \w haréis|strong="H6213"\w* en \w el|strong="H6213"\w* \w día|strong="H3117"\w* de la asamblea solemne,  
\q2 y en \w el|strong="H6213"\w* \w día|strong="H3117"\w* de la \w fiesta|strong="H2282"\w* de Yahvé?   
\q1
\v 6 \w Porque|strong="H3588"\w* he \w aquí|strong="H2009"\w*, \w cuando|strong="H3588"\w* huyan \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w destrucción|strong="H7701"\w*,  
\q2 \w Egipto|strong="H4714"\w* \w los|strong="H3588"\w* recogerá,  
\q2 \w y|strong="H3588"\w* Menfis \w los|strong="H3588"\w* enterrará.  
\q2 Las ortigas \w heredarán|strong="H3423"\w* sus tesoros \w de|strong="H3588"\w* \w plata|strong="H3701"\w*,  
\q2 \w y|strong="H3588"\w* \w los|strong="H3588"\w* espinos crecerán \w en|strong="H3588"\w* sus tiendas.   
\q1
\v 7 Han llegado \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w del|strong="H5921"\w* castigo,  
\q2 han llegado \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* retribución.  
\q1 \w Israel|strong="H3478"\w* \w sabrá|strong="H3045"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* es tenido \w por|strong="H5921"\w* necio,  
\q2 \w y|strong="H5921"\w* \w el|strong="H5921"\w* hombre \w de|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w por|strong="H5921"\w* loco,  
\q2 \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w abundancia|strong="H7230"\w* \w de|strong="H5921"\w* tu \w iniquidad|strong="H5771"\w*,  
\q2 \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* grandeza \w de|strong="H5921"\w* tu hostilidad.   
\q1
\v 8 \w El|strong="H5921"\w* \w profeta|strong="H5030"\w* es \w centinela|strong="H6822"\w* \w de|strong="H5921"\w* Efraín \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* Dios;  
\q2 pero \w lazo|strong="H6341"\w* \w de|strong="H5921"\w* cazador hay \w en|strong="H5921"\w* \w todos|strong="H3605"\w* sus \w caminos|strong="H1870"\w*,  
\q2 \w y|strong="H5921"\w* hostilidad \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su Dios.   
\q1
\v 9 Se han \w corrompido|strong="H7843"\w* profundamente,  
\q2 \w como|strong="H5771"\w* en los \w días|strong="H3117"\w* de \w Gabaa|strong="H1390"\w*.  
\q2 Él se acordará de su \w iniquidad|strong="H5771"\w*,  
\q2 y castigará sus \w pecados|strong="H2403"\w*.   
\q1
\v 10 \w Como|strong="H1961"\w* \w a|strong="H3068"\w* \w uvas|strong="H6025"\w* en \w el|strong="H1992"\w* \w desierto|strong="H4057"\w* \w hallé|strong="H4672"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*;  
\q2 \w como|strong="H1961"\w* la fruta temprana de la higuera en \w su|strong="H1992"\w* \w principio|strong="H7225"\w* \w vi|strong="H7200"\w* \w a|strong="H3068"\w* vuestros padres.  
\q2 Pero \w ellos|strong="H1992"\w* acudieron \w a|strong="H3068"\w* Baal-peor, y \w se|strong="H1961"\w* consagraron \w a|strong="H3068"\w* la vergüenza,  
\q2 y \w se|strong="H1961"\w* volvieron \w abominables|strong="H8251"\w* \w como|strong="H1961"\w* aquello \w que|strong="H1961"\w* amaron.   
\q1
\v 11 En cuanto \w a|strong="H3068"\w* Efraín, su \w gloria|strong="H3519"\w* \w volará|strong="H5774"\w* como un \w ave|strong="H5775"\w*;  
\q2 no habrá nacimientos, ni embarazos, ni concepción.   
