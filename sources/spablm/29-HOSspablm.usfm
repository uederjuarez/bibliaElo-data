\q2 habéis segado \w la|strong="H3588"\w* \w iniquidad|strong="H5766"\w*.  
\q2 Habéis comido \w fruto|strong="H6529"\w* \w de|strong="H3588"\w* \w mentira|strong="H3585"\w*,  
\q2 \w porque|strong="H3588"\w* confiasteis \w en|strong="H3588"\w* \w vuestro|strong="H6529"\w* propio \w camino|strong="H1870"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w multitud|strong="H7230"\w* \w de|strong="H3588"\w* vuestros \w valientes|strong="H1368"\w*.   
\q1
\v 14 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w se|strong="H5921"\w* \w levantará|strong="H6965"\w* un tumulto \w de|strong="H5921"\w* \w guerra|strong="H4421"\w* \w entre|strong="H5921"\w* tu \w pueblo|strong="H5971"\w*,  
\q2 \w y|strong="H5921"\w* \w todas|strong="H3605"\w* tus fortalezas serán destruidas,  
\q2 \w como|strong="H5921"\w* \w Salmán|strong="H8020"\w* destruyó \w a|strong="H3068"\w* Bet-arbel \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w*,  
\q2 \w cuando|strong="H3117"\w* \w la|strong="H5921"\w* madre fue despedazada \w junto|strong="H5921"\w* \w con|strong="H5921"\w* sus \w hijos|strong="H1121"\w*.   
\q1
\v 15 \w Así|strong="H3602"\w* os \w hará|strong="H6213"\w* Betel \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* vuestra gran \w maldad|strong="H7451"\w*.  
\q2 \w Al|strong="H4428"\w* despuntar \w el|strong="H1008"\w* alba, \w el|strong="H1008"\w* \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w será|strong="H6213"\w* destruido \w por|strong="H6440"\w* completo».   
\b  
\c 11
\p
\v 1 “\w Cuando|strong="H3588"\w* \w Israel|strong="H3478"\w* \w era|strong="H1121"\w* \w niño|strong="H5288"\w*, \w yo|strong="H3588"\w* lo amé,  
\q2 \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w llamé|strong="H7121"\w* \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w*.   
\q1
\v 2 \w Cuanto|strong="H3651"\w* más los \w llamaban|strong="H7121"\w*, más \w se|strong="H3651"\w* alejaban \w de|strong="H6440"\w* ellos;  
\q2 ofrecían \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* los baales,  
\q2 y quemaban incienso \w a|strong="H3068"\w* las imágenes talladas.   
\q1
\v 3 \w Con|strong="H5921"\w* todo, \w yo|strong="H3588"\w* enseñé \w a|strong="H3068"\w* andar \w a|strong="H3068"\w* Efraín.  
\q2 \w Los|strong="H5921"\w* \w tomé|strong="H3947"\w* \w por|strong="H5921"\w* sus \w brazos|strong="H2220"\w*,  
\q2 \w pero|strong="H3588"\w* \w no|strong="H3808"\w* comprendieron \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w los|strong="H5921"\w* sanaba.   
\q1
\v 4 \w Los|strong="H5921"\w* atraje \w con|strong="H5921"\w* \w cuerdas|strong="H5688"\w* humanas, \w con|strong="H5921"\w* lazos \w de|strong="H5921"\w* amor;  
\q2 \w y|strong="H5921"\w* \w fui|strong="H1961"\w* \w para|strong="H5921"\w* \w ellos|strong="H5921"\w* \w como|strong="H1961"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* alzan \w el|strong="H5921"\w* \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* su cerviz,  
\q2 \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w incliné|strong="H5186"\w* \w hacia|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* di \w de|strong="H5921"\w* comer.   
\b  
\q1
\v 5 “\w No|strong="H3808"\w* \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*;  
\q2 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H1931"\w* asirio \w será|strong="H1931"\w* \w su|strong="H1931"\w* \w rey|strong="H4428"\w*,  
\q2 \w porque|strong="H3588"\w* \w se|strong="H1931"\w* negaron \w a|strong="H3068"\w* arrepentirse.   
\q1
\v 6 La \w espada|strong="H2719"\w* caerá sobre sus \w ciudades|strong="H5892"\w*,  
\q2 destruirá los cerrojos de sus puertas,  
\q2 y pondrá fin \w a|strong="H3068"\w* sus planes.   
\q1
\v 7 Mi \w pueblo|strong="H5971"\w* está decidido \w a|strong="H3068"\w* rebelarse contra mí.  
\q2 \w Aunque|strong="H3808"\w* \w claman|strong="H7121"\w* al Altísimo,  
\q2 él \w de|strong="H5971"\w* \w ninguna|strong="H3808"\w* manera los enaltecerá.   
\b  
\q1
\v 8 «¿\w Cómo|strong="H5921"\w* podré abandonarte, oh Efraín?  
\q2 ¿\w Cómo|strong="H5921"\w* podré entregarte, \w Israel|strong="H3478"\w*?  
\q2 ¿\w Cómo|strong="H5921"\w* podré yo hacerte \w como|strong="H5921"\w* \w a|strong="H3068"\w* Admá?  
\q2 ¿\w Cómo|strong="H5921"\w* podré tratarte \w como|strong="H5921"\w* \w a|strong="H3068"\w* Zeboím?  
\q1 \w Mi|strong="H5921"\w* \w corazón|strong="H3820"\w* \w se|strong="H5921"\w* conmueve \w dentro|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* enciende \w toda|strong="H5921"\w* \w mi|strong="H5921"\w* compasión.   
\q1
\v 9 \w No|strong="H3808"\w* \w ejecutaré|strong="H6213"\w* \w el|strong="H3588"\w* ardor \w de|strong="H3588"\w* mi \w ira|strong="H2740"\w*.  
\q2 \w No|strong="H3808"\w* \w volveré|strong="H7725"\w* \w para|strong="H3588"\w* \w destruir|strong="H7843"\w* \w a|strong="H3068"\w* Efraín,  
\q2 \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* soy Dios, \w y|strong="H3588"\w* \w no|strong="H3808"\w* hombre, \w el|strong="H3588"\w* \w Santo|strong="H6918"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* vosotros.  
\q2 \w No|strong="H3808"\w* vendré \w con|strong="H3588"\w* \w ira|strong="H2740"\w*.   
\q1
\v 10 \w Caminarán|strong="H3212"\w* \w en|strong="H3588"\w* pos \w de|strong="H3588"\w* Yahvé,  
\q2 \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w rugirá|strong="H7580"\w* \w como|strong="H3588"\w* un león;  
\q2 \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w rugirá|strong="H7580"\w*, \w y|strong="H3588"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* vendrán temblando desde \w el|strong="H1931"\w* occidente.   
\q1
\v 11 Acudirán temblando \w como|strong="H5921"\w* un \w ave|strong="H6833"\w* \w desde|strong="H5921"\w* \w Egipto|strong="H4714"\w*,  
\q2 \w y|strong="H5921"\w* \w como|strong="H5921"\w* una \w paloma|strong="H3123"\w* \w desde|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Asiria;  
\q1 \w y|strong="H5921"\w* \w los|strong="H3427"\w* haré \w habitar|strong="H3427"\w* \w en|strong="H5921"\w* sus \w casas|strong="H1004"\w*», \w dice|strong="H5002"\w* Yahvé.   
\b  
\q1
\v 12 Efraín me ha rodeado de mentira,  
\q2 y la casa de Israel de engaño.  
\q2 Judá aún se aleja de Dios,  
\q2 y es infiel al Santo.   
\c 12
\p
\v 1 Efraín se apacienta \w de|strong="H5973"\w* viento,  
\q2 y persigue al viento solano.  
\q2 Multiplica continuamente la \w mentira|strong="H3585"\w* y la destrucción.  
\q2 Hacen pacto \w con|strong="H5973"\w* Asiria,  
\q2 y llevan aceite \w a|strong="H3068"\w* Egipto.   
\q1
\v 2 Yahvé también tiene pleito \w con|strong="H5973"\w* Judá,  
\q2 y castigará \w a|strong="H3068"\w* Jacob según sus caminos;  
\q2 \w le|strong="H5973"\w* pagará conforme \w a|strong="H3068"\w* sus obras.   
\q1
\v 3 \w En|strong="H5921"\w* \w el|strong="H5921"\w* vientre tomó \w a|strong="H3068"\w* su hermano \w por|strong="H5921"\w* \w el|strong="H5921"\w* talón,  
\q2 \w y|strong="H5921"\w* \w en|strong="H5921"\w* su madurez luchó \w con|strong="H5973"\w* \w Dios|strong="H3068"\w*.   
\q1
\v 4 Luchó con el ángel y prevaleció;  
\q2 lloró, y le rogó.  
\q2 En Betel le halló, y allí habló con nosotros...   
\q2
\v 5 sí, Yahvé, Dios \w de|strong="H5973"\w* \w los|strong="H5973"\w* ejércitos.  
\q2 Yahvé es su \w nombre|strong="H8033"\w* \w de|strong="H5973"\w* recuerdo.   
\q1
\v 6 Tú, pues, vuélvete \w a|strong="H3068"\w* tu \w Dios|strong="H3068"\w*.  
\q2 Guarda la misericordia y la justicia,  
\q2 y espera siempre en tu \w Dios|strong="H3068"\w*.   
\b  
\q1
\v 7 Es un mercader que tiene en su mano una balanza engañosa.  
\q2 Le encanta defraudar.   
\q1
\v 8 Efraín dijo: «Ciertamente me he enriquecido.  
\q2 He hallado riquezas para mí.  
\q2 En todos mis trabajos no hallarán en mí iniquidad \w que|strong="H3027"\w* sea pecado».   
\b  
\q1
\v 9 «Pero yo soy Yahvé, tu Dios, desde \w la|strong="H3605"\w* tierra de Egipto.  
\q2 \w Aún|strong="H3808"\w* os haré morar en tiendas,  
\q2 \w como|strong="H5771"\w* en \w los|strong="H3605"\w* días de \w la|strong="H3605"\w* fiesta solemne.   
\q1
\v 10 \w También|strong="H5750"\w* he hablado \w a|strong="H3068"\w* \w los|strong="H3427"\w* profetas,  
\q2 y he multiplicado las visiones;  
\q2 y \w por|strong="H5750"\w* medio \w de|strong="H5750"\w* \w los|strong="H3427"\w* profetas he usado parábolas.   
\q1
\v 11 \w Si|strong="H5921"\w* Galaad \w es|strong="H3027"\w* iniquidad,  
\q2 ciertamente son vanidad.  
\q1 \w En|strong="H5921"\w* Gilgal sacrifican toros.  
\q2 Sus altares son \w como|strong="H5921"\w* montones \w de|strong="H5921"\w* piedras \w en|strong="H5921"\w* \w los|strong="H5921"\w* surcos \w del|strong="H5921"\w* campo.   
\q1
\v 12 Jacob huyó \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Aram.  
\q2 Israel sirvió \w para|strong="H5921"\w* conseguir una esposa.  
\q2 \w Por|strong="H5921"\w* una mujer, cuidó rebaños.   
\q1
\v 13 \w Y|strong="H3068"\w* por un profeta, Yahvé hizo subir \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* de Egipto,  
\q2 y por un profeta fue \w guardado|strong="H8104"\w*.   
\q1
\v 14 Efraín ha provocado \w a|strong="H3068"\w* \w Dios|strong="H3068"\w* \w a|strong="H3068"\w* amarga \w ira|strong="H5927"\w*.  
\q2 Por tanto, su sangre recaerá sobre \w él|strong="H5030"\w*,  
\q2 y su \w Señor|strong="H3068"\w* le pagará su oprobio».   
\c 13
\p
\v 1 Cuando Efraín \w hablaba|strong="H1696"\w*, causaba temblor.  
\q2 \w Fue|strong="H1931"\w* exaltado en \w Israel|strong="H3478"\w*,  
\q2 pero cuando \w se|strong="H1931"\w* hizo culpable \w a|strong="H3068"\w* causa de \w Baal|strong="H1168"\w*, \w murió|strong="H4191"\w*.   
\q1
\v 2 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* pecan \w más|strong="H3254"\w* y \w más|strong="H3254"\w*,  
\q2 y \w se|strong="H1992"\w* han \w hecho|strong="H6213"\w* \w imágenes|strong="H4541"\w* de \w fundición|strong="H4541"\w* con \w su|strong="H1992"\w* \w plata|strong="H3701"\w*,  
\q2 \w ídolos|strong="H6091"\w* según \w su|strong="H1992"\w* propio \w entendimiento|strong="H8394"\w*,  
\q2 \w todos|strong="H3605"\w* \w ellos|strong="H1992"\w* \w obra|strong="H4639"\w* de \w artífices|strong="H2796"\w*.  
\q2 De \w ellos|strong="H1992"\w* dicen: «\w Los|strong="H1992"\w* hombres \w que|strong="H6258"\w* \w sacrifican|strong="H2076"\w*, besen \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w becerros|strong="H5695"\w*».   
\q1
\v 3 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w serán|strong="H1961"\w* \w como|strong="H1961"\w* la niebla de la \w mañana|strong="H1242"\w*,  
\q2 \w como|strong="H1961"\w* el \w rocío|strong="H2919"\w* \w que|strong="H1961"\w* de madrugada \w se|strong="H1961"\w* desvanece,  
\q2 \w como|strong="H1961"\w* el tamo \w que|strong="H1961"\w* \w es|strong="H1961"\w* arrojado de la \w era|strong="H1961"\w* \w por|strong="H3651"\w* el torbellino,  
\q2 y \w como|strong="H1961"\w* el \w humo|strong="H6227"\w* \w que|strong="H1961"\w* sale \w por|strong="H3651"\w* la chimenea.   
\b  
\q1
\v 4 “\w Mas|strong="H3808"\w* yo soy Yahvé tu \w Dios|strong="H3068"\w* desde la tierra \w de|strong="H2108"\w* \w Egipto|strong="H4714"\w*;  
\q2 \w no|strong="H3808"\w* \w conocerás|strong="H3045"\w* \w a|strong="H3068"\w* otro \w dios|strong="H3068"\w* \w fuera|strong="H2108"\w* \w de|strong="H2108"\w* \w mí|strong="H1115"\w*,  
\q2 y aparte \w de|strong="H2108"\w* \w mí|strong="H1115"\w* \w no|strong="H3808"\w* hay otro \w salvador|strong="H3467"\w*.   
\q1
\v 5 Yo te \w conocí|strong="H3045"\w* en el \w desierto|strong="H4057"\w*,  
\q2 en tierra de terrible sequedad.   
\q1
\v 6 \w En|strong="H5921"\w* sus pastos \w se|strong="H5921"\w* saciaron;  
\q2 \w se|strong="H5921"\w* saciaron, \w y|strong="H5921"\w* \w se|strong="H5921"\w* ensoberbeció su \w corazón|strong="H3820"\w*.  
\q2 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w se|strong="H5921"\w* han olvidado \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\q1
\v 7 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w seré|strong="H1961"\w* \w para|strong="H5921"\w* \w ellos|strong="H5921"\w* \w como|strong="H3644"\w* \w león|strong="H7826"\w*;  
\q2 \w como|strong="H3644"\w* leopardo acecharé \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*.   
\q1
\v 8 Saldré \w a|strong="H3068"\w* su encuentro como osa que ha perdido sus cachorros,  
\q2 y desgarraré las fibras de su \w corazón|strong="H3820"\w*.  
\q2 \w Allí|strong="H8033"\w* los devoraré como leona;  
\q2 la \w bestia|strong="H2416"\w* del \w campo|strong="H7704"\w* los despedazará.   
\q1
\v 9 \w Te|strong="H3588"\w* has destruido, oh \w Israel|strong="H3478"\w*, \w porque|strong="H3588"\w* estás \w contra|strong="H3478"\w* mí,  
\q2 \w contra|strong="H3478"\w* tu ayudador.   
\q1
\v 10 ¿Dónde está ahora \w tu|strong="H8199"\w* \w rey|strong="H4428"\w* \w para|strong="H5414"\w* \w que|strong="H3605"\w* te \w salve|strong="H3467"\w* en \w todas|strong="H3605"\w* tus \w ciudades|strong="H5892"\w*?  
\q2 ¿\w Y|strong="H3068"\w* tus \w jueces|strong="H8199"\w*, \w de|strong="H8269"\w* \w los|strong="H3605"\w* cuales dijiste: ‘\w Dame|strong="H5414"\w* un \w rey|strong="H4428"\w* y \w príncipes|strong="H8269"\w*’?   
\q1
\v 11 Te \w di|strong="H5414"\w* \w rey|strong="H4428"\w* en mi furor,  
\q2 y te lo quité en mi ira.   
\q1
\v 12 \w Atada|strong="H6887"\w* está la \w iniquidad|strong="H5771"\w* de Efraín;  
\q2 guardado está su \w pecado|strong="H2403"\w*.   
\q1
\v 13 \w Dolores|strong="H2256"\w* \w de|strong="H3588"\w* mujer \w de|strong="H3588"\w* parto \w le|strong="H1931"\w* sobrevendrán.  
\q2 \w Es|strong="H1931"\w* un \w hijo|strong="H1121"\w* insensato,  
\q2 \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* presenta \w a|strong="H3068"\w* \w tiempo|strong="H6256"\w* \w en|strong="H3588"\w* \w la|strong="H1931"\w* abertura \w de|strong="H3588"\w* \w la|strong="H1931"\w* matriz.   
\q1
\v 14 ¿\w De|strong="H5869"\w* la \w mano|strong="H3027"\w* del Seol los \w redimiré|strong="H1350"\w*?  
\q2 ¡Los libraré \w de|strong="H5869"\w* la \w muerte|strong="H4194"\w*!  
\q2 ¡Oh \w muerte|strong="H4194"\w*, ¿dónde están tus plagas?!  
\q2 ¡Oh Seol, ¿dónde está tu destrucción?!  
\b  
\q1 «La compasión se ocultará \w de|strong="H5869"\w* mis \w ojos|strong="H5869"\w*.   
\q2
\v 15 \w Aunque|strong="H3588"\w* \w él|strong="H1931"\w* fructifique \w entre|strong="H3588"\w* \w sus|strong="H1931"\w* hermanos, \w vendrá|strong="H5927"\w* \w el|strong="H1931"\w* \w viento|strong="H7307"\w* \w solano|strong="H6921"\w*,  
\q2 \w viento|strong="H7307"\w* \w de|strong="H3588"\w* Yahvé \w subiendo|strong="H5927"\w* del \w desierto|strong="H4057"\w*;  
\q2 \w y|strong="H3588"\w* \w se|strong="H1931"\w* secará \w su|strong="H1931"\w* \w manantial|strong="H4726"\w*,  
\q2 \w y|strong="H3588"\w* \w se|strong="H1931"\w* agotará \w su|strong="H1931"\w* \w fuente|strong="H4599"\w*.  
\q2 \w Él|strong="H1931"\w* \w saqueará|strong="H8154"\w* \w el|strong="H1931"\w* tesoro \w de|strong="H3588"\w* \w todas|strong="H3605"\w* \w sus|strong="H1931"\w* \w preciosas|strong="H2532"\w* \w alhajas|strong="H3627"\w*.   
\q1
\v 16 Samaria será declarada culpable,  
\q2 porque se rebeló contra su Dios.  
\q2 Caerán \w a|strong="H3068"\w* espada;  
\q2 sus niños serán estrellados,  
\q2 y sus mujeres encinta serán abiertas».   
\b  
\c 14
\q1
\v 1 Vuelve, oh Israel, \w a|strong="H3068"\w* Yahvé tu Dios;  
\q2 \w porque|strong="H3588"\w* \w por|strong="H3588"\w* tu pecado has \w caído|strong="H5307"\w*.   
\q1
\v 2 Tomad \w con|strong="H3588"\w* vosotros palabras, \w y|strong="H3588"\w* \w volveos|strong="H7725"\w* \w a|strong="H3068"\w* Yahvé.  
\q2 Decidle: “Perdona toda \w iniquidad|strong="H5771"\w*,  
\q2 \w y|strong="H3588"\w* acepta \w el|strong="H3588"\w* \w bien|strong="H3588"\w*;  
\q2 \w y|strong="H3588"\w* \w te|strong="H3588"\w* ofreceremos \w los|strong="H3588"\w* sacrificios \w de|strong="H3588"\w* nuestros labios.   
\q1
\v 3 Asiria no nos salvará.  
\q2 No montaremos \w en|strong="H5973"\w* caballos;  
\q2 \w ni|strong="H5973"\w* nunca más diremos \w a|strong="H3068"\w* \w la|strong="H3605"\w* obra \w de|strong="H5973"\w* nuestras manos: ‘¡Dioses nuestros!’;  
\q2 porque \w en|strong="H5973"\w* \w ti|strong="H5973"\w* \w el|strong="H5973"\w* huérfano alcanza misericordia”.   
\b  
\q1
\v 4 “Yo sanaré su rebelión,  
\q2 \w los|strong="H5921"\w* amaré \w de|strong="H5921"\w* pura gracia;  
\q2 \w porque|strong="H5921"\w* \w mi|strong="H5921"\w* ira \w se|strong="H5921"\w* \w ha|strong="H3808"\w* apartado \w de|strong="H5921"\w* \w ellos|strong="H3027"\w*.   
\q1
\v 5 \w Yo|strong="H4480"\w* seré \w a|strong="H3068"\w* Israel \w como|strong="H3588"\w* \w el|strong="H3588"\w* rocío;  
\q2 \w él|strong="H3588"\w* florecerá \w como|strong="H3588"\w* \w el|strong="H3588"\w* lirio,  
\q2 \w y|strong="H3588"\w* echará sus raíces \w como|strong="H3588"\w* \w el|strong="H3588"\w* Líbano.   
\q1
\v 6 \w Se|strong="H1961"\w* extenderán sus ramas,  
\q2 y su esplendor \w será|strong="H1961"\w* \w como|strong="H1961"\w* el del olivo,  
\q2 y su fragancia \w como|strong="H1961"\w* la del \w Líbano|strong="H3844"\w*.   
\q1
\v 7 Volverán \w los|strong="H1961"\w* \w que|strong="H1961"\w* moran bajo su sombra;  
\q2 \w serán|strong="H1961"\w* vivificados \w como|strong="H1961"\w* el trigo,  
\q2 y florecerán \w como|strong="H1961"\w* la vid.  
\q2 Su fragancia \w será|strong="H1961"\w* \w como|strong="H1961"\w* el \w vino|strong="H1961"\w* del \w Líbano|strong="H3844"\w*.   
\q1
\v 8 Efraín dirá: ‘¿Qué tengo yo que ver ya con \w los|strong="H3427"\w* ídolos?’  
\q2 Yo le responderé y cuidaré de \w él|strong="H3427"\w*.  
\q2 Yo soy como un ciprés verde;  
\q2 de mí procede tu fruto”.   
\b  
\q1
\v 9 ¿\w Quién|strong="H4100"\w* es sabio \w para|strong="H4480"\w* \w que|strong="H4100"\w* entienda estas cosas?  
\q2 ¿\w Quién|strong="H4100"\w* es prudente \w para|strong="H4480"\w* \w que|strong="H4100"\w* las conozca?  
\q2 \w Porque|strong="H4100"\w* los caminos \w de|strong="H4480"\w* Yahvé son rectos,  
\q2 y los justos andarán \w por|strong="H4480"\w* \w ellos|strong="H4480"\w*,  
\q2 \w mas|strong="H5750"\w* los rebeldes tropezarán \w en|strong="H4480"\w* \w ellos|strong="H4480"\w*.   