\id HOS
\ide  UTF-8
\h OSEAS 
\toc3 Oseas 
\toc1 OSEAS 
\toc2 OSEAS 
\mt1 Oseas  
\c 1
\p
\v 1 \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Oseas|strong="H1954"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Beeri, en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* Uzías, Jotam, Acaz y Ezequías, \w reyes|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, y en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.   
\p
\v 2 \w El|strong="H3588"\w* principio \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w palabra|strong="H1696"\w* \w de|strong="H3588"\w* Yahvé \w por|strong="H3588"\w* medio \w de|strong="H3588"\w* \w Oseas|strong="H1954"\w*. \w Dijo|strong="H1696"\w* Yahvé \w a|strong="H3068"\w* \w Oseas|strong="H1954"\w*: «\w Ve|strong="H3212"\w*, \w tómate|strong="H3947"\w* una mujer \w fornicaria|strong="H2183"\w* \w e|strong="H3068"\w* \w hijos|strong="H3206"\w* \w de|strong="H3588"\w* fornicación; \w porque|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w fornica|strong="H2181"\w* gravemente, apartándose \w de|strong="H3588"\w* Yahvé».   
\p
\v 3 \w Fue|strong="H3212"\w*, pues, y \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Gomer|strong="H1586"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Diblaim, la cual \w concibió|strong="H2029"\w* y le dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*.   
\p
\v 4 \w Y|strong="H3068"\w* \w le|strong="H5921"\w* dijo Yahvé: «\w Ponle|strong="H7121"\w* \w por|strong="H5921"\w* \w nombre|strong="H8034"\w* \w Jezreel|strong="H3157"\w*; \w porque|strong="H3588"\w* \w dentro|strong="H5750"\w* \w de|strong="H5921"\w* \w poco|strong="H4592"\w* \w yo|strong="H3588"\w* castigaré \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w de|strong="H5921"\w* \w Jezreel|strong="H3157"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Jehú|strong="H3058"\w*, \w y|strong="H3588"\w* haré cesar \w el|strong="H5921"\w* reino \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 5 \w Y|strong="H3068"\w* acaecerá en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w que|strong="H1931"\w* yo \w quebraré|strong="H7665"\w* \w el|strong="H1931"\w* \w arco|strong="H7198"\w* de \w Israel|strong="H3478"\w* en \w el|strong="H1931"\w* \w valle|strong="H6010"\w* de \w Jezreel|strong="H3157"\w*».   
\p
\v 6 \w Concibió|strong="H2029"\w* ella \w de|strong="H3588"\w* nuevo \w y|strong="H3588"\w* dio \w a|strong="H3068"\w* luz una \w hija|strong="H1323"\w*.  
\p \w Y|strong="H3068"\w* \w le|strong="H3254"\w* dijo Dios: «\w Ponle|strong="H7121"\w* \w por|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Lo-Ruhamá|strong="H3808"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* compadeceré \w más|strong="H5750"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w para|strong="H3588"\w* perdonarlos \w de|strong="H3588"\w* manera alguna.  
\v 7 \w Mas|strong="H3808"\w* de la \w casa|strong="H1004"\w* de \w Judá|strong="H3063"\w* tendré \w misericordia|strong="H7355"\w*, y los \w salvaré|strong="H3467"\w* por Yahvé su \w Dios|strong="H3068"\w*; y \w no|strong="H3808"\w* los \w salvaré|strong="H3467"\w* con \w arco|strong="H7198"\w*, \w ni|strong="H3808"\w* con \w espada|strong="H2719"\w*, \w ni|strong="H3808"\w* con \w batalla|strong="H4421"\w*, \w ni|strong="H3808"\w* con \w caballos|strong="H5483"\w* \w ni|strong="H3808"\w* \w jinetes|strong="H6571"\w*».   
\p
\v 8 \w Y|strong="H3068"\w* después \w de|strong="H1121"\w* destetar \w a|strong="H3068"\w* Lo-Ruhamá, \w concibió|strong="H2029"\w* y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*.   
\p
\v 9 \w Y|strong="H3068"\w* dijo Dios: “\w Ponle|strong="H7121"\w* \w por|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Lo-Ammí|strong="H3808"\w*, \w porque|strong="H3588"\w* vosotros \w no|strong="H3808"\w* \w sois|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*, \w ni|strong="H3808"\w* \w yo|strong="H3588"\w* \w seré|strong="H1961"\w* vuestro Dios.  
\v 10 Con todo, será el número de los hijos de Israel como la arena del mar, que no se puede medir ni contar. \w Y|strong="H3068"\w* sucederá que, en el lugar donde se les dijo: ‘Vosotros no sois mi pueblo’, se les dirá: ‘Hijos del Dios viviente’.  
\v 11 \w Y|strong="H3068"\w* se congregarán los hijos de Judá y los hijos de Israel, y nombrarán un solo jefe, y subirán de la tierra; porque el día de Jezreel será grande”.   
\c 2
\p
\v 1 “Decid \w a|strong="H3068"\w* vuestros hermanos: «¡\w Pueblo|strong="H5971"\w* \w mío|strong="H5971"\w*!»  
\q2 y \w a|strong="H3068"\w* vuestras hermanas: «¡Amada mía!»   
\q1
\v 2 ¡Pleitead \w con|strong="H4480"\w* vuestra madre!  
\q2 Pleitead, \w porque|strong="H3588"\w* \w no|strong="H3588"\w* \w es|strong="H3588"\w* mi mujer,  
\q2 ni \w yo|strong="H4480"\w* soy \w su|strong="H3588"\w* marido;  
\q1 \w que|strong="H3588"\w* quite, \w pues|strong="H3588"\w*, sus fornicaciones \w de|strong="H4480"\w* \w su|strong="H3588"\w* rostro,  
\q2 \w y|strong="H3588"\w* sus adulterios \w de|strong="H4480"\w* \w entre|strong="H3588"\w* sus pechos;   
\q1
\v 3 no sea \w que|strong="H5971"\w* yo la desnude,  
\q2 y la deje desnuda como en el día en \w que|strong="H5971"\w* nació,  
\q1 y la convierta en un desierto,  
\q2 y la deje como tierra seca,  
\q2 y la mate \w de|strong="H5971"\w* sed.   
\q1
\v 4 \w No|strong="H3808"\w* tendré piedad \w de|strong="H3588"\w* \w sus|strong="H1931"\w* hijos,  
\q2 \w porque|strong="H3588"\w* \w son|strong="H3588"\w* hijos \w de|strong="H3588"\w* fornicación.   
\q1
\v 5 \w Porque|strong="H6435"\w* su madre fornicó;  
\q2 la \w que|strong="H6435"\w* los concibió actuó vergonzosamente;  
\q1 pues dijo: «Iré tras mis amantes,  
\q2 \w que|strong="H6435"\w* me dan mi pan y mi agua,  
\q2 mi lana y mi lino,  
\q2 mi aceite y mi bebida».   
\q1
\v 6 \w Por|strong="H3588"\w* tanto, he aquí \w que|strong="H3588"\w* voy \w a|strong="H3068"\w* cercar \w su|strong="H1992"\w* camino \w con|strong="H3588"\w* espinos,  
\q2 \w y|strong="H3588"\w* levantaré un muro contra ella,  
\q2 \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* encuentre \w sus|strong="H1992"\w* senderos.   
\q1
\v 7 Ella seguirá \w a|strong="H3068"\w* sus amantes,  
\q2 \w pero|strong="H3588"\w* \w no|strong="H3588"\w* \w los|strong="H3588"\w* alcanzará;  
\q1 \w los|strong="H3588"\w* buscará,  
\q2 \w pero|strong="H3588"\w* \w no|strong="H3588"\w* \w los|strong="H3588"\w* encontrará.  
\q1 \w Entonces|strong="H3588"\w* dirá: ‘\w Iré|strong="H3212"\w* \w y|strong="H3588"\w* volveré \w a|strong="H3068"\w* mi primer marido,  
\q2 \w porque|strong="H3588"\w* \w me|strong="H3588"\w* \w iba|strong="H3212"\w* mejor \w entonces|strong="H3588"\w* \w que|strong="H3588"\w* ahora’.   
\q1
\v 8 \w Porque|strong="H3808"\w* ella \w no|strong="H3808"\w* reconocía \w que|strong="H3808"\w* yo le daba el trigo, el mosto y el aceite,  
\q2 y \w que|strong="H3808"\w* le multiplicaba la plata y el oro, los cuales usaron para Baal.   
\q1
\v 9 \w Por|strong="H3588"\w* tanto, \w volveré|strong="H7725"\w* \w y|strong="H3588"\w* tomaré \w mi|strong="H1245"\w* trigo \w a|strong="H3068"\w* \w su|strong="H3588"\w* tiempo,  
\q2 \w y|strong="H3588"\w* \w mi|strong="H1245"\w* mosto \w a|strong="H3068"\w* \w su|strong="H3588"\w* sazón,  
\q2 \w y|strong="H3588"\w* le arrancaré \w mi|strong="H1245"\w* lana \w y|strong="H3588"\w* \w mi|strong="H1245"\w* lino \w que|strong="H3588"\w* habían \w de|strong="H3588"\w* cubrir \w su|strong="H3588"\w* desnudez.   
\q1
\v 10 \w Y|strong="H3068"\w* ahora descubriré \w su|strong="H1931"\w* desvergüenza \w a|strong="H3068"\w* \w la|strong="H1931"\w* vista \w de|strong="H3588"\w* \w sus|strong="H1931"\w* amantes,  
\q2 \w y|strong="H3588"\w* \w nadie|strong="H3808"\w* \w la|strong="H1931"\w* librará \w de|strong="H3588"\w* mi \w mano|strong="H1931"\w*.   
\q1
\v 11 \w También|strong="H3651"\w* haré \w que|strong="H6256"\w* cesen todas sus celebraciones:  
\q2 sus fiestas, sus lunas nuevas, sus días \w de|strong="H6256"\w* reposo y todas sus asambleas solemnes.   
\q1
\v 12 Asolaré sus viñas y sus higueras,  
\q2 \w de|strong="H5869"\w* las cuales \w ha|strong="H3808"\w* dicho: «Este \w es|strong="H3027"\w* el salario \w que|strong="H3808"\w* mis amantes me han dado»;  
\q2 y haré \w de|strong="H5869"\w* ellas un matorral,  
\q2 y las bestias del campo \w se|strong="H3808"\w* las comerán.   
\q1
\v 13 \w La|strong="H3605"\w* castigaré por \w los|strong="H3605"\w* días de \w los|strong="H3605"\w* baales,  
\q2 \w a|strong="H3068"\w* \w los|strong="H3605"\w* cuales quemaba incienso  
\q1 cuando se engalanaba con sus zarcillos y sus joyas,  
\q2 y se iba tras sus amantes  
\q2 olvidándose de mí”, dice Yahvé.   
\q1
\v 14 «\w Por|strong="H5414"\w* tanto, he aquí \w que|strong="H1992"\w* la atraeré,  
\q2 la llevaré al desierto,  
\q2 y le hablaré al corazón.   
\q1
\v 15 \w Le|strong="H5921"\w* daré \w sus|strong="H1992"\w* viñas \w desde|strong="H5921"\w* allí,  
\q2 \w y|strong="H5921"\w* \w el|strong="H5921"\w* valle \w de|strong="H5921"\w* Acor \w por|strong="H5921"\w* puerta \w de|strong="H5921"\w* esperanza;  
\q1 \w y|strong="H5921"\w* allí cantará  
\q2 \w como|strong="H5921"\w* \w en|strong="H5921"\w* \w los|strong="H1992"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H1992"\w* juventud,  
\q2 \w y|strong="H5921"\w* \w como|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w en|strong="H5921"\w* \w que|strong="H5921"\w* subió \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Egipto.   
\q1
\v 16 \w Y|strong="H3068"\w* sucederá \w en|strong="H5921"\w* aquel día», \w dice|strong="H1696"\w* Yahvé,  
\q2 “\w que|strong="H5921"\w* \w me|strong="H5921"\w* llamarás ‘marido \w mío|strong="H5921"\w*’,  
\q2 \w y|strong="H5921"\w* ya \w no|strong="H5921"\w* \w me|strong="H5921"\w* llamarás ‘amo \w mío|strong="H5921"\w*’.   
\q1
\v 17 \w Porque|strong="H8033"\w* quitaré \w de|strong="H5414"\w* su boca los nombres \w de|strong="H5414"\w* los baales,  
\q2 y nunca \w más|strong="H6030"\w* serán mencionados \w por|strong="H5414"\w* su \w nombre|strong="H8033"\w*.   
\q1
\v 18 \w En|strong="H5750"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* haré un pacto \w a|strong="H3068"\w* favor \w de|strong="H5750"\w* \w ellos|strong="H1931"\w* con las bestias del campo,  
\q2 y con las aves del cielo,  
\q2 y con \w los|strong="H1931"\w* reptiles \w de|strong="H5750"\w* \w la|strong="H1931"\w* tierra.  
\q1 Quebraré \w el|strong="H1931"\w* arco, \w la|strong="H1931"\w* espada y \w la|strong="H1931"\w* guerra \w de|strong="H5750"\w* \w la|strong="H1931"\w* tierra,  
\q2 y haré \w que|strong="H1931"\w* duerman seguros.   
\q1
\v 19 \w Y|strong="H3068"\w* te desposaré conmigo \w para|strong="H5493"\w* siempre;  
\q2 \w sí|strong="H3808"\w*, te desposaré conmigo \w en|strong="H5493"\w* justicia, \w en|strong="H5493"\w* derecho, \w en|strong="H5493"\w* benignidad y \w en|strong="H5493"\w* compasión.   
\q1
\v 20 \w Te|strong="H4480"\w* desposaré \w conmigo|strong="H5973"\w* \w en|strong="H4480"\w* fidelidad;  
\q2 y conocerás \w a|strong="H3068"\w* Yahvé.   
\q1
\v 21 En aquel día responderé”, dice Yahvé.  
\q2 “Yo responderé \w a|strong="H3068"\w* los cielos,  
\q2 y ellos responderán \w a|strong="H3068"\w* la tierra;   
\q2
\v 22 y la tierra responderá al trigo, al mosto y al aceite;  
\q2 y ellos responderán \w a|strong="H3068"\w* Jezreel.   
\q1
\v 23 \w La|strong="H1931"\w* sembraré \w para|strong="H1961"\w* \w mí|strong="H1961"\w* en \w la|strong="H1931"\w* tierra;  
\q2 y me compadeceré de \w la|strong="H1931"\w* \w que|strong="H1931"\w* \w no|strong="H1961"\w* \w había|strong="H1961"\w* obtenido misericordia;  
\q2 y diré \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w que|strong="H1931"\w* \w no|strong="H1961"\w* \w eran|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H1992"\w*: «Vosotros \w sois|strong="H1992"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H1992"\w*»,  
\q2 y \w ellos|strong="H1992"\w* dirán: «Tú \w eres|strong="H1931"\w* \w mi|strong="H1961"\w* \w Dios|strong="H3068"\w*»”.   
\c 3
\p
\v 1 Me dijo Yahvé: «\w Ve|strong="H3212"\w* \w otra|strong="H5750"\w* vez, ama \w a|strong="H3068"\w* una mujer amada \w por|strong="H5750"\w* \w su|strong="H1992"\w* \w compañero|strong="H7453"\w*, aunque \w adúltera|strong="H5003"\w*, \w así|strong="H1992"\w* \w como|strong="H5750"\w* Yahvé ama \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*, \w los|strong="H1992"\w* cuales \w se|strong="H1992"\w* vuelven \w a|strong="H3068"\w* dioses ajenos y aman \w las|strong="H1992"\w* tortas \w de|strong="H5750"\w* pasas».   
\p
\v 2 La compré, pues, para mí por \w quince|strong="H2568"\w* siclos \w de|strong="H2568"\w* \w plata|strong="H3701"\w* y un homer y medio \w de|strong="H2568"\w* \w cebada|strong="H8184"\w*.  
\v 3 \w Y|strong="H3068"\w* le dije: «Te quedarás conmigo por \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*. \w No|strong="H3808"\w* \w fornicarás|strong="H2181"\w*, \w ni|strong="H3808"\w* \w tomarás|strong="H1961"\w* otro hombre; \w y|strong="H1571"\w* yo haré \w lo|strong="H3808"\w* \w mismo|strong="H1571"\w* contigo».   
\p
\v 4 \w Porque|strong="H3588"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w estarán|strong="H3427"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w* sin \w rey|strong="H4428"\w*, sin \w príncipe|strong="H8269"\w*, sin \w sacrificio|strong="H2077"\w*, sin piedra sagrada, \w y|strong="H3588"\w* sin efod ni terafines.  
\v 5 Después \w volverán|strong="H7725"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w buscarán|strong="H1245"\w* \w a|strong="H3068"\w* Yahvé su \w Dios|strong="H3068"\w*, y \w a|strong="H3068"\w* \w David|strong="H1732"\w* su \w rey|strong="H4428"\w*; y acudirán temblando \w a|strong="H3068"\w* Yahvé y \w a|strong="H3068"\w* su \w bondad|strong="H2898"\w* en \w los|strong="H1121"\w* últimos \w días|strong="H3117"\w*.   
\c 4
\p
\v 1 \w Escuchad|strong="H8085"\w* \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé, \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*,  
\q2 \w porque|strong="H3588"\w* Yahvé tiene \w pleito|strong="H7379"\w* \w con|strong="H5973"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra:  
\q1 “\w Porque|strong="H3588"\w* \w no|strong="H3588"\w* hay verdad, \w ni|strong="H5973"\w* \w misericordia|strong="H2617"\w*,  
\q2 \w ni|strong="H5973"\w* \w conocimiento|strong="H1847"\w* \w de|strong="H3588"\w* \w Dios|strong="H3068"\w* \w en|strong="H5973"\w* \w la|strong="H3588"\w* tierra.   
\q1
\v 2 Perjurar, mentir, matar, hurtar y adulterar prevalecen;  
\q2 rompen todos los límites, y la \w sangre|strong="H1818"\w* \w toca|strong="H5060"\w* \w a|strong="H3068"\w* la \w sangre|strong="H1818"\w*.   
\q1
\v 3 \w Por|strong="H5921"\w* \w lo|strong="H5921"\w* cual \w la|strong="H5921"\w* tierra \w estará|strong="H3427"\w* \w de|strong="H5921"\w* luto,  
\q2 \w y|strong="H1571"\w* \w se|strong="H5921"\w* extenuará \w todo|strong="H3605"\w* \w morador|strong="H3427"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*,  
\q1 \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w bestias|strong="H2416"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w y|strong="H1571"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*;  
\q2 \w y|strong="H1571"\w* \w aun|strong="H1571"\w* \w los|strong="H3427"\w* peces \w del|strong="H5921"\w* \w mar|strong="H3220"\w* morirán.   
\b  
\q1
\v 4 “Pero \w que|strong="H5971"\w* nadie \w pleitee|strong="H7378"\w*, ni \w reprenda|strong="H3198"\w* ninguno;  
\q2 \w porque|strong="H3198"\w* tu \w pueblo|strong="H5971"\w* es como los \w que|strong="H5971"\w* resisten al \w sacerdote|strong="H3548"\w*.   
\q1
\v 5 \w Tropezarás|strong="H3782"\w*, \w pues|strong="H1571"\w*, \w de|strong="H5973"\w* \w día|strong="H3117"\w*,  
\q2 \w y|strong="H1571"\w* \w el|strong="H5973"\w* \w profeta|strong="H5030"\w* \w tropezará|strong="H3782"\w* \w también|strong="H1571"\w* \w contigo|strong="H5973"\w* \w de|strong="H5973"\w* \w noche|strong="H3915"\w*;  
\q2 \w y|strong="H1571"\w* \w a|strong="H3068"\w* tu madre destruiré.   
\q1
\v 6 Mi \w pueblo|strong="H5971"\w* perece \w por|strong="H3588"\w* falta \w de|strong="H3588"\w* \w conocimiento|strong="H1847"\w*.  
\q2 \w Porque|strong="H3588"\w* has rechazado \w el|strong="H3588"\w* \w conocimiento|strong="H1847"\w*, \w yo|strong="H3588"\w* \w te|strong="H3588"\w* \w echaré|strong="H3988"\w* del \w sacerdocio|strong="H3547"\w*;  
\q2 \w y|strong="H1571"\w* \w porque|strong="H3588"\w* \w olvidaste|strong="H7911"\w* \w la|strong="H1571"\w* \w ley|strong="H8451"\w* \w de|strong="H3588"\w* tu Dios,  
\q1 \w también|strong="H1571"\w* \w yo|strong="H3588"\w* \w me|strong="H3588"\w* \w olvidaré|strong="H7911"\w* \w de|strong="H3588"\w* tus \w hijos|strong="H1121"\w*.   
\q1
\v 7 \w Cuanto|strong="H3651"\w* \w más|strong="H7235"\w* \w se|strong="H3651"\w* \w multiplicaron|strong="H7235"\w*, \w tanto|strong="H3651"\w* \w más|strong="H7235"\w* \w pecaron|strong="H2398"\w* contra mí;  
\q2 cambiaré su \w gloria|strong="H3519"\w* en \w afrenta|strong="H7036"\w*.   
\q1
\v 8 Del \w pecado|strong="H2403"\w* \w de|strong="H5971"\w* \w mi|strong="H5315"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* alimentan,  
\q2 y en su \w iniquidad|strong="H5771"\w* ponen su \w corazón|strong="H5315"\w*.   
\q1
\v 9 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w como|strong="H1961"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w*;  
\q2 \w los|strong="H5921"\w* castigaré \w por|strong="H5921"\w* sus \w caminos|strong="H1870"\w*,  
\q2 \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w pagaré|strong="H7725"\w* \w por|strong="H5921"\w* sus \w obras|strong="H4611"\w*.   
\q1
\v 10 Comerán, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w saciarán|strong="H7646"\w*;  
\q2 \w fornicarán|strong="H2181"\w*, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* multiplicarán;  
\q2 \w porque|strong="H3588"\w* han dejado \w de|strong="H3588"\w* servir \w a|strong="H3068"\w* Yahvé.   
\q1
\v 11 \w Fornicación|strong="H2184"\w*, \w vino|strong="H3196"\w* y \w mosto|strong="H8492"\w* \w quitan|strong="H3947"\w* el juicio.   
\q2
\v 12 Mi \w pueblo|strong="H5971"\w* consulta \w a|strong="H3068"\w* \w su|strong="H3588"\w* ídolo \w de|strong="H3588"\w* \w madera|strong="H6086"\w*,  
\q2 \w y|strong="H3588"\w* un \w palo|strong="H6086"\w* le responde;  
\q1 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w espíritu|strong="H7307"\w* \w de|strong="H3588"\w* fornicación \w los|strong="H3588"\w* hizo \w errar|strong="H8582"\w*,  
\q2 \w y|strong="H3588"\w* \w fornicaron|strong="H2181"\w* apartándose \w de|strong="H3588"\w* \w su|strong="H3588"\w* Dios.   
\q1
\v 13 \w Sacrifican|strong="H2076"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* cumbres \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*,  
\q2 \w y|strong="H3588"\w* queman incienso \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w collados|strong="H1389"\w*, \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* encinas, álamos \w y|strong="H3588"\w* olmos,  
\q2 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w sombra|strong="H6738"\w* \w es|strong="H3588"\w* \w buena|strong="H2896"\w*.  
\q1 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, vuestras \w hijas|strong="H1323"\w* \w fornicarán|strong="H2181"\w*,  
\q2 \w y|strong="H3588"\w* adulterarán vuestras \w nueras|strong="H3618"\w*.   
\q1
\v 14 \w No|strong="H3808"\w* castigaré \w a|strong="H3068"\w* vuestras \w hijas|strong="H1323"\w* \w cuando|strong="H3588"\w* forniquen,  
\q2 \w ni|strong="H3808"\w* \w a|strong="H3068"\w* vuestras \w nueras|strong="H3618"\w* \w cuando|strong="H3588"\w* adulteren;  
\q1 \w porque|strong="H3588"\w* \w los|strong="H1992"\w* padres \w mismos|strong="H1992"\w* \w se|strong="H5921"\w* van \w con|strong="H5973"\w* \w rameras|strong="H2181"\w*,  
\q2 \w y|strong="H3588"\w* \w con|strong="H5973"\w* \w las|strong="H1992"\w* \w rameras|strong="H2181"\w* sagradas \w sacrifican|strong="H2076"\w*;  
\q2 \w por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w sin|strong="H3808"\w* entendimiento \w caerá|strong="H3832"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* ruina.   
\b  
\q1
\v 15 “Aunque tú, \w Israel|strong="H3478"\w*, forniques,  
\q2 que no peque \w Judá|strong="H3063"\w*;  
\q2 y no vengáis \w a|strong="H3068"\w* \w Gilgal|strong="H1537"\w*,  
\q2 ni \w subáis|strong="H5927"\w* \w a|strong="H3068"\w* Bet-avén,  
\q2 ni \w juréis|strong="H7650"\w*: ‘\w Vive|strong="H2416"\w* Yahvé’.   
\q1
\v 16 \w Porque|strong="H3588"\w* \w como|strong="H3588"\w* novilla indómita se ha apartado \w Israel|strong="H3478"\w*;  
\q2 ¿\w los|strong="H3588"\w* \w apacentará|strong="H7462"\w* \w ahora|strong="H6258"\w* Yahvé \w como|strong="H3588"\w* \w a|strong="H3068"\w* \w corderos|strong="H3532"\w* \w en|strong="H3588"\w* lugar espacioso?   
\q1
\v 17 Efraín está apegado \w a|strong="H3068"\w* los \w ídolos|strong="H6091"\w*.  
\q2 ¡Déjalo!   
\q1
\v 18 Su bebida se corrompió;  
\q2 \w fornicaron|strong="H2181"\w* de continuo;  
\q2 sus príncipes amaron ardientemente la deshonra.   
\q1
\v 19 El \w viento|strong="H7307"\w* los envolvió en sus \w alas|strong="H3671"\w*,  
\q2 y de sus \w sacrificios|strong="H2077"\w* se avergonzarán.   
\b  
\c 5
\p
\v 1 “¡\w Escuchad|strong="H8085"\w* \w esto|strong="H2063"\w*, \w sacerdotes|strong="H3548"\w*!  
\q2 ¡\w Estad|strong="H1961"\w* \w atentos|strong="H7181"\w*, \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*,  
\q2 \w y|strong="H3588"\w* prestad atención, \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*!  
\q1 \w Porque|strong="H3588"\w* \w el|strong="H5921"\w* \w juicio|strong="H4941"\w* \w es|strong="H1961"\w* \w contra|strong="H5921"\w* \w vosotros|strong="H8085"\w*;  
\q2 \w porque|strong="H3588"\w* habéis \w sido|strong="H1961"\w* una trampa \w en|strong="H5921"\w* \w Mizpa|strong="H4709"\w*,  
\q2 \w y|strong="H3588"\w* una \w red|strong="H7568"\w* extendida \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w Tabor|strong="H8396"\w*.   
\q1
\v 2 \w Los|strong="H3605"\w* rebeldes se han sumido en \w la|strong="H3605"\w* matanza,  
\q2 pero yo \w los|strong="H3605"\w* castigaré \w a|strong="H3068"\w* \w todos|strong="H3605"\w*.   
\q1
\v 3 \w Yo|strong="H4480"\w* \w conozco|strong="H3045"\w* \w a|strong="H3068"\w* Efraín,  
\q2 \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* \w me|strong="H4480"\w* oculta \w Israel|strong="H3478"\w*;  
\q1 \w porque|strong="H3588"\w* \w ahora|strong="H6258"\w*, Efraín, has \w fornicado|strong="H2181"\w*,  
\q2 \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w se|strong="H3045"\w* \w ha|strong="H3808"\w* \w contaminado|strong="H2930"\w*.   
\q1
\v 4 Sus \w obras|strong="H4611"\w* \w no|strong="H3808"\w* les permiten \w volverse|strong="H7725"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w Dios|strong="H3068"\w*,  
\q2 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w espíritu|strong="H7307"\w* \w de|strong="H3588"\w* fornicación está \w en|strong="H3588"\w* ellos,  
\q2 \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w conocen|strong="H3045"\w* \w a|strong="H3068"\w* Yahvé.   
\q1
\v 5 \w La|strong="H1571"\w* \w soberbia|strong="H1347"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* testifica \w en|strong="H5973"\w* su \w cara|strong="H6440"\w*;  
\q2 \w por|strong="H6440"\w* eso \w Israel|strong="H3478"\w* \w y|strong="H1571"\w* Efraín \w tropezarán|strong="H3782"\w* \w en|strong="H5973"\w* su \w iniquidad|strong="H5771"\w*,  
\q2 \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w Judá|strong="H3063"\w* \w tropezará|strong="H3782"\w* \w con|strong="H5973"\w* \w ellos|strong="H1571"\w*.   
\q1
\v 6 \w Irán|strong="H3212"\w* con \w sus|strong="H1992"\w* rebaños \w y|strong="H1241"\w* con \w sus|strong="H1992"\w* manadas \w a|strong="H3068"\w* buscar \w a|strong="H3068"\w* Yahvé,  
\q2 pero \w no|strong="H3808"\w* \w lo|strong="H3808"\w* encontrarán;  
\q2 \w él|strong="H1992"\w* \w se|strong="H1992"\w* \w ha|strong="H3808"\w* apartado de \w ellos|strong="H1992"\w*.   
\q1
\v 7 Han sido desleales \w a|strong="H3068"\w* Yahvé,  
\q2 \w porque|strong="H3588"\w* han engendrado \w hijos|strong="H1121"\w* extraños.  
\q2 \w Ahora|strong="H6258"\w* \w la|strong="H3588"\w* luna nueva \w los|strong="H1121"\w* devorará junto \w con|strong="H3588"\w* sus heredades.   
\b  
\q1
\v 8 “¡\w Tocad|strong="H8628"\w* la \w bocina|strong="H7782"\w* en \w Gabaa|strong="H1390"\w*,  
\q2 y la \w trompeta|strong="H7782"\w* en \w Ramá|strong="H7414"\w*!  
\q2 ¡Dad gritos de guerra en Bet-avén! ¡Tiembla, \w Benjamín|strong="H1144"\w*!   
\q1
\v 9 Efraín \w será|strong="H1961"\w* \w asolado|strong="H8047"\w* en el \w día|strong="H3117"\w* del castigo;  
\q2 entre las \w tribus|strong="H7626"\w* de \w Israel|strong="H3478"\w* he dado \w a|strong="H3068"\w* conocer lo \w que|strong="H3045"\w* \w es|strong="H1961"\w* seguro.   
\q1
\v 10 \w Los|strong="H5921"\w* \w príncipes|strong="H8269"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w fueron|strong="H1961"\w* \w como|strong="H1961"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* traspasan \w los|strong="H5921"\w* linderos;  
\q2 \w derramaré|strong="H8210"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w mi|strong="H5921"\w* ira \w como|strong="H1961"\w* \w agua|strong="H4325"\w*.   
\q1
\v 11 Efraín está \w oprimido|strong="H6231"\w*,  
\q2 \w quebrantado|strong="H7533"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w juicio|strong="H4941"\w*,  
\q2 \w porque|strong="H3588"\w* \w quiso|strong="H2974"\w* \w andar|strong="H1980"\w* tras \w los|strong="H3588"\w* ídolos.   
\q1
\v 12 Yo, pues, seré como \w polilla|strong="H6211"\w* para Efraín,  
\q2 y como carcoma para la \w casa|strong="H1004"\w* de \w Judá|strong="H3063"\w*.   
\b  
\q1
\v 13 «Cuando Efraín \w vio|strong="H7200"\w* \w su|strong="H1931"\w* \w enfermedad|strong="H2483"\w*,  
\q2 y \w Judá|strong="H3063"\w* \w su|strong="H1931"\w* \w llaga|strong="H4205"\w*,  
\q2 entonces Efraín \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Asiria,  
\q2 y \w envió|strong="H7971"\w* mensajeros \w al|strong="H4480"\w* \w rey|strong="H4428"\w* \w Jareb|strong="H3377"\w*;  
\q1 \w mas|strong="H4480"\w* \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w os|strong="H4480"\w* \w podrá|strong="H3201"\w* sanar,  
\q2 \w ni|strong="H3808"\w* \w os|strong="H4480"\w* \w curará|strong="H7495"\w* \w la|strong="H1931"\w* \w llaga|strong="H4205"\w*.   
\q1
\v 14 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* seré \w como|strong="H3588"\w* \w león|strong="H7826"\w* \w para|strong="H3588"\w* Efraín,  
\q2 \w y|strong="H3588"\w* \w como|strong="H3588"\w* cachorro \w de|strong="H3588"\w* \w león|strong="H7826"\w* \w para|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*.  
\q1 \w Yo|strong="H3588"\w*, \w yo|strong="H3588"\w* mismo, despedazaré \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w iré|strong="H3212"\w*;  
\q2 \w me|strong="H3588"\w* \w llevaré|strong="H5375"\w* \w la|strong="H3588"\w* presa, \w y|strong="H3588"\w* \w no|strong="H3588"\w* habrá quien \w la|strong="H3588"\w* \w libre|strong="H5337"\w*.   
\q1
\v 15 \w Iré|strong="H3212"\w* \w y|strong="H5704"\w* \w volveré|strong="H7725"\w* \w a|strong="H3068"\w* \w mi|strong="H1245"\w* \w lugar|strong="H4725"\w*,  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* reconozcan \w su|strong="H1992"\w* culpa  
\q2 \w y|strong="H5704"\w* \w busquen|strong="H1245"\w* \w mi|strong="H1245"\w* \w rostro|strong="H6440"\w*.  
\q2 \w En|strong="H5704"\w* \w su|strong="H1992"\w* \w angustia|strong="H6862"\w* me \w buscarán|strong="H1245"\w* \w con|strong="H5704"\w* ahínco».   
\b  
\c 6
\p
\v 1 «¡\w Venid|strong="H3212"\w* \w y|strong="H3588"\w* \w volvamos|strong="H7725"\w* \w a|strong="H3068"\w* Yahvé!  
\q2 \w Porque|strong="H3588"\w* \w él|strong="H1931"\w* \w arrebató|strong="H2963"\w*,  
\q2 \w y|strong="H3588"\w* nos \w curará|strong="H7495"\w*;  
\q1 \w él|strong="H1931"\w* \w hirió|strong="H5221"\w*,  
\q2 \w y|strong="H3588"\w* \w vendará|strong="H2280"\w* nuestras heridas.   
\q1
\v 2 Nos dará \w vida|strong="H3117"\w* después \w de|strong="H6440"\w* \w dos|strong="H6440"\w* \w días|strong="H3117"\w*;  
\q2 al tercer \w día|strong="H3117"\w* nos \w resucitará|strong="H6965"\w*,  
\q2 y \w viviremos|strong="H2421"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él.   
\q1
\v 3 \w Y|strong="H3068"\w* \w conoceremos|strong="H3045"\w*, y proseguiremos en conocer \w a|strong="H3068"\w* Yahvé.  
\q2 Como el alba está dispuesta su \w salida|strong="H4161"\w*;  
\q1 y vendrá \w a|strong="H3068"\w* nosotros como la \w lluvia|strong="H1653"\w*,  
\q2 como la \w lluvia|strong="H1653"\w* \w tardía|strong="H4456"\w* y \w temprana|strong="H3384"\w* \w a|strong="H3068"\w* la tierra».   
\b  
\q1
\v 4 “¿\w Qué|strong="H4100"\w* \w haré|strong="H6213"\w* contigo, Efraín?  
\q2 ¿\w Qué|strong="H4100"\w* \w haré|strong="H6213"\w* contigo, \w oh|strong="H4100"\w* \w Judá|strong="H3063"\w*?  
\q2 \w Porque|strong="H4100"\w* vuestra piedad es \w como|strong="H4100"\w* \w nube|strong="H6051"\w* de la \w mañana|strong="H1242"\w*,  
\q2 y \w como|strong="H4100"\w* \w el|strong="H6213"\w* \w rocío|strong="H2919"\w* de la madrugada, \w que|strong="H4100"\w* \w se|strong="H4100"\w* desvanece.   
\q1
\v 5 \w Por|strong="H5921"\w* \w esta|strong="H3651"\w* causa \w los|strong="H5921"\w* corté \w por|strong="H5921"\w* medio \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w*;  
\q2 \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w palabras|strong="H6310"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w boca|strong="H6310"\w* \w los|strong="H5921"\w* \w maté|strong="H2026"\w*,  
\q2 \w y|strong="H5921"\w* mis \w juicios|strong="H4941"\w* \w saldrán|strong="H3318"\w* \w como|strong="H5921"\w* \w la|strong="H5921"\w* luz.   
\q1
\v 6 \w Porque|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w quiero|strong="H2654"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w sacrificio|strong="H2077"\w*;  
\q2 \w y|strong="H3588"\w* \w conocimiento|strong="H1847"\w* \w de|strong="H3588"\w* Dios \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w holocaustos|strong="H5930"\w*.   
\q1
\v 7 Mas \w ellos|strong="H1992"\w*, cual Adán, \w traspasaron|strong="H5674"\w* \w el|strong="H5674"\w* \w pacto|strong="H1285"\w*;  
\q2 \w allí|strong="H8033"\w* prevaricaron contra mí.   
\q1
\v 8 \w Galaad|strong="H1568"\w*, \w ciudad|strong="H7151"\w* \w de|strong="H1818"\w* obradores \w de|strong="H1818"\w* \w iniquidad|strong="H1568"\w*,  
\q2 está manchada \w de|strong="H1818"\w* \w sangre|strong="H1818"\w*.   
\q1
\v 9 \w Y|strong="H3068"\w* \w como|strong="H3588"\w* ladrones \w que|strong="H3588"\w* esperan \w a|strong="H3068"\w* algún hombre,  
\q2 \w así|strong="H3588"\w* una compañía \w de|strong="H3588"\w* \w sacerdotes|strong="H3548"\w* \w mata|strong="H7523"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w hacia|strong="H1870"\w* Siquem;  
\q2 \w así|strong="H3588"\w* cometen \w abominación|strong="H2154"\w*.   
\q1
\v 10 En la \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w* he \w visto|strong="H7200"\w* inmundicia;  
\q2 \w allí|strong="H8033"\w* \w fornicó|strong="H2184"\w* Efraín,  
\q2 y se \w contaminó|strong="H2930"\w* \w Israel|strong="H3478"\w*.   
\b  
\q1
\v 11 “\w Para|strong="H5971"\w* ti \w también|strong="H1571"\w*, oh \w Judá|strong="H3063"\w*, está preparada una siega,  
\q2 \w cuando|strong="H1571"\w* yo haga \w volver|strong="H7725"\w* \w a|strong="H3068"\w* los cautivos \w de|strong="H5971"\w* mi \w pueblo|strong="H5971"\w*.   
\c 7
\p
\v 1 “\w Mientras|strong="H3588"\w* \w yo|strong="H3588"\w* curaba \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*,  
\q2 quedó al descubierto \w la|strong="H3588"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H3588"\w* Efraín,  
