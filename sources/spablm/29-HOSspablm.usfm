\v 8 \w Los|strong="H5921"\w* lugares \w altos|strong="H1116"\w* \w de|strong="H5921"\w* Avén, \w el|strong="H5921"\w* \w pecado|strong="H2403"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, serán \w destruidos|strong="H8045"\w*;  
\q2 \w el|strong="H5921"\w* \w espino|strong="H6975"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* cardo \w crecerán|strong="H5927"\w* \w sobre|strong="H5921"\w* sus \w altares|strong="H4196"\w*.  
\q2 \w Y|strong="H3068"\w* dirán \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*: «¡\w Cubridnos|strong="H3680"\w*!», \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w collados|strong="H1389"\w*: «¡\w Caed|strong="H5307"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*!»   
\b  
\q1
\v 9 «\w Oh|strong="H1121"\w* \w Israel|strong="H3478"\w*, has \w pecado|strong="H2398"\w* \w desde|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w Gabaa|strong="H1390"\w*.  
\q2 \w Allí|strong="H8033"\w* \w se|strong="H5921"\w* mantuvieron.  
\q2 ¿\w No|strong="H3808"\w* \w los|strong="H1121"\w* \w alcanzará|strong="H5381"\w* \w en|strong="H5921"\w* \w Gabaa|strong="H1390"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w* \w contra|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* iniquidad?   
\q1
\v 10 Cuando sea \w mi|strong="H5921"\w* deseo, yo \w los|strong="H5921"\w* \w castigaré|strong="H3256"\w*;  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* reunirán naciones \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*,  
\q2 cuando sean atados \w por|strong="H5921"\w* su doble transgresión.   
\q1
\v 11 Efraín es una \w novilla|strong="H5697"\w* \w domada|strong="H3925"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w que|strong="H5921"\w* \w le|strong="H5921"\w* gusta trillar,  
\q2 \w mas|strong="H5921"\w* yo pondré \w el|strong="H5921"\w* \w yugo|strong="H5921"\w* \w sobre|strong="H5921"\w* su hermoso \w cuello|strong="H6676"\w*.  
\q2 Haré \w que|strong="H5921"\w* Efraín tire \w del|strong="H5921"\w* \w carro|strong="H7392"\w*;  
\q2 \w Judá|strong="H3063"\w* \w arará|strong="H2790"\w*,  
\q2 \w y|strong="H5921"\w* \w Jacob|strong="H3290"\w* romperá sus terrones.   
\q1
\v 12 \w Sembrad|strong="H2232"\w* \w para|strong="H5704"\w* vosotros \w en|strong="H5704"\w* \w justicia|strong="H6664"\w*,  
\q2 \w segad|strong="H7114"\w* \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* la \w misericordia|strong="H2617"\w*.  
\q1 \w Haced|strong="H5215"\w* \w para|strong="H5704"\w* vosotros \w barbecho|strong="H5214"\w*,  
\q2 porque es el \w tiempo|strong="H6256"\w* \w de|strong="H5704"\w* buscar \w a|strong="H3068"\w* Yahvé,  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* venga \w y|strong="H5704"\w* llueva \w justicia|strong="H6664"\w* sobre vosotros.   
