\q1
\v 13 Efraín, según \w veo|strong="H7200"\w*, es como \w Tiro|strong="H6865"\w*, \w plantado|strong="H8362"\w* \w en|strong="H3318"\w* un lugar ameno;  
\q2 pero Efraín \w sacará|strong="H3318"\w* sus \w hijos|strong="H1121"\w* al matador.   
\q1
\v 14 \w Dales|strong="H5414"\w*, \w oh|strong="H4100"\w* Yahvé; ¿\w qué|strong="H4100"\w* les \w darás|strong="H5414"\w*?  
\q2 \w Dales|strong="H5414"\w* una \w matriz|strong="H7358"\w* \w que|strong="H4100"\w* aborte y \w pechos|strong="H7699"\w* secos.   
\b  
\q1
\v 15 «\w Toda|strong="H3605"\w* \w su|strong="H3588"\w* \w maldad|strong="H7451"\w* \w está|strong="H5921"\w* \w en|strong="H5921"\w* \w Gilgal|strong="H1537"\w*;  
\q2 \w ciertamente|strong="H3588"\w* \w allí|strong="H8033"\w* \w los|strong="H5921"\w* \w aborrecí|strong="H8130"\w*.  
\q2 \w A|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* perversidad \w de|strong="H5921"\w* sus \w obras|strong="H4611"\w*, \w los|strong="H5921"\w* expulsaré \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w*.  
\q2 \w No|strong="H3808"\w* \w los|strong="H5921"\w* amaré \w más|strong="H3588"\w*;  
\q2 \w todos|strong="H3605"\w* sus \w príncipes|strong="H8269"\w* \w son|strong="H3588"\w* rebeldes.   
\q1
\v 16 Efraín ha sido herido;  
\q2 \w su|strong="H3588"\w* raíz se ha secado.  
\q2 \w No|strong="H1097"\w* \w darán|strong="H6213"\w* \w más|strong="H3588"\w* \w fruto|strong="H6529"\w*.  
\q2 \w Aunque|strong="H3588"\w* den \w a|strong="H3068"\w* luz, \w yo|strong="H3588"\w* \w mataré|strong="H4191"\w* \w el|strong="H3588"\w* precioso \w fruto|strong="H6529"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* vientre».   
\b  
\q1
\v 17 \w Mi|strong="H1961"\w* Dios \w los|strong="H1961"\w* desechará, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* le \w obedecieron|strong="H8085"\w*;  
\q2 \w y|strong="H3588"\w* \w andarán|strong="H1961"\w* errantes \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w*.   
\c 10
\p
\v 1 \w Israel|strong="H3478"\w* \w es|strong="H7235"\w* una \w vid|strong="H1612"\w* frondosa que da su \w fruto|strong="H6529"\w*.  
\q2 Conforme \w a|strong="H3068"\w* la \w abundancia|strong="H7230"\w* de su \w fruto|strong="H6529"\w*, \w multiplicó|strong="H7235"\w* sus \w altares|strong="H4196"\w*;  
\q2 conforme \w a|strong="H3068"\w* la bondad de su tierra, hermosearon sus pilares sagrados.   
\q1
\v 2 \w Su|strong="H1931"\w* \w corazón|strong="H3820"\w* \w está|strong="H1931"\w* dividido;  
\q2 \w ahora|strong="H6258"\w* \w serán|strong="H1931"\w* hallados culpables.  
\q2 \w Él|strong="H1931"\w* demolerá \w sus|strong="H1931"\w* \w altares|strong="H4196"\w*,  
\q2 y \w destruirá|strong="H7703"\w* \w sus|strong="H1931"\w* pilares sagrados.   
\q1
\v 3 Seguramente \w ahora|strong="H6258"\w* dirán: «\w No|strong="H3808"\w* tenemos \w rey|strong="H4428"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* tememos \w a|strong="H3068"\w* Yahvé;  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w*, ¿\w qué|strong="H3588"\w* puede \w hacer|strong="H6213"\w* \w por|strong="H3588"\w* nosotros?»   
\q1
\v 4 \w Hablan|strong="H1696"\w* \w palabras|strong="H1697"\w* \w vanas|strong="H7723"\w*, jurando \w en|strong="H5921"\w* \w falso|strong="H7723"\w* \w al|strong="H5921"\w* \w hacer|strong="H3772"\w* pactos.  
\q2 \w Por|strong="H5921"\w* eso \w el|strong="H5921"\w* \w juicio|strong="H4941"\w* brota \w como|strong="H5921"\w* ajenjo \w en|strong="H5921"\w* \w los|strong="H5921"\w* surcos \w del|strong="H5921"\w* \w campo|strong="H7704"\w*.   
\q1
\v 5 \w Los|strong="H5921"\w* habitantes \w de|strong="H4480"\w* \w Samaria|strong="H8111"\w* estarán aterrorizados \w por|strong="H5921"\w* \w los|strong="H5921"\w* becerros \w de|strong="H4480"\w* Bet-avén;  
\q2 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5921"\w* lamentará \w por|strong="H5921"\w* \w su|strong="H3588"\w* ídolo,  
\q2 \w junto|strong="H5921"\w* \w con|strong="H5921"\w* sus sacerdotes \w que|strong="H3588"\w* \w se|strong="H5921"\w* regocijaban \w en|strong="H5921"\w* \w él|strong="H5921"\w*,  
\q2 \w por|strong="H5921"\w* \w su|strong="H3588"\w* \w gloria|strong="H3519"\w*, \w la|strong="H5921"\w* \w cual|strong="H3588"\w* \w se|strong="H5921"\w* ha apartado \w de|strong="H4480"\w* \w ella|strong="H4480"\w*.   
\q1
\v 6 \w El|strong="H1571"\w* ídolo \w también|strong="H1571"\w* será \w llevado|strong="H2986"\w* \w a|strong="H3068"\w* Asiria \w como|strong="H1571"\w* regalo para un gran \w rey|strong="H4428"\w*.  
\q2 Efraín se cubrirá de vergüenza,  
\q2 \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* se avergonzará de su propio \w consejo|strong="H6098"\w*.   
