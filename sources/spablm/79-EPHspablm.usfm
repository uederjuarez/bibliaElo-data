\p
\v 1 \w Y|strong="G2532"\w* \w él|strong="G3588"\w* \w os|strong="G5210"\w* dio vida a \w vosotros|strong="G5210"\w*, cuando estabais \w muertos|strong="G3498"\w* \w en|strong="G3588"\w* \w vuestras|strong="G3588"\w* transgresiones \w y|strong="G2532"\w* \w pecados|strong="G3900"\w*,  
