\c 25
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w pon|strong="H7760"\w* tu \w rostro|strong="H6440"\w* \w hacia|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón \w y|strong="H5921"\w* \w profetiza|strong="H5012"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 3 Di \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Amón: ‘\w Oíd|strong="H8085"\w* \w palabra|strong="H1697"\w* del Señor Yahvé. \w Así|strong="H3541"\w* \w dice|strong="H1697"\w* \w el|strong="H3588"\w* Señor Yahvé: \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* dijisteis: «¡\w Ah|strong="H1889"\w*!» \w contra|strong="H3478"\w* \w mi|strong="H2490"\w* \w santuario|strong="H4720"\w* \w cuando|strong="H3588"\w* \w fue|strong="H1980"\w* \w profanado|strong="H2490"\w*, \w y|strong="H3588"\w* \w contra|strong="H3478"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w cuando|strong="H3588"\w* \w fue|strong="H1980"\w* \w asolada|strong="H8074"\w*, \w y|strong="H3588"\w* \w contra|strong="H3478"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w cuando|strong="H3588"\w* \w fue|strong="H1980"\w* \w en|strong="H3588"\w* \w cautiverio|strong="H1473"\w*,  
