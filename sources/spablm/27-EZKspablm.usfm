\c 33
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* tu \w pueblo|strong="H5971"\w* \w y|strong="H3588"\w* \w diles|strong="H1696"\w*: ‘\w Cuando|strong="H3588"\w* \w yo|strong="H3588"\w* \w traiga|strong="H3947"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w sobre|strong="H5921"\w* una tierra, \w y|strong="H3588"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w tome|strong="H3947"\w* \w a|strong="H3068"\w* un \w hombre|strong="H1121"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w y|strong="H3588"\w* \w lo|strong="H5921"\w* ponga \w por|strong="H5921"\w* \w atalaya|strong="H6822"\w*,  
\v 3 \w si|strong="H5921"\w* \w él|strong="H5921"\w* \w ve|strong="H7200"\w* venir \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* toca \w la|strong="H5921"\w* \w trompeta|strong="H7782"\w* \w y|strong="H5921"\w* advierte \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w*,  
\v 4 entonces, cualquiera \w que|strong="H3808"\w* \w oiga|strong="H8085"\w* el \w sonido|strong="H6963"\w* \w de|strong="H1818"\w* la \w trompeta|strong="H7782"\w* y \w no|strong="H3808"\w* haga \w caso|strong="H3947"\w* \w de|strong="H1818"\w* la advertencia, \w si|strong="H3808"\w* la \w espada|strong="H2719"\w* viene y \w se|strong="H1961"\w* \w lo|strong="H3808"\w* lleva, su \w sangre|strong="H1818"\w* \w será|strong="H1961"\w* \w sobre|strong="H1961"\w* su propia \w cabeza|strong="H7218"\w*.  
\v 5 \w El|strong="H1931"\w* \w sonido|strong="H6963"\w* \w de|strong="H1818"\w* \w la|strong="H1931"\w* \w trompeta|strong="H7782"\w* \w oyó|strong="H8085"\w*, y \w no|strong="H3808"\w* \w se|strong="H1961"\w* apercibió; \w su|strong="H1931"\w* \w sangre|strong="H1818"\w* \w será|strong="H1961"\w* \w sobre|strong="H1961"\w* \w él|strong="H1931"\w*. \w Mas|strong="H3808"\w* \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w se|strong="H1961"\w* apercibiere \w librará|strong="H4422"\w* \w su|strong="H1931"\w* \w vida|strong="H5315"\w*.  
\v 6 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w el|strong="H1931"\w* \w atalaya|strong="H6822"\w* \w ve|strong="H7200"\w* venir \w la|strong="H1931"\w* \w espada|strong="H2719"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* toca \w la|strong="H1931"\w* \w trompeta|strong="H7782"\w*, \w y|strong="H3588"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* \w es|strong="H1931"\w* advertido, \w y|strong="H3588"\w* viene \w la|strong="H1931"\w* \w espada|strong="H2719"\w* \w y|strong="H3588"\w* \w se|strong="H1931"\w* lleva \w a|strong="H3068"\w* \w alguno|strong="H5315"\w* \w de|strong="H3588"\w* \w entre|strong="H3808"\w* \w ellos|strong="H1992"\w*, \w este|strong="H1931"\w* \w será|strong="H1931"\w* llevado \w por|strong="H3588"\w* causa \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w iniquidad|strong="H5771"\w*, \w pero|strong="H3588"\w* \w yo|strong="H3588"\w* \w demandaré|strong="H1875"\w* \w su|strong="H1931"\w* \w sangre|strong="H1818"\w* \w de|strong="H3588"\w* \w mano|strong="H3027"\w* del \w atalaya|strong="H6822"\w*’.   
\p
\v 7 “\w A|strong="H3068"\w* \w ti|strong="H4480"\w*, \w pues|strong="H4480"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w hombre|strong="H1121"\w*, \w te|strong="H4480"\w* he \w puesto|strong="H5414"\w* \w por|strong="H4480"\w* \w atalaya|strong="H6822"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*; \w oirás|strong="H8085"\w* la \w palabra|strong="H1697"\w* \w de|strong="H4480"\w* mi \w boca|strong="H6310"\w*, y \w los|strong="H1121"\w* amonestarás \w de|strong="H4480"\w* mi parte.  
\v 8 Cuando yo \w diga|strong="H1696"\w* al \w impío|strong="H7563"\w*: ‘¡\w Impío|strong="H7563"\w*, \w de|strong="H1818"\w* \w cierto|strong="H3808"\w* \w morirás|strong="H4191"\w*!’, \w si|strong="H3808"\w* tú \w no|strong="H3808"\w* hablas para advertir al \w impío|strong="H7563"\w* \w de|strong="H1818"\w* \w su|strong="H1931"\w* \w camino|strong="H1870"\w*, \w el|strong="H1931"\w* \w impío|strong="H7563"\w* \w morirá|strong="H4191"\w* \w por|strong="H1870"\w* \w su|strong="H1931"\w* \w iniquidad|strong="H5771"\w*, pero yo \w demandaré|strong="H1245"\w* \w su|strong="H1931"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* tu \w mano|strong="H3027"\w*.  
\v 9 \w Mas|strong="H3588"\w* \w si|strong="H3588"\w* tú adviertes \w al|strong="H4480"\w* \w impío|strong="H7563"\w* \w de|strong="H4480"\w* \w su|strong="H1931"\w* \w camino|strong="H1870"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H1931"\w* \w aparte|strong="H1931"\w* \w de|strong="H4480"\w* \w él|strong="H1931"\w*, \w y|strong="H3588"\w* \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* aparta \w de|strong="H4480"\w* \w su|strong="H1931"\w* \w camino|strong="H1870"\w*, \w él|strong="H1931"\w* \w morirá|strong="H4191"\w* \w por|strong="H3588"\w* \w su|strong="H1931"\w* \w iniquidad|strong="H5771"\w*, \w pero|strong="H3588"\w* tú habrás \w librado|strong="H5337"\w* tu \w alma|strong="H5315"\w*.   
\p
\v 10 “Tú, \w pues|strong="H3588"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, di \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: ‘Vosotros habláis \w así|strong="H3651"\w*, diciendo: «Nuestras \w rebeliones|strong="H6588"\w* \w y|strong="H3588"\w* nuestros \w pecados|strong="H2403"\w* están \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w nos|strong="H5921"\w* consumimos; ¿\w cómo|strong="H3588"\w*, \w pues|strong="H3588"\w*, \w viviremos|strong="H2421"\w*?»’.  
\v 11 Diles: ‘\w Vivo|strong="H2416"\w* \w yo|strong="H3588"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé, \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w quiero|strong="H2654"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* del \w impío|strong="H7563"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w impío|strong="H7563"\w* \w se|strong="H4100"\w* \w vuelva|strong="H7725"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w camino|strong="H1870"\w* \w y|strong="H3588"\w* \w viva|strong="H2416"\w*. ¡\w Volveos|strong="H7725"\w*, \w volveos|strong="H7725"\w* \w de|strong="H3588"\w* vuestros \w malos|strong="H7451"\w* \w caminos|strong="H1870"\w*! ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w moriréis|strong="H4191"\w*, \w oh|strong="H4100"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*?’.   
\p
\v 12 “\w Y|strong="H3068"\w* tú, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, di \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* tu \w pueblo|strong="H5971"\w*: ‘La \w justicia|strong="H6666"\w* del \w justo|strong="H6662"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w librará|strong="H5337"\w* \w el|strong="H1121"\w* \w día|strong="H3117"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* rebele; y la \w impiedad|strong="H7562"\w* del \w impío|strong="H7563"\w* \w no|strong="H3808"\w* le \w será|strong="H3808"\w* estorbo \w el|strong="H1121"\w* \w día|strong="H3117"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* \w vuelva|strong="H7725"\w* \w de|strong="H1121"\w* su \w impiedad|strong="H7562"\w*; \w ni|strong="H3808"\w* \w el|strong="H1121"\w* \w justo|strong="H6662"\w* \w podrá|strong="H3201"\w* \w vivir|strong="H2421"\w* por su \w justicia|strong="H6666"\w* \w el|strong="H1121"\w* \w día|strong="H3117"\w* \w que|strong="H3808"\w* \w peque|strong="H2398"\w*.  
\v 13 Cuando \w yo|strong="H6213"\w* diga \w al|strong="H5921"\w* \w justo|strong="H6662"\w*: «\w De|strong="H5921"\w* \w cierto|strong="H3808"\w* \w vivirás|strong="H2421"\w*», \w si|strong="H3808"\w* \w él|strong="H1931"\w* confía \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w justicia|strong="H6666"\w* \w y|strong="H5921"\w* comete \w iniquidad|strong="H5766"\w*, \w ninguna|strong="H3605"\w* \w de|strong="H5921"\w* \w sus|strong="H1931"\w* obras justas \w será|strong="H1931"\w* recordada, \w sino|strong="H3808"\w* \w que|strong="H1931"\w* \w morirá|strong="H4191"\w* \w por|strong="H5921"\w* \w la|strong="H1931"\w* \w iniquidad|strong="H5766"\w* \w que|strong="H1931"\w* \w cometió|strong="H6213"\w*.  
\v 14 \w Y|strong="H3068"\w* cuando \w yo|strong="H6213"\w* diga al \w impío|strong="H7563"\w*: «De \w cierto|strong="H4191"\w* \w morirás|strong="H4191"\w*», si \w él|strong="H6213"\w* se aparta de su \w pecado|strong="H2403"\w* y \w hace|strong="H6213"\w* según \w el|strong="H6213"\w* \w derecho|strong="H4941"\w* y la \w justicia|strong="H6666"\w*,  
\v 15 \w si|strong="H3808"\w* \w el|strong="H6213"\w* \w impío|strong="H7563"\w* restituye la prenda, devuelve \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w había|strong="H6213"\w* robado, y \w camina|strong="H1980"\w* en los \w estatutos|strong="H2708"\w* de la \w vida|strong="H2416"\w*, \w no|strong="H3808"\w* cometiendo \w iniquidad|strong="H5766"\w*, \w ciertamente|strong="H4191"\w* \w vivirá|strong="H2421"\w*; \w no|strong="H3808"\w* \w morirá|strong="H4191"\w*.  
\v 16 \w Ninguno|strong="H3808"\w* de \w los|strong="H3605"\w* \w pecados|strong="H2403"\w* \w que|strong="H3808"\w* \w cometió|strong="H2398"\w* le \w será|strong="H6213"\w* recordado; \w ha|strong="H3808"\w* \w hecho|strong="H6213"\w* según \w el|strong="H3605"\w* \w derecho|strong="H4941"\w* y \w la|strong="H3605"\w* \w justicia|strong="H6666"\w*; \w ciertamente|strong="H2421"\w* \w vivirá|strong="H2421"\w*’.   
\p
\v 17 “\w Sin|strong="H3808"\w* embargo, \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* tu \w pueblo|strong="H5971"\w* dicen: ‘\w No|strong="H3808"\w* es recto \w el|strong="H1121"\w* \w camino|strong="H1870"\w* del Señor’; pero es \w el|strong="H1121"\w* \w camino|strong="H1870"\w* \w de|strong="H1121"\w* \w ellos|strong="H1992"\w* \w el|strong="H1121"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* es recto.  
\v 18 Cuando \w el|strong="H6213"\w* \w justo|strong="H6662"\w* se aparta \w de|strong="H6662"\w* su \w justicia|strong="H6666"\w* y comete \w iniquidad|strong="H5766"\w*, \w morirá|strong="H4191"\w* por ello.  
\v 19 \w Y|strong="H3068"\w* cuando \w el|strong="H1931"\w* \w impío|strong="H7563"\w* \w se|strong="H1931"\w* aparta \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w impiedad|strong="H7564"\w* \w y|strong="H5921"\w* \w hace|strong="H6213"\w* \w según|strong="H5921"\w* \w el|strong="H1931"\w* \w derecho|strong="H4941"\w* \w y|strong="H5921"\w* \w la|strong="H1931"\w* \w justicia|strong="H6666"\w*, \w vivirá|strong="H2421"\w* \w por|strong="H5921"\w* \w ello|strong="H1931"\w*.  
\v 20 \w Y|strong="H3068"\w* vosotros decís: ‘\w No|strong="H3808"\w* es recto el \w camino|strong="H1870"\w* del Señor’. Yo os \w juzgaré|strong="H8199"\w*, oh \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* cada uno conforme \w a|strong="H3068"\w* sus \w caminos|strong="H1870"\w*”.   
\b  
\p
\v 21 \w Aconteció|strong="H1961"\w* \w en|strong="H5221"\w* el \w año|strong="H8141"\w* \w duodécimo|strong="H8147"\w* \w de|strong="H2568"\w* nuestro \w cautiverio|strong="H1546"\w*, \w en|strong="H5221"\w* el \w mes|strong="H2320"\w* \w décimo|strong="H6224"\w*, \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w cinco|strong="H2568"\w* días del \w mes|strong="H2320"\w*, \w que|strong="H1961"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H3389"\w* un fugitivo \w de|strong="H2568"\w* Jerusalén, diciendo: «¡La \w ciudad|strong="H5892"\w* ha \w sido|strong="H1961"\w* tomada!».  
\v 22 \w Y|strong="H3068"\w* la \w mano|strong="H3027"\w* \w de|strong="H6440"\w* Yahvé \w había|strong="H1961"\w* \w estado|strong="H1961"\w* \w sobre|strong="H1961"\w* \w mí|strong="H1961"\w* la \w tarde|strong="H6153"\w* anterior \w a|strong="H3068"\w* la llegada del fugitivo, \w y|strong="H5704"\w* \w había|strong="H1961"\w* \w abierto|strong="H6605"\w* \w mi|strong="H1961"\w* \w boca|strong="H6310"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* él \w llegó|strong="H5704"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w por|strong="H6440"\w* la \w mañana|strong="H1242"\w*; \w y|strong="H5704"\w* \w se|strong="H1961"\w* \w abrió|strong="H6605"\w* \w mi|strong="H1961"\w* \w boca|strong="H6310"\w*, \w y|strong="H5704"\w* ya \w no|strong="H3808"\w* \w estuve|strong="H1961"\w* \w más|strong="H5750"\w* mudo.   
\p
\v 23 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 24 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w los|strong="H3427"\w* \w que|strong="H5921"\w* \w habitan|strong="H3427"\w* aquellos lugares \w en|strong="H5921"\w* ruinas \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* andan diciendo: ‘Abraham \w era|strong="H1961"\w* uno solo, \w y|strong="H5921"\w* \w poseyó|strong="H3423"\w* \w la|strong="H5921"\w* tierra; \w pues|strong="H1961"\w* \w nosotros|strong="H5921"\w* \w somos|strong="H1961"\w* \w muchos|strong="H7227"\w*, \w a|strong="H3068"\w* \w nosotros|strong="H5921"\w* \w nos|strong="H5921"\w* \w es|strong="H1961"\w* \w dada|strong="H5414"\w* \w la|strong="H5921"\w* tierra \w en|strong="H5921"\w* \w posesión|strong="H4181"\w*’.  
\v 25 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, diles: ‘\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: Vosotros coméis \w la|strong="H5921"\w* carne \w con|strong="H5921"\w* \w sangre|strong="H1818"\w*, \w y|strong="H5921"\w* alzáis vuestros \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* vuestros \w ídolos|strong="H1544"\w*, \w y|strong="H5921"\w* derramáis \w sangre|strong="H1818"\w*; ¿\w y|strong="H5921"\w* habéis \w de|strong="H5921"\w* poseer \w la|strong="H5921"\w* tierra?  
\v 26 \w Os|strong="H5921"\w* apoyáis \w en|strong="H5921"\w* vuestra \w espada|strong="H2719"\w*, cometéis \w abominación|strong="H8441"\w*, \w y|strong="H5921"\w* cada uno profana \w a|strong="H3068"\w* \w la|strong="H5921"\w* mujer \w de|strong="H5921"\w* su \w prójimo|strong="H7453"\w*; ¿\w y|strong="H5921"\w* habéis \w de|strong="H5921"\w* poseer \w la|strong="H5921"\w* tierra?’.   
\p
\v 27 “\w Les|strong="H5921"\w* dirás \w así|strong="H3541"\w*: ‘\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: \w Vivo|strong="H2416"\w* yo, \w que|strong="H3808"\w* \w los|strong="H5921"\w* \w que|strong="H3808"\w* están \w en|strong="H5921"\w* \w las|strong="H5921"\w* ruinas \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w que|strong="H3808"\w* \w está|strong="H5921"\w* \w en|strong="H5921"\w* \w campo|strong="H7704"\w* abierto \w lo|strong="H3808"\w* \w entregaré|strong="H5414"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* fieras \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w lo|strong="H3808"\w* devoren; \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3808"\w* están \w en|strong="H5921"\w* \w las|strong="H5921"\w* fortalezas \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w cuevas|strong="H4631"\w* \w morirán|strong="H4191"\w* \w de|strong="H5921"\w* peste.  
\v 28 \w Y|strong="H3068"\w* convertiré la tierra en desolación \w y|strong="H5797"\w* en espanto, \w y|strong="H5797"\w* cesará la \w soberbia|strong="H1347"\w* \w de|strong="H5414"\w* su poderío; \w y|strong="H5797"\w* los \w montes|strong="H2022"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w* \w quedarán|strong="H5414"\w* desolados, \w de|strong="H5414"\w* modo que no habrá quien \w pase|strong="H5674"\w*.  
\v 29 \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w cuando|strong="H3588"\w* haya convertido \w la|strong="H5921"\w* tierra \w en|strong="H5921"\w* desolación \w y|strong="H3588"\w* \w en|strong="H5921"\w* espanto, \w por|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w abominaciones|strong="H8441"\w* \w que|strong="H3588"\w* han cometido’.   
\p
\v 30 “\w Y|strong="H3068"\w* \w en|strong="H3318"\w* \w cuanto|strong="H4100"\w* \w a|strong="H3068"\w* ti, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* tu \w pueblo|strong="H5971"\w* \w hablan|strong="H1696"\w* \w de|strong="H1121"\w* ti \w junto|strong="H5971"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* muros y \w en|strong="H3318"\w* las \w puertas|strong="H6607"\w* \w de|strong="H1121"\w* las \w casas|strong="H1004"\w*, y \w se|strong="H5971"\w* \w hablan|strong="H1696"\w* \w el|strong="H1121"\w* uno al otro, \w cada|strong="H1697"\w* \w cual|strong="H4100"\w* \w a|strong="H3068"\w* su hermano, \w diciendo|strong="H1696"\w*: ‘Venid, \w por|strong="H1697"\w* favor, y \w oíd|strong="H8085"\w* \w qué|strong="H4100"\w* \w palabra|strong="H1697"\w* viene \w de|strong="H1121"\w* Yahvé’.  
\v 31 \w Y|strong="H3068"\w* vienen \w a|strong="H3068"\w* ti \w como|strong="H3588"\w* \w viene|strong="H1980"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H3588"\w* \w se|strong="H3808"\w* sientan \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti \w como|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w mío|strong="H5971"\w*, \w y|strong="H3588"\w* \w oyen|strong="H8085"\w* tus \w palabras|strong="H1697"\w*, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w las|strong="H1992"\w* ponen \w por|strong="H3588"\w* \w obra|strong="H6213"\w*; \w porque|strong="H3588"\w* \w con|strong="H3588"\w* \w su|strong="H1992"\w* \w boca|strong="H6310"\w* muestran mucho amor, \w pero|strong="H3588"\w* \w su|strong="H1992"\w* \w corazón|strong="H3820"\w* \w va|strong="H3068"\w* tras \w su|strong="H1992"\w* propia \w avaricia|strong="H1215"\w*.  
\v 32 \w Y|strong="H3068"\w* he \w aquí|strong="H2005"\w* \w que|strong="H1697"\w* \w tú|strong="H6213"\w* eres para ellos como un cantor \w de|strong="H1697"\w* amores, \w de|strong="H1697"\w* \w voz|strong="H6963"\w* \w hermosa|strong="H3303"\w* y \w que|strong="H1697"\w* toca \w bien|strong="H2895"\w* un instrumento; porque \w oyen|strong="H8085"\w* tus \w palabras|strong="H1697"\w*, pero \w no|strong="H6213"\w* las ponen \w por|strong="H1697"\w* \w obra|strong="H6213"\w*.   
\p
\v 33 «\w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* esto suceda —\w y|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* viene—, \w entonces|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w hubo|strong="H1961"\w* \w profeta|strong="H5030"\w* \w entre|strong="H8432"\w* ellos».   
\c 34
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w profetiza|strong="H5012"\w* \w contra|strong="H5921"\w* \w los|strong="H1121"\w* \w pastores|strong="H7462"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*; \w profetiza|strong="H5012"\w*, \w y|strong="H5921"\w* di \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w pastores|strong="H7462"\w*: \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w pastores|strong="H7462"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H3808"\w* \w se|strong="H1961"\w* \w apacientan|strong="H7462"\w* \w a|strong="H3068"\w* \w sí|strong="H3808"\w* mismos! ¿\w No|strong="H3808"\w* deben \w los|strong="H1121"\w* \w pastores|strong="H7462"\w* apacentar \w a|strong="H3068"\w* \w los|strong="H1121"\w* rebaños?  
\v 3 Os coméis la grasa, os vestís con la \w lana|strong="H6785"\w* y degolláis \w a|strong="H3068"\w* la oveja engordada, pero \w no|strong="H3808"\w* \w apacentáis|strong="H7462"\w* \w a|strong="H3068"\w* las \w ovejas|strong="H6629"\w*.  
\v 4 \w No|strong="H3808"\w* fortalecisteis \w a|strong="H3068"\w* las débiles, \w ni|strong="H3808"\w* \w curasteis|strong="H7495"\w* \w a|strong="H3068"\w* la enferma; \w no|strong="H3808"\w* vendasteis \w a|strong="H3068"\w* la perniquebrada, \w ni|strong="H3808"\w* hicisteis \w volver|strong="H7725"\w* \w a|strong="H3068"\w* la descarriada, \w ni|strong="H3808"\w* \w buscasteis|strong="H1245"\w* \w a|strong="H3068"\w* la perdida, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* os habéis enseñoreado de ellas con dureza y con violencia.  
\v 5 \w Y|strong="H3068"\w* andan errantes por falta de \w pastor|strong="H7462"\w*, y \w son|strong="H1961"\w* presa de \w todas|strong="H3605"\w* las fieras del \w campo|strong="H7704"\w*, y \w se|strong="H1961"\w* han dispersado.  
\v 6 Mis \w ovejas|strong="H6629"\w* anduvieron perdidas \w por|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w* \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w collado|strong="H1389"\w* \w alto|strong="H7311"\w*; \w sí|strong="H6440"\w*, \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra fueron esparcidas mis \w ovejas|strong="H6629"\w*, \w y|strong="H5921"\w* \w no|strong="H5921"\w* hubo \w quien|strong="H3605"\w* \w las|strong="H5921"\w* \w buscase|strong="H1875"\w*, ni \w quien|strong="H3605"\w* preguntase \w por|strong="H5921"\w* \w ellas|strong="H5921"\w*.   
\p
\v 7 “\w Por|strong="H1697"\w* \w tanto|strong="H3651"\w*, \w pastores|strong="H7462"\w*, \w oíd|strong="H8085"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé:  
\v 8 \w Vivo|strong="H2416"\w* yo, \w dice|strong="H5002"\w* \w el|strong="H3605"\w* Señor Yahvé, \w que|strong="H3808"\w* \w por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w mi|strong="H1961"\w* \w rebaño|strong="H6629"\w* \w fue|strong="H1961"\w* \w para|strong="H3282"\w* ser robado, y mis \w ovejas|strong="H6629"\w* \w fueron|strong="H1961"\w* \w para|strong="H3282"\w* ser presa de \w todas|strong="H3605"\w* las fieras del \w campo|strong="H7704"\w*, \w sin|strong="H3808"\w* \w pastor|strong="H7462"\w*; y mis \w pastores|strong="H7462"\w* \w no|strong="H3808"\w* \w buscaron|strong="H1875"\w* \w a|strong="H3068"\w* mis \w ovejas|strong="H6629"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w los|strong="H3605"\w* \w pastores|strong="H7462"\w* \w se|strong="H1961"\w* \w apacentaron|strong="H7462"\w* \w a|strong="H3068"\w* \w sí|strong="H3808"\w* mismos, y \w no|strong="H3808"\w* \w apacentaron|strong="H7462"\w* \w a|strong="H3068"\w* mis \w ovejas|strong="H6629"\w*;  
\v 9 \w por|strong="H1697"\w* \w tanto|strong="H3651"\w*, oh \w pastores|strong="H7462"\w*, \w oíd|strong="H8085"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé.  
\v 10 \w Así|strong="H3541"\w* dice el Señor Yahvé: He \w aquí|strong="H3541"\w*, yo \w estoy|strong="H1961"\w* \w contra|strong="H1961"\w* \w los|strong="H1961"\w* \w pastores|strong="H7462"\w*; \w y|strong="H3541"\w* \w demandaré|strong="H1875"\w* mis \w ovejas|strong="H6629"\w* \w de|strong="H5750"\w* su \w mano|strong="H3027"\w*, \w y|strong="H3541"\w* haré \w que|strong="H3808"\w* dejen \w de|strong="H5750"\w* apacentar las \w ovejas|strong="H6629"\w*; \w ni|strong="H3808"\w* \w los|strong="H1961"\w* \w pastores|strong="H7462"\w* \w se|strong="H1961"\w* apacentarán \w más|strong="H5750"\w* \w a|strong="H3068"\w* \w sí|strong="H2005"\w* mismos, \w pues|strong="H1961"\w* yo \w libraré|strong="H5337"\w* mis \w ovejas|strong="H6629"\w* \w de|strong="H5750"\w* sus \w bocas|strong="H6310"\w*, \w y|strong="H3541"\w* \w no|strong="H3808"\w* les \w serán|strong="H1961"\w* \w más|strong="H5750"\w* \w por|strong="H3027"\w* comida.   
\p
\v 11 “\w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice \w el|strong="H3588"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w*, \w yo|strong="H3588"\w* mismo, iré \w a|strong="H3068"\w* buscar \w a|strong="H3068"\w* mis \w ovejas|strong="H6629"\w*, \w y|strong="H3588"\w* las \w reconoceré|strong="H1239"\w*.  
\v 12 \w Como|strong="H1961"\w* reconoce su \w rebaño|strong="H6629"\w* \w el|strong="H3605"\w* \w pastor|strong="H7462"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w que|strong="H3117"\w* \w está|strong="H1961"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de sus \w ovejas|strong="H6629"\w* \w esparcidas|strong="H6567"\w*, \w así|strong="H3651"\w* \w reconoceré|strong="H1239"\w* \w a|strong="H3068"\w* mis \w ovejas|strong="H6629"\w*, y las \w libraré|strong="H5337"\w* de \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w lugares|strong="H4725"\w* \w en|strong="H8432"\w* \w que|strong="H3117"\w* \w fueron|strong="H1961"\w* \w esparcidas|strong="H6567"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* del \w nublado|strong="H6051"\w* y de \w la|strong="H3605"\w* \w oscuridad|strong="H6205"\w*.  
\v 13 \w Y|strong="H3068"\w* \w yo|strong="H4480"\w* las sacaré \w de|strong="H4480"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*, y las \w juntaré|strong="H6908"\w* \w de|strong="H4480"\w* las tierras; las traeré \w a|strong="H3068"\w* su propia tierra, y las \w apacentaré|strong="H7462"\w* \w en|strong="H4480"\w* \w los|strong="H3605"\w* \w montes|strong="H2022"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w por|strong="H4480"\w* las riberas, y \w en|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* lugares habitados \w del|strong="H4480"\w* país.  
\v 14 En \w buenos|strong="H2896"\w* \w pastos|strong="H4829"\w* las \w apacentaré|strong="H7462"\w*, y en \w los|strong="H1961"\w* altos \w montes|strong="H2022"\w* de \w Israel|strong="H3478"\w* \w estará|strong="H1961"\w* su \w majada|strong="H7257"\w*; \w allí|strong="H8033"\w* \w dormirán|strong="H7257"\w* en \w buen|strong="H2896"\w* redil, y en \w pastos|strong="H4829"\w* suculentos \w serán|strong="H1961"\w* apacentadas \w sobre|strong="H1961"\w* \w los|strong="H1961"\w* \w montes|strong="H2022"\w* de \w Israel|strong="H3478"\w*.  
\v 15 Yo \w apacentaré|strong="H7462"\w* \w a|strong="H3068"\w* mis \w ovejas|strong="H6629"\w*, y yo les daré aprisco, \w dice|strong="H5002"\w* el Señor Yahvé.  
\v 16 \w Buscaré|strong="H1245"\w* \w a|strong="H3068"\w* la perdida, y haré \w volver|strong="H7725"\w* al redil \w a|strong="H3068"\w* la descarriada; vendaré \w a|strong="H3068"\w* la perniquebrada, y fortaleceré \w a|strong="H3068"\w* la débil; \w mas|strong="H1245"\w* \w a|strong="H3068"\w* la engordada y \w a|strong="H3068"\w* la \w fuerte|strong="H2389"\w* \w destruiré|strong="H8045"\w*; las \w apacentaré|strong="H7462"\w* con \w justicia|strong="H4941"\w*.   
\p
\v 17 “Mas en cuanto \w a|strong="H3068"\w* vosotras, \w ovejas|strong="H6629"\w* mías, \w así|strong="H3541"\w* dice el Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H3541"\w* yo \w juzgo|strong="H8199"\w* entre \w oveja|strong="H7716"\w* \w y|strong="H3541"\w* \w oveja|strong="H7716"\w*, entre carneros \w y|strong="H3541"\w* machos cabríos.  
\v 18 ¿\w Os|strong="H4480"\w* es \w poco|strong="H4592"\w* \w que|strong="H4480"\w* comáis los \w buenos|strong="H2896"\w* \w pastos|strong="H4829"\w*, \w sino|strong="H2896"\w* \w que|strong="H4480"\w* también holláis \w con|strong="H4480"\w* vuestros \w pies|strong="H7272"\w* lo \w que|strong="H4480"\w* \w queda|strong="H3498"\w* \w de|strong="H4480"\w* vuestros pastizales? ¿\w Y|strong="H3068"\w* \w que|strong="H4480"\w* \w bebáis|strong="H8354"\w* \w de|strong="H4480"\w* las \w aguas|strong="H4325"\w* claras, \w sino|strong="H2896"\w* \w que|strong="H4480"\w* también enturbiáis el \w resto|strong="H3499"\w* \w con|strong="H4480"\w* vuestros \w pies|strong="H7272"\w*?  
\v 19 \w Y|strong="H3068"\w* mis \w ovejas|strong="H6629"\w* han de comer lo que vosotros hollasteis con vuestros \w pies|strong="H7272"\w*, y han de \w beber|strong="H8354"\w* lo que con vuestros \w pies|strong="H7272"\w* enturbiasteis.   
\p
\v 20 “\w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* les dice el Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H3541"\w* yo, yo mismo, \w juzgaré|strong="H8199"\w* entre la \w oveja|strong="H7716"\w* engordada \w y|strong="H3541"\w* la \w oveja|strong="H7716"\w* \w flaca|strong="H7330"\w*.  
\v 21 \w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* empujasteis \w con|strong="H5704"\w* \w el|strong="H3605"\w* costado \w y|strong="H5704"\w* \w con|strong="H5704"\w* \w el|strong="H3605"\w* \w hombro|strong="H3802"\w*, \w y|strong="H5704"\w* acorneasteis \w con|strong="H5704"\w* vuestros \w cuernos|strong="H7161"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las débiles, \w hasta|strong="H5704"\w* esparcirlas \w por|strong="H3282"\w* \w fuera|strong="H2351"\w*,  
\v 22 yo \w salvaré|strong="H3467"\w* \w a|strong="H3068"\w* mis \w ovejas|strong="H6629"\w*, y \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w serán|strong="H1961"\w* \w por|strong="H5750"\w* despojo; y \w juzgaré|strong="H8199"\w* \w entre|strong="H3808"\w* \w oveja|strong="H7716"\w* y \w oveja|strong="H7716"\w*.  
\v 23 \w Y|strong="H3068"\w* \w levantaré|strong="H6965"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H1931"\w* \w a|strong="H3068"\w* un \w solo|strong="H1931"\w* \w pastor|strong="H7462"\w*, \w y|strong="H5921"\w* \w él|strong="H1931"\w* \w las|strong="H5921"\w* \w apacentará|strong="H7462"\w*; \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* \w David|strong="H1732"\w*, \w él|strong="H1931"\w* \w las|strong="H5921"\w* \w apacentará|strong="H7462"\w*, \w y|strong="H5921"\w* \w él|strong="H1931"\w* \w les|strong="H5921"\w* \w será|strong="H1961"\w* \w por|strong="H5921"\w* \w pastor|strong="H7462"\w*.  
\v 24 Yo, Yahvé, \w seré|strong="H1961"\w* \w a|strong="H3068"\w* ellos por \w Dios|strong="H3068"\w*, y \w mi|strong="H1961"\w* \w siervo|strong="H5650"\w* \w David|strong="H1732"\w* \w será|strong="H1961"\w* \w príncipe|strong="H5387"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ellos. Yo, Yahvé, he \w hablado|strong="H1696"\w*.   
\p
\v 25 «\w Y|strong="H3068"\w* estableceré \w con|strong="H4480"\w* \w ellos|strong="H4480"\w* un \w pacto|strong="H1285"\w* \w de|strong="H4480"\w* \w paz|strong="H7965"\w*, y quitaré \w de|strong="H4480"\w* la tierra las \w malas|strong="H7451"\w* \w bestias|strong="H2416"\w*; y \w habitarán|strong="H3427"\w* seguros \w en|strong="H4480"\w* \w el|strong="H3427"\w* \w desierto|strong="H4057"\w*, y dormirán \w en|strong="H4480"\w* \w los|strong="H3427"\w* bosques.  
\v 26 \w Y|strong="H3068"\w* \w daré|strong="H5414"\w* \w bendición|strong="H1293"\w* \w a|strong="H3068"\w* ellos y \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w alrededores|strong="H5439"\w* \w de|strong="H5414"\w* \w mi|strong="H1961"\w* \w collado|strong="H1389"\w*, y \w haré|strong="H5414"\w* descender la \w lluvia|strong="H1653"\w* en su \w tiempo|strong="H6256"\w*; \w lluvias|strong="H1653"\w* \w de|strong="H5414"\w* \w bendición|strong="H1293"\w* \w serán|strong="H1961"\w*.  
\v 27 \w El|strong="H5921"\w* \w árbol|strong="H6086"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w dará|strong="H5414"\w* \w su|strong="H3588"\w* \w fruto|strong="H6529"\w*, \w y|strong="H3588"\w* \w la|strong="H5921"\w* tierra \w dará|strong="H5414"\w* \w su|strong="H3588"\w* cosecha, \w y|strong="H3588"\w* \w estarán|strong="H1961"\w* seguras \w en|strong="H5921"\w* \w su|strong="H3588"\w* tierra; \w y|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé, \w cuando|strong="H3588"\w* rompa \w las|strong="H5921"\w* coyundas \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w yugo|strong="H5923"\w*, \w y|strong="H3588"\w* \w las|strong="H5921"\w* \w libre|strong="H5337"\w* \w de|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w se|strong="H3045"\w* \w sirven|strong="H5647"\w* \w de|strong="H5921"\w* \w ellas|strong="H5921"\w*.  
\v 28 \w No|strong="H3808"\w* \w serán|strong="H1961"\w* \w más|strong="H5750"\w* despojo \w de|strong="H5750"\w* las \w naciones|strong="H1471"\w*, \w ni|strong="H3808"\w* las fieras \w de|strong="H5750"\w* la tierra las devorarán; \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w habitarán|strong="H3427"\w* seguras, y \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* quien las espante.  
\v 29 \w Y|strong="H3068"\w* les \w levantaré|strong="H5375"\w* un \w plantío|strong="H4302"\w* \w de|strong="H5750"\w* renombre, y \w no|strong="H3808"\w* \w serán|strong="H1961"\w* \w más|strong="H5750"\w* consumidas \w de|strong="H5750"\w* \w hambre|strong="H7458"\w* \w en|strong="H5750"\w* la tierra, \w ni|strong="H3808"\w* ya \w más|strong="H5750"\w* \w serán|strong="H1961"\w* avergonzadas \w por|strong="H5750"\w* las \w naciones|strong="H1471"\w*.  
\v 30 \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé \w su|strong="H1992"\w* \w Dios|strong="H3069"\w*, estoy \w con|strong="H3588"\w* \w ellos|strong="H1992"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w ellos|strong="H1992"\w* \w son|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*, \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* Yahvé.  
\v 31 \w Y|strong="H3068"\w* vosotras, \w ovejas|strong="H6629"\w* mías, \w ovejas|strong="H6629"\w* de mi \w pasto|strong="H4830"\w*, hombres sois, y yo vuestro \w Dios|strong="H3069"\w*, \w dice|strong="H5002"\w* el Señor Yahvé».   
\c 35
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w pon|strong="H7760"\w* tu \w rostro|strong="H6440"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w de|strong="H5921"\w* \w Seír|strong="H8165"\w*, \w y|strong="H5921"\w* \w profetiza|strong="H5012"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w*,  
\v 3 \w y|strong="H5921"\w* dile: ‘\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* yo estoy \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, oh \w monte|strong="H2022"\w* \w de|strong="H5921"\w* \w Seír|strong="H8165"\w*; \w extenderé|strong="H5186"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* convertiré \w en|strong="H5921"\w* desolación \w y|strong="H5921"\w* espanto.  
\v 4 Destruiré tus \w ciudades|strong="H5892"\w* \w y|strong="H3588"\w* quedarás \w asolado|strong="H8077"\w*; \w y|strong="H3588"\w* \w sabrás|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé.   
\p
\v 5 “‘\w Por|strong="H5921"\w* \w cuanto|strong="H3282"\w* tuviste enemistad \w perpetua|strong="H5769"\w*, \w y|strong="H5921"\w* entregaste \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w al|strong="H5921"\w* \w poder|strong="H3027"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5921"\w* su calamidad, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w iniquidad|strong="H5771"\w* final;  
\v 6 \w por|strong="H3588"\w* \w tanto|strong="H3651"\w*, \w vivo|strong="H2416"\w* \w yo|strong="H3588"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé, \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w sangre|strong="H1818"\w* \w te|strong="H3588"\w* destinaré, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w sangre|strong="H1818"\w* \w te|strong="H3588"\w* \w perseguirá|strong="H7291"\w*; \w y|strong="H3588"\w* \w puesto|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w aborreciste|strong="H8130"\w* \w la|strong="H3588"\w* \w sangre|strong="H1818"\w*, \w la|strong="H3588"\w* \w sangre|strong="H1818"\w* \w te|strong="H3588"\w* \w perseguirá|strong="H7291"\w*.  
\v 7 Convertiré \w el|strong="H5674"\w* \w monte|strong="H2022"\w* \w de|strong="H4480"\w* \w Seír|strong="H8165"\w* \w en|strong="H4480"\w* desolación y espanto, y \w cortaré|strong="H3772"\w* \w de|strong="H4480"\w* \w él|strong="H5674"\w* \w al|strong="H4480"\w* \w que|strong="H4480"\w* \w pase|strong="H5674"\w* y \w al|strong="H4480"\w* \w que|strong="H4480"\w* regrese.  
\v 8 Llenaré sus \w montes|strong="H2022"\w* de sus \w muertos|strong="H2491"\w*; en tus \w collados|strong="H1389"\w*, en tus valles y en \w todos|strong="H3605"\w* tus arroyos, \w caerán|strong="H5307"\w* \w muertos|strong="H2491"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.  
\v 9 \w Te|strong="H3588"\w* convertiré \w en|strong="H3588"\w* desolación \w perpetua|strong="H5769"\w*, \w y|strong="H3588"\w* tus \w ciudades|strong="H5892"\w* \w no|strong="H3808"\w* serán \w habitadas|strong="H3427"\w*; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé.   
\p
\v 10 “‘\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* dijiste: «Estas \w dos|strong="H8147"\w* \w naciones|strong="H1471"\w* y estas \w dos|strong="H8147"\w* tierras \w serán|strong="H1961"\w* mías, y las tomaremos en posesión», \w estando|strong="H1961"\w* Yahvé \w allí|strong="H8033"\w*;  
\v 11 \w por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w vivo|strong="H2416"\w* \w yo|strong="H6213"\w*, \w dice|strong="H5002"\w* \w el|strong="H6213"\w* Señor Yahvé, \w que|strong="H3045"\w* \w yo|strong="H6213"\w* \w haré|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w tu|strong="H8199"\w* ira, y conforme \w a|strong="H3068"\w* la \w envidia|strong="H7068"\w* \w que|strong="H3045"\w* mostraste en \w tu|strong="H8199"\w* \w odio|strong="H8135"\w* contra ellos; y seré \w conocido|strong="H3045"\w* en medio de ellos, cuando te \w juzgue|strong="H8199"\w*.  
\v 12 \w Y|strong="H3068"\w* \w sabrás|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, he \w oído|strong="H8085"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* injurias \w que|strong="H3588"\w* \w has|strong="H5414"\w* proferido \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, diciendo: «Han sido \w asolados|strong="H8074"\w*, \w nos|strong="H5921"\w* han sido \w dados|strong="H5414"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w los|strong="H5921"\w* devoremos».  
\v 13 \w Y|strong="H3068"\w* \w te|strong="H5921"\w* engrandeciste \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w con|strong="H5921"\w* tu \w boca|strong="H6310"\w*, \w y|strong="H5921"\w* multiplicaste \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* tus \w palabras|strong="H1697"\w*; yo \w lo|strong="H1697"\w* he \w oído|strong="H8085"\w*.  
\v 14 “‘\w Así|strong="H3541"\w* dice \w el|strong="H3605"\w* Señor Yahvé: Cuando \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra se regocije, \w yo|strong="H6213"\w* te asolaré.  
\v 15 \w Como|strong="H3588"\w* \w te|strong="H5921"\w* alegraste \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w heredad|strong="H5159"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w porque|strong="H3588"\w* \w fue|strong="H1961"\w* \w asolada|strong="H8077"\w*, \w así|strong="H3651"\w* \w haré|strong="H6213"\w* \w contigo|strong="H5921"\w*; \w asolado|strong="H8077"\w* \w serás|strong="H1961"\w*, oh \w monte|strong="H2022"\w* \w de|strong="H5921"\w* \w Seír|strong="H8165"\w*, \w y|strong="H3588"\w* \w todo|strong="H3605"\w* Edom, \w todo|strong="H3605"\w* \w él|strong="H5921"\w*. \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé’”.   
\c 36
\p
\v 1 Tú, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w profetiza|strong="H5012"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w montes|strong="H2022"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y di: “\w Montes|strong="H2022"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w oíd|strong="H8085"\w* \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé.  
\v 2 \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: \w Por|strong="H5921"\w* \w cuanto|strong="H3282"\w* \w el|strong="H5921"\w* enemigo dijo \w contra|strong="H5921"\w* vosotros: ‘¡\w Ea|strong="H1889"\w*! ¡\w Las|strong="H5921"\w* alturas \w antiguas|strong="H5769"\w* \w nos|strong="H5921"\w* han \w sido|strong="H1961"\w* dadas \w en|strong="H5921"\w* \w posesión|strong="H4181"\w*!’;  
\v 3 \w profetiza|strong="H5012"\w*, \w pues|strong="H3651"\w*, \w y|strong="H5921"\w* di: \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: \w Por|strong="H5921"\w* \w cuanto|strong="H3282"\w* \w os|strong="H5921"\w* asolaron \w y|strong="H5921"\w* \w os|strong="H5921"\w* devoraron \w por|strong="H5921"\w* \w todas|strong="H5439"\w* \w partes|strong="H5439"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* fueseis \w posesión|strong="H4181"\w* \w del|strong="H5921"\w* \w resto|strong="H7611"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, \w y|strong="H5921"\w* habéis andado \w de|strong="H5921"\w* \w boca|strong="H8193"\w* \w en|strong="H5921"\w* \w boca|strong="H8193"\w* \w y|strong="H5921"\w* habéis \w sido|strong="H1961"\w* \w el|strong="H5921"\w* oprobio \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w*;  
\v 4 \w por|strong="H1697"\w* \w tanto|strong="H3651"\w*, \w montes|strong="H2022"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*, \w oíd|strong="H8085"\w* \w palabra|strong="H1697"\w* del Señor Yahvé. \w Así|strong="H3541"\w* \w dice|strong="H1697"\w* el Señor Yahvé \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w montes|strong="H2022"\w* \w y|strong="H3541"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w collados|strong="H1389"\w*, \w a|strong="H3068"\w* \w los|strong="H1961"\w* arroyos \w y|strong="H3541"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* valles, \w a|strong="H3068"\w* las ruinas desoladas \w y|strong="H3541"\w* \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w* \w desamparadas|strong="H5800"\w*, \w que|strong="H1697"\w* \w fueron|strong="H1961"\w* hechas botín \w y|strong="H3541"\w* escarnio \w para|strong="H1961"\w* el \w resto|strong="H7611"\w* \w de|strong="H1697"\w* las \w naciones|strong="H1471"\w* \w de|strong="H1697"\w* \w alrededor|strong="H5439"\w*;  
\v 5 \w por|strong="H5921"\w* \w eso|strong="H3651"\w*, \w así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H5921"\w* Señor Yahvé: \w Ciertamente|strong="H5414"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* fuego \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w celo|strong="H7068"\w* he \w hablado|strong="H1696"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w resto|strong="H7611"\w* \w de|strong="H5921"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w* \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w todo|strong="H3605"\w* Edom, \w los|strong="H1992"\w* cuales \w se|strong="H5921"\w* adjudicaron \w mi|strong="H5921"\w* tierra \w en|strong="H5921"\w* \w posesión|strong="H4181"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w alegría|strong="H8057"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w su|strong="H1992"\w* \w corazón|strong="H3824"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* despecho \w de|strong="H5921"\w* \w su|strong="H1992"\w* \w alma|strong="H5315"\w*, \w para|strong="H4616"\w* arrojarla \w como|strong="H5921"\w* botín”.  
