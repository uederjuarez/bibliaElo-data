\v 12 “‘\w Y|strong="H3068"\w* \w el|strong="H1931"\w* \w príncipe|strong="H5387"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H6440"\w* \w ellos|strong="H1931"\w* \w llevará|strong="H5375"\w* \w la|strong="H1931"\w* carga al \w hombro|strong="H3802"\w* \w en|strong="H8432"\w* \w la|strong="H1931"\w* oscuridad, y \w saldrá|strong="H3318"\w*. \w Horadarán|strong="H2864"\w* \w la|strong="H1931"\w* \w pared|strong="H7023"\w* \w para|strong="H3282"\w* sacarlo \w por|strong="H3282"\w* \w ella|strong="H1931"\w*; \w él|strong="H1931"\w* \w cubrirá|strong="H3680"\w* \w su|strong="H1931"\w* \w rostro|strong="H6440"\w* \w para|strong="H3282"\w* \w no|strong="H3808"\w* \w ver|strong="H7200"\w* con \w sus|strong="H1931"\w* \w ojos|strong="H5869"\w* \w la|strong="H1931"\w* tierra.  
\v 13 \w Mas|strong="H5921"\w* yo \w extenderé|strong="H6566"\w* \w mi|strong="H5921"\w* \w red|strong="H7568"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w será|strong="H3808"\w* preso \w en|strong="H5921"\w* \w mi|strong="H5921"\w* lazo; \w y|strong="H5921"\w* \w lo|strong="H3808"\w* llevaré \w a|strong="H3068"\w* Babilonia, \w a|strong="H3068"\w* tierra \w de|strong="H5921"\w* \w caldeos|strong="H3778"\w*, pero \w no|strong="H3808"\w* \w la|strong="H5921"\w* \w verá|strong="H7200"\w*, \w y|strong="H5921"\w* \w allá|strong="H8033"\w* \w morirá|strong="H4191"\w*.  
