\v 2 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 3 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w y|strong="H3541"\w* \w diles|strong="H1696"\w*: \w Así|strong="H3541"\w* \w dice|strong="H5002"\w* \w el|strong="H1121"\w* Señor Yahvé: ‘¿\w A|strong="H3068"\w* consultarme venís vosotros? \w Vivo|strong="H2416"\w* yo, \w que|strong="H1121"\w* no os responderé, \w dice|strong="H5002"\w* \w el|strong="H1121"\w* Señor Yahvé’.   
\p
\v 4 “¿\w Los|strong="H1121"\w* \w juzgarás|strong="H8199"\w* \w tú|strong="H8199"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*? ¿\w Los|strong="H1121"\w* \w juzgarás|strong="H8199"\w* \w tú|strong="H8199"\w*? Hazles conocer las \w abominaciones|strong="H8441"\w* \w de|strong="H1121"\w* sus padres,  
\v 5 \w y|strong="H3541"\w* diles: \w Así|strong="H3541"\w* dice el \w Señor|strong="H3068"\w* Yahvé: ‘El \w día|strong="H3117"\w* \w que|strong="H3045"\w* escogí \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3541"\w* \w alcé|strong="H5375"\w* \w mi|strong="H5375"\w* \w mano|strong="H3027"\w* para jurar \w a|strong="H3068"\w* la \w descendencia|strong="H2233"\w* de la \w casa|strong="H1004"\w* de \w Jacob|strong="H3290"\w*, \w cuando|strong="H3117"\w* \w me|strong="H3541"\w* di \w a|strong="H3068"\w* conocer \w a|strong="H3068"\w* \w ellos|strong="H3027"\w* en la tierra de \w Egipto|strong="H4714"\w*, \w cuando|strong="H3117"\w* \w alcé|strong="H5375"\w* \w mi|strong="H5375"\w* \w mano|strong="H3027"\w* \w y|strong="H3541"\w* les juré diciendo: Yo soy Yahvé vuestro \w Dios|strong="H3069"\w*;  
\v 6 \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w alcé|strong="H5375"\w* \w mi|strong="H5375"\w* \w mano|strong="H3027"\w* para jurarles \w que|strong="H1931"\w* \w los|strong="H3605"\w* sacaría de \w la|strong="H1931"\w* tierra de \w Egipto|strong="H4714"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w que|strong="H1931"\w* les había provisto, \w que|strong="H1931"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* y \w miel|strong="H1706"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* más hermosa de \w todas|strong="H3605"\w* las tierras.  
\v 7 Entonces les dije: Arrojad \w de|strong="H5869"\w* vosotros cada uno las \w abominaciones|strong="H8251"\w* \w de|strong="H5869"\w* sus \w ojos|strong="H5869"\w*, y no \w os|strong="H5869"\w* \w contaminéis|strong="H2930"\w* con los \w ídolos|strong="H1544"\w* \w de|strong="H5869"\w* \w Egipto|strong="H4714"\w*. Yo soy Yahvé vuestro \w Dios|strong="H3068"\w*.   
\p
\v 8 “‘\w Mas|strong="H5921"\w* \w ellos|strong="H5921"\w* \w se|strong="H5921"\w* rebelaron \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* quisieron \w obedecerme|strong="H8085"\w*; \w no|strong="H3808"\w* \w echó|strong="H7993"\w* \w de|strong="H5921"\w* \w sí|strong="H3808"\w* cada uno \w las|strong="H5921"\w* \w abominaciones|strong="H8251"\w* \w de|strong="H5921"\w* sus \w ojos|strong="H5869"\w*, \w ni|strong="H3808"\w* \w dejaron|strong="H5800"\w* \w los|strong="H5921"\w* \w ídolos|strong="H1544"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*; \w y|strong="H5921"\w* dije \w que|strong="H3808"\w* derramaría \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w para|strong="H5921"\w* cumplir \w mi|strong="H5921"\w* \w enojo|strong="H2534"\w* \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.  
\v 9 Pero actué \w a|strong="H3068"\w* causa \w de|strong="H5869"\w* \w mi|strong="H2490"\w* \w nombre|strong="H8034"\w*, \w para|strong="H4616"\w* \w que|strong="H1115"\w* \w no|strong="H6213"\w* \w se|strong="H3045"\w* profanase ante \w los|strong="H1992"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5869"\w* \w las|strong="H1992"\w* cuales estaban, ante cuyos \w ojos|strong="H5869"\w* me di \w a|strong="H3068"\w* conocer \w a|strong="H3068"\w* \w ellos|strong="H1992"\w* sacándolos \w de|strong="H5869"\w* la tierra \w de|strong="H5869"\w* \w Egipto|strong="H4714"\w*.  
\v 10 Los \w saqué|strong="H3318"\w* de la tierra de \w Egipto|strong="H4714"\w*, y los traje al \w desierto|strong="H4057"\w*;  
\v 11 y les \w di|strong="H5414"\w* \w mis|strong="H5414"\w* \w estatutos|strong="H2708"\w*, y les \w hice|strong="H6213"\w* conocer \w mis|strong="H5414"\w* decretos, \w por|strong="H5414"\w* los cuales \w el|strong="H6213"\w* hombre \w que|strong="H3045"\w* los cumpliere \w vivirá|strong="H2425"\w*.  
\v 12 \w Y|strong="H3068"\w* les \w di|strong="H5414"\w* \w también|strong="H1571"\w* \w mis|strong="H5414"\w* \w sábados|strong="H7676"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* fuesen \w por|strong="H3588"\w* señal \w entre|strong="H3588"\w* \w mí|strong="H1961"\w* \w y|strong="H1571"\w* \w ellos|strong="H1571"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* supiesen \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé \w que|strong="H3588"\w* \w los|strong="H1961"\w* \w santifico|strong="H6942"\w*.   
\p
\v 13 “‘\w Mas|strong="H5921"\w* \w se|strong="H5921"\w* rebeló \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*; \w no|strong="H3808"\w* \w anduvieron|strong="H1980"\w* \w en|strong="H5921"\w* mis \w estatutos|strong="H2708"\w*, \w y|strong="H5921"\w* \w desecharon|strong="H3988"\w* mis decretos, \w por|strong="H5921"\w* \w los|strong="H5921"\w* cuales \w el|strong="H5921"\w* hombre \w que|strong="H3808"\w* \w los|strong="H5921"\w* cumpliere \w vivirá|strong="H2425"\w*; \w y|strong="H5921"\w* mis \w sábados|strong="H7676"\w* \w profanaron|strong="H2490"\w* \w en|strong="H5921"\w* \w gran|strong="H3966"\w* \w manera|strong="H3966"\w*; dije, \w por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w que|strong="H3808"\w* derramaría \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w* \w para|strong="H5921"\w* consumirlos.  
\v 14 Pero actué \w a|strong="H3068"\w* causa \w de|strong="H5869"\w* \w mi|strong="H2490"\w* \w nombre|strong="H8034"\w*, \w para|strong="H4616"\w* \w que|strong="H1115"\w* \w no|strong="H6213"\w* se profanase ante los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* las \w naciones|strong="H1471"\w* ante cuyos \w ojos|strong="H5869"\w* los \w había|strong="H6213"\w* \w sacado|strong="H3318"\w*.  
\v 15 \w También|strong="H1571"\w* yo \w alcé|strong="H5375"\w* \w mi|strong="H5375"\w* \w mano|strong="H3027"\w* en \w el|strong="H1931"\w* \w desierto|strong="H4057"\w* \w para|strong="H5414"\w* jurarles \w que|strong="H1931"\w* \w no|strong="H1115"\w* \w los|strong="H3605"\w* traería \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w que|strong="H1931"\w* les había \w dado|strong="H5414"\w*, \w que|strong="H1931"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* \w y|strong="H1571"\w* \w miel|strong="H1706"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w más|strong="H1571"\w* hermosa \w de|strong="H5414"\w* \w todas|strong="H3605"\w* las tierras;  
\v 16 \w porque|strong="H3588"\w* \w desecharon|strong="H3988"\w* mis decretos, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w anduvieron|strong="H1980"\w* \w en|strong="H3588"\w* mis \w estatutos|strong="H2708"\w*, \w y|strong="H3588"\w* mis \w sábados|strong="H7676"\w* \w profanaron|strong="H2490"\w*, \w porque|strong="H3588"\w* tras sus \w ídolos|strong="H1544"\w* \w iba|strong="H1980"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w*.  
\v 17 \w Con|strong="H5921"\w* todo, \w los|strong="H5921"\w* perdonó \w mi|strong="H5921"\w* \w ojo|strong="H5869"\w*, pues \w no|strong="H3808"\w* \w los|strong="H5921"\w* maté, \w ni|strong="H3808"\w* \w los|strong="H5921"\w* exterminé \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*;  
\v 18 antes dije \w en|strong="H3212"\w* \w el|strong="H1121"\w* \w desierto|strong="H4057"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*: No \w andéis|strong="H3212"\w* \w en|strong="H3212"\w* \w los|strong="H1121"\w* \w estatutos|strong="H2706"\w* \w de|strong="H1121"\w* vuestros padres, ni \w guardéis|strong="H8104"\w* sus leyes, ni os \w contaminéis|strong="H2930"\w* con sus \w ídolos|strong="H1544"\w*.  
\v 19 \w Yo|strong="H6213"\w* soy Yahvé vuestro \w Dios|strong="H3068"\w*; \w andad|strong="H3212"\w* \w en|strong="H3212"\w* mis \w estatutos|strong="H2708"\w*, y \w guardad|strong="H8104"\w* mis preceptos, y ponedlos por \w obra|strong="H6213"\w*;  
\v 20 \w y|strong="H3588"\w* \w santificad|strong="H6942"\w* mis \w sábados|strong="H7676"\w*, \w y|strong="H3588"\w* \w sean|strong="H1961"\w* \w por|strong="H3588"\w* señal \w entre|strong="H3588"\w* \w mí|strong="H1961"\w* \w y|strong="H3588"\w* vosotros, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w sepáis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé vuestro \w Dios|strong="H3068"\w*.   
\p
\v 21 “‘\w Mas|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w se|strong="H5921"\w* rebelaron \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*; \w no|strong="H3808"\w* \w anduvieron|strong="H1980"\w* \w en|strong="H5921"\w* mis \w estatutos|strong="H2708"\w*, \w ni|strong="H3808"\w* \w guardaron|strong="H8104"\w* mis decretos \w para|strong="H5921"\w* ponerlos \w por|strong="H5921"\w* \w obra|strong="H6213"\w*, \w por|strong="H5921"\w* \w los|strong="H1121"\w* cuales \w el|strong="H5921"\w* \w hombre|strong="H1121"\w* \w que|strong="H3808"\w* \w los|strong="H1121"\w* cumpliere \w vivirá|strong="H2425"\w*; \w profanaron|strong="H2490"\w* mis \w sábados|strong="H7676"\w*. Dije entonces \w que|strong="H3808"\w* derramaría \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w para|strong="H5921"\w* cumplir \w mi|strong="H5921"\w* \w enojo|strong="H2534"\w* \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*.  
\v 22 \w Mas|strong="H1471"\w* retraje \w mi|strong="H2490"\w* \w mano|strong="H3027"\w*, y actué \w a|strong="H3068"\w* causa \w de|strong="H5869"\w* \w mi|strong="H2490"\w* \w nombre|strong="H8034"\w*, \w para|strong="H4616"\w* \w que|strong="H1115"\w* \w no|strong="H6213"\w* se profanase ante los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* las \w naciones|strong="H1471"\w* ante cuyos \w ojos|strong="H5869"\w* los \w había|strong="H6213"\w* \w sacado|strong="H3318"\w*.  
