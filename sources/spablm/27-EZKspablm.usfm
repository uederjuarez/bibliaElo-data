\v 55 \w Y|strong="H3068"\w* tus hermanas, \w Sodoma|strong="H5467"\w* y sus \w hijas|strong="H1323"\w*, y \w Samaria|strong="H8111"\w* y sus \w hijas|strong="H1323"\w*, \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* su estado anterior; tú también y tus \w hijas|strong="H1323"\w* \w volveréis|strong="H7725"\w* \w a|strong="H3068"\w* vuestro estado anterior.  
\v 56 \w No|strong="H3808"\w* \w era|strong="H1961"\w* \w Sodoma|strong="H5467"\w* tu hermana nombrada en tu \w boca|strong="H6310"\w* en el \w tiempo|strong="H3117"\w* de tus soberbias,  
\v 57 \w antes|strong="H2962"\w* \w que|strong="H6256"\w* tu \w maldad|strong="H7451"\w* fuese \w descubierta|strong="H1540"\w*. Así también ahora llevas tú \w el|strong="H3605"\w* \w oprobio|strong="H2781"\w* \w de|strong="H7451"\w* las \w hijas|strong="H1323"\w* \w de|strong="H7451"\w* Siria y \w de|strong="H7451"\w* \w todas|strong="H3605"\w* las \w que|strong="H6256"\w* \w la|strong="H3605"\w* \w rodean|strong="H5439"\w*, las \w hijas|strong="H1323"\w* \w de|strong="H7451"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w*, \w que|strong="H6256"\w* por \w todas|strong="H3605"\w* \w partes|strong="H5439"\w* te menosprecian.  
\v 58 Tú has \w llevado|strong="H5375"\w* tu lascivia y tus \w abominaciones|strong="H8441"\w*, \w dice|strong="H5002"\w* Yahvé.   
\p
\v 59 “‘\w Pero|strong="H3588"\w* \w así|strong="H3541"\w* dice \w el|strong="H3588"\w* Señor Yahvé: ¿\w Haré|strong="H6213"\w* \w yo|strong="H3588"\w* contigo \w como|strong="H3588"\w* \w tú|strong="H6213"\w* \w hiciste|strong="H6213"\w*, \w que|strong="H3588"\w* menospreciaste \w el|strong="H3588"\w* juramento \w para|strong="H3588"\w* invalidar \w el|strong="H3588"\w* \w pacto|strong="H1285"\w*?  
\v 60 Antes yo tendré \w memoria|strong="H2142"\w* de mi \w pacto|strong="H1285"\w* \w que|strong="H3117"\w* concerté contigo en los \w días|strong="H3117"\w* de tu \w juventud|strong="H5271"\w*, y \w estableceré|strong="H6965"\w* contigo un \w pacto|strong="H1285"\w* \w sempiterno|strong="H5769"\w*.  
\v 61 \w Y|strong="H3068"\w* \w te|strong="H4480"\w* acordarás \w de|strong="H4480"\w* tus \w caminos|strong="H1870"\w* y \w te|strong="H4480"\w* avergonzarás, cuando \w recibas|strong="H3947"\w* \w a|strong="H3068"\w* tus hermanas, las \w mayores|strong="H1419"\w* \w que|strong="H4480"\w* tú y las \w menores|strong="H6996"\w* \w que|strong="H4480"\w* tú, las cuales \w yo|strong="H4480"\w* \w te|strong="H4480"\w* \w daré|strong="H5414"\w* \w por|strong="H4480"\w* \w hijas|strong="H1323"\w*, \w mas|strong="H4480"\w* \w no|strong="H3808"\w* \w por|strong="H4480"\w* tu \w pacto|strong="H1285"\w*,  
\v 62 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w estableceré|strong="H6965"\w* mi \w pacto|strong="H1285"\w* contigo, \w y|strong="H3588"\w* \w sabrás|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé;  
\v 63 \w para|strong="H4616"\w* \w que|strong="H3808"\w* te acuerdes y te avergüences, y \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w abras|strong="H6610"\w* \w la|strong="H3605"\w* \w boca|strong="H6310"\w*, \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w tu|strong="H6213"\w* \w vergüenza|strong="H3639"\w*, \w cuando|strong="H1961"\w* \w yo|strong="H6213"\w* perdone \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w hiciste|strong="H6213"\w*, \w dice|strong="H5002"\w* \w el|strong="H3605"\w* Señor Yahvé’”.   
\c 17
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, propón un \w enigma|strong="H2420"\w* y relata una \w parábola|strong="H4912"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.  
\v 3 Dirás: \w Así|strong="H3541"\w* dice el Señor Yahvé: ‘Una \w gran|strong="H1419"\w* águila, de \w grandes|strong="H1419"\w* \w alas|strong="H3671"\w* \w y|strong="H3541"\w* largos miembros, \w llena|strong="H4392"\w* de \w plumas|strong="H5133"\w* de diversos colores, vino al \w Líbano|strong="H3844"\w* \w y|strong="H3541"\w* \w tomó|strong="H3947"\w* la copa del cedro.  
\v 4 \w Arrancó|strong="H6998"\w* el extremo de sus renuevos y lo llevó \w a|strong="H3068"\w* una tierra de comercio, y lo \w puso|strong="H7760"\w* en una \w ciudad|strong="H5892"\w* de mercaderes.   
\p
\v 5 “‘\w Tomó|strong="H3947"\w* también \w de|strong="H5921"\w* \w la|strong="H5921"\w* semilla \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w y|strong="H5921"\w* \w la|strong="H5921"\w* plantó \w en|strong="H5921"\w* un \w campo|strong="H7704"\w* fértil; \w la|strong="H5921"\w* colocó \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w aguas|strong="H4325"\w* abundantes \w y|strong="H5921"\w* \w la|strong="H5921"\w* plantó \w como|strong="H5921"\w* un sauce.  
\v 6 \w Y|strong="H3068"\w* \w brotó|strong="H6779"\w*, y \w se|strong="H1961"\w* convirtió \w en|strong="H8478"\w* una \w vid|strong="H1612"\w* \w de|strong="H8478"\w* mucha rama y \w baja|strong="H8217"\w* estatura, \w para|strong="H1961"\w* \w que|strong="H1961"\w* sus ramas \w se|strong="H1961"\w* volviesen \w hacia|strong="H6213"\w* \w el|strong="H6213"\w* águila y sus \w raíces|strong="H8328"\w* estuviesen \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* ella. Así \w se|strong="H1961"\w* convirtió \w en|strong="H8478"\w* una \w vid|strong="H1612"\w*, y \w echó|strong="H7971"\w* sarmientos y dio vástagos.   
\p
\v 7 “‘\w Había|strong="H1961"\w* también otra \w gran|strong="H1419"\w* águila, \w de|strong="H5921"\w* \w grandes|strong="H1419"\w* \w alas|strong="H3671"\w* \w y|strong="H5921"\w* \w mucho|strong="H7227"\w* plumaje; \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w esta|strong="H2063"\w* \w vid|strong="H1612"\w* \w juntó|strong="H5921"\w* sus \w raíces|strong="H8328"\w* \w hacia|strong="H5921"\w* \w ella|strong="H5921"\w*, \w y|strong="H5921"\w* \w extendió|strong="H7971"\w* \w hacia|strong="H5921"\w* \w ella|strong="H5921"\w* sus ramas \w desde|strong="H5921"\w* \w los|strong="H5921"\w* surcos \w de|strong="H5921"\w* su \w plantío|strong="H4302"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* regase.  
\v 8 En un \w buen|strong="H2896"\w* \w campo|strong="H7704"\w*, junto \w a|strong="H3068"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*, \w fue|strong="H1961"\w* \w plantada|strong="H8362"\w*, \w para|strong="H1961"\w* \w que|strong="H1931"\w* echase ramas y diese \w fruto|strong="H6529"\w*, y \w para|strong="H1961"\w* \w que|strong="H1931"\w* \w fuese|strong="H1961"\w* una \w vid|strong="H1612"\w* robusta’.   
\p
\v 9 “Di: \w Así|strong="H3541"\w* dice \w el|strong="H3605"\w* Señor Yahvé: ‘¿\w Prosperará|strong="H6743"\w*? ¿\w No|strong="H3808"\w* \w arrancará|strong="H5423"\w* \w el|strong="H3605"\w* águila sus \w raíces|strong="H8328"\w* \w y|strong="H3541"\w* cortará su \w fruto|strong="H6529"\w*, \w y|strong="H3541"\w* \w se|strong="H3808"\w* \w secará|strong="H3001"\w*? \w Todas|strong="H3605"\w* sus hojas lozanas \w se|strong="H3808"\w* secarán; \w y|strong="H3541"\w* \w no|strong="H3808"\w* \w será|strong="H3808"\w* necesario un \w gran|strong="H1419"\w* \w brazo|strong="H2220"\w* \w ni|strong="H3808"\w* \w mucha|strong="H7227"\w* \w gente|strong="H5971"\w* \w para|strong="H5971"\w* arrancarla \w de|strong="H5971"\w* raíz.  
\v 10 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w*, \w aunque|strong="H3808"\w* esté \w plantada|strong="H8362"\w*, ¿\w prosperará|strong="H6743"\w*? ¿\w No|strong="H3808"\w* \w se|strong="H5921"\w* \w secará|strong="H3001"\w* \w del|strong="H5921"\w* todo cuando \w el|strong="H5921"\w* \w viento|strong="H7307"\w* \w solano|strong="H6921"\w* \w la|strong="H5921"\w* toque? \w En|strong="H5921"\w* \w los|strong="H5921"\w* surcos \w de|strong="H5921"\w* su nacimiento \w se|strong="H5921"\w* \w secará|strong="H3001"\w*’”.   
\p
\v 11 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 12 “Di \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w*: ‘¿\w No|strong="H3808"\w* \w sabéis|strong="H3045"\w* \w qué|strong="H4100"\w* \w significan|strong="H3808"\w* estas \w cosas|strong="H3045"\w*?’. Decidles: ‘He \w aquí|strong="H2009"\w* \w que|strong="H4100"\w* el \w rey|strong="H4428"\w* \w de|strong="H8269"\w* Babilonia \w vino|strong="H4100"\w* \w a|strong="H3068"\w* Jerusalén, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* su \w rey|strong="H4428"\w* y \w a|strong="H3068"\w* sus \w príncipes|strong="H8269"\w* y los \w llevó|strong="H3947"\w* \w consigo|strong="H4805"\w* \w a|strong="H3068"\w* Babilonia.  
\v 13 \w Tomó|strong="H3947"\w* también \w a|strong="H3068"\w* uno de la \w simiente|strong="H2233"\w* \w real|strong="H4410"\w* \w e|strong="H3068"\w* \w hizo|strong="H3772"\w* \w pacto|strong="H1285"\w* con él, y le \w hizo|strong="H3772"\w* prestar juramento; y se \w llevó|strong="H3947"\w* \w a|strong="H3068"\w* los poderosos de la tierra,  
\v 14 \w para|strong="H1961"\w* \w que|strong="H1115"\w* el \w reino|strong="H4467"\w* \w fuese|strong="H1961"\w* \w abatido|strong="H8217"\w* y \w no|strong="H1961"\w* \w se|strong="H1961"\w* levantase, sino \w que|strong="H1115"\w* guardase su \w pacto|strong="H1285"\w* y \w se|strong="H1961"\w* mantuviese \w en|strong="H5975"\w* \w pie|strong="H5975"\w*.  
\v 15 Pero \w se|strong="H5971"\w* rebeló contra \w él|strong="H6213"\w* enviando \w embajadores|strong="H4397"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* \w para|strong="H5414"\w* \w que|strong="H5971"\w* le diesen \w caballos|strong="H5483"\w* y \w mucha|strong="H7227"\w* \w gente|strong="H5971"\w*. ¿\w Prosperará|strong="H6743"\w*? ¿\w Escapará|strong="H4422"\w* \w el|strong="H6213"\w* \w que|strong="H5971"\w* \w hace|strong="H6213"\w* tales \w cosas|strong="H7227"\w*? ¿Romperá \w el|strong="H6213"\w* \w pacto|strong="H1285"\w* y \w escapará|strong="H4422"\w*?   
\p
\v 16 “‘\w Vivo|strong="H2416"\w* yo, \w dice|strong="H5002"\w* el Señor Yahvé, \w que|strong="H3808"\w* \w morirá|strong="H4191"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de Babilonia, \w en|strong="H8432"\w* el \w lugar|strong="H4725"\w* \w donde|strong="H4725"\w* habita el \w rey|strong="H4428"\w* \w que|strong="H3808"\w* le hizo reinar, cuyo juramento menospreció y cuyo \w pacto|strong="H1285"\w* rompió.  
\v 17 \w Y|strong="H3068"\w* \w ni|strong="H3808"\w* con \w gran|strong="H1419"\w* \w ejército|strong="H2428"\w* \w ni|strong="H3808"\w* con \w mucha|strong="H7227"\w* \w compañía|strong="H6951"\w* le ayudará \w Faraón|strong="H6547"\w* en la \w batalla|strong="H4421"\w*, cuando levanten \w baluartes|strong="H1785"\w* y edifiquen torres para cortar \w muchas|strong="H7227"\w* \w vidas|strong="H5315"\w*.  
\v 18 \w Por|strong="H3027"\w* cuanto menospreció \w el|strong="H3605"\w* juramento quebrantando \w el|strong="H3605"\w* \w pacto|strong="H1285"\w*, y he \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w había|strong="H6213"\w* \w dado|strong="H5414"\w* su \w mano|strong="H3027"\w*, y \w ha|strong="H3808"\w* \w hecho|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H6213"\w* cosas, \w no|strong="H3808"\w* \w escapará|strong="H4422"\w*.   
\p
\v 19 “‘\w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice el Señor Yahvé: \w Vivo|strong="H2416"\w* yo, \w que|strong="H3808"\w* el juramento mío \w que|strong="H3808"\w* menospreció, \w y|strong="H3541"\w* mi \w pacto|strong="H1285"\w* \w que|strong="H3808"\w* \w ha|strong="H3541"\w* quebrantado, \w lo|strong="H3808"\w* \w haré|strong="H5414"\w* recaer sobre su propia \w cabeza|strong="H7218"\w*.  
\v 20 \w Extenderé|strong="H6566"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w mi|strong="H5921"\w* \w red|strong="H7568"\w*, \w y|strong="H5921"\w* será preso \w en|strong="H5921"\w* \w mi|strong="H5921"\w* lazo; \w y|strong="H5921"\w* \w lo|strong="H5921"\w* haré venir \w a|strong="H3068"\w* Babilonia, \w y|strong="H5921"\w* \w allí|strong="H8033"\w* entraré \w en|strong="H5921"\w* juicio \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w por|strong="H5921"\w* su \w prevaricación|strong="H4603"\w* \w con|strong="H5921"\w* \w que|strong="H5921"\w* \w prevaricó|strong="H4603"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*.  
\v 21 \w Y|strong="H3068"\w* \w todos|strong="H3605"\w* sus fugitivos, \w con|strong="H3588"\w* \w todas|strong="H3605"\w* sus tropas, \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w y|strong="H3588"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* queden serán esparcidos \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w vientos|strong="H7307"\w*; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, he \w hablado|strong="H1696"\w*.   
\p
\v 22 “‘\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: \w Tomaré|strong="H3947"\w* yo también \w del|strong="H5921"\w* cogollo \w de|strong="H5921"\w* aquel \w alto|strong="H1364"\w* cedro, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* plantaré; \w del|strong="H5921"\w* \w principal|strong="H7218"\w* \w de|strong="H5921"\w* sus renuevos \w cortaré|strong="H6998"\w* un tallo \w tierno|strong="H7390"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* plantaré \w sobre|strong="H5921"\w* un \w monte|strong="H2022"\w* \w alto|strong="H1364"\w* \w y|strong="H5921"\w* sublime.  
\v 23 \w En|strong="H8478"\w* \w el|strong="H3605"\w* \w monte|strong="H2022"\w* \w alto|strong="H4791"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w* \w lo|strong="H6213"\w* plantaré, y echará ramas, y dará \w fruto|strong="H6529"\w*, y \w se|strong="H1961"\w* \w hará|strong="H6213"\w* un cedro magnífico; y \w habitarán|strong="H7931"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w él|strong="H3605"\w* \w todas|strong="H3605"\w* las aves \w de|strong="H8478"\w* \w toda|strong="H3605"\w* \w especie|strong="H3671"\w*; \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w sombra|strong="H6738"\w* \w de|strong="H8478"\w* sus ramas \w habitarán|strong="H7931"\w*.  
\v 24 \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* del \w campo|strong="H7704"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, \w abatí|strong="H8217"\w* \w el|strong="H3588"\w* \w árbol|strong="H6086"\w* \w sublime|strong="H1361"\w*, \w levanté|strong="H1364"\w* \w el|strong="H3588"\w* \w árbol|strong="H6086"\w* \w bajo|strong="H8217"\w*, \w hice|strong="H6213"\w* secar \w el|strong="H3588"\w* \w árbol|strong="H6086"\w* \w verde|strong="H3892"\w*, \w e|strong="H3068"\w* \w hice|strong="H6213"\w* reverdecer \w el|strong="H3588"\w* \w árbol|strong="H6086"\w* \w seco|strong="H3001"\w*. \w Yo|strong="H3588"\w*, Yahvé, \w lo|strong="H6213"\w* he \w dicho|strong="H1696"\w*, \w y|strong="H3588"\w* \w lo|strong="H6213"\w* \w haré|strong="H6213"\w*’”.   
\c 18
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “¿\w Qué|strong="H4100"\w* queréis decir \w al|strong="H5921"\w* usar \w este|strong="H2088"\w* refrán \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H4100"\w* dice:  
\q1 ‘\w Los|strong="H1121"\w* padres comieron \w las|strong="H5921"\w* uvas agrias,  
\q2 \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w les|strong="H5921"\w* dio dentera’?   
\p
\v 3 “\w Vivo|strong="H2416"\w* yo —\w dice|strong="H5002"\w* el Señor Yahvé—, \w que|strong="H1961"\w* nunca \w más|strong="H5750"\w* \w tendréis|strong="H1961"\w* \w que|strong="H1961"\w* usar \w este|strong="H2088"\w* refrán \w en|strong="H5750"\w* \w Israel|strong="H3478"\w*.  
\v 4 He \w aquí|strong="H2005"\w* \w que|strong="H1931"\w* \w todas|strong="H3605"\w* las \w almas|strong="H5315"\w* son mías; \w como|strong="H1931"\w* \w el|strong="H1931"\w* \w alma|strong="H5315"\w* del padre, \w así|strong="H1931"\w* \w el|strong="H1931"\w* \w alma|strong="H5315"\w* del \w hijo|strong="H1121"\w* \w es|strong="H1931"\w* mía; \w el|strong="H1931"\w* \w alma|strong="H5315"\w* \w que|strong="H1931"\w* \w pecare|strong="H2398"\w*, \w esa|strong="H1931"\w* \w morirá|strong="H4191"\w*.   
\b  
\q1
\v 5 «\w Y|strong="H3068"\w* \w el|strong="H3588"\w* hombre \w que|strong="H3588"\w* \w fuere|strong="H1961"\w* \w justo|strong="H6662"\w*,  
\q2 \w e|strong="H3068"\w* \w hiciere|strong="H6213"\w* según \w el|strong="H3588"\w* \w derecho|strong="H4941"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w justicia|strong="H6666"\w*;   
\q1
\v 6 \w que|strong="H3808"\w* \w no|strong="H3808"\w* comiere sobre los \w montes|strong="H2022"\w*,  
\q2 \w ni|strong="H3808"\w* \w alzare|strong="H5375"\w* sus \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* los \w ídolos|strong="H1544"\w* \w de|strong="H5869"\w* la \w casa|strong="H1004"\w* \w de|strong="H5869"\w* \w Israel|strong="H3478"\w*,  
\q1 \w ni|strong="H3808"\w* profanare \w a|strong="H3068"\w* la mujer \w de|strong="H5869"\w* su \w prójimo|strong="H7453"\w*,  
\q2 \w ni|strong="H3808"\w* \w se|strong="H3808"\w* \w llegare|strong="H7126"\w* \w a|strong="H3068"\w* la mujer \w menstruosa|strong="H5079"\w*,   
\q1
\v 7 \w ni|strong="H3808"\w* \w oprimiere|strong="H3238"\w* \w a|strong="H3068"\w* \w ninguno|strong="H3808"\w*;  
\q2 \w que|strong="H3808"\w* al deudor devolviere su prenda,  
\q1 \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w cometiere|strong="H1497"\w* \w robo|strong="H1497"\w*,  
\q2 y \w que|strong="H3808"\w* \w diere|strong="H5414"\w* \w de|strong="H5414"\w* su \w pan|strong="H3899"\w* al hambriento,  
\q2 y cubriere al desnudo con vestido,   
\q1
\v 8 \w que|strong="H3808"\w* \w no|strong="H3808"\w* prestare \w a|strong="H3068"\w* interés  
\q2 \w ni|strong="H3808"\w* \w tomare|strong="H3947"\w* \w usura|strong="H5392"\w*;  
\q1 \w que|strong="H3808"\w* \w de|strong="H5414"\w* la \w maldad|strong="H5766"\w* \w retrajere|strong="H7725"\w* su \w mano|strong="H3027"\w*,  
\q2 \w e|strong="H3068"\w* \w hiciere|strong="H6213"\w* \w juicio|strong="H4941"\w* \w de|strong="H5414"\w* verdad \w entre|strong="H3808"\w* hombre y hombre,   
\q1
\v 9 en mis \w ordenanzas|strong="H4941"\w* \w caminare|strong="H1980"\w*,  
\q2 y \w guardare|strong="H8104"\w* mis decretos  
\q2 para \w hacer|strong="H6213"\w* rectamente,  
\q1 \w este|strong="H1931"\w* \w es|strong="H1931"\w* \w justo|strong="H6662"\w*;  
\q2 \w este|strong="H1931"\w* \w vivirá|strong="H2421"\w* \w ciertamente|strong="H2421"\w*», \w dice|strong="H5002"\w* \w el|strong="H1931"\w* Señor Yahvé.   
\b  
\p
\v 10 “Mas si \w engendrare|strong="H3205"\w* \w hijo|strong="H1121"\w* \w ladrón|strong="H6530"\w*, \w derramador|strong="H8210"\w* \w de|strong="H1121"\w* \w sangre|strong="H1818"\w*, \w o|strong="H3068"\w* \w que|strong="H1121"\w* \w haga|strong="H6213"\w* alguna cosa \w de|strong="H1121"\w* \w estas|strong="H6213"\w*,  
\v 11 \w y|strong="H1571"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w haga|strong="H6213"\w* las otras,  
\q1 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* comiere sobre \w los|strong="H3605"\w* \w montes|strong="H2022"\w*,  
\q2 \w o|strong="H3068"\w* profanare \w a|strong="H3068"\w* \w la|strong="H1931"\w* mujer \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w prójimo|strong="H7453"\w*,   
\q1
\v 12 \w oprimiere|strong="H3238"\w* al \w pobre|strong="H6041"\w* y menesteroso,  
\q2 \w cometiere|strong="H1497"\w* \w robos|strong="H1497"\w*,  
\q1 \w no|strong="H3808"\w* devolviere la prenda,  
\q2 \w o|strong="H3068"\w* \w alzare|strong="H5375"\w* sus \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* los \w ídolos|strong="H1544"\w*  
\q2 \w e|strong="H3068"\w* \w hiciere|strong="H6213"\w* \w abominación|strong="H8441"\w*,   
\q1
\v 13 prestare \w a|strong="H3068"\w* interés  
\q2 y \w tomare|strong="H3947"\w* \w usura|strong="H5392"\w*;  
\m ¿\w vivirá|strong="H2421"\w* \w este|strong="H1961"\w*? \w No|strong="H3808"\w* \w vivirá|strong="H2421"\w*. \w Todas|strong="H3605"\w* \w estas|strong="H6213"\w* \w abominaciones|strong="H8441"\w* \w hizo|strong="H6213"\w*; \w de|strong="H5414"\w* \w cierto|strong="H4191"\w* \w morirá|strong="H4191"\w*, su \w sangre|strong="H1818"\w* \w será|strong="H1961"\w* \w sobre|strong="H1961"\w* \w él|strong="H3605"\w*.   
\p
\v 14 “Pero \w si|strong="H3808"\w* este \w engendrare|strong="H3205"\w* \w hijo|strong="H1121"\w*, \w el|strong="H3605"\w* cual \w viere|strong="H7200"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* \w que|strong="H3808"\w* su padre \w hizo|strong="H6213"\w*, y viéndolos \w no|strong="H3808"\w* \w hiciere|strong="H6213"\w* según \w ellos|strong="H3605"\w*;   
\q1
\v 15 \w no|strong="H3808"\w* comiere \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*,  
\q2 \w ni|strong="H3808"\w* \w alzare|strong="H5375"\w* sus \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w ídolos|strong="H1544"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*;  
\q2 \w a|strong="H3068"\w* \w la|strong="H5921"\w* mujer \w de|strong="H5921"\w* su \w prójimo|strong="H7453"\w* \w no|strong="H3808"\w* profanare,   
\q1
\v 16 \w ni|strong="H3808"\w* \w oprimiere|strong="H3238"\w* \w a|strong="H3068"\w* \w nadie|strong="H3808"\w*,  
\q2 la prenda \w no|strong="H3808"\w* retuviere,  
\q1 \w ni|strong="H3808"\w* \w cometiere|strong="H1497"\w* \w robos|strong="H1497"\w*;  
\q2 al hambriento \w diere|strong="H5414"\w* \w de|strong="H5414"\w* su \w pan|strong="H3899"\w*,  
\q2 y cubriere \w de|strong="H5414"\w* vestido al desnudo;   
\q1
\v 17 \w apartare|strong="H7725"\w* \w su|strong="H1931"\w* \w mano|strong="H3027"\w* del \w pobre|strong="H6041"\w*,  
\q2 interés y \w usura|strong="H5392"\w* \w no|strong="H3808"\w* \w recibiere|strong="H3947"\w*;  
\q1 guardare mis decretos  
\q2 y anduviere en mis \w ordenanzas|strong="H4941"\w*;  
\m \w este|strong="H1931"\w* \w no|strong="H3808"\w* \w morirá|strong="H4191"\w* \w por|strong="H3027"\w* \w la|strong="H1931"\w* \w maldad|strong="H5771"\w* de \w su|strong="H1931"\w* padre; de \w cierto|strong="H4191"\w* \w vivirá|strong="H2421"\w*.  
\v 18 \w Su|strong="H3588"\w* padre, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w hizo|strong="H6213"\w* \w agravio|strong="H6231"\w*, \w despojó|strong="H1499"\w* \w violentamente|strong="H1497"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* hermano \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w es|strong="H3588"\w* \w bueno|strong="H2896"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* \w morirá|strong="H4191"\w* \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w maldad|strong="H5771"\w*.   
\p
\v 19 “\w Y|strong="H3068"\w* \w si|strong="H3808"\w* dijereis: ‘¿\w Por|strong="H4069"\w* \w qué|strong="H3808"\w* \w el|strong="H3605"\w* \w hijo|strong="H1121"\w* \w no|strong="H3808"\w* \w llevará|strong="H5375"\w* \w el|strong="H3605"\w* \w pecado|strong="H5771"\w* \w de|strong="H1121"\w* su padre?’. \w Porque|strong="H3808"\w* \w el|strong="H3605"\w* \w hijo|strong="H1121"\w* \w hizo|strong="H6213"\w* según \w el|strong="H3605"\w* \w derecho|strong="H4941"\w* y \w la|strong="H8104"\w* \w justicia|strong="H6666"\w*, \w guardó|strong="H8104"\w* \w todos|strong="H3605"\w* \w mis|strong="H5375"\w* \w estatutos|strong="H2708"\w* y \w los|strong="H1121"\w* cumplió, \w de|strong="H1121"\w* \w cierto|strong="H3808"\w* \w vivirá|strong="H2421"\w*.  
\v 20 \w El|strong="H1931"\w* \w alma|strong="H5315"\w* \w que|strong="H1931"\w* \w pecare|strong="H2398"\w*, \w esa|strong="H1931"\w* \w morirá|strong="H4191"\w*; \w el|strong="H1931"\w* \w hijo|strong="H1121"\w* \w no|strong="H3808"\w* \w llevará|strong="H5375"\w* \w el|strong="H1931"\w* \w pecado|strong="H5771"\w* \w del|strong="H5921"\w* padre, \w ni|strong="H3808"\w* \w el|strong="H1931"\w* padre \w llevará|strong="H5375"\w* \w el|strong="H1931"\w* \w pecado|strong="H5771"\w* \w del|strong="H5921"\w* \w hijo|strong="H1121"\w*; \w la|strong="H1931"\w* \w justicia|strong="H6666"\w* \w del|strong="H5921"\w* \w justo|strong="H6662"\w* \w será|strong="H1961"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w*, \w y|strong="H5921"\w* \w la|strong="H1931"\w* \w impiedad|strong="H7564"\w* \w del|strong="H5921"\w* \w impío|strong="H7563"\w* \w será|strong="H1961"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w*.   
\p
\v 21 “\w Mas|strong="H3588"\w* \w el|strong="H3588"\w* \w impío|strong="H7563"\w*, \w si|strong="H3588"\w* \w se|strong="H3808"\w* \w apartare|strong="H7725"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* sus \w pecados|strong="H2403"\w* \w que|strong="H3588"\w* \w hizo|strong="H6213"\w*, \w y|strong="H3588"\w* \w guardare|strong="H8104"\w* \w todos|strong="H3605"\w* mis \w estatutos|strong="H2708"\w* \w e|strong="H3068"\w* \w hiciere|strong="H6213"\w* según \w el|strong="H3588"\w* \w derecho|strong="H4941"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w justicia|strong="H6666"\w*, \w de|strong="H3588"\w* \w cierto|strong="H3588"\w* \w vivirá|strong="H2421"\w*; \w no|strong="H3808"\w* \w morirá|strong="H4191"\w*.  
\v 22 \w Todas|strong="H3605"\w* las transgresiones \w que|strong="H3808"\w* \w cometió|strong="H6213"\w*, \w no|strong="H3808"\w* le serán recordadas; en su \w justicia|strong="H6666"\w* \w que|strong="H3808"\w* \w hizo|strong="H6213"\w* \w vivirá|strong="H2421"\w*.  
\v 23 ¿\w Quiero|strong="H2654"\w* yo la \w muerte|strong="H4194"\w* del \w impío|strong="H7563"\w*? \w dice|strong="H5002"\w* el Señor Yahvé. ¿\w No|strong="H3808"\w* \w vivirá|strong="H2421"\w* \w si|strong="H3808"\w* \w se|strong="H3808"\w* \w apartare|strong="H7725"\w* de sus \w caminos|strong="H1870"\w*?   
\p
\v 24 “\w Mas|strong="H4191"\w* \w si|strong="H3808"\w* \w el|strong="H3605"\w* \w justo|strong="H6662"\w* \w se|strong="H3808"\w* \w apartare|strong="H7725"\w* \w de|strong="H6662"\w* su \w justicia|strong="H6666"\w* y \w cometiere|strong="H4604"\w* \w maldad|strong="H5766"\w*, \w e|strong="H3068"\w* \w hiciere|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w abominaciones|strong="H8441"\w* \w que|strong="H3808"\w* \w el|strong="H3605"\w* \w impío|strong="H7563"\w* \w hizo|strong="H6213"\w*, ¿\w vivirá|strong="H2425"\w* \w él|strong="H3605"\w*? \w Ninguna|strong="H3605"\w* \w de|strong="H6662"\w* las \w justicias|strong="H6666"\w* \w que|strong="H3808"\w* \w hizo|strong="H6213"\w* le \w serán|strong="H5766"\w* tenidas en cuenta; por su rebelión con \w que|strong="H3808"\w* \w prevaricó|strong="H4603"\w*, y por \w el|strong="H3605"\w* \w pecado|strong="H2403"\w* \w que|strong="H3808"\w* \w cometió|strong="H2398"\w*, por ello \w morirá|strong="H4191"\w*.   
\p
\v 25 “\w Y|strong="H3068"\w* \w si|strong="H3808"\w* dijereis: ‘\w No|strong="H3808"\w* es recto el \w camino|strong="H1870"\w* del Señor’. \w Oíd|strong="H8085"\w* \w ahora|strong="H4994"\w*, \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*: ¿\w No|strong="H3808"\w* es recto \w mi|strong="H4994"\w* \w camino|strong="H1870"\w*? ¿\w No|strong="H3808"\w* \w son|strong="H3808"\w* vuestros \w caminos|strong="H1870"\w* los \w que|strong="H3808"\w* \w son|strong="H3808"\w* \w torcidos|strong="H3808"\w*?  
\v 26 \w Apartándose|strong="H7725"\w* \w el|strong="H5921"\w* \w justo|strong="H6662"\w* \w de|strong="H5921"\w* su \w justicia|strong="H6666"\w*, \w y|strong="H5921"\w* \w haciendo|strong="H6213"\w* \w iniquidad|strong="H5766"\w*, \w él|strong="H5921"\w* \w morirá|strong="H4191"\w* \w por|strong="H5921"\w* ello; \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w iniquidad|strong="H5766"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w*, \w morirá|strong="H4191"\w*.  
\v 27 \w Y|strong="H3068"\w* \w apartándose|strong="H7725"\w* \w el|strong="H1931"\w* \w impío|strong="H7563"\w* de \w su|strong="H1931"\w* \w impiedad|strong="H7564"\w* \w que|strong="H1931"\w* \w hizo|strong="H6213"\w*, y \w haciendo|strong="H6213"\w* según \w el|strong="H1931"\w* \w derecho|strong="H4941"\w* y \w la|strong="H1931"\w* \w justicia|strong="H6666"\w*, \w hará|strong="H6213"\w* \w vivir|strong="H2421"\w* \w su|strong="H1931"\w* \w alma|strong="H5315"\w*.  
\v 28 \w Porque|strong="H3808"\w* \w miró|strong="H7200"\w* y \w se|strong="H3808"\w* apartó de \w todas|strong="H3605"\w* sus transgresiones \w que|strong="H3808"\w* \w había|strong="H6213"\w* cometido, de \w cierto|strong="H4191"\w* \w vivirá|strong="H2421"\w*; \w no|strong="H3808"\w* \w morirá|strong="H4191"\w*.  
\v 29 \w Si|strong="H3808"\w* \w aun|strong="H3808"\w* dijere la \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*: ‘\w No|strong="H3808"\w* es recto el \w camino|strong="H1870"\w* del Señor’; ¿\w no|strong="H3808"\w* \w son|strong="H3808"\w* rectos mis \w caminos|strong="H1870"\w*, \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*? Ciertamente, vuestros \w caminos|strong="H1870"\w* \w no|strong="H3808"\w* \w son|strong="H3808"\w* rectos.   
\p
\v 30 “\w Por|strong="H1870"\w* \w tanto|strong="H3651"\w*, yo os \w juzgaré|strong="H8199"\w* \w a|strong="H3068"\w* \w cada|strong="H3605"\w* uno según sus \w caminos|strong="H1870"\w*, oh \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*, \w dice|strong="H5002"\w* \w el|strong="H3605"\w* Señor Yahvé. \w Convertíos|strong="H7725"\w*, y apartaos de \w todas|strong="H3605"\w* vuestras transgresiones, y \w no|strong="H3808"\w* os \w será|strong="H1961"\w* \w la|strong="H3605"\w* \w iniquidad|strong="H5771"\w* causa de ruina.  
\v 31 \w Echad|strong="H7993"\w* \w de|strong="H5921"\w* vosotros \w todas|strong="H3605"\w* vuestras transgresiones \w con|strong="H5921"\w* \w que|strong="H4100"\w* habéis \w pecado|strong="H6588"\w*, \w y|strong="H5921"\w* haceos un \w corazón|strong="H3820"\w* \w nuevo|strong="H2319"\w* \w y|strong="H5921"\w* un \w espíritu|strong="H7307"\w* \w nuevo|strong="H2319"\w*. ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w moriréis|strong="H4191"\w*, \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?  
\v 32 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* \w quiero|strong="H2654"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* del \w que|strong="H3588"\w* muere, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé; ¡\w convertíos|strong="H7725"\w*, \w pues|strong="H3588"\w*, \w y|strong="H3588"\w* viviréis!   
\c 19
\p
\v 1 “\w Y|strong="H3068"\w* tú, \w levanta|strong="H5375"\w* una elegía por los \w príncipes|strong="H5387"\w* de \w Israel|strong="H3478"\w*,  
\v 2 y di:  
\q1 ‘¿\w Qué|strong="H4100"\w* fue tu madre?  
\q2 Una leona.  
\q1 \w Se|strong="H4100"\w* recostó \w entre|strong="H8432"\w* \w leones|strong="H3833"\w*,  
\q2 \w entre|strong="H8432"\w* los leoncillos \w crió|strong="H7235"\w* \w a|strong="H3068"\w* sus cachorros.   
\q1
\v 3 Crió \w a|strong="H3068"\w* uno de sus cachorros,  
\q2 \w que|strong="H1961"\w* \w se|strong="H1961"\w* convirtió en un león joven.  
\q1 \w Aprendió|strong="H3925"\w* \w a|strong="H3068"\w* arrebatar la presa;  
\q2 devoró hombres.   
\q1
\v 4 Las \w naciones|strong="H1471"\w* \w oyeron|strong="H8085"\w* hablar de él;  
\q2 fue apresado en el foso de ellas,  
\q2 y lo llevaron con garfios \w a|strong="H3068"\w* la tierra de \w Egipto|strong="H4714"\w*.   
\b  
\q1
\v 5 “‘\w Cuando|strong="H3588"\w* ella \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* esperado,  
\q2 \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w esperanza|strong="H8615"\w* se \w había|strong="H3588"\w* perdido,  
\q1 \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* otro \w de|strong="H3588"\w* sus cachorros,  
\q2 \w y|strong="H3588"\w* lo \w puso|strong="H7760"\w* \w por|strong="H3588"\w* león joven.   
\q1
\v 6 \w Y|strong="H3068"\w* él \w andaba|strong="H1980"\w* \w entre|strong="H8432"\w* \w los|strong="H1961"\w* leones;  
\q2 \w se|strong="H1961"\w* hizo un león joven.  
\q1 \w Aprendió|strong="H3925"\w* \w a|strong="H3068"\w* arrebatar la presa;  
\q2 devoró hombres.   
\q1
\v 7 \w Conoció|strong="H3045"\w* sus palacios  
\q2 y asoló sus \w ciudades|strong="H5892"\w*;  
\q1 la tierra y su plenitud quedaron desoladas  
\q2 por el \w estruendo|strong="H6963"\w* de sus rugidos.   
\q1
\v 8 Entonces \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w se|strong="H5921"\w* \w pusieron|strong="H5414"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w*  
\q2 \w desde|strong="H5439"\w* \w las|strong="H5921"\w* \w provincias|strong="H4082"\w* \w de|strong="H5921"\w* \w alrededor|strong="H5439"\w*;  
\q2 extendieron \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* su \w red|strong="H7568"\w*,  
\q2 \w y|strong="H5921"\w* fue apresado \w en|strong="H5921"\w* \w el|strong="H5921"\w* foso \w de|strong="H5921"\w* \w ellas|strong="H5921"\w*.   
\q1
\v 9 \w Lo|strong="H3808"\w* \w pusieron|strong="H5414"\w* \w en|strong="H5750"\w* una jaula con \w cadenas|strong="H2397"\w*  
\q2 y \w lo|strong="H3808"\w* llevaron ante el \w rey|strong="H4428"\w* \w de|strong="H5750"\w* Babilonia;  
\q1 \w lo|strong="H3808"\w* metieron \w en|strong="H5750"\w* las fortalezas,  
\q2 \w para|strong="H4616"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* oyese \w más|strong="H5750"\w* su \w voz|strong="H6963"\w* \w en|strong="H5750"\w* los \w montes|strong="H2022"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*.   
\b  
\q1
\v 10 “‘Tu madre \w fue|strong="H1961"\w* \w como|strong="H1961"\w* una \w vid|strong="H1612"\w* \w en|strong="H5921"\w* tu \w sangre|strong="H1818"\w*, \w plantada|strong="H8362"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*;  
\q2 \w era|strong="H1961"\w* fructífera \w y|strong="H5921"\w* frondosa \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*.   
\q1
\v 11 \w Tenía|strong="H1961"\w* \w varas|strong="H4294"\w* \w fuertes|strong="H5797"\w* \w para|strong="H5921"\w* \w cetros|strong="H7626"\w* \w de|strong="H5921"\w* gobernantes;  
\q2 \w y|strong="H5921"\w* \w se|strong="H1961"\w* elevó su estatura \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w del|strong="H5921"\w* espesaje \w de|strong="H5921"\w* \w las|strong="H5921"\w* ramas,  
