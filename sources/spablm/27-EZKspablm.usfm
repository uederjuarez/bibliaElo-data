\p
\v 20 \w Aconteció|strong="H1961"\w* en el \w año|strong="H8141"\w* undécimo, en el \w primer|strong="H7223"\w* \w mes|strong="H2320"\w*, \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w siete|strong="H7651"\w* días del \w mes|strong="H2320"\w*, \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 21 «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, he \w quebrantado|strong="H7665"\w* \w el|strong="H1121"\w* \w brazo|strong="H2220"\w* \w de|strong="H1121"\w* \w Faraón|strong="H6547"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*; y he \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* sido vendado \w para|strong="H5414"\w* aplicarle \w medicinas|strong="H7499"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* le \w ha|strong="H3808"\w* \w puesto|strong="H5414"\w* una \w faja|strong="H2848"\w* \w para|strong="H5414"\w* ligarlo \w a|strong="H3068"\w* fin \w de|strong="H1121"\w* \w que|strong="H3808"\w* recobre fuerza \w para|strong="H5414"\w* sostener la \w espada|strong="H2719"\w*.  
\v 22 \w Por|strong="H3027"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H5307"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H3541"\w* yo estoy contra \w Faraón|strong="H6547"\w* \w rey|strong="H4428"\w* de \w Egipto|strong="H4714"\w*, \w y|strong="H3541"\w* \w quebrantaré|strong="H7665"\w* sus \w brazos|strong="H2220"\w*, \w el|strong="H5307"\w* \w fuerte|strong="H2389"\w* \w y|strong="H3541"\w* \w el|strong="H5307"\w* \w que|strong="H3541"\w* ya estaba quebrado; \w y|strong="H3541"\w* haré \w que|strong="H3541"\w* la \w espada|strong="H2719"\w* \w caiga|strong="H5307"\w* de su \w mano|strong="H3027"\w*.  
\v 23 \w Esparciré|strong="H2219"\w* \w a|strong="H3068"\w* los \w egipcios|strong="H4714"\w* entre las \w naciones|strong="H1471"\w*, y los dispersaré por las tierras.  
\v 24 \w Y|strong="H3068"\w* fortaleceré los \w brazos|strong="H2220"\w* del \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Babilonia, y \w pondré|strong="H5414"\w* mi \w espada|strong="H2719"\w* en su \w mano|strong="H3027"\w*; mas \w quebrantaré|strong="H7665"\w* los \w brazos|strong="H2220"\w* \w de|strong="H6440"\w* \w Faraón|strong="H6547"\w*, y él gemirá \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él con los gemidos \w de|strong="H6440"\w* un herido \w de|strong="H6440"\w* muerte.  
\v 25 \w Yo|strong="H3588"\w*, \w pues|strong="H3588"\w*, sostendré \w los|strong="H3588"\w* \w brazos|strong="H2220"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia, \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w brazos|strong="H2220"\w* \w de|strong="H3588"\w* \w Faraón|strong="H6547"\w* \w caerán|strong="H5307"\w*; \w y|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w cuando|strong="H3588"\w* ponga mi \w espada|strong="H2719"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia, \w y|strong="H3588"\w* \w él|strong="H3588"\w* \w la|strong="H3588"\w* extienda sobre \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.  
\v 26 \w Y|strong="H3068"\w* \w esparciré|strong="H2219"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w egipcios|strong="H4714"\w* \w entre|strong="H3588"\w* las \w naciones|strong="H1471"\w*, \w y|strong="H3588"\w* \w los|strong="H3588"\w* dispersaré \w por|strong="H3588"\w* las tierras; \w y|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé».   
\c 31
\p
\v 1 \w Aconteció|strong="H1961"\w* en el \w año|strong="H8141"\w* undécimo, en el \w mes|strong="H2320"\w* \w tercero|strong="H7992"\w*, el día primero del \w mes|strong="H2320"\w*, \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, di \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, y \w a|strong="H3068"\w* su \w multitud|strong="H1995"\w*:  
\q1 ‘¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* te comparas en tu \w grandeza|strong="H1433"\w*?   
\q1
\v 3 He \w aquí|strong="H2009"\w* \w que|strong="H1961"\w* el asirio \w era|strong="H1961"\w* un cedro en el \w Líbano|strong="H3844"\w*,  
\q2 de \w hermosas|strong="H3303"\w* ramas,  
\q1 de follaje sombroso  
\q2 y de alta estatura;  
\q2 y su copa \w estaba|strong="H1961"\w* entre las ramas espesas.   
\q1
\v 4 Las \w aguas|strong="H4325"\w* \w lo|strong="H3605"\w* hicieron crecer,  
\q2 \w el|strong="H3605"\w* \w abismo|strong="H8415"\w* \w lo|strong="H3605"\w* encumbró;  
\q1 sus ríos corrían \w alrededor|strong="H5439"\w* \w de|strong="H4325"\w* su \w plantío|strong="H4302"\w*,  
\q2 y \w enviaba|strong="H7971"\w* sus corrientes \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* del \w campo|strong="H7704"\w*.   
\q1
\v 5 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w se|strong="H5921"\w* exaltó su estatura \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w*;  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w multiplicaron|strong="H7235"\w* sus ramas.  
\q1 Sus ramas \w se|strong="H5921"\w* extendieron \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*,  
\q2 cuando \w echó|strong="H7971"\w* sus renuevos.   
\q1
\v 6 \w Todas|strong="H3605"\w* las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w* hacían sus nidos \w en|strong="H8478"\w* sus ramas;  
\q2 \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* sus ramas \w parían|strong="H3205"\w* \w todas|strong="H3605"\w* las \w bestias|strong="H2416"\w* del \w campo|strong="H7704"\w*,  
\q2 y \w a|strong="H3068"\w* su \w sombra|strong="H6738"\w* \w habitaban|strong="H3427"\w* \w todas|strong="H3605"\w* las \w grandes|strong="H7227"\w* \w naciones|strong="H1471"\w*.   
\q1
\v 7 \w Era|strong="H1961"\w*, \w pues|strong="H3588"\w*, \w hermoso|strong="H3302"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w grandeza|strong="H1433"\w*,  
\q2 \w en|strong="H3588"\w* \w la|strong="H3588"\w* extensión \w de|strong="H3588"\w* sus ramas;  
\q2 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* raíz \w estaba|strong="H1961"\w* junto \w a|strong="H3068"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*.   
\q1
\v 8 \w Los|strong="H3605"\w* cedros en \w el|strong="H3605"\w* \w huerto|strong="H1588"\w* de Dios \w no|strong="H3808"\w* podían ocultarlo;  
\q2 \w los|strong="H3605"\w* cipreses \w no|strong="H3808"\w* \w se|strong="H1961"\w* igualaban \w a|strong="H3068"\w* sus ramas.  
\q1 \w Los|strong="H3605"\w* castaños \w no|strong="H3808"\w* \w eran|strong="H1961"\w* \w como|strong="H1961"\w* sus sarmientos;  
\q2 \w ningún|strong="H3605"\w* \w árbol|strong="H6086"\w* en \w el|strong="H3605"\w* \w huerto|strong="H1588"\w* de Dios \w era|strong="H1961"\w* semejante \w a|strong="H3068"\w* \w él|strong="H3605"\w* en su \w hermosura|strong="H3308"\w*.   
\q1
\v 9 \w Lo|strong="H6213"\w* \w hice|strong="H6213"\w* \w hermoso|strong="H3303"\w* \w con|strong="H7065"\w* \w la|strong="H3605"\w* \w multitud|strong="H7230"\w* de sus ramas,  
\q2 de modo \w que|strong="H3605"\w* \w lo|strong="H6213"\w* envidiaban \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* del Edén,  
\q2 \w que|strong="H3605"\w* estaban en \w el|strong="H3605"\w* \w huerto|strong="H1588"\w* de Dios’.   
\p
\v 10 “\w Por|strong="H3282"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice el Señor Yahvé: ‘\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w se|strong="H3651"\w* enalteció en su estatura, \w y|strong="H3541"\w* \w puso|strong="H5414"\w* su copa entre las ramas espesas, \w y|strong="H3541"\w* su \w corazón|strong="H3824"\w* \w se|strong="H3651"\w* enorgulleció \w por|strong="H3282"\w* su \w altura|strong="H1363"\w*,  
\v 11 \w yo|strong="H6213"\w* \w lo|strong="H6213"\w* \w entregaré|strong="H5414"\w* en \w manos|strong="H3027"\w* del poderoso \w de|strong="H5414"\w* las \w naciones|strong="H1471"\w*, \w el|strong="H6213"\w* cual \w ciertamente|strong="H5414"\w* \w lo|strong="H6213"\w* tratará según su maldad; \w yo|strong="H6213"\w* \w lo|strong="H6213"\w* he desechado.  
\v 12 \w Y|strong="H3068"\w* extranjeros, \w los|strong="H3605"\w* \w más|strong="H1471"\w* temibles \w de|strong="H5971"\w* las \w naciones|strong="H1471"\w*, \w lo|strong="H3605"\w* \w cortaron|strong="H3772"\w* y \w lo|strong="H3605"\w* abandonaron; sus ramas \w cayeron|strong="H5307"\w* sobre \w los|strong="H3605"\w* \w montes|strong="H2022"\w* y por \w todos|strong="H3605"\w* \w los|strong="H3605"\w* valles, y su ramaje fue quebrado por \w todos|strong="H3605"\w* \w los|strong="H3605"\w* arroyos \w de|strong="H5971"\w* \w la|strong="H3605"\w* tierra. \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* tierra \w se|strong="H5971"\w* retiraron \w de|strong="H5971"\w* su \w sombra|strong="H6738"\w* y \w lo|strong="H3605"\w* abandonaron.  
\v 13 \w Sobre|strong="H5921"\w* su ruina \w habitarán|strong="H7931"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* sus ramas \w estarán|strong="H1961"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w bestias|strong="H2416"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w*,  
\v 14 \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w ningún|strong="H3605"\w* \w árbol|strong="H6086"\w* junto \w a|strong="H3068"\w* las \w aguas|strong="H4325"\w* \w se|strong="H3808"\w* exalte \w en|strong="H8432"\w* \w su|strong="H3588"\w* estatura, \w ni|strong="H3808"\w* levante \w su|strong="H3588"\w* copa \w entre|strong="H8432"\w* las ramas espesas. \w Que|strong="H3588"\w* sus poderosos \w no|strong="H3808"\w* \w se|strong="H3808"\w* enaltezcan \w en|strong="H8432"\w* \w su|strong="H3588"\w* \w altura|strong="H6967"\w*, \w ni|strong="H3808"\w* \w ninguno|strong="H3808"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* \w beben|strong="H8354"\w* \w agua|strong="H4325"\w*; \w porque|strong="H3588"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* están destinados \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w*, \w a|strong="H3068"\w* las partes \w más|strong="H3588"\w* bajas \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*, \w con|strong="H3588"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* \w descienden|strong="H3381"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* fosa’.   
\p
\v 15 “\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: ‘\w El|strong="H5921"\w* \w día|strong="H3117"\w* \w que|strong="H5921"\w* \w descendió|strong="H3381"\w* \w al|strong="H5921"\w* Seol,\f + \fr 31:15 \ft El Seol es el lugar de los muertos.\f* hice hacer luto; \w cubrí|strong="H3680"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w* \w el|strong="H5921"\w* \w abismo|strong="H8415"\w*, \w detuve|strong="H4513"\w* sus ríos, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w* fueron retenidas. Hice \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w Líbano|strong="H3844"\w* \w se|strong="H5921"\w* vistiera \w de|strong="H5921"\w* luto \w por|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w se|strong="H5921"\w* desmayaron \w por|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 16 \w Del|strong="H8354"\w* \w estruendo|strong="H6963"\w* \w de|strong="H4325"\w* su caída hice \w temblar|strong="H7493"\w* \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*, cuando \w lo|strong="H3605"\w* hice descender al Seol\f + \fr 31:16 \ft El Seol es el lugar de los muertos.\f* con \w los|strong="H3605"\w* \w que|strong="H4325"\w* \w descienden|strong="H3381"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* fosa. \w Y|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* \w del|strong="H8354"\w* Edén, \w los|strong="H3605"\w* \w más|strong="H1471"\w* \w escogidos|strong="H4005"\w* y \w los|strong="H3605"\w* \w mejores|strong="H2896"\w* \w del|strong="H8354"\w* \w Líbano|strong="H3844"\w*, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H4325"\w* \w beben|strong="H8354"\w* \w agua|strong="H4325"\w*, fueron consolados en las partes \w más|strong="H1471"\w* bajas \w de|strong="H4325"\w* \w la|strong="H3605"\w* tierra.  
\v 17 \w También|strong="H1571"\w* \w ellos|strong="H1992"\w* \w descendieron|strong="H3381"\w* \w con|strong="H1571"\w* \w él|strong="H3427"\w* al Seol, \w con|strong="H1571"\w* \w los|strong="H1992"\w* \w muertos|strong="H2491"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*; \w sí|strong="H1571"\w*, \w los|strong="H1992"\w* \w que|strong="H1571"\w* fueron \w su|strong="H1992"\w* \w brazo|strong="H2220"\w*, \w los|strong="H1992"\w* \w que|strong="H1571"\w* \w habitaron|strong="H3427"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w sombra|strong="H6738"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w las|strong="H1992"\w* \w naciones|strong="H1471"\w*.   
\p
\v 18 “‘¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w*, \w pues|strong="H3381"\w*, te comparas \w en|strong="H8432"\w* \w gloria|strong="H3519"\w* \w y|strong="H3519"\w* \w en|strong="H8432"\w* \w grandeza|strong="H3519"\w* \w entre|strong="H8432"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* del Edén? Sin embargo, serás derribado con \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* del Edén \w a|strong="H3068"\w* las partes \w más|strong="H3519"\w* bajas de \w la|strong="H1931"\w* tierra; \w yacerás|strong="H7901"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w los|strong="H3605"\w* \w incircuncisos|strong="H6189"\w*, con \w los|strong="H3605"\w* \w muertos|strong="H2491"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.  
\p “‘\w Este|strong="H1931"\w* \w es|strong="H1931"\w* \w Faraón|strong="H6547"\w* \w y|strong="H3519"\w* \w toda|strong="H3605"\w* \w su|strong="H1931"\w* \w multitud|strong="H1995"\w*’, \w dice|strong="H5002"\w* \w el|strong="H1931"\w* Señor Yahvé”.   
\c 32
\p
\v 1 \w Aconteció|strong="H1961"\w* en el \w año|strong="H8141"\w* \w duodécimo|strong="H8147"\w*, en el \w mes|strong="H2320"\w* \w duodécimo|strong="H8147"\w*, el día primero del \w mes|strong="H2320"\w*, \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w levanta|strong="H5375"\w* una \w endecha|strong="H7015"\w* \w sobre|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H5921"\w* dile:  
\q1 “\w A|strong="H3068"\w* un \w leoncillo|strong="H3715"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* eras semejante;  
\q2 pero eres \w como|strong="H5921"\w* un monstruo \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w mares|strong="H3220"\w*.  
\q1 Prorrumpías \w en|strong="H5921"\w* tus ríos,  
\q2 turbabas \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w con|strong="H5921"\w* tus \w pies|strong="H7272"\w*  
\q2 \w y|strong="H5921"\w* ensuciabas sus corrientes.   
\q1
