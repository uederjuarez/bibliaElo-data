\v 5 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* \w a|strong="H3068"\w* Rabá \w por|strong="H3588"\w* majada \w de|strong="H3588"\w* \w camellos|strong="H1581"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Amón \w por|strong="H3588"\w* sesteadero \w de|strong="H3588"\w* rebaños; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé’.  
\v 6 \w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice \w el|strong="H3588"\w* Señor Yahvé: ‘\w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* batisteis las \w manos|strong="H3027"\w* \w y|strong="H3588"\w* golpeasteis \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w pie|strong="H7272"\w*, \w y|strong="H3588"\w* os alegrasteis \w con|strong="H3588"\w* \w todo|strong="H3605"\w* vuestro menosprecio \w contra|strong="H3478"\w* \w la|strong="H3605"\w* tierra \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*,  
