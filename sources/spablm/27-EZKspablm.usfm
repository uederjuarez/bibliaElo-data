\v 37 «\w Así|strong="H3541"\w* dice \w el|strong="H6213"\w* Señor Yahvé: \w Aún|strong="H5750"\w* seré \w consultado|strong="H1875"\w* \w por|strong="H5750"\w* \w la|strong="H2063"\w* \w casa|strong="H1004"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*, para \w hacerles|strong="H6213"\w* \w esto|strong="H2063"\w*: \w multiplicaré|strong="H7235"\w* sus hombres \w como|strong="H5750"\w* rebaños \w de|strong="H5750"\w* \w ovejas|strong="H6629"\w*.  
\v 38 \w Como|strong="H3588"\w* las \w ovejas|strong="H6629"\w* consagradas, \w como|strong="H3588"\w* las \w ovejas|strong="H6629"\w* \w de|strong="H3588"\w* Jerusalén \w en|strong="H3588"\w* sus fiestas solemnes, \w así|strong="H3651"\w* las \w ciudades|strong="H5892"\w* \w desiertas|strong="H2720"\w* \w se|strong="H3045"\w* llenarán \w de|strong="H3588"\w* rebaños \w de|strong="H3588"\w* hombres; \w y|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé».   
\c 37
\p
\v 1 \w La|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* Yahvé \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* \w me|strong="H5921"\w* llevó \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w me|strong="H5921"\w* puso \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* un valle \w que|strong="H1931"\w* \w estaba|strong="H1961"\w* \w lleno|strong="H4392"\w* \w de|strong="H5921"\w* \w huesos|strong="H6106"\w*.  
\v 2 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* hizo \w pasar|strong="H5674"\w* \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w por|strong="H5921"\w* \w todo|strong="H5439"\w* \w en|strong="H5921"\w* \w derredor|strong="H5439"\w*; \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* eran muchísimos \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w del|strong="H5921"\w* \w campo|strong="H1237"\w*, \w y|strong="H5921"\w* \w por|strong="H5921"\w* cierto \w secos|strong="H3002"\w* \w en|strong="H5921"\w* \w gran|strong="H3966"\w* \w manera|strong="H3966"\w*.  
\v 3 \w Y|strong="H3068"\w* me dijo: «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, ¿\w vivirán|strong="H2421"\w* estos \w huesos|strong="H6106"\w*?».  
\p \w Y|strong="H3068"\w* respondí: «Señor Yahvé, tú lo \w sabes|strong="H3045"\w*».   
\p
\v 4 \w Me|strong="H5921"\w* dijo entonces: “\w Profetiza|strong="H5012"\w* \w sobre|strong="H5921"\w* estos \w huesos|strong="H6106"\w*, \w y|strong="H5921"\w* \w diles|strong="H1697"\w*: ‘\w Huesos|strong="H6106"\w* \w secos|strong="H3002"\w*, \w oíd|strong="H8085"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé.  
\v 5 \w Así|strong="H3541"\w* dice el Señor Yahvé \w a|strong="H3068"\w* estos \w huesos|strong="H6106"\w*: He \w aquí|strong="H2009"\w*, \w yo|strong="H2009"\w* hago entrar \w espíritu|strong="H7307"\w* en vosotros, \w y|strong="H3541"\w* viviréis.  
\v 6 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* tendones \w sobre|strong="H5921"\w* vosotros, \w y|strong="H3588"\w* \w haré|strong="H5414"\w* \w subir|strong="H5927"\w* \w carne|strong="H1320"\w* \w sobre|strong="H5921"\w* vosotros, \w y|strong="H3588"\w* \w os|strong="H5921"\w* \w cubriré|strong="H7159"\w* \w de|strong="H5921"\w* \w piel|strong="H5785"\w*, \w y|strong="H3588"\w* \w pondré|strong="H5414"\w* \w en|strong="H5921"\w* vosotros \w espíritu|strong="H7307"\w*, \w y|strong="H3588"\w* viviréis; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé’”.   
\p
\v 7 \w Profeticé|strong="H5012"\w*, \w pues|strong="H1961"\w*, \w como|strong="H1961"\w* me \w fue|strong="H1961"\w* \w mandado|strong="H6680"\w*; y \w hubo|strong="H1961"\w* un \w ruido|strong="H6963"\w* mientras \w yo|strong="H2009"\w* profetizaba, y he \w aquí|strong="H2009"\w* un \w temblor|strong="H7494"\w*; y \w los|strong="H1961"\w* \w huesos|strong="H6106"\w* \w se|strong="H1961"\w* juntaron, cada \w hueso|strong="H6106"\w* con su \w hueso|strong="H6106"\w*.  
\v 8 \w Y|strong="H3068"\w* \w miré|strong="H7200"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* tendones \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w carne|strong="H1320"\w* \w subió|strong="H5927"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w piel|strong="H5785"\w* \w cubrió|strong="H7159"\w* \w por|strong="H5921"\w* \w encima|strong="H4605"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*; pero \w no|strong="H5921"\w* había \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* \w espíritu|strong="H7307"\w*.   
\p
\v 9 \w Y|strong="H3068"\w* \w me|strong="H3541"\w* dijo: “\w Profetiza|strong="H5012"\w* al \w espíritu|strong="H7307"\w*, \w profetiza|strong="H5012"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w y|strong="H3541"\w* di al \w espíritu|strong="H7307"\w*: ‘\w Así|strong="H3541"\w* dice \w el|strong="H1121"\w* Señor Yahvé: \w Espíritu|strong="H7307"\w*, ven \w de|strong="H1121"\w* \w los|strong="H1121"\w* cuatro \w vientos|strong="H7307"\w*, \w y|strong="H3541"\w* sopla sobre estos muertos, \w y|strong="H3541"\w* \w vivirán|strong="H2421"\w*’”.   
\p
\v 10 \w Y|strong="H3068"\w* \w profeticé|strong="H5012"\w* \w como|strong="H5921"\w* \w me|strong="H5921"\w* \w había|strong="H5975"\w* \w mandado|strong="H6680"\w*, \w y|strong="H5921"\w* entró \w espíritu|strong="H7307"\w* \w en|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* vivieron, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w pusieron|strong="H5975"\w* \w sobre|strong="H5921"\w* sus \w pies|strong="H7272"\w*; un \w ejército|strong="H2428"\w* \w grande|strong="H1419"\w* \w en|strong="H5921"\w* extremo.   
\p
\v 11 Me dijo luego: “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w todos|strong="H3605"\w* \w estos|strong="H1992"\w* \w huesos|strong="H6106"\w* son \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. He \w aquí|strong="H2009"\w*, \w ellos|strong="H1992"\w* dicen: ‘Nuestros \w huesos|strong="H6106"\w* \w se|strong="H1992"\w* secaron, y pereció nuestra \w esperanza|strong="H8615"\w*, y somos del \w todo|strong="H3605"\w* destruidos’.  
\v 12 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w profetiza|strong="H5012"\w*, \w y|strong="H3541"\w* diles: ‘\w Así|strong="H3541"\w* dice el Señor Yahvé: He \w aquí|strong="H2009"\w* \w yo|strong="H2009"\w* \w abro|strong="H6605"\w* vuestros \w sepulcros|strong="H6913"\w*, \w pueblo|strong="H5971"\w* \w mío|strong="H5971"\w*, \w y|strong="H3541"\w* os haré \w subir|strong="H5927"\w* \w de|strong="H5971"\w* vuestras sepulturas, \w y|strong="H3541"\w* os traeré \w a|strong="H3068"\w* la tierra \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*.  
\v 13 \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w cuando|strong="H3588"\w* abra vuestros \w sepulcros|strong="H6913"\w*, \w y|strong="H3588"\w* os \w saque|strong="H5927"\w* \w de|strong="H3588"\w* vuestras sepulturas, \w pueblo|strong="H5971"\w* \w mío|strong="H5971"\w*.  
\v 14 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* \w mi|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w en|strong="H5921"\w* vosotros, \w y|strong="H3588"\w* viviréis, \w y|strong="H3588"\w* \w os|strong="H5921"\w* \w haré|strong="H6213"\w* reposar \w sobre|strong="H5921"\w* vuestra tierra; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, \w hablé|strong="H1696"\w* \w y|strong="H3588"\w* \w lo|strong="H5921"\w* \w hice|strong="H6213"\w*, \w dice|strong="H5002"\w* Yahvé’”.   
\b  
\p
\v 15 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 16 “Tú, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w toma|strong="H3947"\w* ahora una vara, \w y|strong="H5921"\w* \w escribe|strong="H3789"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w*: ‘\w Para|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w para|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* sus compañeros’. \w Toma|strong="H3947"\w* \w después|strong="H5921"\w* otra vara, \w y|strong="H5921"\w* \w escribe|strong="H3789"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w*: ‘\w Para|strong="H5921"\w* \w José|strong="H3130"\w*, vara \w de|strong="H5921"\w* Efraín, \w y|strong="H5921"\w* \w para|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* sus compañeros’.  
\v 17 Júntalas luego la una con la otra, \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w sean|strong="H1961"\w* una sola, y \w serán|strong="H1961"\w* uno en tu \w mano|strong="H3027"\w*.   
\p
\v 18 “\w Y|strong="H3068"\w* \w cuando|strong="H4100"\w* te pregunten \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* tu \w pueblo|strong="H5971"\w*, diciendo: ‘¿\w No|strong="H3808"\w* \w nos|strong="H4100"\w* enseñarás \w qué|strong="H4100"\w* te propones con eso?’,  
\v 19 \w diles|strong="H1696"\w*: ‘\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H5921"\w* Señor Yahvé: He \w aquí|strong="H2009"\w*, \w yo|strong="H2009"\w* \w tomo|strong="H3947"\w* \w la|strong="H5921"\w* \w vara|strong="H7626"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w* \w que|strong="H5921"\w* \w está|strong="H1961"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* Efraín, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w tribus|strong="H7626"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* sus compañeros, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w pondré|strong="H5414"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w vara|strong="H7626"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w haré|strong="H6213"\w* una sola \w vara|strong="H7626"\w*, \w y|strong="H5921"\w* \w serán|strong="H1961"\w* uno \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*’.  
\v 20 \w Y|strong="H3068"\w* \w las|strong="H5921"\w* varas \w sobre|strong="H5921"\w* \w que|strong="H5921"\w* escribas \w estarán|strong="H1961"\w* \w en|strong="H5921"\w* tu \w mano|strong="H3027"\w* \w delante|strong="H5869"\w* \w de|strong="H5921"\w* sus \w ojos|strong="H5869"\w*.  
\v 21 \w Y|strong="H3068"\w* les \w dirás|strong="H1696"\w*: ‘\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H1121"\w* Señor Yahvé: He \w aquí|strong="H2009"\w*, \w yo|strong="H2009"\w* \w tomo|strong="H3947"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w de|strong="H1121"\w* \w entre|strong="H8033"\w* las \w naciones|strong="H1471"\w* \w a|strong="H3068"\w* las cuales \w fueron|strong="H1980"\w*, \w y|strong="H3541"\w* \w los|strong="H1121"\w* \w recogeré|strong="H6908"\w* \w de|strong="H1121"\w* \w todas|strong="H5439"\w* \w partes|strong="H5439"\w*, \w y|strong="H3541"\w* \w los|strong="H1121"\w* traeré \w a|strong="H3068"\w* su tierra.  
\v 22 \w Y|strong="H3068"\w* \w los|strong="H3605"\w* \w haré|strong="H6213"\w* una \w nación|strong="H1471"\w* \w en|strong="H5750"\w* \w la|strong="H3605"\w* tierra, \w en|strong="H5750"\w* \w los|strong="H3605"\w* \w montes|strong="H2022"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*, y un \w rey|strong="H4428"\w* \w será|strong="H1961"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w por|strong="H5750"\w* \w rey|strong="H4428"\w*; y \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w serán|strong="H1961"\w* \w dos|strong="H8147"\w* \w naciones|strong="H1471"\w*, \w ni|strong="H3808"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w serán|strong="H1961"\w* divididos \w en|strong="H5750"\w* \w dos|strong="H8147"\w* \w reinos|strong="H4467"\w*.  
\v 23 \w Ni|strong="H3808"\w* \w se|strong="H1961"\w* contaminarán ya \w más|strong="H5750"\w* con sus \w ídolos|strong="H1544"\w*, con sus \w abominaciones|strong="H8251"\w* y con \w todas|strong="H3605"\w* sus \w rebeliones|strong="H6588"\w*; y \w los|strong="H3605"\w* \w salvaré|strong="H3467"\w* \w de|strong="H5750"\w* \w todas|strong="H3605"\w* sus moradas \w en|strong="H5750"\w* las cuales \w pecaron|strong="H2398"\w*, y \w los|strong="H3605"\w* limpiaré; y me \w serán|strong="H1961"\w* \w por|strong="H5750"\w* \w pueblo|strong="H5971"\w*, y yo \w a|strong="H3068"\w* \w ellos|strong="H3605"\w* \w por|strong="H5750"\w* Dios.   
\p
\v 24 “‘\w Mi|strong="H5921"\w* \w siervo|strong="H5650"\w* \w David|strong="H1732"\w* \w será|strong="H1961"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w ellos|strong="H5921"\w* \w tendrán|strong="H1961"\w* un solo \w pastor|strong="H7462"\w*; \w y|strong="H5921"\w* \w andarán|strong="H3212"\w* \w en|strong="H5921"\w* mis preceptos, \w y|strong="H5921"\w* mis \w estatutos|strong="H2708"\w* \w guardarán|strong="H8104"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* pondrán \w por|strong="H5921"\w* \w obra|strong="H6213"\w*.  
\v 25 \w Habitarán|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* \w di|strong="H5414"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* \w Jacob|strong="H3290"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* cual \w habitaron|strong="H3427"\w* vuestros padres; \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w habitarán|strong="H3427"\w* \w ellos|strong="H1992"\w*, \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*; \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* \w David|strong="H1732"\w* \w será|strong="H5414"\w* \w príncipe|strong="H5387"\w* \w de|strong="H5921"\w* \w ellos|strong="H1992"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.  
\v 26 \w Y|strong="H3068"\w* \w haré|strong="H5414"\w* con ellos \w pacto|strong="H1285"\w* \w de|strong="H5414"\w* \w paz|strong="H7965"\w*, \w pacto|strong="H1285"\w* \w perpetuo|strong="H5769"\w* \w será|strong="H1961"\w* con ellos; y \w los|strong="H1961"\w* estableceré y \w los|strong="H1961"\w* \w multiplicaré|strong="H7235"\w*, y \w pondré|strong="H5414"\w* \w mi|strong="H1961"\w* \w santuario|strong="H4720"\w* \w entre|strong="H8432"\w* ellos \w para|strong="H5414"\w* \w siempre|strong="H5769"\w*.  
\v 27 \w Estará|strong="H1961"\w* \w en|strong="H5921"\w* medio \w de|strong="H5921"\w* \w ellos|strong="H1992"\w* \w mi|strong="H5921"\w* \w tabernáculo|strong="H4908"\w*, \w y|strong="H5921"\w* \w seré|strong="H1961"\w* \w a|strong="H3068"\w* \w ellos|strong="H1992"\w* \w por|strong="H5921"\w* Dios, \w y|strong="H5921"\w* \w ellos|strong="H1992"\w* \w me|strong="H5921"\w* \w serán|strong="H1961"\w* \w por|strong="H5921"\w* \w pueblo|strong="H5971"\w*.  
\v 28 \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* las \w naciones|strong="H1471"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* Yahvé \w santifico|strong="H6942"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w estando|strong="H1961"\w* \w mi|strong="H1961"\w* \w santuario|strong="H4720"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* ellos \w para|strong="H3588"\w* \w siempre|strong="H5769"\w*’”.   
\c 38
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w pon|strong="H7760"\w* tu \w rostro|strong="H6440"\w* \w hacia|strong="H5921"\w* \w Gog|strong="H1463"\w*, \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Magog|strong="H4031"\w*, \w príncipe|strong="H5387"\w* soberano \w de|strong="H5921"\w* Rosh, \w Mesec|strong="H4902"\w* \w y|strong="H5921"\w* \w Tubal|strong="H8422"\w*, \w y|strong="H5921"\w* \w profetiza|strong="H5012"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w*,  
\v 3 \w y|strong="H3541"\w* di: ‘\w Así|strong="H3541"\w* dice el Señor Yahvé: He \w aquí|strong="H3541"\w*, yo estoy contra ti, oh \w Gog|strong="H1463"\w*, \w príncipe|strong="H5387"\w* soberano de Rosh, \w Mesec|strong="H4902"\w* \w y|strong="H3541"\w* \w Tubal|strong="H8422"\w*.  
\v 4 Te \w haré|strong="H5414"\w* \w dar|strong="H5414"\w* \w la|strong="H3605"\w* vuelta, \w pondré|strong="H5414"\w* garfios \w en|strong="H3318"\w* tus quijadas, y te sacaré \w a|strong="H3068"\w* ti y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* tu \w ejército|strong="H2428"\w*, \w caballos|strong="H5483"\w* y \w jinetes|strong="H6571"\w*, \w todos|strong="H3605"\w* \w vestidos|strong="H3847"\w* con armadura completa, una \w gran|strong="H7227"\w* \w multitud|strong="H6951"\w* con \w paveses|strong="H6793"\w* y \w escudos|strong="H4043"\w*, \w teniendo|strong="H8610"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w espadas|strong="H2719"\w*;  
\v 5 \w Persia|strong="H6539"\w*, Cus y Fut con \w ellos|strong="H3605"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* con \w escudo|strong="H4043"\w* y yelmo;  
\v 6 \w Gómer|strong="H1586"\w* y \w todas|strong="H3605"\w* sus tropas; \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Togarmá \w de|strong="H5971"\w* \w los|strong="H3605"\w* confines del \w norte|strong="H6828"\w*, y \w todas|strong="H3605"\w* sus tropas; \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* \w contigo|strong="H5971"\w*.   
\p
\v 7 “‘Prepárate \w y|strong="H5921"\w* apercíbete, tú \w y|strong="H5921"\w* \w toda|strong="H3605"\w* tu \w multitud|strong="H6951"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* ha reunido \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w sé|strong="H1961"\w* tú su \w guarda|strong="H4929"\w*.  
\v 8 \w De|strong="H5921"\w* aquí \w a|strong="H3068"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w* \w serás|strong="H1961"\w* visitado; \w al|strong="H5921"\w* cabo \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w años|strong="H8141"\w* vendrás \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w salvada|strong="H7725"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w espada|strong="H2719"\w*, \w recogida|strong="H6908"\w* \w de|strong="H5921"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*, \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w montes|strong="H2022"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H1931"\w* \w siempre|strong="H8548"\w* \w fueron|strong="H1961"\w* una desolación; \w mas|strong="H5921"\w* \w fue|strong="H1961"\w* sacada \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w los|strong="H3427"\w* \w pueblos|strong="H5971"\w*, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w ellos|strong="H1931"\w* \w habitarán|strong="H3427"\w* confiadamente.  
\v 9 \w Subirás|strong="H5927"\w* tú, y vendrás \w como|strong="H1961"\w* tempestad; \w como|strong="H1961"\w* \w nublado|strong="H6051"\w* \w para|strong="H1961"\w* \w cubrir|strong="H3680"\w* \w la|strong="H3605"\w* tierra \w serás|strong="H1961"\w* tú y \w todas|strong="H3605"\w* tus tropas, y \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* \w contigo|strong="H5971"\w*.   
\p
\v 10 “‘\w Así|strong="H3541"\w* \w dice|strong="H1697"\w* \w el|strong="H1931"\w* Señor Yahvé: \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w subirán|strong="H5927"\w* \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* tu \w corazón|strong="H3824"\w*, \w y|strong="H5921"\w* concebirás un \w mal|strong="H7451"\w* \w pensamiento|strong="H4284"\w*,  
\v 11 \w y|strong="H5921"\w* dirás: \w Subiré|strong="H5927"\w* \w contra|strong="H5921"\w* una tierra indefensa, \w iré|strong="H5927"\w* \w contra|strong="H5921"\w* gentes tranquilas \w que|strong="H5921"\w* \w habitan|strong="H3427"\w* confiadamente; \w todos|strong="H3605"\w* \w ellos|strong="H5921"\w* \w habitan|strong="H3427"\w* sin \w muros|strong="H2346"\w*, \w y|strong="H5921"\w* \w no|strong="H5921"\w* tienen \w cerrojos|strong="H1280"\w* ni \w puertas|strong="H1817"\w*;  
\v 12 \w para|strong="H5921"\w* arrebatar \w despojos|strong="H7998"\w* \w y|strong="H5921"\w* \w para|strong="H5921"\w* tomar botín, \w para|strong="H5921"\w* poner tus \w manos|strong="H3027"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* ruinas ya \w habitadas|strong="H3427"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* recogido \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w hace|strong="H6213"\w* \w de|strong="H5921"\w* \w ganado|strong="H4735"\w* \w y|strong="H5921"\w* posesiones, \w que|strong="H5921"\w* \w mora|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte central \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
\v 13 Sabá, \w Dedán|strong="H1719"\w*, y \w los|strong="H3605"\w* \w mercaderes|strong="H5503"\w* de \w Tarsis|strong="H8659"\w* y \w todos|strong="H3605"\w* sus leoncillos, te dirán: ¿Has venido \w a|strong="H3068"\w* arrebatar \w despojos|strong="H7998"\w*? ¿Has reunido tu \w multitud|strong="H6951"\w* para \w tomar|strong="H3947"\w* botín, para quitar \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w*, para \w tomar|strong="H3947"\w* \w ganados|strong="H4735"\w* y posesiones, para \w tomar|strong="H3947"\w* \w grandes|strong="H1419"\w* \w despojos|strong="H7998"\w*?’.   
\p
\v 14 “\w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w profetiza|strong="H5012"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w y|strong="H3541"\w* di \w a|strong="H3068"\w* \w Gog|strong="H1463"\w*: ‘\w Así|strong="H3541"\w* dice \w el|strong="H1931"\w* Señor Yahvé: En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w cuando|strong="H3117"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w* habite con seguridad, ¿\w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w sabrás|strong="H3045"\w* tú?  
\v 15 Vendrás \w de|strong="H5971"\w* tu \w lugar|strong="H4725"\w*, \w de|strong="H5971"\w* las regiones del \w norte|strong="H6828"\w*, tú y \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* \w contigo|strong="H5971"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w a|strong="H3068"\w* \w caballo|strong="H5483"\w*, \w gran|strong="H1419"\w* \w multitud|strong="H6951"\w* y poderoso \w ejército|strong="H2428"\w*,  
\v 16 \w y|strong="H5921"\w* \w subirás|strong="H5927"\w* \w contra|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w* \w como|strong="H1961"\w* \w nublado|strong="H6051"\w* \w para|strong="H4616"\w* \w cubrir|strong="H3680"\w* \w la|strong="H5921"\w* tierra; \w será|strong="H1961"\w* \w al|strong="H5921"\w* cabo \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w*; \w y|strong="H5921"\w* \w te|strong="H5869"\w* traeré \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* tierra, \w para|strong="H4616"\w* \w que|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w me|strong="H5921"\w* \w conozcan|strong="H3045"\w*, \w cuando|strong="H3117"\w* \w sea|strong="H1961"\w* santificado \w en|strong="H5921"\w* \w ti|strong="H5921"\w*, oh \w Gog|strong="H1463"\w*, \w delante|strong="H5869"\w* \w de|strong="H5921"\w* sus \w ojos|strong="H5869"\w*.   
\p
\v 17 “‘\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H1931"\w* Señor Yahvé: ¿\w No|strong="H5921"\w* \w eres|strong="H1931"\w* tú \w aquel|strong="H1931"\w* \w de|strong="H5921"\w* \w quien|strong="H1931"\w* \w hablé|strong="H1696"\w* \w en|strong="H5921"\w* \w tiempos|strong="H8141"\w* pasados \w por|strong="H5921"\w* mis \w siervos|strong="H5650"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w los|strong="H1992"\w* cuales \w profetizaron|strong="H5012"\w* \w en|strong="H5921"\w* \w aquellos|strong="H1992"\w* \w tiempos|strong="H8141"\w* \w que|strong="H1931"\w* yo \w te|strong="H5921"\w* había \w de|strong="H5921"\w* traer \w sobre|strong="H5921"\w* \w ellos|strong="H1992"\w*?  
\v 18 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w*, \w cuando|strong="H3117"\w* \w venga|strong="H1961"\w* \w Gog|strong="H1463"\w* \w contra|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w dice|strong="H5002"\w* \w el|strong="H1931"\w* Señor Yahvé, \w subirá|strong="H5927"\w* \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w enojo|strong="H2534"\w*.  
\v 19 \w Porque|strong="H5921"\w* he \w hablado|strong="H1696"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w celo|strong="H7068"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* fuego \w de|strong="H5921"\w* \w mi|strong="H5921"\w* ira: \w Que|strong="H1931"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w* \w habrá|strong="H1961"\w* \w gran|strong="H1419"\w* \w temblor|strong="H7494"\w* \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*;  
\v 20 \w de|strong="H5921"\w* modo \w que|strong="H5921"\w* \w los|strong="H5921"\w* peces \w del|strong="H5921"\w* \w mar|strong="H3220"\w*, \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w las|strong="H5921"\w* \w bestias|strong="H2416"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w reptil|strong="H7431"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* arrastra \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* hombres \w que|strong="H5921"\w* están \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w temblarán|strong="H7493"\w* \w ante|strong="H6440"\w* \w mi|strong="H5921"\w* \w presencia|strong="H6440"\w*; \w y|strong="H5921"\w* \w se|strong="H5921"\w* derrumbarán \w los|strong="H5921"\w* \w montes|strong="H2022"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* peñascos \w caerán|strong="H5307"\w*, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w muro|strong="H2346"\w* \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* tierra.  
\v 21 \w Y|strong="H3068"\w* \w en|strong="H5921"\w* \w todos|strong="H3605"\w* mis \w montes|strong="H2022"\w* \w llamaré|strong="H7121"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor Yahvé; \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w de|strong="H5921"\w* \w cada|strong="H3605"\w* cual \w será|strong="H1961"\w* \w contra|strong="H5921"\w* su hermano.  
\v 22 \w Y|strong="H3068"\w* yo \w litigaré|strong="H8199"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w con|strong="H5921"\w* \w pestilencia|strong="H1698"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w sangre|strong="H1818"\w*; \w y|strong="H5921"\w* haré llover \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w sobre|strong="H5921"\w* sus tropas \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* \w que|strong="H5921"\w* están \w con|strong="H5921"\w* \w él|strong="H5921"\w*, \w impetuosa|strong="H7857"\w* \w lluvia|strong="H1653"\w*, \w y|strong="H5921"\w* piedras \w de|strong="H5921"\w* granizo, fuego \w y|strong="H5921"\w* \w azufre|strong="H1614"\w*.  
\v 23 \w Y|strong="H3068"\w* seré \w engrandecido|strong="H1431"\w* \w y|strong="H3588"\w* santificado, \w y|strong="H3588"\w* seré \w conocido|strong="H3045"\w* ante \w los|strong="H3588"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w*; \w y|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé’”.   
\c 39
\p
\v 1 “Tú, pues, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w profetiza|strong="H5012"\w* \w contra|strong="H5921"\w* \w Gog|strong="H1463"\w*, \w y|strong="H5921"\w* di: \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* yo estoy \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w oh|strong="H1121"\w* \w Gog|strong="H1463"\w*, \w príncipe|strong="H5387"\w* soberano \w de|strong="H5921"\w* Rosh, \w Mesec|strong="H4902"\w* \w y|strong="H5921"\w* \w Tubal|strong="H8422"\w*.  
\v 2 \w Te|strong="H5921"\w* haré dar \w la|strong="H5921"\w* vuelta, \w te|strong="H5921"\w* conduciré \w y|strong="H5921"\w* \w te|strong="H5921"\w* haré \w subir|strong="H5927"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* partes \w más|strong="H5921"\w* lejanas \w del|strong="H5921"\w* \w norte|strong="H6828"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* traeré \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 3 Derribaré tu \w arco|strong="H7198"\w* de tu \w mano|strong="H3027"\w* \w izquierda|strong="H8040"\w*, y haré \w caer|strong="H5307"\w* tus flechas de tu \w mano|strong="H3027"\w* \w derecha|strong="H3225"\w*.  
\v 4 \w Sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w caerás|strong="H5307"\w*, tú \w y|strong="H5921"\w* \w todas|strong="H3605"\w* tus tropas, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w que|strong="H5921"\w* están \w contigo|strong="H5921"\w*. \w A|strong="H3068"\w* \w las|strong="H5921"\w* \w aves|strong="H5861"\w* \w de|strong="H5921"\w* rapiña \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w especie|strong="H3671"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* fieras \w del|strong="H5921"\w* \w campo|strong="H7704"\w*, \w te|strong="H5921"\w* he \w dado|strong="H5414"\w* \w por|strong="H5921"\w* comida.  
\v 5 \w Sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* abierto \w caerás|strong="H5307"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* he \w hablado|strong="H1696"\w*, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor Yahvé.  
\v 6 \w Y|strong="H3068"\w* \w enviaré|strong="H7971"\w* fuego sobre \w Magog|strong="H4031"\w*, \w y|strong="H3588"\w* sobre \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w moran|strong="H3427"\w* confiadamente \w en|strong="H3588"\w* las costas; \w y|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé.   
\p
\v 7 “\w Y|strong="H3068"\w* daré \w a|strong="H3068"\w* conocer \w mi|strong="H2490"\w* \w santo|strong="H6918"\w* \w nombre|strong="H8034"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w mi|strong="H2490"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* permitiré \w que|strong="H3588"\w* \w mi|strong="H2490"\w* \w santo|strong="H6918"\w* \w nombre|strong="H8034"\w* sea \w profanado|strong="H2490"\w* \w más|strong="H5750"\w*. \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* las \w naciones|strong="H1471"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w el|strong="H3588"\w* \w Santo|strong="H6918"\w* \w en|strong="H8432"\w* \w Israel|strong="H3478"\w*.  
\v 8 He \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* viene, y \w se|strong="H1961"\w* cumplirá, \w dice|strong="H5002"\w* \w el|strong="H1931"\w* Señor Yahvé. \w Este|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* del \w cual|strong="H1931"\w* he \w hablado|strong="H1696"\w*.   
\p
