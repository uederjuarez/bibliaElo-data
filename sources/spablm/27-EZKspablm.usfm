\p
\v 1 \w En|strong="H5921"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* \w veinticinco|strong="H6242"\w* \w de|strong="H5921"\w* nuestro \w cautiverio|strong="H1546"\w*, \w al|strong="H5921"\w* principio \w del|strong="H5921"\w* \w año|strong="H8141"\w*, \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w diez|strong="H6240"\w* \w días|strong="H3117"\w* \w del|strong="H5921"\w* \w mes|strong="H2320"\w*, \w a|strong="H3068"\w* \w los|strong="H5921"\w* catorce \w años|strong="H8141"\w* \w después|strong="H5921"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w fue|strong="H1961"\w* conquistada, \w en|strong="H5921"\w* \w aquel|strong="H2088"\w* \w mismo|strong="H6106"\w* \w día|strong="H3117"\w* \w fue|strong="H1961"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* Yahvé \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* \w me|strong="H5921"\w* llevó \w allá|strong="H8033"\w*.  
