\v 45 \w Hija|strong="H1323"\w* eres tú \w de|strong="H1121"\w* tu madre, \w que|strong="H1121"\w* desechó \w a|strong="H3068"\w* su marido y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*; y hermana eres tú \w de|strong="H1121"\w* tus hermanas, \w que|strong="H1121"\w* \w desecharon|strong="H1602"\w* \w a|strong="H3068"\w* sus maridos y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*; vuestra madre fue hitita, y vuestro padre amorreo.  
\v 46 \w Y|strong="H3068"\w* tu hermana \w mayor|strong="H1419"\w* \w es|strong="H1931"\w* \w Samaria|strong="H8111"\w*, \w ella|strong="H1931"\w* \w y|strong="H5921"\w* \w sus|strong="H1931"\w* \w hijas|strong="H1323"\w*, \w que|strong="H4480"\w* \w habitan|strong="H3427"\w* \w a|strong="H3068"\w* tu \w izquierda|strong="H8040"\w*; \w y|strong="H5921"\w* tu hermana \w menor|strong="H6996"\w*, \w que|strong="H4480"\w* \w habita|strong="H3427"\w* \w a|strong="H3068"\w* tu \w derecha|strong="H3225"\w*, \w es|strong="H1931"\w* \w Sodoma|strong="H5467"\w* \w y|strong="H5921"\w* \w sus|strong="H1931"\w* \w hijas|strong="H1323"\w*.  
\v 47 \w Y|strong="H3068"\w* \w aun|strong="H3808"\w* \w no|strong="H3808"\w* \w anduviste|strong="H1980"\w* en sus \w caminos|strong="H1870"\w*, \w ni|strong="H3808"\w* \w hiciste|strong="H6213"\w* según sus \w abominaciones|strong="H8441"\w*; \w sino|strong="H3808"\w* \w que|strong="H3808"\w*, como \w si|strong="H3808"\w* \w esto|strong="H6213"\w* fuera \w poco|strong="H4592"\w* y muy \w poco|strong="H4592"\w*, te \w corrompiste|strong="H7843"\w* \w más|strong="H3808"\w* \w que|strong="H3808"\w* ellas en \w todos|strong="H3605"\w* tus \w caminos|strong="H1870"\w*.  
\v 48 \w Vivo|strong="H2416"\w* \w yo|strong="H6213"\w*, \w dice|strong="H5002"\w* \w el|strong="H1931"\w* Señor Yahvé, \w que|strong="H1931"\w* \w Sodoma|strong="H5467"\w* \w tu|strong="H6213"\w* hermana y \w sus|strong="H1931"\w* \w hijas|strong="H1323"\w* \w no|strong="H6213"\w* han \w hecho|strong="H6213"\w* \w como|strong="H1931"\w* \w hiciste|strong="H6213"\w* \w tú|strong="H6213"\w* y tus \w hijas|strong="H1323"\w*.   
\p
\v 49 “‘He \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w esta|strong="H2088"\w* \w fue|strong="H1961"\w* la \w maldad|strong="H5771"\w* de \w Sodoma|strong="H5467"\w* tu hermana: \w soberbia|strong="H1347"\w*, saciedad de \w pan|strong="H3899"\w* y abundancia de ociosidad \w tuvieron|strong="H1961"\w* ella y sus \w hijas|strong="H1323"\w*; y \w no|strong="H3808"\w* fortaleció la \w mano|strong="H3027"\w* del \w afligido|strong="H6041"\w* y del menesteroso.  
\v 50 \w Y|strong="H3068"\w* se llenaron \w de|strong="H6440"\w* soberbia \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* \w abominación|strong="H8441"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* mí, y cuando \w lo|strong="H6213"\w* \w vi|strong="H7200"\w* las \w quité|strong="H5493"\w*.  
\v 51 \w Y|strong="H3068"\w* \w Samaria|strong="H8111"\w* \w no|strong="H3808"\w* \w cometió|strong="H2398"\w* \w ni|strong="H3808"\w* \w la|strong="H3605"\w* mitad de tus \w pecados|strong="H2403"\w*; \w porque|strong="H3808"\w* \w tú|strong="H6213"\w* \w multiplicaste|strong="H7235"\w* tus \w abominaciones|strong="H8441"\w* \w más|strong="H7235"\w* \w que|strong="H3808"\w* \w ellas|strong="H2007"\w*, y has \w justificado|strong="H6663"\w* \w a|strong="H3068"\w* tus hermanas con \w todas|strong="H3605"\w* las \w abominaciones|strong="H8441"\w* \w que|strong="H3808"\w* \w tú|strong="H6213"\w* \w hiciste|strong="H6213"\w*.  
\v 52 Tú \w también|strong="H1571"\w*, \w que|strong="H4480"\w* \w juzgaste|strong="H6419"\w* \w a|strong="H3068"\w* tus hermanas, \w lleva|strong="H5375"\w* tu \w vergüenza|strong="H3639"\w* \w en|strong="H4480"\w* los \w pecados|strong="H2403"\w* \w que|strong="H4480"\w* tú hiciste, \w más|strong="H4480"\w* \w abominables|strong="H8581"\w* \w que|strong="H4480"\w* los \w de|strong="H4480"\w* ellas; \w más|strong="H4480"\w* justas son \w que|strong="H4480"\w* tú; avergüénzate, \w pues|strong="H4480"\w*, tú \w también|strong="H1571"\w*, \w y|strong="H1571"\w* \w lleva|strong="H5375"\w* tu \w confusión|strong="H3639"\w*, \w por|strong="H4480"\w* cuanto has \w justificado|strong="H6663"\w* \w a|strong="H3068"\w* tus hermanas.   
\p
\v 53 “‘Yo, pues, haré \w volver|strong="H7725"\w* \w a|strong="H3068"\w* sus \w cautivos|strong="H7628"\w*, los \w cautivos|strong="H7628"\w* de \w Sodoma|strong="H5467"\w* y de sus \w hijas|strong="H1323"\w*, y los \w cautivos|strong="H7628"\w* de \w Samaria|strong="H8111"\w* y de sus \w hijas|strong="H1323"\w*, y los \w cautivos|strong="H7628"\w* de vuestros cautiverios \w entre|strong="H8432"\w* ellas,  
