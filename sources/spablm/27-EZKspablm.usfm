\p
\v 9 “\w Mas|strong="H3588"\w* \w cuando|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w se|strong="H3808"\w* presente \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Yahvé \w en|strong="H3588"\w* las fiestas solemnes, \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w entre|strong="H3808"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* del \w norte|strong="H6828"\w* \w para|strong="H3588"\w* adorar, \w saldrá|strong="H3318"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* del sur; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w entre|strong="H3808"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* del sur, \w saldrá|strong="H3318"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* del \w norte|strong="H6828"\w*. \w No|strong="H3808"\w* regresará \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* entró, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w saldrá|strong="H3318"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w que|strong="H3588"\w* está derecho \w hacia|strong="H1870"\w* adelante.  
\v 10 \w Y|strong="H3068"\w* el \w príncipe|strong="H5387"\w* entrará \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ellos cuando ellos entren, y cuando ellos \w salgan|strong="H3318"\w*, él \w saldrá|strong="H3318"\w*.   
\p
\v 11 “En las fiestas y en las \w solemnidades|strong="H4150"\w*, la \w ofrenda|strong="H4503"\w* de cereal \w será|strong="H1961"\w* de un efa\f + \fr 46:11 \ft 1 efa equivale a unos 22 litros o a 2/3 de una fanega.\f* \w por|strong="H3027"\w* cada \w novillo|strong="H6499"\w*, y de un efa \w por|strong="H3027"\w* cada carnero, y \w por|strong="H3027"\w* \w los|strong="H1961"\w* \w corderos|strong="H3532"\w* lo \w que|strong="H1961"\w* él desee dar, más un \w hin|strong="H1969"\w* de \w aceite|strong="H8081"\w* \w por|strong="H3027"\w* cada efa.  
\v 12 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w el|strong="H3588"\w* \w príncipe|strong="H5387"\w* prepare una ofrenda \w voluntaria|strong="H5071"\w*, ya sea un \w holocausto|strong="H5930"\w* \w o|strong="H3068"\w* una ofrenda \w de|strong="H3588"\w* paz \w como|strong="H3588"\w* ofrenda \w voluntaria|strong="H5071"\w* \w a|strong="H3068"\w* Yahvé, se le \w abrirá|strong="H6605"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* \w que|strong="H3588"\w* \w mira|strong="H6437"\w* \w hacia|strong="H6213"\w* \w el|strong="H3588"\w* oriente, \w y|strong="H3588"\w* preparará \w su|strong="H3588"\w* \w holocausto|strong="H5930"\w* \w y|strong="H3588"\w* sus ofrendas \w de|strong="H3588"\w* paz \w como|strong="H3588"\w* \w lo|strong="H6213"\w* \w hace|strong="H6213"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* reposo. \w Luego|strong="H3318"\w* \w saldrá|strong="H3318"\w*, \w y|strong="H3588"\w* después \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w salida|strong="H3318"\w* se \w cerrará|strong="H5462"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w*.   
\p
\v 13 “Prepararás \w cada|strong="H3117"\w* \w día|strong="H3117"\w* un \w cordero|strong="H3532"\w* \w de|strong="H1121"\w* un \w año|strong="H8141"\w*, sin defecto, para \w el|strong="H1121"\w* \w holocausto|strong="H5930"\w* \w a|strong="H3068"\w* Yahvé; \w cada|strong="H3117"\w* \w mañana|strong="H1242"\w* \w lo|strong="H6213"\w* prepararás.  
\v 14 \w Y|strong="H3068"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w* prepararás cada \w mañana|strong="H1242"\w* una \w ofrenda|strong="H4503"\w* \w de|strong="H5921"\w* cereal: \w la|strong="H5921"\w* sexta \w parte|strong="H8345"\w* \w de|strong="H5921"\w* un efa,\f + \fr 46:14 \ft 1 efa equivale a unos 22 litros o a 2/3 de una fanega.\f* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w tercera|strong="H7992"\w* \w parte|strong="H8345"\w* \w de|strong="H5921"\w* un \w hin|strong="H1969"\w* \w de|strong="H5921"\w* \w aceite|strong="H8081"\w* \w para|strong="H5921"\w* amasar \w la|strong="H5921"\w* flor \w de|strong="H5921"\w* harina; \w ofrenda|strong="H4503"\w* \w a|strong="H3068"\w* Yahvé \w continuamente|strong="H8548"\w*, \w por|strong="H5921"\w* \w estatuto|strong="H2708"\w* \w perpetuo|strong="H5769"\w*.  
\v 15 Así prepararán \w el|strong="H6213"\w* \w cordero|strong="H3532"\w*, la \w ofrenda|strong="H4503"\w* de cereal y \w el|strong="H6213"\w* \w aceite|strong="H8081"\w*, cada \w mañana|strong="H1242"\w*, como un \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*.   
\p
\v 16 «\w Así|strong="H3541"\w* dice \w el|strong="H1931"\w* Señor Yahvé: \w Si|strong="H3588"\w* \w el|strong="H1931"\w* \w príncipe|strong="H5387"\w* hace un regalo \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w heredad|strong="H5159"\w* \w a|strong="H3068"\w* alguno \w de|strong="H3588"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*, \w será|strong="H1961"\w* \w de|strong="H3588"\w* \w ellos|strong="H1931"\w*; \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w posesión|strong="H5159"\w* \w por|strong="H3588"\w* \w herencia|strong="H5159"\w*.  
\v 17 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* \w heredad|strong="H5159"\w* \w da|strong="H5414"\w* un regalo \w a|strong="H3068"\w* alguno \w de|strong="H3588"\w* \w sus|strong="H1992"\w* \w siervos|strong="H5650"\w*, \w será|strong="H1961"\w* suyo \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w año|strong="H8141"\w* del jubileo; \w entonces|strong="H3588"\w* \w volverá|strong="H7725"\w* \w al|strong="H5704"\w* \w príncipe|strong="H5387"\w*. \w Su|strong="H1992"\w* \w heredad|strong="H5159"\w* \w será|strong="H1961"\w* únicamente \w para|strong="H5704"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w*.  
\v 18 Además, \w el|strong="H1121"\w* \w príncipe|strong="H5387"\w* \w no|strong="H3808"\w* \w tomará|strong="H3947"\w* \w de|strong="H1121"\w* la \w herencia|strong="H5159"\w* del \w pueblo|strong="H5971"\w* \w para|strong="H4616"\w* despojarlos \w de|strong="H1121"\w* su \w posesión|strong="H5159"\w*. Dará \w herencia|strong="H5159"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* su propia \w posesión|strong="H5159"\w*, \w para|strong="H4616"\w* \w que|strong="H3808"\w* mi \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* sea dispersado, cada uno lejos \w de|strong="H1121"\w* su propiedad».   
\p
\v 19 Luego \w me|strong="H5921"\w* llevó \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w entrada|strong="H3996"\w* \w que|strong="H5921"\w* \w estaba|strong="H2009"\w* \w a|strong="H3068"\w* un \w lado|strong="H3802"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w*, \w hacia|strong="H5921"\w* \w las|strong="H5921"\w* \w cámaras|strong="H3957"\w* \w santas|strong="H6944"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w*, \w las|strong="H5921"\w* cuales \w miraban|strong="H6437"\w* \w al|strong="H5921"\w* \w norte|strong="H6828"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* había un \w lugar|strong="H4725"\w* \w al|strong="H5921"\w* fondo, \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* occidente.  
\v 20 \w Y|strong="H3068"\w* me dijo: «\w Este|strong="H2088"\w* \w es|strong="H2088"\w* \w el|strong="H1310"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* los \w sacerdotes|strong="H3548"\w* \w cocerán|strong="H1310"\w* la \w ofrenda|strong="H4503"\w* \w por|strong="H2088"\w* la culpa y la \w ofrenda|strong="H4503"\w* \w por|strong="H2088"\w* \w el|strong="H1310"\w* \w pecado|strong="H2403"\w*, y \w donde|strong="H8033"\w* hornearán la \w ofrenda|strong="H4503"\w* \w de|strong="H5971"\w* cereal, \w para|strong="H5971"\w* \w no|strong="H1115"\w* tener \w que|strong="H5971"\w* sacarlas al \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w* y \w así|strong="H2088"\w* \w no|strong="H1115"\w* transmitir santidad al \w pueblo|strong="H5971"\w*».   
\p
\v 21 Entonces me \w sacó|strong="H3318"\w* al \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w* y me hizo \w pasar|strong="H5674"\w* por las cuatro \w esquinas|strong="H4740"\w* del \w atrio|strong="H2691"\w*; y he \w aquí|strong="H2009"\w* \w que|strong="H2691"\w* \w en|strong="H3318"\w* cada esquina del \w atrio|strong="H2691"\w* había un \w patio|strong="H2691"\w*.  
\v 22 \f + \fr 46:22 \ft Un codo es la longitud desde la punta del dedo corazón hasta el codo del brazo de un hombre, es decir, unos 46 centímetros.\f* En las cuatro \w esquinas|strong="H4740"\w* del \w atrio|strong="H2691"\w* había \w patios|strong="H2691"\w* cerrados, de cuarenta codos de largo y \w treinta|strong="H7970"\w* de ancho; los cuatro \w patios|strong="H2691"\w* de las \w esquinas|strong="H4740"\w* tenían la misma \w medida|strong="H4060"\w*.  
\v 23 \w Y|strong="H3068"\w* \w había|strong="H6213"\w* un muro \w de|strong="H8478"\w* mampostería \w alrededor|strong="H5439"\w* \w de|strong="H8478"\w* los cuatro, y se habían construido fogones \w en|strong="H8478"\w* la parte baja \w de|strong="H8478"\w* los muros \w en|strong="H8478"\w* \w todo|strong="H5439"\w* su perímetro.  
\v 24 \w Y|strong="H3068"\w* me dijo: «Estas son las cocinas, \w donde|strong="H8033"\w* los servidores \w de|strong="H5971"\w* la \w casa|strong="H1004"\w* \w cocerán|strong="H1310"\w* los \w sacrificios|strong="H2077"\w* del \w pueblo|strong="H5971"\w*».   
\c 47
\p
\v 1 \w Me|strong="H3588"\w* hizo \w volver|strong="H7725"\w* \w luego|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w puerta|strong="H6607"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w*; \w y|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w salían|strong="H3318"\w* \w aguas|strong="H4325"\w* \w por|strong="H3588"\w* \w debajo|strong="H8478"\w* \w del|strong="H4196"\w* \w umbral|strong="H4670"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w hacia|strong="H6440"\w* \w el|strong="H3588"\w* oriente, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* fachada \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w estaba|strong="H2009"\w* \w al|strong="H8478"\w* oriente. Las \w aguas|strong="H4325"\w* \w descendían|strong="H3381"\w* \w de|strong="H3588"\w* \w debajo|strong="H8478"\w*, \w desde|strong="H6440"\w* \w el|strong="H3588"\w* \w lado|strong="H3802"\w* \w derecho|strong="H3233"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w*, \w al|strong="H8478"\w* sur \w del|strong="H4196"\w* \w altar|strong="H4196"\w*.  
\v 2 \w Luego|strong="H3318"\w* \w me|strong="H4480"\w* \w sacó|strong="H3318"\w* \w por|strong="H4480"\w* el \w camino|strong="H1870"\w* \w de|strong="H4480"\w* la \w puerta|strong="H8179"\w* \w del|strong="H4480"\w* \w norte|strong="H6828"\w*, y \w me|strong="H4480"\w* hizo dar la \w vuelta|strong="H5437"\w* \w por|strong="H4480"\w* el \w camino|strong="H1870"\w* exterior, hasta la \w puerta|strong="H8179"\w* exterior \w que|strong="H4480"\w* \w mira|strong="H2009"\w* \w hacia|strong="H1870"\w* el oriente; y he \w aquí|strong="H2009"\w* \w que|strong="H4480"\w* las \w aguas|strong="H4325"\w* fluían \w por|strong="H4480"\w* el \w lado|strong="H3802"\w* \w derecho|strong="H3233"\w*.   
\p
\v 3 \w Y|strong="H3068"\w* cuando \w el|strong="H5674"\w* varón \w salió|strong="H3318"\w* hacia \w el|strong="H5674"\w* oriente con \w el|strong="H5674"\w* cordel \w en|strong="H3318"\w* su \w mano|strong="H3027"\w*, \w midió|strong="H4058"\w* mil codos\f + \fr 47:3 \ft Un codo es la longitud desde la punta del dedo corazón hasta el codo del brazo de un hombre, es decir, unos 46 centímetros.\f*, y me hizo \w pasar|strong="H5674"\w* \w por|strong="H3027"\w* las \w aguas|strong="H4325"\w*, \w que|strong="H4325"\w* me llegaban hasta los tobillos.  
\v 4 \w Midió|strong="H4058"\w* otros mil, y me hizo \w pasar|strong="H5674"\w* por las \w aguas|strong="H4325"\w*, \w que|strong="H4325"\w* me llegaban hasta las \w rodillas|strong="H1290"\w*. \w Midió|strong="H4058"\w* \w luego|strong="H5674"\w* otros mil, y me hizo \w pasar|strong="H5674"\w* por las \w aguas|strong="H4325"\w*, \w que|strong="H4325"\w* me llegaban hasta los \w lomos|strong="H4975"\w*.  
\v 5 \w Midió|strong="H4058"\w* otros mil, \w y|strong="H3588"\w* era ya un río \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w no|strong="H3808"\w* \w podía|strong="H3201"\w* vadear, \w porque|strong="H3588"\w* las \w aguas|strong="H4325"\w* habían crecido tanto \w que|strong="H3588"\w* era un río \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w cual|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w podía|strong="H3201"\w* \w pasar|strong="H5674"\w* \w sino|strong="H3588"\w* \w a|strong="H3068"\w* nado.   
\p
\v 6 \w Y|strong="H3068"\w* me dijo: «¿Has \w visto|strong="H7200"\w* esto, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*?».  
\p Después me llevó y me hizo \w volver|strong="H7725"\w* por la ribera del río.  
\v 7 \w Y|strong="H3068"\w* al \w volver|strong="H7725"\w*, he \w aquí|strong="H2088"\w* \w que|strong="H2088"\w* en la ribera del río había muchísimos \w árboles|strong="H6086"\w* \w a|strong="H3068"\w* uno y \w otro|strong="H2088"\w* lado.  
\v 8 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* dijo: «Estas \w aguas|strong="H4325"\w* \w salen|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* región \w del|strong="H5921"\w* oriente, \w y|strong="H5921"\w* \w descenderán|strong="H3381"\w* \w al|strong="H5921"\w* Arabá, \w y|strong="H5921"\w* entrarán \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*; \w y|strong="H5921"\w* \w al|strong="H5921"\w* entrar \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* serán sanadas.  
\v 9 \w Y|strong="H3068"\w* \w acontecerá|strong="H1961"\w* \w que|strong="H3588"\w* \w toda|strong="H3605"\w* \w alma|strong="H5315"\w* \w viviente|strong="H2416"\w* \w que|strong="H3588"\w* nade \w por|strong="H3588"\w* dondequiera \w que|strong="H3588"\w* entraren \w estos|strong="H3605"\w* dos ríos, \w vivirá|strong="H2421"\w*; \w y|strong="H3588"\w* \w habrá|strong="H1961"\w* muchísimos \w peces|strong="H1710"\w* \w por|strong="H3588"\w* \w haber|strong="H1961"\w* entrado \w allá|strong="H8033"\w* estas \w aguas|strong="H4325"\w*, \w y|strong="H3588"\w* \w serán|strong="H1961"\w* sanadas; \w y|strong="H3588"\w* \w vivirá|strong="H2421"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3588"\w* \w entre|strong="H3588"\w* \w en|strong="H3588"\w* \w este|strong="H1961"\w* río.  
\v 10 \w Y|strong="H3068"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w estarán|strong="H1961"\w* \w los|strong="H5921"\w* \w pescadores|strong="H7227"\w*; \w desde|strong="H5704"\w* En-gadi \w hasta|strong="H5704"\w* \w En-eglaim|strong="H5882"\w* \w será|strong="H1961"\w* \w tendedero|strong="H4894"\w* \w de|strong="H5921"\w* redes. Sus \w peces|strong="H1710"\w*, \w según|strong="H5921"\w* su \w especie|strong="H4327"\w*, \w serán|strong="H1961"\w* \w tan|strong="H3966"\w* abundantes \w como|strong="H1961"\w* \w los|strong="H5921"\w* \w peces|strong="H1710"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w* \w Grande|strong="H1419"\w*.  
\v 11 Pero sus pantanos y sus lagunas \w no|strong="H3808"\w* serán sanados; \w quedarán|strong="H5414"\w* \w para|strong="H5414"\w* salinas.  
\v 12 \w Y|strong="H3068"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* río, \w en|strong="H5921"\w* \w sus|strong="H1992"\w* riberas, \w a|strong="H3068"\w* uno \w y|strong="H3588"\w* \w otro|strong="H2088"\w* lado, \w crecerá|strong="H5927"\w* \w toda|strong="H3605"\w* clase \w de|strong="H4480"\w* \w árboles|strong="H6086"\w* frutales; \w sus|strong="H1992"\w* \w hojas|strong="H5929"\w* \w nunca|strong="H3808"\w* caerán, \w ni|strong="H3808"\w* \w faltará|strong="H8552"\w* \w su|strong="H1992"\w* \w fruto|strong="H6529"\w*. \w A|strong="H3068"\w* \w su|strong="H1992"\w* tiempo \w madurará|strong="H1069"\w*, \w porque|strong="H3588"\w* \w sus|strong="H1992"\w* \w aguas|strong="H4325"\w* \w salen|strong="H3318"\w* \w del|strong="H4480"\w* \w santuario|strong="H4720"\w*; \w su|strong="H1992"\w* \w fruto|strong="H6529"\w* \w será|strong="H1961"\w* \w para|strong="H5921"\w* comer, \w y|strong="H3588"\w* \w su|strong="H1992"\w* hoja \w para|strong="H5921"\w* medicina».   
\p
\v 13 \w Así|strong="H3541"\w* dice el Señor Yahvé: “Estos son los límites en \w que|strong="H3541"\w* repartiréis \w la|strong="H1366"\w* tierra por heredad entre las \w doce|strong="H8147"\w* \w tribus|strong="H7626"\w* de \w Israel|strong="H3478"\w*. \w José|strong="H3130"\w* tendrá \w dos|strong="H8147"\w* porciones.  
\v 14 \w Y|strong="H3068"\w* \w la|strong="H2063"\w* \w heredaréis|strong="H5157"\w* tanto los unos como los otros; \w por|strong="H3027"\w* ella \w alcé|strong="H5375"\w* \w mi|strong="H5375"\w* \w mano|strong="H3027"\w* jurando \w que|strong="H3027"\w* \w la|strong="H2063"\w* \w daría|strong="H5414"\w* \w a|strong="H3068"\w* vuestros padres. \w Por|strong="H3027"\w* tanto, \w esta|strong="H2063"\w* tierra os \w caerá|strong="H5307"\w* en \w heredad|strong="H5159"\w*.   
\p
\v 15 “\w Y|strong="H3068"\w* \w este|strong="H2088"\w* será el límite \w de|strong="H4480"\w* \w la|strong="H1366"\w* tierra:  
