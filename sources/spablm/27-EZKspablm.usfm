\v 37 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H2005"\w* \w que|strong="H5921"\w* yo reuniré \w a|strong="H3068"\w* \w todos|strong="H3605"\w* tus amantes \w con|strong="H5921"\w* \w los|strong="H5921"\w* cuales tomaste placer, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* amaste, \w con|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w aborreciste|strong="H8130"\w*; \w y|strong="H5921"\w* \w los|strong="H5921"\w* reuniré \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w descubriré|strong="H1540"\w* tu \w desnudez|strong="H6172"\w*, \w y|strong="H5921"\w* \w verán|strong="H7200"\w* \w toda|strong="H3605"\w* tu \w desnudez|strong="H6172"\w*.  
