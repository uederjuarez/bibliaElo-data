\v 24 \w porque|strong="H3282"\w* \w no|strong="H3808"\w* \w pusieron|strong="H6213"\w* \w por|strong="H3282"\w* \w obra|strong="H6213"\w* mis decretos, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w desecharon|strong="H3988"\w* mis \w estatutos|strong="H2708"\w* y \w profanaron|strong="H2490"\w* mis \w sábados|strong="H7676"\w*, y tras \w los|strong="H1961"\w* \w ídolos|strong="H1544"\w* \w de|strong="H5869"\w* sus padres \w se|strong="H1961"\w* \w le|strong="H5869"\w* \w fueron|strong="H1961"\w* \w los|strong="H1961"\w* \w ojos|strong="H5869"\w*.  
\v 25 \w Por|strong="H5414"\w* eso yo \w también|strong="H1571"\w* les \w di|strong="H5414"\w* \w estatutos|strong="H2706"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w eran|strong="H3808"\w* \w buenos|strong="H2896"\w*, \w y|strong="H1571"\w* decretos \w por|strong="H5414"\w* los cuales \w no|strong="H3808"\w* podrían \w vivir|strong="H2421"\w*.  
\v 26 \w Y|strong="H3068"\w* \w los|strong="H3605"\w* contaminé en sus \w ofrendas|strong="H4979"\w*, cuando hacían \w pasar|strong="H5674"\w* \w por|strong="H4616"\w* \w el|strong="H3605"\w* fuego \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w primogénito|strong="H6363"\w*, \w para|strong="H4616"\w* asolarlos y hacerles \w saber|strong="H3045"\w* \w que|strong="H3045"\w* yo soy Yahvé’.   
\p
\v 27 “\w Por|strong="H5750"\w* \w tanto|strong="H3651"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5750"\w* \w hombre|strong="H1121"\w*, \w habla|strong="H1696"\w* \w a|strong="H3068"\w* \w la|strong="H2063"\w* \w casa|strong="H1004"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3541"\w* \w diles|strong="H1696"\w*: \w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H1121"\w* Señor Yahvé: ‘\w Aun|strong="H5750"\w* \w en|strong="H5750"\w* \w esto|strong="H2063"\w* \w me|strong="H3541"\w* blasfemaron vuestros padres, cometiendo \w prevaricación|strong="H4603"\w* \w contra|strong="H3478"\w* mí.  
\v 28 \w Porque|strong="H8033"\w* yo \w los|strong="H3605"\w* traje \w a|strong="H3068"\w* \w la|strong="H3605"\w* tierra sobre \w la|strong="H3605"\w* cual había alzado \w mi|strong="H5375"\w* \w mano|strong="H3027"\w* jurando \w que|strong="H3605"\w* se \w la|strong="H3605"\w* \w daría|strong="H5414"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w*; y \w miraron|strong="H7200"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w collado|strong="H1389"\w* \w alto|strong="H7311"\w* y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* frondoso, y \w allí|strong="H8033"\w* \w sacrificaron|strong="H2076"\w* sus \w víctimas|strong="H2076"\w*, y \w allí|strong="H8033"\w* \w presentaron|strong="H5414"\w* \w la|strong="H3605"\w* \w ofrenda|strong="H7133"\w* \w de|strong="H5414"\w* su provocación, \w allí|strong="H8033"\w* \w pusieron|strong="H7760"\w* también su \w olor|strong="H7381"\w* \w suave|strong="H5207"\w*, y \w allí|strong="H8033"\w* \w derramaron|strong="H5258"\w* sus \w libaciones|strong="H5262"\w*.  
\v 29 \w Y|strong="H3068"\w* yo les dije: ¿\w Qué|strong="H4100"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* lugar alto \w adonde|strong="H5704"\w* vosotros vais? \w Y|strong="H3068"\w* fue \w llamado|strong="H8034"\w* su \w nombre|strong="H8034"\w* \w Bamah|strong="H1116"\w* \w hasta|strong="H5704"\w* el \w día|strong="H3117"\w* \w de|strong="H5704"\w* \w hoy|strong="H3117"\w*’.   
\p
\v 30 “Di, \w pues|strong="H3651"\w*, \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*: \w Así|strong="H3541"\w* dice el Señor Yahvé: ‘¿\w No|strong="H1870"\w* os contamináis vosotros \w a|strong="H3068"\w* la manera de vuestros padres, \w y|strong="H3541"\w* fornicáis tras sus \w abominaciones|strong="H8251"\w*?  
\v 31 Porque \w al|strong="H5704"\w* ofrecer vuestras \w ofrendas|strong="H4979"\w*, haciendo \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* vuestros \w hijos|strong="H1121"\w* \w por|strong="H5704"\w* \w el|strong="H3605"\w* fuego, \w os|strong="H5704"\w* habéis \w contaminado|strong="H2930"\w* \w con|strong="H5704"\w* \w todos|strong="H3605"\w* vuestros \w ídolos|strong="H1544"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*; ¿\w y|strong="H5704"\w* he \w de|strong="H5704"\w* responderos yo, \w casa|strong="H1004"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*? \w Vivo|strong="H2416"\w* yo, \w dice|strong="H5002"\w* \w el|strong="H3605"\w* Señor Yahvé, \w que|strong="H5704"\w* no \w os|strong="H5704"\w* responderé.   
\p
\v 32 “‘\w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* \w de|strong="H5921"\w* ser \w lo|strong="H3808"\w* \w que|strong="H3808"\w* habéis pensado. Decís: \w Seremos|strong="H1961"\w* \w como|strong="H1961"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, \w como|strong="H1961"\w* \w las|strong="H5921"\w* \w familias|strong="H4940"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w sirviendo|strong="H8334"\w* \w al|strong="H5921"\w* \w madero|strong="H6086"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* piedra.  
\v 33 \w Vivo|strong="H2416"\w* yo, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor Yahvé, \w que|strong="H3808"\w* \w con|strong="H5921"\w* \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w* \w y|strong="H5921"\w* \w brazo|strong="H2220"\w* \w extendido|strong="H5186"\w*, \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w ira|strong="H2534"\w* derramada, he \w de|strong="H5921"\w* reinar \w sobre|strong="H5921"\w* vosotros;  
\v 34 y \w os|strong="H4480"\w* sacaré \w de|strong="H4480"\w* \w entre|strong="H4480"\w* los \w pueblos|strong="H5971"\w*, y \w os|strong="H4480"\w* reuniré \w de|strong="H4480"\w* las tierras \w en|strong="H4480"\w* \w que|strong="H4480"\w* estáis esparcidos, \w con|strong="H4480"\w* \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w* y \w brazo|strong="H2220"\w* \w extendido|strong="H5186"\w*, y \w con|strong="H4480"\w* \w ira|strong="H2534"\w* derramada;  
\v 35 y os traeré al \w desierto|strong="H4057"\w* \w de|strong="H6440"\w* los \w pueblos|strong="H5971"\w*, y \w allí|strong="H8033"\w* \w litigaré|strong="H8199"\w* con vosotros \w cara|strong="H6440"\w* \w a|strong="H3068"\w* \w cara|strong="H6440"\w*.  
\v 36 \w Como|strong="H3651"\w* \w litigué|strong="H8199"\w* con vuestros padres en el \w desierto|strong="H4057"\w* de la tierra de \w Egipto|strong="H4714"\w*, \w así|strong="H3651"\w* \w litigaré|strong="H8199"\w* con vosotros, \w dice|strong="H5002"\w* el Señor Yahvé.  
\v 37 \w Y|strong="H3068"\w* os haré \w pasar|strong="H5674"\w* \w bajo|strong="H8478"\w* la \w vara|strong="H7626"\w*, y os haré entrar \w en|strong="H8478"\w* los vínculos del \w pacto|strong="H1285"\w*;  
\v 38 \w y|strong="H3588"\w* apartaré \w de|strong="H4480"\w* \w entre|strong="H3808"\w* vosotros \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w rebeldes|strong="H4775"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H3045"\w* rebelaron \w contra|strong="H4480"\w* mí; \w de|strong="H4480"\w* \w la|strong="H3588"\w* tierra \w de|strong="H4480"\w* sus peregrinaciones \w los|strong="H3588"\w* sacaré, \w mas|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* entrarán; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H4480"\w* soy Yahvé.   
\p
\v 39 “‘\w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w vosotros|strong="H8085"\w*, oh \w casa|strong="H1004"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*, \w así|strong="H3541"\w* dice el Señor Yahvé: \w Andad|strong="H3212"\w*, \w servid|strong="H5647"\w* cada uno \w a|strong="H3068"\w* sus \w ídolos|strong="H1544"\w*, \w y|strong="H3541"\w* servidlos \w de|strong="H5750"\w* \w aquí|strong="H3541"\w* \w en|strong="H5750"\w* \w adelante|strong="H5750"\w*, \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w me|strong="H3541"\w* queréis \w obedecer|strong="H8085"\w* \w a|strong="H3068"\w* \w mí|strong="H2490"\w*; pero \w no|strong="H3808"\w* \w profanéis|strong="H2490"\w* \w más|strong="H5750"\w* \w mi|strong="H2490"\w* \w santo|strong="H6944"\w* \w nombre|strong="H8034"\w* con vuestras \w ofrendas|strong="H4979"\w* \w y|strong="H3541"\w* con \w vuestros|strong="H5647"\w* \w ídolos|strong="H1544"\w*.  
\v 40 \w Pero|strong="H3588"\w* \w en|strong="H3588"\w* mi \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*, \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w alto|strong="H4791"\w* \w monte|strong="H2022"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé, \w allí|strong="H8033"\w* \w me|strong="H3588"\w* \w servirá|strong="H5647"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w toda|strong="H3605"\w* \w ella|strong="H8033"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra; \w allí|strong="H8033"\w* \w los|strong="H3605"\w* aceptaré, \w y|strong="H3588"\w* \w allí|strong="H8033"\w* \w demandaré|strong="H1875"\w* vuestras \w ofrendas|strong="H8641"\w*, \w y|strong="H3588"\w* las \w primicias|strong="H7225"\w* \w de|strong="H3588"\w* \w vuestros|strong="H5647"\w* dones \w con|strong="H3588"\w* \w todas|strong="H3605"\w* vuestras cosas consagradas.  
\v 41 Como \w olor|strong="H7381"\w* \w suave|strong="H5207"\w* \w os|strong="H4480"\w* aceptaré, cuando \w os|strong="H4480"\w* \w saque|strong="H3318"\w* \w de|strong="H4480"\w* \w entre|strong="H4480"\w* los \w pueblos|strong="H5971"\w*, y \w os|strong="H4480"\w* reúna \w de|strong="H4480"\w* las tierras \w en|strong="H4480"\w* \w que|strong="H4480"\w* estáis esparcidos; y seré santificado \w en|strong="H4480"\w* vosotros ante los \w ojos|strong="H5869"\w* \w de|strong="H4480"\w* las \w naciones|strong="H1471"\w*.  
\v 42 \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w cuando|strong="H3588"\w* os traiga \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w la|strong="H3588"\w* tierra \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w alcé|strong="H5375"\w* \w mi|strong="H5375"\w* \w mano|strong="H3027"\w* jurando \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w daría|strong="H5414"\w* \w a|strong="H3068"\w* vuestros padres.  
\v 43 \w Y|strong="H3068"\w* \w allí|strong="H8033"\w* os acordaréis \w de|strong="H6440"\w* vuestros \w caminos|strong="H1870"\w*, y \w de|strong="H6440"\w* \w todas|strong="H3605"\w* vuestras \w obras|strong="H5949"\w* en \w que|strong="H3605"\w* os contaminasteis; y os aborreceréis \w a|strong="H3068"\w* vosotros mismos \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w todos|strong="H3605"\w* vuestros pecados \w que|strong="H3605"\w* \w cometisteis|strong="H6213"\w*.  
\v 44 \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w cuando|strong="H3588"\w* \w haga|strong="H6213"\w* \w con|strong="H3588"\w* vosotros \w por|strong="H3588"\w* amor \w de|strong="H3588"\w* mi \w nombre|strong="H8034"\w*, \w no|strong="H3808"\w* según vuestros \w caminos|strong="H1870"\w* \w malos|strong="H7451"\w* \w ni|strong="H3808"\w* según vuestras \w obras|strong="H5949"\w* corruptas, oh \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* Yahvé’”.   
\p
\v 45 Vino \w a|strong="H3068"\w* mí palabra de Yahvé, diciendo:  
\v 46 “Hijo de hombre, pon tu rostro hacia el sur, y derrama tu palabra hacia la parte austral, y profetiza contra el bosque del campo del sur.  
\v 47 \w Y|strong="H3068"\w* dirás al bosque del sur: ‘Oye palabra de Yahvé: Así dice el Señor Yahvé: He aquí que yo enciendo en ti fuego, el cual consumirá en ti todo árbol verde y todo árbol seco; no se apagará la llama del fuego, y serán quemados en ella todos los rostros desde el sur hasta el norte.  
\v 48 \w Y|strong="H3068"\w* verá toda carne que yo, Yahvé, lo encendí; no se apagará’”.   
\p
\v 49 \w Y|strong="H3068"\w* dije: “¡Ah, Señor Yahvé! Ellos dicen de mí: ‘¿No profiere este parábolas?’”.   
\c 21
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w hombre|strong="H1121"\w*, \w pon|strong="H7760"\w* tu \w rostro|strong="H6440"\w* \w hacia|strong="H1870"\w* Jerusalén, y predica \w contra|strong="H6440"\w* \w los|strong="H1121"\w* santuarios, y \w profetiza|strong="H5012"\w* \w contra|strong="H6440"\w* la tierra \w de|strong="H6440"\w* Israel.  
\v 3 \w Y|strong="H3068"\w* dirás \w a|strong="H3068"\w* \w la|strong="H3605"\w* tierra \w de|strong="H6440"\w* Israel: ‘\w Así|strong="H3541"\w* \w dice|strong="H1697"\w* Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H3808"\w* yo estoy \w contra|strong="H6440"\w* ti; sacaré mi espada \w de|strong="H6440"\w* su vaina \w y|strong="H3541"\w* cortaré \w de|strong="H6440"\w* ti al justo \w y|strong="H3541"\w* al impío.  
\v 4 \w Y|strong="H3068"\w* \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* he \w de|strong="H3588"\w* cortar \w de|strong="H3588"\w* ti al justo \w y|strong="H3588"\w* al impío, \w por|strong="H3588"\w* eso saldrá mi espada \w de|strong="H3588"\w* \w su|strong="H3588"\w* vaina contra \w toda|strong="H3605"\w* \w carne|strong="H1320"\w*, desde \w el|strong="H3588"\w* sur hasta \w el|strong="H3588"\w* norte.  
\v 5 \w Y|strong="H3068"\w* sabrá toda carne \w que|strong="H1931"\w* yo, Yahvé, he sacado mi espada de \w su|strong="H1931"\w* vaina; \w no|strong="H3808"\w* volverá \w más|strong="H3808"\w* \w a|strong="H3068"\w* \w ella|strong="H1931"\w*’.   
\p
\v 6 “Gime tú, \w pues|strong="H1961"\w*, hijo \w de|strong="H1697"\w* hombre. Gime ante \w los|strong="H1961"\w* ojos \w de|strong="H1697"\w* ellos con quebrantamiento \w de|strong="H1697"\w* lomos\f + \fr 21:6 \ft literalmente, la ruptura de sus muslos\f* y con amargura.  
\v 7 \w Y|strong="H3068"\w* cuando te dijeren: ‘¿\w Por|strong="H6440"\w* \w qué|strong="H1121"\w* gimes?’, dirás: ‘\w Por|strong="H6440"\w* la noticia \w que|strong="H1121"\w* viene’. \w Y|strong="H3068"\w* todo corazón desfallecerá, y todas las manos se debilitarán, y se angustiará todo espíritu, y todas las rodillas se volverán como agua. He aquí \w que|strong="H1121"\w* viene, y se \w hará|strong="H7760"\w*, dice \w el|strong="H1121"\w* Señor Yahvé”.   
\p
\v 8 Vino \w a|strong="H3068"\w* mí palabra \w de|strong="H4480"\w* Yahvé, diciendo:  
\v 9 “Hijo \w de|strong="H4480"\w* hombre, profetiza y di: ‘\w Así|strong="H3651"\w* dice Yahvé:  
\q1 “¡\w La|strong="H3605"\w* \w espada|strong="H2719"\w*, \w la|strong="H3605"\w* \w espada|strong="H2719"\w*!  
\q2 \w Está|strong="H3651"\w* afilada,  
\q2 y \w también|strong="H3651"\w* acicalada.   
\q1
\v 10 Afilada está \w para|strong="H3588"\w* degollar víctimas;  
\q2 acicalada está \w para|strong="H3588"\w* \w que|strong="H3588"\w* relumbre \w como|strong="H3588"\w* un rayo.  
\q1 ¿Habremos \w de|strong="H3588"\w* alegrarnos?  
\q2 \w El|strong="H3588"\w* cetro \w de|strong="H3588"\w* mi hijo desprecia \w todo|strong="H3605"\w* leño.   
\q1
\v 11 \w Y|strong="H3068"\w* la dio \w a|strong="H3068"\w* acicalar  
\q2 para tenerla en la mano;  
\q1 la espada está afilada,  
\q2 y está acicalada  
\q2 para entregarla en mano del matador.   
\q1
\v 12 Clama \w y|strong="H3588"\w* aúlla, hijo \w de|strong="H5921"\w* hombre;  
\q2 \w porque|strong="H3588"\w* \w ésta|strong="H1961"\w* \w será|strong="H1961"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* pueblo,  
\q2 \w será|strong="H1961"\w* \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* príncipes \w de|strong="H5921"\w* Israel.  
\q1 Han \w sido|strong="H1961"\w* entregados \w a|strong="H3068"\w* \w la|strong="H5921"\w* espada \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w mi|strong="H5921"\w* pueblo;  
\q2 hiere, \w pues|strong="H3588"\w*, tu muslo.   
\b  
\p
\v 13 “‘Porque \w es|strong="H1961"\w* una prueba. ¿\w Y|strong="H3068"\w* \w qué|strong="H1697"\w* \w si|strong="H1961"\w* el cetro despreciador \w no|strong="H1961"\w* existiera más?, \w dice|strong="H1697"\w* el \w Señor|strong="H3068"\w* Yahvé.   
\q1
\v 14 “Tú, \w pues|strong="H1571"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w profetiza|strong="H5012"\w*,  
\q2 \w y|strong="H1571"\w* bate una mano contra \w la|strong="H1571"\w* otra.  
\q1 \w Que|strong="H1571"\w* se duplique \w y|strong="H1571"\w* triplique \w la|strong="H1571"\w* \w espada|strong="H2719"\w*,  
\q2 \w la|strong="H1571"\w* \w espada|strong="H2719"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* muertos.  
\q1 \w Es|strong="H3541"\w* \w la|strong="H1571"\w* \w espada|strong="H2719"\w* \w de|strong="H1121"\w* \w la|strong="H1571"\w* gran matanza,  
\q2 \w que|strong="H1571"\w* \w los|strong="H1121"\w* penetra en sus habitaciones.   
\q1
\v 15 \w Para|strong="H4616"\w* \w que|strong="H1121"\w* \w el|strong="H3605"\w* corazón desmaye,  
\q2 y \w los|strong="H1121"\w* tropiezos \w se|strong="H1961"\w* multipliquen,  
\q2 he puesto \w el|strong="H3605"\w* horror \w de|strong="H1121"\w* \w la|strong="H3605"\w* espada en \w todas|strong="H3605"\w* sus puertas.  
\q1 ¡Ah! Dispuesta \w está|strong="H1961"\w* \w para|strong="H4616"\w* relumbrar,  
\q2 preparada \w para|strong="H4616"\w* \w el|strong="H3605"\w* degüello.   
\q1
\v 16 Únete,  
\q2 ve \w a|strong="H3068"\w* \w la|strong="H1931"\w* derecha,  
\q1 organízate,  
\q2 ve \w a|strong="H3068"\w* \w la|strong="H1931"\w* izquierda,  
\q2 adondequiera \w que|strong="H1931"\w* tu \w filo|strong="H3027"\w* \w se|strong="H1931"\w* dirija.   
\q1
\v 17 \w Y|strong="H3068"\w* \w yo|strong="H3588"\w* \w también|strong="H3651"\w* batiré mis manos,  
\q2 \w y|strong="H3588"\w* haré descansar \w mi|strong="H1961"\w* ira.  
\q2 \w Yo|strong="H3588"\w*, Yahvé, he hablado’”.   
\p
\v 18 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* palabra \w de|strong="H3588"\w* Yahvé, diciendo:  
\v 19 “Tú, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, traza dos caminos por \w donde|strong="H1931"\w* venga \w la|strong="H1931"\w* \w espada|strong="H2719"\w* del \w rey|strong="H5221"\w* \w de|strong="H1121"\w* Babilonia. Ambos saldrán \w de|strong="H1121"\w* una \w misma|strong="H1931"\w* tierra; y pon una señal al comienzo del camino \w de|strong="H1121"\w* \w la|strong="H1931"\w* ciudad.  
\v 20 Señalarás \w el|strong="H5921"\w* camino \w para|strong="H4616"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w* venga \w a|strong="H3068"\w* Rabá \w de|strong="H5921"\w* \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* Amón, \w y|strong="H5921"\w* \w a|strong="H3068"\w* Judá, \w contra|strong="H5921"\w* Jerusalén \w la|strong="H5921"\w* fortificada.  
\v 21 \w Porque|strong="H6440"\w* el rey \w de|strong="H6440"\w* Babilonia se ha detenido \w en|strong="H3259"\w* la encrucijada, al principio \w de|strong="H6440"\w* los \w dos|strong="H6440"\w* caminos, para usar \w de|strong="H6440"\w* adivinación; ha sacudido las saetas, ha consultado \w a|strong="H3068"\w* sus terafines,\f + \fr 21:21 \ft Los terafines eran ídolos domésticos que podían estar asociados a los derechos de herencia de los bienes del hogar.\f* ha mirado el hígado.  
\v 22 \w En|strong="H5221"\w* su \w mano|strong="H3709"\w* derecha cayó \w la|strong="H1571"\w* suerte de Jerusalén, para plantar arietes, para abrir \w la|strong="H1571"\w* boca \w a|strong="H3068"\w* \w la|strong="H1571"\w* matanza, para levantar \w la|strong="H1571"\w* voz \w en|strong="H5221"\w* grito de guerra, para poner arietes contra las puertas, para levantar vallado \w y|strong="H1571"\w* edificar torres de asedio.  
\v 23 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w para|strong="H1961"\w* ellos \w como|strong="H1961"\w* adivinación mentirosa ante sus ojos, ya \w que|strong="H1697"\w* les han \w hecho|strong="H1961"\w* juramentos solemnes; pero él trae \w a|strong="H3068"\w* la memoria la iniquidad, \w para|strong="H1961"\w* \w que|strong="H1697"\w* \w sean|strong="H1961"\w* apresados.   
\p
\v 24 “\w Por|strong="H1870"\w* tanto, así dice \w el|strong="H1121"\w* Señor Yahvé: ‘\w Por|strong="H1870"\w* cuanto habéis hecho traer \w a|strong="H3068"\w* la memoria vuestra iniquidad, descubriendo vuestras traiciones, \w de|strong="H1121"\w* modo \w que|strong="H1121"\w* \w en|strong="H3318"\w* todas vuestras obras aparecen vuestros pecados; \w por|strong="H1870"\w* cuanto habéis venido \w en|strong="H3318"\w* memoria, seréis apresados con \w mano|strong="H3027"\w*.   
\p
\v 25 “‘\w Y|strong="H3068"\w* tú, profano \w e|strong="H3068"\w* impío príncipe \w de|strong="H1121"\w* Israel, cuyo \w día|strong="H1121"\w* ha llegado al tiempo \w de|strong="H1121"\w* la iniquidad final,  
\v 26 \w así|strong="H3588"\w* dice \w el|strong="H3588"\w* Señor Yahvé: Depón \w la|strong="H3588"\w* tiara, quita \w la|strong="H3588"\w* corona; esto \w no|strong="H3588"\w* será \w más|strong="H3588"\w* \w así|strong="H3588"\w*. Sea exaltado lo bajo, \w y|strong="H3588"\w* humillado lo alto.  
\v 27 \w A|strong="H3068"\w* ruina, \w a|strong="H3068"\w* ruina, \w a|strong="H3068"\w* ruina \w lo|strong="H5921"\w* reduciré, \w y|strong="H5921"\w* esto \w no|strong="H1961"\w* \w será|strong="H1961"\w* \w más|strong="H5921"\w*, \w hasta|strong="H5921"\w* \w que|strong="H5921"\w* \w venga|strong="H1961"\w* aquel \w a|strong="H3068"\w* quien corresponde \w el|strong="H5921"\w* \w derecho|strong="H3225"\w*, \w y|strong="H5921"\w* yo \w se|strong="H1961"\w* \w lo|strong="H5921"\w* entregaré’.   
\p
\v 28 “\w Y|strong="H3068"\w* tú, hijo \w de|strong="H5869"\w* hombre, profetiza y di: ‘\w Así|strong="H1931"\w* dice \w el|strong="H1931"\w* Señor Yahvé acerca \w de|strong="H5869"\w* \w los|strong="H1931"\w* hijos \w de|strong="H5869"\w* Amón y \w de|strong="H5869"\w* \w su|strong="H1931"\w* oprobio; dirás, \w pues|strong="H1931"\w*:  
\q1 «¡\w La|strong="H1931"\w* espada, \w la|strong="H1931"\w* espada \w está|strong="H1931"\w* desenvainada!  
\q2 \w Para|strong="H1961"\w* \w el|strong="H1931"\w* degüello \w está|strong="H1931"\w* pulida,  
\q1 \w para|strong="H1961"\w* consumir,  
\q2 \w para|strong="H1961"\w* ser \w como|strong="H1961"\w* un rayo;   
\q1
\v 29 \w mientras|strong="H3605"\w* te \w ven|strong="H7200"\w* vanas visiones,  
\q2 \w mientras|strong="H3605"\w* te adivinan mentira,  
\q1 \w para|strong="H3282"\w* ponerte sobre \w los|strong="H3605"\w* cuellos de \w los|strong="H3605"\w* impíos sentenciados \w a|strong="H3068"\w* muerte,  
\q2 cuyo día \w ha|strong="H3541"\w* llegado en \w el|strong="H3605"\w* tiempo de \w la|strong="H3605"\w* \w iniquidad|strong="H5771"\w* final.   
\q1
\v 30 Vuelve la espada \w a|strong="H3068"\w* su vaina.  
\q2 En el lugar donde fuiste creado,  
\q2 en la tierra donde naciste, te juzgaré.   
\q1
\v 31 \w Y|strong="H3068"\w* derramaré sobre ti mi ira;  
\q2 el fuego de mi enojo soplaré contra ti,  
\q1 \w y|strong="H3541"\w* te entregaré \w en|strong="H5493"\w* mano de hombres brutales,  
\q2 artífices de destrucción.   
\q1
\v 32 \w Serás|strong="H1961"\w* pasto del fuego;  
\q2 tu sangre \w quedará|strong="H1961"\w* \w en|strong="H5704"\w* medio \w de|strong="H5704"\w* \w la|strong="H1571"\w* tierra.  
\q1 \w No|strong="H3808"\w* \w habrá|strong="H1961"\w* \w más|strong="H1571"\w* memoria \w de|strong="H5704"\w* ti;  
\q2 \w porque|strong="H3808"\w* yo, Yahvé, he hablado»’”.   
\c 22
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Y|strong="H3068"\w* \w tú|strong="H8199"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, ¿\w juzgarás|strong="H8199"\w*? ¿\w Juzgarás|strong="H8199"\w* \w tú|strong="H8199"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* sanguinaria? Hazle conocer, pues, \w todas|strong="H3605"\w* sus \w abominaciones|strong="H8441"\w*.  
\v 3 Dirás: \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: ¡\w Ciudad|strong="H5892"\w* \w que|strong="H5921"\w* \w derrama|strong="H8210"\w* \w sangre|strong="H1818"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w sí|strong="H5921"\w* misma, \w para|strong="H5921"\w* \w que|strong="H5921"\w* venga su \w hora|strong="H6256"\w*, \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w hace|strong="H6213"\w* \w ídolos|strong="H1544"\w* \w contra|strong="H5921"\w* \w sí|strong="H5921"\w* misma \w para|strong="H5921"\w* contaminarse!  
\v 4 \w Por|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w que|strong="H5921"\w* \w derramaste|strong="H8210"\w* \w te|strong="H5921"\w* \w has|strong="H5414"\w* \w hecho|strong="H6213"\w* culpable, \w y|strong="H5921"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w ídolos|strong="H1544"\w* \w que|strong="H5921"\w* \w hiciste|strong="H6213"\w* \w te|strong="H5921"\w* \w has|strong="H5414"\w* \w contaminado|strong="H2930"\w*. \w Has|strong="H5414"\w* \w hecho|strong="H6213"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* acerquen tus \w días|strong="H3117"\w*, \w y|strong="H5921"\w* \w has|strong="H5414"\w* llegado \w al|strong="H5921"\w* término \w de|strong="H5921"\w* tus \w años|strong="H8141"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w te|strong="H5921"\w* he convertido \w en|strong="H5921"\w* \w oprobio|strong="H2781"\w* \w para|strong="H5704"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* escarnio \w para|strong="H5704"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* tierras.  
\v 5 Las \w que|strong="H4480"\w* están \w cerca|strong="H7138"\w* y las \w que|strong="H4480"\w* están \w lejos|strong="H7350"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w* \w se|strong="H4480"\w* burlarán \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, oh ciudad \w de|strong="H4480"\w* mala \w fama|strong="H8034"\w* y llena \w de|strong="H4480"\w* tumulto.   
\p
\v 6 “He \w aquí|strong="H2009"\w* \w que|strong="H1961"\w* \w los|strong="H1961"\w* \w príncipes|strong="H5387"\w* \w de|strong="H1818"\w* \w Israel|strong="H3478"\w*, cada uno según su poder, han \w estado|strong="H1961"\w* en ti \w para|strong="H4616"\w* derramar \w sangre|strong="H1818"\w*.  
\v 7 Al padre y \w a|strong="H3068"\w* la madre \w despreciaron|strong="H7043"\w* \w en|strong="H8432"\w* ti;\f + \fr 22:7 \ft Literalmente, se \fqa ha despreciado al padre y a la madre.\f* al \w extranjero|strong="H1616"\w* \w trataron|strong="H6213"\w* con \w violencia|strong="H6233"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ti; al \w huérfano|strong="H3490"\w* y \w a|strong="H3068"\w* la viuda vejaron \w en|strong="H8432"\w* ti.  
\v 8 Mis cosas \w sagradas|strong="H6944"\w* menospreciaste, y mis \w sábados|strong="H7676"\w* has \w profanado|strong="H2490"\w*.  
\v 9 Calumniadores \w hubo|strong="H1961"\w* \w en|strong="H8432"\w* ti \w para|strong="H4616"\w* derramar \w sangre|strong="H1818"\w*; y \w sobre|strong="H1961"\w* \w los|strong="H1961"\w* \w montes|strong="H2022"\w* comieron \w en|strong="H8432"\w* ti; \w hicieron|strong="H6213"\w* vilezas \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1818"\w* ti.  
\v 10 La \w desnudez|strong="H6172"\w* del padre \w descubrieron|strong="H1540"\w* en ti; \w a|strong="H3068"\w* la que estaba impura por su menstruación humillaron en ti.  
\v 11 Cada uno \w cometió|strong="H6213"\w* \w abominación|strong="H8441"\w* con la mujer de su \w prójimo|strong="H7453"\w*; \w el|strong="H6213"\w* \w otro|strong="H7453"\w* \w contaminó|strong="H2930"\w* con perversidad \w a|strong="H3068"\w* su \w nuera|strong="H3618"\w*; y \w el|strong="H6213"\w* \w otro|strong="H7453"\w* \w humilló|strong="H6031"\w* en ti \w a|strong="H3068"\w* su hermana, \w hija|strong="H1323"\w* de su padre.  
\v 12 En ti aceptaron sobornos \w para|strong="H4616"\w* derramar \w sangre|strong="H1818"\w*; \w tomaste|strong="H3947"\w* interés y \w usura|strong="H5392"\w*, y codiciosamente oprimiste \w a|strong="H3068"\w* tu \w prójimo|strong="H7453"\w* \w para|strong="H4616"\w* ganar, y \w de|strong="H1818"\w* mí te \w olvidaste|strong="H7911"\w*, \w dice|strong="H5002"\w* el Señor Yahvé.   
\p
\v 13 «\w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* batí mis \w manos|strong="H3709"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w avaricia|strong="H1215"\w* \w que|strong="H5921"\w* \w cometiste|strong="H6213"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w que|strong="H5921"\w* \w hubo|strong="H1961"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*.  
\v 14 ¿\w Resistirá|strong="H5975"\w* \w tu|strong="H6213"\w* \w corazón|strong="H3820"\w*, \w o|strong="H3068"\w* serán fuertes tus \w manos|strong="H3027"\w* \w en|strong="H5975"\w* los \w días|strong="H3117"\w* \w en|strong="H5975"\w* \w que|strong="H3117"\w* \w yo|strong="H6213"\w* proceda contra ti? \w Yo|strong="H6213"\w*, Yahvé, he \w hablado|strong="H1696"\w* y \w lo|strong="H6213"\w* \w haré|strong="H6213"\w*.  
\v 15 \w Te|strong="H4480"\w* dispersaré \w por|strong="H4480"\w* las \w naciones|strong="H1471"\w* y \w te|strong="H4480"\w* \w esparciré|strong="H2219"\w* \w por|strong="H4480"\w* las tierras, y haré fenecer \w en|strong="H4480"\w* \w ti|strong="H4480"\w* tu \w inmundicia|strong="H2932"\w*.  
\v 16 \w Y|strong="H3068"\w* serás profanada \w en|strong="H3588"\w* ti misma ante \w los|strong="H3588"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w*; \w y|strong="H3588"\w* \w sabrás|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé».   
\p
\v 17 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 18 «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* me ha convertido \w en|strong="H8432"\w* \w escoria|strong="H5509"\w*; \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w son|strong="H1961"\w* bronce, estaño, \w hierro|strong="H1270"\w* y plomo \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del horno; \w escorias|strong="H5509"\w* \w de|strong="H1121"\w* \w plata|strong="H3701"\w* \w son|strong="H1961"\w*.  
\v 19 \w Por|strong="H3282"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H3605"\w* Señor Yahvé: \w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w todos|strong="H3605"\w* vosotros os habéis convertido \w en|strong="H8432"\w* \w escorias|strong="H5509"\w*, he \w aquí|strong="H3541"\w* \w que|strong="H1961"\w* yo os reuniré \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de Jerusalén.  
\v 20 \w Como|strong="H5921"\w* \w se|strong="H5921"\w* junta \w plata|strong="H3701"\w*, bronce, \w hierro|strong="H1270"\w*, plomo \w y|strong="H5921"\w* estaño \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H5921"\w* horno, \w para|strong="H5921"\w* encender fuego \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* fundirlos, \w así|strong="H3651"\w* \w os|strong="H5921"\w* \w juntaré|strong="H6908"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w furor|strong="H2534"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w ira|strong="H2534"\w*, \w y|strong="H5921"\w* \w os|strong="H5921"\w* pondré allí \w y|strong="H5921"\w* \w os|strong="H5921"\w* fundiré.  
\v 21 \w Sí|strong="H5921"\w*, \w os|strong="H5921"\w* reuniré \w y|strong="H5921"\w* soplaré \w sobre|strong="H5921"\w* vosotros \w en|strong="H5921"\w* \w el|strong="H5921"\w* fuego \w de|strong="H5921"\w* \w mi|strong="H5921"\w* ira, \w y|strong="H5921"\w* seréis fundidos \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*.  
\v 22 \w Como|strong="H3588"\w* \w se|strong="H3045"\w* funde \w la|strong="H5921"\w* \w plata|strong="H3701"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H5921"\w* horno, \w así|strong="H3651"\w* seréis fundidos \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, he \w derramado|strong="H8210"\w* \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* vosotros».   
\p
\v 23 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 24 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, di \w a|strong="H3068"\w* Jerusalén: Tú \w eres|strong="H1931"\w* tierra \w no|strong="H3808"\w* limpiada, \w ni|strong="H3808"\w* rociada con lluvia en \w el|strong="H1931"\w* \w día|strong="H3117"\w* del \w furor|strong="H2195"\w*.  
\v 25 Hay \w conjuración|strong="H7195"\w* de sus \w profetas|strong="H5030"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ella, \w como|strong="H7580"\w* león rugiente que arrebata la \w presa|strong="H5315"\w*; devoraron \w almas|strong="H5315"\w*, \w tomaron|strong="H3947"\w* \w haciendas|strong="H2633"\w* y \w honra|strong="H3366"\w*, \w multiplicaron|strong="H7235"\w* sus viudas \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ella.  
\v 26 Sus \w sacerdotes|strong="H3548"\w* \w violentaron|strong="H2554"\w* \w mi|strong="H2490"\w* \w ley|strong="H8451"\w* y \w profanaron|strong="H2490"\w* mis \w cosas|strong="H3045"\w* \w santas|strong="H6944"\w*; \w no|strong="H3808"\w* hicieron diferencia \w entre|strong="H8432"\w* \w lo|strong="H3808"\w* \w santo|strong="H6944"\w* y \w lo|strong="H3808"\w* profano, \w ni|strong="H3808"\w* enseñaron \w a|strong="H3068"\w* distinguir \w entre|strong="H8432"\w* \w lo|strong="H3808"\w* impuro y \w lo|strong="H3808"\w* \w limpio|strong="H2889"\w*; y \w de|strong="H5869"\w* mis \w sábados|strong="H7676"\w* escondieron sus \w ojos|strong="H5869"\w*, y he sido \w profanado|strong="H2490"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5869"\w* ellos.  
\v 27 Sus \w príncipes|strong="H8269"\w* en \w medio|strong="H7130"\w* \w de|strong="H8269"\w* ella son como \w lobos|strong="H2061"\w* \w que|strong="H4616"\w* arrebatan la \w presa|strong="H5315"\w*, \w derramando|strong="H8210"\w* \w sangre|strong="H1818"\w* \w para|strong="H4616"\w* destruir las \w almas|strong="H5315"\w*, \w a|strong="H3068"\w* fin \w de|strong="H8269"\w* obtener ganancias deshonestas.  
\v 28 \w Y|strong="H3068"\w* sus \w profetas|strong="H5030"\w* la recubrieron con lodo suelto, viéndoles \w vanidad|strong="H7723"\w* \w y|strong="H3541"\w* adivinándoles \w mentira|strong="H3577"\w*, \w diciendo|strong="H1696"\w*: ‘\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H5030"\w* \w Señor|strong="H3068"\w* Yahvé’, cuando Yahvé \w no|strong="H3808"\w* había \w hablado|strong="H1696"\w*.  
\v 29 El \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* la tierra \w usaba|strong="H6233"\w* \w de|strong="H5971"\w* opresión y cometía \w robo|strong="H1497"\w*, al \w afligido|strong="H6041"\w* y menesteroso hacía \w violencia|strong="H6233"\w*, y al \w extranjero|strong="H1616"\w* oprimía \w sin|strong="H3808"\w* \w derecho|strong="H4941"\w*.   
\p
\v 30 «\w Y|strong="H3068"\w* \w busqué|strong="H1245"\w* \w entre|strong="H3808"\w* \w ellos|strong="H1992"\w* un hombre \w que|strong="H3808"\w* levantase \w vallado|strong="H1443"\w* y \w que|strong="H3808"\w* \w se|strong="H3808"\w* pusiese \w en|strong="H5975"\w* la brecha \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H1245"\w*, \w a|strong="H3068"\w* favor \w de|strong="H6440"\w* la tierra, para \w que|strong="H3808"\w* yo \w no|strong="H3808"\w* la \w destruyese|strong="H7843"\w*; y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w hallé|strong="H4672"\w*.  
\v 31 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, he \w derramado|strong="H8210"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w mi|strong="H5921"\w* ira; \w con|strong="H5921"\w* \w el|strong="H5921"\w* fuego \w de|strong="H5921"\w* \w mi|strong="H5921"\w* ira \w los|strong="H5921"\w* he consumido; he hecho recaer su propio \w camino|strong="H1870"\w* \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor Yahvé».   
\c 23
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w hubo|strong="H1961"\w* \w dos|strong="H8147"\w* \w mujeres|strong="H1323"\w*, \w hijas|strong="H1323"\w* \w de|strong="H1121"\w* una misma madre.  
\v 3 \w Estas|strong="H6213"\w* \w fornicaron|strong="H2181"\w* en \w Egipto|strong="H4714"\w*; en su \w juventud|strong="H5271"\w* \w fornicaron|strong="H2181"\w*. \w Allí|strong="H8033"\w* fueron apretados sus \w pechos|strong="H7699"\w*, y \w allí|strong="H8033"\w* fueron estrujados sus pezones virginales.  
\v 4 Sus \w nombres|strong="H8034"\w* \w eran|strong="H1961"\w* Oholá la \w mayor|strong="H1419"\w* y Oholibá su hermana. \w Fueron|strong="H1961"\w* mías, y dieron \w a|strong="H3068"\w* luz \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*. \w Y|strong="H3068"\w* en cuanto \w a|strong="H3068"\w* sus \w nombres|strong="H8034"\w*: \w Samaria|strong="H8111"\w* \w es|strong="H1961"\w* Oholá, y Jerusalén, Oholibá.   
\p
\v 5 “Oholá \w fornicó|strong="H2181"\w* aun estando \w en|strong="H5921"\w* \w mi|strong="H5921"\w* poder; \w y|strong="H5921"\w* \w se|strong="H5921"\w* apasionó \w de|strong="H5921"\w* sus amantes, \w los|strong="H5921"\w* asirios, sus \w vecinos|strong="H7138"\w*,  
\v 6 \w vestidos|strong="H3847"\w* \w de|strong="H3847"\w* azul, \w gobernadores|strong="H6346"\w* y \w capitanes|strong="H5461"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* jóvenes codiciables, \w jinetes|strong="H6571"\w* \w que|strong="H3605"\w* montaban \w a|strong="H3068"\w* \w caballo|strong="H5483"\w*.  
\v 7 \w Y|strong="H3068"\w* \w entregó|strong="H5414"\w* sus \w fornicaciones|strong="H8457"\w* \w a|strong="H3068"\w* \w ellos|strong="H5921"\w*, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w más|strong="H5921"\w* \w escogidos|strong="H4005"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Asiria; \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w todos|strong="H3605"\w* \w aquellos|strong="H3605"\w* \w de|strong="H5921"\w* quienes \w se|strong="H5921"\w* enamoró, \w se|strong="H5921"\w* \w contaminó|strong="H2930"\w* \w con|strong="H5921"\w* \w todos|strong="H3605"\w* sus \w ídolos|strong="H1544"\w*.  
\v 8 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w dejó|strong="H5800"\w* \w sus|strong="H1992"\w* \w fornicaciones|strong="H8457"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*; \w porque|strong="H3588"\w* \w se|strong="H5921"\w* acostaron \w con|strong="H5921"\w* \w ella|strong="H5921"\w* \w en|strong="H5921"\w* \w su|strong="H1992"\w* \w juventud|strong="H5271"\w*, \w y|strong="H3588"\w* \w ellos|strong="H1992"\w* estrujaron \w sus|strong="H1992"\w* pezones virginales \w y|strong="H3588"\w* \w derramaron|strong="H8210"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* \w su|strong="H1992"\w* \w fornicación|strong="H8457"\w*.   
\p
\v 9 “\w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w la|strong="H5921"\w* \w entregué|strong="H5414"\w* \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* sus amantes, \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* asirios, \w de|strong="H5921"\w* \w los|strong="H1121"\w* cuales \w se|strong="H5921"\w* había enamorado.  
\v 10 \w Ellos|strong="H1992"\w* \w descubrieron|strong="H1540"\w* \w su|strong="H1992"\w* \w desnudez|strong="H6172"\w*; \w tomaron|strong="H3947"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w* y \w sus|strong="H1992"\w* \w hijas|strong="H1323"\w*, y \w a|strong="H3068"\w* ella la \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*. \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* ser renombrada entre \w las|strong="H1992"\w* \w mujeres|strong="H1323"\w*, \w pues|strong="H1961"\w* en ella ejecutaron \w juicios|strong="H8196"\w*.   
\p
\v 11 “\w Viéndolo|strong="H7200"\w* su hermana Oholibá, \w se|strong="H4480"\w* corrompió \w en|strong="H4480"\w* sus amores \w más|strong="H4480"\w* \w que|strong="H4480"\w* \w ella|strong="H4480"\w*, y sus \w fornicaciones|strong="H8457"\w* fueron mayores \w que|strong="H4480"\w* las \w fornicaciones|strong="H8457"\w* \w de|strong="H4480"\w* su hermana.  
\v 12 Se enamoró \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* asirios, \w gobernadores|strong="H6346"\w* y \w capitanes|strong="H5461"\w*, sus \w vecinos|strong="H7138"\w*, \w vestidos|strong="H3847"\w* con ropas lujosas, \w jinetes|strong="H6571"\w* \w que|strong="H1121"\w* montaban \w a|strong="H3068"\w* \w caballo|strong="H5483"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* jóvenes codiciables.  
\v 13 \w Y|strong="H3068"\w* \w vi|strong="H7200"\w* \w que|strong="H3588"\w* se \w había|strong="H3588"\w* \w contaminado|strong="H2930"\w*; \w el|strong="H3588"\w* mismo \w camino|strong="H1870"\w* siguieron las \w dos|strong="H8147"\w*.   
\p
\v 14 “Pero \w esta|strong="H5921"\w* aumentó sus \w fornicaciones|strong="H8457"\w*; \w pues|strong="H7200"\w* cuando \w vio|strong="H7200"\w* hombres \w pintados|strong="H2707"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w pared|strong="H7023"\w*, \w imágenes|strong="H6754"\w* \w de|strong="H5921"\w* \w caldeos|strong="H3778"\w* \w pintadas|strong="H2710"\w* \w de|strong="H5921"\w* bermellón,  
\v 15 \w ceñidos|strong="H2289"\w* \w los|strong="H1121"\w* \w lomos|strong="H4975"\w* con talabartes, y con tiaras \w de|strong="H1121"\w* colores en sus \w cabezas|strong="H7218"\w*, teniendo \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w apariencia|strong="H4758"\w* \w de|strong="H1121"\w* \w capitanes|strong="H7218"\w*, \w a|strong="H3068"\w* \w semejanza|strong="H1823"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Babilonia, cuya tierra nativa es Caldea,  
\v 16 \w se|strong="H5921"\w* enamoró \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* primera \w vista|strong="H4758"\w*, \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* Caldea.  
\v 17 \w Y|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Babilonia vinieron \w a|strong="H3068"\w* ella al lecho \w de|strong="H1121"\w* \w los|strong="H1992"\w* amores, y la \w contaminaron|strong="H2930"\w* \w con|strong="H4904"\w* \w sus|strong="H1992"\w* \w fornicaciones|strong="H8457"\w*; y ella \w se|strong="H1992"\w* \w contaminó|strong="H2930"\w* \w con|strong="H4904"\w* \w ellos|strong="H1992"\w*, y \w su|strong="H1992"\w* \w alma|strong="H5315"\w* \w se|strong="H1992"\w* hastió \w de|strong="H1121"\w* \w ellos|strong="H1992"\w*.  
\v 18 Así \w descubrió|strong="H1540"\w* sus \w fornicaciones|strong="H8457"\w* \w y|strong="H5921"\w* \w descubrió|strong="H1540"\w* su \w desnudez|strong="H6172"\w*; entonces \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w se|strong="H5921"\w* hastió \w de|strong="H5921"\w* \w ella|strong="H5921"\w*, \w como|strong="H5921"\w* \w se|strong="H5921"\w* había hastiado \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w de|strong="H5921"\w* su hermana.  
\v 19 Sin embargo, ella \w multiplicó|strong="H7235"\w* sus \w fornicaciones|strong="H8457"\w*, trayendo \w a|strong="H3068"\w* la \w memoria|strong="H2142"\w* los \w días|strong="H3117"\w* de su \w juventud|strong="H5271"\w*, \w cuando|strong="H3117"\w* fornicaba en la tierra de \w Egipto|strong="H4714"\w*.  
\v 20 \w Y|strong="H3068"\w* \w se|strong="H5921"\w* apasionó \w de|strong="H5921"\w* sus amantes, cuya \w carne|strong="H1320"\w* es \w como|strong="H5921"\w* \w carne|strong="H1320"\w* \w de|strong="H5921"\w* \w asnos|strong="H2543"\w*, \w y|strong="H5921"\w* cuyo \w flujo|strong="H2231"\w* es \w como|strong="H5921"\w* \w flujo|strong="H2231"\w* \w de|strong="H5921"\w* \w caballos|strong="H5483"\w*.  
\v 21 Así echaste de menos la lujuria de \w tu|strong="H6213"\w* \w juventud|strong="H5271"\w*, cuando los \w egipcios|strong="H4714"\w* estrujaban tus pezones \w a|strong="H3068"\w* causa de tus \w pechos|strong="H7699"\w* juveniles.   
\p
\v 22 “\w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, Oholibá, \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* \w yo|strong="H5315"\w* suscitaré \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w a|strong="H3068"\w* tus amantes, \w de|strong="H5921"\w* \w los|strong="H1992"\w* cuales \w se|strong="H5921"\w* hastió tu \w alma|strong="H5315"\w*, \w y|strong="H5921"\w* \w los|strong="H1992"\w* traeré \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w de|strong="H5921"\w* todos \w lados|strong="H5439"\w*:  
\v 23 \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Babilonia y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w caldeos|strong="H3778"\w*, \w a|strong="H3068"\w* Pecod, \w a|strong="H3068"\w* Soa y \w a|strong="H3068"\w* Coa, y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Asiria con \w ellos|strong="H3605"\w*; jóvenes codiciables, \w gobernadores|strong="H6346"\w* y \w capitanes|strong="H6346"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w*, grandes señores y \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* renombre, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* jinetes \w a|strong="H3068"\w* \w caballo|strong="H5483"\w*.  
\v 24 \w Y|strong="H3068"\w* vendrán \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w con|strong="H5921"\w* armas, \w carros|strong="H7393"\w* \w y|strong="H5921"\w* \w carretas|strong="H7393"\w*, \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w multitud|strong="H6951"\w* \w de|strong="H5921"\w* \w pueblos|strong="H5971"\w*; \w pondrán|strong="H7760"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w escudo|strong="H4043"\w*, adarga \w y|strong="H5921"\w* yelmo \w alrededor|strong="H5439"\w*. \w Y|strong="H3068"\w* yo \w pondré|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w el|strong="H5921"\w* \w juicio|strong="H4941"\w*, \w y|strong="H5921"\w* \w ellos|strong="H5921"\w* \w te|strong="H5921"\w* \w juzgarán|strong="H8199"\w* \w según|strong="H5921"\w* sus leyes.  
\v 25 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* mi \w celo|strong="H7068"\w* contra ti, y actuarán contigo con \w furor|strong="H2534"\w*; te quitarán la nariz y \w las|strong="H1992"\w* orejas, y \w lo|strong="H6213"\w* \w que|strong="H1121"\w* te quede \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*. \w Tomarán|strong="H3947"\w* \w a|strong="H3068"\w* tus \w hijos|strong="H1121"\w* y \w a|strong="H3068"\w* tus \w hijas|strong="H1323"\w*, y \w tu|strong="H6213"\w* remanente \w será|strong="H5414"\w* consumido \w por|strong="H5414"\w* \w el|strong="H5307"\w* fuego.  
\v 26 Te despojarán de tus vestidos y se llevarán tus hermosas \w alhajas|strong="H3627"\w*.  
\v 27 \w Y|strong="H3068"\w* haré cesar \w de|strong="H4480"\w* \w ti|strong="H4480"\w* tu lujuria y tu \w fornicación|strong="H2184"\w* \w de|strong="H4480"\w* la tierra \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*; y \w no|strong="H3808"\w* \w levantarás|strong="H5375"\w* ya tus \w ojos|strong="H5869"\w* \w hacia|strong="H4480"\w* \w ellos|strong="H4480"\w*, \w ni|strong="H3808"\w* \w te|strong="H5869"\w* acordarás \w más|strong="H5750"\w* \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 28 “\w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice \w el|strong="H3588"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H3588"\w* \w entrego|strong="H5414"\w* \w en|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w aquellos|strong="H1992"\w* \w a|strong="H3068"\w* quienes \w aborreces|strong="H8130"\w*, \w en|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w aquellos|strong="H1992"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* cuales \w se|strong="H1992"\w* hastió tu \w alma|strong="H5315"\w*.  
\v 29 \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* obrarán contigo con \w odio|strong="H8135"\w*, y te quitarán \w todo|strong="H3605"\w* \w el|strong="H3605"\w* fruto de \w tu|strong="H6213"\w* \w trabajo|strong="H3018"\w*, y te dejarán \w desnuda|strong="H6181"\w* y \w descubierta|strong="H1540"\w*; y se \w descubrirá|strong="H1540"\w* \w la|strong="H3605"\w* \w desnudez|strong="H6172"\w* de tus \w fornicaciones|strong="H8457"\w*, y \w tu|strong="H6213"\w* lujuria y tus \w fornicaciones|strong="H8457"\w*.  
\v 30 \w Estas|strong="H6213"\w* cosas \w se|strong="H5921"\w* \w harán|strong="H6213"\w* \w contigo|strong="H5921"\w*, \w porque|strong="H5921"\w* \w fornicaste|strong="H2181"\w* \w en|strong="H5921"\w* pos \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, \w con|strong="H5921"\w* \w las|strong="H5921"\w* cuales \w te|strong="H5921"\w* contaminaste \w en|strong="H5921"\w* sus \w ídolos|strong="H1544"\w*.  
\v 31 En el \w camino|strong="H1870"\w* \w de|strong="H5414"\w* tu hermana \w anduviste|strong="H1980"\w*; yo, pues, \w pondré|strong="H5414"\w* su copa en tu \w mano|strong="H3027"\w*.   
\p
\v 32 “\w Así|strong="H3541"\w* dice el Señor Yahvé:  
\q1 \w Beberás|strong="H8354"\w* la honda \w y|strong="H3541"\w* ancha copa de tu hermana;  
\q2 \w serás|strong="H1961"\w* objeto de risa \w y|strong="H3541"\w* de escarnio;  
\q2 cabe mucho en ella.   
\q1
\v 33 Te llenarás de embriaguez y de \w dolor|strong="H3015"\w*,  
\q2 con la copa de \w espanto|strong="H8047"\w* y de \w asolamiento|strong="H8077"\w*,  
\q2 con la copa de tu hermana \w Samaria|strong="H8111"\w*.   
\q1
\v 34 \w La|strong="H3588"\w* \w beberás|strong="H8354"\w*, \w pues|strong="H3588"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* apurarás,  
\q2 \w y|strong="H3588"\w* quebrarás sus tiestos,  
\q2 \w y|strong="H3588"\w* \w te|strong="H3588"\w* arrancarás \w los|strong="H3588"\w* \w pechos|strong="H7699"\w*;  
\m \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* he \w hablado|strong="H1696"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé.   
\p
\v 35 «\w Por|strong="H3282"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H1571"\w* Señor Yahvé: \w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* te has olvidado \w de|strong="H7911"\w* \w mí|strong="H5375"\w*, \w y|strong="H1571"\w* \w me|strong="H3541"\w* has \w echado|strong="H7993"\w* tras tus \w espaldas|strong="H1458"\w*, \w lleva|strong="H5375"\w* tú \w también|strong="H1571"\w* tu lujuria \w y|strong="H1571"\w* tus \w fornicaciones|strong="H8457"\w*».   
\p
\v 36 \w Y|strong="H3068"\w* me \w dijo|strong="H5046"\w* Yahvé: “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, ¿\w juzgarás|strong="H8199"\w* \w tú|strong="H8199"\w* \w a|strong="H3068"\w* Oholá y \w a|strong="H3068"\w* Oholibá? Declárales, pues, sus \w abominaciones|strong="H8441"\w*.  
\v 37 \w Porque|strong="H3588"\w* han adulterado, \w y|strong="H1571"\w* hay \w sangre|strong="H1818"\w* \w en|strong="H3588"\w* sus \w manos|strong="H3027"\w*; han fornicado \w con|strong="H3588"\w* sus \w ídolos|strong="H1544"\w*, \w y|strong="H1571"\w* \w aun|strong="H1571"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w que|strong="H3588"\w* dieron \w a|strong="H3068"\w* luz \w para|strong="H3588"\w* mí, \w los|strong="H1121"\w* hicieron \w pasar|strong="H5674"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* fuego \w para|strong="H3588"\w* \w que|strong="H3588"\w* fuesen consumidos.  
\v 38 \w Aún|strong="H5750"\w* \w esto|strong="H2063"\w* \w más|strong="H5750"\w* me \w hicieron|strong="H6213"\w*: \w contaminaron|strong="H2490"\w* \w mi|strong="H2490"\w* \w santuario|strong="H4720"\w* \w en|strong="H5750"\w* \w el|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*, y \w profanaron|strong="H2490"\w* mis \w sábados|strong="H7676"\w*.  
\v 39 \w Pues|strong="H1931"\w* habiendo sacrificado \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w ídolos|strong="H1544"\w*, entraban \w en|strong="H8432"\w* \w mi|strong="H2009"\w* \w santuario|strong="H4720"\w* \w el|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w* para contaminarlo; \w y|strong="H3541"\w* he \w aquí|strong="H2009"\w*, \w así|strong="H3541"\w* \w hicieron|strong="H6213"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* \w mi|strong="H2009"\w* \w casa|strong="H1004"\w*.   
\p
\v 40 “\w Además|strong="H3588"\w*, \w enviaron|strong="H7971"\w* \w por|strong="H3588"\w* hombres \w que|strong="H3588"\w* venían \w de|strong="H3588"\w* lejos, \w a|strong="H3068"\w* \w los|strong="H3588"\w* cuales \w había|strong="H3588"\w* sido \w enviado|strong="H7971"\w* \w mensajero|strong="H4397"\w*; \w y|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* vinieron; \w y|strong="H3588"\w* \w por|strong="H3588"\w* amor \w a|strong="H3068"\w* ellos \w te|strong="H5869"\w* lavaste, \w y|strong="H3588"\w* pintaste tus \w ojos|strong="H5869"\w* \w con|strong="H3588"\w* antimonio, \w y|strong="H3588"\w* \w te|strong="H5869"\w* ataviaste \w con|strong="H3588"\w* adornos;  
\v 41 \w y|strong="H5921"\w* \w te|strong="H5921"\w* sentaste \w sobre|strong="H5921"\w* un suntuoso lecho, \w y|strong="H5921"\w* una \w mesa|strong="H7979"\w* preparada \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* cual \w pusiste|strong="H7760"\w* \w mi|strong="H5921"\w* incienso \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w aceite|strong="H8081"\w*.   
\p
\v 42 “\w Y|strong="H3068"\w* \w se|strong="H5921"\w* oyó \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* \w multitud|strong="H1995"\w* despreocupada; \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* \w la|strong="H5921"\w* plebe fueron traídos borrachos \w del|strong="H5921"\w* \w desierto|strong="H4057"\w*, \w y|strong="H5921"\w* \w pusieron|strong="H5414"\w* \w brazaletes|strong="H6781"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w ellas|strong="H5921"\w*, \w y|strong="H5921"\w* hermosas \w coronas|strong="H5850"\w* \w sobre|strong="H5921"\w* sus \w cabezas|strong="H7218"\w*.  
\v 43 \w Y|strong="H3068"\w* dije respecto \w a|strong="H3068"\w* \w la|strong="H1931"\w* envejecida en adulterios: ¿\w Fornicarán|strong="H2181"\w* \w ahora|strong="H6258"\w* con \w ella|strong="H1931"\w*, y \w ella|strong="H1931"\w* con \w ellos|strong="H1931"\w*?  
\v 44 \w Y|strong="H3068"\w* entraron \w a|strong="H3068"\w* ella \w como|strong="H3651"\w* quien entra \w a|strong="H3068"\w* una \w ramera|strong="H2181"\w*; \w así|strong="H3651"\w* entraron \w a|strong="H3068"\w* Oholá y \w a|strong="H3068"\w* Oholibá, mujeres \w depravadas|strong="H2154"\w*.  
\v 45 \w Por|strong="H3588"\w* tanto, \w los|strong="H1992"\w* hombres \w justos|strong="H6662"\w* \w las|strong="H1992"\w* \w juzgarán|strong="H8199"\w* según \w la|strong="H3588"\w* ley \w de|strong="H3588"\w* \w las|strong="H1992"\w* \w adúlteras|strong="H5003"\w*, \w y|strong="H3588"\w* según \w la|strong="H3588"\w* ley \w de|strong="H3588"\w* \w las|strong="H1992"\w* \w que|strong="H3588"\w* derraman \w sangre|strong="H1818"\w*; \w porque|strong="H3588"\w* \w son|strong="H3588"\w* \w adúlteras|strong="H5003"\w*, \w y|strong="H3588"\w* \w hay|strong="H2007"\w* \w sangre|strong="H1818"\w* \w en|strong="H3588"\w* \w sus|strong="H1992"\w* \w manos|strong="H3027"\w*.   
\p
\v 46 «\w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: \w Yo|strong="H3588"\w* \w haré|strong="H5414"\w* \w subir|strong="H5927"\w* \w contra|strong="H5921"\w* \w ellas|strong="H5921"\w* una \w multitud|strong="H6951"\w*, \w y|strong="H3588"\w* \w las|strong="H5921"\w* \w entregaré|strong="H5414"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* turbación \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* rapiña.  
\v 47 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w multitud|strong="H6951"\w* \w las|strong="H5921"\w* apedreará, \w y|strong="H5921"\w* \w las|strong="H5921"\w* atravesarán \w con|strong="H5921"\w* sus \w espadas|strong="H2719"\w*; \w matarán|strong="H2026"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* sus \w hijas|strong="H1323"\w*, \w y|strong="H5921"\w* \w quemarán|strong="H8313"\w* sus \w casas|strong="H1004"\w* \w con|strong="H5921"\w* fuego.  
\v 48 \w Y|strong="H3068"\w* \w haré|strong="H6213"\w* cesar \w la|strong="H3605"\w* lujuria \w de|strong="H4480"\w* \w la|strong="H3605"\w* tierra, \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w todas|strong="H3605"\w* las mujeres escarmienten y \w no|strong="H3808"\w* \w hagan|strong="H6213"\w* según vuestras obscenidades.  
\v 49 \w Y|strong="H3068"\w* cargarán vuestra lujuria \w sobre|strong="H5921"\w* vosotras, \w y|strong="H3588"\w* \w llevaréis|strong="H5375"\w* \w los|strong="H5921"\w* \w pecados|strong="H2399"\w* \w de|strong="H5921"\w* vuestros \w ídolos|strong="H1544"\w*; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy \w el|strong="H5921"\w* Señor Yahvé».   
\c 24
\p
\v 1 En el \w noveno|strong="H8671"\w* \w año|strong="H8141"\w*, en el \w mes|strong="H2320"\w* \w décimo|strong="H6224"\w*, \w a|strong="H3068"\w* \w los|strong="H1961"\w* diez días del \w mes|strong="H2320"\w*, \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w escribe|strong="H3789"\w* la fecha del \w día|strong="H3117"\w*, \w de|strong="H1121"\w* \w este|strong="H2088"\w* \w mismo|strong="H6106"\w* \w día|strong="H3117"\w*. \w El|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia ha puesto sitio \w a|strong="H3068"\w* Jerusalén \w este|strong="H2088"\w* \w mismo|strong="H6106"\w* \w día|strong="H3117"\w*.  
\v 3 \w Y|strong="H3068"\w* \w profiere|strong="H4912"\w* una \w parábola|strong="H4912"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w*, \w y|strong="H1571"\w* diles: ‘\w Así|strong="H3541"\w* dice \w el|strong="H1571"\w* Señor Yahvé:  
\q1 «\w Pon|strong="H8239"\w* \w la|strong="H1571"\w* \w olla|strong="H5518"\w*,  
\q2 \w ponla|strong="H8239"\w*,  
\q2 \w y|strong="H1571"\w* echa \w también|strong="H1571"\w* \w agua|strong="H4325"\w* en ella.   
\q1
\v 4 Junta en \w ella|strong="H3605"\w* sus presas,  
\q2 \w todas|strong="H3605"\w* las \w buenas|strong="H2896"\w* presas:  
\q2 \w pierna|strong="H3409"\w* y espaldilla.  
\q2 Llénala de \w los|strong="H3605"\w* \w huesos|strong="H6106"\w* \w escogidos|strong="H4005"\w*.   
\q1
\v 5 \w Toma|strong="H3947"\w* lo mejor del \w rebaño|strong="H6629"\w*,  
\q2 \w y|strong="H1571"\w* apila \w también|strong="H1571"\w* \w la|strong="H1571"\w* leña \w bajo|strong="H8478"\w* \w la|strong="H1571"\w* olla.  
\q1 Hazla hervir bien,  
\q2 \w y|strong="H1571"\w* \w que|strong="H1571"\w* se cuezan sus \w huesos|strong="H6106"\w* \w dentro|strong="H8432"\w* \w de|strong="H8478"\w* ella».   
\m
\v 6 “‘\w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé:  
\q1 ¡Ay \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* sanguinaria,  
\q2 \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w olla|strong="H5518"\w* \w que|strong="H4480"\w* tiene herrumbre,  
\q2 \w y|strong="H5921"\w* cuya herrumbre \w no|strong="H3808"\w* \w se|strong="H5921"\w* \w ha|strong="H3541"\w* quitado!  
\q1 \w Sácala|strong="H3318"\w* presa \w por|strong="H5921"\w* presa,  
\q2 \w sin|strong="H3808"\w* \w echar|strong="H5307"\w* \w suertes|strong="H1486"\w* \w sobre|strong="H5921"\w* \w ella|strong="H4480"\w*.   
\b  
\q1
\v 7 «‘\w Porque|strong="H3588"\w* \w su|strong="H3588"\w* \w sangre|strong="H1818"\w* \w está|strong="H1961"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*;  
\q2 \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w piedra|strong="H5553"\w* desnuda \w la|strong="H5921"\w* \w puso|strong="H7760"\w*.  
\q1 \w No|strong="H3808"\w* \w la|strong="H5921"\w* \w derramó|strong="H8210"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w tierra|strong="H6083"\w*,  
\q2 \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w* \w la|strong="H5921"\w* cubriese.   
\q1
\v 8 \w Para|strong="H5921"\w* hacer \w subir|strong="H5927"\w* \w la|strong="H5921"\w* \w ira|strong="H2534"\w* \w y|strong="H5921"\w* \w para|strong="H5921"\w* tomar \w venganza|strong="H5359"\w*,  
\q2 yo he \w puesto|strong="H5414"\w* su \w sangre|strong="H1818"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w piedra|strong="H5553"\w* desnuda,  
\q2 \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w no|strong="H5921"\w* sea cubierta».   
\m
\v 9 “‘\w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H1571"\w* Señor Yahvé:  
\q1 ¡Ay \w de|strong="H1818"\w* \w la|strong="H1571"\w* \w ciudad|strong="H5892"\w* sanguinaria!  
\q2 Yo \w también|strong="H1571"\w* \w haré|strong="H1431"\w* \w grande|strong="H1431"\w* \w la|strong="H1571"\w* hoguera.   
\q1
\v 10 Amontona la \w leña|strong="H6086"\w*,  
\q2 enciende el fuego,  
\q1 consume la \w carne|strong="H1320"\w*.  
\q2 Espesa el caldo,  
\q2 y que se quemen los \w huesos|strong="H6106"\w*.   
\q1
\v 11 Ponla luego \w vacía|strong="H7386"\w* \w sobre|strong="H5921"\w* sus \w brasas|strong="H1513"\w*,  
\q2 \w para|strong="H4616"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* caldee,  
\q1 \w y|strong="H5921"\w* \w se|strong="H5921"\w* queme su bronce,  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* funda \w en|strong="H5921"\w* \w ella|strong="H5921"\w* su suciedad,  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* consuma su herrumbre.   
\q1
\v 12 \w En|strong="H4480"\w* vano \w se|strong="H4480"\w* \w ha|strong="H3808"\w* \w cansado|strong="H3811"\w* el trabajo;  
\q2 \w no|strong="H3808"\w* \w salió|strong="H3318"\w* \w de|strong="H4480"\w* \w ella|strong="H4480"\w* su \w mucha|strong="H7227"\w* herrumbre.  
\q2 ¡\w Al|strong="H4480"\w* fuego su herrumbre!   
\p
\v 13 “‘\w En|strong="H5704"\w* tu \w inmundicia|strong="H2932"\w* \w hay|strong="H5750"\w* lujuria. \w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* yo te \w limpié|strong="H2891"\w* \w y|strong="H5704"\w* tú \w no|strong="H3808"\w* te \w limpiaste|strong="H2891"\w*, \w no|strong="H3808"\w* serás \w limpia|strong="H2891"\w* \w más|strong="H5750"\w* \w de|strong="H5750"\w* tu \w inmundicia|strong="H2932"\w*, \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* yo haya hecho descansar mi \w ira|strong="H2534"\w* sobre ti.   
\p
\v 14 “\w Yo|strong="H6213"\w*, Yahvé, he \w hablado|strong="H1696"\w*. Vendrá, y \w yo|strong="H6213"\w* \w lo|strong="H3808"\w* \w haré|strong="H6213"\w*. \w No|strong="H3808"\w* me volveré atrás, \w no|strong="H3808"\w* perdonaré, \w ni|strong="H3808"\w* me arrepentiré; según tus \w caminos|strong="H1870"\w* y según tus \w obras|strong="H5949"\w* te \w juzgarán|strong="H8199"\w*, \w dice|strong="H5002"\w* \w el|strong="H6213"\w* \w Señor|strong="H3068"\w* Yahvé’”.   
\p
\v 15 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 16 «\w Hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w hombre|strong="H1121"\w*, he \w aquí|strong="H2005"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* \w te|strong="H5869"\w* \w quito|strong="H3947"\w* \w de|strong="H4480"\w* golpe \w el|strong="H1121"\w* deleite \w de|strong="H4480"\w* tus \w ojos|strong="H5869"\w*; \w no|strong="H3808"\w* hagas duelo, \w ni|strong="H3808"\w* \w llores|strong="H1058"\w*, \w ni|strong="H3808"\w* corran tus \w lágrimas|strong="H1832"\w*.  
\v 17 Gime \w en|strong="H5921"\w* silencio, \w no|strong="H3808"\w* \w hagas|strong="H6213"\w* luto \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w muertos|strong="H4191"\w*. \w Ata|strong="H2280"\w* \w tu|strong="H6213"\w* turbante \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w pon|strong="H7760"\w* tus sandalias \w en|strong="H5921"\w* tus \w pies|strong="H7272"\w*; \w no|strong="H3808"\w* \w te|strong="H5921"\w* cubras \w el|strong="H5921"\w* labio superior, \w ni|strong="H3808"\w* \w comas|strong="H3899"\w* \w pan|strong="H3899"\w* \w de|strong="H5921"\w* duelo».   
\p
\v 18 \w Hablé|strong="H1696"\w*, pues, al \w pueblo|strong="H5971"\w* por la \w mañana|strong="H1242"\w*, y \w a|strong="H3068"\w* la \w tarde|strong="H6153"\w* \w murió|strong="H4191"\w* mi mujer; y \w a|strong="H3068"\w* la \w mañana|strong="H1242"\w* siguiente \w hice|strong="H6213"\w* como \w se|strong="H5971"\w* me \w había|strong="H6213"\w* \w mandado|strong="H6680"\w*.   
\p
\v 19 \w Y|strong="H3068"\w* \w me|strong="H3588"\w* \w dijo|strong="H5046"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*: «¿\w No|strong="H3808"\w* \w nos|strong="H4100"\w* enseñarás \w qué|strong="H3588"\w* \w significan|strong="H3808"\w* \w para|strong="H3588"\w* nosotros \w estas|strong="H6213"\w* cosas \w que|strong="H3588"\w* \w haces|strong="H6213"\w*?».   
\p
\v 20 \w Y|strong="H3068"\w* yo les dije: “La \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, diciendo:  
\v 21 ‘Di \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: \w Así|strong="H3541"\w* dice \w el|strong="H5307"\w* Señor Yahvé: He \w aquí|strong="H3541"\w*, \w yo|strong="H5315"\w* profano \w mi|strong="H2490"\w* \w santuario|strong="H4720"\w*, la \w soberbia|strong="H1347"\w* \w de|strong="H1121"\w* vuestra fuerza, \w el|strong="H5307"\w* deleite \w de|strong="H1121"\w* vuestros \w ojos|strong="H5869"\w* \w y|strong="H3541"\w* la pasión \w de|strong="H1121"\w* vuestra \w alma|strong="H5315"\w*; \w y|strong="H3541"\w* vuestros \w hijos|strong="H1121"\w* \w y|strong="H3541"\w* vuestras \w hijas|strong="H1323"\w* \w que|strong="H1121"\w* \w dejasteis|strong="H5800"\w* \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.  
\v 22 \w Y|strong="H3068"\w* \w haréis|strong="H6213"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* manera \w que|strong="H3808"\w* \w yo|strong="H6213"\w* \w hice|strong="H6213"\w*: \w no|strong="H3808"\w* \w os|strong="H5921"\w* cubriréis \w el|strong="H5921"\w* labio superior, \w ni|strong="H3808"\w* comeréis \w pan|strong="H3899"\w* \w de|strong="H5921"\w* duelo.  
\v 23 Vuestros turbantes estarán \w sobre|strong="H5921"\w* vuestras \w cabezas|strong="H7218"\w*, \w y|strong="H5921"\w* vuestras sandalias \w en|strong="H5921"\w* vuestros \w pies|strong="H7272"\w*. \w No|strong="H3808"\w* haréis duelo \w ni|strong="H3808"\w* \w lloraréis|strong="H1058"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w os|strong="H5921"\w* consumiréis \w en|strong="H5921"\w* vuestras \w iniquidades|strong="H5771"\w*, \w y|strong="H5921"\w* gemiréis unos \w con|strong="H5921"\w* otros.  
\v 24 \w Ezequiel|strong="H3168"\w*, \w pues|strong="H3588"\w*, os \w será|strong="H1961"\w* \w por|strong="H3588"\w* señal; según \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* \w hizo|strong="H6213"\w*, \w haréis|strong="H6213"\w*. \w Cuando|strong="H3588"\w* \w esto|strong="H6213"\w* ocurra, \w entonces|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* \w el|strong="H3588"\w* Señor Yahvé’.   
