\v 25 \w Y|strong="H3068"\w* tú, \w oh|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w pondrán|strong="H5414"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w cuerdas|strong="H5688"\w*, \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w ellas|strong="H5921"\w* \w te|strong="H5921"\w* ligarán, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w saldrás|strong="H3318"\w* \w entre|strong="H8432"\w* \w ellos|strong="H5921"\w*.  
