\p
\v 4 “\w Y|strong="H3068"\w* tú \w acuéstate|strong="H7901"\w* \w sobre|strong="H5921"\w* tu \w lado|strong="H6654"\w* \w izquierdo|strong="H8042"\w*, \w y|strong="H5921"\w* \w pon|strong="H7760"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w la|strong="H5921"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Según|strong="H5921"\w* \w el|strong="H5921"\w* \w número|strong="H4557"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w que|strong="H5921"\w* estés \w acostado|strong="H7901"\w* \w sobre|strong="H5921"\w* ese \w lado|strong="H6654"\w*, \w llevarás|strong="H5375"\w* \w la|strong="H5921"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 5 Yo te he fijado los \w años|strong="H8141"\w* \w de|strong="H5414"\w* su \w iniquidad|strong="H5771"\w* \w por|strong="H5414"\w* un \w número|strong="H4557"\w* \w de|strong="H5414"\w* \w días|strong="H3117"\w*: \w trescientos|strong="H7969"\w* \w noventa|strong="H8673"\w* \w días|strong="H3117"\w*. Así \w llevarás|strong="H5375"\w* la \w iniquidad|strong="H5771"\w* \w de|strong="H5414"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*.   
\p
\v 6 “\w Y|strong="H3068"\w* \w cuando|strong="H3117"\w* hayas cumplido estos, \w te|strong="H5921"\w* acostarás \w por|strong="H5921"\w* \w segunda|strong="H8145"\w* vez, \w ahora|strong="H3117"\w* \w sobre|strong="H5921"\w* tu \w lado|strong="H6654"\w* derecho, \w y|strong="H5921"\w* cargarás \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* durante cuarenta \w días|strong="H3117"\w*; un \w día|strong="H3117"\w* \w por|strong="H5921"\w* \w cada|strong="H3117"\w* \w año|strong="H8141"\w* \w te|strong="H5921"\w* he fijado.  
\v 7 \w Hacia|strong="H5921"\w* \w el|strong="H5921"\w* asedio \w de|strong="H5921"\w* Jerusalén fijarás tu \w rostro|strong="H6440"\w* \w y|strong="H5921"\w* tu \w brazo|strong="H2220"\w* descubierto, \w y|strong="H5921"\w* \w profetizarás|strong="H5012"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*.  
