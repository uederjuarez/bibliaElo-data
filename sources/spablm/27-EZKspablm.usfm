\v 22 Sus \w ventanas|strong="H2474"\w*, sus arcos y sus palmeras eran conforme \w a|strong="H3068"\w* la \w medida|strong="H4060"\w* \w de|strong="H6440"\w* la \w puerta|strong="H8179"\w* \w que|strong="H7651"\w* \w miraba|strong="H6440"\w* al oriente; y se \w subía|strong="H5927"\w* \w a|strong="H3068"\w* ella \w por|strong="H1870"\w* \w siete|strong="H7651"\w* \w gradas|strong="H4609"\w*, y sus arcos estaban \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellas.  
\v 23 \w Y|strong="H3068"\w* la \w puerta|strong="H8179"\w* del \w atrio|strong="H2691"\w* \w interior|strong="H6442"\w* estaba \w enfrente|strong="H5048"\w* \w de|strong="H5048"\w* la \w puerta|strong="H8179"\w* del \w norte|strong="H6828"\w* y \w de|strong="H5048"\w* la del oriente; y \w midió|strong="H4058"\w* \w de|strong="H5048"\w* \w puerta|strong="H8179"\w* \w a|strong="H3068"\w* \w puerta|strong="H8179"\w*, \w cien|strong="H3967"\w* codos.   
\p
\v 24 Me llevó después \w hacia|strong="H1870"\w* el sur, y he \w aquí|strong="H2009"\w* una \w puerta|strong="H8179"\w* que miraba al sur; y \w midió|strong="H4058"\w* sus pilastras y sus arcos conforme \w a|strong="H3068"\w* estas mismas medidas.  
\v 25 \w Y|strong="H3068"\w* había en ella y en sus arcos \w ventanas|strong="H2474"\w* \w alrededor|strong="H5439"\w*, como las otras \w ventanas|strong="H2474"\w*; la longitud era \w de|strong="H2568"\w* \w cincuenta|strong="H2572"\w* codos, y la \w anchura|strong="H7341"\w* \w de|strong="H2568"\w* \w veinticinco|strong="H6242"\w* codos.  
\v 26 Sus \w gradas|strong="H4609"\w* para subir eran \w siete|strong="H7651"\w*, y sus arcos estaban \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellas; y tenía palmeras, una \w de|strong="H6440"\w* un lado y otra del otro, en sus pilastras.  
\v 27 \w Y|strong="H3068"\w* el \w atrio|strong="H2691"\w* \w interior|strong="H6442"\w* tenía una \w puerta|strong="H8179"\w* \w hacia|strong="H1870"\w* el sur; y \w midió|strong="H4058"\w* de \w puerta|strong="H8179"\w* \w a|strong="H3068"\w* \w puerta|strong="H8179"\w* \w hacia|strong="H1870"\w* el sur, \w cien|strong="H3967"\w* codos.   
\p
\v 28 \w Luego|strong="H4058"\w* me llevó al \w atrio|strong="H2691"\w* \w interior|strong="H6442"\w* por la \w puerta|strong="H8179"\w* del sur, y \w midió|strong="H4058"\w* la \w puerta|strong="H8179"\w* del sur conforme \w a|strong="H3068"\w* estas mismas medidas.  
\v 29 \w Y|strong="H3068"\w* sus \w cámaras|strong="H8372"\w*, sus pilastras y sus arcos eran conforme \w a|strong="H3068"\w* estas medidas. \w Y|strong="H3068"\w* había en ella y en sus arcos \w ventanas|strong="H2474"\w* \w alrededor|strong="H5439"\w*; la longitud era \w de|strong="H2568"\w* \w cincuenta|strong="H2572"\w* codos, y la \w anchura|strong="H7341"\w* \w de|strong="H2568"\w* \w veinticinco|strong="H6242"\w* codos.  
\v 30 Había arcos \w alrededor|strong="H5439"\w*, \w de|strong="H2568"\w* \w veinticinco|strong="H6242"\w* codos \w de|strong="H2568"\w* longitud y \w cinco|strong="H2568"\w* \w de|strong="H2568"\w* \w anchura|strong="H7341"\w*.  
\v 31 Sus arcos miraban al \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w*; y había palmeras en sus pilastras, y su subida tenía \w ocho|strong="H8083"\w* \w gradas|strong="H4609"\w*.   
\p
\v 32 Me llevó al \w atrio|strong="H2691"\w* \w interior|strong="H6442"\w* \w hacia|strong="H1870"\w* el oriente; y \w midió|strong="H4058"\w* la \w puerta|strong="H8179"\w* conforme \w a|strong="H3068"\w* estas mismas medidas.  
\v 33 Sus \w cámaras|strong="H8372"\w*, sus pilastras y sus arcos eran conforme \w a|strong="H3068"\w* estas medidas. \w Y|strong="H3068"\w* había en ella y en sus arcos \w ventanas|strong="H2474"\w* \w alrededor|strong="H5439"\w*; la longitud era \w de|strong="H2568"\w* \w cincuenta|strong="H2572"\w* codos, y la \w anchura|strong="H7341"\w* \w de|strong="H2568"\w* \w veinticinco|strong="H6242"\w* codos.  
\v 34 Sus arcos miraban al \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w*; y había palmeras en sus pilastras de un lado y del otro, y su subida tenía \w ocho|strong="H8083"\w* \w gradas|strong="H4609"\w*.   
\p
\v 35 Me llevó \w luego|strong="H4058"\w* \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* del \w norte|strong="H6828"\w*, y \w midió|strong="H4058"\w* conforme \w a|strong="H3068"\w* estas mismas medidas;  
\v 36 sus \w cámaras|strong="H8372"\w*, sus pilastras y sus arcos. \w Y|strong="H3068"\w* tenía \w ventanas|strong="H2474"\w* \w alrededor|strong="H5439"\w*; la longitud era \w de|strong="H2568"\w* \w cincuenta|strong="H2572"\w* codos, y la \w anchura|strong="H7341"\w* \w de|strong="H2568"\w* \w veinticinco|strong="H6242"\w* codos.  
\v 37 Sus pilastras miraban al \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w*; y había palmeras en sus pilastras de un lado y del otro, y su subida tenía \w ocho|strong="H8083"\w* \w gradas|strong="H4609"\w*.   
\p
\v 38 \w Y|strong="H3068"\w* había una \w cámara|strong="H3957"\w* con su \w puerta|strong="H6607"\w* junto \w a|strong="H3068"\w* las pilastras de las \w puertas|strong="H8179"\w*; \w allí|strong="H8033"\w* lavaban el \w holocausto|strong="H5930"\w*.  
\v 39 En el vestíbulo de la \w puerta|strong="H8179"\w* había \w dos|strong="H8147"\w* \w mesas|strong="H7979"\w* \w a|strong="H3068"\w* un lado y \w dos|strong="H8147"\w* \w mesas|strong="H7979"\w* \w al|strong="H5930"\w* otro, para degollar sobre ellas el \w holocausto|strong="H5930"\w*, la ofrenda por el \w pecado|strong="H2403"\w* y el sacrificio por la culpa.  
\v 40 \w Y|strong="H3068"\w* al \w lado|strong="H3802"\w* de \w afuera|strong="H2351"\w*, \w a|strong="H3068"\w* la subida de la entrada de la \w puerta|strong="H6607"\w* del \w norte|strong="H6828"\w*, había \w dos|strong="H8147"\w* \w mesas|strong="H7979"\w*; y al otro \w lado|strong="H3802"\w* del vestíbulo de la \w puerta|strong="H6607"\w* había \w dos|strong="H8147"\w* \w mesas|strong="H7979"\w*.  
\v 41 Cuatro \w mesas|strong="H7979"\w* \w a|strong="H3068"\w* un \w lado|strong="H3802"\w* y cuatro \w mesas|strong="H7979"\w* al otro, junto \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w*; \w ocho|strong="H8083"\w* \w mesas|strong="H7979"\w* sobre las cuales \w degollaban|strong="H7819"\w* las víctimas.  
\v 42 Además, había cuatro \w mesas|strong="H7979"\w* de piedra labrada para el \w holocausto|strong="H5930"\w*, de un codo y \w medio|strong="H2677"\w* de longitud, un codo y \w medio|strong="H2677"\w* de \w anchura|strong="H7341"\w* y un codo de \w altura|strong="H1363"\w*; sobre ellas ponían los \w instrumentos|strong="H3627"\w* con que \w degollaban|strong="H7819"\w* el \w holocausto|strong="H5930"\w* y el \w sacrificio|strong="H2077"\w*.  
\v 43 \w Y|strong="H3068"\w* unos \w ganchos|strong="H8240"\w* de un \w palmo|strong="H2948"\w* de largo estaban fijados por dentro, \w todo|strong="H5439"\w* \w alrededor|strong="H5439"\w*; y sobre las \w mesas|strong="H7979"\w* se ponía la \w carne|strong="H1320"\w* de las \w ofrendas|strong="H7133"\w*.   
\p
\v 44 \w Y|strong="H3068"\w* \w por|strong="H1870"\w* \w fuera|strong="H2351"\w* \w de|strong="H6440"\w* la \w puerta|strong="H8179"\w* \w interior|strong="H6442"\w*, en el \w atrio|strong="H2691"\w* \w interior|strong="H6442"\w*, estaban las \w cámaras|strong="H3957"\w* \w de|strong="H6440"\w* los \w cantores|strong="H7891"\w*, una al \w lado|strong="H3802"\w* \w de|strong="H6440"\w* la \w puerta|strong="H8179"\w* del \w norte|strong="H6828"\w*, \w que|strong="H2691"\w* \w miraba|strong="H6440"\w* \w hacia|strong="H1870"\w* el sur; y la otra al \w lado|strong="H3802"\w* \w de|strong="H6440"\w* la \w puerta|strong="H8179"\w* \w oriental|strong="H6921"\w*, \w que|strong="H2691"\w* \w miraba|strong="H6440"\w* \w hacia|strong="H1870"\w* el \w norte|strong="H6828"\w*.  
\v 45 \w Y|strong="H3068"\w* él me \w dijo|strong="H1696"\w*: «\w Esta|strong="H2090"\w* \w cámara|strong="H3957"\w* que \w mira|strong="H8104"\w* \w hacia|strong="H1870"\w* el sur es para los \w sacerdotes|strong="H3548"\w* que hacen \w la|strong="H8104"\w* guardia del \w templo|strong="H1004"\w*.  
\v 46 \w Y|strong="H3068"\w* \w la|strong="H8104"\w* \w cámara|strong="H3957"\w* \w que|strong="H1121"\w* \w mira|strong="H8104"\w* \w hacia|strong="H1870"\w* \w el|strong="H1121"\w* \w norte|strong="H6828"\w* es para \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H1121"\w* hacen \w la|strong="H8104"\w* guardia \w del|strong="H4196"\w* \w altar|strong="H4196"\w*; \w estos|strong="H1992"\w* son \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Sadoc|strong="H6659"\w*, \w los|strong="H1992"\w* cuales, \w de|strong="H6440"\w* entre \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Leví|strong="H3878"\w*, \w se|strong="H1992"\w* acercan \w a|strong="H3068"\w* Yahvé para \w ministrarle|strong="H8334"\w*».  
\v 47 \w Y|strong="H3068"\w* \w midió|strong="H4058"\w* el \w atrio|strong="H2691"\w*: \w cien|strong="H3967"\w* codos \w de|strong="H6440"\w* longitud y \w cien|strong="H3967"\w* codos \w de|strong="H6440"\w* \w anchura|strong="H7341"\w*, en forma cuadrada; y el \w altar|strong="H4196"\w* \w estaba|strong="H1004"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* la \w casa|strong="H1004"\w*.   
\p
\v 48 \w Luego|strong="H4058"\w* me llevó al vestíbulo \w de|strong="H2568"\w* la \w casa|strong="H1004"\w*, y \w midió|strong="H4058"\w* cada pilastra del vestíbulo: \w cinco|strong="H2568"\w* codos \w a|strong="H3068"\w* un lado y \w cinco|strong="H2568"\w* codos al otro. \w Y|strong="H3068"\w* la \w anchura|strong="H7341"\w* \w de|strong="H2568"\w* la \w puerta|strong="H8179"\w* era \w de|strong="H2568"\w* \w tres|strong="H7969"\w* codos \w a|strong="H3068"\w* un lado y \w tres|strong="H7969"\w* codos al otro.  
\v 49 La longitud del vestíbulo era de \w veinte|strong="H6242"\w* codos, y la \w anchura|strong="H7341"\w* de \w once|strong="H6249"\w* codos; y se \w subía|strong="H5927"\w* \w a|strong="H3068"\w* él por \w gradas|strong="H4609"\w*. \w Y|strong="H3068"\w* había \w columnas|strong="H5982"\w* junto \w a|strong="H3068"\w* las pilastras, una \w a|strong="H3068"\w* un lado y otra al otro.   
\c 41
\p
\v 1 Me llevó \w luego|strong="H4058"\w* \w a|strong="H3068"\w* la nave y \w midió|strong="H4058"\w* las pilastras: \w seis|strong="H8337"\w* codos de ancho por un lado y \w seis|strong="H8337"\w* codos de ancho por el otro, que era la \w anchura|strong="H7341"\w* del tabernáculo.  
\v 2 La \w anchura|strong="H7341"\w* \w de|strong="H2568"\w* la entrada era \w de|strong="H2568"\w* \w diez|strong="H6235"\w* codos, y los lados \w de|strong="H2568"\w* la entrada medían \w cinco|strong="H2568"\w* codos \w a|strong="H3068"\w* un \w lado|strong="H3802"\w* y \w cinco|strong="H2568"\w* codos al otro. \w Midió|strong="H4058"\w* su longitud, \w de|strong="H2568"\w* cuarenta codos, y la \w anchura|strong="H7341"\w*, \w de|strong="H2568"\w* \w veinte|strong="H6242"\w* codos.   
\p
\v 3 \w Luego|strong="H4058"\w* pasó al interior y \w midió|strong="H4058"\w* cada pilastra de la entrada, de \w dos|strong="H8147"\w* codos; y la entrada, de \w seis|strong="H8337"\w* codos; y la \w anchura|strong="H7341"\w* de la entrada, de \w siete|strong="H7651"\w* codos.  
\v 4 \w Midió|strong="H4058"\w* su longitud, \w de|strong="H6440"\w* \w veinte|strong="H6242"\w* codos, y la \w anchura|strong="H7341"\w*, \w de|strong="H6440"\w* \w veinte|strong="H6242"\w* codos, \w por|strong="H6440"\w* la parte delantera \w de|strong="H6440"\w* la nave. \w Y|strong="H3068"\w* me dijo: «\w Este|strong="H2088"\w* \w es|strong="H2088"\w* el Lugar \w Santísimo|strong="H6944"\w*».   
\p
\v 5 Después \w midió|strong="H4058"\w* el muro de la \w casa|strong="H1004"\w*, de \w seis|strong="H8337"\w* codos; y la \w anchura|strong="H7341"\w* de cada cámara lateral, de cuatro codos, por \w todo|strong="H5439"\w* el contorno de la \w casa|strong="H1004"\w*.  
\v 6 Las \w cámaras|strong="H6763"\w* laterales \w estaban|strong="H1961"\w* superpuestas en \w tres|strong="H7969"\w* pisos, \w treinta|strong="H7970"\w* en cada piso. \w Y|strong="H3068"\w* entraban en el muro de la \w casa|strong="H1004"\w* por \w todo|strong="H5439"\w* su contorno, \w para|strong="H1961"\w* apoyarse en él y \w no|strong="H3808"\w* estar empotradas en el muro mismo de la \w casa|strong="H1004"\w*.  
\v 7 \w Las|strong="H5921"\w* \w cámaras|strong="H6763"\w* laterales eran \w más|strong="H3588"\w* anchas \w a|strong="H3068"\w* medida \w que|strong="H3588"\w* \w se|strong="H5921"\w* ascendía, \w porque|strong="H3588"\w* \w la|strong="H5921"\w* estructura \w se|strong="H5921"\w* iba estrechando \w en|strong="H5921"\w* \w los|strong="H5921"\w* niveles superiores \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*. \w Por|strong="H5921"\w* \w lo|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w la|strong="H5921"\w* \w anchura|strong="H7341"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* aumentaba \w hacia|strong="H5921"\w* \w arriba|strong="H4605"\w*; \w y|strong="H3588"\w* \w así|strong="H3651"\w* \w se|strong="H5921"\w* \w subía|strong="H5927"\w* \w del|strong="H5921"\w* piso inferior \w al|strong="H5921"\w* superior pasando \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w de|strong="H5921"\w* \w en|strong="H5921"\w* medio.   
\p
\v 8 \w Vi|strong="H7200"\w* también que la \w casa|strong="H1004"\w* tenía una plataforma elevada en \w todo|strong="H5439"\w* su perímetro. Los cimientos de las \w cámaras|strong="H6763"\w* laterales medían una \w caña|strong="H7070"\w* \w entera|strong="H4393"\w* de \w seis|strong="H8337"\w* codos largos.  
\v 9 El grosor del muro exterior \w de|strong="H2568"\w* las \w cámaras|strong="H6763"\w* laterales era \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* codos. El espacio que quedaba libre era el área \w de|strong="H2568"\w* las \w cámaras|strong="H6763"\w* laterales que pertenecían \w a|strong="H3068"\w* la \w casa|strong="H1004"\w*.  
\v 10 Entre las \w cámaras|strong="H3957"\w* había una \w anchura|strong="H7341"\w* de \w veinte|strong="H6242"\w* codos por \w todo|strong="H5439"\w* el contorno de la \w casa|strong="H1004"\w*.  
\v 11 Las \w puertas|strong="H6607"\w* \w de|strong="H2568"\w* las \w cámaras|strong="H6763"\w* laterales daban al espacio libre: una \w puerta|strong="H6607"\w* \w hacia|strong="H1870"\w* el \w norte|strong="H6828"\w* y otra \w hacia|strong="H1870"\w* el sur. \w Y|strong="H3068"\w* la \w anchura|strong="H7341"\w* \w de|strong="H2568"\w* este espacio libre era \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* codos en \w todo|strong="H5439"\w* su contorno.   
\p
\v 12 El edificio que estaba \w delante|strong="H6440"\w* del espacio separado, \w hacia|strong="H1870"\w* el \w lado|strong="H6285"\w* \w occidental|strong="H3220"\w*, tenía \w setenta|strong="H7657"\w* codos \w de|strong="H6440"\w* \w anchura|strong="H7341"\w*; el muro del edificio era \w de|strong="H6440"\w* \w cinco|strong="H2568"\w* codos \w de|strong="H6440"\w* grosor \w alrededor|strong="H5439"\w*, y su longitud \w de|strong="H6440"\w* \w noventa|strong="H8673"\w* codos.   
\p
\v 13 \w Midió|strong="H4058"\w*, pues, el \w templo|strong="H1004"\w*, de \w cien|strong="H3967"\w* codos de longitud; también el espacio separado, y el \w edificio|strong="H1004"\w* con sus muros, \w cien|strong="H3967"\w* codos de longitud;  
\v 14 y la \w anchura|strong="H7341"\w* \w de|strong="H6440"\w* la fachada del \w templo|strong="H1004"\w*, y del espacio separado \w hacia|strong="H6440"\w* el oriente, \w de|strong="H6440"\w* \w cien|strong="H3967"\w* codos.   
\p
\v 15 \w Midió|strong="H4058"\w* \w la|strong="H5921"\w* longitud \w del|strong="H5921"\w* edificio \w que|strong="H5921"\w* estaba \w delante|strong="H6440"\w* \w del|strong="H5921"\w* espacio separado \w que|strong="H5921"\w* quedaba \w a|strong="H3068"\w* sus espaldas, \w y|strong="H5921"\w* sus galerías \w a|strong="H3068"\w* un lado \w y|strong="H5921"\w* \w al|strong="H5921"\w* otro, \w cien|strong="H3967"\w* codos. \w El|strong="H5921"\w* \w templo|strong="H1964"\w* \w interior|strong="H6442"\w*, \w los|strong="H5921"\w* pórticos \w del|strong="H5921"\w* \w atrio|strong="H2691"\w*,  
\v 16 los umbrales, las \w ventanas|strong="H2474"\w* estrechas \w y|strong="H5704"\w* las galerías \w alrededor|strong="H5439"\w* \w de|strong="H5048"\w* sus \w tres|strong="H7969"\w* pisos, \w frente|strong="H5048"\w* \w al|strong="H5704"\w* umbral, estaban recubiertos \w de|strong="H5048"\w* \w madera|strong="H6086"\w* \w en|strong="H5704"\w* \w derredor|strong="H5439"\w*, \w desde|strong="H5704"\w* el suelo \w hasta|strong="H5704"\w* las \w ventanas|strong="H2474"\w* (\w y|strong="H5704"\w* las \w ventanas|strong="H2474"\w* estaban \w cubiertas|strong="H3680"\w*).  
\v 17 \w Desde|strong="H5704"\w* \w el|strong="H5921"\w* espacio \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w*, \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w interior|strong="H6442"\w*, \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w fuera|strong="H2351"\w*, \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* muro \w en|strong="H5921"\w* \w derredor|strong="H5439"\w*, \w por|strong="H5921"\w* \w dentro|strong="H5921"\w* \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w fuera|strong="H2351"\w*, \w todo|strong="H3605"\w* \w estaba|strong="H1004"\w* medido.  
\v 18 Estaba decorado con \w querubines|strong="H3742"\w* y palmeras. \w Había|strong="H6213"\w* una palmera entre \w querubín|strong="H3742"\w* y \w querubín|strong="H3742"\w*, y cada \w querubín|strong="H3742"\w* tenía \w dos|strong="H8147"\w* \w rostros|strong="H6440"\w*:  
\v 19 \w el|strong="H3605"\w* \w rostro|strong="H6440"\w* \w de|strong="H6440"\w* hombre \w miraba|strong="H6440"\w* \w hacia|strong="H6213"\w* \w la|strong="H3605"\w* palmera \w de|strong="H6440"\w* un lado, y \w el|strong="H3605"\w* \w rostro|strong="H6440"\w* \w de|strong="H6440"\w* león \w miraba|strong="H6440"\w* \w hacia|strong="H6213"\w* \w la|strong="H3605"\w* palmera del otro lado. Así \w estaba|strong="H1004"\w* \w hecho|strong="H6213"\w* \w por|strong="H6440"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* en \w derredor|strong="H5439"\w*.  
\v 20 \w Desde|strong="H5704"\w* \w el|strong="H5921"\w* suelo \w hasta|strong="H5704"\w* \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w había|strong="H6213"\w* \w querubines|strong="H3742"\w* \w y|strong="H5921"\w* palmeras labrados \w en|strong="H5921"\w* \w el|strong="H5921"\w* muro \w de|strong="H5921"\w* \w la|strong="H5921"\w* nave.   
\p
\v 21 Las pilastras \w de|strong="H6440"\w* la nave eran \w cuadradas|strong="H7251"\w*. En cuanto \w a|strong="H3068"\w* la fachada del \w santuario|strong="H6944"\w*, su \w aspecto|strong="H4758"\w* era semejante al del \w templo|strong="H1964"\w*.  
\v 22 El \w altar|strong="H4196"\w* \w era|strong="H2088"\w* \w de|strong="H6440"\w* \w madera|strong="H6086"\w*, \w de|strong="H6440"\w* \w tres|strong="H7969"\w* codos \w de|strong="H6440"\w* altura y \w dos|strong="H8147"\w* codos \w de|strong="H6440"\w* longitud. Sus \w esquinas|strong="H4740"\w*, su base y sus paredes eran \w de|strong="H6440"\w* \w madera|strong="H6086"\w*. \w Y|strong="H3068"\w* él me \w dijo|strong="H1696"\w*: «\w Esta|strong="H2088"\w* \w es|strong="H2088"\w* la \w mesa|strong="H7979"\w* \w que|strong="H2088"\w* \w está|strong="H2088"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé».  
\v 23 El \w templo|strong="H1964"\w* y el \w santuario|strong="H6944"\w* tenían \w dos|strong="H8147"\w* \w puertas|strong="H1817"\w*.  
\v 24 Cada \w puerta|strong="H1817"\w* tenía \w dos|strong="H8147"\w* hojas, \w dos|strong="H8147"\w* hojas giratorias: \w dos|strong="H8147"\w* hojas para una \w puerta|strong="H1817"\w* y \w dos|strong="H8147"\w* hojas para la otra.  
\v 25 Sobre ellas, en las \w puertas|strong="H1817"\w* \w de|strong="H6440"\w* la nave, \w había|strong="H6213"\w* \w querubines|strong="H3742"\w* y palmeras labrados, como los que se habían \w hecho|strong="H6213"\w* en los muros. \w Había|strong="H6213"\w* también un umbral \w de|strong="H6440"\w* \w madera|strong="H6086"\w* en la fachada exterior del pórtico.  
\v 26 Había \w ventanas|strong="H2474"\w* estrechas y palmeras \w a|strong="H3068"\w* un \w lado|strong="H3802"\w* y al otro, en los flancos del pórtico. Así estaban decoradas las \w cámaras|strong="H6763"\w* laterales de la \w casa|strong="H1004"\w* y los umbrales.   
\c 42
\p
\v 1 Me \w sacó|strong="H3318"\w* \w luego|strong="H3318"\w* al \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w*, \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* \w hacia|strong="H1870"\w* el \w norte|strong="H6828"\w*, y me llevó \w a|strong="H3068"\w* las \w cámaras|strong="H3957"\w* \w que|strong="H2691"\w* estaban \w frente|strong="H5048"\w* al espacio separado y \w frente|strong="H5048"\w* al edificio \w que|strong="H2691"\w* daba al \w norte|strong="H6828"\w*.  
\v 2 \w Por|strong="H6440"\w* la fachada \w norte|strong="H6828"\w*, la longitud del edificio era \w de|strong="H6440"\w* \w cien|strong="H3967"\w* codos\f + \fr 42:2 \ft Un codo es la longitud desde la punta del dedo corazón hasta el codo del brazo de un hombre, es decir, unos 46 centímetros.\f*, y su \w anchura|strong="H7341"\w* era \w de|strong="H6440"\w* \w cincuenta|strong="H2572"\w* codos.  
\v 3 \w Frente|strong="H5048"\w* \w a|strong="H3068"\w* los \w veinte|strong="H6242"\w* codos \w que|strong="H2691"\w* pertenecían al \w atrio|strong="H2691"\w* \w interior|strong="H6442"\w*, y \w frente|strong="H5048"\w* al pavimento del \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w*, había galerías, la una \w frente|strong="H5048"\w* \w a|strong="H3068"\w* la otra, en tres pisos.  
\v 4 \w Delante|strong="H6440"\w* \w de|strong="H6440"\w* las \w cámaras|strong="H3957"\w* había un pasillo \w de|strong="H6440"\w* \w diez|strong="H6235"\w* codos \w de|strong="H6440"\w* \w anchura|strong="H7341"\w* que daba al \w interior|strong="H6442"\w*, y un paso \w de|strong="H6440"\w* un codo; y sus \w puertas|strong="H6607"\w* daban al \w norte|strong="H6828"\w*.  
\v 5 Las \w cámaras|strong="H3957"\w* superiores eran \w más|strong="H3588"\w* estrechas, \w porque|strong="H3588"\w* las galerías les quitaban \w más|strong="H3588"\w* espacio \w a|strong="H3068"\w* \w estas|strong="H2007"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* las inferiores \w y|strong="H3588"\w* \w a|strong="H3068"\w* las \w de|strong="H3588"\w* \w en|strong="H3588"\w* medio del edificio.  
\v 6 \w Porque|strong="H3588"\w* estaban dispuestas \w en|strong="H5921"\w* tres pisos, \w y|strong="H3588"\w* \w no|strong="H3588"\w* tenían \w columnas|strong="H5982"\w* \w como|strong="H3588"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w atrios|strong="H2691"\w*; \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w el|strong="H5921"\w* piso superior era \w más|strong="H3588"\w* estrecho \w que|strong="H3588"\w* \w el|strong="H5921"\w* inferior \w y|strong="H3588"\w* \w el|strong="H5921"\w* \w de|strong="H5921"\w* \w en|strong="H5921"\w* medio \w desde|strong="H5921"\w* \w el|strong="H5921"\w* suelo.  
\v 7 \w Y|strong="H3068"\w* el muro \w que|strong="H2691"\w* estaba \w afuera|strong="H2351"\w*, paralelo \w a|strong="H3068"\w* las \w cámaras|strong="H3957"\w*, \w hacia|strong="H1870"\w* el \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w* y \w delante|strong="H6440"\w* \w de|strong="H6440"\w* las \w cámaras|strong="H3957"\w*, tenía una longitud \w de|strong="H6440"\w* \w cincuenta|strong="H2572"\w* codos.  
\v 8 \w Porque|strong="H3588"\w* \w la|strong="H5921"\w* longitud \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w cámaras|strong="H3957"\w* \w que|strong="H3588"\w* daban \w al|strong="H5921"\w* \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w* era \w de|strong="H5921"\w* \w cincuenta|strong="H2572"\w* codos, \w mientras|strong="H3588"\w* \w que|strong="H3588"\w* \w las|strong="H5921"\w* \w que|strong="H3588"\w* daban \w a|strong="H3068"\w* \w la|strong="H5921"\w* fachada \w del|strong="H5921"\w* \w templo|strong="H1964"\w* medían \w cien|strong="H3967"\w* codos.  
\v 9 \w Por|strong="H8478"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w estas|strong="H2007"\w* \w cámaras|strong="H3957"\w* estaba la \w entrada|strong="H3996"\w* \w por|strong="H8478"\w* el lado \w oriental|strong="H6921"\w*, para entrar \w en|strong="H8478"\w* \w ellas|strong="H2007"\w* desde el \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w*.   
\p
\v 10 \w A|strong="H3068"\w* lo ancho del muro del \w atrio|strong="H2691"\w* \w hacia|strong="H1870"\w* el oriente, frente al espacio separado y \w delante|strong="H6440"\w* del edificio, había también \w cámaras|strong="H3957"\w*.  
\v 11 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* pasillo \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellas tenía \w el|strong="H3605"\w* \w mismo|strong="H3605"\w* \w aspecto|strong="H4758"\w* \w que|strong="H3605"\w* \w el|strong="H3605"\w* \w de|strong="H6440"\w* las \w cámaras|strong="H3957"\w* \w que|strong="H3605"\w* daban al \w norte|strong="H6828"\w*; su longitud y su \w anchura|strong="H7341"\w* eran iguales. \w Todas|strong="H3605"\w* sus salidas, su disposición y sus \w puertas|strong="H6607"\w* eran semejantes.  
\v 12 \w De|strong="H6440"\w* igual manera, las \w puertas|strong="H6607"\w* \w de|strong="H6440"\w* las \w cámaras|strong="H3957"\w* que daban al sur tenían una \w puerta|strong="H6607"\w* al comienzo del pasillo, el pasillo que estaba directamente frente al muro protector \w hacia|strong="H1870"\w* el oriente, \w por|strong="H1870"\w* donde se entraba.   
\p
\v 13 Luego \w me|strong="H3588"\w* dijo: «Las \w cámaras|strong="H3957"\w* del \w norte|strong="H6828"\w* \w y|strong="H3588"\w* las \w cámaras|strong="H3957"\w* del sur, \w que|strong="H3588"\w* están frente al espacio separado, \w son|strong="H3588"\w* \w cámaras|strong="H3957"\w* \w santas|strong="H6944"\w*, \w donde|strong="H8033"\w* \w los|strong="H3588"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H3588"\w* se acercan \w a|strong="H3068"\w* Yahvé comerán las ofrendas santísimas. \w Allí|strong="H8033"\w* depositarán las ofrendas santísimas: \w la|strong="H3588"\w* \w ofrenda|strong="H4503"\w* \w de|strong="H3588"\w* cereal, \w la|strong="H3588"\w* \w ofrenda|strong="H4503"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w pecado|strong="H2403"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* sacrificio \w por|strong="H3588"\w* \w la|strong="H3588"\w* culpa, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w lugar|strong="H4725"\w* \w es|strong="H3588"\w* \w santo|strong="H6918"\w*.  
\v 14 \w Cuando|strong="H3588"\w* \w los|strong="H3588"\w* \w sacerdotes|strong="H3548"\w* entren, \w no|strong="H3808"\w* \w saldrán|strong="H3318"\w* del lugar \w santo|strong="H6944"\w* al \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w* \w sin|strong="H3808"\w* dejar \w allí|strong="H8033"\w* las vestiduras \w con|strong="H3588"\w* \w que|strong="H3588"\w* \w ministran|strong="H8334"\w*, \w porque|strong="H3588"\w* \w son|strong="H3588"\w* \w santas|strong="H6944"\w*. \w Se|strong="H3808"\w* \w pondrán|strong="H3240"\w* otras vestiduras, \w y|strong="H3588"\w* \w entonces|strong="H3588"\w* \w se|strong="H3808"\w* acercarán \w a|strong="H3068"\w* las áreas destinadas al \w pueblo|strong="H5971"\w*».   
\p
\v 15 Cuando terminó \w de|strong="H6440"\w* medir el \w interior|strong="H6442"\w* \w de|strong="H6440"\w* la \w casa|strong="H1004"\w*, me \w sacó|strong="H3318"\w* \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* \w de|strong="H6440"\w* la \w puerta|strong="H8179"\w* que mira \w hacia|strong="H1870"\w* el oriente, y \w midió|strong="H4058"\w* \w todo|strong="H5439"\w* el contorno.  
\v 16 \w Midió|strong="H4058"\w* el \w lado|strong="H7307"\w* \w oriental|strong="H6921"\w* con la \w caña|strong="H7070"\w* \w de|strong="H2568"\w* medir: \w quinientas|strong="H2568"\w* \w cañas|strong="H7070"\w*, con la \w caña|strong="H7070"\w* \w de|strong="H2568"\w* medir en \w derredor|strong="H5439"\w*.  
\v 17 \w Midió|strong="H4058"\w* el \w lado|strong="H7307"\w* \w norte|strong="H6828"\w*: \w quinientas|strong="H2568"\w* \w cañas|strong="H7070"\w*, con la \w caña|strong="H7070"\w* \w de|strong="H2568"\w* medir en \w derredor|strong="H5439"\w*.  
\v 18 \w Midió|strong="H4058"\w* el \w lado|strong="H7307"\w* sur: \w quinientas|strong="H2568"\w* \w cañas|strong="H7070"\w* con la \w caña|strong="H7070"\w* \w de|strong="H2568"\w* medir.  
\v 19 Se volvió hacia el \w lado|strong="H7307"\w* \w occidental|strong="H3220"\w*, y \w midió|strong="H4058"\w* \w quinientas|strong="H2568"\w* \w cañas|strong="H7070"\w* con la \w caña|strong="H7070"\w* \w de|strong="H2568"\w* medir.  
\v 20 Lo \w midió|strong="H4058"\w* por los cuatro \w lados|strong="H5439"\w*. Tenía un \w muro|strong="H2346"\w* \w a|strong="H3068"\w* su \w alrededor|strong="H5439"\w*, \w de|strong="H2568"\w* \w quinientos|strong="H2568"\w* codos \w de|strong="H2568"\w* longitud y \w quinientos|strong="H2568"\w* codos \w de|strong="H2568"\w* \w anchura|strong="H7341"\w*, para hacer separación entre lo \w santo|strong="H6944"\w* y lo profano.   
\c 43
\p
\v 1 Después me llevó \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w*, la \w puerta|strong="H8179"\w* que \w mira|strong="H6437"\w* \w hacia|strong="H1870"\w* el oriente.  
\v 2 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H4325"\w* la \w gloria|strong="H3519"\w* del Dios \w de|strong="H4325"\w* \w Israel|strong="H3478"\w* venía \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* del oriente. Su \w sonido|strong="H6963"\w* era como el \w estruendo|strong="H6963"\w* \w de|strong="H4325"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*, \w y|strong="H3519"\w* la tierra resplandecía \w a|strong="H3068"\w* causa \w de|strong="H4325"\w* su \w gloria|strong="H3519"\w*.  
\v 3 \w El|strong="H5307"\w* \w aspecto|strong="H4758"\w* \w de|strong="H6440"\w* lo que \w vi|strong="H7200"\w* era como una \w visión|strong="H4758"\w*, semejante \w a|strong="H3068"\w* la \w visión|strong="H4758"\w* que tuve cuando vine para \w destruir|strong="H7843"\w* la \w ciudad|strong="H5892"\w*; y las visiones eran como la \w visión|strong="H4758"\w* que \w vi|strong="H7200"\w* junto al \w río|strong="H5104"\w* Quebar; y me postré sobre mi \w rostro|strong="H6440"\w*.  
\v 4 \w Y|strong="H3068"\w* la \w gloria|strong="H3519"\w* \w de|strong="H6440"\w* Yahvé entró en la \w casa|strong="H1004"\w* \w por|strong="H1870"\w* la vía \w de|strong="H6440"\w* la \w puerta|strong="H8179"\w* que da al oriente.  
\v 5 Entonces el \w Espíritu|strong="H7307"\w* me \w levantó|strong="H5375"\w* \w y|strong="H3519"\w* me \w llevó|strong="H5375"\w* al \w atrio|strong="H2691"\w* \w interior|strong="H6442"\w*; \w y|strong="H3519"\w* he \w aquí|strong="H2009"\w* \w que|strong="H2691"\w* la \w gloria|strong="H3519"\w* de Yahvé llenaba la \w casa|strong="H1004"\w*.   
\p
\v 6 \w Y|strong="H3068"\w* \w oí|strong="H8085"\w* \w a|strong="H3068"\w* uno \w que|strong="H1961"\w* me \w hablaba|strong="H1696"\w* desde la \w casa|strong="H1004"\w*, y un varón \w estaba|strong="H1961"\w* de \w pie|strong="H5975"\w* junto \w a|strong="H3068"\w* \w mí|strong="H1961"\w*.  
\v 7 \w Y|strong="H3068"\w* me dijo: “\w Hijo|strong="H1121"\w* \w de|strong="H5750"\w* \w hombre|strong="H1121"\w*, este es \w el|strong="H1121"\w* \w lugar|strong="H4725"\w* \w de|strong="H5750"\w* mi \w trono|strong="H3678"\w*, \w el|strong="H1121"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* posaré \w las|strong="H1992"\w* plantas \w de|strong="H5750"\w* mis \w pies|strong="H7272"\w*, \w en|strong="H8432"\w* \w el|strong="H1121"\w* cual \w habitaré|strong="H7931"\w* \w entre|strong="H8432"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w* para \w siempre|strong="H5769"\w*. \w Nunca|strong="H3808"\w* \w más|strong="H5750"\w* profanará la \w casa|strong="H1004"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w* mi \w santo|strong="H6944"\w* \w nombre|strong="H8034"\w*, \w ni|strong="H3808"\w* \w ellos|strong="H1992"\w* \w ni|strong="H3808"\w* \w sus|strong="H1992"\w* \w reyes|strong="H4428"\w*, con \w sus|strong="H1992"\w* \w fornicaciones|strong="H1992"\w*, \w ni|strong="H3808"\w* con \w los|strong="H1992"\w* cadáveres \w de|strong="H5750"\w* \w sus|strong="H1992"\w* \w reyes|strong="H4428"\w* \w en|strong="H8432"\w* \w sus|strong="H1992"\w* \w lugares|strong="H4725"\w* \w altos|strong="H1116"\w*.  
\v 8 Al \w poner|strong="H5414"\w* ellos su umbral junto \w a|strong="H3068"\w* mi umbral, y su \w poste|strong="H4201"\w* junto \w a|strong="H3068"\w* mi \w poste|strong="H4201"\w*, \w no|strong="H6213"\w* \w había|strong="H6213"\w* más que un muro entre ellos y \w yo|strong="H6213"\w*; y profanaron mi \w santo|strong="H6944"\w* \w nombre|strong="H8034"\w* con las \w abominaciones|strong="H8441"\w* que \w cometieron|strong="H6213"\w*. \w Por|strong="H5414"\w* tanto, los consumí en mi furor.  
\v 9 \w Ahora|strong="H6258"\w* alejarán \w de|strong="H4480"\w* mí sus fornicaciones y los cadáveres \w de|strong="H4480"\w* sus \w reyes|strong="H4428"\w*, y \w habitaré|strong="H7931"\w* \w en|strong="H4480"\w* \w medio|strong="H8432"\w* \w de|strong="H4480"\w* \w ellos|strong="H4480"\w* \w para|strong="H4480"\w* \w siempre|strong="H5769"\w*.   
\p
\v 10 “Tú, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w muestra|strong="H5046"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* esta \w casa|strong="H1004"\w*, para \w que|strong="H1121"\w* se avergüencen \w de|strong="H1121"\w* sus \w pecados|strong="H5771"\w*; y midan \w el|strong="H1121"\w* diseño.  
\v 11 \w Y|strong="H3068"\w* si \w se|strong="H3045"\w* avergüenzan \w de|strong="H5869"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3045"\w* han \w hecho|strong="H6213"\w*, \w hazles|strong="H6213"\w* conocer \w el|strong="H3605"\w* diseño \w de|strong="H5869"\w* \w la|strong="H8104"\w* \w casa|strong="H1004"\w*, su disposición, sus salidas y sus entradas, \w todos|strong="H3605"\w* sus diseños, \w todos|strong="H3605"\w* sus \w estatutos|strong="H2708"\w* y \w todas|strong="H3605"\w* sus \w leyes|strong="H8451"\w*. Escríbelo ante sus \w ojos|strong="H5869"\w*, para \w que|strong="H3045"\w* \w guarden|strong="H8104"\w* \w toda|strong="H3605"\w* su forma y \w todas|strong="H3605"\w* sus \w ordenanzas|strong="H2708"\w*, y las pongan \w por|strong="H3789"\w* \w obra|strong="H6213"\w*.   
\p
\v 12 “\w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*: \w Sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w del|strong="H5921"\w* \w monte|strong="H2022"\w*, \w todo|strong="H3605"\w* su recinto, \w en|strong="H5921"\w* \w todo|strong="H3605"\w* su contorno, será \w santísimo|strong="H6944"\w*. He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*.   
\p
\v 13 «\w Y|strong="H3068"\w* \w estas|strong="H2088"\w* son las medidas \w del|strong="H4196"\w* \w altar|strong="H4196"\w* \w por|strong="H2088"\w* codos (el codo\f + \fr 43:13 \ft El codo normal es la longitud desde la punta del dedo medio hasta el codo del brazo de un hombre, es decir, unos 46 centímetros. La anchura de una mano es de unos 11 centímetros.\f* equivale \w a|strong="H3068"\w* un codo y un \w palmo|strong="H2948"\w* menor): \w la|strong="H1366"\w* base será de un codo de \w alto|strong="H1354"\w*, y de un codo de ancho, y el reborde en su contorno será de un \w palmo|strong="H2948"\w*;\f + \fr 43:13 \ft Un palmo es la longitud desde la punta del pulgar de un hombre hasta la punta de su dedo meñique cuando su mano está extendida (aproximadamente medio codo, o 22,8 cm).\f* y \w este|strong="H2088"\w* será el zócalo \w del|strong="H4196"\w* \w altar|strong="H4196"\w*.  
\v 14 \w Desde|strong="H5704"\w* la base sobre el suelo \w hasta|strong="H5704"\w* el saliente inferior habrá \w dos|strong="H8147"\w* codos, \w y|strong="H5704"\w* la \w anchura|strong="H7341"\w* será \w de|strong="H5704"\w* un codo; \w y|strong="H5704"\w* \w desde|strong="H5704"\w* el saliente \w menor|strong="H6996"\w* \w hasta|strong="H5704"\w* el saliente \w mayor|strong="H1419"\w* habrá cuatro codos, \w y|strong="H5704"\w* la \w anchura|strong="H7341"\w* será \w de|strong="H5704"\w* un codo.  
\v 15 El hogar del altar tendrá cuatro codos de altura, y desde el hogar del altar hacia \w arriba|strong="H4605"\w* se alzarán cuatro \w cuernos|strong="H7161"\w*.  
\v 16 El hogar del altar medirá \w doce|strong="H8147"\w* codos de longitud por \w doce|strong="H8147"\w* de \w anchura|strong="H7341"\w*, \w cuadrado|strong="H7251"\w* por sus cuatro \w lados|strong="H7253"\w*.  
\v 17 \w Y|strong="H3068"\w* el saliente medirá catorce codos de longitud por catorce de \w anchura|strong="H7341"\w* en sus cuatro \w lados|strong="H7253"\w*, y el reborde \w a|strong="H3068"\w* su \w alrededor|strong="H5439"\w* será de \w medio|strong="H2677"\w* codo, y su base será de un codo en \w derredor|strong="H5439"\w*; y sus \w gradas|strong="H4609"\w* mirarán \w hacia|strong="H1366"\w* el oriente».   
\p
\v 18 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* dijo: “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: \w Estas|strong="H6213"\w* son \w las|strong="H5921"\w* \w ordenanzas|strong="H2708"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w en|strong="H5921"\w* \w que|strong="H5921"\w* sea construido, \w para|strong="H5921"\w* ofrecer \w holocaustos|strong="H5930"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w para|strong="H5921"\w* esparcir \w sangre|strong="H1818"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 19 \w A|strong="H3068"\w* \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* \w levitas|strong="H3881"\w* \w que|strong="H1121"\w* son \w de|strong="H1121"\w* la \w descendencia|strong="H2233"\w* \w de|strong="H1121"\w* \w Sadoc|strong="H6659"\w*, \w que|strong="H1121"\w* \w se|strong="H1992"\w* acercan \w a|strong="H3068"\w* mí \w para|strong="H5414"\w* servirme, \w dice|strong="H5002"\w* \w el|strong="H1121"\w* Señor Yahvé, \w les|strong="H1992"\w* \w darás|strong="H5414"\w* un \w novillo|strong="H1121"\w* \w de|strong="H1121"\w* la vacada \w para|strong="H5414"\w* \w expiación|strong="H2403"\w*.  
\v 20 \w Y|strong="H3068"\w* \w tomarás|strong="H3947"\w* \w de|strong="H5921"\w* su \w sangre|strong="H1818"\w*, \w y|strong="H5921"\w* \w pondrás|strong="H5414"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* cuatro \w cuernos|strong="H7161"\w* \w del|strong="H5921"\w* altar, \w en|strong="H5921"\w* \w las|strong="H5921"\w* cuatro \w esquinas|strong="H6438"\w* \w del|strong="H5921"\w* saliente \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* reborde \w alrededor|strong="H5439"\w*; así \w lo|strong="H5921"\w* purificarás \w y|strong="H5921"\w* harás \w expiación|strong="H3722"\w* \w por|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 21 \w Tomarás|strong="H3947"\w* también el \w novillo|strong="H6499"\w* de la ofrenda por el \w pecado|strong="H2403"\w*, y lo \w quemarás|strong="H8313"\w* en el lugar señalado de la \w casa|strong="H1004"\w*, \w fuera|strong="H2351"\w* del \w santuario|strong="H4720"\w*.   
\p
\v 22 “Al \w segundo|strong="H8145"\w* \w día|strong="H3117"\w* \w ofrecerás|strong="H7126"\w* un \w macho|strong="H8163"\w* \w cabrío|strong="H5795"\w* sin defecto para \w expiación|strong="H2403"\w*; y purificarán el \w altar|strong="H4196"\w* como lo purificaron con el \w novillo|strong="H6499"\w*.  
\v 23 Cuando acabes \w de|strong="H4480"\w* purificarlo, \w ofrecerás|strong="H7126"\w* un \w novillo|strong="H1241"\w* \w de|strong="H4480"\w* la vacada sin defecto, \w y|strong="H1241"\w* un carnero \w del|strong="H4480"\w* \w rebaño|strong="H6629"\w* sin defecto.  
\v 24 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* \w ofrecerás|strong="H7126"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Yahvé; \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w echarán|strong="H7993"\w* \w sal|strong="H4417"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w ofrecerán|strong="H7126"\w* \w en|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w a|strong="H3068"\w* Yahvé.   
\p
\v 25 «\w Por|strong="H4480"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w ofrecerás|strong="H6213"\w* un \w macho|strong="H8163"\w* cabrío \w cada|strong="H3117"\w* \w día|strong="H3117"\w* como ofrenda \w por|strong="H4480"\w* \w el|strong="H1121"\w* \w pecado|strong="H2403"\w*; también \w ofrecerán|strong="H6213"\w* un \w novillo|strong="H1121"\w* \w de|strong="H4480"\w* la vacada \w y|strong="H1241"\w* un carnero \w del|strong="H4480"\w* \w rebaño|strong="H6629"\w*, sin defecto.  
\v 26 \w Por|strong="H3027"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* harán \w expiación|strong="H3722"\w* \w por|strong="H3027"\w* el \w altar|strong="H4196"\w* y lo purificarán; así lo consagrarán.  
\v 27 \w Y|strong="H3068"\w* \w cuando|strong="H3117"\w* \w se|strong="H1961"\w* hayan \w cumplido|strong="H6213"\w* estos \w días|strong="H3117"\w*, \w el|strong="H5921"\w* \w octavo|strong="H8066"\w* \w día|strong="H3117"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* adelante, \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w ofrecerán|strong="H6213"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* vuestros \w holocaustos|strong="H5930"\w* \w y|strong="H5921"\w* vuestras ofrendas \w de|strong="H5921"\w* paz; \w y|strong="H5921"\w* \w yo|strong="H6213"\w* \w os|strong="H5921"\w* \w seré|strong="H1961"\w* propicio, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor Yahvé».   
\c 44
\p
\v 1 Me hizo \w volver|strong="H7725"\w* \w luego|strong="H1931"\w* \w por|strong="H1870"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* de \w la|strong="H1931"\w* \w puerta|strong="H8179"\w* \w exterior|strong="H2435"\w* del \w santuario|strong="H4720"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w mira|strong="H6437"\w* \w hacia|strong="H1870"\w* \w el|strong="H1931"\w* oriente; y estaba \w cerrada|strong="H5462"\w*.  
\v 2 \w Y|strong="H3068"\w* \w me|strong="H3588"\w* dijo Yahvé: «\w Esta|strong="H2088"\w* \w puerta|strong="H8179"\w* \w estará|strong="H1961"\w* \w cerrada|strong="H5462"\w*; \w no|strong="H3808"\w* \w se|strong="H1961"\w* \w abrirá|strong="H6605"\w*, \w ni|strong="H3808"\w* entrará \w por|strong="H3588"\w* ella hombre alguno, \w porque|strong="H3588"\w* Yahvé \w Dios|strong="H3068"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* entró \w por|strong="H3588"\w* ella; \w estará|strong="H1961"\w*, \w por|strong="H3588"\w* tanto, \w cerrada|strong="H5462"\w*.  
\v 3 \w En|strong="H3318"\w* cuanto al \w príncipe|strong="H5387"\w*, \w por|strong="H1870"\w* ser \w el|strong="H1931"\w* \w príncipe|strong="H5387"\w*, \w él|strong="H1931"\w* \w se|strong="H1931"\w* sentará \w en|strong="H3318"\w* \w ella|strong="H1931"\w* para comer \w pan|strong="H3899"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé; \w por|strong="H1870"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* del vestíbulo \w de|strong="H6440"\w* \w la|strong="H1931"\w* \w puerta|strong="H8179"\w* entrará, y \w por|strong="H1870"\w* \w el|strong="H1931"\w* \w mismo|strong="H1931"\w* \w camino|strong="H1870"\w* \w saldrá|strong="H3318"\w*».   
\p
\v 4 Me llevó luego \w hacia|strong="H1870"\w* la \w puerta|strong="H8179"\w* del \w norte|strong="H6828"\w*, \w por|strong="H1870"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* la \w casa|strong="H1004"\w*; \w y|strong="H3519"\w* \w miré|strong="H7200"\w*, \w y|strong="H3519"\w* he \w aquí|strong="H2009"\w* que la \w gloria|strong="H3519"\w* \w de|strong="H6440"\w* Yahvé había llenado la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* Yahvé; \w y|strong="H3519"\w* me postré sobre \w mi|strong="H2009"\w* \w rostro|strong="H6440"\w*.   
\p
\v 5 \w Y|strong="H3068"\w* me \w dijo|strong="H1696"\w* Yahvé: «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w pon|strong="H7760"\w* \w corazón|strong="H3820"\w*, y \w mira|strong="H7200"\w* con tus \w ojos|strong="H5869"\w*, y \w oye|strong="H8085"\w* con tus \w oídos|strong="H8085"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1121"\w* yo \w hablo|strong="H1696"\w* contigo sobre \w todas|strong="H3605"\w* las \w ordenanzas|strong="H2708"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Yahvé, y \w todas|strong="H3605"\w* sus \w leyes|strong="H8451"\w*; y \w pon|strong="H7760"\w* \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* las entradas \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w*, y \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las salidas del \w santuario|strong="H4720"\w*.  
\v 6 \w Y|strong="H3068"\w* dirás \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w rebeldes|strong="H4805"\w*, \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*: \w Así|strong="H3541"\w* dice \w el|strong="H3605"\w* Señor Yahvé: \w Basta|strong="H7227"\w* ya de \w todas|strong="H3605"\w* vuestras \w abominaciones|strong="H8441"\w*, oh \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*;  
