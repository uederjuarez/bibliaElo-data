\v 9 “\w Toma|strong="H3947"\w* también \w para|strong="H5921"\w* \w ti|strong="H5921"\w* \w trigo|strong="H2406"\w*, \w cebada|strong="H8184"\w*, judías, \w lentejas|strong="H5742"\w*, mijo \w y|strong="H5921"\w* espelta; ponlos \w en|strong="H5921"\w* una \w vasija|strong="H3627"\w* \w y|strong="H5921"\w* \w hazte|strong="H6213"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w pan|strong="H3899"\w*. \w El|strong="H5921"\w* \w número|strong="H4557"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w que|strong="H5921"\w* estés \w acostado|strong="H7901"\w* \w de|strong="H5921"\w* \w lado|strong="H6654"\w*, \w trescientos|strong="H7969"\w* \w noventa|strong="H8673"\w* \w días|strong="H3117"\w*, comerás \w de|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 10 La \w comida|strong="H3978"\w* \w que|strong="H5704"\w* has \w de|strong="H5704"\w* comer será \w por|strong="H5704"\w* peso: \w veinte|strong="H6242"\w* \w siclos|strong="H8255"\w*\f + \fr 4:10 \ft «Bamah» significa «Lugar Alto».\f* \w al|strong="H5704"\w* \w día|strong="H3117"\w*; la comerás \w de|strong="H5704"\w* \w tiempo|strong="H6256"\w* \w en|strong="H5704"\w* \w tiempo|strong="H6256"\w*.  
\v 11 \w Beberás|strong="H8354"\w* el \w agua|strong="H4325"\w* \w por|strong="H5704"\w* \w medida|strong="H4884"\w*: la sexta \w parte|strong="H8345"\w* \w de|strong="H5704"\w* un \w hin|strong="H1969"\w*; la \w beberás|strong="H8354"\w* \w de|strong="H5704"\w* \w tiempo|strong="H6256"\w* \w en|strong="H5704"\w* \w tiempo|strong="H6256"\w*.  
\v 12 \w Lo|strong="H1931"\w* comerás \w como|strong="H1931"\w* \w tortas|strong="H5692"\w* \w de|strong="H5869"\w* \w cebada|strong="H8184"\w*, y \w lo|strong="H1931"\w* cocerás \w a|strong="H3068"\w* \w la|strong="H1931"\w* vista \w de|strong="H5869"\w* \w ellos|strong="H1931"\w* con excrementos humanos”.  
\v 13 \w Y|strong="H3068"\w* dijo Yahvé: «\w Así|strong="H3602"\w* comerán \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* su \w pan|strong="H3899"\w* \w inmundo|strong="H2931"\w* \w entre|strong="H8033"\w* las \w naciones|strong="H1471"\w* \w a|strong="H3068"\w* \w donde|strong="H8033"\w* yo \w los|strong="H1121"\w* arrojaré».   
\p
\v 14 Entonces dije: «¡Ah, Señor Yahvé! He \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* \w mi|strong="H2009"\w* \w alma|strong="H5315"\w* \w nunca|strong="H3808"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* \w contaminado|strong="H2930"\w*; \w desde|strong="H5704"\w* \w mi|strong="H2009"\w* \w juventud|strong="H5271"\w* \w hasta|strong="H5704"\w* \w ahora|strong="H6258"\w* \w nunca|strong="H3808"\w* he comido \w animal|strong="H5315"\w* muerto \w ni|strong="H3808"\w* despedazado \w por|strong="H5704"\w* fieras, \w ni|strong="H3808"\w* \w jamás|strong="H3808"\w* \w ha|strong="H3808"\w* entrado \w en|strong="H5704"\w* \w mi|strong="H2009"\w* \w boca|strong="H6310"\w* \w carne|strong="H1320"\w* abominable».   
\p
\v 15 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* respondió: «He aquí \w que|strong="H5921"\w* \w te|strong="H5921"\w* permito usar estiércol \w de|strong="H5921"\w* buey \w en|strong="H5921"\w* \w lugar|strong="H8478"\w* \w de|strong="H5921"\w* excremento humano \w para|strong="H5921"\w* \w que|strong="H5921"\w* prepares \w tu|strong="H6213"\w* \w pan|strong="H3899"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*».   
\p
\v 16 Me dijo además: “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, he \w aquí|strong="H2005"\w* \w que|strong="H4325"\w* voy \w a|strong="H3068"\w* quebrantar \w el|strong="H1121"\w* sustento \w del|strong="H8354"\w* \w pan|strong="H3899"\w* en Jerusalén. Comerán \w el|strong="H1121"\w* \w pan|strong="H3899"\w* por \w peso|strong="H4948"\w* y con angustia, y \w beberán|strong="H8354"\w* \w el|strong="H1121"\w* \w agua|strong="H4325"\w* por \w medida|strong="H4884"\w* y con espanto;  
\v 17 \w para|strong="H4616"\w* \w que|strong="H4325"\w*, faltándoles el \w pan|strong="H3899"\w* y el \w agua|strong="H4325"\w*, se miren unos \w a|strong="H3068"\w* otros con asombro y se consuman en su \w iniquidad|strong="H5771"\w*.   
\c 5
\p
\v 1 “\w Y|strong="H3068"\w* tú, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w toma|strong="H3947"\w* una \w espada|strong="H2719"\w* afilada; \w tómala|strong="H3947"\w* \w y|strong="H5921"\w* úsala \w como|strong="H5921"\w* \w navaja|strong="H8593"\w* \w de|strong="H5921"\w* barbero, \w y|strong="H5921"\w* pásala \w sobre|strong="H5921"\w* tu \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* tu \w barba|strong="H2206"\w*. \w Toma|strong="H3947"\w* \w luego|strong="H5674"\w* una balanza \w de|strong="H5921"\w* \w peso|strong="H4948"\w* \w y|strong="H5921"\w* reparte \w los|strong="H1121"\w* pelos.  
\v 2 Quemarás una \w tercera|strong="H7992"\w* parte \w en|strong="H8432"\w* el fuego \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w la|strong="H1197"\w* \w ciudad|strong="H5892"\w*, \w cuando|strong="H3117"\w* se cumplan los \w días|strong="H3117"\w* del asedio; \w tomarás|strong="H3947"\w* otra \w tercera|strong="H7992"\w* parte \w y|strong="H1197"\w* \w la|strong="H1197"\w* golpearás con \w la|strong="H1197"\w* \w espada|strong="H2719"\w* \w alrededor|strong="H5439"\w* de \w la|strong="H1197"\w* \w ciudad|strong="H5892"\w*; \w y|strong="H1197"\w* dispersarás \w la|strong="H1197"\w* otra \w tercera|strong="H7992"\w* parte al \w viento|strong="H7307"\w*, \w y|strong="H1197"\w* yo desenvainaré \w la|strong="H1197"\w* \w espada|strong="H2719"\w* tras ellos.  
\v 3 \w Tomarás|strong="H3947"\w* de \w allí|strong="H8033"\w* unos \w pocos|strong="H4557"\w* en \w número|strong="H4557"\w*, y los atarás en las faldas de tu manto.  
\v 4 \w De|strong="H4480"\w* \w estos|strong="H1992"\w* \w tomarás|strong="H3947"\w* \w otra|strong="H5750"\w* vez algunos, \w los|strong="H1992"\w* echarás \w en|strong="H4480"\w* \w medio|strong="H8432"\w* \w del|strong="H4480"\w* fuego y \w los|strong="H1992"\w* \w quemarás|strong="H8313"\w*; \w de|strong="H4480"\w* allí \w saldrá|strong="H3318"\w* un fuego \w contra|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*.   
\p
\v 5 “\w Así|strong="H3541"\w* dice el Señor Yahvé: ‘\w Esta|strong="H2063"\w* \w es|strong="H2063"\w* Jerusalén; yo \w la|strong="H2063"\w* \w puse|strong="H7760"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de las \w naciones|strong="H1471"\w* \w y|strong="H3541"\w* de las tierras \w que|strong="H3541"\w* están \w a|strong="H3068"\w* su \w alrededor|strong="H5439"\w*.  
\v 6 \w Y|strong="H3068"\w* \w ella|strong="H4480"\w* \w se|strong="H4480"\w* \w ha|strong="H3808"\w* rebelado \w contra|strong="H4480"\w* mis decretos \w con|strong="H4480"\w* \w más|strong="H3588"\w* \w impiedad|strong="H7564"\w* \w que|strong="H3588"\w* las \w naciones|strong="H1471"\w*, \w y|strong="H3588"\w* \w contra|strong="H4480"\w* mis \w estatutos|strong="H2708"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* las tierras \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w rodean|strong="H5439"\w*; \w porque|strong="H3588"\w* han \w desechado|strong="H3988"\w* mis decretos, \w y|strong="H3588"\w* \w en|strong="H4480"\w* mis \w estatutos|strong="H2708"\w* \w no|strong="H3808"\w* han \w andado|strong="H1980"\w*’.   
\p
\v 7 “\w Por|strong="H3282"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H6213"\w* Señor Yahvé: ‘\w Por|strong="H3282"\w* \w haber|strong="H3808"\w* sido vosotros \w más|strong="H4480"\w* rebeldes \w que|strong="H4480"\w* las \w naciones|strong="H1471"\w* \w que|strong="H4480"\w* \w os|strong="H4480"\w* \w rodean|strong="H5439"\w*, \w y|strong="H3541"\w* \w no|strong="H3808"\w* \w haber|strong="H3808"\w* \w andado|strong="H1980"\w* \w en|strong="H4480"\w* mis \w estatutos|strong="H2708"\w* \w ni|strong="H3808"\w* guardado mis decretos, \w ni|strong="H3808"\w* siquiera \w haber|strong="H3808"\w* actuado conforme \w a|strong="H3068"\w* los decretos \w de|strong="H4480"\w* las \w naciones|strong="H1471"\w* \w que|strong="H4480"\w* \w os|strong="H4480"\w* \w rodean|strong="H5439"\w*;  
\v 8 \w por|strong="H5921"\w* \w eso|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* \w yo|strong="H6213"\w*, \w yo|strong="H6213"\w* \w mismo|strong="H1571"\w*, estoy \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H1571"\w* \w ejecutaré|strong="H6213"\w* \w juicios|strong="H4941"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* ante \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.  
\v 9 \w Y|strong="H3068"\w* \w haré|strong="H6213"\w* \w en|strong="H5750"\w* ti \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w nunca|strong="H3808"\w* \w hice|strong="H6213"\w*, y \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w haré|strong="H6213"\w*, \w a|strong="H3068"\w* causa \w de|strong="H5750"\w* \w todas|strong="H3605"\w* tus \w abominaciones|strong="H8441"\w*.  
\v 10 \w Por|strong="H3651"\w* \w eso|strong="H3651"\w* \w los|strong="H1121"\w* padres comerán \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* ti, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* comerán \w a|strong="H3068"\w* sus padres; y \w ejecutaré|strong="H6213"\w* \w juicios|strong="H8201"\w* \w en|strong="H8432"\w* ti, y \w esparciré|strong="H2219"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w vientos|strong="H7307"\w* \w todo|strong="H3605"\w* \w tu|strong="H6213"\w* remanente.  
\v 11 \w Por|strong="H3282"\w* \w tanto|strong="H3651"\w*, \w vivo|strong="H2416"\w* yo — \w dice|strong="H5002"\w* \w el|strong="H3605"\w* Señor Yahvé —, \w ciertamente|strong="H1571"\w*, \w por|strong="H3282"\w* \w haber|strong="H3808"\w* profanado mi \w santuario|strong="H4720"\w* \w con|strong="H1571"\w* \w todas|strong="H3605"\w* tus cosas detestables \w y|strong="H1571"\w* \w con|strong="H1571"\w* \w todas|strong="H3605"\w* tus \w abominaciones|strong="H8441"\w*, yo \w también|strong="H1571"\w* \w te|strong="H5869"\w* \w quebrantaré|strong="H1639"\w*; mi \w ojo|strong="H5869"\w* \w no|strong="H3808"\w* \w perdonará|strong="H2550"\w*, \w ni|strong="H3808"\w* tendré \w misericordia|strong="H2550"\w*.  
\v 12 Una \w tercera|strong="H7992"\w* parte de ti \w morirá|strong="H4191"\w* de peste y será consumida por \w el|strong="H3605"\w* \w hambre|strong="H7458"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ti; una \w tercera|strong="H7992"\w* parte \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w alrededor|strong="H5439"\w* de ti; y una \w tercera|strong="H7992"\w* parte \w esparciré|strong="H2219"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w vientos|strong="H7307"\w*, y tras \w ellos|strong="H3605"\w* desenvainaré \w la|strong="H3605"\w* \w espada|strong="H2719"\w*.   
\p
\v 13 “‘\w Así|strong="H3588"\w* \w se|strong="H3045"\w* desahogará mi \w enojo|strong="H2534"\w* \w y|strong="H3588"\w* saciaré \w en|strong="H3588"\w* ellos mi \w ira|strong="H2534"\w*, \w y|strong="H3588"\w* quedaré satisfecho. \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, he \w hablado|strong="H1696"\w* \w en|strong="H3588"\w* mi \w celo|strong="H7068"\w*, \w cuando|strong="H3588"\w* haya consumado \w en|strong="H3588"\w* ellos mi \w ira|strong="H2534"\w*.   
\p
\v 14 “‘\w Y|strong="H3068"\w* \w a|strong="H3068"\w* ti \w te|strong="H5869"\w* convertiré en soledad y en \w oprobio|strong="H2781"\w* entre las \w naciones|strong="H1471"\w* \w que|strong="H3605"\w* \w te|strong="H5869"\w* \w rodean|strong="H5439"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5414"\w* \w todo|strong="H3605"\w* transeúnte.  
\v 15 \w Y|strong="H3068"\w* \w serás|strong="H1961"\w* \w oprobio|strong="H2781"\w* y escarnio, escarmiento y espanto \w para|strong="H1961"\w* las \w naciones|strong="H1471"\w* \w que|strong="H1961"\w* te \w rodean|strong="H5439"\w*, \w cuando|strong="H1961"\w* \w yo|strong="H6213"\w* ejecute \w juicios|strong="H8201"\w* en ti con \w ira|strong="H2534"\w* \w e|strong="H3068"\w* indignación, y con reprensiones de \w ira|strong="H2534"\w*. \w Yo|strong="H6213"\w*, Yahvé, he \w hablado|strong="H1696"\w*.  
\v 16 \w cuando|strong="H1961"\w* \w envíe|strong="H7971"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w* \w las|strong="H5921"\w* flechas \w malignas|strong="H7451"\w* \w del|strong="H5921"\w* \w hambre|strong="H7458"\w*, \w que|strong="H5921"\w* \w son|strong="H1961"\w* \w para|strong="H5921"\w* destrucción, \w las|strong="H5921"\w* cuales \w enviaré|strong="H7971"\w* \w para|strong="H5921"\w* \w destruirte|strong="H7843"\w*. Aumentaré \w el|strong="H5921"\w* \w hambre|strong="H7458"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* \w quebraré|strong="H7665"\w* tu sustento \w de|strong="H5921"\w* \w pan|strong="H3899"\w*.  
\v 17 \w Enviaré|strong="H7971"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w hambre|strong="H7458"\w* \w y|strong="H5921"\w* \w bestias|strong="H2416"\w* feroces, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w dejarán|strong="H7971"\w* sin hijos. \w La|strong="H5921"\w* \w pestilencia|strong="H1698"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w pasarán|strong="H5674"\w* \w por|strong="H5921"\w* \w ti|strong="H5921"\w*. Traeré \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*. Yo, Yahveh, \w lo|strong="H5921"\w* he \w dicho|strong="H1696"\w*”.   
\c 6
\p
\v 1 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w hombre|strong="H1121"\w*, dirige tu \w rostro|strong="H6440"\w* \w hacia|strong="H6440"\w* \w los|strong="H1121"\w* \w montes|strong="H2022"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, y \w profetiza|strong="H5012"\w* \w contra|strong="H6440"\w* ellos.  
\v 3 Dirás: ¡\w Montes|strong="H2022"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w oíd|strong="H8085"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w del|strong="H5921"\w* Señor Yahvé! \w Así|strong="H3541"\w* \w dice|strong="H1697"\w* \w el|strong="H5921"\w* Señor Yahvé \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* colinas, \w a|strong="H3068"\w* \w los|strong="H5921"\w* arroyos \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* valles: He \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w yo|strong="H2009"\w*, \w yo|strong="H2009"\w* mismo, traeré \w espada|strong="H2719"\w* \w sobre|strong="H5921"\w* \w vosotros|strong="H8085"\w*, \w y|strong="H5921"\w* destruiré vuestros lugares \w altos|strong="H1116"\w*.  
\v 4 Vuestros \w altares|strong="H4196"\w* serán \w asolados|strong="H8074"\w*, y vuestras imágenes \w del|strong="H4196"\w* sol serán quebradas; y haré que \w caigan|strong="H5307"\w* vuestros \w muertos|strong="H2491"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vuestros \w ídolos|strong="H1544"\w*.  
\v 5 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* \w los|strong="H1121"\w* cadáveres \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* sus \w ídolos|strong="H1544"\w*, y \w esparciré|strong="H2219"\w* vuestros \w huesos|strong="H6106"\w* \w alrededor|strong="H5439"\w* \w de|strong="H6440"\w* vuestros \w altares|strong="H4196"\w*.  
\v 6 En \w todas|strong="H3605"\w* vuestras moradas, las \w ciudades|strong="H5892"\w* serán devastadas y \w los|strong="H3605"\w* \w lugares|strong="H5892"\w* \w altos|strong="H1116"\w* quedarán desolados, \w para|strong="H4616"\w* \w que|strong="H4616"\w* vuestros \w altares|strong="H4196"\w* sean asolados y devastados, vuestros \w ídolos|strong="H1544"\w* sean quebrados y se acaben, vuestras imágenes \w del|strong="H4196"\w* sol sean \w destruidas|strong="H2717"\w* y vuestras \w obras|strong="H4639"\w* sean deshechas.  
\v 7 \w Y|strong="H3068"\w* \w los|strong="H3588"\w* \w muertos|strong="H2491"\w* \w caerán|strong="H5307"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* vosotros; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé.   
\p
\v 8 “‘Sin embargo, dejaré un remanente, \w pues|strong="H1961"\w* \w tendréis|strong="H1961"\w* \w algunos|strong="H3498"\w* \w que|strong="H1961"\w* escaparán de la \w espada|strong="H2719"\w* entre las \w naciones|strong="H1471"\w*, \w cuando|strong="H1961"\w* \w seáis|strong="H1961"\w* esparcidos por las tierras.  
\v 9 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w de|strong="H5921"\w* vosotros escapen \w se|strong="H5921"\w* acordarán \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w entre|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w que|strong="H5921"\w* sean llevados cautivos; \w de|strong="H5921"\w* \w cómo|strong="H5921"\w* fui \w quebrantado|strong="H7665"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* su \w corazón|strong="H3820"\w* \w fornicario|strong="H2181"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* sus \w ojos|strong="H5869"\w* \w que|strong="H5921"\w* \w fornicaron|strong="H2181"\w* tras sus \w ídolos|strong="H1544"\w*. \w Y|strong="H3068"\w* \w se|strong="H5921"\w* aborrecerán \w a|strong="H3068"\w* \w sí|strong="H6440"\w* mismos \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w males|strong="H7451"\w* \w que|strong="H5921"\w* han \w hecho|strong="H6213"\w* \w en|strong="H5921"\w* \w todas|strong="H3605"\w* sus \w abominaciones|strong="H8441"\w*.  
\v 10 \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé; \w no|strong="H3808"\w* \w en|strong="H3588"\w* \w vano|strong="H2600"\w* he \w dicho|strong="H1696"\w* \w que|strong="H3588"\w* les \w haría|strong="H6213"\w* \w este|strong="H2063"\w* \w mal|strong="H7451"\w*’.   
\p
\v 11 “\w Así|strong="H3541"\w* dice \w el|strong="H3605"\w* Señor Yahvé: ‘Bate tus \w manos|strong="H3709"\w*, golpea con tu \w pie|strong="H7272"\w*, \w y|strong="H3541"\w* di: «¡Ay!», por \w todas|strong="H3605"\w* las graves \w abominaciones|strong="H8441"\w* \w de|strong="H7451"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H7451"\w* \w Israel|strong="H3478"\w*; porque \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w de|strong="H7451"\w* \w hambre|strong="H7458"\w* \w y|strong="H3541"\w* \w de|strong="H7451"\w* peste.  
\v 12 \w El|strong="H5307"\w* que esté \w lejos|strong="H7350"\w* \w morirá|strong="H4191"\w* de peste; \w el|strong="H5307"\w* que esté \w cerca|strong="H7138"\w* \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*; y \w el|strong="H5307"\w* que \w quede|strong="H7604"\w* y sea asediado \w morirá|strong="H4191"\w* de \w hambre|strong="H7458"\w*. Así consumaré mi \w furor|strong="H2534"\w* sobre ellos.  
\v 13 \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé, \w cuando|strong="H3588"\w* sus \w muertos|strong="H2491"\w* \w estén|strong="H1961"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* sus \w ídolos|strong="H1544"\w*, \w alrededor|strong="H5439"\w* \w de|strong="H3588"\w* sus \w altares|strong="H4196"\w*, \w en|strong="H8432"\w* \w todo|strong="H3605"\w* \w collado|strong="H1389"\w* \w alto|strong="H7311"\w*, \w en|strong="H8432"\w* \w todas|strong="H3605"\w* las cumbres \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w montes|strong="H2022"\w*, \w debajo|strong="H8478"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w frondoso|strong="H7488"\w* \w y|strong="H3588"\w* \w debajo|strong="H8478"\w* \w de|strong="H3588"\w* \w toda|strong="H3605"\w* encina \w espesa|strong="H5687"\w*, \w lugares|strong="H4725"\w* \w donde|strong="H8033"\w* \w ofrecieron|strong="H7311"\w* incienso agradable \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w ídolos|strong="H1544"\w*.  
\v 14 \w Y|strong="H3068"\w* \w extenderé|strong="H5186"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w ellos|strong="H3027"\w* \w y|strong="H3588"\w* \w haré|strong="H5414"\w* \w la|strong="H5921"\w* tierra \w más|strong="H3588"\w* \w desolada|strong="H8077"\w* \w y|strong="H3588"\w* devastada \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w* \w hacia|strong="H5921"\w* Dibla, \w en|strong="H5921"\w* \w todas|strong="H3605"\w* sus moradas. \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé’”.   
\b  
\c 7
\p
\v 1 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Y|strong="H3068"\w* tú, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, di: \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: ‘¡\w El|strong="H5921"\w* \w fin|strong="H7093"\w*! \w El|strong="H5921"\w* \w fin|strong="H7093"\w* \w ha|strong="H3541"\w* llegado \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* cuatro extremos \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.  
\v 3 \w Ahora|strong="H6258"\w* \w el|strong="H5921"\w* \w fin|strong="H7093"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w enviaré|strong="H7971"\w* \w mi|strong="H5921"\w* ira \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*; \w te|strong="H5921"\w* \w juzgaré|strong="H8199"\w* \w según|strong="H5921"\w* tus \w caminos|strong="H1870"\w* \w y|strong="H5921"\w* \w pondré|strong="H5414"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w todas|strong="H3605"\w* tus \w abominaciones|strong="H8441"\w*.  
\v 4 \w Mi|strong="H5921"\w* \w ojo|strong="H5869"\w* \w no|strong="H3808"\w* \w te|strong="H5869"\w* \w perdonará|strong="H2550"\w*, \w ni|strong="H3808"\w* \w tendré|strong="H1961"\w* \w misericordia|strong="H2550"\w*; \w antes|strong="H3588"\w* \w bien|strong="H3588"\w*, \w haré|strong="H5414"\w* recaer \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* tus propios \w caminos|strong="H1870"\w*, \w y|strong="H3588"\w* tus \w abominaciones|strong="H8441"\w* \w estarán|strong="H1961"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*. \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé’.   
\p
\v 5 “\w Así|strong="H3541"\w* dice el Señor Yahvé: ‘¡Un \w mal|strong="H7451"\w*! ¡He \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* viene un \w mal|strong="H7451"\w*, único en su género!  
\v 6 El \w fin|strong="H7093"\w* ha llegado. ¡Ha llegado el \w fin|strong="H7093"\w*! Se ha despertado contra ti. ¡He \w aquí|strong="H2009"\w* que viene!  
\v 7 La fatalidad \w ha|strong="H3808"\w* llegado contra ti, oh habitante \w de|strong="H6256"\w* la tierra. \w El|strong="H3427"\w* \w tiempo|strong="H6256"\w* \w ha|strong="H3808"\w* llegado, \w se|strong="H3808"\w* acerca \w el|strong="H3427"\w* \w día|strong="H3117"\w*; \w día|strong="H3117"\w* \w de|strong="H6256"\w* tumulto y \w no|strong="H3808"\w* \w de|strong="H6256"\w* alegría en \w los|strong="H3427"\w* \w montes|strong="H2022"\w*.  
\v 8 \w Ahora|strong="H6258"\w*, pronto \w derramaré|strong="H8210"\w* \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* consumaré \w mi|strong="H5921"\w* \w furor|strong="H2534"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*; \w te|strong="H5921"\w* \w juzgaré|strong="H8199"\w* \w según|strong="H5921"\w* tus \w caminos|strong="H1870"\w* \w y|strong="H5921"\w* \w pondré|strong="H5414"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w todas|strong="H3605"\w* tus \w abominaciones|strong="H8441"\w*.  
\v 9 \w Mi|strong="H5921"\w* \w ojo|strong="H5869"\w* \w no|strong="H3808"\w* \w perdonará|strong="H2550"\w*, \w ni|strong="H3808"\w* \w tendré|strong="H1961"\w* \w misericordia|strong="H2550"\w*. \w Según|strong="H5921"\w* tus \w caminos|strong="H1870"\w* \w te|strong="H5869"\w* castigaré, \w y|strong="H3588"\w* tus \w abominaciones|strong="H8441"\w* \w estarán|strong="H1961"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* vosotros. \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé, \w el|strong="H5921"\w* \w que|strong="H3588"\w* castiga.   
\p
\v 10 “‘¡He \w aquí|strong="H2009"\w* el \w día|strong="H3117"\w*! ¡He \w aquí|strong="H2009"\w* \w que|strong="H3117"\w* \w viene|strong="H2087"\w*! La fatalidad ha \w salido|strong="H3318"\w*; la \w vara|strong="H4294"\w* ha \w florecido|strong="H6692"\w*, la soberbia ha reverdecido.  
\v 11 La \w violencia|strong="H2555"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* levantado como \w vara|strong="H4294"\w* de maldad; \w no|strong="H3808"\w* \w quedará|strong="H6965"\w* \w nada|strong="H3808"\w* de \w ellos|strong="H1992"\w*, \w ni|strong="H3808"\w* de \w su|strong="H1992"\w* \w multitud|strong="H1995"\w*, \w ni|strong="H3808"\w* de \w su|strong="H1992"\w* riqueza, \w ni|strong="H3808"\w* habrá \w nada|strong="H3808"\w* de valor \w entre|strong="H3808"\w* \w ellos|strong="H1992"\w*.  
\v 12 \w El|strong="H3588"\w* \w tiempo|strong="H6256"\w* ha \w llegado|strong="H5060"\w*, \w el|strong="H3588"\w* \w día|strong="H3117"\w* se acerca. \w No|strong="H3588"\w* se alegre \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w compra|strong="H7069"\w* ni llore \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w vende|strong="H4376"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w ira|strong="H2740"\w* está sobre \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w multitud|strong="H1995"\w*.  
\v 13 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w vende|strong="H4376"\w* \w no|strong="H3808"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* \w lo|strong="H3808"\w* vendido \w aunque|strong="H3588"\w* queden \w vivos|strong="H2416"\w*; \w pues|strong="H3588"\w* \w la|strong="H3588"\w* \w visión|strong="H2377"\w* \w se|strong="H3808"\w* refiere \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w multitud|strong="H1995"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w será|strong="H3808"\w* revocada; \w y|strong="H3588"\w* \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w iniquidad|strong="H5771"\w*, \w nadie|strong="H3808"\w* \w podrá|strong="H4376"\w* fortalecer \w su|strong="H3588"\w* \w vida|strong="H2416"\w*.  
\v 14 Han tocado \w la|strong="H3588"\w* \w trompeta|strong="H8628"\w* \w y|strong="H3588"\w* han preparado \w todo|strong="H3605"\w*, \w pero|strong="H3588"\w* \w nadie|strong="H3605"\w* sale \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w*; \w porque|strong="H3588"\w* mi \w ira|strong="H1980"\w* está sobre \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w multitud|strong="H1995"\w*.   
\p
\v 15 “‘\w Fuera|strong="H2351"\w* la \w espada|strong="H2719"\w*, y dentro la peste y el \w hambre|strong="H7458"\w*; el que esté en el \w campo|strong="H7704"\w* \w morirá|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, y al que esté en la \w ciudad|strong="H5892"\w* lo devorarán el \w hambre|strong="H7458"\w* y la peste.  
\v 16 \w Y|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H1961"\w* escapen de \w ellos|strong="H3605"\w* \w huirán|strong="H6403"\w* y \w estarán|strong="H1961"\w* en \w los|strong="H3605"\w* \w montes|strong="H2022"\w* \w como|strong="H1961"\w* palomas de \w los|strong="H3605"\w* valles, \w gimiendo|strong="H1993"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w*, \w cada|strong="H3605"\w* uno por su \w iniquidad|strong="H5771"\w*.  
\v 17 \w Todas|strong="H3605"\w* las \w manos|strong="H3027"\w* se debilitarán, y \w todas|strong="H3605"\w* las \w rodillas|strong="H1290"\w* se volverán \w de|strong="H4325"\w* \w agua|strong="H4325"\w*.  
\v 18 Se ceñirán también \w de|strong="H6440"\w* cilicio, y \w el|strong="H3605"\w* terror \w los|strong="H3605"\w* \w cubrirá|strong="H3680"\w*; en \w todo|strong="H3605"\w* \w rostro|strong="H6440"\w* habrá vergüenza, y calvicie en \w todas|strong="H3605"\w* sus \w cabezas|strong="H7218"\w*.  
\v 19 \w Arrojarán|strong="H7993"\w* \w su|strong="H3588"\w* \w plata|strong="H3701"\w* \w en|strong="H3588"\w* las \w calles|strong="H2351"\w*, \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w oro|strong="H2091"\w* \w será|strong="H1961"\w* \w como|strong="H3588"\w* \w cosa|strong="H5315"\w* \w inmunda|strong="H5079"\w*. \w Ni|strong="H3808"\w* \w su|strong="H3588"\w* \w plata|strong="H3701"\w* \w ni|strong="H3808"\w* \w su|strong="H3588"\w* \w oro|strong="H2091"\w* \w podrán|strong="H3201"\w* librarlos \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* ira \w de|strong="H3588"\w* Yahvé; \w no|strong="H3808"\w* \w saciarán|strong="H7646"\w* \w su|strong="H3588"\w* \w alma|strong="H5315"\w* \w ni|strong="H3808"\w* llenarán sus \w entrañas|strong="H4578"\w*, \w porque|strong="H3588"\w* \w ha|strong="H3808"\w* \w sido|strong="H1961"\w* \w el|strong="H3588"\w* \w tropezadero|strong="H4383"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w maldad|strong="H5771"\w*.  
\v 20 Convirtieron \w la|strong="H5921"\w* belleza \w de|strong="H5921"\w* sus ornamentos \w en|strong="H5921"\w* \w soberbia|strong="H1347"\w*, \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* sus \w imágenes|strong="H6754"\w* \w abominables|strong="H8251"\w* \w y|strong="H5921"\w* detestables; \w por|strong="H5921"\w* \w eso|strong="H3651"\w* \w se|strong="H5921"\w* \w lo|strong="H5921"\w* he convertido \w en|strong="H5921"\w* cosa \w inmunda|strong="H5079"\w*.  
\v 21 \w Y|strong="H3068"\w* la \w entregaré|strong="H5414"\w* en \w manos|strong="H3027"\w* \w de|strong="H5414"\w* extraños \w para|strong="H5414"\w* ser saqueada, y \w a|strong="H3068"\w* los \w impíos|strong="H7563"\w* \w de|strong="H5414"\w* la tierra como botín; y la \w profanarán|strong="H2490"\w*.  
\v 22 \w Y|strong="H3068"\w* apartaré \w de|strong="H6440"\w* \w ellos|strong="H1992"\w* \w mi|strong="H2490"\w* \w rostro|strong="H6440"\w*, y \w profanarán|strong="H2490"\w* \w mi|strong="H2490"\w* lugar \w secreto|strong="H6845"\w*; pues entrarán en \w él|strong="H1992"\w* invasores y \w lo|strong="H1992"\w* \w profanarán|strong="H2490"\w*.   
\p
\v 23 “‘Prepara cadenas, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* tierra está \w llena|strong="H4390"\w* \w de|strong="H3588"\w* delitos \w de|strong="H3588"\w* \w sangre|strong="H1818"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w llena|strong="H4390"\w* \w de|strong="H3588"\w* \w violencia|strong="H2555"\w*.  
\v 24 Por tanto, traeré \w a|strong="H3068"\w* los \w más|strong="H1471"\w* malvados \w de|strong="H7451"\w* las \w naciones|strong="H1471"\w*, que \w poseerán|strong="H3423"\w* sus \w casas|strong="H1004"\w*; y haré cesar la \w soberbia|strong="H1347"\w* \w de|strong="H7451"\w* los poderosos, y sus santuarios serán profanados.  
\v 25 ¡La \w destrucción|strong="H7089"\w* viene! \w Buscarán|strong="H1245"\w* la \w paz|strong="H7965"\w*, pero no la habrá.  
\v 26 \w Vendrá|strong="H1961"\w* quebranto \w sobre|strong="H5921"\w* quebranto, \w y|strong="H5921"\w* \w habrá|strong="H1961"\w* \w rumor|strong="H8052"\w* \w sobre|strong="H5921"\w* \w rumor|strong="H8052"\w*; \w buscarán|strong="H1245"\w* \w respuesta|strong="H2377"\w* \w del|strong="H5921"\w* \w profeta|strong="H5030"\w*, pero \w la|strong="H5921"\w* \w ley|strong="H8451"\w* desaparecerá \w del|strong="H5921"\w* \w sacerdote|strong="H3548"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w consejo|strong="H6098"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w*.  
\v 27 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w hará|strong="H6213"\w* duelo, \w el|strong="H3588"\w* \w príncipe|strong="H5387"\w* \w se|strong="H3045"\w* \w vestirá|strong="H3847"\w* \w de|strong="H3588"\w* desolación \w y|strong="H3588"\w* las \w manos|strong="H3027"\w* del \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra temblarán. Según \w su|strong="H3588"\w* \w camino|strong="H1870"\w* \w haré|strong="H6213"\w* \w con|strong="H3588"\w* \w ellos|strong="H3027"\w*, \w y|strong="H3588"\w* \w con|strong="H3588"\w* sus propios \w juicios|strong="H4941"\w* \w los|strong="H3588"\w* \w juzgaré|strong="H8199"\w*. \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé’”.   
\c 8
\p
\v 1 \w En|strong="H5921"\w* \w el|strong="H5921"\w* \w sexto|strong="H8345"\w* \w año|strong="H8141"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w mes|strong="H2320"\w* \w sexto|strong="H8345"\w*, \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w cinco|strong="H2568"\w* días \w del|strong="H5921"\w* \w mes|strong="H2320"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* yo \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w*, \w y|strong="H5921"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w estaban|strong="H1961"\w* \w sentados|strong="H3427"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* \w allí|strong="H8033"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w del|strong="H5921"\w* Señor Yahvé \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*.  
\v 2 \w Y|strong="H3068"\w* \w miré|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* una \w figura|strong="H1823"\w* que \w parecía|strong="H5869"\w* \w de|strong="H5869"\w* fuego: desde la cintura para \w abajo|strong="H4295"\w*, fuego; y desde su cintura para \w arriba|strong="H4605"\w*, \w parecía|strong="H5869"\w* resplandor, \w como|strong="H1823"\w* el \w aspecto|strong="H4758"\w* del bronce bruñido.  
\v 3 \w Y|strong="H3068"\w* aquella \w figura|strong="H8403"\w* \w extendió|strong="H7971"\w* una \w mano|strong="H3027"\w*, y me \w tomó|strong="H3947"\w* \w por|strong="H3027"\w* una guedeja de \w mi|strong="H3389"\w* \w cabeza|strong="H7218"\w*; y el \w Espíritu|strong="H7307"\w* me elevó \w entre|strong="H8033"\w* la tierra y el \w cielo|strong="H8064"\w*, y me \w llevó|strong="H3947"\w* en \w visiones|strong="H4759"\w* de Dios \w a|strong="H3068"\w* Jerusalén, \w a|strong="H3068"\w* la entrada de la \w puerta|strong="H6607"\w* \w interior|strong="H6442"\w* \w que|strong="H3027"\w* \w mira|strong="H6437"\w* \w hacia|strong="H8033"\w* el \w norte|strong="H6828"\w*, \w donde|strong="H8033"\w* estaba la habitación de la imagen del \w celo|strong="H7068"\w*, la \w que|strong="H3027"\w* provoca \w a|strong="H3068"\w* celos.  
\v 4 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* que \w allí|strong="H8033"\w* \w estaba|strong="H2009"\w* la \w gloria|strong="H3519"\w* del Dios de \w Israel|strong="H3478"\w*, como la \w visión|strong="H4758"\w* que \w yo|strong="H2009"\w* había \w visto|strong="H7200"\w* en el \w campo|strong="H1237"\w*.   
\p
\v 5 \w Y|strong="H3068"\w* me dijo: «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w alza|strong="H5375"\w* \w ahora|strong="H4994"\w* tus \w ojos|strong="H5869"\w* \w hacia|strong="H1870"\w* \w el|strong="H1121"\w* lado \w del|strong="H4196"\w* \w norte|strong="H6828"\w*». \w Y|strong="H3068"\w* \w alcé|strong="H5375"\w* \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w* \w hacia|strong="H1870"\w* \w el|strong="H1121"\w* \w norte|strong="H6828"\w*, y he \w aquí|strong="H2009"\w* al \w norte|strong="H6828"\w*, junto \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*, aquella imagen \w del|strong="H4196"\w* \w celo|strong="H7068"\w* en la entrada.   
\p
\v 6 \w Me|strong="H5921"\w* dijo \w entonces|strong="H7725"\w*: «\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, ¿\w no|strong="H6213"\w* \w ves|strong="H7200"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w hacen|strong="H6213"\w* \w estos|strong="H1992"\w*? ¿\w Las|strong="H1992"\w* \w grandes|strong="H1419"\w* \w abominaciones|strong="H8441"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* comete \w aquí|strong="H6311"\w* \w para|strong="H5921"\w* alejarme \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w santuario|strong="H4720"\w*? Pero \w tórnate|strong="H7725"\w*, \w y|strong="H5921"\w* \w verás|strong="H7200"\w* \w abominaciones|strong="H8441"\w* \w aún|strong="H5750"\w* \w mayores|strong="H1419"\w*».   
\p
\v 7 Me llevó \w a|strong="H3068"\w* la entrada del \w atrio|strong="H2691"\w*, y \w miré|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* un \w agujero|strong="H2356"\w* en la \w pared|strong="H7023"\w*.  
\v 8 \w Y|strong="H3068"\w* me dijo: «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, taladra \w ahora|strong="H4994"\w* en la \w pared|strong="H7023"\w*». \w Y|strong="H3068"\w* taladré en la \w pared|strong="H7023"\w*, y he \w aquí|strong="H2009"\w* una \w puerta|strong="H6607"\w*.   
\p
\v 9 Me dijo luego: «Entra, y \w ve|strong="H7200"\w* \w las|strong="H1992"\w* malvadas \w abominaciones|strong="H8441"\w* \w que|strong="H1992"\w* \w estos|strong="H1992"\w* \w hacen|strong="H6213"\w* \w aquí|strong="H6311"\w*».   
\p
\v 10 \w Entré|strong="H5921"\w*, \w pues|strong="H7200"\w*, \w y|strong="H5921"\w* \w miré|strong="H7200"\w*; \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w toda|strong="H3605"\w* forma \w de|strong="H5921"\w* \w reptiles|strong="H7431"\w* \w y|strong="H5921"\w* bestias abominables, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w ídolos|strong="H1544"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H5921"\w* estaban \w pintados|strong="H2707"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w pared|strong="H7023"\w* \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w alrededor|strong="H5439"\w*.  
\v 11 \w Y|strong="H3068"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H3027"\w* \w estaban|strong="H5975"\w* \w setenta|strong="H7657"\w* varones \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H6440"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, y Jaazanías \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Safán \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H6440"\w* \w ellos|strong="H3027"\w*, cada uno con su incensario \w en|strong="H8432"\w* su \w mano|strong="H3027"\w*; y \w subía|strong="H5927"\w* una \w nube|strong="H6051"\w* espesa \w de|strong="H6440"\w* incienso.  
\v 12 \w Y|strong="H3068"\w* \w me|strong="H3588"\w* dijo: “\w Hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w hombre|strong="H1121"\w*, ¿has \w visto|strong="H7200"\w* las cosas \w que|strong="H3588"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w hacen|strong="H6213"\w* \w en|strong="H3588"\w* \w tinieblas|strong="H2822"\w*, cada uno \w en|strong="H3588"\w* sus cámaras pintadas \w de|strong="H3588"\w* imágenes? \w Porque|strong="H3588"\w* dicen ellos: ‘\w No|strong="H6213"\w* nos \w ve|strong="H7200"\w* Yahvé; Yahvé ha abandonado \w la|strong="H3588"\w* tierra’”.  
\v 13 Me dijo después: «\w Vuélvete|strong="H7725"\w*, y \w verás|strong="H7200"\w* \w abominaciones|strong="H8441"\w* \w aún|strong="H5750"\w* \w mayores|strong="H1419"\w* \w que|strong="H1992"\w* \w hacen|strong="H6213"\w* \w estos|strong="H1992"\w*».   
\p
\v 14 \w Y|strong="H3068"\w* me llevó \w a|strong="H3068"\w* la entrada de la \w puerta|strong="H6607"\w* de la \w casa|strong="H1004"\w* de Yahvé, que \w está|strong="H3427"\w* al \w norte|strong="H6828"\w*; y he \w aquí|strong="H2009"\w* mujeres que \w estaban|strong="H3427"\w* \w allí|strong="H8033"\w* \w sentadas|strong="H3427"\w* \w endechando|strong="H1058"\w* \w a|strong="H3068"\w* Tamuz.  
\v 15 \w Luego|strong="H7725"\w* me dijo: «¿No \w ves|strong="H7200"\w* esto, \w hijo|strong="H1121"\w* \w de|strong="H5750"\w* \w hombre|strong="H1121"\w*? \w Vuélvete|strong="H7725"\w* \w aún|strong="H5750"\w*, \w verás|strong="H7200"\w* \w abominaciones|strong="H8441"\w* \w mayores|strong="H1419"\w* \w que|strong="H1121"\w* estas».   
\p
\v 16 \w Y|strong="H3068"\w* me llevó al \w atrio|strong="H2691"\w* \w interior|strong="H6442"\w* \w de|strong="H6440"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* Yahvé; y he \w aquí|strong="H2009"\w* \w que|strong="H2691"\w* \w a|strong="H3068"\w* la entrada \w del|strong="H4196"\w* \w templo|strong="H1964"\w* \w de|strong="H6440"\w* Yahvé, entre la entrada y \w el|strong="H1992"\w* \w altar|strong="H4196"\w*, había como \w veinticinco|strong="H6242"\w* varones, \w sus|strong="H1992"\w* espaldas vueltas al \w templo|strong="H1964"\w* \w de|strong="H6440"\w* Yahvé y \w sus|strong="H1992"\w* \w rostros|strong="H6440"\w* \w hacia|strong="H6440"\w* \w el|strong="H1992"\w* \w oriente|strong="H6924"\w*, y adoraban al \w sol|strong="H8121"\w*, postrándose \w hacia|strong="H6440"\w* \w el|strong="H1992"\w* \w oriente|strong="H6924"\w*.  
\v 17 \w Y|strong="H3068"\w* \w me|strong="H3588"\w* dijo: «¿\w No|strong="H6213"\w* has \w visto|strong="H7200"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w hombre|strong="H1121"\w*? ¿\w Es|strong="H3588"\w* cosa ligera \w para|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w hacer|strong="H6213"\w* las \w abominaciones|strong="H8441"\w* \w que|strong="H3588"\w* \w hacen|strong="H6213"\w* \w aquí|strong="H6311"\w*? Después \w que|strong="H3588"\w* han llenado \w de|strong="H3588"\w* maldad \w la|strong="H3588"\w* tierra, se \w volvieron|strong="H7725"\w* \w a|strong="H3068"\w* mí \w para|strong="H3588"\w* irritarme; he \w aquí|strong="H6311"\w* \w que|strong="H3588"\w* aplican \w el|strong="H3588"\w* ramo \w a|strong="H3068"\w* sus narices.  
\v 18 \w Pues|strong="H1571"\w* \w también|strong="H1571"\w* \w yo|strong="H6213"\w* procederé \w con|strong="H1571"\w* \w furor|strong="H2534"\w*; \w no|strong="H3808"\w* \w perdonará|strong="H2550"\w* mi \w ojo|strong="H5869"\w*, \w ni|strong="H3808"\w* tendré \w misericordia|strong="H2550"\w*; \w y|strong="H1571"\w* \w aunque|strong="H1571"\w* clamen \w a|strong="H3068"\w* mis \w oídos|strong="H8085"\w* \w con|strong="H1571"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*, \w no|strong="H3808"\w* los \w oiré|strong="H8085"\w*».   
\c 9
\p
\v 1 Entonces \w clamó|strong="H7121"\w* \w a|strong="H3068"\w* mis oídos con \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*, diciendo: «¡Haced \w que|strong="H3027"\w* se acerquen los verdugos de la \w ciudad|strong="H5892"\w*, cada uno con su arma de destrucción en la \w mano|strong="H3027"\w*!».  
\v 2 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3027"\w* \w seis|strong="H8337"\w* hombres venían \w del|strong="H4196"\w* \w camino|strong="H1870"\w* \w de|strong="H3847"\w* la \w puerta|strong="H8179"\w* superior \w que|strong="H3027"\w* \w mira|strong="H2009"\w* \w hacia|strong="H1870"\w* el \w norte|strong="H6828"\w*, cada uno con su arma \w de|strong="H3847"\w* destrucción \w en|strong="H8432"\w* la \w mano|strong="H3027"\w*. \w En|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3847"\w* \w ellos|strong="H3027"\w* \w había|strong="H5975"\w* un varón \w vestido|strong="H3847"\w* \w de|strong="H3847"\w* lino, el cual traía \w a|strong="H3068"\w* su cintura un tintero \w de|strong="H3847"\w* escribano. Entraron y se detuvieron \w junto|strong="H3027"\w* al \w altar|strong="H4196"\w* \w de|strong="H3847"\w* bronce.   
\p
\v 3 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w del|strong="H5921"\w* Dios \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* elevó \w de|strong="H5921"\w* \w encima|strong="H5921"\w* \w del|strong="H5921"\w* \w querubín|strong="H3742"\w*, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* cual \w había|strong="H1961"\w* \w estado|strong="H1961"\w*, \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w umbral|strong="H4670"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*; \w y|strong="H5921"\w* \w llamó|strong="H7121"\w* Jehová \w al|strong="H5921"\w* varón \w vestido|strong="H3847"\w* \w de|strong="H5921"\w* lino, \w que|strong="H5921"\w* \w tenía|strong="H1961"\w* \w a|strong="H3068"\w* su cintura \w el|strong="H5921"\w* tintero \w de|strong="H5921"\w* escribano,  
\v 4 \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijo Yahvé: «\w Pasa|strong="H5674"\w* \w por|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w por|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* Jerusalén, \w y|strong="H5921"\w* pon una señal \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w frente|strong="H4696"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* hombres \w que|strong="H5921"\w* gimen \w y|strong="H5921"\w* \w que|strong="H5921"\w* claman \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w abominaciones|strong="H8441"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w hacen|strong="H6213"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*».   
\p
\v 5 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* otros dijo, oyéndolo yo: «\w Pasad|strong="H5674"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w en|strong="H5921"\w* pos \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w herid|strong="H5221"\w*; \w no|strong="H5921"\w* \w perdone|strong="H2347"\w* vuestro \w ojo|strong="H5869"\w*, ni tengáis \w misericordia|strong="H2550"\w*.  
\v 6 \w Matad|strong="H2026"\w* \w a|strong="H3068"\w* \w viejos|strong="H2205"\w*, jóvenes \w y|strong="H5921"\w* \w vírgenes|strong="H1330"\w*, \w niños|strong="H2945"\w* \w y|strong="H5921"\w* mujeres, \w hasta|strong="H5921"\w* \w que|strong="H5921"\w* \w no|strong="H5921"\w* quede \w ninguno|strong="H3605"\w*; pero \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* cual hubiere señal, \w no|strong="H5921"\w* \w os|strong="H5921"\w* acercaréis; \w y|strong="H5921"\w* comenzaréis \w por|strong="H5921"\w* \w mi|strong="H5921"\w* \w santuario|strong="H4720"\w*». \w Comenzaron|strong="H2490"\w*, pues, \w desde|strong="H6440"\w* \w los|strong="H5921"\w* varones \w ancianos|strong="H2205"\w* \w que|strong="H5921"\w* estaban \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w templo|strong="H1004"\w*.   
\p
\v 7 \w Y|strong="H3068"\w* les dijo: «Profanad la \w casa|strong="H1004"\w*, y llenad los \w atrios|strong="H2691"\w* de \w muertos|strong="H2491"\w*; \w salid|strong="H3318"\w*». \w Y|strong="H3068"\w* \w salieron|strong="H3318"\w*, \w e|strong="H3068"\w* \w hirieron|strong="H5221"\w* \w en|strong="H3318"\w* la \w ciudad|strong="H5892"\w*.   
\p
\v 8 \w Aconteció|strong="H1961"\w* \w que|strong="H5921"\w* \w cuando|strong="H1961"\w* \w ellos|strong="H5921"\w* iban matando \w y|strong="H5921"\w* \w quedé|strong="H7604"\w* yo solo, \w me|strong="H5921"\w* postré \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w*, \w y|strong="H5921"\w* \w clamé|strong="H2199"\w* \w y|strong="H5921"\w* dije: «¡Ah, Señor Yahvé! ¿\w Destruirás|strong="H7843"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* remanente \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w derramando|strong="H8210"\w* tu \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* Jerusalén?».   
\p
\v 9 \w Y|strong="H3068"\w* \w me|strong="H3588"\w* dijo: “\w La|strong="H3588"\w* \w maldad|strong="H5771"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w es|strong="H3588"\w* \w sobremanera|strong="H3966"\w* \w grande|strong="H1419"\w*; \w pues|strong="H3588"\w* \w la|strong="H3588"\w* tierra está \w llena|strong="H4390"\w* \w de|strong="H3588"\w* \w sangre|strong="H1818"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w llena|strong="H4390"\w* \w de|strong="H3588"\w* perversidad; \w porque|strong="H3588"\w* han dicho: ‘Ha abandonado Yahvé \w la|strong="H3588"\w* tierra, \w y|strong="H3588"\w* Yahvé \w no|strong="H3588"\w* \w ve|strong="H7200"\w*’.  
\v 10 \w Así|strong="H1571"\w* \w pues|strong="H1571"\w*, \w haré|strong="H5414"\w* yo; mi \w ojo|strong="H5869"\w* \w no|strong="H3808"\w* \w perdonará|strong="H2550"\w*, \w ni|strong="H3808"\w* tendré \w misericordia|strong="H2550"\w*; \w haré|strong="H5414"\w* recaer \w el|strong="H1571"\w* \w camino|strong="H1870"\w* \w de|strong="H5414"\w* \w ellos|strong="H1571"\w* sobre sus propias \w cabezas|strong="H7218"\w*”.   
\p
\v 11 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H1697"\w* \w el|strong="H6213"\w* varón \w vestido|strong="H3830"\w* \w de|strong="H1697"\w* lino, \w que|strong="H1697"\w* tenía \w el|strong="H6213"\w* tintero \w a|strong="H3068"\w* su cintura, \w respondió|strong="H7725"\w* una \w palabra|strong="H1697"\w*, diciendo: «He \w hecho|strong="H6213"\w* conforme \w a|strong="H3068"\w* todo \w lo|strong="H1697"\w* \w que|strong="H1697"\w* me \w mandaste|strong="H6680"\w*».   
\c 10
\p
\v 1 \w Miré|strong="H7200"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* bóveda \w que|strong="H5921"\w* \w estaba|strong="H2009"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w*, aparecía \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* algo \w como|strong="H5921"\w* una piedra \w de|strong="H5921"\w* zafiro, \w que|strong="H5921"\w* tenía \w el|strong="H5921"\w* \w aspecto|strong="H4758"\w* \w de|strong="H5921"\w* un \w trono|strong="H3678"\w*.  
\v 2 \w Y|strong="H3068"\w* habló \w al|strong="H5921"\w* varón \w vestido|strong="H3847"\w* \w de|strong="H5921"\w* lino, \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijo: «Entra \w en|strong="H5921"\w* medio \w de|strong="H5921"\w* \w las|strong="H5921"\w* ruedas, \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w*, \w y|strong="H5921"\w* \w llena|strong="H4390"\w* tus manos \w de|strong="H5921"\w* \w brasas|strong="H1513"\w* \w de|strong="H5921"\w* fuego \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w*, \w y|strong="H5921"\w* espárcelas \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*». \w Y|strong="H3068"\w* entró ante mis propios \w ojos|strong="H5869"\w*.  
\v 3 \w Y|strong="H3068"\w* los \w querubines|strong="H3742"\w* \w estaban|strong="H5975"\w* \w a|strong="H3068"\w* la mano \w derecha|strong="H3225"\w* de la \w casa|strong="H1004"\w* cuando \w este|strong="H5975"\w* varón entró; y la \w nube|strong="H6051"\w* llenaba el \w atrio|strong="H2691"\w* \w interior|strong="H6442"\w*.  
\v 4 Entonces \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* elevó \w de|strong="H5921"\w* \w encima|strong="H5921"\w* \w del|strong="H5921"\w* \w querubín|strong="H3742"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w umbral|strong="H4670"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*; \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w se|strong="H5921"\w* \w llenó|strong="H4390"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w nube|strong="H6051"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w atrio|strong="H2691"\w* \w se|strong="H5921"\w* \w llenó|strong="H4390"\w* \w del|strong="H5921"\w* \w resplandor|strong="H5051"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* Yahvé.  
\v 5 \w Y|strong="H3068"\w* el \w estruendo|strong="H6963"\w* \w de|strong="H5704"\w* las \w alas|strong="H3671"\w* \w de|strong="H5704"\w* los \w querubines|strong="H3742"\w* se \w oía|strong="H8085"\w* \w hasta|strong="H5704"\w* el \w atrio|strong="H2691"\w* \w exterior|strong="H2435"\w*, \w como|strong="H5704"\w* la \w voz|strong="H6963"\w* del Dios \w Omnipotente|strong="H7706"\w* \w cuando|strong="H5704"\w* \w habla|strong="H1696"\w*.   
\p
\v 6 \w Aconteció|strong="H1961"\w*, \w pues|strong="H1961"\w*, \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w ordenó|strong="H5975"\w* al varón \w vestido|strong="H3847"\w* \w de|strong="H3847"\w* lino, diciendo: «\w Toma|strong="H3947"\w* fuego \w de|strong="H3847"\w* entre las ruedas, \w de|strong="H3847"\w* entre \w los|strong="H1961"\w* \w querubines|strong="H3742"\w*», él entró y \w se|strong="H1961"\w* detuvo junto \w a|strong="H3068"\w* una \w rueda|strong="H1534"\w*.  
\v 7 \w Y|strong="H3068"\w* un \w querubín|strong="H3742"\w* \w extendió|strong="H7971"\w* su \w mano|strong="H3027"\w* \w de|strong="H3847"\w* \w en|strong="H3318"\w* \w medio|strong="H3027"\w* \w de|strong="H3847"\w* los \w querubines|strong="H3742"\w* hacia el fuego \w que|strong="H3027"\w* estaba entre \w ellos|strong="H3027"\w*, y \w tomó|strong="H3947"\w* \w de|strong="H3847"\w* él y lo \w puso|strong="H5414"\w* \w en|strong="H3318"\w* las \w manos|strong="H3027"\w* del \w que|strong="H3027"\w* estaba \w vestido|strong="H3847"\w* \w de|strong="H3847"\w* lino, el cual lo \w tomó|strong="H3947"\w* y \w salió|strong="H3318"\w*.  
\v 8 \w Y|strong="H3068"\w* \w apareció|strong="H7200"\w* \w en|strong="H8478"\w* los \w querubines|strong="H3742"\w* la forma \w de|strong="H8478"\w* una \w mano|strong="H3027"\w* \w de|strong="H8478"\w* hombre \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* sus \w alas|strong="H3671"\w*.   
\p
\v 9 \w Y|strong="H3068"\w* \w miré|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* cuatro ruedas junto \w a|strong="H3068"\w* los \w querubines|strong="H3742"\w*, una rueda junto \w a|strong="H3068"\w* cada \w querubín|strong="H3742"\w*; y el \w aspecto|strong="H4758"\w* \w de|strong="H5869"\w* las ruedas era como el \w de|strong="H5869"\w* piedra \w de|strong="H5869"\w* berilo.  
\v 10 \w En|strong="H8432"\w* cuanto \w a|strong="H3068"\w* su \w aspecto|strong="H4758"\w*, las cuatro \w tenían|strong="H1961"\w* una misma \w semejanza|strong="H1823"\w*, \w como|strong="H1961"\w* \w si|strong="H1961"\w* una rueda estuviera \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de otra.  
\v 11 \w Cuando|strong="H3588"\w* \w andaban|strong="H3212"\w*, \w se|strong="H3808"\w* movían hacia sus cuatro \w costados|strong="H7253"\w*; \w no|strong="H3808"\w* \w se|strong="H3808"\w* volvían al \w andar|strong="H3212"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* al \w lugar|strong="H4725"\w* adonde \w se|strong="H3808"\w* volvía \w la|strong="H3588"\w* primera, \w en|strong="H3588"\w* pos \w de|strong="H3588"\w* ella \w iban|strong="H3212"\w*; \w no|strong="H3808"\w* \w se|strong="H3808"\w* volvían al \w andar|strong="H3212"\w*.  
\v 12 \w Todo|strong="H3605"\w* su cuerpo, sus espaldas, sus \w manos|strong="H3027"\w*, sus \w alas|strong="H3671"\w* y las ruedas estaban \w llenos|strong="H4392"\w* \w de|strong="H5869"\w* \w ojos|strong="H5869"\w* \w por|strong="H3027"\w* \w todas|strong="H3605"\w* \w partes|strong="H3027"\w*; así eran las ruedas \w de|strong="H5869"\w* \w los|strong="H3605"\w* cuatro.  
\v 13 En cuanto \w a|strong="H3068"\w* las ruedas, oí que las \w llamaban|strong="H7121"\w* “ruedas giratorias”.  
\v 14 Cada uno tenía cuatro caras. La primera \w cara|strong="H6440"\w* era \w de|strong="H6440"\w* \w querubín|strong="H3742"\w*; la \w segunda|strong="H8145"\w*, \w cara|strong="H6440"\w* \w de|strong="H6440"\w* hombre; la \w tercera|strong="H7992"\w*, \w cara|strong="H6440"\w* \w de|strong="H6440"\w* león; y la cuarta, \w cara|strong="H6440"\w* \w de|strong="H6440"\w* águila.   
\p
\v 15 Entonces \w los|strong="H1931"\w* \w querubines|strong="H3742"\w* \w se|strong="H1931"\w* elevaron. Eran \w los|strong="H1931"\w* mismos seres \w vivientes|strong="H2416"\w* \w que|strong="H1931"\w* \w vi|strong="H7200"\w* junto al \w río|strong="H5104"\w* Quebar.  
\v 16 \w Cuando|strong="H1571"\w* \w los|strong="H1992"\w* \w querubines|strong="H3742"\w* avanzaban, \w las|strong="H1992"\w* ruedas avanzaban \w a|strong="H3068"\w* \w su|strong="H1992"\w* lado; \w y|strong="H1571"\w* \w cuando|strong="H1571"\w* \w los|strong="H1992"\w* \w querubines|strong="H3742"\w* \w alzaban|strong="H5375"\w* \w sus|strong="H1992"\w* \w alas|strong="H3671"\w* \w para|strong="H5921"\w* elevarse \w del|strong="H5921"\w* suelo, \w las|strong="H1992"\w* ruedas \w no|strong="H3808"\w* \w se|strong="H5921"\w* apartaban \w de|strong="H5921"\w* \w su|strong="H1992"\w* lado.  
\v 17 \w Si|strong="H3588"\w* ellos se detenían, ellas se detenían; \w si|strong="H3588"\w* ellos se elevaban, ellas se elevaban \w con|strong="H3588"\w* ellos, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w espíritu|strong="H7307"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* seres \w vivientes|strong="H2416"\w* \w estaba|strong="H5975"\w* \w en|strong="H3588"\w* ellas.   
\p
\v 18 \w La|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* Yahvé \w salió|strong="H3318"\w* \w del|strong="H5921"\w* \w umbral|strong="H4670"\w* \w del|strong="H5921"\w* \w templo|strong="H1004"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* colocó \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w*.  
\v 19 Mientras \w yo|strong="H4480"\w* \w miraba|strong="H5869"\w*, \w los|strong="H5921"\w* \w querubines|strong="H3742"\w* desplegaron sus \w alas|strong="H3671"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* elevaron \w del|strong="H4480"\w* suelo \w para|strong="H5921"\w* \w salir|strong="H3318"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* ruedas \w se|strong="H5921"\w* \w fueron|strong="H5869"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w Se|strong="H5921"\w* detuvieron \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* oriental \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H4480"\w* Yahvé, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w del|strong="H4480"\w* \w Dios|strong="H3068"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w estaba|strong="H5975"\w* \w por|strong="H5921"\w* \w encima|strong="H4605"\w* \w de|strong="H4480"\w* \w ellos|strong="H5921"\w*.   
\p
\v 20 \w Estos|strong="H1992"\w* eran \w los|strong="H1992"\w* seres \w vivientes|strong="H2416"\w* \w que|strong="H3588"\w* \w vi|strong="H7200"\w* \w debajo|strong="H8478"\w* del Dios \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* junto \w al|strong="H8478"\w* \w río|strong="H5104"\w* Quebar; \w y|strong="H3588"\w* \w supe|strong="H3045"\w* \w que|strong="H3588"\w* eran \w querubines|strong="H3742"\w*.  
\v 21 Cada uno tenía cuatro caras y cuatro \w alas|strong="H3671"\w*, y \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* sus \w alas|strong="H3671"\w* había algo semejante \w a|strong="H3068"\w* \w manos|strong="H3027"\w* humanas.  
\v 22 \w En|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w forma|strong="H1823"\w* \w de|strong="H5921"\w* \w sus|strong="H1992"\w* caras, eran \w las|strong="H1992"\w* mismas \w que|strong="H5921"\w* \w vi|strong="H7200"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w río|strong="H5104"\w* Quebar; tenían \w la|strong="H5921"\w* misma \w apariencia|strong="H4758"\w* \w y|strong="H5921"\w* eran \w los|strong="H1992"\w* \w mismos|strong="H1992"\w* seres. Cada uno avanzaba \w de|strong="H5921"\w* frente.   
\c 11
\p
\v 1 Además, \w el|strong="H1121"\w* \w Espíritu|strong="H7307"\w* me elevó y me \w llevó|strong="H5375"\w* \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* \w oriental|strong="H6921"\w* \w de|strong="H2568"\w* la \w casa|strong="H1004"\w* \w de|strong="H2568"\w* Yahvé, la \w que|strong="H5971"\w* \w mira|strong="H7200"\w* hacia \w el|strong="H1121"\w* este. \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5971"\w* \w a|strong="H3068"\w* la entrada \w de|strong="H2568"\w* la \w puerta|strong="H6607"\w* había \w veinticinco|strong="H6242"\w* \w hombres|strong="H1121"\w*, y \w vi|strong="H7200"\w* \w entre|strong="H8432"\w* ellos \w a|strong="H3068"\w* Jaazanías \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* \w Azur|strong="H5809"\w* y \w a|strong="H3068"\w* \w Pelatías|strong="H6410"\w* \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* \w Benaía|strong="H1141"\w*, \w príncipes|strong="H8269"\w* del \w pueblo|strong="H5971"\w*.  
\v 2 \w Y|strong="H3068"\w* me dijo: “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w estos|strong="H2063"\w* son \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w que|strong="H1121"\w* \w maquinan|strong="H2803"\w* perversidad y dan \w mal|strong="H7451"\w* \w consejo|strong="H6098"\w* en \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*.  
\v 3 \w Son|strong="H3808"\w* \w los|strong="H1931"\w* \w que|strong="H1931"\w* dicen: ‘\w No|strong="H3808"\w* \w será|strong="H1931"\w* \w tan|strong="H1931"\w* pronto; \w edifiquemos|strong="H1129"\w* \w casas|strong="H1004"\w*. \w Esta|strong="H1931"\w* ciudad \w es|strong="H1931"\w* \w la|strong="H1931"\w* caldera, y \w nosotros|strong="H1931"\w* somos \w la|strong="H1931"\w* \w carne|strong="H1320"\w*’.  
\v 4 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w profetiza|strong="H5012"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*; \w profetiza|strong="H5012"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*”.   
\p
\v 5 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Yahvé \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* \w me|strong="H5921"\w* dijo: “Di: \w Así|strong="H3541"\w* \w ha|strong="H3541"\w* dicho Yahvé: ‘\w Así|strong="H3541"\w* habéis hablado, oh \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* yo \w conozco|strong="H3045"\w* \w las|strong="H5921"\w* \w cosas|strong="H3045"\w* \w que|strong="H5921"\w* suben \w a|strong="H3068"\w* vuestro \w espíritu|strong="H7307"\w*.  
\v 6 Habéis multiplicado vuestros \w muertos|strong="H2491"\w* en \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, y habéis llenado de \w muertos|strong="H2491"\w* sus \w calles|strong="H2351"\w*’”.   
\p
\v 7 “\w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H1931"\w* Señor Yahvé: ‘Vuestros \w muertos|strong="H2491"\w* \w que|strong="H1931"\w* habéis puesto \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w ella|strong="H1931"\w*, \w ellos|strong="H1992"\w* son \w la|strong="H1931"\w* \w carne|strong="H1320"\w*, \w y|strong="H3541"\w* \w ella|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* caldera; mas \w a|strong="H3068"\w* vosotros os sacaré de \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w ella|strong="H1931"\w*.  
\v 8 Habéis \w temido|strong="H3372"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*, \w y|strong="H5921"\w* \w espada|strong="H2719"\w* traeré \w sobre|strong="H5921"\w* vosotros’, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor Yahvé.  
\v 9 ‘Os sacaré \w de|strong="H5414"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5414"\w* ella, os \w entregaré|strong="H5414"\w* \w en|strong="H8432"\w* \w manos|strong="H3027"\w* \w de|strong="H5414"\w* extraños y \w ejecutaré|strong="H6213"\w* \w juicios|strong="H8201"\w* contra vosotros.  
\v 10 \w A|strong="H3068"\w* \w espada|strong="H2719"\w* \w caeréis|strong="H5307"\w*; \w en|strong="H5921"\w* \w los|strong="H5921"\w* límites \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w os|strong="H5921"\w* \w juzgaré|strong="H8199"\w*, \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé.  
\v 11 \w Esta|strong="H1931"\w* ciudad \w no|strong="H3808"\w* \w será|strong="H1961"\w* \w vuestra|strong="H1961"\w* caldera, \w ni|strong="H3808"\w* vosotros \w seréis|strong="H1961"\w* \w la|strong="H1931"\w* \w carne|strong="H1320"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w ella|strong="H1931"\w*; \w en|strong="H8432"\w* \w los|strong="H1931"\w* límites de \w Israel|strong="H3478"\w* os \w juzgaré|strong="H8199"\w*.  
\v 12 \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* habéis \w andado|strong="H1980"\w* \w en|strong="H3588"\w* mis \w estatutos|strong="H2706"\w* \w ni|strong="H3808"\w* habéis obedecido mis decretos, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* habéis actuado según las costumbres \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w* \w que|strong="H3588"\w* os \w rodean|strong="H5439"\w*’”.   
\p
\v 13 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H5921"\w*, mientras \w yo|strong="H6213"\w* profetizaba, \w murió|strong="H4191"\w* \w Pelatías|strong="H6410"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Benaía|strong="H1141"\w*. Entonces \w caí|strong="H5307"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w* \w y|strong="H5921"\w* \w clamé|strong="H2199"\w* \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*, diciendo: «¡Ah, Señor Yahvé! ¿Destruirás \w del|strong="H5921"\w* todo \w al|strong="H5921"\w* remanente \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?».   
\p
\v 14 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 15 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, tus hermanos, tus parientes, \w los|strong="H3427"\w* \w hombres|strong="H1121"\w* \w de|strong="H5921"\w* tu parentela \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w toda|strong="H3605"\w* \w ella|strong="H1931"\w*, son \w aquellos|strong="H3605"\w* \w a|strong="H3068"\w* quienes \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén han dicho: ‘\w Alejaos|strong="H7368"\w* \w de|strong="H5921"\w* Yahvé; \w a|strong="H3068"\w* \w nosotros|strong="H3605"\w* \w nos|strong="H5921"\w* ha sido \w dada|strong="H5414"\w* \w la|strong="H1931"\w* tierra \w en|strong="H5921"\w* \w posesión|strong="H4181"\w*’.   
\p
\v 16 “\w Por|strong="H3588"\w* \w tanto|strong="H3651"\w*, di: \w Así|strong="H3541"\w* dice \w el|strong="H3588"\w* Señor Yahvé: ‘\w Aunque|strong="H3588"\w* \w los|strong="H1961"\w* he arrojado \w lejos|strong="H7368"\w* \w entre|strong="H3588"\w* las \w naciones|strong="H1471"\w*, \w y|strong="H3588"\w* \w aunque|strong="H3588"\w* \w los|strong="H1961"\w* he dispersado \w por|strong="H3588"\w* las tierras, \w con|strong="H3588"\w* todo, \w yo|strong="H3588"\w* \w seré|strong="H1961"\w* \w para|strong="H3588"\w* ellos un pequeño \w santuario|strong="H4720"\w* \w en|strong="H3588"\w* las tierras adonde lleguen’.   
\p
\v 17 “\w Di|strong="H5414"\w*, \w pues|strong="H3651"\w*: \w Así|strong="H3541"\w* dice el Señor Yahvé: ‘\w Yo|strong="H4480"\w* \w os|strong="H4480"\w* \w recogeré|strong="H6908"\w* \w de|strong="H4480"\w* los \w pueblos|strong="H5971"\w*, \w y|strong="H3541"\w* \w os|strong="H4480"\w* congregaré \w de|strong="H4480"\w* las tierras \w en|strong="H4480"\w* las cuales estáis esparcidos, \w y|strong="H3541"\w* \w os|strong="H4480"\w* \w daré|strong="H5414"\w* la tierra \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*’.   
\p
\v 18 «\w Y|strong="H3068"\w* volverán \w allá|strong="H8033"\w*, y quitarán \w de|strong="H4480"\w* \w ella|strong="H8033"\w* \w todas|strong="H3605"\w* sus cosas detestables y \w todas|strong="H3605"\w* sus \w abominaciones|strong="H8441"\w*.  
\v 19 \w Y|strong="H3068"\w* les \w daré|strong="H5414"\w* un \w corazón|strong="H3820"\w*, y un \w espíritu|strong="H7307"\w* \w nuevo|strong="H2319"\w* \w pondré|strong="H5414"\w* \w dentro|strong="H7130"\w* \w de|strong="H5414"\w* ellos; y \w quitaré|strong="H5493"\w* el \w corazón|strong="H3820"\w* \w de|strong="H5414"\w* piedra \w de|strong="H5414"\w* su \w carne|strong="H1320"\w*, y les \w daré|strong="H5414"\w* un \w corazón|strong="H3820"\w* \w de|strong="H5414"\w* \w carne|strong="H1320"\w*,  
\v 20 \w para|strong="H4616"\w* \w que|strong="H5971"\w* \w anden|strong="H3212"\w* \w en|strong="H3212"\w* mis \w ordenanzas|strong="H4941"\w*, y \w guarden|strong="H8104"\w* mis decretos y \w los|strong="H1961"\w* cumplan, y me \w sean|strong="H1961"\w* \w por|strong="H4616"\w* \w pueblo|strong="H5971"\w*, y \w yo|strong="H6213"\w* \w sea|strong="H1961"\w* \w a|strong="H3068"\w* \w ellos|strong="H2708"\w* \w por|strong="H4616"\w* Dios.  
\v 21 Mas en cuanto \w a|strong="H3068"\w* aquellos cuyo \w corazón|strong="H3820"\w* \w anda|strong="H1980"\w* tras el deseo \w de|strong="H5414"\w* sus cosas detestables y \w de|strong="H5414"\w* sus \w abominaciones|strong="H8441"\w*, yo \w haré|strong="H5414"\w* recaer su \w camino|strong="H1870"\w* sobre sus propias \w cabezas|strong="H7218"\w*», \w dice|strong="H5002"\w* el Señor Yahvé.   
\p
\v 22 \w Después|strong="H5921"\w* \w los|strong="H5921"\w* \w querubines|strong="H3742"\w* \w alzaron|strong="H5375"\w* sus \w alas|strong="H3671"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* ruedas \w tras|strong="H5980"\w* \w ellos|strong="H5921"\w*; \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w del|strong="H5921"\w* Dios \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* estaba \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 23 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* Yahvé \w subió|strong="H5927"\w* \w de|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w puso|strong="H5975"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w que|strong="H5921"\w* \w está|strong="H5975"\w* \w al|strong="H5921"\w* \w oriente|strong="H6924"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.  
\v 24 \w Luego|strong="H5927"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w me|strong="H5921"\w* elevó \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w llevó|strong="H5375"\w* \w en|strong="H5921"\w* \w visión|strong="H4758"\w* \w del|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Dios \w a|strong="H3068"\w* Caldea, \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w cautivos|strong="H1473"\w*. \w Y|strong="H3068"\w* \w se|strong="H5921"\w* fue \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w la|strong="H5921"\w* \w visión|strong="H4758"\w* \w que|strong="H5921"\w* había \w visto|strong="H7200"\w*.  
\v 25 \w Y|strong="H3068"\w* \w hablé|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w cautivos|strong="H1473"\w* \w de|strong="H1697"\w* \w todas|strong="H3605"\w* las \w cosas|strong="H1697"\w* \w que|strong="H1697"\w* Yahvé me había mostrado.   
\c 12
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w hombre|strong="H1121"\w*, tú \w habitas|strong="H3427"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* una \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w*; \w tienen|strong="H1992"\w* \w ojos|strong="H5869"\w* \w para|strong="H3588"\w* \w ver|strong="H7200"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w ven|strong="H7200"\w*, \w tienen|strong="H1992"\w* \w oídos|strong="H8085"\w* \w para|strong="H3588"\w* \w oír|strong="H8085"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w oyen|strong="H8085"\w*, \w porque|strong="H3588"\w* \w son|strong="H3588"\w* una \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w*.   
\p
\v 3 «\w Por|strong="H3588"\w* tanto, \w tú|strong="H6213"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w hombre|strong="H1121"\w*, prepárate \w enseres|strong="H3627"\w* \w de|strong="H3588"\w* destierro \w y|strong="H3588"\w* ponte \w en|strong="H3588"\w* marcha \w de|strong="H3588"\w* \w día|strong="H3119"\w*, ante \w sus|strong="H1992"\w* propios \w ojos|strong="H5869"\w*. \w Te|strong="H5869"\w* trasladarás \w de|strong="H3588"\w* \w tu|strong="H6213"\w* \w lugar|strong="H4725"\w* \w a|strong="H3068"\w* otro \w lugar|strong="H4725"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* vista \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*; tal vez recapaciten, \w aunque|strong="H3588"\w* \w son|strong="H3588"\w* una \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w*.  
\v 4 \w Sacarás|strong="H3318"\w* tus \w enseres|strong="H3627"\w* \w de|strong="H5869"\w* \w día|strong="H3119"\w*, \w a|strong="H3068"\w* la vista \w de|strong="H5869"\w* ellos, como equipaje \w de|strong="H5869"\w* exilio; y tú \w saldrás|strong="H3318"\w* al atardecer, \w a|strong="H3068"\w* la vista \w de|strong="H5869"\w* ellos, como quien \w sale|strong="H3318"\w* al \w cautiverio|strong="H1473"\w*.  
\v 5 Ante sus propios \w ojos|strong="H5869"\w*, horada la \w pared|strong="H7023"\w* y \w sal|strong="H3318"\w* por ella.  
\v 6 \w Ante|strong="H6440"\w* sus \w ojos|strong="H5869"\w* \w los|strong="H5921"\w* \w llevarás|strong="H5375"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w hombro|strong="H3802"\w*; \w de|strong="H5921"\w* noche \w los|strong="H5921"\w* \w sacarás|strong="H3318"\w*. \w Cubrirás|strong="H3680"\w* tu \w rostro|strong="H6440"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w mirarás|strong="H7200"\w* \w la|strong="H5921"\w* tierra, \w porque|strong="H3588"\w* \w te|strong="H5869"\w* he \w puesto|strong="H5414"\w* \w como|strong="H3588"\w* señal \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*».   
