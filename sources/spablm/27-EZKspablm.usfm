\v 21 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 22 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, ¿\w qué|strong="H4100"\w* refrán \w es|strong="H2088"\w* \w este|strong="H2088"\w* \w que|strong="H4100"\w* tenéis \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H4100"\w* dice: ‘\w Se|strong="H5921"\w* van prolongando \w los|strong="H1121"\w* \w días|strong="H3117"\w*, \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w visión|strong="H2377"\w* fracasa’?  
\v 23 \w Diles|strong="H1697"\w*, \w por|strong="H3588"\w* \w tanto|strong="H3651"\w*: \w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H3588"\w* Señor Yahvé: ‘Haré cesar \w este|strong="H2088"\w* refrán, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H1697"\w* \w repetirán|strong="H4911"\w* \w más|strong="H5750"\w* \w en|strong="H3588"\w* \w Israel|strong="H3478"\w*’. \w Diles|strong="H1697"\w*, \w más|strong="H5750"\w* \w bien|strong="H3588"\w*: ‘\w Se|strong="H3808"\w* acercan \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* cumplimiento \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w visión|strong="H2377"\w*.  
\v 24 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* \w más|strong="H5750"\w* \w visión|strong="H2377"\w* \w vana|strong="H7723"\w* \w ni|strong="H3808"\w* \w adivinación|strong="H4738"\w* lisonjera \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.  
\v 25 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé. \w Hablaré|strong="H1696"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w hable|strong="H1696"\w* \w se|strong="H3808"\w* \w cumplirá|strong="H6213"\w*. \w No|strong="H3808"\w* \w se|strong="H3808"\w* dilatará \w más|strong="H5750"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* vuestros \w días|strong="H3117"\w*, \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w*, \w hablaré|strong="H1696"\w* \w palabra|strong="H1697"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* cumpliré’, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* Yahvé”.   
\p
\v 26 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 27 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, he \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w los|strong="H1121"\w* \w de|strong="H1121"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* dicen: ‘\w La|strong="H1931"\w* \w visión|strong="H2377"\w* \w que|strong="H1931"\w* \w este|strong="H1931"\w* \w ve|strong="H2372"\w* \w es|strong="H1931"\w* para \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*, y \w profetiza|strong="H5012"\w* para \w tiempos|strong="H6256"\w* \w lejanos|strong="H7350"\w*’.   
\p
\v 28 “\w Diles|strong="H1697"\w*, \w por|strong="H1697"\w* \w tanto|strong="H3651"\w*: \w Así|strong="H3541"\w* \w dice|strong="H5002"\w* \w el|strong="H3605"\w* Señor Yahvé: ‘\w No|strong="H3808"\w* \w se|strong="H3808"\w* dilatará \w más|strong="H5750"\w* \w ninguna|strong="H3605"\w* \w de|strong="H5750"\w* mis \w palabras|strong="H1697"\w*; \w la|strong="H3605"\w* \w palabra|strong="H1697"\w* \w que|strong="H3808"\w* \w yo|strong="H6213"\w* \w hable|strong="H1696"\w* \w se|strong="H3808"\w* \w cumplirá|strong="H6213"\w*’, \w dice|strong="H5002"\w* \w el|strong="H3605"\w* Señor Yahvé”.   
\c 13
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w profetiza|strong="H5012"\w* \w contra|strong="H3478"\w* \w los|strong="H1121"\w* \w profetas|strong="H5030"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1697"\w* \w profetizan|strong="H5012"\w*, y di \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H1697"\w* \w profetizan|strong="H5012"\w* \w de|strong="H1121"\w* su propio \w corazón|strong="H3820"\w*: ‘\w Oíd|strong="H8085"\w* \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé.  
\v 3 \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w* \w insensatos|strong="H5036"\w*, \w que|strong="H5921"\w* \w siguen|strong="H1980"\w* su propio \w espíritu|strong="H7307"\w* \w y|strong="H5921"\w* \w no|strong="H5921"\w* han \w visto|strong="H7200"\w* nada!  
\v 4 \w Como|strong="H1961"\w* \w zorras|strong="H7776"\w* en las ruinas han \w sido|strong="H1961"\w* tus \w profetas|strong="H5030"\w*, oh \w Israel|strong="H3478"\w*.  
\v 5 \w No|strong="H3808"\w* habéis \w subido|strong="H5927"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* brechas, \w ni|strong="H3808"\w* habéis edificado un muro \w alrededor|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w para|strong="H5921"\w* \w que|strong="H3808"\w* resista \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* Yahvé.  
\v 6 Han visto \w vanidad|strong="H7723"\w* y \w adivinación|strong="H7081"\w* \w mentirosa|strong="H3577"\w*. Dicen: «\w Ha|strong="H3808"\w* \w dicho|strong="H1697"\w* Yahvé», y Yahvé \w no|strong="H3808"\w* los \w envió|strong="H7971"\w*; y hacen \w esperar|strong="H3176"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* \w confirme|strong="H6965"\w* la \w palabra|strong="H1697"\w*.  
\v 7 ¿\w No|strong="H3808"\w* habéis visto \w visión|strong="H4236"\w* \w vana|strong="H7723"\w*, y \w no|strong="H3808"\w* habéis \w dicho|strong="H5002"\w* \w adivinación|strong="H4738"\w* \w mentirosa|strong="H3577"\w*, pues decís: «\w Dijo|strong="H1696"\w* Yahvé», cuando yo \w no|strong="H3808"\w* he \w hablado|strong="H1696"\w*?’.   
\p
\v 8 “\w Por|strong="H3282"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* \w dice|strong="H5002"\w* el Señor Yahvé: ‘\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* habéis \w hablado|strong="H1696"\w* \w vanidad|strong="H7723"\w* \w y|strong="H3541"\w* habéis visto \w mentira|strong="H3577"\w*, \w por|strong="H3282"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H3541"\w* yo estoy contra vosotros, \w dice|strong="H5002"\w* el Señor Yahvé.  
\v 9 \w Estará|strong="H1961"\w* \w mi|strong="H1961"\w* \w mano|strong="H3027"\w* \w contra|strong="H3478"\w* \w los|strong="H1961"\w* \w profetas|strong="H5030"\w* \w que|strong="H3588"\w* ven \w vanidad|strong="H7723"\w* \w y|strong="H3588"\w* \w adivinan|strong="H7080"\w* \w mentira|strong="H3577"\w*; \w no|strong="H3808"\w* \w estarán|strong="H1961"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w congregación|strong="H5475"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*, \w ni|strong="H3808"\w* \w serán|strong="H1961"\w* inscritos \w en|strong="H3588"\w* \w el|strong="H3588"\w* libro \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* entrarán; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* \w el|strong="H3588"\w* Señor Yahvé.   
\p
\v 10 “‘\w Sí|strong="H1931"\w*, \w por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w engañaron|strong="H2937"\w* \w a|strong="H3068"\w* \w mi|strong="H2009"\w* \w pueblo|strong="H5971"\w*, diciendo: «\w Paz|strong="H7965"\w*», no habiendo \w paz|strong="H7965"\w*; y mientras uno \w edifica|strong="H1129"\w* \w el|strong="H1931"\w* muro, he \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w los|strong="H1931"\w* otros \w lo|strong="H1931"\w* recubren con cal;  
\v 11 decid \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w que|strong="H1961"\w* lo recubren con cal \w que|strong="H1961"\w* \w caerá|strong="H5307"\w*. \w Vendrá|strong="H1961"\w* \w lluvia|strong="H1653"\w* torrencial; y vosotras, grandes piedras de granizo, \w caeréis|strong="H5307"\w*; y \w viento|strong="H7307"\w* \w tempestuoso|strong="H5591"\w* lo romperá.  
\v 12 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w*, cuando \w el|strong="H5307"\w* muro haya \w caído|strong="H5307"\w*, ¿\w no|strong="H3808"\w* os dirán: «¿Dónde está la cal con \w que|strong="H3808"\w* \w lo|strong="H3808"\w* recubristeis?».   
\p
\v 13 “‘\w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice el Señor Yahvé: Lo romperé con \w viento|strong="H7307"\w* \w tempestuoso|strong="H5591"\w* en \w mi|strong="H1961"\w* \w ira|strong="H2534"\w*, \w y|strong="H3541"\w* \w lluvia|strong="H1653"\w* torrencial \w vendrá|strong="H1961"\w* en \w mi|strong="H1961"\w* \w furor|strong="H2534"\w*, \w y|strong="H3541"\w* piedras de granizo en \w mi|strong="H1961"\w* \w enojo|strong="H2534"\w* \w para|strong="H1961"\w* consumir.  
\v 14 \w Así|strong="H3588"\w* derribaré \w el|strong="H3588"\w* muro \w que|strong="H3588"\w* recubristeis \w con|strong="H3588"\w* cal, \w y|strong="H3588"\w* lo echaré \w por|strong="H3588"\w* tierra, \w y|strong="H3588"\w* sus cimientos quedarán al descubierto; \w y|strong="H3588"\w* \w caerá|strong="H5307"\w*, \w y|strong="H3588"\w* seréis consumidos \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*. \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé.  
\v 15 \w Cumpliré|strong="H3615"\w* así mi \w furor|strong="H2534"\w* en el muro y en los que lo recubrieron con cal, y os diré: «No existe el muro, ni los que lo recubrieron,  
\v 16 los \w profetas|strong="H5030"\w* de \w Israel|strong="H3478"\w* que \w profetizan|strong="H5012"\w* acerca de Jerusalén, y ven para ella \w visión|strong="H2377"\w* de \w paz|strong="H7965"\w*, no habiendo \w paz|strong="H7965"\w*, \w dice|strong="H5002"\w* \w el|strong="H5030"\w* Señor Yahvé»’.   
\p
\v 17 “\w Y|strong="H3068"\w* tú, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w pon|strong="H7760"\w* tu \w rostro|strong="H6440"\w* \w contra|strong="H5921"\w* \w las|strong="H5921"\w* \w hijas|strong="H1323"\w* \w de|strong="H5921"\w* tu \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w profetizan|strong="H5012"\w* \w de|strong="H5921"\w* su propio \w corazón|strong="H3820"\w*, \w y|strong="H5921"\w* \w profetiza|strong="H5012"\w* \w contra|strong="H5921"\w* \w ellas|strong="H5921"\w*,  
\v 18 \w y|strong="H5921"\w* di: ‘\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* aquellas \w que|strong="H5921"\w* cosen vendas mágicas \w para|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w*, \w y|strong="H5921"\w* \w hacen|strong="H6213"\w* velos mágicos \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w edad|strong="H6967"\w*, \w para|strong="H5921"\w* cazar \w las|strong="H5921"\w* \w almas|strong="H5315"\w*! ¿Habéis \w de|strong="H5921"\w* cazar \w las|strong="H5921"\w* \w almas|strong="H5315"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w para|strong="H5921"\w* mantener \w así|strong="H3541"\w* vuestra propia \w vida|strong="H5315"\w*?  
\v 19 \w Y|strong="H3068"\w* me habéis \w profanado|strong="H2490"\w* en medio \w de|strong="H5971"\w* \w mi|strong="H2490"\w* \w pueblo|strong="H5971"\w* por unos puñados \w de|strong="H5971"\w* \w cebada|strong="H8184"\w* y por unos pedazos \w de|strong="H5971"\w* \w pan|strong="H3899"\w*, \w matando|strong="H4191"\w* \w a|strong="H3068"\w* las \w almas|strong="H5315"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* deben \w morir|strong="H4191"\w*, y dando \w vida|strong="H5315"\w* \w a|strong="H3068"\w* las \w almas|strong="H5315"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* deben \w vivir|strong="H2421"\w*, \w mintiendo|strong="H3576"\w* \w a|strong="H3068"\w* \w mi|strong="H2490"\w* \w pueblo|strong="H5971"\w* \w que|strong="H3808"\w* \w escucha|strong="H8085"\w* la \w mentira|strong="H3577"\w*.   
\p
\v 20 “‘\w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: He \w aquí|strong="H8033"\w* \w yo|strong="H5315"\w* estoy \w contra|strong="H5921"\w* vuestras vendas mágicas, \w con|strong="H5921"\w* \w que|strong="H5921"\w* \w cazáis|strong="H6679"\w* \w las|strong="H5921"\w* \w almas|strong="H5315"\w* \w al|strong="H5921"\w* vuelo; \w yo|strong="H5315"\w* \w las|strong="H5921"\w* arrancaré \w de|strong="H5921"\w* vuestros \w brazos|strong="H2220"\w*, \w y|strong="H5921"\w* \w dejaré|strong="H7971"\w* \w ir|strong="H7971"\w* \w las|strong="H5921"\w* \w almas|strong="H5315"\w*, \w las|strong="H5921"\w* \w almas|strong="H5315"\w* \w que|strong="H5921"\w* \w cazáis|strong="H6679"\w* \w como|strong="H5921"\w* \w a|strong="H3068"\w* aves.  
\v 21 \w Romperé|strong="H7167"\w* asimismo vuestros velos mágicos, \w y|strong="H3588"\w* \w libraré|strong="H5337"\w* \w a|strong="H3068"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* \w vuestra|strong="H1961"\w* \w mano|strong="H3027"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w estarán|strong="H1961"\w* \w más|strong="H5750"\w* \w como|strong="H3588"\w* presa \w en|strong="H3588"\w* \w vuestra|strong="H1961"\w* \w mano|strong="H3027"\w*; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé.  
\v 22 \w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* entristecisteis con \w mentiras|strong="H8267"\w* el \w corazón|strong="H3820"\w* del \w justo|strong="H6662"\w*, al cual yo \w no|strong="H3808"\w* \w entristecí|strong="H3510"\w*, y fortalecisteis las \w manos|strong="H3027"\w* del \w impío|strong="H7563"\w*, \w para|strong="H3282"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* apartase \w de|strong="H6662"\w* su \w mal|strong="H7451"\w* \w camino|strong="H1870"\w* y viviese;  
\v 23 \w por|strong="H3588"\w* \w tanto|strong="H3651"\w*, \w no|strong="H3808"\w* \w veréis|strong="H2372"\w* \w más|strong="H5750"\w* visión \w vana|strong="H7723"\w*, \w ni|strong="H3808"\w* practicaréis \w más|strong="H5750"\w* \w adivinación|strong="H7081"\w*; \w y|strong="H3588"\w* \w libraré|strong="H5337"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* vuestra \w mano|strong="H3027"\w*, \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé’”.   
\c 14
\p
\v 1 Vinieron entonces \w a|strong="H3068"\w* mí algunos \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* y se \w sentaron|strong="H3427"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* mí.  
\v 2 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 3 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, estos \w hombres|strong="H1121"\w* han \w puesto|strong="H5414"\w* sus \w ídolos|strong="H1544"\w* \w en|strong="H5921"\w* su \w corazón|strong="H3820"\w*, \w y|strong="H5921"\w* han establecido \w el|strong="H5921"\w* \w tropiezo|strong="H4383"\w* \w de|strong="H5921"\w* su \w iniquidad|strong="H5771"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* su \w rostro|strong="H6440"\w*. ¿Acaso he \w de|strong="H5921"\w* ser yo \w consultado|strong="H1875"\w* \w por|strong="H5921"\w* \w ellos|strong="H5921"\w*?  
\v 4 \w Háblales|strong="H1696"\w*, \w por|strong="H6440"\w* \w tanto|strong="H3651"\w*, \w y|strong="H3541"\w* \w diles|strong="H1696"\w*: \w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H5030"\w* \w Señor|strong="H3068"\w* Yahvé: ‘Cualquier hombre \w de|strong="H6440"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w que|strong="H3541"\w* \w ponga|strong="H7760"\w* sus \w ídolos|strong="H1544"\w* en su \w corazón|strong="H3820"\w*, \w y|strong="H3541"\w* establezca \w el|strong="H5030"\w* \w tropiezo|strong="H4383"\w* \w de|strong="H6440"\w* su \w iniquidad|strong="H5771"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* su \w rostro|strong="H6440"\w*, \w y|strong="H3541"\w* \w venga|strong="H5927"\w* al \w profeta|strong="H5030"\w*, yo, Yahvé, le \w responderé|strong="H6030"\w* conforme \w a|strong="H3068"\w* la \w multitud|strong="H7230"\w* \w de|strong="H6440"\w* sus \w ídolos|strong="H1544"\w*,  
\v 5 \w para|strong="H4616"\w* atrapar \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* su propio \w corazón|strong="H3820"\w*, ya \w que|strong="H5921"\w* \w todos|strong="H3605"\w* \w ellos|strong="H5921"\w* \w se|strong="H5921"\w* han apartado \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* sus \w ídolos|strong="H1544"\w*’.   
\p
\v 6 “\w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, di \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: ‘¡\w Convertíos|strong="H7725"\w* \w y|strong="H5921"\w* apartaos \w de|strong="H5921"\w* vuestros \w ídolos|strong="H1544"\w*! \w Apartad|strong="H7725"\w* vuestros \w rostros|strong="H6440"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* vuestras \w abominaciones|strong="H8441"\w*.   
\p
\v 7 “‘\w Porque|strong="H3588"\w* cualquier hombre \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w o|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w extranjeros|strong="H1616"\w* \w que|strong="H3588"\w* \w moran|strong="H1616"\w* \w en|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w que|strong="H3588"\w* se aparte \w de|strong="H3588"\w* \w mí|strong="H6030"\w*, \w y|strong="H3588"\w* \w ponga|strong="H7760"\w* sus \w ídolos|strong="H1544"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w*, \w y|strong="H3588"\w* establezca \w el|strong="H3588"\w* \w tropiezo|strong="H4383"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w iniquidad|strong="H5771"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w rostro|strong="H6440"\w*, \w y|strong="H3588"\w* \w venga|strong="H5927"\w* al \w profeta|strong="H5030"\w* \w para|strong="H3588"\w* consultarme \w a|strong="H3068"\w* \w mí|strong="H6030"\w*, \w yo|strong="H3588"\w*, Yahvé, le \w responderé|strong="H6030"\w* \w por|strong="H3588"\w* \w mí|strong="H6030"\w* mismo.  
\v 8 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* mi \w rostro|strong="H6440"\w* \w contra|strong="H6440"\w* \w ese|strong="H1931"\w* hombre, \w y|strong="H3588"\w* \w lo|strong="H1931"\w* \w haré|strong="H3772"\w* señal \w y|strong="H3588"\w* refrán, \w y|strong="H3588"\w* \w lo|strong="H1931"\w* \w cortaré|strong="H3772"\w* \w de|strong="H3588"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1931"\w* Yahvé.   
\p
\v 9 “‘\w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w el|strong="H1931"\w* \w profeta|strong="H5030"\w* \w se|strong="H1931"\w* dejare engañar \w y|strong="H3588"\w* \w hablare|strong="H1696"\w* \w palabra|strong="H1697"\w*, \w yo|strong="H3588"\w*, Yahvé, habré \w engañado|strong="H6601"\w* \w a|strong="H3068"\w* \w ese|strong="H1931"\w* \w profeta|strong="H5030"\w*; \w y|strong="H3588"\w* \w extenderé|strong="H5186"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w él|strong="H1931"\w* \w y|strong="H3588"\w* \w lo|strong="H1931"\w* \w destruiré|strong="H8045"\w* \w de|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.  
\v 10 \w Y|strong="H3068"\w* \w llevarán|strong="H5375"\w* su castigo; \w como|strong="H1961"\w* la \w iniquidad|strong="H5771"\w* del \w que|strong="H1961"\w* consulta, así \w será|strong="H1961"\w* la \w iniquidad|strong="H5771"\w* del \w profeta|strong="H5030"\w*,  
\v 11 \w para|strong="H4616"\w* \w que|strong="H3808"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* desvíe \w más|strong="H5750"\w* \w de|strong="H5750"\w* \w en|strong="H5750"\w* pos \w de|strong="H5750"\w* \w mí|strong="H1961"\w*, \w ni|strong="H3808"\w* \w se|strong="H1961"\w* contamine \w más|strong="H5750"\w* con \w todas|strong="H3605"\w* sus \w rebeliones|strong="H6588"\w*; \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w sean|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* y yo \w sea|strong="H1961"\w* su \w Dios|strong="H3069"\w*, \w dice|strong="H5002"\w* \w el|strong="H3605"\w* Señor Yahvé’”.   
\p
\v 12 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 13 “\w Hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w hombre|strong="H1121"\w*, \w cuando|strong="H3588"\w* \w la|strong="H5921"\w* tierra \w pecare|strong="H2398"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* rebelándose \w pérfidamente|strong="H4604"\w*, \w y|strong="H3588"\w* \w yo|strong="H4480"\w* extendiere \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w ella|strong="H4480"\w*, \w y|strong="H3588"\w* \w le|strong="H5921"\w* \w quebrantare|strong="H7665"\w* \w el|strong="H5921"\w* sustento \w del|strong="H4480"\w* \w pan|strong="H3899"\w*, \w y|strong="H3588"\w* \w enviare|strong="H7971"\w* \w en|strong="H5921"\w* \w ella|strong="H4480"\w* \w hambre|strong="H7458"\w*, \w y|strong="H3588"\w* \w cortare|strong="H3772"\w* \w de|strong="H4480"\w* \w ella|strong="H4480"\w* \w hombres|strong="H1121"\w* \w y|strong="H3588"\w* bestias,  
\v 14 \w si|strong="H1961"\w* estuviesen \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ella \w estos|strong="H1992"\w* \w tres|strong="H7969"\w* varones, \w Noé|strong="H5146"\w*, \w Daniel|strong="H1840"\w* y Job, \w ellos|strong="H1992"\w* por \w su|strong="H1992"\w* \w justicia|strong="H6666"\w* librarían únicamente \w sus|strong="H1992"\w* propias \w vidas|strong="H5315"\w*, \w dice|strong="H5002"\w* \w el|strong="H1992"\w* Señor Yahvé.   
\p
\v 15 “\w Y|strong="H3068"\w* \w si|strong="H3863"\w* yo \w hiciere|strong="H1961"\w* \w pasar|strong="H5674"\w* \w bestias|strong="H2416"\w* feroces \w por|strong="H6440"\w* la tierra y la asolaren, y quedare \w desolada|strong="H8077"\w* \w de|strong="H6440"\w* modo \w que|strong="H1961"\w* \w no|strong="H1097"\w* \w haya|strong="H1961"\w* quien \w pase|strong="H5674"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* las fieras,  
\v 16 y \w estos|strong="H1992"\w* \w tres|strong="H7969"\w* varones estuviesen \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* ella, \w vivo|strong="H2416"\w* yo, \w dice|strong="H5002"\w* \w el|strong="H1121"\w* Señor Yahvé, \w que|strong="H1121"\w* \w no|strong="H1961"\w* librarían \w ni|strong="H8432"\w* \w a|strong="H3068"\w* \w hijos|strong="H1121"\w* \w ni|strong="H8432"\w* \w a|strong="H3068"\w* \w hijas|strong="H1323"\w*; \w ellos|strong="H1992"\w* solos serían \w librados|strong="H5337"\w*, pero la tierra quedaría \w desolada|strong="H8077"\w*.   
\p
\v 17 “\w O|strong="H3068"\w* \w si|strong="H1931"\w* \w yo|strong="H4480"\w* trajere \w espada|strong="H2719"\w* \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* tierra, \w y|strong="H5921"\w* dijere: ‘\w Espada|strong="H2719"\w*, \w pasa|strong="H5674"\w* \w por|strong="H5921"\w* \w la|strong="H1931"\w* tierra’, \w e|strong="H3068"\w* hiciere cortar \w de|strong="H4480"\w* \w ella|strong="H1931"\w* hombres \w y|strong="H5921"\w* bestias,  
\v 18 \w y|strong="H3588"\w* \w estos|strong="H1992"\w* \w tres|strong="H7969"\w* \w varones|strong="H3588"\w* estuviesen \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* ella, \w vivo|strong="H2416"\w* \w yo|strong="H3588"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé, \w que|strong="H3588"\w* \w no|strong="H3808"\w* librarían \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w hijos|strong="H1121"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w hijas|strong="H1323"\w*; \w ellos|strong="H1992"\w* solos serían \w librados|strong="H5337"\w*.   
\p
\v 19 «\w O|strong="H3068"\w* \w si|strong="H1931"\w* \w enviare|strong="H7971"\w* peste \w sobre|strong="H5921"\w* \w esa|strong="H1931"\w* tierra \w y|strong="H5921"\w* \w derramare|strong="H8210"\w* \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w sobre|strong="H5921"\w* \w ella|strong="H1931"\w* \w con|strong="H5921"\w* \w sangre|strong="H1818"\w*, \w para|strong="H5921"\w* cortar \w de|strong="H4480"\w* \w ella|strong="H1931"\w* hombres \w y|strong="H5921"\w* bestias,  
\v 20 y estuviesen \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* ella \w Noé|strong="H5146"\w*, \w Daniel|strong="H1840"\w* y Job, \w vivo|strong="H2416"\w* \w yo|strong="H5315"\w*, \w dice|strong="H5002"\w* \w el|strong="H1121"\w* Señor Yahvé, \w que|strong="H1121"\w* no librarían \w a|strong="H3068"\w* \w hijo|strong="H1121"\w* \w ni|strong="H8432"\w* \w a|strong="H3068"\w* \w hija|strong="H1323"\w*; \w ellos|strong="H1992"\w* por \w su|strong="H1992"\w* \w justicia|strong="H6666"\w* librarían solamente \w sus|strong="H1992"\w* propias \w vidas|strong="H5315"\w*».   
\p
\v 21 \w Por|strong="H3588"\w* lo \w cual|strong="H3588"\w* \w así|strong="H3541"\w* dice \w el|strong="H3588"\w* Señor Yahvé: «¡\w Cuánto|strong="H3588"\w* \w más|strong="H3588"\w* \w cuando|strong="H3588"\w* \w yo|strong="H4480"\w* \w enviare|strong="H7971"\w* \w contra|strong="H4480"\w* Jerusalén mis cuatro \w juicios|strong="H8201"\w* terribles: \w espada|strong="H2719"\w*, \w hambre|strong="H7458"\w*, fieras \w y|strong="H3588"\w* peste, \w para|strong="H3588"\w* cortar \w de|strong="H4480"\w* \w ella|strong="H4480"\w* hombres \w y|strong="H3588"\w* \w bestias|strong="H2416"\w*!  
\v 22 Sin embargo, he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w quedará|strong="H3498"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* un remanente, \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w* \w que|strong="H5921"\w* serán sacados; he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* \w saldrán|strong="H3318"\w* \w hacia|strong="H1870"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w verás|strong="H7200"\w* su \w camino|strong="H1870"\w* \w y|strong="H5921"\w* sus \w obras|strong="H5949"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* consolarás \w del|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H5921"\w* hice venir \w sobre|strong="H5921"\w* Jerusalén, \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* traje \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*.  
\v 23 \w Y|strong="H3068"\w* os consolarán \w cuando|strong="H3588"\w* \w veáis|strong="H7200"\w* \w su|strong="H3588"\w* \w camino|strong="H1870"\w* \w y|strong="H3588"\w* sus \w obras|strong="H5949"\w*, \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w sin|strong="H3808"\w* causa \w hice|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* he \w hecho|strong="H6213"\w* \w en|strong="H3588"\w* \w ella|strong="H3605"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé».   
\c 15
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, ¿\w qué|strong="H4100"\w* \w es|strong="H1961"\w* \w la|strong="H3605"\w* \w madera|strong="H6086"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w vid|strong="H1612"\w* más \w que|strong="H4100"\w* \w cualquier|strong="H3605"\w* otra \w madera|strong="H6086"\w*? ¿\w Qué|strong="H4100"\w* \w es|strong="H1961"\w* \w el|strong="H3605"\w* \w sarmiento|strong="H2156"\w* \w que|strong="H4100"\w* \w está|strong="H1961"\w* entre \w los|strong="H1121"\w* \w árboles|strong="H6086"\w* del \w bosque|strong="H3293"\w*?  
\v 3 ¿\w Se|strong="H5921"\w* \w toma|strong="H3947"\w* \w de|strong="H4480"\w* \w ella|strong="H3605"\w* \w madera|strong="H6086"\w* \w para|strong="H5921"\w* \w hacer|strong="H6213"\w* \w alguna|strong="H3605"\w* \w obra|strong="H4399"\w*? ¿\w Se|strong="H5921"\w* \w toma|strong="H3947"\w* \w de|strong="H4480"\w* \w ella|strong="H3605"\w* acaso una estaca \w para|strong="H5921"\w* colgar \w en|strong="H5921"\w* \w ella|strong="H3605"\w* \w alguna|strong="H3605"\w* \w vasija|strong="H3627"\w*?  
\v 4 He \w aquí|strong="H2009"\w* que es echada al fuego \w para|strong="H5414"\w* ser consumida; el fuego consume sus \w dos|strong="H8147"\w* extremos, y su centro se quema. ¿Sirve entonces \w para|strong="H5414"\w* alguna \w obra|strong="H4399"\w*?  
\v 5 He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w estaba|strong="H1961"\w* \w entera|strong="H8549"\w*, \w no|strong="H3808"\w* \w servía|strong="H1961"\w* \w para|strong="H3588"\w* \w obra|strong="H4399"\w* alguna; ¿\w cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w después|strong="H1961"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* fuego \w la|strong="H3588"\w* \w ha|strong="H3808"\w* consumido \w y|strong="H3588"\w* \w está|strong="H1961"\w* quemada, \w servirá|strong="H1961"\w* \w para|strong="H3588"\w* algo?».   
\p
\v 6 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H3427"\w* Señor Yahvé: «\w Como|strong="H3651"\w* la \w madera|strong="H6086"\w* \w de|strong="H5414"\w* la \w vid|strong="H1612"\w* entre \w los|strong="H3427"\w* \w árboles|strong="H6086"\w* del \w bosque|strong="H3293"\w*, la cual \w di|strong="H5414"\w* al fuego \w para|strong="H5414"\w* ser consumida, \w así|strong="H3541"\w* \w haré|strong="H5414"\w* con \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5414"\w* Jerusalén.  
\v 7 \w Y|strong="H3068"\w* \w pondré|strong="H7760"\w* mi \w rostro|strong="H6440"\w* \w contra|strong="H6440"\w* ellos; \w aunque|strong="H3588"\w* \w salgan|strong="H3318"\w* del fuego, \w el|strong="H3588"\w* fuego \w los|strong="H3588"\w* devorará. \w Y|strong="H3068"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w cuando|strong="H3588"\w* \w ponga|strong="H7760"\w* mi \w rostro|strong="H6440"\w* \w contra|strong="H6440"\w* ellos.  
\v 8 \w Y|strong="H3068"\w* convertiré la tierra en desolación, \w por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w cometieron|strong="H4604"\w* \w prevaricación|strong="H4603"\w*», \w dice|strong="H5002"\w* el Señor Yahvé.   
\c 16
\p
\v 1 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, haz \w saber|strong="H3045"\w* \w a|strong="H3068"\w* Jerusalén sus \w abominaciones|strong="H8441"\w*,  
\v 3 \w y|strong="H3541"\w* di: \w Así|strong="H3541"\w* dice el Señor Yahvé sobre Jerusalén: ‘Tu origen \w y|strong="H3541"\w* tu \w nacimiento|strong="H4138"\w* son de la tierra del \w cananeo|strong="H3669"\w*. Tu padre fue amorreo \w y|strong="H3541"\w* tu madre hitita.  
\v 4 \w Y|strong="H3068"\w* en cuanto \w a|strong="H3068"\w* tu \w nacimiento|strong="H4138"\w*, el \w día|strong="H3117"\w* \w que|strong="H3808"\w* \w naciste|strong="H3205"\w* \w no|strong="H3808"\w* \w fue|strong="H3808"\w* \w cortado|strong="H3772"\w* tu \w ombligo|strong="H8270"\w*, \w ni|strong="H3808"\w* fuiste lavada con \w agua|strong="H4325"\w* para limpiarte, \w ni|strong="H3808"\w* \w salada|strong="H4414"\w* con \w sal|strong="H4414"\w*, \w ni|strong="H3808"\w* fuiste envuelta en pañales.  
\v 5 \w No|strong="H3808"\w* hubo \w ojo|strong="H5869"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* compadeciese \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w para|strong="H5921"\w* hacerte algo \w de|strong="H5921"\w* \w esto|strong="H6213"\w*, teniendo \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w misericordia|strong="H2550"\w*; \w sino|strong="H3808"\w* \w que|strong="H3808"\w* fuiste arrojada \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w*, \w con|strong="H5921"\w* menosprecio \w de|strong="H5921"\w* \w tu|strong="H6213"\w* \w vida|strong="H5315"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w que|strong="H3808"\w* \w naciste|strong="H3205"\w*.   
\p
\v 6 “‘\w Y|strong="H3068"\w* yo \w pasé|strong="H5674"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w vi|strong="H7200"\w* sucia \w en|strong="H5921"\w* tus \w sangres|strong="H1818"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* dije: ¡\w En|strong="H5921"\w* tus \w sangres|strong="H1818"\w*, \w vive|strong="H2421"\w*! \w Sí|strong="H5921"\w*, \w te|strong="H5921"\w* dije: ¡\w En|strong="H5921"\w* tus \w sangres|strong="H1818"\w*, \w vive|strong="H2421"\w*!  
\v 7 Te hice multiplicar como la hierba del \w campo|strong="H7704"\w*; y creciste y te hiciste \w grande|strong="H7235"\w*, y llegaste \w a|strong="H3068"\w* ser muy hermosa; tus \w pechos|strong="H7699"\w* se formaron, y tu \w pelo|strong="H8181"\w* \w creció|strong="H1431"\w*; pero estabas \w desnuda|strong="H6181"\w* y descubierta.   
\p
\v 8 “‘\w Y|strong="H3068"\w* \w pasé|strong="H5674"\w* \w yo|strong="H2009"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w miré|strong="H7200"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H5921"\w* tu \w tiempo|strong="H6256"\w* \w era|strong="H1961"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5921"\w* amores; \w y|strong="H5921"\w* \w extendí|strong="H6566"\w* \w mi|strong="H5921"\w* manto \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w cubrí|strong="H3680"\w* tu \w desnudez|strong="H6172"\w*; \w y|strong="H5921"\w* \w te|strong="H5921"\w* di juramento \w y|strong="H5921"\w* \w entré|strong="H5921"\w* \w en|strong="H5921"\w* \w pacto|strong="H1285"\w* \w contigo|strong="H5921"\w*, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor Yahvé, \w y|strong="H5921"\w* \w fuiste|strong="H1961"\w* mía.   
\p
\v 9 “‘\w Te|strong="H5921"\w* lavé \w con|strong="H5921"\w* \w agua|strong="H4325"\w*, \w y|strong="H5921"\w* lavé tus \w sangres|strong="H1818"\w* \w de|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* ungí \w con|strong="H5921"\w* \w aceite|strong="H8081"\w*.  
\v 10 \w Y|strong="H3068"\w* te vestí \w de|strong="H3847"\w* bordado, te calcé \w de|strong="H3847"\w* tejón, te ceñí \w de|strong="H3847"\w* lino y te \w cubrí|strong="H3680"\w* \w de|strong="H3847"\w* seda.  
\v 11 \w Te|strong="H5921"\w* atavié \w con|strong="H5921"\w* ornamentos, \w y|strong="H5921"\w* \w puse|strong="H5414"\w* \w brazaletes|strong="H6781"\w* \w en|strong="H5921"\w* tus brazos \w y|strong="H5921"\w* collar \w a|strong="H3068"\w* tu cuello.  
\v 12 \w Puse|strong="H5414"\w* un joyel \w en|strong="H5921"\w* tu nariz, \w y|strong="H5921"\w* \w zarcillos|strong="H5694"\w* \w en|strong="H5921"\w* tus orejas, \w y|strong="H5921"\w* una hermosa diadema \w en|strong="H5921"\w* tu \w cabeza|strong="H7218"\w*.  
\v 13 Así fuiste adornada de \w oro|strong="H2091"\w* y de \w plata|strong="H3701"\w*, y tu \w vestido|strong="H4403"\w* era de lino fino, seda y bordado; comiste flor de harina de trigo, \w miel|strong="H1706"\w* y \w aceite|strong="H8081"\w*; y fuiste hermoseada en extremo, y prosperaste hasta llegar \w a|strong="H3068"\w* reinar.  
\v 14 \w Y|strong="H3068"\w* \w salió|strong="H3318"\w* tu renombre \w entre|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* tu belleza; \w porque|strong="H3588"\w* \w era|strong="H1931"\w* perfecta, \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w hermosura|strong="H3308"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w puse|strong="H7760"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w dice|strong="H5002"\w* \w el|strong="H1931"\w* Señor Yahvé.   
\p
\v 15 “‘Pero confiaste \w en|strong="H5921"\w* tu \w hermosura|strong="H3308"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* prostituiste \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* tu renombre, \w y|strong="H5921"\w* \w derramaste|strong="H8210"\w* tus \w fornicaciones|strong="H8457"\w* \w a|strong="H3068"\w* \w cuantos|strong="H3605"\w* \w pasaron|strong="H5674"\w*; suya \w eras|strong="H1961"\w*.  
\v 16 \w Y|strong="H3068"\w* \w tomaste|strong="H3947"\w* \w de|strong="H5921"\w* tus vestidos, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w hiciste|strong="H6213"\w* diversos lugares \w altos|strong="H1116"\w*, \w y|strong="H5921"\w* \w fornicaste|strong="H2181"\w* \w en|strong="H5921"\w* \w ellos|strong="H5921"\w*; cosa semejante \w nunca|strong="H3808"\w* \w había|strong="H1961"\w* sucedido, \w ni|strong="H3808"\w* \w sucederá|strong="H1961"\w* \w más|strong="H5921"\w*.  
\v 17 \w Tomaste|strong="H3947"\w* asimismo tus hermosas \w alhajas|strong="H3627"\w* \w de|strong="H5414"\w* \w oro|strong="H2091"\w* y \w de|strong="H5414"\w* \w plata|strong="H3701"\w* que \w yo|strong="H6213"\w* te \w había|strong="H6213"\w* \w dado|strong="H5414"\w*, y te \w hiciste|strong="H6213"\w* \w imágenes|strong="H6754"\w* \w de|strong="H5414"\w* hombre y \w fornicaste|strong="H2181"\w* con ellas;  
\v 18 y \w tomaste|strong="H3947"\w* tus \w vestidos|strong="H3680"\w* \w de|strong="H6440"\w* diversos colores y las \w cubriste|strong="H3680"\w*; y mi \w aceite|strong="H8081"\w* y mi incienso \w pusiste|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellas.  
\v 19 \w Mi|strong="H1961"\w* \w pan|strong="H3899"\w* también, \w que|strong="H1961"\w* yo te \w había|strong="H1961"\w* \w dado|strong="H5414"\w*, la flor \w de|strong="H6440"\w* harina, el \w aceite|strong="H8081"\w* y la \w miel|strong="H1706"\w* con \w que|strong="H1961"\w* yo te mantenía, \w pusiste|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellas \w para|strong="H5414"\w* \w olor|strong="H7381"\w* agradable; y así \w fue|strong="H1961"\w*, \w dice|strong="H5002"\w* el Señor Yahvé.   
\p
\v 20 “‘Además \w de|strong="H1121"\w* esto, \w tomaste|strong="H3947"\w* \w a|strong="H3068"\w* tus \w hijos|strong="H1121"\w* y \w a|strong="H3068"\w* tus \w hijas|strong="H1323"\w* \w que|strong="H1121"\w* habías dado \w a|strong="H3068"\w* luz para mí, y \w los|strong="H1121"\w* sacrificaste \w a|strong="H3068"\w* ellas para \w que|strong="H1121"\w* fuesen consumidos. ¿\w Era|strong="H1121"\w* \w poca|strong="H4592"\w* tu \w fornicación|strong="H8457"\w*,  
\v 21 \w para|strong="H5414"\w* \w que|strong="H1121"\w* matases \w a|strong="H3068"\w* \w mis|strong="H5414"\w* \w hijos|strong="H1121"\w* y \w los|strong="H1121"\w* dieses \w a|strong="H3068"\w* ellas, haciéndolos \w pasar|strong="H5674"\w* \w por|strong="H5414"\w* \w el|strong="H1121"\w* fuego?  
\v 22 \w Y|strong="H3068"\w* con \w todas|strong="H3605"\w* tus \w abominaciones|strong="H8441"\w* y tus \w fornicaciones|strong="H8457"\w* \w no|strong="H3808"\w* te has acordado \w de|strong="H1818"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H1818"\w* tu \w juventud|strong="H5271"\w*, \w cuando|strong="H3117"\w* \w estabas|strong="H1961"\w* \w desnuda|strong="H6181"\w* y descubierta, revolcándote en tu \w sangre|strong="H1818"\w*.   
\p
\v 23 “‘\w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w después|strong="H1961"\w* \w de|strong="H7451"\w* \w toda|strong="H3605"\w* tu \w maldad|strong="H7451"\w* (¡ay, ay \w de|strong="H7451"\w* ti!, \w dice|strong="H5002"\w* \w el|strong="H3605"\w* Señor Yahvé),  
\v 24 te \w edificaste|strong="H1129"\w* lugares altos y te \w hiciste|strong="H6213"\w* \w altar|strong="H7413"\w* en \w todas|strong="H3605"\w* las \w plazas|strong="H7339"\w*.  
