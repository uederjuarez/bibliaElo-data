\v 43 “‘\w Por|strong="H5921"\w* \w cuanto|strong="H3282"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* acordaste \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w tu|strong="H6213"\w* \w juventud|strong="H5271"\w*, \w y|strong="H1571"\w* \w me|strong="H5921"\w* provocaste \w a|strong="H3068"\w* ira \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w esto|strong="H6213"\w*, \w por|strong="H5921"\w* eso, he aquí \w yo|strong="H6213"\w* \w también|strong="H1571"\w* he \w hecho|strong="H6213"\w* recaer \w tu|strong="H6213"\w* \w camino|strong="H1870"\w* \w sobre|strong="H5921"\w* \w tu|strong="H6213"\w* \w cabeza|strong="H7218"\w*, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor Yahvé; \w pues|strong="H3282"\w* \w ni|strong="H3808"\w* \w aun|strong="H1571"\w* \w has|strong="H5414"\w* pensado \w en|strong="H5921"\w* \w todas|strong="H3605"\w* tus \w abominaciones|strong="H8441"\w*.   
