\p \w Esta|strong="H1931"\w* \w fue|strong="H1961"\w* \w la|strong="H1931"\w* \w visión|strong="H4758"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w semejanza|strong="H1823"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* Yahvé. \w Y|strong="H3068"\w* \w cuando|strong="H3117"\w* \w la|strong="H1931"\w* \w vi|strong="H7200"\w*, \w caí|strong="H5307"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w*, \w y|strong="H5921"\w* \w oí|strong="H8085"\w* \w la|strong="H1931"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* uno \w que|strong="H1931"\w* \w hablaba|strong="H1696"\w*.   
\c 2
\p
\v 1 \w Él|strong="H5921"\w* \w me|strong="H5921"\w* \w dijo|strong="H1696"\w*: «\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w ponte|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H7272"\w*, \w y|strong="H5921"\w* \w hablaré|strong="H1696"\w* \w contigo|strong="H5921"\w*».  
\v 2 \w El|strong="H5921"\w* \w Espíritu|strong="H7307"\w* entró \w en|strong="H5921"\w* \w mí|strong="H5921"\w* cuando \w me|strong="H5921"\w* \w habló|strong="H1696"\w*, \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w puso|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H7272"\w*; \w y|strong="H5921"\w* \w oí|strong="H8085"\w* \w al|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* \w hablaba|strong="H1696"\w*.   
\p
\v 3 Me dijo: “\w Hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w hombre|strong="H1121"\w*, yo te \w envío|strong="H7971"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* una \w nación|strong="H1471"\w* \w de|strong="H5704"\w* \w rebeldes|strong="H4775"\w* \w que|strong="H5704"\w* \w se|strong="H1992"\w* ha rebelado \w contra|strong="H3478"\w* mí. Tanto \w ellos|strong="H1992"\w* \w como|strong="H5704"\w* \w sus|strong="H1992"\w* padres \w se|strong="H1992"\w* han rebelado \w contra|strong="H3478"\w* mí \w hasta|strong="H5704"\w* \w el|strong="H1121"\w* \w día|strong="H3117"\w* \w de|strong="H5704"\w* \w hoy|strong="H3117"\w*.  
\v 4 Son \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w rostro|strong="H6440"\w* endurecido \w y|strong="H3541"\w* \w de|strong="H6440"\w* \w corazón|strong="H3820"\w* obstinado. Te \w envío|strong="H7971"\w* \w a|strong="H3068"\w* ellos, \w y|strong="H3541"\w* les dirás: ‘\w Así|strong="H3541"\w* dice \w el|strong="H1121"\w* Señor\f + \fr 2:4 \ft La palabra traducida «Señor» es «Adonai».\f* Yahvé’.  
\v 5 \w Y|strong="H3068"\w* \w ellos|strong="H1992"\w*, ya \w sea|strong="H1961"\w* \w que|strong="H3588"\w* \w escuchen|strong="H8085"\w* \w o|strong="H3068"\w* \w que|strong="H3588"\w* \w dejen|strong="H2308"\w* \w de|strong="H3588"\w* \w escuchar|strong="H8085"\w* — \w puesto|strong="H3588"\w* \w que|strong="H3588"\w* \w son|strong="H1961"\w* una \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w* —, \w sabrán|strong="H3045"\w* al \w menos|strong="H3588"\w* \w que|strong="H3588"\w* ha habido un \w profeta|strong="H5030"\w* \w entre|strong="H8432"\w* \w ellos|strong="H1992"\w*.  
\v 6 \w Y|strong="H3068"\w* tú, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w hombre|strong="H1121"\w*, \w no|strong="H3588"\w* \w les|strong="H1992"\w* tengas \w miedo|strong="H3372"\w*, ni \w temas|strong="H3372"\w* \w sus|strong="H1992"\w* \w palabras|strong="H1697"\w*, \w aunque|strong="H3588"\w* \w te|strong="H3588"\w* halles \w entre|strong="H3588"\w* \w zarzas|strong="H5621"\w* \w y|strong="H3588"\w* espinas, \w y|strong="H3588"\w* habites \w con|strong="H3588"\w* escorpiones. \w No|strong="H3588"\w* tengas \w miedo|strong="H3372"\w* \w de|strong="H3588"\w* \w sus|strong="H1992"\w* \w palabras|strong="H1697"\w*, ni \w te|strong="H3588"\w* asustes \w por|strong="H3588"\w* \w su|strong="H1992"\w* aspecto, \w por|strong="H3588"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* sean una \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w*.  
\v 7 \w Les|strong="H1992"\w* comunicarás, \w pues|strong="H3588"\w*, mis \w palabras|strong="H1697"\w*, \w escuchen|strong="H8085"\w* \w o|strong="H3068"\w* \w dejen|strong="H2308"\w* \w de|strong="H3588"\w* \w escuchar|strong="H8085"\w*, \w porque|strong="H3588"\w* \w son|strong="H3588"\w* muy \w rebeldes|strong="H4805"\w*.  
\v 8 Pero tú, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w escucha|strong="H8085"\w* lo \w que|strong="H1121"\w* yo te digo; \w no|strong="H1961"\w* \w seas|strong="H1961"\w* \w rebelde|strong="H4805"\w* \w como|strong="H1961"\w* esa \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w*. \w Abre|strong="H6475"\w* tu \w boca|strong="H6310"\w* y come lo \w que|strong="H1121"\w* te \w doy|strong="H5414"\w*”.   
\p
\v 9 Entonces \w miré|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* \w que|strong="H3027"\w* una \w mano|strong="H3027"\w* \w estaba|strong="H2009"\w* extendida hacia \w mí|strong="H2009"\w*, y en ella había un \w rollo|strong="H4039"\w* de \w libro|strong="H5612"\w*.  
\v 10 \w Lo|strong="H1931"\w* desenrolló \w ante|strong="H6440"\w* mí, y estaba \w escrito|strong="H3789"\w* \w por|strong="H6440"\w* \w el|strong="H1931"\w* anverso y \w por|strong="H6440"\w* \w el|strong="H1931"\w* reverso; y en \w él|strong="H1931"\w* estaban \w escritas|strong="H3789"\w* lamentaciones, gemidos y ayes.   
\c 3
\p
\v 1 Me \w dijo|strong="H1696"\w*: «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, come lo \w que|strong="H1121"\w* \w halles|strong="H4672"\w*; come \w este|strong="H2063"\w* \w rollo|strong="H4039"\w*, y \w ve|strong="H3212"\w* y \w habla|strong="H1696"\w* \w a|strong="H3068"\w* \w la|strong="H2063"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*».   
\p
\v 2 \w Abrí|strong="H6605"\w* mi \w boca|strong="H6310"\w*, y me hizo comer aquel \w rollo|strong="H4039"\w*.   
\p
\v 3 \w Y|strong="H3068"\w* me dijo: «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, alimenta tu vientre y \w llena|strong="H4390"\w* tus \w entrañas|strong="H4578"\w* con \w este|strong="H2063"\w* \w rollo|strong="H4039"\w* \w que|strong="H1121"\w* yo te \w doy|strong="H5414"\w*».  
\p Lo comí, y \w fue|strong="H1961"\w* en \w mi|strong="H1961"\w* \w boca|strong="H6310"\w* \w dulce|strong="H4966"\w* \w como|strong="H1961"\w* \w la|strong="H2063"\w* \w miel|strong="H1706"\w*.   
\p
\v 4 Me \w dijo|strong="H1696"\w* entonces: «\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w ve|strong="H3212"\w* y dirígete \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w diles|strong="H1697"\w* mis \w palabras|strong="H1697"\w*.  
