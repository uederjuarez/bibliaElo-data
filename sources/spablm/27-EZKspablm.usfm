\p
\v 26 “\w Allí|strong="H8033"\w* están \w Mesec|strong="H4902"\w* \w y|strong="H3588"\w* \w Tubal|strong="H8422"\w* \w con|strong="H3588"\w* \w toda|strong="H3605"\w* \w su|strong="H3588"\w* \w multitud|strong="H1995"\w*. Sus \w sepulcros|strong="H6913"\w* \w los|strong="H3605"\w* \w rodean|strong="H5439"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w incircuncisos|strong="H6189"\w*, \w muertos|strong="H2490"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*; \w porque|strong="H3588"\w* habían infundido \w su|strong="H3588"\w* terror \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w vivientes|strong="H2416"\w*.  
\v 27 \w No|strong="H3808"\w* \w yacerán|strong="H7901"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* héroes \w caídos|strong="H5307"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w incircuncisos|strong="H6189"\w*, \w que|strong="H3588"\w* \w descendieron|strong="H3381"\w* \w al|strong="H5921"\w* Seol \w con|strong="H5921"\w* sus \w armas|strong="H3627"\w* \w de|strong="H5921"\w* \w guerra|strong="H4421"\w*, \w y|strong="H3588"\w* \w pusieron|strong="H5414"\w* sus \w espadas|strong="H2719"\w* \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* sus \w cabezas|strong="H7218"\w*. Sus \w iniquidades|strong="H5771"\w* \w estarán|strong="H1961"\w* \w sobre|strong="H5921"\w* sus \w huesos|strong="H6106"\w*, \w por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w fueron|strong="H1961"\w* \w el|strong="H5921"\w* terror \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w poderosos|strong="H1368"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w vivientes|strong="H2416"\w*.   
\p
\v 28 “También tú serás \w quebrantado|strong="H7665"\w* \w entre|strong="H8432"\w* los \w incircuncisos|strong="H6189"\w*, y \w yacerás|strong="H7901"\w* con los \w muertos|strong="H2491"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.   
\p
\v 29 “\w Allí|strong="H8033"\w* \w está|strong="H1992"\w* Edom, \w sus|strong="H1992"\w* \w reyes|strong="H4428"\w* y \w todos|strong="H3605"\w* \w sus|strong="H1992"\w* \w príncipes|strong="H5387"\w*, \w los|strong="H1992"\w* cuales en medio \w de|strong="H5414"\w* \w su|strong="H1992"\w* poderío fueron puestos con \w los|strong="H1992"\w* \w muertos|strong="H2491"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*. \w Ellos|strong="H1992"\w* \w yacerán|strong="H7901"\w* con \w los|strong="H1992"\w* \w incircuncisos|strong="H6189"\w* y con \w los|strong="H1992"\w* \w que|strong="H1992"\w* \w descienden|strong="H3381"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* fosa.   
\p
\v 30 “\w Allí|strong="H8033"\w* están \w los|strong="H3605"\w* \w príncipes|strong="H5257"\w* del \w norte|strong="H6828"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w*, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w sidonios|strong="H6722"\w*, \w que|strong="H3605"\w* \w descendieron|strong="H3381"\w* con \w los|strong="H3605"\w* \w muertos|strong="H2491"\w*. Han sido \w avergonzados|strong="H5375"\w* por \w el|strong="H3605"\w* terror \w que|strong="H3605"\w* infundieron con su poderío. \w Yacen|strong="H7901"\w* \w incircuncisos|strong="H6189"\w* con \w los|strong="H3605"\w* \w muertos|strong="H2491"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, y \w llevan|strong="H5375"\w* su \w vergüenza|strong="H3639"\w* con \w los|strong="H3605"\w* \w que|strong="H3605"\w* \w descienden|strong="H3381"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* fosa.   
\p
\v 31 «\w A|strong="H3068"\w* \w estos|strong="H3605"\w* \w verá|strong="H7200"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w consolará|strong="H5162"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* su \w multitud|strong="H1995"\w*; \w Faraón|strong="H6547"\w* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* su \w ejército|strong="H2428"\w*, \w muertos|strong="H2491"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* Señor Yahvé.  
