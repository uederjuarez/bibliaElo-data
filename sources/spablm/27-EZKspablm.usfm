\q2 \w y|strong="H5921"\w* \w saciaré|strong="H7646"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w bestias|strong="H2416"\w* \w de|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.   
\q1
\v 5 \w Pondré|strong="H5414"\w* tus \w carnes|strong="H1320"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*,  
\q2 \w y|strong="H5921"\w* llenaré \w los|strong="H5921"\w* valles \w de|strong="H5921"\w* tu enorme tamaño.   
\q1
\v 6 Regaré \w con|strong="H4480"\w* tu \w sangre|strong="H1818"\w* la tierra \w por|strong="H4480"\w* donde nadas,  
\q2 hasta llegar \w a|strong="H3068"\w* los \w montes|strong="H2022"\w*;  
\q2 y los arroyos \w se|strong="H4480"\w* llenarán \w de|strong="H4480"\w* \w ti|strong="H4480"\w*.   
\q1
\v 7 Cuando te haya extinguido, \w cubriré|strong="H3680"\w* los \w cielos|strong="H8064"\w*,  
\q2 y haré oscurecer sus \w estrellas|strong="H3556"\w*;  
