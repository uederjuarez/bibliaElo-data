\v 27 \w Mas|strong="H3588"\w* \w cuando|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H3588"\w* hubiere \w hablado|strong="H1696"\w*, \w abriré|strong="H6605"\w* tu \w boca|strong="H6310"\w*, \w y|strong="H3588"\w* \w les|strong="H1992"\w* \w dirás|strong="H1696"\w*: ‘\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H3588"\w* Señor Yahvé’. \w El|strong="H3588"\w* \w que|strong="H3588"\w* \w oye|strong="H8085"\w*, \w oiga|strong="H8085"\w*; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w cesa|strong="H2308"\w* \w de|strong="H3588"\w* \w oír|strong="H8085"\w*, cese; \w porque|strong="H3588"\w* \w casa|strong="H1004"\w* \w rebelde|strong="H4805"\w* \w son|strong="H3588"\w*”.   
\c 4
\p
\v 1 “Tú también, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w toma|strong="H3947"\w* una teja \w y|strong="H5921"\w* ponla \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*; graba \w en|strong="H5921"\w* \w ella|strong="H5921"\w* una \w ciudad|strong="H5892"\w*: Jerusalén.  
\v 2 Ponle sitio, construye \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* fortalezas \w y|strong="H5921"\w* levanta \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* un \w baluarte|strong="H5550"\w*. \w Pon|strong="H7760"\w* también \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* \w campamentos|strong="H4264"\w* \w y|strong="H5921"\w* coloca \w arietes|strong="H5550"\w* \w a|strong="H3068"\w* su \w alrededor|strong="H5439"\w*.  
