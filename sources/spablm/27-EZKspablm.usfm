\p
\v 16 «\w Esta|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w endecha|strong="H7015"\w*, \w y|strong="H5921"\w* \w la|strong="H1931"\w* cantarán; \w las|strong="H5921"\w* \w hijas|strong="H1323"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w la|strong="H1931"\w* cantarán; \w la|strong="H1931"\w* cantarán \w sobre|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w su|strong="H1931"\w* \w multitud|strong="H1995"\w*, \w dice|strong="H5002"\w* \w el|strong="H1931"\w* Señor Yahvé».   
\b  
\p
