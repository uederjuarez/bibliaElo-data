\m \w Esta|strong="H1931"\w* \w es|strong="H1931"\w* una elegía, \w y|strong="H5797"\w* de elegía \w servirá|strong="H1961"\w*.   
\c 20
\p
\v 1 \w Aconteció|strong="H1961"\w* en \w el|strong="H3427"\w* \w séptimo|strong="H7637"\w* \w año|strong="H8141"\w*, en \w el|strong="H3427"\w* \w mes|strong="H2320"\w* \w quinto|strong="H2549"\w*, \w a|strong="H3068"\w* \w los|strong="H3427"\w* diez días del \w mes|strong="H2320"\w*, \w que|strong="H1961"\w* vinieron algunos \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* consultar \w a|strong="H3068"\w* Yahvé, y \w se|strong="H1961"\w* \w sentaron|strong="H3427"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H1961"\w*.   
