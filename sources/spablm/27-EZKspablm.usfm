\q2 “\w Extenderé|strong="H6566"\w* \w mi|strong="H5921"\w* \w red|strong="H7568"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w con|strong="H5921"\w* asamblea \w de|strong="H5921"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*,  
\q2 \w y|strong="H5921"\w* \w te|strong="H5921"\w* sacarán \w con|strong="H5921"\w* \w mi|strong="H5921"\w* \w red|strong="H7568"\w*.   
\q1
\v 4 \w Te|strong="H5921"\w* dejaré \w en|strong="H5921"\w* tierra,  
