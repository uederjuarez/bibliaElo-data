\p
\v 8 “\w Así|strong="H3541"\w* dice \w el|strong="H3605"\w* Señor Yahvé: ‘\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* dicen \w Moab|strong="H4124"\w* \w y|strong="H3541"\w* \w Seir|strong="H8165"\w*: «He \w aquí|strong="H2009"\w*, \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de \w Judá|strong="H3063"\w* \w es|strong="H3541"\w* como \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w*»,  
\v 9 \w por|strong="H3651"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H2005"\w* que yo \w abro|strong="H6605"\w* el flanco de \w Moab|strong="H4124"\w* desde las \w ciudades|strong="H5892"\w*, desde sus \w ciudades|strong="H5892"\w* que están en sus fronteras, la \w gloria|strong="H6643"\w* del país: Bet-jesimot, Baal-meón y Quiriataim,  
\v 10 \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w lo|strong="H3808"\w* \w daré|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5921"\w* \w oriente|strong="H6924"\w* \w como|strong="H5921"\w* \w posesión|strong="H4181"\w*, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, \w para|strong="H4616"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* haya \w memoria|strong="H2142"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón \w entre|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.  
\v 11 \w Haré|strong="H6213"\w* \w juicios|strong="H8201"\w* \w en|strong="H3588"\w* \w Moab|strong="H4124"\w*, \w y|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé’.   
\p
\v 12 “\w Así|strong="H3541"\w* dice \w el|strong="H6213"\w* Señor Yahvé: ‘\w Por|strong="H3282"\w* \w lo|strong="H6213"\w* \w que|strong="H3541"\w* \w hizo|strong="H6213"\w* Edom, tomando \w venganza|strong="H5359"\w* de la \w casa|strong="H1004"\w* de \w Judá|strong="H3063"\w*, \w pues|strong="H3282"\w* delinquieron en gran manera \w y|strong="H3541"\w* se vengaron de ellos;  
\v 13 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: \w Yo|strong="H4480"\w* \w también|strong="H3651"\w* \w extenderé|strong="H5186"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* Edom, \w y|strong="H5921"\w* \w cortaré|strong="H3772"\w* \w de|strong="H4480"\w* \w ella|strong="H4480"\w* hombres \w y|strong="H5921"\w* bestias, \w y|strong="H5921"\w* \w la|strong="H5921"\w* asolaré; \w desde|strong="H4480"\w* \w Temán|strong="H8487"\w* \w hasta|strong="H5921"\w* \w Dedán|strong="H1719"\w* \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*.  
\v 14 \w Y|strong="H3068"\w* \w pondré|strong="H5414"\w* mi \w venganza|strong="H5360"\w* \w contra|strong="H3478"\w* Edom en \w manos|strong="H3027"\w* \w de|strong="H5971"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, y \w harán|strong="H6213"\w* en Edom según mi \w ira|strong="H2534"\w* y según mi \w furor|strong="H2534"\w*; y \w conocerán|strong="H3045"\w* mi \w venganza|strong="H5360"\w*, \w dice|strong="H5002"\w* \w el|strong="H6213"\w* Señor Yahvé’.   
\p
\v 15 “\w Así|strong="H3541"\w* dice \w el|strong="H6213"\w* Señor Yahvé: ‘\w Por|strong="H3282"\w* \w lo|strong="H6213"\w* \w que|strong="H3541"\w* \w hicieron|strong="H6213"\w* los \w filisteos|strong="H6430"\w* con \w venganza|strong="H5360"\w*, cuando se vengaron con despecho de \w ánimo|strong="H5315"\w*, destruyendo \w por|strong="H3282"\w* \w antiguas|strong="H5769"\w* enemistades;  
\v 16 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* yo extiendo \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w*, \w y|strong="H5921"\w* \w cortaré|strong="H3772"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* cereteos \w y|strong="H5921"\w* \w destruiré|strong="H3772"\w* \w el|strong="H5921"\w* \w resto|strong="H7611"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* costa \w del|strong="H5921"\w* \w mar|strong="H3220"\w*.  
\v 17 \w Y|strong="H3068"\w* \w haré|strong="H6213"\w* \w en|strong="H3588"\w* ellos \w grandes|strong="H1419"\w* \w venganzas|strong="H5360"\w* \w con|strong="H3588"\w* reprensiones \w de|strong="H3588"\w* \w ira|strong="H2534"\w*; \w y|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé, \w cuando|strong="H3588"\w* \w haga|strong="H6213"\w* mi \w venganza|strong="H5360"\w* \w en|strong="H3588"\w* ellos’”.   
\c 26
\p
\v 1 \w Aconteció|strong="H1961"\w* en el \w undécimo|strong="H6249"\w* \w año|strong="H8141"\w*, el día primero del \w mes|strong="H2320"\w*, \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w por|strong="H5921"\w* \w cuanto|strong="H3282"\w* \w Tiro|strong="H6865"\w* ha dicho \w contra|strong="H5921"\w* Jerusalén: ‘¡\w Ea|strong="H1889"\w*! \w Quebrantada|strong="H7665"\w* \w está|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H5921"\w* \w era|strong="H1121"\w* \w puerta|strong="H1817"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* naciones; \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w se|strong="H5921"\w* ha vuelto; yo seré \w llena|strong="H4390"\w*, \w y|strong="H5921"\w* \w ella|strong="H5921"\w* quedará desierta’;  
\v 3 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* yo estoy \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, oh \w Tiro|strong="H6865"\w*, \w y|strong="H5921"\w* haré \w subir|strong="H5927"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w*, \w como|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* hace \w subir|strong="H5927"\w* sus olas.  
\v 4 \w Y|strong="H3068"\w* demolerán los \w muros|strong="H2346"\w* \w de|strong="H4480"\w* \w Tiro|strong="H6865"\w*, y derribarán sus \w torres|strong="H4026"\w*; y barreré \w de|strong="H4480"\w* \w ella|strong="H4480"\w* hasta su \w polvo|strong="H6083"\w*, y la dejaré como una \w peña|strong="H5553"\w* pelada.  
\v 5 \w Tendedero|strong="H4894"\w* \w de|strong="H3588"\w* redes \w será|strong="H1961"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w mar|strong="H3220"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* he \w hablado|strong="H1696"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé; \w y|strong="H3588"\w* \w será|strong="H1961"\w* saqueada \w por|strong="H3588"\w* las \w naciones|strong="H1471"\w*.  
\v 6 \w Y|strong="H3068"\w* sus \w hijas|strong="H1323"\w* \w que|strong="H3588"\w* están \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w* serán muertas \w a|strong="H3068"\w* \w espada|strong="H2719"\w*; \w y|strong="H3588"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé.   
\p
\v 7 “\w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice \w el|strong="H3588"\w* Señor Yahvé: He \w aquí|strong="H3541"\w* \w que|strong="H3588"\w* del \w norte|strong="H6828"\w* traigo \w yo|strong="H3588"\w* contra \w Tiro|strong="H6865"\w* \w a|strong="H3068"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w reyes|strong="H4428"\w*, \w con|strong="H3588"\w* \w caballos|strong="H5483"\w*, \w carros|strong="H7393"\w*, \w jinetes|strong="H6571"\w*, \w y|strong="H3588"\w* tropas \w y|strong="H3588"\w* \w mucho|strong="H7227"\w* \w pueblo|strong="H5971"\w*.  
\v 8 \w Matará|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* tus \w hijas|strong="H1323"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campo|strong="H7704"\w*; \w y|strong="H5921"\w* \w pondrá|strong="H5414"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* torres \w de|strong="H5921"\w* asedio, \w y|strong="H5921"\w* \w levantará|strong="H6965"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w baluarte|strong="H5550"\w*, \w y|strong="H5921"\w* alzará \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w escudos|strong="H6793"\w*.  
\v 9 \w Pondrá|strong="H5414"\w* sus arietes contra tus \w muros|strong="H2346"\w*, y con sus \w hachas|strong="H2719"\w* \w derribará|strong="H5422"\w* tus \w torres|strong="H4026"\w*.  
\v 10 Por la \w multitud|strong="H8229"\w* de sus \w caballos|strong="H5483"\w* te \w cubrirá|strong="H3680"\w* el polvo de ellos; con el \w estruendo|strong="H6963"\w* de la caballería, de las ruedas y de los \w carros|strong="H7393"\w*, \w temblarán|strong="H7493"\w* tus \w muros|strong="H2346"\w*, cuando entre por tus \w puertas|strong="H8179"\w* como se entra en una \w ciudad|strong="H5892"\w* con brechas.  
\v 11 Con \w los|strong="H3605"\w* cascos \w de|strong="H5971"\w* sus \w caballos|strong="H5483"\w* pisoteará \w todas|strong="H3605"\w* tus \w calles|strong="H2351"\w*; \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* \w matará|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*, \w y|strong="H5797"\w* tus \w fuertes|strong="H5797"\w* \w columnas|strong="H4676"\w* \w caerán|strong="H3381"\w* \w a|strong="H3068"\w* tierra.  
\v 12 \w Y|strong="H3068"\w* robarán tus \w riquezas|strong="H2428"\w* y saquearán tus mercaderías; derribarán tus \w muros|strong="H2346"\w* y \w destruirán|strong="H5422"\w* tus \w casas|strong="H1004"\w* \w preciosas|strong="H2532"\w*, y \w pondrán|strong="H7760"\w* tus piedras, tu \w madera|strong="H6086"\w* y tu \w polvo|strong="H6083"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H4325"\w* las \w aguas|strong="H4325"\w*.  
\v 13 \w Y|strong="H3068"\w* haré cesar el estrépito \w de|strong="H5750"\w* tus \w canciones|strong="H7892"\w*, y \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w oirá|strong="H8085"\w* \w más|strong="H5750"\w* el \w son|strong="H3808"\w* \w de|strong="H5750"\w* tus \w arpas|strong="H3658"\w*.  
\v 14 \w Y|strong="H3068"\w* \w te|strong="H3588"\w* \w pondré|strong="H5414"\w* \w como|strong="H3588"\w* una \w peña|strong="H5553"\w* pelada; \w tendedero|strong="H4894"\w* \w de|strong="H3588"\w* redes \w serás|strong="H1961"\w*, \w y|strong="H3588"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w serás|strong="H1961"\w* \w edificada|strong="H1129"\w*; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w*, Yahvé, he \w hablado|strong="H1696"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* Yahvé.   
\p
\v 15 “\w Así|strong="H3541"\w* dice el Señor Yahvé \w a|strong="H3068"\w* \w Tiro|strong="H6865"\w*: ¿\w No|strong="H3808"\w* \w se|strong="H3808"\w* estremecerán las costas al \w estruendo|strong="H6963"\w* de tu caída, cuando giman los \w heridos|strong="H2491"\w*, cuando \w se|strong="H3808"\w* haga la \w matanza|strong="H2027"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ti?  
\v 16 \w Entonces|strong="H5493"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w príncipes|strong="H5387"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w* \w descenderán|strong="H3381"\w* \w de|strong="H5921"\w* sus tronos, \w y|strong="H5921"\w* \w se|strong="H5921"\w* quitarán sus mantos, \w y|strong="H5921"\w* \w se|strong="H5921"\w* despojarán \w de|strong="H5921"\w* sus ropas bordadas; \w de|strong="H5921"\w* \w espanto|strong="H2729"\w* \w se|strong="H5921"\w* vestirán, \w se|strong="H5921"\w* sentarán \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* temblarán \w a|strong="H3068"\w* \w cada|strong="H3605"\w* \w momento|strong="H7281"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* asombrarán \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w ti|strong="H5921"\w*.  
\v 17 \w Y|strong="H3068"\w* levantarán \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w endecha|strong="H7015"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* dirán:  
\q1 ‘¡\w Cómo|strong="H1961"\w* pereciste tú, \w poblada|strong="H3427"\w* \w por|strong="H5921"\w* gente \w de|strong="H5921"\w* \w mar|strong="H3220"\w*,  
\q2 \w ciudad|strong="H5892"\w* \w que|strong="H1931"\w* \w eras|strong="H1961"\w* alabada!  
\q1 \w Que|strong="H1931"\w* \w eras|strong="H1961"\w* \w fuerte|strong="H2389"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w mar|strong="H3220"\w*,  
\q2 tú \w y|strong="H5921"\w* tus \w habitantes|strong="H3427"\w*,  
\q1 \w que|strong="H1931"\w* infundíais terror  
\q2 \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H1931"\w* \w en|strong="H5921"\w* \w ti|strong="H5921"\w* \w moraban|strong="H3427"\w*.   
\q1
\v 18 \w Ahora|strong="H6258"\w* se estremecerán las islas \w en|strong="H3318"\w* el \w día|strong="H3117"\w* de tu caída;  
\q2 sí, las islas \w que|strong="H6258"\w* están \w en|strong="H3318"\w* el \w mar|strong="H3220"\w* se espantarán de tu fin’.   
\p
\v 19 «\w Porque|strong="H3588"\w* \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: \w Yo|strong="H3588"\w* \w te|strong="H5921"\w* convertiré \w en|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w asolada|strong="H2717"\w*, \w como|strong="H3588"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* \w habitan|strong="H3427"\w*; \w haré|strong="H5414"\w* \w subir|strong="H5927"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w el|strong="H5921"\w* \w abismo|strong="H8415"\w*, \w y|strong="H3588"\w* \w te|strong="H5921"\w* \w cubrirán|strong="H3680"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*.  
\v 20 \w Y|strong="H3068"\w* te \w haré|strong="H5414"\w* descender con \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w descienden|strong="H3381"\w* al sepulcro, con \w los|strong="H3427"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* otros tiempos, y te \w pondré|strong="H5414"\w* en las partes \w más|strong="H3808"\w* bajas \w de|strong="H5971"\w* la tierra, como en \w los|strong="H3427"\w* lugares desolados \w de|strong="H5971"\w* la antigüedad, con \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w descienden|strong="H3381"\w* al sepulcro, \w para|strong="H4616"\w* \w que|strong="H3808"\w* \w nunca|strong="H3808"\w* \w más|strong="H3808"\w* seas \w habitada|strong="H3427"\w*; y \w daré|strong="H5414"\w* \w gloria|strong="H6643"\w* \w a|strong="H3068"\w* la tierra \w de|strong="H5971"\w* \w los|strong="H3427"\w* \w vivientes|strong="H2416"\w*.  
\v 21 Te convertiré \w en|strong="H5750"\w* \w espanto|strong="H1091"\w*, \w y|strong="H1091"\w* dejarás \w de|strong="H5750"\w* ser; serás buscada, \w y|strong="H1091"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* serás hallada, \w dice|strong="H5002"\w* el Señor Yahvé».   
\c 27
\p
\v 1 La \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé volvió \w a|strong="H3068"\w* dirigirse \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, diciendo:  
\v 2 “Tú, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w levanta|strong="H5375"\w* una \w endecha|strong="H7015"\w* \w sobre|strong="H5921"\w* \w Tiro|strong="H6865"\w*;  
\v 3 \w y|strong="H5921"\w* dile \w a|strong="H3068"\w* \w Tiro|strong="H6865"\w*: ‘Tú \w que|strong="H5921"\w* \w habitas|strong="H3427"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* entradas \w del|strong="H5921"\w* \w mar|strong="H3220"\w*, \w que|strong="H5921"\w* eres \w la|strong="H5921"\w* \w mercadera|strong="H7402"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w pueblos|strong="H5971"\w* \w para|strong="H5921"\w* \w muchas|strong="H7227"\w* costas, \w así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé:  
\q1 “Tú, \w Tiro|strong="H6865"\w*, has dicho:  
\q2 ‘Soy \w de|strong="H5921"\w* perfecta \w hermosura|strong="H3308"\w*’.   
\q1
\v 4 Tus fronteras están en el \w corazón|strong="H3820"\w* de los \w mares|strong="H3220"\w*.  
\q2 Tus constructores han perfeccionado tu belleza.   
\q1
\v 5 Han \w hecho|strong="H6213"\w* \w todas|strong="H3605"\w* tus \w tablas|strong="H3871"\w* \w de|strong="H5921"\w* ciprés \w de|strong="H5921"\w* \w Senir|strong="H8149"\w*.  
\q2 Han \w tomado|strong="H3947"\w* un cedro \w del|strong="H5921"\w* \w Líbano|strong="H3844"\w* \w para|strong="H5921"\w* hacerte un mástil.   
\q1
\v 6 Han \w hecho|strong="H6213"\w* tus remos con encinas de \w Basán|strong="H1316"\w*.  
\q2 Han \w hecho|strong="H6213"\w* tus bancos de \w marfil|strong="H8127"\w* incrustado en madera de ciprés de las costas de Quitim.   
\q1
\v 7 Tu vela \w era|strong="H1961"\w* de lino fino bordado de \w Egipto|strong="H4714"\w*,  
\q2 \w para|strong="H1961"\w* \w que|strong="H1961"\w* te sirviese de estandarte.  
\q2 De azul y púrpura de las costas de Elisa \w era|strong="H1961"\w* tu toldo.   
\q1
\v 8 \w Los|strong="H1992"\w* \w habitantes|strong="H3427"\w* de \w Sidón|strong="H6721"\w* y de Arvad \w eran|strong="H1961"\w* tus remeros.  
\q2 Tus \w sabios|strong="H2450"\w*, oh \w Tiro|strong="H6865"\w*, \w estaban|strong="H1961"\w* en ti;  
\q2 \w ellos|strong="H1992"\w* \w eran|strong="H1961"\w* tus pilotos.   
\q1
\v 9 \w Los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de Gebal  
\q2 y sus \w sabios|strong="H2450"\w* \w eran|strong="H1961"\w* tus calafateadores en ti.  
\q1 \w Todas|strong="H3605"\w* las naves del \w mar|strong="H3220"\w* con sus marineros \w estaban|strong="H1961"\w* en ti  
\q2 \w para|strong="H1961"\w* negociar con tus mercaderías.   
\b  
\q1
\v 10 “‘\w Persia|strong="H6539"\w*, \w Lud|strong="H3865"\w* y Fut \w estaban|strong="H1961"\w* en tu \w ejército|strong="H2428"\w*;  
\q2 \w eran|strong="H1961"\w* tus hombres \w de|strong="H5414"\w* \w guerra|strong="H4421"\w*.  
\q1 \w Colgaron|strong="H8518"\w* \w el|strong="H1992"\w* \w escudo|strong="H4043"\w* y \w el|strong="H1992"\w* yelmo en ti.  
\q2 \w Ellos|strong="H1992"\w* mostraron tu esplendor.   
\q1
\v 11 \w Los|strong="H1992"\w* \w hombres|strong="H1121"\w* \w de|strong="H5921"\w* Arvad \w con|strong="H5921"\w* \w su|strong="H1992"\w* \w ejército|strong="H2428"\w* \w estaban|strong="H1961"\w* \w sobre|strong="H5921"\w* tus \w muros|strong="H2346"\w* \w por|strong="H5921"\w* \w todas|strong="H5439"\w* \w partes|strong="H5439"\w*,  
\q2 \w y|strong="H5921"\w* \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w* \w estaban|strong="H1961"\w* \w en|strong="H5921"\w* tus \w torres|strong="H4026"\w*.  
\q1 \w Colgaron|strong="H8518"\w* \w sus|strong="H1992"\w* \w escudos|strong="H7982"\w* \w en|strong="H5921"\w* tus \w muros|strong="H2346"\w* \w por|strong="H5921"\w* \w todas|strong="H5439"\w* \w partes|strong="H5439"\w*.  
\q2 \w Ellos|strong="H1992"\w* perfeccionaron tu \w hermosura|strong="H3308"\w*.   
\p
\v 12 “‘\w Tarsis|strong="H8659"\w* comerciaba contigo \w por|strong="H5414"\w* \w la|strong="H3605"\w* \w abundancia|strong="H7230"\w* \w de|strong="H5414"\w* \w toda|strong="H3605"\w* clase \w de|strong="H5414"\w* \w riquezas|strong="H1952"\w*. Con \w plata|strong="H3701"\w*, \w hierro|strong="H1270"\w*, estaño y plomo pagaban tus mercaderías.   
\p
\v 13 “‘\w Javán|strong="H3120"\w*, \w Tubal|strong="H8422"\w* y \w Mesec|strong="H4902"\w* eran tus mercaderes. \w Ellos|strong="H1992"\w* intercambiaban esclavos y vasijas \w de|strong="H5414"\w* bronce \w por|strong="H5414"\w* tus mercancías.   
\p
\v 14 “‘Los \w de|strong="H5414"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Togarmá pagaban tus mercaderías con \w caballos|strong="H5483"\w*, corceles \w de|strong="H5414"\w* guerra y mulos.   
\p
\v 15 “‘\w Los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* \w Dedán|strong="H1719"\w* comerciaban contigo. \w Muchas|strong="H7227"\w* costas eran \w el|strong="H1121"\w* mercado \w de|strong="H1121"\w* tu \w mano|strong="H3027"\w*; te traían en pago colmillos \w de|strong="H1121"\w* \w marfil|strong="H8127"\w* y ébano.   
\p
\v 16 “‘Aram comerciaba contigo \w por|strong="H5414"\w* la \w multitud|strong="H7230"\w* \w de|strong="H5414"\w* tus \w obras|strong="H4639"\w*. Pagaban tus mercaderías con esmeraldas, púrpura, \w bordados|strong="H7553"\w*, lino fino, corales y rubíes.   
\p
\v 17 “‘\w Judá|strong="H3063"\w* y la tierra \w de|strong="H5414"\w* \w Israel|strong="H3478"\w* comerciaban contigo. Pagaban tus mercaderías con \w trigo|strong="H2406"\w* \w de|strong="H5414"\w* Minit, dulces, \w miel|strong="H1706"\w*, \w aceite|strong="H8081"\w* y \w bálsamo|strong="H6875"\w*.   
\p
\v 18 “‘\w Damasco|strong="H1834"\w* comerciaba contigo por \w la|strong="H3605"\w* \w multitud|strong="H7230"\w* de tus \w obras|strong="H4639"\w*, por \w la|strong="H3605"\w* \w abundancia|strong="H7230"\w* de \w toda|strong="H3605"\w* clase de \w riquezas|strong="H1952"\w*, con \w vino|strong="H3196"\w* de Helbón y \w lana|strong="H6785"\w* \w blanca|strong="H6713"\w*.   
\p
\v 19 “‘Vedán y \w Javán|strong="H3120"\w* pagaban tus mercaderías con hilo; \w hierro|strong="H1270"\w* forjado, casia y cálamo \w había|strong="H1961"\w* entre tus intercambios.   
\p
\v 20 “‘\w Dedán|strong="H1719"\w* comerciaba contigo en preciosas mantas para cabalgar.   
\p
\v 21 “‘\w Arabia|strong="H6152"\w* y \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w príncipes|strong="H5387"\w* de \w Cedar|strong="H6938"\w* traficaban contigo; en \w corderos|strong="H3733"\w*, carneros y machos cabríos, en \w estas|strong="H1992"\w* \w cosas|strong="H1992"\w* eran tus \w mercaderes|strong="H5503"\w*.   
\p
\v 22 “‘\w Los|strong="H1992"\w* mercaderes \w de|strong="H5414"\w* Sabá y Raamá comerciaban contigo. Pagaban tus mercaderías con \w lo|strong="H1992"\w* mejor \w de|strong="H5414"\w* \w todas|strong="H3605"\w* \w las|strong="H1992"\w* \w especias|strong="H1314"\w*, con \w toda|strong="H3605"\w* clase \w de|strong="H5414"\w* piedras \w preciosas|strong="H3368"\w* y \w oro|strong="H2091"\w*.   
\p
\v 23 “‘\w Harán|strong="H2771"\w*, Cané, Edén, y los mercaderes de Sabá, Asiria y Quilmad, comerciaban contigo.  
\v 24 \w Estos|strong="H1992"\w* comerciaban contigo en ricas \w vestiduras|strong="H1992"\w*, en mantos de azul y \w bordados|strong="H7553"\w*, y en cofres de ropas preciosas, atados con cuerdas y hechos de cedro, entre tus mercaderías.   
\q1
\v 25 “‘Las naves de \w Tarsis|strong="H8659"\w* eran tus caravanas para tus mercaderías.  
\q2 \w Te|strong="H3220"\w* llenaste  
\q2 y \w te|strong="H3220"\w* hiciste \w muy|strong="H3966"\w* gloriosa en el \w corazón|strong="H3820"\w* de los \w mares|strong="H3220"\w*.   
\q1
\v 26 Tus remeros \w te|strong="H3220"\w* han llevado \w a|strong="H3068"\w* \w aguas|strong="H4325"\w* profundas.  
\q2 El \w viento|strong="H7307"\w* \w solano|strong="H6921"\w* \w te|strong="H3220"\w* ha \w quebrantado|strong="H7665"\w* en el \w corazón|strong="H3820"\w* \w de|strong="H4325"\w* los \w mares|strong="H3220"\w*.   
\q1
\v 27 Tus \w riquezas|strong="H1952"\w*, tus mercancías, tu comercio,  
\q2 tus marineros, tus pilotos, tus calafateadores,  
\q1 \w los|strong="H3605"\w* mercaderes de tu tráfico,  
\q2 y \w todos|strong="H3605"\w* tus hombres de \w guerra|strong="H4421"\w* \w que|strong="H3117"\w* hay \w en|strong="H8432"\w* ti,  
\q1 con \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w compañía|strong="H6951"\w* \w que|strong="H3117"\w* hay \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ti,  
\q2 \w caerán|strong="H5307"\w* \w en|strong="H8432"\w* \w el|strong="H3605"\w* \w corazón|strong="H3820"\w* de \w los|strong="H3605"\w* \w mares|strong="H3220"\w* \w en|strong="H8432"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* de tu ruina.   
\q1
\v 28 Al \w sonido|strong="H6963"\w* del \w clamor|strong="H2201"\w* de tus pilotos,  
\q2 \w temblarán|strong="H7493"\w* las costas.   
\q1
\v 29 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* manejan \w el|strong="H3605"\w* \w remo|strong="H4880"\w*,  
\q2 \w los|strong="H3605"\w* marineros y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* pilotos del \w mar|strong="H3220"\w*,  
\q2 \w descenderán|strong="H3381"\w* de sus naves.  
\q1 Se pondrán \w en|strong="H5975"\w* tierra firme,   
\q2
\v 30 \w y|strong="H5921"\w* harán \w oír|strong="H8085"\w* su \w voz|strong="H6963"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* llorarán \w amargamente|strong="H4751"\w*.  
\q1 Echarán \w polvo|strong="H6083"\w* \w sobre|strong="H5921"\w* sus \w cabezas|strong="H7218"\w*  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* revolcarán \w en|strong="H5921"\w* \w la|strong="H5921"\w* ceniza.   
\q1
\v 31 Se raparán por ti,  
\q2 y se ceñirán de cilicio.  
\q1 \w Llorarán|strong="H1058"\w* por ti con \w amargura|strong="H4751"\w* de \w alma|strong="H5315"\w*,  
\q2 con \w amargo|strong="H4751"\w* luto.   
\q1
\v 32 \w En|strong="H5921"\w* sus lamentos levantarán \w por|strong="H5921"\w* \w ti|strong="H5921"\w* una \w endecha|strong="H7015"\w*,  
\q2 \w y|strong="H5921"\w* \w se|strong="H5921"\w* lamentarán \w por|strong="H5921"\w* \w ti|strong="H5921"\w*, diciendo:  
\q1 «¿\w Quién|strong="H4310"\w* \w hay|strong="H4310"\w* \w como|strong="H5921"\w* \w Tiro|strong="H6865"\w*,  
\q2 \w como|strong="H5921"\w* \w la|strong="H5921"\w* \w que|strong="H4310"\w* ha sido reducida \w al|strong="H5921"\w* silencio \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w*?».   
\q1
\v 33 Cuando tus mercaderías \w salían|strong="H3318"\w* \w de|strong="H5971"\w* los \w mares|strong="H3220"\w*,  
\q2 saciabas \w a|strong="H3068"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*.  
\q1 \w Enriqueciste|strong="H6238"\w* \w a|strong="H3068"\w* los \w reyes|strong="H4428"\w* \w de|strong="H5971"\w* \w la|strong="H7646"\w* tierra  
\q2 con \w la|strong="H7646"\w* \w multitud|strong="H7230"\w* \w de|strong="H5971"\w* tus \w riquezas|strong="H1952"\w* y \w de|strong="H5971"\w* tu comercio.   
\q1
\v 34 Ahora \w que|strong="H4325"\w* has sido \w quebrantada|strong="H7665"\w* por \w los|strong="H3605"\w* \w mares|strong="H3220"\w*,  
\q2 \w en|strong="H8432"\w* las profundidades \w de|strong="H4325"\w* las \w aguas|strong="H4325"\w*,  
\q2 tus mercaderías y \w toda|strong="H3605"\w* tu tripulación han \w caído|strong="H5307"\w* contigo.   
\q1
\v 35 \w Todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* costas \w están|strong="H3427"\w* pasmados \w por|strong="H5921"\w* \w ti|strong="H5921"\w*,  
\q2 \w y|strong="H5921"\w* sus \w reyes|strong="H4428"\w* \w están|strong="H3427"\w* aterrorizados;  
\q2 tienen \w el|strong="H5921"\w* \w rostro|strong="H6440"\w* demudado.   
\q1
\v 36 \w Los|strong="H5921"\w* \w mercaderes|strong="H5503"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* silban \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*.  
\q2 Has llegado \w a|strong="H3068"\w* un final terrible,  
\q2 \w y|strong="H5921"\w* dejarás \w de|strong="H5921"\w* ser \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*’”.   
\c 28
\p
\v 1 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*, \w di|strong="H5414"\w* al \w príncipe|strong="H5057"\w* \w de|strong="H1121"\w* \w Tiro|strong="H6865"\w*: ‘\w Así|strong="H3541"\w* dice \w el|strong="H1121"\w* Señor Yahvé:  
\q1 “\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w se|strong="H3808"\w* enalteció tu \w corazón|strong="H3820"\w*,  
\q2 \w y|strong="H3541"\w* dijiste: ‘Yo soy un \w dios|strong="H3069"\w*,  
\q1 en \w el|strong="H1121"\w* trono \w de|strong="H1121"\w* \w Dios|strong="H3069"\w* estoy \w sentado|strong="H3427"\w*,  
\q2 en medio \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w mares|strong="H3220"\w*’;  
\q1 siendo tú un \w hombre|strong="H1121"\w* \w y|strong="H3541"\w* \w no|strong="H3808"\w* \w Dios|strong="H3069"\w*,  
\q2 \w aunque|strong="H3808"\w* \w has|strong="H5414"\w* hecho pasar tu \w corazón|strong="H3820"\w* \w por|strong="H3282"\w* \w el|strong="H1121"\w* \w corazón|strong="H3820"\w* \w de|strong="H1121"\w* un \w dios|strong="H3069"\w*.   
\q1
\v 3 He \w aquí|strong="H2009"\w* \w que|strong="H3808"\w* tú eres \w más|strong="H3808"\w* \w sabio|strong="H2450"\w* \w que|strong="H3808"\w* \w Daniel|strong="H1840"\w*;  
\q2 \w no|strong="H3808"\w* hay secreto \w que|strong="H3808"\w* te sea oculto.   
\q1
\v 4 Con \w tu|strong="H6213"\w* \w sabiduría|strong="H2451"\w* y con \w tu|strong="H6213"\w* prudencia has acumulado \w riquezas|strong="H2428"\w*,  
\q2 y has atesorado \w oro|strong="H2091"\w* y \w plata|strong="H3701"\w* en tus arcas.   
\q1
\v 5 Con \w la|strong="H2451"\w* grandeza de tu \w sabiduría|strong="H2451"\w*  
\q2 y con tu comercio has multiplicado tus \w riquezas|strong="H2428"\w*,  
\q2 y \w a|strong="H3068"\w* causa de tus \w riquezas|strong="H2428"\w* se ha enaltecido tu \w corazón|strong="H3824"\w*”.   
\p
\v 6 “‘\w Por|strong="H3282"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* dice el Señor Yahvé:  
\q1 “\w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w has|strong="H5414"\w* hecho pasar tu \w corazón|strong="H3820"\w* \w por|strong="H3282"\w* el \w corazón|strong="H3820"\w* \w de|strong="H5414"\w* \w Dios|strong="H3069"\w*,   
\q2
\v 7 \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, he \w aquí|strong="H2005"\w* yo traigo \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* extranjeros,  
\q2 \w los|strong="H5921"\w* \w más|strong="H5921"\w* temibles \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.  
\q1 Desenvainarán sus \w espadas|strong="H2719"\w* \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w hermosura|strong="H3308"\w* \w de|strong="H5921"\w* tu \w sabiduría|strong="H2451"\w*,  
\q2 \w y|strong="H5921"\w* mancharán tu esplendor.   
\q1
\v 8 Al \w sepulcro|strong="H7845"\w* \w te|strong="H3220"\w* harán descender,  
\q2 y \w morirás|strong="H4191"\w* con la \w muerte|strong="H4191"\w* de los que caen traspasados  
\q2 en el \w corazón|strong="H3820"\w* de los \w mares|strong="H3220"\w*.   
\q1
\v 9 ¿Acaso dirás \w delante|strong="H6440"\w* \w de|strong="H6440"\w* quien te \w mate|strong="H2026"\w*: ‘Yo soy Dios’?  
\q2 Tú eres un hombre, y \w no|strong="H3808"\w* Dios,  
\q2 en \w manos|strong="H3027"\w* \w de|strong="H6440"\w* quienes te traspasen.   
\q1
\v 10 \w De|strong="H3588"\w* \w muerte|strong="H4194"\w* \w de|strong="H3588"\w* \w incircuncisos|strong="H6189"\w* \w morirás|strong="H4191"\w*,  
\q2 \w por|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* extranjeros;  
\q2 \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* he \w hablado|strong="H1696"\w*, \w dice|strong="H5002"\w* \w el|strong="H3588"\w* Señor Yahvé’”.   
\b  
\p
\v 11 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* además \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 12 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w levanta|strong="H5375"\w* una \w endecha|strong="H7015"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Tiro|strong="H6865"\w*, \w y|strong="H5921"\w* dile: ‘\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé:  
\q1 «Tú eras \w el|strong="H5921"\w* sello \w de|strong="H5921"\w* \w la|strong="H5921"\w* perfección,  
\q2 \w lleno|strong="H4392"\w* \w de|strong="H5921"\w* \w sabiduría|strong="H2451"\w*,  
\q2 \w y|strong="H5921"\w* \w de|strong="H5921"\w* perfecta \w hermosura|strong="H3308"\w*.   
\q1
\v 13 En Edén,  
\q2 en \w el|strong="H3605"\w* \w huerto|strong="H1588"\w* de Dios \w estuviste|strong="H1961"\w*;  
\q1 \w toda|strong="H3605"\w* piedra \w preciosa|strong="H3368"\w* \w era|strong="H1961"\w* tu vestidura:  
\q2 rubí, \w topacio|strong="H6357"\w*, esmeralda,  
\q2 \w crisólito|strong="H8658"\w*, ónice, jaspe,  
\q2 zafiro,\f + \fr 28:13 \ft o, lapislázuli \f* turquesa y berilo.  
\q1 \w Los|strong="H3605"\w* primores de tus panderos  
\q2 y de tus flautas \w estuvieron|strong="H1961"\w* en ti;  
\q2 \w fueron|strong="H1961"\w* preparados en \w el|strong="H3605"\w* \w día|strong="H3117"\w* en \w que|strong="H3117"\w* \w fuiste|strong="H1961"\w* creado.   
\q1
\v 14 Tú \w eras|strong="H1961"\w* un \w querubín|strong="H3742"\w* \w grande|strong="H4473"\w*, protector.  
\q2 Yo te \w puse|strong="H5414"\w* \w en|strong="H8432"\w* el \w santo|strong="H6944"\w* \w monte|strong="H2022"\w* \w de|strong="H5414"\w* Dios;  
\q2 allí \w estuviste|strong="H1961"\w* y \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5414"\w* las piedras \w de|strong="H5414"\w* fuego te paseabas.   
\q1
\v 15 \w Perfecto|strong="H8549"\w* eras \w en|strong="H5704"\w* todos tus \w caminos|strong="H1870"\w* \w desde|strong="H5704"\w* el \w día|strong="H3117"\w* \w que|strong="H5704"\w* fuiste creado,  
\q2 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* se \w halló|strong="H4672"\w* \w en|strong="H5704"\w* ti \w iniquidad|strong="H5766"\w*.   
\q1
\v 16 \w A|strong="H3068"\w* causa de la \w multitud|strong="H7230"\w* de tu comercio, te llenaste de \w violencia|strong="H2555"\w*,  
\q2 y pecaste.  
\q1 Por lo cual yo te eché como profano del \w monte|strong="H2022"\w* de Dios;  
\q2 y te destruí, oh \w querubín|strong="H3742"\w* protector,  
\q2 de \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de las piedras de fuego.   
\q1
\v 17 \w Se|strong="H5921"\w* enalteció tu \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* tu \w hermosura|strong="H3308"\w*;  
\q2 \w corrompiste|strong="H7843"\w* tu \w sabiduría|strong="H2451"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* tu esplendor.  
\q1 Yo \w te|strong="H5921"\w* he arrojado \w por|strong="H5921"\w* tierra;  
\q2 \w te|strong="H5921"\w* he \w puesto|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w*,  
\q2 \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* fijen \w en|strong="H5921"\w* \w ti|strong="H5921"\w*.   
\q1
\v 18 \w Por|strong="H5921"\w* \w la|strong="H1931"\w* \w multitud|strong="H7230"\w* \w de|strong="H5921"\w* tus \w iniquidades|strong="H5771"\w*,  
\q2 \w por|strong="H5921"\w* \w la|strong="H1931"\w* injusticia \w de|strong="H5921"\w* tu comercio,  
\q2 profanaste tus santuarios.  
\q1 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, yo \w saqué|strong="H3318"\w* fuego \w de|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*,  
\q2 \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w te|strong="H5869"\w* consumió;  
\q1 \w y|strong="H5921"\w* \w te|strong="H5869"\w* reduje \w a|strong="H3068"\w* cenizas \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* tierra  
\q2 \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H1931"\w* \w te|strong="H5869"\w* \w miran|strong="H7200"\w*.   
\q1
\v 19 \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* \w conocieron|strong="H3045"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w se|strong="H3045"\w* maravillarán \w de|strong="H5921"\w* \w ti|strong="H5921"\w*;  
\q2 \w espanto|strong="H1091"\w* \w serás|strong="H1961"\w*,  
\q2 \w y|strong="H5921"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w* dejarás \w de|strong="H5921"\w* ser»’”.   
\b  
\p
\v 20 \w Vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 21 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w pon|strong="H7760"\w* tu \w rostro|strong="H6440"\w* \w hacia|strong="H5921"\w* \w Sidón|strong="H6721"\w*, \w y|strong="H5921"\w* \w profetiza|strong="H5012"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*,  
\v 22 \w y|strong="H3588"\w* di: ‘\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* Yahvé:  
\q1 “He \w aquí|strong="H3541"\w* \w yo|strong="H3588"\w* estoy \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, oh \w Sidón|strong="H6721"\w*;  
\q2 \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* seré glorificado.  
\q1 \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé,  
\q2 \w cuando|strong="H3588"\w* ejecute \w en|strong="H5921"\w* \w ella|strong="H5921"\w* mis \w juicios|strong="H8201"\w*,  
\q2 \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w me|strong="H5921"\w* santifique.   
\q1
\v 23 \w Porque|strong="H3588"\w* \w enviaré|strong="H7971"\w* \w a|strong="H3068"\w* \w ella|strong="H5921"\w* peste,  
\q2 \w y|strong="H3588"\w* \w sangre|strong="H1818"\w* \w a|strong="H3068"\w* sus \w calles|strong="H2351"\w*;  
\q1 \w y|strong="H3588"\w* \w caerán|strong="H5307"\w* \w muertos|strong="H2491"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*,  
\q2 \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* \w por|strong="H5921"\w* todos \w lados|strong="H5439"\w*.  
\q2 \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé.   
\p
\v 24 “‘\w Y|strong="H3068"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w será|strong="H1961"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* zarza punzante, \w ni|strong="H3808"\w* espina dolorosa \w de|strong="H3588"\w* parte \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w rodean|strong="H5439"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* desprecian. \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* \w el|strong="H3588"\w* Señor Yahvé’.   
\p
\v 25 “\w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* Señor Yahvé: ‘\w Cuando|strong="H5650"\w* \w yo|strong="H4480"\w* recoja \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w de|strong="H4480"\w* \w entre|strong="H5921"\w* \w los|strong="H3427"\w* \w pueblos|strong="H5971"\w* \w en|strong="H5921"\w* \w los|strong="H3427"\w* cuales \w está|strong="H3427"\w* esparcida, \w y|strong="H5921"\w* \w me|strong="H4480"\w* santifique \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* ante \w los|strong="H3427"\w* \w ojos|strong="H5869"\w* \w de|strong="H4480"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, entonces \w habitarán|strong="H3427"\w* \w en|strong="H5921"\w* su propia tierra, \w la|strong="H5921"\w* cual \w di|strong="H5414"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w siervo|strong="H5650"\w* \w Jacob|strong="H3290"\w*.  
\v 26 \w Y|strong="H3068"\w* \w habitarán|strong="H3427"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* seguros; \w sí|strong="H3588"\w*, \w edificarán|strong="H1129"\w* \w casas|strong="H1004"\w*, \w plantarán|strong="H5193"\w* \w viñas|strong="H3754"\w* \w y|strong="H3588"\w* vivirán confiados, \w cuando|strong="H3588"\w* \w yo|strong="H3588"\w* haya ejecutado \w juicios|strong="H8201"\w* \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w los|strong="H3427"\w* \w rodean|strong="H5439"\w* \w y|strong="H3588"\w* \w los|strong="H3427"\w* desprecian. \w Y|strong="H3068"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy Yahvé \w su|strong="H3588"\w* \w Dios|strong="H3068"\w*’”.   
\c 29
\p
\v 1 En el \w año|strong="H8141"\w* \w décimo|strong="H6224"\w*, en el \w mes|strong="H2320"\w* \w décimo|strong="H6224"\w*, \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w doce|strong="H8147"\w* días del \w mes|strong="H2320"\w*, \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 2 “\w Hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w hombre|strong="H1121"\w*, \w pon|strong="H7760"\w* tu \w rostro|strong="H6440"\w* \w contra|strong="H5921"\w* \w Faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H5921"\w* \w profetiza|strong="H5012"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w todo|strong="H3605"\w* \w Egipto|strong="H4714"\w*.  
\v 3 \w Habla|strong="H1696"\w* \w y|strong="H5921"\w* \w di|strong="H1696"\w*: ‘\w Así|strong="H3541"\w* \w dice|strong="H1696"\w* \w el|strong="H5921"\w* Señor Yahvé:  
\q1 “He \w aquí|strong="H3541"\w* \w que|strong="H5921"\w* \w yo|strong="H6213"\w* estoy \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w Faraón|strong="H6547"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*,  
\q2 \w el|strong="H5921"\w* \w gran|strong="H1419"\w* \w dragón|strong="H8577"\w* \w que|strong="H5921"\w* yace \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* sus \w ríos|strong="H2975"\w*,  
\q1 \w el|strong="H5921"\w* cual \w dijo|strong="H1696"\w*: ‘\w Mío|strong="H5921"\w* \w es|strong="H3541"\w* \w mi|strong="H5921"\w* \w río|strong="H2975"\w*,  
\q2 \w y|strong="H5921"\w* \w yo|strong="H6213"\w* \w me|strong="H5921"\w* \w lo|strong="H5921"\w* \w hice|strong="H6213"\w*’.   
\q1
