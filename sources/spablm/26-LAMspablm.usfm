\v 32 \w antes|strong="H3588"\w* \w bien|strong="H3588"\w*, \w aunque|strong="H3588"\w* causa dolor,  
\q2 tiene compasión según \w la|strong="H3588"\w* \w multitud|strong="H7230"\w* \w de|strong="H3588"\w* sus \w misericordias|strong="H2617"\w*.   
\q1
\v 33 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* \w aflige|strong="H6031"\w* \w por|strong="H3588"\w* gusto,  
\q2 \w ni|strong="H3808"\w* entristece \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*.   
\b  
\q1
\v 34 Aplastar \w bajo|strong="H8478"\w* \w los|strong="H3605"\w* \w pies|strong="H7272"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* prisioneros \w de|strong="H8478"\w* \w la|strong="H3605"\w* tierra,   
\q2
\v 35 conculcar el \w derecho|strong="H4941"\w* del \w hombre|strong="H1397"\w* \w ante|strong="H6440"\w* la \w presencia|strong="H6440"\w* del \w Altísimo|strong="H5945"\w*,   
\q2
\v 36 \w o|strong="H3068"\w* torcer la \w causa|strong="H7379"\w* de un hombre, el Señor \w no|strong="H3808"\w* \w lo|strong="H3808"\w* aprueba.   
\b  
\q1
\v 37 ¿\w Quién|strong="H4310"\w* puede decir \w que|strong="H4310"\w* algo sucede  
\q2 \w sin|strong="H3808"\w* \w que|strong="H4310"\w* \w el|strong="H4310"\w* Señor \w lo|strong="H3808"\w* \w mande|strong="H6680"\w*?   
\q1
\v 38 ¿\w No|strong="H3808"\w* \w salen|strong="H3318"\w* \w de|strong="H7451"\w* la \w boca|strong="H6310"\w* del \w Altísimo|strong="H5945"\w*  
\q2 tanto los \w males|strong="H7451"\w* como los bienes?   
\q1
\v 39 ¿\w De|strong="H5921"\w* \w qué|strong="H4100"\w* \w se|strong="H5921"\w* queja \w el|strong="H5921"\w* \w hombre|strong="H1397"\w* \w viviente|strong="H2416"\w*?  
\q2 Quéjese cada uno \w de|strong="H5921"\w* sus propios \w pecados|strong="H2399"\w*.   
\b  
\q1
\v 40 \w Escudriñemos|strong="H2664"\w* nuestros \w caminos|strong="H1870"\w* \w y|strong="H5704"\w* busquemos,  
\q2 \w y|strong="H5704"\w* \w volvamos|strong="H7725"\w* \w a|strong="H3068"\w* Yahvé.   
\q1
\v 41 Elevemos nuestro \w corazón|strong="H3824"\w* y nuestras \w manos|strong="H3709"\w* al Dios\f + \fr 3:41 \ft La palabra hebrea traducida como «Dios» es «אֱלֹהִ֑ים» (Elohim).\f* que está en los \w cielos|strong="H8064"\w*.   
\q2
\v 42 “\w Nosotros|strong="H5168"\w* hemos pecado y nos hemos rebelado;  
\q2 tú \w no|strong="H3808"\w* has perdonado.   
\b  
\q1
\v 43 “Nos cubriste con tu ira y nos \w perseguiste|strong="H7291"\w*;  
\q2 \w mataste|strong="H2026"\w* y \w no|strong="H3808"\w* tuviste piedad.   
\q1
\v 44 Te cubriste con una \w nube|strong="H6051"\w*  
\q2 para que no \w pasase|strong="H5674"\w* la \w oración|strong="H8605"\w* nuestra.   
\q1
\v 45 Nos has puesto como basura y desecho  
\q2 en \w medio|strong="H7130"\w* \w de|strong="H5971"\w* los \w pueblos|strong="H5971"\w*.   
\b  
\q1
\v 46 «\w Todos|strong="H3605"\w* nuestros enemigos \w abrieron|strong="H6475"\w* su \w boca|strong="H6310"\w* \w contra|strong="H5921"\w* \w nosotros|strong="H3605"\w*.   
\q2
\v 47 \w Temor|strong="H6343"\w* y fosa nos han sobrevenido,  
\q2 \w asolamiento|strong="H7612"\w* y destrucción».   
\b  
\q1
\v 48 \w Ríos|strong="H6388"\w* \w de|strong="H5921"\w* \w agua|strong="H4325"\w* derraman mis \w ojos|strong="H5869"\w*  
\q2 \w por|strong="H5921"\w* \w la|strong="H5921"\w* ruina \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*.   
\q1
\v 49 Mis \w ojos|strong="H5869"\w* fluyen lágrimas  
\q2 y \w no|strong="H3808"\w* cesan, \w ni|strong="H3808"\w* tienen descanso,   
\q1
\v 50 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* Yahvé \w mire|strong="H7200"\w*  
\q2 \w y|strong="H5704"\w* \w vea|strong="H7200"\w* \w desde|strong="H5704"\w* los \w cielos|strong="H8064"\w*.   
\q1
\v 51 Mis \w ojos|strong="H5869"\w* me causan dolor  
\q2 por \w todas|strong="H3605"\w* las \w hijas|strong="H1323"\w* \w de|strong="H5869"\w* \w mi|strong="H5315"\w* \w ciudad|strong="H5892"\w*.   
\b  
\q1
\v 52 Mis enemigos me dieron \w caza|strong="H6679"\w* como \w a|strong="H3068"\w* un \w pájaro|strong="H6833"\w*,  
\q2 sin haber motivo.   
\q1
\v 53 Cortaron mi \w vida|strong="H2416"\w* en la mazmorra  
\q2 y arrojaron piedras sobre mí.   
\q1
\v 54 \w Las|strong="H5921"\w* \w aguas|strong="H4325"\w* cubrieron \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*;  
\q2 \w y|strong="H5921"\w* dije: «¡Estoy perdido!».   
\b  
\q1
\v 55 \w Invoqué|strong="H7121"\w* tu \w nombre|strong="H8034"\w*, Yahvé,  
\q2 desde lo \w profundo|strong="H8482"\w* de la mazmorra.   
\q1
\v 56 \w Oíste|strong="H8085"\w* mi \w voz|strong="H6963"\w*;  
\q2 no cierres tu \w oído|strong="H8085"\w* \w a|strong="H3068"\w* mi \w clamor|strong="H7775"\w* por alivio.   
\b  
\q1
\v 57 Te acercaste el \w día|strong="H3117"\w* \w que|strong="H3117"\w* te \w invoqué|strong="H7121"\w*;  
\q2 dijiste: «No \w temas|strong="H3372"\w*».   
\b  
\q1
\v 58 Señor, tú has defendido la \w causa|strong="H7379"\w* de \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*;  
\q2 has redimido \w mi|strong="H5315"\w* \w vida|strong="H5315"\w*.   
\q1
\v 59 Yahvé, \w tú|strong="H8199"\w* has \w visto|strong="H7200"\w* mi agravio;  
\q2 ¡\w juzga|strong="H8199"\w* mi causa!   
\q1
\v 60 Has \w visto|strong="H7200"\w* \w toda|strong="H3605"\w* su \w venganza|strong="H5360"\w*,  
\q2 y \w todos|strong="H3605"\w* sus planes contra mí.   
\b  
\q1
\v 61 Has \w oído|strong="H8085"\w* su \w oprobio|strong="H2781"\w*, Yahvé,  
\q2 \w y|strong="H5921"\w* \w todas|strong="H3605"\w* sus maquinaciones \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*;   
