\q2 \w obra|strong="H4639"\w* \w de|strong="H1121"\w* \w manos|strong="H3027"\w* \w de|strong="H1121"\w* alfarero!   
\b  
\q1
\v 3 Incluso \w los|strong="H3588"\w* chacales ofrecen sus mamas  
\q2 \w para|strong="H3588"\w* amamantar \w a|strong="H3068"\w* sus crías;  
\q1 \w pero|strong="H3588"\w* \w la|strong="H1571"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* ha vuelto cruel,  
\q2 \w como|strong="H3588"\w* \w los|strong="H3588"\w* avestruces \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*.   
\b  
\q1
\v 4 La \w lengua|strong="H3956"\w* del lactante \w se|strong="H1992"\w* pega al paladar por la \w sed|strong="H6772"\w*.  
\q2 \w Los|strong="H1992"\w* \w niños|strong="H5768"\w* pequeños piden \w pan|strong="H3899"\w*,  
\q2 pero no hay quien \w se|strong="H1992"\w* \w lo|strong="H1992"\w* parta.   
\b  
\q1
\v 5 \w Los|strong="H5921"\w* \w que|strong="H5921"\w* comían manjares desfallecen \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w*;  
\q2 \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* criaron \w entre|strong="H5921"\w* púrpura \w se|strong="H5921"\w* abrazan \w a|strong="H3068"\w* \w los|strong="H5921"\w* estercoleros.   
\b  
\q1
\v 6 Pues la \w iniquidad|strong="H5771"\w* \w de|strong="H5971"\w* la \w hija|strong="H1323"\w* \w de|strong="H5971"\w* \w mi|strong="H1431"\w* \w pueblo|strong="H5971"\w* \w es|strong="H3027"\w* mayor \w que|strong="H3808"\w* el \w pecado|strong="H2403"\w* \w de|strong="H5971"\w* \w Sodoma|strong="H5467"\w*,  
\q2 \w que|strong="H3808"\w* \w fue|strong="H3808"\w* destruida en un \w momento|strong="H7281"\w*  
\q2 \w sin|strong="H3808"\w* \w que|strong="H3808"\w* \w manos|strong="H3027"\w* humanas intervinieran.   
\b  
\q1
\v 7 Sus nobles eran más puros que la nieve,  
\q2 más blancos que la \w leche|strong="H2461"\w*;  
\q1 su cuerpo era más rubicundo que el coral,  
\q2 su porte era como el zafiro.   
\b  
\q1
\v 8 Pero ahora su aspecto \w es|strong="H1961"\w* \w más|strong="H5921"\w* oscuro \w que|strong="H3808"\w* \w el|strong="H5921"\w* hollín;  
\q2 \w nadie|strong="H3808"\w* \w los|strong="H5921"\w* \w reconoce|strong="H5234"\w* \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w*.  
\q1 Su \w piel|strong="H5785"\w* \w se|strong="H1961"\w* \w ha|strong="H3808"\w* pegado \w a|strong="H3068"\w* sus \w huesos|strong="H6106"\w*;  
\q2 \w se|strong="H1961"\w* \w ha|strong="H3808"\w* secado, \w se|strong="H1961"\w* \w ha|strong="H3808"\w* vuelto \w como|strong="H1961"\w* \w madera|strong="H6086"\w*.   
\b  
\q1
\v 9 Dichosos \w los|strong="H1992"\w* \w que|strong="H1961"\w* \w murieron|strong="H1856"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* antes \w que|strong="H1961"\w* \w los|strong="H1992"\w* \w que|strong="H1961"\w* mueren de \w hambre|strong="H7458"\w*;  
\q2 porque \w estos|strong="H1992"\w* mueren lentamente, consumidos  
\q2 por falta de \w los|strong="H1992"\w* frutos del \w campo|strong="H7704"\w*.   
\b  
\q1
\v 10 Las \w manos|strong="H3027"\w* \w de|strong="H5971"\w* \w mujeres|strong="H1323"\w* \w que|strong="H5971"\w* \w eran|strong="H1961"\w* compasivas \w cocieron|strong="H1310"\w* \w a|strong="H3068"\w* sus propios \w hijos|strong="H3206"\w*;  
\q2 \w ellos|strong="H3027"\w* les sirvieron \w de|strong="H5971"\w* alimento en la ruina \w de|strong="H5971"\w* la \w hija|strong="H1323"\w* \w de|strong="H5971"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*.   
\b  
\q1
\v 11 Yahvé ha agotado su \w furor|strong="H2740"\w*;  
\q2 ha \w derramado|strong="H8210"\w* el ardor de su \w ira|strong="H2534"\w*.  
\q1 Ha encendido en \w Sión|strong="H6726"\w* un fuego  
\q2 que ha devorado hasta sus cimientos.   
\b  
\q1
\v 12 \w Nunca|strong="H3808"\w* creyeron \w los|strong="H3427"\w* \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra,  
\q2 \w ni|strong="H3808"\w* \w ninguno|strong="H3808"\w* \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* del \w mundo|strong="H8398"\w*,  
\q2 \w que|strong="H3588"\w* \w el|strong="H3588"\w* adversario \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w enemigo|strong="H6862"\w* entrarían \w por|strong="H3588"\w* las \w puertas|strong="H8179"\w* \w de|strong="H3588"\w* Jerusalén.   
\b  
\q1
\v 13 Fue por los \w pecados|strong="H2403"\w* \w de|strong="H1818"\w* sus \w profetas|strong="H5030"\w*  
\q2 y por las \w iniquidades|strong="H5771"\w* \w de|strong="H1818"\w* sus \w sacerdotes|strong="H3548"\w*,  
\q2 que \w derramaron|strong="H8210"\w* en \w medio|strong="H7130"\w* \w de|strong="H1818"\w* ella la \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* los \w justos|strong="H6662"\w*.   
\b  
\q1
\v 14 \w Eran|strong="H3808"\w* \w como|strong="H5060"\w* \w ciegos|strong="H5787"\w* vagando por las \w calles|strong="H2351"\w*,  
\q2 contaminados \w con|strong="H5060"\w* \w sangre|strong="H1818"\w*,  
\q2 \w de|strong="H1818"\w* modo \w que|strong="H3808"\w* \w nadie|strong="H3808"\w* \w podía|strong="H3201"\w* \w tocar|strong="H5060"\w* sus \w vestiduras|strong="H3830"\w*.   
\b  
\q1
\v 15 «¡\w Apartaos|strong="H5493"\w*! ¡Impuros!», les gritaban.  
\q2 «¡\w Apartaos|strong="H5493"\w*, \w apartaos|strong="H5493"\w*! ¡\w No|strong="H3808"\w* nos \w toquéis|strong="H5060"\w*!».  
\q1 Huyeron \w y|strong="H1571"\w* vagaron, \w y|strong="H1571"\w* \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w* \w se|strong="H3808"\w* decía:  
\q2 «\w No|strong="H3808"\w* pueden seguir habitando aquí».   
\b  
\q1
\v 16 La \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé los dispersó;  
\q2 \w ya|strong="H3254"\w* \w no|strong="H3808"\w* \w volverá|strong="H3254"\w* \w a|strong="H3068"\w* mirarlos.  
\q1 \w No|strong="H3808"\w* \w respetaron|strong="H5375"\w* \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w*,  
\q2 \w ni|strong="H3808"\w* tuvieron piedad \w de|strong="H6440"\w* los \w ancianos|strong="H2205"\w*.   
\b  
\q1
\v 17 Nuestros \w ojos|strong="H5869"\w* \w aún|strong="H5751"\w* \w se|strong="H3808"\w* cansan  
\q2 esperando en \w vano|strong="H1892"\w* un \w socorro|strong="H5833"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* llega.  
\q2 Desde nuestras atalayas \w aguardamos|strong="H6822"\w* \w a|strong="H3068"\w* una \w nación|strong="H1471"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w podía|strong="H3808"\w* \w salvar|strong="H3467"\w*.   
\b  
\q1
\v 18 Acechaban nuestros \w pasos|strong="H6806"\w*  
\q2 \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* pudiéramos \w andar|strong="H3212"\w* \w por|strong="H3588"\w* nuestras \w plazas|strong="H7339"\w*.  
\q1 Nuestro \w fin|strong="H7093"\w* está \w cerca|strong="H7126"\w*, nuestros \w días|strong="H3117"\w* se han cumplido;  
\q2 ¡\w sí|strong="H3588"\w*, ha llegado nuestro \w fin|strong="H7093"\w*!   
\b  
\q1
\v 19 Nuestros \w perseguidores|strong="H7291"\w* \w fueron|strong="H1961"\w* \w más|strong="H5921"\w* veloces \w que|strong="H5921"\w* \w las|strong="H5921"\w* águilas \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*;  
\q2 \w nos|strong="H5921"\w* acosaron \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*,  
\q2 \w nos|strong="H5921"\w* tendieron emboscadas \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*.   
\b  
\q1
\v 20 El aliento de nuestra \w vida|strong="H2421"\w*, el \w ungido|strong="H4899"\w* de Yahvé,  
\q2 quedó atrapado en sus fosas;  
\q2 aquel de quien decíamos: «Bajo su \w sombra|strong="H6738"\w* \w viviremos|strong="H2421"\w* entre las \w naciones|strong="H1471"\w*».   
\b  
\q1
\v 21 ¡Regocíjate \w y|strong="H1571"\w* alégrate, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* Edom,  
\q2 tú \w que|strong="H5921"\w* \w habitas|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Uz|strong="H5780"\w*!  
\q1 \w También|strong="H1571"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w te|strong="H5921"\w* llegará \w la|strong="H5921"\w* copa;  
\q2 \w te|strong="H5921"\w* embriagarás \w y|strong="H1571"\w* quedarás desnuda.   
\b  
\q1
\v 22 Tu castigo \w ha|strong="H3808"\w* terminado, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Sión|strong="H6726"\w*;  
\q2 \w él|strong="H5921"\w* \w no|strong="H3808"\w* \w volverá|strong="H3254"\w* \w a|strong="H3068"\w* llevarte \w al|strong="H5921"\w* cautiverio.  
\q1 Pero castigará tu \w iniquidad|strong="H5771"\w*, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* Edom;  
\q2 \w él|strong="H5921"\w* pondrá \w al|strong="H5921"\w* descubierto tus \w pecados|strong="H2403"\w*.   
\c 5
\q1
\v 1 \w Acuérdate|strong="H2142"\w*, Yahvé, de \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w nos|strong="H4100"\w* ha sucedido;  
\q2 \w mira|strong="H7200"\w* y considera nuestro \w oprobio|strong="H2781"\w*.   
\q1
\v 2 Nuestra \w heredad|strong="H5159"\w* ha pasado \w a|strong="H3068"\w* extraños,  
\q2 nuestras \w casas|strong="H1004"\w* \w a|strong="H3068"\w* extranjeros.   
\q1
\v 3 \w Huérfanos|strong="H3490"\w* \w somos|strong="H1961"\w*, sin padre;  
\q2 nuestras madres \w son|strong="H1961"\w* \w como|strong="H1961"\w* viudas.   
\q1
\v 4 Nuestra propia \w agua|strong="H4325"\w* \w bebemos|strong="H8354"\w* por \w dinero|strong="H3701"\w*;  
\q2 la \w leña|strong="H6086"\w* nos la venden por \w precio|strong="H3701"\w*.   
\q1
\v 5 \w El|strong="H5921"\w* \w yugo|strong="H5921"\w* \w de|strong="H5921"\w* nuestros \w perseguidores|strong="H7291"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* nuestro \w cuello|strong="H6677"\w*;  
\q2 estamos agotados \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w nos|strong="H5921"\w* da descanso.   
\q1
\v 6 Al \w egipcio|strong="H4713"\w* y al asirio extendimos \w la|strong="H7646"\w* \w mano|strong="H3027"\w*,  
\q2 \w para|strong="H5414"\w* saciarnos \w de|strong="H5414"\w* \w pan|strong="H3899"\w*.   
\q1
\v 7 Nuestros padres \w pecaron|strong="H2398"\w*, y ya no existen;  
\q2 y nosotros cargamos con sus \w iniquidades|strong="H5771"\w*.   
\q1
\v 8 \w Siervos|strong="H5650"\w* se han enseñoreado de nosotros;  
\q2 no hay quien nos libre de su \w mano|strong="H3027"\w*.   
\q1
\v 9 Con peligro \w de|strong="H6440"\w* nuestra \w vida|strong="H5315"\w* traemos nuestro \w pan|strong="H3899"\w*,  
\q2 \w ante|strong="H6440"\w* la \w espada|strong="H2719"\w* del \w desierto|strong="H4057"\w*.   
\q1
\v 10 Nuestra \w piel|strong="H5785"\w* se ha ennegrecido como un \w horno|strong="H8574"\w*,  
\q2 \w por|strong="H6440"\w* el ardor abrasador del \w hambre|strong="H7458"\w*.   
\q1
\v 11 \w Violaron|strong="H6031"\w* \w a|strong="H3068"\w* las mujeres en \w Sión|strong="H6726"\w*,  
\q2 \w a|strong="H3068"\w* las \w vírgenes|strong="H1330"\w* en las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w*.   
\q1
\v 12 \w A|strong="H3068"\w* los \w príncipes|strong="H8269"\w* \w colgaron|strong="H8518"\w* \w de|strong="H6440"\w* sus \w manos|strong="H3027"\w*;  
\q2 \w no|strong="H3808"\w* \w respetaron|strong="H1921"\w* el \w rostro|strong="H6440"\w* \w de|strong="H6440"\w* los \w ancianos|strong="H2205"\w*.   
\q1
\v 13 Obligaron \w a|strong="H3068"\w* los jóvenes \w a|strong="H3068"\w* mover el molino,  
\q2 y los muchachos \w desfallecieron|strong="H3782"\w* bajo el peso de la \w leña|strong="H6086"\w*.   
\q1
\v 14 Los \w ancianos|strong="H2205"\w* ya no se sientan \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w*,  
\q2 y los jóvenes dejaron sus canciones.   
\q1
\v 15 \w Cesó|strong="H7673"\w* el \w gozo|strong="H4885"\w* de nuestro \w corazón|strong="H3820"\w*;  
\q2 nuestra danza se tornó en luto.   
\q1
\v 16 \w Cayó|strong="H5307"\w* \w la|strong="H3588"\w* \w corona|strong="H5850"\w* \w de|strong="H3588"\w* nuestra \w cabeza|strong="H7218"\w*;  
\q2 ¡ay \w de|strong="H3588"\w* nosotros, \w porque|strong="H3588"\w* hemos \w pecado|strong="H2398"\w*!   
\q1
\v 17 \w Por|strong="H5921"\w* \w esto|strong="H2088"\w* desfallece nuestro \w corazón|strong="H3820"\w*,  
\q2 \w por|strong="H5921"\w* \w esto|strong="H2088"\w* \w se|strong="H1961"\w* nublan nuestros \w ojos|strong="H5869"\w*:   
\q1
\v 18 \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w de|strong="H5921"\w* \w Sión|strong="H6726"\w*, \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w asolado|strong="H8074"\w*;  
\q2 \w los|strong="H5921"\w* zorros merodean \w por|strong="H5921"\w* \w él|strong="H5921"\w*.   
\b  
\q1
\v 19 Mas tú, Yahvé, permaneces para \w siempre|strong="H5769"\w*;  
\q2 tu \w trono|strong="H3678"\w*, de \w generación|strong="H1755"\w* en \w generación|strong="H1755"\w*.   
\q1
\v 20 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* te olvidas \w de|strong="H7911"\w* nosotros para siempre,  
\q2 y \w nos|strong="H4100"\w* abandonas \w por|strong="H4100"\w* tanto \w tiempo|strong="H3117"\w*?   
\q1
\v 21 Haznos \w volver|strong="H7725"\w* \w a|strong="H3068"\w* ti, Yahvé, y \w volveremos|strong="H7725"\w*;  
\q2 \w renueva|strong="H2318"\w* nuestros \w días|strong="H3117"\w* como antaño.   
\q1
\v 22 ¿\w O|strong="H3068"\w* \w es|strong="H3588"\w* \w que|strong="H3588"\w* \w nos|strong="H5921"\w* has \w desechado|strong="H3988"\w* \w por|strong="H5921"\w* completo  
\q2 \w y|strong="H3588"\w* estás airado \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w en|strong="H5921"\w* demasía?   
\b  