\mt1 Lamentaciones  
\mt2 de Jeremías  
\c 1
\p
\v 1 ¡\w Cómo|strong="H1961"\w* yace solitaria la \w ciudad|strong="H5892"\w* \w que|strong="H5971"\w* \w estaba|strong="H1961"\w* llena \w de|strong="H5971"\w* \w gente|strong="H1471"\w*!  
\q2 \w Se|strong="H1961"\w* ha convertido en una viuda la \w que|strong="H5971"\w* \w era|strong="H1961"\w* \w grande|strong="H7227"\w* entre las \w naciones|strong="H1471"\w*.  
\q1 La \w que|strong="H5971"\w* \w fue|strong="H1961"\w* princesa entre las \w provincias|strong="H4082"\w*  
\q2 ¡\w se|strong="H1961"\w* ha convertido en una esclava!   
\b  
\q1
\v 2 \w Llora|strong="H1058"\w* \w amargamente|strong="H1058"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w noche|strong="H3915"\w*; sus \w lágrimas|strong="H1832"\w* bañan sus mejillas.  
\q2 \w Entre|strong="H5921"\w* \w todos|strong="H3605"\w* sus amantes \w no|strong="H1961"\w* \w tiene|strong="H1961"\w* \w a|strong="H3068"\w* \w nadie|strong="H3605"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* consuele.  
\q1 \w Todos|strong="H3605"\w* sus \w amigos|strong="H7453"\w* \w la|strong="H5921"\w* han traicionado;  
\q2 \w se|strong="H1961"\w* han convertido \w en|strong="H5921"\w* sus enemigos.   
\b  
\q1
\v 3 \w Judá|strong="H3063"\w* \w ha|strong="H3808"\w* marchado al cautiverio \w a|strong="H3068"\w* causa de \w la|strong="H1931"\w* \w aflicción|strong="H6040"\w*  
\q2 y por \w la|strong="H1931"\w* dura \w servidumbre|strong="H5656"\w*.  
\q1 \w Ella|strong="H1931"\w* \w habita|strong="H3427"\w* \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w*, \w mas|strong="H1471"\w* \w no|strong="H3808"\w* encuentra \w descanso|strong="H4494"\w*.  
\q2 \w Todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w perseguidores|strong="H7291"\w* \w la|strong="H1931"\w* \w alcanzaron|strong="H5381"\w* en medio de \w su|strong="H1931"\w* angustia.   
\b  
\q1
\v 4 \w Los|strong="H3605"\w* \w caminos|strong="H1870"\w* de \w Sión|strong="H6726"\w* están de luto,  
\q2 porque \w nadie|strong="H3605"\w* acude \w a|strong="H3068"\w* las \w solemnidades|strong="H4150"\w*.  
\q1 \w Todas|strong="H3605"\w* \w sus|strong="H1931"\w* \w puertas|strong="H8179"\w* están \w asoladas|strong="H8074"\w*; \w sus|strong="H1931"\w* \w sacerdotes|strong="H3548"\w* gimen.  
\q2 \w Sus|strong="H1931"\w* \w vírgenes|strong="H1330"\w* están \w afligidas|strong="H3013"\w*, y \w ella|strong="H1931"\w* \w misma|strong="H1931"\w* \w está|strong="H1931"\w* sumida en \w la|strong="H1931"\w* \w amargura|strong="H4751"\w*.   
\b  
\q1
\v 5 Sus \w adversarios|strong="H6862"\w* han llegado \w a|strong="H3068"\w* ser \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w y|strong="H3588"\w* sus \w enemigos|strong="H6862"\w* \w prosperan|strong="H7951"\w*;  
\q2 \w porque|strong="H3588"\w* Yahvé\f + \fr 1:5 \ft «Yahvé» es el nombre propio de Dios, a veces traducido como «SEÑOR» (en mayúsculas) en otras traducciones.\f* \w la|strong="H5921"\w* ha afligido \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w multitud|strong="H7230"\w* \w de|strong="H5921"\w* sus transgresiones.  
\q2 Sus hijos pequeños han ido \w al|strong="H5921"\w* \w cautiverio|strong="H7628"\w* \w ante|strong="H6440"\w* \w el|strong="H5921"\w* adversario.   
\b  
\q1
\v 6 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* majestad \w se|strong="H1961"\w* \w ha|strong="H3808"\w* alejado \w de|strong="H4480"\w* \w la|strong="H3605"\w* \w hija|strong="H1323"\w* \w de|strong="H4480"\w* Sión.  
\q2 Sus \w príncipes|strong="H8269"\w* han quedado \w como|strong="H1961"\w* ciervos \w que|strong="H4480"\w* \w no|strong="H3808"\w* \w hallan|strong="H4672"\w* \w pasto|strong="H4829"\w*;  
\q2 \w se|strong="H1961"\w* han marchado \w sin|strong="H3808"\w* \w fuerzas|strong="H3581"\w* \w ante|strong="H6440"\w* \w el|strong="H3605"\w* perseguidor.   
\b  
\q1
\v 7 Jerusalén recuerda, \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* su \w aflicción|strong="H6040"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* sus miserias,  
\q2 \w todos|strong="H3605"\w* \w los|strong="H5921"\w* tesoros \w que|strong="H5921"\w* poseía \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* antaño.  
\q1 \w Cuando|strong="H3117"\w* su \w pueblo|strong="H5971"\w* \w cayó|strong="H5307"\w* \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w del|strong="H5921"\w* adversario \w y|strong="H5921"\w* \w nadie|strong="H3605"\w* \w la|strong="H5921"\w* \w ayudó|strong="H5826"\w*,  
\q2 \w los|strong="H5921"\w* \w enemigos|strong="H6862"\w* \w la|strong="H5921"\w* \w miraron|strong="H7200"\w* \w y|strong="H5921"\w* \w se|strong="H1961"\w* burlaron \w de|strong="H5921"\w* su ruina.   
\b  
\q1
\v 8 Jerusalén ha \w pecado|strong="H2399"\w* gravemente; \w por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w se|strong="H1961"\w* ha \w vuelto|strong="H7725"\w* impura.  
\q2 \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w la|strong="H1931"\w* \w honraban|strong="H3513"\w* \w la|strong="H1931"\w* desprecian \w porque|strong="H3588"\w* han \w visto|strong="H7200"\w* \w su|strong="H1931"\w* \w desnudez|strong="H6172"\w*;  
\q2 \w sí|strong="H3588"\w*, \w ella|strong="H1931"\w* \w misma|strong="H1931"\w* gime \w y|strong="H1571"\w* \w se|strong="H1961"\w* \w vuelve|strong="H7725"\w* \w de|strong="H5921"\w* espaldas.   
\b  
\q1
\v 9 \w Su|strong="H3588"\w* \w inmundicia|strong="H2932"\w* estaba \w en|strong="H3588"\w* sus faldas; \w no|strong="H3808"\w* pensó \w en|strong="H3588"\w* \w su|strong="H3588"\w* fin.  
\q2 \w Por|strong="H3588"\w* \w lo|strong="H3808"\w* tanto, \w su|strong="H3588"\w* caída \w ha|strong="H3808"\w* sido asombrosa; \w no|strong="H3808"\w* tiene quien \w la|strong="H3588"\w* consuele.  
\q1 «\w Mira|strong="H7200"\w*, Yahvé, \w mi|strong="H1431"\w* \w aflicción|strong="H6040"\w*,  
\q2 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* enemigo \w se|strong="H3808"\w* \w ha|strong="H3808"\w* \w engrandecido|strong="H1431"\w*».   
\b  
\q1
\v 10 \w El|strong="H5921"\w* adversario \w ha|strong="H3808"\w* extendido \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* sus tesoros;  
\q2 \w ella|strong="H3605"\w* \w ha|strong="H3808"\w* \w visto|strong="H7200"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* entrar \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w santuario|strong="H4720"\w*,  
\q2 \w de|strong="H5921"\w* \w las|strong="H5921"\w* cuales \w ordenaste|strong="H6680"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* entrasen \w en|strong="H5921"\w* vuestra asamblea.   
\b  
\q1
\v 11 \w Todo|strong="H3605"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* gime \w buscando|strong="H1245"\w* \w pan|strong="H3899"\w*;  
\q2 han \w dado|strong="H5414"\w* sus tesoros \w a|strong="H3068"\w* cambio \w de|strong="H3588"\w* alimento \w para|strong="H3588"\w* recobrar \w la|strong="H3588"\w* \w vida|strong="H5315"\w*.  
\q1 «\w Mira|strong="H7200"\w*, Yahvé, \w y|strong="H3588"\w* observa,  
\q2 \w porque|strong="H3588"\w* \w me|strong="H3588"\w* han despreciado».   
\b  
\q1
\v 12 “¿\w No|strong="H3808"\w* os importa \w nada|strong="H3808"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w vosotros|strong="H3426"\w* \w los|strong="H3605"\w* \w que|strong="H3808"\w* \w pasáis|strong="H5674"\w* \w por|strong="H1870"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w*?  
\q2 \w Mirad|strong="H7200"\w* y \w ved|strong="H7200"\w* \w si|strong="H3808"\w* \w hay|strong="H3426"\w* \w dolor|strong="H4341"\w* como \w el|strong="H3605"\w* mío,  
\q2 \w el|strong="H3605"\w* cual me \w ha|strong="H3808"\w* sobrevenido,  
\q2 con \w el|strong="H3605"\w* \w que|strong="H3808"\w* Yahvé me \w ha|strong="H3808"\w* afligido en \w el|strong="H3605"\w* \w día|strong="H3117"\w* de su ardiente \w ira|strong="H2740"\w*.   
\b  
\q1
\v 13 “Desde \w lo|strong="H3605"\w* \w alto|strong="H4791"\w* \w envió|strong="H7971"\w* fuego \w a|strong="H3068"\w* \w mis|strong="H5414"\w* \w huesos|strong="H6106"\w* y este prevaleció contra \w ellos|strong="H3605"\w*.  
\q2 Ha tendido una \w red|strong="H7568"\w* \w a|strong="H3068"\w* \w mis|strong="H5414"\w* \w pies|strong="H7272"\w* y me ha hecho \w volver|strong="H7725"\w* atrás.  
\q2 Me ha dejado desolada y desfallezco \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w*.   
\b  
\q1
\v 14 “\w El|strong="H5921"\w* \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* \w mis|strong="H5414"\w* \w rebeliones|strong="H6588"\w* \w ha|strong="H3808"\w* sido atado \w por|strong="H5921"\w* su \w mano|strong="H3027"\w*;  
\q2 están entrelazadas \w y|strong="H5921"\w* han \w subido|strong="H5927"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w cuello|strong="H6677"\w*. \w Él|strong="H5921"\w* \w ha|strong="H3808"\w* hecho flaquear \w mis|strong="H5414"\w* \w fuerzas|strong="H3581"\w*.  
\q1 \w El|strong="H5921"\w* Señor\f + \fr 1:14 \ft La palabra traducida «Señor» es «Adonai».\f* \w me|strong="H5921"\w* \w ha|strong="H3808"\w* \w entregado|strong="H5414"\w* \w en|strong="H5921"\w* \w manos|strong="H3027"\w*  
\q2 \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* soy capaz \w de|strong="H5921"\w* \w levantarme|strong="H6965"\w*.   
\b  
\q1
\v 15 “\w El|strong="H5921"\w* Señor ha despreciado \w a|strong="H3068"\w* \w todos|strong="H3605"\w* mis valientes \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.  
\q2 \w Convocó|strong="H7121"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* una asamblea \w para|strong="H5921"\w* aplastar \w a|strong="H3068"\w* mis jóvenes.  
\q2 \w El|strong="H5921"\w* Señor ha \w pisado|strong="H1869"\w* \w como|strong="H5921"\w* \w en|strong="H5921"\w* un lagar \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w virgen|strong="H1330"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\b  
\q1
\v 16 «\w Por|strong="H5921"\w* estas cosas \w lloro|strong="H1058"\w*; mis \w ojos|strong="H5869"\w* \w se|strong="H1961"\w* deshacen \w en|strong="H5921"\w* lágrimas,  
\q2 \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w consolador|strong="H5162"\w* \w que|strong="H3588"\w* debería reanimar \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w está|strong="H1961"\w* \w lejos|strong="H7368"\w* \w de|strong="H4480"\w* \w mí|strong="H5921"\w*.  
\q1 Mis \w hijos|strong="H1121"\w* \w están|strong="H1961"\w* desolados  
\q2 \w porque|strong="H3588"\w* \w el|strong="H5921"\w* enemigo ha prevalecido».   
\b  
\q1
\v 17 \w Sión|strong="H6726"\w* \w extiende|strong="H6566"\w* sus \w manos|strong="H3027"\w*, pero \w no|strong="H1961"\w* \w hay|strong="H1961"\w* quien la consuele.  
\q2 Yahvé ha dado órdenes \w contra|strong="H1961"\w* \w Jacob|strong="H3290"\w* \w para|strong="H1961"\w* \w que|strong="H1961"\w* sus vecinos \w sean|strong="H1961"\w* sus \w adversarios|strong="H6862"\w*.  
\q2 Jerusalén \w es|strong="H1961"\w* entre \w ellos|strong="H3027"\w* \w como|strong="H1961"\w* una cosa impura.   
\b  
\q1
\v 18 “Yahvé \w es|strong="H1931"\w* \w justo|strong="H6662"\w*, \w pues|strong="H3588"\w* \w yo|strong="H3588"\w* \w me|strong="H3588"\w* rebelé contra \w su|strong="H1931"\w* \w mandamiento|strong="H6310"\w*.  
\q1 \w Oíd|strong="H8085"\w*, os \w ruego|strong="H4994"\w*, \w pueblos|strong="H5971"\w* \w todos|strong="H3605"\w*, \w y|strong="H3588"\w* \w ved|strong="H7200"\w* \w mi|strong="H4994"\w* \w dolor|strong="H4341"\w*;  
\q2 mis \w vírgenes|strong="H1330"\w* \w y|strong="H3588"\w* mis jóvenes han marchado al \w cautiverio|strong="H7628"\w*.   
\b  
\q1
\v 19 “\w Llamé|strong="H7121"\w* \w a|strong="H3068"\w* mis amantes, \w mas|strong="H3588"\w* \w ellos|strong="H1992"\w* \w me|strong="H3588"\w* engañaron.  
\q1 Mis \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* mis \w ancianos|strong="H2205"\w* expiraron \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*  
\q2 \w mientras|strong="H3588"\w* buscaban comida \w para|strong="H3588"\w* sustentar \w sus|strong="H1992"\w* \w vidas|strong="H5315"\w*.   
\b  
\q1
\v 20 “\w Mira|strong="H7200"\w*, Yahvé, \w que|strong="H3588"\w* \w estoy|strong="H6862"\w* angustiada; mis \w entrañas|strong="H4578"\w* se conmueven.  
\q1 Mi \w corazón|strong="H3820"\w* se vuelca \w dentro|strong="H7130"\w* \w de|strong="H3588"\w* mí \w porque|strong="H3588"\w* \w me|strong="H3588"\w* he rebelado gravemente.  
\q2 \w Fuera|strong="H2351"\w*, \w la|strong="H3588"\w* \w espada|strong="H2719"\w* \w me|strong="H3588"\w* deja sin hijos; \w dentro|strong="H7130"\w*, \w es|strong="H3588"\w* \w como|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w*.   
\b  
\q1
\v 21 “Han \w oído|strong="H8085"\w* \w que|strong="H3588"\w* gimo, \w pero|strong="H3588"\w* \w nadie|strong="H3605"\w* \w me|strong="H3588"\w* \w consuela|strong="H5162"\w*.  
\q1 \w Todos|strong="H3605"\w* mis enemigos han sabido \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \w mal|strong="H7451"\w* \w y|strong="H3588"\w* \w se|strong="H1961"\w* alegran \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w tú|strong="H6213"\w* \w lo|strong="H6213"\w* hayas \w hecho|strong="H6213"\w*.  
\q2 ¡Ojalá traigas \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w que|strong="H3588"\w* has anunciado \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w sean|strong="H1961"\w* \w como|strong="H3588"\w* \w yo|strong="H3588"\w*!   
\b  
\q1
\v 22 «Venga \w ante|strong="H6440"\w* \w ti|strong="H5921"\w* \w toda|strong="H3605"\w* \w su|strong="H3588"\w* \w maldad|strong="H7451"\w*.  
\q2 Haz \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w como|strong="H3588"\w* has hecho conmigo \w por|strong="H5921"\w* \w todas|strong="H3605"\w* mis transgresiones;  
\q1 \w porque|strong="H3588"\w* \w muchos|strong="H7227"\w* \w son|strong="H3588"\w* mis suspiros \w y|strong="H3588"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w* \w desfallece|strong="H1742"\w*».   
\c 2
\p
\v 1 ¡\w Cómo|strong="H7272"\w* \w ha|strong="H3808"\w* cubierto el Señor de nubes \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* de \w Sión|strong="H6726"\w* en su ira!  
\q2 \w Ha|strong="H3808"\w* derribado del \w cielo|strong="H8064"\w* \w a|strong="H3068"\w* la tierra la hermosura de \w Israel|strong="H3478"\w*,  
\q2 y \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* acordado del \w estrado|strong="H1916"\w* de sus \w pies|strong="H7272"\w* en el \w día|strong="H3117"\w* de su furor.   
\b  
\q1
\v 2 \w El|strong="H3605"\w* Señor \w ha|strong="H3808"\w* destruido \w todas|strong="H3605"\w* las moradas \w de|strong="H8269"\w* \w Jacob|strong="H3290"\w*  
\q2 \w sin|strong="H3808"\w* piedad.  
\q1 \w Ha|strong="H3808"\w* derribado en su furor las fortalezas \w de|strong="H8269"\w* \w la|strong="H3605"\w* \w hija|strong="H1323"\w* \w de|strong="H8269"\w* \w Judá|strong="H3063"\w*;  
\q2 las \w ha|strong="H3808"\w* echado por tierra.  
\q2 \w Ha|strong="H3808"\w* \w profanado|strong="H2490"\w* \w el|strong="H3605"\w* \w reino|strong="H4467"\w* y \w a|strong="H3068"\w* sus \w príncipes|strong="H8269"\w*.   
\b  
\q1
\v 3 Ha \w cortado|strong="H1438"\w* con \w el|strong="H3605"\w* ardor \w de|strong="H6440"\w* su ira \w todo|strong="H3605"\w* \w el|strong="H3605"\w* poder \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.  
\q2 Ha retirado su \w diestra|strong="H3225"\w* frente al enemigo.  
\q1 Ha \w encendido|strong="H1197"\w* en \w Jacob|strong="H3290"\w* un fuego \w ardiente|strong="H1197"\w*  
\q2 \w que|strong="H3605"\w* devora \w todo|strong="H3605"\w* \w a|strong="H3068"\w* su \w alrededor|strong="H5439"\w*.   
\b  
\q1
\v 4 Ha \w entesado|strong="H1869"\w* su \w arco|strong="H7198"\w* como un \w enemigo|strong="H6862"\w*;  
\q2 ha afirmado su mano \w derecha|strong="H3225"\w* como un adversario.  
\q1 Ha matado \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1869"\w* era hermoso \w a|strong="H3068"\w* \w la|strong="H3605"\w* vista;  
\q2 en \w la|strong="H3605"\w* tienda \w de|strong="H5869"\w* \w la|strong="H3605"\w* \w hija|strong="H1323"\w* \w de|strong="H5869"\w* \w Sión|strong="H6726"\w* ha \w derramado|strong="H8210"\w* su \w ira|strong="H2534"\w* como fuego.   
\b  
\q1
\v 5 \w El|strong="H3605"\w* Señor \w se|strong="H1961"\w* ha vuelto \w como|strong="H1961"\w* un enemigo;  
\q2 ha destruido \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.  
\q1 Ha derruido \w todos|strong="H3605"\w* sus palacios  
\q2 y ha destrozado sus fortalezas.  
