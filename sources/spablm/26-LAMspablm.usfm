\v 62 \w los|strong="H3605"\w* \w labios|strong="H8193"\w* \w de|strong="H5921"\w* \w los|strong="H3605"\w* \w que|strong="H5921"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w se|strong="H5921"\w* \w levantaron|strong="H6965"\w*,  
\q2 \w y|strong="H5921"\w* su acechanza \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w*.   
\q1
\v 63 \w Mira|strong="H5027"\w* su sentarse y su levantarse;  
\q2 yo soy \w el|strong="H3427"\w* objeto de sus burlas.   
\b  
\q1
\v 64 Tú les darás el \w pago|strong="H1576"\w*, Yahvé,  
\q2 según la \w obra|strong="H4639"\w* de sus \w manos|strong="H3027"\w*.   
\q1
\v 65 \w Les|strong="H1992"\w* \w darás|strong="H5414"\w* dureza \w de|strong="H5414"\w* \w corazón|strong="H3820"\w*;  
\q2 ¡tu maldición caiga sobre \w ellos|strong="H1992"\w*!   
\q1
\v 66 \w Los|strong="H7291"\w* perseguirás \w en|strong="H8478"\w* tu ira,  
\q2 y \w los|strong="H7291"\w* destruirás \w de|strong="H8478"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w los|strong="H7291"\w* \w cielos|strong="H8064"\w* \w de|strong="H8478"\w* Yahvé.   
\c 4
\q1
\v 1 ¡Cómo se ha empañado \w el|strong="H3605"\w* \w oro|strong="H2091"\w*!  
\q2 ¡\w El|strong="H3605"\w* \w oro|strong="H2091"\w* más puro ha perdido su brillo!  
\q1 Las piedras del \w santuario|strong="H6944"\w* están esparcidas  
\q2 por las esquinas de \w todas|strong="H3605"\w* las \w calles|strong="H2351"\w*.   
\b  
\q1
\v 2 \w Los|strong="H1121"\w* valiosos \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sión|strong="H6726"\w*,  
\q2 \w que|strong="H1121"\w* valían su peso en \w oro|strong="H6337"\w* \w fino|strong="H6337"\w*,  
