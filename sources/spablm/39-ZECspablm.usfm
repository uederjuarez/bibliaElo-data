\toc1 ZACARÍAS 
\toc2 ZACARÍAS 
\mt1 Zacarías  
\c 1
\p
\v 1 En \w el|strong="H1121"\w* \w octavo|strong="H8066"\w* \w mes|strong="H2320"\w*, en \w el|strong="H1121"\w* \w segundo|strong="H8147"\w* \w año|strong="H8141"\w* \w de|strong="H1121"\w* \w Darío|strong="H1867"\w*, llegó la \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé al \w profeta|strong="H5030"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Iddo|strong="H5714"\w*, diciendo:  
\v 2 “Yahvé \w se|strong="H5921"\w* disgustó mucho \w con|strong="H5921"\w* vuestros padres.  
\v 3 Por lo tanto, decidles \w que|strong="H3541"\w* el \w Señor|strong="H3068"\w* de los \w Ejércitos|strong="H6635"\w* \w dice|strong="H5002"\w*: ‘\w Volved|strong="H7725"\w* \w a|strong="H3068"\w* mí’, \w dice|strong="H5002"\w* el \w Señor|strong="H3068"\w* de los \w Ejércitos|strong="H6635"\w*, ‘\w y|strong="H3541"\w* yo \w volveré|strong="H7725"\w* \w a|strong="H3068"\w* vosotros’, \w dice|strong="H5002"\w* el \w Señor|strong="H3068"\w* de los \w Ejércitos|strong="H6635"\w*.  
\v 4 \w No|strong="H3808"\w* \w seáis|strong="H1961"\w* \w como|strong="H1961"\w* vuestros padres, \w a|strong="H3068"\w* quienes \w los|strong="H1961"\w* antiguos \w profetas|strong="H5030"\w* proclamaban diciendo: \w El|strong="H5030"\w* \w Señor|strong="H3068"\w* \w de|strong="H7451"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w* \w dice|strong="H5002"\w*: ‘\w Volved|strong="H7725"\w* \w ahora|strong="H4994"\w* \w de|strong="H7451"\w* vuestros \w malos|strong="H7451"\w* \w caminos|strong="H1870"\w* \w y|strong="H3541"\w* \w de|strong="H7451"\w* vuestras \w malas|strong="H7451"\w* acciones’; pero \w no|strong="H3808"\w* \w oyeron|strong="H8085"\w* \w ni|strong="H3808"\w* \w me|strong="H3541"\w* \w escucharon|strong="H8085"\w*, \w dice|strong="H5002"\w* \w el|strong="H5030"\w* \w Señor|strong="H3068"\w*.  
\v 5 Vuestros padres, ¿dónde están? ¿\w Y|strong="H3068"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w*, viven para \w siempre|strong="H5769"\w*?  
\v 6 Pero mis \w palabras|strong="H1697"\w* y mis decretos, \w que|strong="H3808"\w* \w ordené|strong="H6680"\w* \w a|strong="H3068"\w* mis \w siervos|strong="H5650"\w* los \w profetas|strong="H5030"\w*, ¿\w no|strong="H3808"\w* \w alcanzaron|strong="H5381"\w* \w a|strong="H3068"\w* vuestros padres?  
\p “\w Entonces|strong="H3651"\w* \w se|strong="H3808"\w* arrepintieron y \w dijeron|strong="H1697"\w*: ‘\w Tal|strong="H3651"\w* \w como|strong="H3651"\w* Yahvé \w de|strong="H1697"\w* los \w Ejércitos|strong="H6635"\w* decidió hacernos, según nuestros \w caminos|strong="H1870"\w* y según nuestras prácticas, \w así|strong="H3651"\w* nos \w ha|strong="H3808"\w* tratado’”.   
\p
\v 7 \w El|strong="H1931"\w* \w día|strong="H3117"\w* \w veinticuatro|strong="H6242"\w* del \w mes|strong="H2320"\w* \w undécimo|strong="H6249"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w de|strong="H1121"\w* Sebat, en \w el|strong="H1931"\w* \w segundo|strong="H8147"\w* \w año|strong="H8141"\w* \w de|strong="H1121"\w* \w Darío|strong="H1867"\w*, \w vino|strong="H1961"\w* \w la|strong="H1931"\w* \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé al \w profeta|strong="H5030"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Iddo|strong="H5714"\w*, diciendo:  
\v 8 “Tuve una visión \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w noche|strong="H3915"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* un hombre \w montado|strong="H7392"\w* \w en|strong="H5921"\w* un \w caballo|strong="H5483"\w* rojo \w se|strong="H1931"\w* paró \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w arrayanes|strong="H1918"\w* \w que|strong="H1931"\w* \w estaban|strong="H5975"\w* \w en|strong="H5921"\w* un barranco; \w y|strong="H5921"\w* detrás \w de|strong="H5921"\w* \w él|strong="H1931"\w* \w había|strong="H5975"\w* \w caballos|strong="H5483"\w* rojos, alazanes \w y|strong="H5921"\w* \w blancos|strong="H3836"\w*.  
\v 9 Entonces pregunté: «Señor mío, ¿\w qué|strong="H4100"\w* es esto?».  
\p \w El|strong="H1992"\w* \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo me \w dijo|strong="H1696"\w*: «Te \w mostraré|strong="H7200"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* son».   
\p
\v 10 El hombre que \w estaba|strong="H5975"\w* entre los mirtos \w respondió|strong="H6030"\w*: «Son los que Yahvé ha \w enviado|strong="H7971"\w* para recorrer la tierra».   
\p
\v 11 Informaron al \w ángel|strong="H4397"\w* de Yahvé, \w que|strong="H3605"\w* \w estaba|strong="H5975"\w* de \w pie|strong="H5975"\w* entre \w los|strong="H3427"\w* mirtos, y dijeron: «Hemos recorrido \w la|strong="H3605"\w* tierra, y he \w aquí|strong="H2009"\w* \w que|strong="H3605"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w está|strong="H5975"\w* \w en|strong="H5975"\w* \w reposo|strong="H8252"\w* y \w en|strong="H5975"\w* paz».   
\p
\v 12 Entonces el \w ángel|strong="H4397"\w* \w de|strong="H5704"\w* Yahvé \w respondió|strong="H6030"\w*: «Oh Yahvé \w de|strong="H5704"\w* los \w Ejércitos|strong="H6635"\w*, ¿\w hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* \w no|strong="H3808"\w* tendrás piedad \w de|strong="H5704"\w* Jerusalén \w y|strong="H5704"\w* \w de|strong="H5704"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, contra las \w que|strong="H3808"\w* has estado indignado \w estos|strong="H2088"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*?».   
\p
\v 13 El \w Señor|strong="H3068"\w* \w respondió|strong="H6030"\w* al \w ángel|strong="H4397"\w* \w que|strong="H1697"\w* \w hablaba|strong="H1696"\w* conmigo con \w palabras|strong="H1697"\w* amables y reconfortantes.  
\v 14 El \w ángel|strong="H4397"\w* \w que|strong="H3541"\w* \w hablaba|strong="H1696"\w* conmigo \w me|strong="H3541"\w* \w dijo|strong="H1696"\w*: “Proclama, \w diciendo|strong="H1696"\w*: El \w Señor|strong="H3068"\w* de los \w Ejércitos|strong="H6635"\w* \w dice|strong="H1696"\w*: «Estoy celoso por Jerusalén \w y|strong="H3541"\w* por \w Sión|strong="H6726"\w* \w con|strong="H7065"\w* \w gran|strong="H1419"\w* \w celo|strong="H7068"\w*.  
\v 15 Estoy muy airado \w con|strong="H5921"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w* \w que|strong="H5921"\w* están tranquilas; \w porque|strong="H5921"\w* yo \w me|strong="H5921"\w* disgusté un \w poco|strong="H4592"\w*, pero \w ellas|strong="H1992"\w* aumentaron \w la|strong="H5921"\w* calamidad».  
\v 16 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w dice|strong="H5002"\w* Yahvé: «He \w vuelto|strong="H7725"\w* \w a|strong="H3068"\w* Jerusalén \w con|strong="H5921"\w* misericordia. \w Mi|strong="H5921"\w* \w casa|strong="H1004"\w* será \w edificada|strong="H1129"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* — \w dice|strong="H5002"\w* \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* — \w y|strong="H5921"\w* un cordel \w se|strong="H5921"\w* \w extenderá|strong="H5186"\w* \w sobre|strong="H5921"\w* Jerusalén».   
\p
\v 17 “\w Proclamad|strong="H7121"\w* \w además|strong="H5750"\w*, diciendo: “El \w Señor|strong="H3068"\w* \w de|strong="H5750"\w* los \w Ejércitos|strong="H6635"\w* dice: «Mis \w ciudades|strong="H5892"\w* volverán \w a|strong="H3068"\w* rebosar \w de|strong="H5750"\w* prosperidad, \w y|strong="H3541"\w* el \w Señor|strong="H3068"\w* volverá \w a|strong="H3068"\w* consolar \w a|strong="H3068"\w* \w Sión|strong="H6726"\w*, \w y|strong="H3541"\w* volverá \w a|strong="H3068"\w* elegir \w a|strong="H3068"\w* Jerusalén»”.   
\p
\v 18 Levanté los ojos y vi, y he aquí cuatro cuernos.  
\v 19 Le pregunté al ángel que hablaba conmigo: «¿Qué son estos?».  
\p Me respondió: «Estos son los cuernos que han dispersado \w a|strong="H3068"\w* Judá, Israel y Jerusalén».   
\p
\v 20 El Señor me mostró cuatro artesanos.  
\v 21 Entonces pregunté: «¿Qué vienen \w a|strong="H3068"\w* hacer estos?».  
\p Dijo: «Estos son los cuernos que dispersaron \w a|strong="H3068"\w* Judá, para que nadie levantara la cabeza; pero estos han venido para aterrorizarlos, para derribar los cuernos de las naciones que alzaron su poder contra la tierra de Judá para dispersarla».   
\c 2
\p
\v 1 Levanté los \w ojos|strong="H5869"\w* y \w vi|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* un hombre con un cordel \w de|strong="H5869"\w* medir en la mano.  
\v 2 Entonces pregunté: «¿Adónde vas?».  
\p Me \w dijo|strong="H1696"\w*: «\w A|strong="H3068"\w* medir Jerusalén, para ver \w cuál|strong="H4100"\w* es su anchura y \w cuál|strong="H4100"\w* su longitud».   
\p
\v 3 He aquí que el ángel que hablaba conmigo salió, y otro ángel salió \w a|strong="H3068"\w* su encuentro,  
\v 4 y le dijo: “Corre, habla \w a|strong="H3068"\w* este joven, diciendo: ‘Jerusalén \w será|strong="H3808"\w* habitada \w como|strong="H4100"\w* aldeas \w sin|strong="H3808"\w* murallas, \w a|strong="H3068"\w* causa de la multitud de hombres y de ganado \w que|strong="H4100"\w* habrá en ella.  
\v 5 \w Porque|strong="H2009"\w* \w yo|strong="H2009"\w* — dice Yahvé — seré para ella un muro \w de|strong="H5869"\w* fuego alrededor, y seré la gloria en \w medio|strong="H3027"\w* \w de|strong="H5869"\w* ella’”.   
\p
\v 6 «¡Venid! ¡Venid! Huid de la tierra del norte», dice Yahvé; «\w porque|strong="H4100"\w* os he esparcido \w como|strong="H4100"\w* los cuatro vientos del cielo», dice Yahvé.  
\v 7 «¡Ven, Sión! Escapa tú, que habitas con la hija de Babilonia».  
\v 8 Porque Yahvé de \w los|strong="H3427"\w* Ejércitos \w dice|strong="H1696"\w*: «Para su gloria me ha enviado \w a|strong="H3068"\w* las naciones que os saquearon; porque \w el|strong="H3427"\w* que os toca, toca la niña de sus ojos.  
\v 9 Porque he aquí \w que|strong="H1961"\w* yo sacudiré \w mi|strong="H1961"\w* mano \w sobre|strong="H1961"\w* ellas, \w y|strong="H3519"\w* \w serán|strong="H1961"\w* botín \w para|strong="H1961"\w* \w los|strong="H1961"\w* \w que|strong="H1961"\w* las sirvieron; \w y|strong="H3519"\w* sabréis \w que|strong="H1961"\w* el \w Señor|strong="H3068"\w* de \w los|strong="H1961"\w* Ejércitos me ha enviado.  
\v 10 ¡Canta \w y|strong="H3588"\w* alégrate, hija \w de|strong="H3588"\w* Sión! \w Porque|strong="H3588"\w* he aquí \w que|strong="H3588"\w* vengo \w y|strong="H3588"\w* habitaré \w en|strong="H3588"\w* medio \w de|strong="H3588"\w* ti», \w dice|strong="H5002"\w* Yahvé.  
\v 11 Muchas naciones se unirán \w a|strong="H3068"\w* Yahvé en aquel día, y serán mi pueblo; y yo \w habitaré|strong="H3427"\w* en medio de vosotros, y sabréis \w que|strong="H1323"\w* Yahvé de \w los|strong="H3427"\w* Ejércitos me ha enviado \w a|strong="H3068"\w* vosotros.  
\v 12 Yahvé heredará \w a|strong="H3068"\w* Judá \w como|strong="H3588"\w* \w su|strong="H3588"\w* porción \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra santa, \w y|strong="H3588"\w* volverá \w a|strong="H3068"\w* elegir \w a|strong="H3068"\w* Jerusalén.  
\v 13 ¡Silencio, \w toda|strong="H5921"\w* carne, ante Yahvé, \w porque|strong="H3588"\w* \w él|strong="H5921"\w* \w se|strong="H3045"\w* ha levantado \w de|strong="H5921"\w* \w su|strong="H3588"\w* santa morada!”.   
\c 3
\p
\v 1 \w Me|strong="H5921"\w* \w mostró|strong="H7200"\w* \w al|strong="H5921"\w* \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* \w Josué|strong="H3091"\w* \w de|strong="H5921"\w* \w pie|strong="H5975"\w* \w ante|strong="H6440"\w* \w el|strong="H5921"\w* \w ángel|strong="H4397"\w* \w de|strong="H5921"\w* Yahvé, \w y|strong="H5921"\w* \w a|strong="H3068"\w* Satanás \w de|strong="H5921"\w* \w pie|strong="H5975"\w* \w a|strong="H3068"\w* su \w derecha|strong="H3225"\w* \w para|strong="H5921"\w* ser su adversario.  
\v 2 Yahvé dijo \w a|strong="H3068"\w* Satanás: «¡Yahvé te reprende, Satanás! ¡\w Sí|strong="H3808"\w*, Yahvé, \w que|strong="H3808"\w* \w ha|strong="H3808"\w* elegido \w a|strong="H3068"\w* Jerusalén, te reprende! ¿\w No|strong="H3808"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* un tizón \w arrebatado|strong="H5337"\w* del incendio?».   
\p
\v 3 \w Josué|strong="H3091"\w* \w estaba|strong="H1961"\w* \w vestido|strong="H3847"\w* con vestiduras sucias y permanecía \w de|strong="H6440"\w* \w pie|strong="H5975"\w* \w ante|strong="H6440"\w* el \w ángel|strong="H4397"\w*.  
\v 4 \w Este|strong="H5975"\w* \w habló|strong="H6030"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w estaban|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, diciendo: «\w Quitadle|strong="H5493"\w* \w las|strong="H5921"\w* vestiduras sucias». \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w le|strong="H5921"\w* dijo: «\w Mira|strong="H7200"\w* \w que|strong="H5921"\w* he hecho \w pasar|strong="H5674"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* tu \w iniquidad|strong="H5771"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w vestiré|strong="H3847"\w* \w con|strong="H5921"\w* vestiduras \w de|strong="H5921"\w* \w gala|strong="H4254"\w*».   
\p
\v 5 Entonces dije: «\w Que|strong="H5921"\w* \w le|strong="H5921"\w* \w pongan|strong="H7760"\w* un turbante \w limpio|strong="H2889"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w*».  
\p Así \w le|strong="H5921"\w* \w pusieron|strong="H7760"\w* un turbante \w limpio|strong="H2889"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* vistieron; \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w ángel|strong="H4397"\w* \w de|strong="H5921"\w* Yahvé \w estaba|strong="H5975"\w* presente.   
\p
\v 6 El \w ángel|strong="H4397"\w* de Yahvé dio testimonio \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, diciendo:  
\v 7 “Yahvé \w de|strong="H5414"\w* los \w Ejércitos|strong="H6635"\w* dice: ‘\w Si|strong="H1571"\w* andas \w en|strong="H5975"\w* \w mis|strong="H5414"\w* \w caminos|strong="H1870"\w*, \w y|strong="H1571"\w* \w si|strong="H1571"\w* \w guardas|strong="H8104"\w* \w mis|strong="H5414"\w* ordenanzas, \w entonces|strong="H1571"\w* tú \w también|strong="H1571"\w* gobernarás mi \w casa|strong="H1004"\w* \w y|strong="H1571"\w* \w guardarás|strong="H8104"\w* \w mis|strong="H5414"\w* \w atrios|strong="H2691"\w*, \w y|strong="H1571"\w* te \w daré|strong="H5414"\w* lugar \w de|strong="H5414"\w* acceso entre \w estos|strong="H1571"\w* \w que|strong="H1571"\w* están \w aquí|strong="H3541"\w* \w presentes|strong="H5975"\w*’.  
\v 8 \w Escucha|strong="H8085"\w* \w ahora|strong="H4994"\w*, \w Josué|strong="H3091"\w*, \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w*, tú \w y|strong="H3588"\w* tus \w compañeros|strong="H7453"\w* \w que|strong="H3588"\w* \w se|strong="H1992"\w* sientan \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti, \w porque|strong="H3588"\w* \w son|strong="H3588"\w* hombres \w que|strong="H3588"\w* sirven \w de|strong="H3588"\w* señal; \w pues|strong="H3588"\w* he \w aquí|strong="H2005"\w*, \w yo|strong="H3588"\w* traigo \w a|strong="H3068"\w* \w mi|strong="H4994"\w* \w siervo|strong="H5650"\w*, \w el|strong="H3588"\w* \w Renuevo|strong="H6780"\w*.  
\v 9 \w Porque|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w la|strong="H1931"\w* piedra \w que|strong="H3588"\w* he \w puesto|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Josué|strong="H3091"\w*: \w en|strong="H5921"\w* una sola piedra hay \w siete|strong="H7651"\w* \w ojos|strong="H5869"\w*; he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* grabaré \w su|strong="H1931"\w* inscripción’, \w dice|strong="H5002"\w* \w el|strong="H1931"\w* \w Señor|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w*, ‘\w y|strong="H3588"\w* quitaré \w la|strong="H1931"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H5921"\w* \w esta|strong="H1931"\w* tierra \w en|strong="H5921"\w* un \w solo|strong="H1931"\w* \w día|strong="H3117"\w*.  
\v 10 \w En|strong="H8478"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* — \w dice|strong="H5002"\w* \w el|strong="H1931"\w* \w Señor|strong="H3068"\w* \w de|strong="H8478"\w* \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w* — invitaréis \w cada|strong="H3117"\w* uno \w a|strong="H3068"\w* vuestro \w prójimo|strong="H7453"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w la|strong="H1931"\w* \w vid|strong="H1612"\w* y \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w la|strong="H1931"\w* higuera”.   
\c 4
\p
\v 1 El \w ángel|strong="H4397"\w* que \w hablaba|strong="H1696"\w* conmigo \w volvió|strong="H7725"\w* y me \w despertó|strong="H5782"\w*, como \w a|strong="H3068"\w* un hombre \w a|strong="H3068"\w* quien se \w despierta|strong="H5782"\w* de su \w sueño|strong="H8142"\w*.  
\v 2 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* preguntó: «¿\w Qué|strong="H4100"\w* \w ves|strong="H7200"\w*?».  
\p \w Yo|strong="H2009"\w* respondí: «He mirado, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* un candelabro \w todo|strong="H3605"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w con|strong="H5921"\w* su depósito \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w y|strong="H5921"\w* sus \w siete|strong="H7651"\w* \w lámparas|strong="H5216"\w* \w encima|strong="H5921"\w*; hay \w siete|strong="H7651"\w* caños \w para|strong="H5921"\w* \w cada|strong="H3605"\w* una \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w lámparas|strong="H5216"\w* \w que|strong="H4100"\w* \w están|strong="H2009"\w* \w en|strong="H5921"\w* su parte superior.  
\v 3 \w Y|strong="H3068"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* hay \w dos|strong="H8147"\w* olivos, uno \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w del|strong="H5921"\w* depósito \w y|strong="H5921"\w* \w el|strong="H5921"\w* otro \w a|strong="H3068"\w* su \w izquierda|strong="H8040"\w*».   
\p
\v 4 \w Proseguí|strong="H6030"\w* y \w hablé|strong="H1696"\w* al \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo, \w diciendo|strong="H1696"\w*: «¿\w Qué|strong="H4100"\w* es esto, \w mi|strong="H6030"\w* señor?».   
\p
\v 5 \w El|strong="H1992"\w* \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo me \w respondió|strong="H6030"\w*: «¿\w No|strong="H3808"\w* \w sabes|strong="H3045"\w* \w qué|strong="H4100"\w* es esto?».  
\p Yo \w dije|strong="H1696"\w*: «\w No|strong="H3808"\w*, \w mi|strong="H6030"\w* señor».   
\p
\v 6 \w Entonces|strong="H3588"\w* \w él|strong="H3588"\w* \w respondió|strong="H6030"\w* \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w habló|strong="H1697"\w* diciendo: “\w Esta|strong="H2088"\w* \w es|strong="H2088"\w* \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé \w para|strong="H3588"\w* \w Zorobabel|strong="H2216"\w*, \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w dice|strong="H1697"\w*: ‘\w No|strong="H3808"\w* \w con|strong="H3588"\w* \w fuerza|strong="H3581"\w*, \w ni|strong="H3808"\w* \w con|strong="H3588"\w* \w poder|strong="H3581"\w*, \w sino|strong="H3588"\w* \w con|strong="H3588"\w* \w mi|strong="H6030"\w* \w Espíritu|strong="H7307"\w*’, \w dice|strong="H1697"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w*.  
\v 7 ¿\w Quién|strong="H4310"\w* eres tú, \w gran|strong="H1419"\w* montaña? \w Ante|strong="H6440"\w* \w Zorobabel|strong="H2216"\w* te convertirás \w en|strong="H3318"\w* llanura; y \w él|strong="H4310"\w* \w sacará|strong="H3318"\w* la piedra \w principal|strong="H1419"\w* entre aclamaciones \w de|strong="H6440"\w*: ‘¡\w Gracia|strong="H2580"\w*, \w gracia|strong="H2580"\w* \w a|strong="H3068"\w* ella!’”.   
\p
\v 8 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé, diciendo:  
\v 9 «Las \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w Zorobabel|strong="H2216"\w* han \w puesto|strong="H3588"\w* \w los|strong="H3588"\w* \w cimientos|strong="H3245"\w* \w de|strong="H3588"\w* \w esta|strong="H2088"\w* \w casa|strong="H1004"\w*, \w y|strong="H3588"\w* sus propias \w manos|strong="H3027"\w* \w la|strong="H3588"\w* terminarán; \w así|strong="H2088"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w* \w me|strong="H3588"\w* ha \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* vosotros.  
\v 10 \w Pues|strong="H3588"\w*, ¿\w quién|strong="H4310"\w* desprecia \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* modestos comienzos? \w Porque|strong="H3588"\w* \w estos|strong="H1992"\w* \w siete|strong="H7651"\w* \w se|strong="H1992"\w* alegrarán al \w ver|strong="H7200"\w* \w la|strong="H3588"\w* plomada \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w Zorobabel|strong="H2216"\w*. \w Estos|strong="H1992"\w* \w son|strong="H3588"\w* \w los|strong="H1992"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* Yahvé, \w que|strong="H3588"\w* \w recorren|strong="H7751"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra».   
\p
\v 11 Entonces \w le|strong="H5921"\w* pregunté: «¿\w Qué|strong="H4100"\w* son esos \w dos|strong="H8147"\w* olivos \w que|strong="H4100"\w* están \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w* \w del|strong="H5921"\w* candelabro?».   
\p
\v 12 \w Le|strong="H5921"\w* pregunté \w por|strong="H5921"\w* \w segunda|strong="H8145"\w* vez: «¿\w Qué|strong="H4100"\w* son estas \w dos|strong="H8147"\w* \w ramas|strong="H7641"\w* \w de|strong="H5921"\w* olivo \w que|strong="H4100"\w* están \w al|strong="H5921"\w* \w lado|strong="H8145"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w tubos|strong="H6804"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w que|strong="H4100"\w* \w vierten|strong="H7324"\w* \w de|strong="H5921"\w* \w sí|strong="H5921"\w* \w el|strong="H5921"\w* aceite \w de|strong="H5921"\w* \w oro|strong="H2091"\w*?».   
\p
\v 13 Él me respondió: «¿\w No|strong="H3808"\w* \w sabes|strong="H3045"\w* \w qué|strong="H4100"\w* \w son|strong="H3808"\w*?».  
\p Yo dije: «\w No|strong="H3808"\w*, mi señor».   
\p
\v 14 Entonces dijo: «\w Estos|strong="H3605"\w* son \w los|strong="H1121"\w* \w dos|strong="H8147"\w* ungidos \w que|strong="H5921"\w* están ante \w el|strong="H5921"\w* Señor \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra».   
\c 5
\p
\v 1 \w Entonces|strong="H7725"\w* \w volví|strong="H7725"\w* \w a|strong="H3068"\w* alzar los \w ojos|strong="H5869"\w* y \w vi|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* un \w rollo|strong="H4039"\w* \w volador|strong="H5774"\w*.  
\v 2 \w Y|strong="H3068"\w* me preguntó: «¿\w Qué|strong="H4100"\w* \w ves|strong="H7200"\w*?».  
\p Respondí: «\w Veo|strong="H7200"\w* un \w rollo|strong="H4039"\w* \w volador|strong="H5774"\w*; su longitud es de \w veinte|strong="H6242"\w* codos, y su \w anchura|strong="H7341"\w* de \w diez|strong="H6235"\w* codos».   
\p
\v 3 \w Entonces|strong="H3588"\w* \w me|strong="H5921"\w* dijo: «\w Esta|strong="H2063"\w* \w es|strong="H2088"\w* \w la|strong="H5921"\w* maldición \w que|strong="H3588"\w* \w sale|strong="H3318"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra; \w porque|strong="H3588"\w* \w aquel|strong="H2088"\w* \w que|strong="H3588"\w* robe será destruido \w según|strong="H5921"\w* \w lo|strong="H2088"\w* escrito \w en|strong="H5921"\w* un lado; \w y|strong="H3588"\w* \w aquel|strong="H2088"\w* \w que|strong="H3588"\w* \w jure|strong="H7650"\w* \w en|strong="H5921"\w* falso será destruido \w según|strong="H5921"\w* \w lo|strong="H2088"\w* escrito \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w otro|strong="H2088"\w* lado.  
\v 4 Yo la haré \w salir|strong="H3318"\w* — \w dice|strong="H5002"\w* \w el|strong="H3885"\w* \w Señor|strong="H3068"\w* de los \w Ejércitos|strong="H6635"\w* — y entrará \w en|strong="H8432"\w* la \w casa|strong="H1004"\w* del \w ladrón|strong="H1590"\w* y \w en|strong="H8432"\w* la \w casa|strong="H1004"\w* de aquel que \w jura|strong="H7650"\w* \w en|strong="H8432"\w* \w falso|strong="H8267"\w* por mi \w nombre|strong="H8034"\w*; y permanecerá \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de su \w casa|strong="H1004"\w*, y la \w consumirá|strong="H3615"\w* con su \w madera|strong="H6086"\w* y sus piedras».   
\p
\v 5 Entonces el \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo \w se|strong="H4100"\w* adelantó y me \w dijo|strong="H1696"\w*: «\w Alza|strong="H5375"\w* \w ahora|strong="H4994"\w* tus \w ojos|strong="H5869"\w* y \w mira|strong="H7200"\w* \w qué|strong="H4100"\w* \w es|strong="H2063"\w* \w esto|strong="H2063"\w* \w que|strong="H4100"\w* aparece».   
\p
\v 6 Yo pregunté: «¿\w Qué|strong="H4100"\w* \w es|strong="H1931"\w*?».  
\p \w Él|strong="H1931"\w* dijo: «\w Esta|strong="H2063"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* cesta \w de|strong="H5869"\w* un efa \w que|strong="H4100"\w* aparece». Además dijo: «\w Esta|strong="H2063"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* iniquidad \w de|strong="H5869"\w* \w ellos|strong="H1931"\w* \w en|strong="H3318"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra».  
\v 7 \w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* que se \w levantó|strong="H5375"\w* una tapa de plomo que pesaba un talento, y había una mujer sentada \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w la|strong="H2063"\w* cesta del efa.  
\v 8 Él dijo: «\w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w maldad|strong="H7564"\w*»; y \w la|strong="H2063"\w* arrojó \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w la|strong="H2063"\w* cesta, y lanzó el peso de plomo sobre \w la|strong="H2063"\w* \w boca|strong="H6310"\w* de \w esta|strong="H2063"\w*.   
\p
\v 9 \w Entonces|strong="H2007"\w* \w alcé|strong="H5375"\w* los \w ojos|strong="H5869"\w* y \w vi|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* que aparecieron \w dos|strong="H8147"\w* mujeres; el \w viento|strong="H7307"\w* soplaba \w en|strong="H3318"\w* sus \w alas|strong="H3671"\w*, \w pues|strong="H7200"\w* tenían \w alas|strong="H3671"\w* \w como|strong="H2007"\w* \w de|strong="H5869"\w* cigüeña, y levantaron la cesta entre la tierra y el \w cielo|strong="H8064"\w*.  
\v 10 Entonces pregunté al \w ángel|strong="H4397"\w* \w que|strong="H1992"\w* \w hablaba|strong="H1696"\w* conmigo: «¿\w A|strong="H3068"\w* dónde \w llevan|strong="H3212"\w* \w estas|strong="H1992"\w* la cesta del efa?».   
\p
\v 11 \w Él|strong="H5921"\w* \w me|strong="H5921"\w* respondió: «\w A|strong="H3068"\w* edificarle una \w casa|strong="H1004"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Sinar; \w y|strong="H5921"\w* cuando esté preparada, será asentada \w allí|strong="H8033"\w* \w en|strong="H5921"\w* su propio lugar».   
\c 6
\p
\v 1 \w Volví|strong="H7725"\w* \w a|strong="H3068"\w* alzar los \w ojos|strong="H5869"\w* y \w miré|strong="H7200"\w*, y he \w aquí|strong="H2009"\w* que cuatro \w carros|strong="H4818"\w* \w salían|strong="H3318"\w* \w de|strong="H5869"\w* entre \w dos|strong="H8147"\w* \w montes|strong="H2022"\w*; y los \w montes|strong="H2022"\w* eran \w de|strong="H5869"\w* bronce.  
\v 2 En el \w primer|strong="H7223"\w* \w carro|strong="H4818"\w* había \w caballos|strong="H5483"\w* rojos. En el \w segundo|strong="H8145"\w* \w carro|strong="H4818"\w* había \w caballos|strong="H5483"\w* \w negros|strong="H7838"\w*.  
\v 3 En el tercer \w carro|strong="H4818"\w* había \w caballos|strong="H5483"\w* \w blancos|strong="H3836"\w*. En el \w cuarto|strong="H7243"\w* \w carro|strong="H4818"\w* había \w caballos|strong="H5483"\w* tordos, todos ellos poderosos.  
\v 4 Entonces pregunté al \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo: «¿\w Qué|strong="H4100"\w* son estos, \w mi|strong="H6030"\w* señor?».   
\p
\v 5 \w El|strong="H5921"\w* \w ángel|strong="H4397"\w* \w me|strong="H5921"\w* \w respondió|strong="H6030"\w*: «\w Estos|strong="H3605"\w* son \w los|strong="H5921"\w* cuatro \w vientos|strong="H7307"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w que|strong="H5921"\w* \w salen|strong="H3318"\w* tras haberse presentado ante \w el|strong="H5921"\w* Señor \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.  
\v 6 El de los \w caballos|strong="H5483"\w* \w negros|strong="H7838"\w* \w sale|strong="H3318"\w* hacia el país del \w norte|strong="H6828"\w*, el \w blanco|strong="H3836"\w* \w salió|strong="H3318"\w* tras ellos, y el tordo \w salió|strong="H3318"\w* hacia el país del sur».  
\v 7 Los fuertes \w salieron|strong="H3318"\w* y \w buscaron|strong="H1245"\w* recorrer la tierra de un lado \w a|strong="H3068"\w* otro. Él les dijo: «¡\w Id|strong="H3212"\w*, \w recorred|strong="H1980"\w* la tierra!». Así que recorrieron la tierra de un lado \w a|strong="H3068"\w* otro.   
\p
\v 8 Entonces me \w llamó|strong="H2199"\w* y me \w habló|strong="H1696"\w* \w diciendo|strong="H1696"\w*: «He aquí que los que van hacia el país del \w norte|strong="H6828"\w* han aplacado mi \w espíritu|strong="H7307"\w* \w en|strong="H3318"\w* la tierra del \w norte|strong="H6828"\w*».   
\p
\v 9 La \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w*, diciendo:  
\v 10 “\w Tomad|strong="H3947"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* del \w cautiverio|strong="H1473"\w*, \w de|strong="H1121"\w* Heldai, \w de|strong="H1121"\w* \w Tobías|strong="H2900"\w* y \w de|strong="H1121"\w* \w Jedaías|strong="H3048"\w*; venid \w el|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w* y entrad en \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Sofonías|strong="H6846"\w*, adonde han llegado \w de|strong="H1121"\w* Babilonia.  
\v 11 \w Tomad|strong="H3947"\w*, pues, \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w*, \w haced|strong="H6213"\w* \w coronas|strong="H5850"\w* y \w ponedlas|strong="H7760"\w* sobre la \w cabeza|strong="H7218"\w* del \w sumo|strong="H7218"\w* \w sacerdote|strong="H3548"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Josadac;  
\v 12 \w y|strong="H3541"\w* habladle diciendo: “\w Así|strong="H3541"\w* dice el \w Señor|strong="H3068"\w* \w de|strong="H8478"\w* los \w Ejércitos|strong="H6635"\w*: ‘He \w aquí|strong="H2009"\w* el hombre cuyo \w nombre|strong="H8034"\w* \w es|strong="H3541"\w* el \w Renuevo|strong="H6780"\w*; él \w brotará|strong="H6779"\w* \w de|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w y|strong="H3541"\w* \w edificará|strong="H1129"\w* el \w templo|strong="H1964"\w* \w de|strong="H8478"\w* Yahvé’.  
\v 13 \w Él|strong="H1931"\w* \w edificará|strong="H1129"\w* \w el|strong="H1931"\w* \w templo|strong="H1964"\w* \w de|strong="H5921"\w* Yahvé. Ostentará majestad, \w y|strong="H5921"\w* \w se|strong="H1961"\w* sentará \w y|strong="H5921"\w* gobernará \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w trono|strong="H3678"\w*. \w Será|strong="H1961"\w* \w sacerdote|strong="H3548"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w trono|strong="H3678"\w*, \w y|strong="H5921"\w* \w el|strong="H1931"\w* \w consejo|strong="H6098"\w* \w de|strong="H5921"\w* \w paz|strong="H7965"\w* \w estará|strong="H1961"\w* \w entre|strong="H5921"\w* \w ambos|strong="H8147"\w*.  
\v 14 Las \w coronas|strong="H5850"\w* \w serán|strong="H1961"\w* \w para|strong="H1961"\w* Helem, \w Tobías|strong="H2900"\w*, \w Jedaías|strong="H3048"\w* y Hen, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Sofonías|strong="H6846"\w*, \w como|strong="H1961"\w* \w memoria|strong="H2146"\w* en \w el|strong="H1121"\w* \w templo|strong="H1964"\w* \w de|strong="H1121"\w* Yahvé.   
\p
\v 15 \w Los|strong="H1961"\w* \w que|strong="H3588"\w* \w están|strong="H1961"\w* \w lejos|strong="H7350"\w* vendrán \w y|strong="H3588"\w* trabajarán \w en|strong="H3588"\w* \w la|strong="H3588"\w* edificación del \w templo|strong="H1964"\w* \w de|strong="H3588"\w* Yahvé; \w y|strong="H3588"\w* \w sabréis|strong="H3045"\w* \w que|strong="H3588"\w* Yahvé \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w* \w me|strong="H3588"\w* ha \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* \w vosotros|strong="H8085"\w*. Esto \w sucederá|strong="H1961"\w* \w si|strong="H3588"\w* obedecéis diligentemente \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* Yahvé vuestro \w Dios|strong="H3068"\w*”.   
\c 7
\p
\v 1 En el cuarto \w año|strong="H8141"\w* del \w rey|strong="H4428"\w* \w Darío|strong="H1867"\w*, la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé llegó \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w* en el cuarto día del \w noveno|strong="H8671"\w* \w mes|strong="H2320"\w*, el \w mes|strong="H2320"\w* \w de|strong="H1697"\w* Quisleu.  
\v 2 \w El|strong="H1008"\w* pueblo \w de|strong="H6440"\w* Betel \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Sarezer y \w a|strong="H3068"\w* Regem Melec y \w a|strong="H3068"\w* sus hombres \w a|strong="H3068"\w* implorar \w el|strong="H1008"\w* favor \w de|strong="H6440"\w* Yahvé,  
\v 3 y \w a|strong="H3068"\w* hablar con los \w sacerdotes|strong="H3548"\w* de la \w casa|strong="H1004"\w* de Yahvé de los \w Ejércitos|strong="H6635"\w* y con los \w profetas|strong="H5030"\w*, diciendo: «¿Debo llorar en \w el|strong="H6213"\w* \w quinto|strong="H2549"\w* \w mes|strong="H2320"\w*, separándome, \w como|strong="H4100"\w* he \w hecho|strong="H6213"\w* durante tantos \w años|strong="H8141"\w*?».   
\p
\v 4 Entonces \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w de|strong="H1697"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w*, diciendo:  
\v 5 “Habla \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w*, diciendo: ‘\w Cuando|strong="H3588"\w* \w ayunasteis|strong="H6684"\w* \w y|strong="H3588"\w* llorasteis \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w quinto|strong="H2549"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w séptimo|strong="H7637"\w* mes durante \w estos|strong="H2088"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*, ¿habéis ayunado \w en|strong="H3588"\w* absoluto \w para|strong="H3588"\w* mí, realmente \w para|strong="H3588"\w* mí?  
\v 6 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* coméis \w y|strong="H3588"\w* \w cuando|strong="H3588"\w* \w bebéis|strong="H8354"\w*, ¿\w no|strong="H3808"\w* coméis \w para|strong="H3588"\w* vosotros mismos \w y|strong="H3588"\w* \w bebéis|strong="H8354"\w* \w para|strong="H3588"\w* vosotros mismos?  
\v 7 ¿\w No|strong="H3808"\w* \w son|strong="H1961"\w* estas las \w palabras|strong="H1697"\w* \w que|strong="H3808"\w* Yahvé \w proclamó|strong="H7121"\w* \w por|strong="H1697"\w* \w medio|strong="H3027"\w* \w de|strong="H1697"\w* \w los|strong="H3427"\w* antiguos \w profetas|strong="H5030"\w*, \w cuando|strong="H1961"\w* Jerusalén \w estaba|strong="H1961"\w* \w habitada|strong="H3427"\w* y en prosperidad, con sus \w ciudades|strong="H5892"\w* \w alrededor|strong="H5439"\w*, y \w el|strong="H5030"\w* Neguev y la llanura \w estaban|strong="H1961"\w* habitados?’”.   
\p
\v 8 La \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Yahvé \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w*, diciendo:  
\v 9 “\w Así|strong="H3541"\w* \w ha|strong="H3541"\w* hablado Yahvé de los \w Ejércitos|strong="H6635"\w*, diciendo: ‘\w Ejecutad|strong="H6213"\w* \w el|strong="H6213"\w* \w juicio|strong="H4941"\w* verdadero, \w y|strong="H3541"\w* mostrad bondad \w y|strong="H3541"\w* compasión cada uno con su hermano.  
\v 10 No oprimáis \w a|strong="H3068"\w* la viuda, ni al \w huérfano|strong="H3490"\w*, ni al \w extranjero|strong="H1616"\w*, ni al \w pobre|strong="H6041"\w*; y \w que|strong="H1616"\w* ninguno \w de|strong="H7451"\w* vosotros \w piense|strong="H2803"\w* en su \w corazón|strong="H3824"\w* el \w mal|strong="H7451"\w* contra su hermano’.  
\v 11 Pero \w no|strong="H3985"\w* \w quisieron|strong="H3985"\w* \w escuchar|strong="H8085"\w*, y volvieron la espalda, y se taparon los \w oídos|strong="H8085"\w* \w para|strong="H5414"\w* \w no|strong="H3985"\w* \w oír|strong="H8085"\w*.  
\v 12 \w Sí|strong="H1961"\w*, endurecieron su \w corazón|strong="H3820"\w* \w como|strong="H1961"\w* \w el|strong="H5030"\w* pedernal, \w para|strong="H1961"\w* \w no|strong="H1961"\w* \w oír|strong="H8085"\w* la \w ley|strong="H8451"\w* ni las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w el|strong="H5030"\w* \w Señor|strong="H3068"\w* \w de|strong="H1697"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w* \w había|strong="H1961"\w* \w enviado|strong="H7971"\w* \w por|strong="H1697"\w* su \w Espíritu|strong="H7307"\w* \w a|strong="H3068"\w* través \w de|strong="H1697"\w* \w los|strong="H1961"\w* antiguos \w profetas|strong="H5030"\w*. \w Por|strong="H1697"\w* eso \w vino|strong="H1961"\w* una \w gran|strong="H1419"\w* \w ira|strong="H7110"\w* \w de|strong="H1697"\w* parte del \w Señor|strong="H3068"\w* \w de|strong="H1697"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w*.  
\v 13 \w Sucedió|strong="H1961"\w* \w que|strong="H3808"\w*, \w como|strong="H1961"\w* él \w llamó|strong="H7121"\w* y ellos \w no|strong="H3808"\w* quisieron \w escuchar|strong="H8085"\w*, \w así|strong="H3651"\w* \w llamarán|strong="H7121"\w* y yo \w no|strong="H3808"\w* \w escucharé|strong="H8085"\w*”, dijo el \w Señor|strong="H3068"\w* de \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w*;  
\v 14 «\w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w los|strong="H5921"\w* dispersaré \w con|strong="H5921"\w* un torbellino \w entre|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* han \w conocido|strong="H3045"\w*. Así, \w la|strong="H5921"\w* tierra quedó desolada tras \w ellos|strong="H5921"\w*, \w de|strong="H5921"\w* modo \w que|strong="H3808"\w* \w nadie|strong="H3808"\w* \w pasó|strong="H5674"\w* \w ni|strong="H3808"\w* regresó; \w porque|strong="H5921"\w* convirtieron \w en|strong="H5921"\w* desierto \w la|strong="H5921"\w* tierra placentera».   
\c 8
\p
\v 1 Me llegó la \w palabra|strong="H1697"\w* del \w Señor|strong="H3068"\w* \w de|strong="H1697"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w*.  
\v 2 Yahvé de los \w Ejércitos|strong="H6635"\w* dice: «Estoy celoso por \w Sión|strong="H6726"\w* \w con|strong="H7065"\w* \w gran|strong="H1419"\w* \w celo|strong="H7068"\w*, \w y|strong="H3541"\w* estoy celoso por ella \w con|strong="H7065"\w* \w gran|strong="H1419"\w* \w ira|strong="H2534"\w*».   
\p
\v 3 Yahvé dice: “He \w vuelto|strong="H7725"\w* \w a|strong="H3068"\w* \w Sión|strong="H6726"\w*, \w y|strong="H3541"\w* \w habitaré|strong="H7931"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de Jerusalén. Jerusalén se \w llamará|strong="H7121"\w* ‘La \w Ciudad|strong="H5892"\w* de la Verdad’; \w y|strong="H3541"\w* el \w monte|strong="H2022"\w* de Yahvé de los \w Ejércitos|strong="H6635"\w*, ‘El \w Monte|strong="H2022"\w* \w Santo|strong="H6944"\w*’”.   
\p
\v 4 \w El|strong="H3427"\w* \w Señor|strong="H3068"\w* \w de|strong="H5750"\w* \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w* dice: «\w Los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w y|strong="H3541"\w* las ancianas volverán \w a|strong="H3068"\w* \w habitar|strong="H3427"\w* las \w calles|strong="H7339"\w* \w de|strong="H5750"\w* Jerusalén, \w cada|strong="H3117"\w* uno con su bastón \w en|strong="H5750"\w* la \w mano|strong="H3027"\w* \w a|strong="H3068"\w* causa \w de|strong="H5750"\w* su vejez.  
\v 5 Las \w calles|strong="H7339"\w* de la \w ciudad|strong="H5892"\w* estarán \w llenas|strong="H4390"\w* de \w niños|strong="H3206"\w* y niñas jugando en sus \w plazas|strong="H7339"\w*».   
\p
\v 6 \w Dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w Ejércitos|strong="H6635"\w*: «\w Si|strong="H3588"\w* \w esto|strong="H2088"\w* parece maravilloso \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w ojos|strong="H5869"\w* del remanente \w de|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w en|strong="H3588"\w* esos \w días|strong="H3117"\w*, ¿\w lo|strong="H2088"\w* será \w también|strong="H1571"\w* \w a|strong="H3068"\w* mis \w ojos|strong="H5869"\w*?», \w dice|strong="H5002"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w Ejércitos|strong="H6635"\w*.   
\p
\v 7 El \w Señor|strong="H3068"\w* \w de|strong="H5971"\w* los \w Ejércitos|strong="H6635"\w* dice: «He \w aquí|strong="H3541"\w* \w que|strong="H5971"\w* yo \w salvaré|strong="H3467"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* del país \w oriental|strong="H4217"\w* \w y|strong="H3541"\w* del país occidental.  
\v 8 Lo traeré y \w habitará|strong="H7931"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5971"\w* Jerusalén. Ellos \w serán|strong="H1961"\w* \w mi|strong="H3389"\w* \w pueblo|strong="H5971"\w*, y yo \w seré|strong="H1961"\w* su Dios, \w en|strong="H8432"\w* verdad y \w en|strong="H8432"\w* \w justicia|strong="H6666"\w*».   
\p
\v 9 \w Dice|strong="H1697"\w* Yahvé \w de|strong="H1697"\w* los \w Ejércitos|strong="H6635"\w*: «Fortaleced \w vuestras|strong="H1697"\w* \w manos|strong="H3027"\w*, \w vosotros|strong="H8085"\w* \w que|strong="H1697"\w* oís en estos \w días|strong="H3117"\w* estas \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w boca|strong="H6310"\w* \w de|strong="H1697"\w* los \w profetas|strong="H5030"\w*, desde \w el|strong="H5030"\w* \w día|strong="H3117"\w* en \w que|strong="H1697"\w* se pusieron los \w cimientos|strong="H3245"\w* \w de|strong="H1697"\w* la \w casa|strong="H1004"\w* \w de|strong="H1697"\w* Yahvé \w de|strong="H1697"\w* los \w Ejércitos|strong="H6635"\w*, \w el|strong="H5030"\w* \w templo|strong="H1964"\w*, para \w que|strong="H1697"\w* fuera \w edificado|strong="H1129"\w*.  
\v 10 \w Porque|strong="H3588"\w* \w antes|strong="H6440"\w* \w de|strong="H4480"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w no|strong="H3808"\w* \w había|strong="H1961"\w* \w paga|strong="H7939"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w ni|strong="H3808"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* animal, \w ni|strong="H3808"\w* \w había|strong="H1961"\w* \w paz|strong="H7965"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w salía|strong="H3318"\w* \w o|strong="H3068"\w* entraba \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w del|strong="H4480"\w* adversario; \w porque|strong="H3588"\w* \w yo|strong="H4480"\w* puse \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* hombres \w contra|strong="H6440"\w* \w su|strong="H1992"\w* \w prójimo|strong="H7453"\w*.  
\v 11 Pero \w ahora|strong="H6258"\w* \w no|strong="H3808"\w* \w seré|strong="H3808"\w* con el remanente \w de|strong="H5971"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* como en los \w días|strong="H3117"\w* anteriores», \w dice|strong="H5002"\w* el \w Señor|strong="H3068"\w* \w de|strong="H5971"\w* los \w Ejércitos|strong="H6635"\w*.  
\v 12 «\w Porque|strong="H3588"\w* habrá \w simiente|strong="H2233"\w* \w de|strong="H3588"\w* \w paz|strong="H7965"\w*; \w la|strong="H3588"\w* \w vid|strong="H1612"\w* \w dará|strong="H5414"\w* \w su|strong="H3588"\w* \w fruto|strong="H6529"\w*, \w la|strong="H3588"\w* tierra \w dará|strong="H5414"\w* \w su|strong="H3588"\w* producto \w y|strong="H3588"\w* \w los|strong="H3605"\w* \w cielos|strong="H8064"\w* \w darán|strong="H5414"\w* \w su|strong="H3588"\w* \w rocío|strong="H2919"\w*. \w Yo|strong="H3588"\w* \w haré|strong="H5414"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* remanente \w de|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* herede \w todas|strong="H3605"\w* \w estas|strong="H2088"\w* cosas.  
\v 13 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H1961"\w*, \w así|strong="H3651"\w* \w como|strong="H1961"\w* \w fuisteis|strong="H1961"\w* una \w maldición|strong="H7045"\w* entre las \w naciones|strong="H1471"\w*, \w casa|strong="H1004"\w* \w de|strong="H3372"\w* \w Judá|strong="H3063"\w* y \w casa|strong="H1004"\w* \w de|strong="H3372"\w* \w Israel|strong="H3478"\w*, \w así|strong="H3651"\w* os \w salvaré|strong="H3467"\w* y \w seréis|strong="H1961"\w* una \w bendición|strong="H1293"\w*. \w No|strong="H1961"\w* tengáis \w miedo|strong="H3372"\w*; \w que|strong="H1961"\w* vuestras \w manos|strong="H3027"\w* \w sean|strong="H1961"\w* fuertes».   
\p
\v 14 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w* dice: «\w Así|strong="H3541"\w* \w como|strong="H3588"\w* \w pensé|strong="H2161"\w* haceros \w mal|strong="H7489"\w* \w cuando|strong="H3588"\w* vuestros padres \w me|strong="H3588"\w* provocaron \w a|strong="H3068"\w* ira — dice \w el|strong="H3588"\w* \w Señor|strong="H3068"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w Ejércitos|strong="H6635"\w* — \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* arrepentí,  
\v 15 \w así|strong="H3651"\w* he \w vuelto|strong="H7725"\w* \w a|strong="H3068"\w* pensar en estos \w días|strong="H3117"\w* en hacer \w bien|strong="H3190"\w* \w a|strong="H3068"\w* Jerusalén y \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H3372"\w* \w Judá|strong="H3063"\w*. No tengáis \w miedo|strong="H3372"\w*.  
\v 16 \w Estas|strong="H6213"\w* son las \w cosas|strong="H1697"\w* \w que|strong="H1697"\w* habéis \w de|strong="H1697"\w* \w hacer|strong="H6213"\w*: \w hablad|strong="H1696"\w* verdad \w cada|strong="H1697"\w* uno con su \w prójimo|strong="H7453"\w*. \w Ejecutad|strong="H6213"\w* \w el|strong="H6213"\w* \w juicio|strong="H4941"\w* \w de|strong="H1697"\w* la verdad y \w de|strong="H1697"\w* la \w paz|strong="H7965"\w* en \w vuestras|strong="H1697"\w* \w puertas|strong="H8179"\w*,  
\v 17 \w y|strong="H3588"\w* \w ninguno|strong="H3605"\w* \w de|strong="H3588"\w* vosotros maquine \w mal|strong="H7451"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w corazón|strong="H3824"\w* contra \w su|strong="H3588"\w* \w prójimo|strong="H7453"\w*, ni améis \w el|strong="H3588"\w* \w juramento|strong="H7621"\w* \w falso|strong="H8267"\w*; \w porque|strong="H3588"\w* \w todas|strong="H3605"\w* estas \w son|strong="H3588"\w* \w cosas|strong="H7451"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w aborrezco|strong="H8130"\w*», \w dice|strong="H5002"\w* Yahvé.   
\p
\v 18 Me llegó la \w palabra|strong="H1697"\w* del \w Señor|strong="H3068"\w* \w de|strong="H1697"\w* \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w*.  
\v 19 Dice el \w Señor|strong="H3068"\w* de \w los|strong="H1961"\w* \w Ejércitos|strong="H6635"\w*: «\w Los|strong="H1961"\w* ayunos de \w los|strong="H1961"\w* meses \w cuarto|strong="H7243"\w*, \w quinto|strong="H2549"\w*, \w séptimo|strong="H7637"\w* \w y|strong="H3541"\w* \w décimo|strong="H6224"\w* \w se|strong="H1961"\w* convertirán \w para|strong="H1961"\w* la \w casa|strong="H1004"\w* de \w Judá|strong="H3063"\w* en \w alegría|strong="H8057"\w*, \w gozo|strong="H8057"\w* \w y|strong="H3541"\w* fiestas solemnes. Amad, \w pues|strong="H1961"\w*, la verdad \w y|strong="H3541"\w* la \w paz|strong="H7965"\w*».   
\p
\v 20 Dice \w el|strong="H3427"\w* \w Señor|strong="H3068"\w* \w de|strong="H5750"\w* \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w*: “\w Todavía|strong="H5750"\w* vendrán \w pueblos|strong="H5971"\w* \w y|strong="H3541"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5750"\w* \w muchas|strong="H7227"\w* \w ciudades|strong="H5892"\w*.  
\v 21 \w Los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H6440"\w* una ciudad \w irán|strong="H3212"\w* \w a|strong="H3068"\w* otra, diciendo: ‘\w Vayamos|strong="H3212"\w* pronto \w a|strong="H3068"\w* suplicar \w el|strong="H3427"\w* favor \w de|strong="H6440"\w* Yahvé \w y|strong="H1571"\w* \w a|strong="H3068"\w* buscar \w a|strong="H3068"\w* Yahvé \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w*. Yo \w también|strong="H1571"\w* \w iré|strong="H3212"\w*’.  
\v 22 \w Sí|strong="H6440"\w*, \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* y \w naciones|strong="H1471"\w* \w fuertes|strong="H6099"\w* vendrán \w a|strong="H3068"\w* buscar \w a|strong="H3068"\w* Yahvé \w de|strong="H6440"\w* los \w Ejércitos|strong="H6635"\w* en Jerusalén y \w a|strong="H3068"\w* implorar el favor \w de|strong="H6440"\w* Yahvé”.  
\v 23 Yahvé \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w Ejércitos|strong="H6635"\w* dice: “\w En|strong="H5973"\w* esos \w días|strong="H3117"\w*, \w diez|strong="H6235"\w* hombres \w de|strong="H3588"\w* \w todas|strong="H3605"\w* \w las|strong="H1992"\w* lenguas \w de|strong="H3588"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w* \w se|strong="H1992"\w* agarrarán \w del|strong="H5973"\w* manto \w de|strong="H3588"\w* un \w judío|strong="H3064"\w*, diciendo: ‘\w Iremos|strong="H3212"\w* \w con|strong="H5973"\w* \w vosotros|strong="H8085"\w*, \w porque|strong="H3588"\w* hemos \w oído|strong="H8085"\w* \w que|strong="H3588"\w* \w Dios|strong="H3068"\w* \w está|strong="H1992"\w* \w con|strong="H5973"\w* \w vosotros|strong="H8085"\w*’”.   
\c 9
\p
\v 1 Una revelación.  
\q1 \w La|strong="H3588"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé \w es|strong="H3588"\w* \w contra|strong="H3478"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* Hadrac,  
\q2 \w y|strong="H3588"\w* descansará sobre \w Damasco|strong="H1834"\w* —  
\q1 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w ojo|strong="H5869"\w* del hombre  
\q2 \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* está \w puesto|strong="H3588"\w* \w en|strong="H3588"\w* Yahvé —   
\q1
\v 2 \w y|strong="H1571"\w* \w también|strong="H1571"\w* Hamat, \w que|strong="H3588"\w* limita \w con|strong="H3588"\w* ella,  
\q2 \w y|strong="H1571"\w* \w Tiro|strong="H6865"\w* \w y|strong="H1571"\w* \w Sidón|strong="H6721"\w*, \w aunque|strong="H3588"\w* sean \w muy|strong="H3966"\w* sabias.   
\q1
\v 3 \w Tiro|strong="H6865"\w* se ha \w edificado|strong="H1129"\w* una \w fortaleza|strong="H4692"\w*,  
\q2 ha amontonado \w plata|strong="H3701"\w* como el \w polvo|strong="H6083"\w*,  
\q2 y oro fino como el lodo de las \w calles|strong="H2351"\w*.   
\q1
\v 4 He \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* \w el|strong="H1931"\w* Señor \w la|strong="H1931"\w* desposeerá,  
\q2 y \w herirá|strong="H5221"\w* \w su|strong="H1931"\w* poder \w en|strong="H5221"\w* \w el|strong="H1931"\w* \w mar|strong="H3220"\w*;  
\q2 y \w ella|strong="H1931"\w* \w será|strong="H1931"\w* devorada por \w el|strong="H1931"\w* fuego.   
\b  
\q1
\v 5 Ascalón \w lo|strong="H3808"\w* \w verá|strong="H7200"\w* \w y|strong="H3588"\w* \w temerá|strong="H3372"\w*;  
\q2 \w Gaza|strong="H5804"\w* también, \w y|strong="H3588"\w* \w se|strong="H3808"\w* retorcerá \w de|strong="H3588"\w* \w dolor|strong="H2342"\w*;  
\q2 \w lo|strong="H3808"\w* mismo \w Ecrón|strong="H6138"\w*, \w pues|strong="H3588"\w* \w su|strong="H3588"\w* \w esperanza|strong="H4007"\w* quedará defraudada.  
\q2 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w perecerá|strong="H3808"\w* \w en|strong="H3588"\w* \w Gaza|strong="H5804"\w*,  
\q2 \w y|strong="H3588"\w* Ascalón quedará deshabitada.   
\q1
\v 6 Un pueblo \w bastardo|strong="H4464"\w* \w habitará|strong="H3427"\w* en Asdod,  
\q2 y yo aniquilaré \w el|strong="H3427"\w* orgullo de \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w*.   
\q1
\v 7 \w Quitaré|strong="H5493"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* \w su|strong="H1931"\w* \w boca|strong="H6310"\w*,  
\q2 \w y|strong="H1571"\w* \w sus|strong="H1931"\w* \w abominaciones|strong="H8251"\w* \w de|strong="H1818"\w* entre \w sus|strong="H1931"\w* \w dientes|strong="H8127"\w*.  
\q1 \w También|strong="H1571"\w* \w él|strong="H1931"\w* \w será|strong="H1961"\w* un remanente \w para|strong="H1961"\w* nuestro Dios;  
\q2 \w será|strong="H1961"\w* \w como|strong="H1571"\w* un jefe \w en|strong="H5493"\w* \w Judá|strong="H3063"\w*,  
\q2 \w y|strong="H1571"\w* \w Ecrón|strong="H6138"\w* \w será|strong="H1961"\w* \w como|strong="H1571"\w* \w el|strong="H1931"\w* \w jebuseo|strong="H2983"\w*.   
\q1
\v 8 Acamparé \w alrededor|strong="H5921"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w* \w como|strong="H3588"\w* una guardia,  
\q2 \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w nadie|strong="H3808"\w* \w pase|strong="H5674"\w* \w ni|strong="H3808"\w* \w vuelva|strong="H7725"\w*;  
\q2 \w y|strong="H3588"\w* \w ningún|strong="H3808"\w* opresor \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* \w pasar|strong="H5674"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*,  
\q2 \w pues|strong="H3588"\w* \w ahora|strong="H6258"\w* he \w visto|strong="H7200"\w* \w con|strong="H5921"\w* mis propios \w ojos|strong="H5869"\w*.   
\b  
\q1
\v 9 ¡\w Alégrate|strong="H1523"\w* \w mucho|strong="H3966"\w*, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Sión|strong="H6726"\w*!  
\q2 ¡\w Grita|strong="H7321"\w* \w de|strong="H5921"\w* júbilo, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* Jerusalén!  
\q1 He \w aquí|strong="H2009"\w* \w que|strong="H1931"\w* tu \w Rey|strong="H4428"\w* viene \w a|strong="H3068"\w* \w ti|strong="H5921"\w*.  
\q2 \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w justo|strong="H6662"\w* \w y|strong="H5921"\w* trae salvación;  
\q2 \w humilde|strong="H6041"\w*, \w y|strong="H5921"\w* \w montado|strong="H7392"\w* \w sobre|strong="H5921"\w* un \w asno|strong="H2543"\w*,  
\q2 \w sobre|strong="H5921"\w* un pollino, cría \w de|strong="H5921"\w* asna.   
\q1
\v 10 \w Destruiré|strong="H3772"\w* los \w carros|strong="H7393"\w* \w de|strong="H5704"\w* Efraín  
\q2 \w y|strong="H5704"\w* los \w caballos|strong="H5483"\w* \w de|strong="H5704"\w* Jerusalén.  
\q1 El \w arco|strong="H7198"\w* \w de|strong="H5704"\w* \w guerra|strong="H4421"\w* será quebrado,  
\q2 \w y|strong="H5704"\w* él \w hablará|strong="H1696"\w* \w de|strong="H5704"\w* \w paz|strong="H7965"\w* \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*.  
\q1 Su dominio será \w de|strong="H5704"\w* \w mar|strong="H3220"\w* \w a|strong="H3068"\w* \w mar|strong="H3220"\w*,  
\q2 \w y|strong="H5704"\w* \w desde|strong="H5704"\w* el \w río|strong="H5104"\w* \w hasta|strong="H5704"\w* los confines \w de|strong="H5704"\w* la tierra.   
\b  
\q1
\v 11 En cuanto \w a|strong="H3068"\w* ti,  
\q2 por \w la|strong="H1571"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* tu \w pacto|strong="H1285"\w*,  
\q2 he sacado \w a|strong="H3068"\w* tus prisioneros del pozo en \w el|strong="H1571"\w* \w que|strong="H1571"\w* no hay \w agua|strong="H4325"\w*.   
\q1
\v 12 ¡\w Volved|strong="H7725"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* fortaleza, prisioneros de \w la|strong="H1571"\w* \w esperanza|strong="H8615"\w*!  
\q2 \w Hoy|strong="H3117"\w* \w mismo|strong="H1571"\w* \w anuncio|strong="H5046"\w* \w que|strong="H1571"\w* os devolveré \w el|strong="H1571"\w* doble.   
\q1
\v 13 \w Porque|strong="H3588"\w* he tensado \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w como|strong="H3588"\w* \w mi|strong="H5921"\w* \w arco|strong="H7198"\w*,  
\q2 \w y|strong="H3588"\w* he \w puesto|strong="H3588"\w* \w a|strong="H3068"\w* Efraín \w como|strong="H3588"\w* flecha.  
\q1 Incitaré \w a|strong="H3068"\w* tus \w hijos|strong="H1121"\w*, \w Sión|strong="H6726"\w*,  
\q2 \w contra|strong="H5921"\w* tus \w hijos|strong="H1121"\w*, \w Grecia|strong="H3120"\w*,  
\q2 \w y|strong="H3588"\w* \w te|strong="H5921"\w* \w haré|strong="H7760"\w* \w como|strong="H3588"\w* \w espada|strong="H2719"\w* \w de|strong="H5921"\w* guerrero.   
\b  
\q1
\v 14 Yahvé será \w visto|strong="H7200"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\q2 Su flecha \w saldrá|strong="H3318"\w* \w como|strong="H5921"\w* un rayo.  
\q1 \w El|strong="H5921"\w* \w Señor|strong="H3068"\w* Yahvé \w tocará|strong="H8628"\w* \w la|strong="H5921"\w* \w trompeta|strong="H7782"\w*,  
\q2 \w y|strong="H5921"\w* \w avanzará|strong="H1980"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* torbellinos \w del|strong="H5921"\w* sur.   
\q1
\v 15 \w El|strong="H5921"\w* \w Señor|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* \w los|strong="H5921"\w* protegerá.  
\q2 Devorarán \w y|strong="H5921"\w* pisotearán \w las|strong="H5921"\w* piedras \w de|strong="H5921"\w* \w la|strong="H5921"\w* honda.  
\q1 \w Beberán|strong="H8354"\w* \w y|strong="H5921"\w* rugirán \w como|strong="H3644"\w* excitados \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w vino|strong="H3196"\w*.  
\q2 \w Se|strong="H5921"\w* llenarán \w como|strong="H3644"\w* copas \w de|strong="H5921"\w* sacrificio,  
\q2 \w como|strong="H3644"\w* \w las|strong="H5921"\w* esquinas \w del|strong="H5921"\w* \w altar|strong="H4196"\w*.   
\b  
\q1
\v 16 \w El|strong="H1931"\w* \w Señor|strong="H3068"\w* \w su|strong="H1931"\w* \w Dios|strong="H3068"\w* \w los|strong="H5921"\w* \w salvará|strong="H3467"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w como|strong="H3588"\w* \w al|strong="H5921"\w* \w rebaño|strong="H6629"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*;  
\q2 \w porque|strong="H3588"\w* \w son|strong="H3588"\w* \w como|strong="H3588"\w* joyas \w de|strong="H5921"\w* una corona,  
\q2 centelleando \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* tierra.   
\q1
\v 17 ¡\w Qué|strong="H3588"\w* grande \w es|strong="H3588"\w* \w su|strong="H3588"\w* \w bondad|strong="H2898"\w*  
\q2 \w y|strong="H3588"\w* \w qué|strong="H3588"\w* grande \w es|strong="H3588"\w* \w su|strong="H3588"\w* \w hermosura|strong="H3308"\w*!  
\q1 \w El|strong="H3588"\w* \w trigo|strong="H1715"\w* hará florecer \w a|strong="H3068"\w* \w los|strong="H3588"\w* jóvenes,  
\q2 \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w vino|strong="H8492"\w* nuevo \w a|strong="H3068"\w* las \w doncellas|strong="H1330"\w*.   
\c 10
\q1
\v 1 \w Pedid|strong="H7592"\w* \w a|strong="H3068"\w* Yahvé \w lluvia|strong="H1653"\w* en primavera, Yahvé \w que|strong="H6256"\w* \w hace|strong="H6213"\w* \w las|strong="H1992"\w* nubes \w de|strong="H5414"\w* tormenta; \w él|strong="H6213"\w* os \w dará|strong="H5414"\w* aguaceros \w a|strong="H3068"\w* todos \w para|strong="H5414"\w* la \w hierba|strong="H6212"\w* del \w campo|strong="H7704"\w*.   
\q1
\v 2 \w Porque|strong="H3588"\w* \w los|strong="H5921"\w* terafines han \w hablado|strong="H1696"\w* \w vanidad|strong="H1892"\w*, \w y|strong="H3588"\w* \w los|strong="H5921"\w* \w adivinos|strong="H7080"\w* han visto \w mentira|strong="H8267"\w* \w y|strong="H3588"\w* han contado \w sueños|strong="H2472"\w* \w falsos|strong="H8267"\w*.  
\q1 \w Consuelan|strong="H5162"\w* \w en|strong="H5921"\w* \w vano|strong="H1892"\w*; \w por|strong="H5921"\w* \w lo|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w el|strong="H5921"\w* pueblo vaga \w como|strong="H3588"\w* \w ovejas|strong="H6629"\w*.  
\q2 Están atribulados \w porque|strong="H3588"\w* \w no|strong="H3588"\w* tienen \w pastor|strong="H7462"\w*.   
\b  
\q1
\v 3 \w Mi|strong="H5921"\w* cólera \w se|strong="H5921"\w* ha encendido \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w pastores|strong="H7462"\w*, \w y|strong="H3588"\w* castigaré \w a|strong="H3068"\w* \w los|strong="H5921"\w* machos cabríos; \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Ejércitos|strong="H6635"\w* ha visitado \w su|strong="H3588"\w* rebaño, \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3588"\w* \w los|strong="H5921"\w* \w hará|strong="H7760"\w* \w como|strong="H3588"\w* \w su|strong="H3588"\w* \w caballo|strong="H5483"\w* \w de|strong="H5921"\w* honor \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w*.   
\q1
\v 4 \w De|strong="H4480"\w* \w él|strong="H3605"\w* \w saldrá|strong="H3318"\w* \w la|strong="H3605"\w* piedra \w angular|strong="H6438"\w*, \w de|strong="H4480"\w* \w él|strong="H3605"\w* \w la|strong="H3605"\w* estaca \w de|strong="H4480"\w* \w la|strong="H3605"\w* tienda, \w de|strong="H4480"\w* \w él|strong="H3605"\w* \w el|strong="H3605"\w* \w arco|strong="H7198"\w* \w de|strong="H4480"\w* \w batalla|strong="H4421"\w*, \w de|strong="H4480"\w* \w él|strong="H3605"\w* \w todo|strong="H3605"\w* gobernante.   
\q2
\v 5 \w Serán|strong="H1961"\w* \w como|strong="H3588"\w* \w valientes|strong="H1368"\w* \w que|strong="H3588"\w* pisan \w el|strong="H5973"\w* lodo \w de|strong="H3588"\w* las \w calles|strong="H2351"\w* \w en|strong="H5973"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w*.  
\q1 Lucharán, \w porque|strong="H3588"\w* Yahvé \w estará|strong="H1961"\w* \w con|strong="H5973"\w* ellos; \w y|strong="H3588"\w* \w los|strong="H5973"\w* \w que|strong="H3588"\w* montan \w a|strong="H3068"\w* \w caballo|strong="H5483"\w* \w serán|strong="H1961"\w* \w avergonzados|strong="H3001"\w*.   
\b  
\q1
\v 6 «Fortaleceré \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w salvaré|strong="H3467"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w José|strong="H3130"\w*.  
\q2 \w Los|strong="H1961"\w* haré \w volver|strong="H7725"\w*, \w porque|strong="H3588"\w* tengo \w misericordia|strong="H7355"\w* \w de|strong="H3588"\w* ellos.  
\q1 \w Serán|strong="H1961"\w* \w como|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H1961"\w* hubiera desechado; \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w soy|strong="H1961"\w* Yahvé, \w su|strong="H3588"\w* \w Dios|strong="H3068"\w*, \w y|strong="H3588"\w* \w los|strong="H1961"\w* escucharé.   
\q1
\v 7 Efraín \w será|strong="H1961"\w* \w como|strong="H3644"\w* un \w valiente|strong="H1368"\w*, y su \w corazón|strong="H3820"\w* \w se|strong="H1961"\w* alegrará \w como|strong="H3644"\w* con \w el|strong="H1121"\w* \w vino|strong="H3196"\w*.  
\q1 \w Sí|strong="H1961"\w*, sus \w hijos|strong="H1121"\w* lo \w verán|strong="H7200"\w* y \w se|strong="H1961"\w* gozarán; su \w corazón|strong="H3820"\w* \w se|strong="H1961"\w* alegrará en Yahvé.   
\q1
\v 8 \w Yo|strong="H3588"\w* les silbaré \w para|strong="H3588"\w* reunirlos, \w porque|strong="H3588"\w* \w los|strong="H3588"\w* he redimido; \w y|strong="H3588"\w* se multiplicarán \w como|strong="H3588"\w* \w antes|strong="H3588"\w* se \w multiplicaron|strong="H7235"\w*.   
\q1
\v 9 Aunque \w los|strong="H1121"\w* sembraré entre \w los|strong="H1121"\w* \w pueblos|strong="H5971"\w*, en países lejanos \w se|strong="H5971"\w* acordarán \w de|strong="H1121"\w* mí; \w vivirán|strong="H2421"\w* con sus \w hijos|strong="H1121"\w* y \w volverán|strong="H7725"\w*.   
\q1
\v 10 También los haré \w volver|strong="H7725"\w* de la tierra de \w Egipto|strong="H4714"\w* y los reuniré de Asiria.  
\q1 Los llevaré \w a|strong="H3068"\w* la tierra de \w Galaad|strong="H1568"\w* y del \w Líbano|strong="H3844"\w*, y \w no|strong="H3808"\w* habrá sitio suficiente para ellos.   
\q1
\v 11 \w Él|strong="H3605"\w* \w pasará|strong="H5674"\w* por \w el|strong="H3605"\w* \w mar|strong="H3220"\w* de \w la|strong="H3605"\w* \w aflicción|strong="H6869"\w* y \w herirá|strong="H5221"\w* las olas del \w mar|strong="H3220"\w*, y \w todas|strong="H3605"\w* las profundidades del Nilo se secarán.  
\q2 \w El|strong="H3605"\w* orgullo de Asiria será derribado y \w el|strong="H3605"\w* \w cetro|strong="H7626"\w* de \w Egipto|strong="H4714"\w* se \w apartará|strong="H5493"\w*.   
\q1
\v 12 Yo los fortaleceré en Yahvé, y caminarán en su \w nombre|strong="H8034"\w*», \w dice|strong="H5002"\w* Yahvé.   
\c 11
\q1
\v 1 \w Abre|strong="H6605"\w* tus \w puertas|strong="H1817"\w*, oh \w Líbano|strong="H3844"\w*,  
\q2 para que el fuego devore tus cedros.   
\q1
\v 2 Laméntate, ciprés, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* cedro ha \w caído|strong="H5307"\w*,  
\q2 \w porque|strong="H3588"\w* \w los|strong="H3588"\w* árboles majestuosos han sido destruidos.  
\q1 \w Aullad|strong="H3213"\w*, robles \w de|strong="H3588"\w* \w Basán|strong="H1316"\w*,  
\q2 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w bosque|strong="H3293"\w* espeso ha sido talado.   
\q1
\v 3 ¡Se oye \w la|strong="H3588"\w* \w voz|strong="H6963"\w* del lamento \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w pastores|strong="H7462"\w*,  
\q2 \w porque|strong="H3588"\w* \w su|strong="H3588"\w* gloria ha sido \w destruida|strong="H7703"\w*! ¡Se oye \w el|strong="H3588"\w* rugido \w de|strong="H3588"\w* \w los|strong="H3588"\w* leones jóvenes,  
\q2 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* orgullo del \w Jordán|strong="H3383"\w* ha sido arruinado!   
\p
\v 4 \w Así|strong="H3541"\w* dice Yahvé, mi \w Dios|strong="H3068"\w*: “\w Apacienta|strong="H7462"\w* el \w rebaño|strong="H6629"\w* destinado \w a|strong="H3068"\w* la matanza.  
\v 5 Sus compradores \w los|strong="H5921"\w* sacrifican \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* sienten culpables. \w Los|strong="H5921"\w* \w que|strong="H3808"\w* \w los|strong="H5921"\w* venden dicen: ‘\w Bendito|strong="H1288"\w* sea Yahvé, \w porque|strong="H5921"\w* \w me|strong="H5921"\w* he enriquecido’; \w y|strong="H5921"\w* sus propios \w pastores|strong="H7462"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* apiadan \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 6 \w Porque|strong="H3588"\w* ya \w no|strong="H3808"\w* tendré piedad \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra — \w dice|strong="H5002"\w* Yahvé —; \w por|strong="H5921"\w* \w el|strong="H5921"\w* contrario, \w entregaré|strong="H4672"\w* \w a|strong="H3068"\w* cada hombre \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w prójimo|strong="H7453"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w rey|strong="H4428"\w*. Golpearán \w la|strong="H5921"\w* tierra, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H3427"\w* \w libraré|strong="H5337"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*”.   
\p
\v 7 \w Así|strong="H3651"\w* \w pues|strong="H3651"\w*, \w apacenté|strong="H7462"\w* el \w rebaño|strong="H6629"\w* de la matanza, especialmente \w a|strong="H3068"\w* los más pobres del \w rebaño|strong="H6629"\w*. \w Tomé|strong="H3947"\w* para mí \w dos|strong="H8147"\w* \w cayados|strong="H4731"\w*: al uno \w llamé|strong="H7121"\w* «Favor» y al otro \w llamé|strong="H7121"\w* «Unión», y \w apacenté|strong="H7462"\w* las \w ovejas|strong="H6629"\w*.  
\v 8 En un solo \w mes|strong="H3391"\w* eliminé \w a|strong="H3068"\w* los \w tres|strong="H7969"\w* \w pastores|strong="H7462"\w*, \w pues|strong="H1571"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* se impacientó \w con|strong="H1571"\w* \w ellos|strong="H1571"\w* \w y|strong="H1571"\w* \w el|strong="H1571"\w* \w alma|strong="H5315"\w* de \w ellos|strong="H1571"\w* \w también|strong="H1571"\w* me aborrecía.  
\v 9 Entonces dije: «\w No|strong="H3808"\w* os \w apacentaré|strong="H7462"\w* \w más|strong="H4191"\w*. La \w que|strong="H3808"\w* haya de \w morir|strong="H4191"\w*, \w que|strong="H3808"\w* \w muera|strong="H4191"\w*; la \w que|strong="H3808"\w* haya de ser destruida, \w que|strong="H3808"\w* \w lo|strong="H3808"\w* sea; y las \w que|strong="H3808"\w* queden, \w que|strong="H3808"\w* \w se|strong="H3808"\w* coman la \w carne|strong="H1320"\w* unas \w a|strong="H3068"\w* otras».  
\v 10 \w Tomé|strong="H3947"\w* mi cayado Favor y \w lo|strong="H3605"\w* \w quebré|strong="H1438"\w*, \w para|strong="H5971"\w* romper \w el|strong="H3605"\w* \w pacto|strong="H1285"\w* \w que|strong="H5971"\w* había concertado con \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*.  
\v 11 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* pacto quedó roto, \w y|strong="H3588"\w* \w así|strong="H3651"\w* \w los|strong="H1931"\w* pobres del \w rebaño|strong="H6629"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* observaban \w supieron|strong="H3045"\w* \w que|strong="H3588"\w* \w era|strong="H1931"\w* \w palabra|strong="H1697"\w* \w de|strong="H3588"\w* Yahvé.  
\v 12 \w Y|strong="H3068"\w* les dije: «\w Si|strong="H3808"\w* \w os|strong="H5869"\w* parece \w bien|strong="H2896"\w*, \w dadme|strong="H3051"\w* mi \w salario|strong="H7939"\w*; y \w si|strong="H3808"\w* \w no|strong="H3808"\w*, \w dejadlo|strong="H2308"\w*». \w Y|strong="H3068"\w* pesaron por mi \w salario|strong="H7939"\w* \w treinta|strong="H7970"\w* piezas \w de|strong="H5869"\w* \w plata|strong="H3701"\w*.  
\v 13 Entonces Yahvé \w me|strong="H5921"\w* dijo: «Tíralo \w al|strong="H5921"\w* alfarero; ¡\w qué|strong="H5921"\w* \w precio|strong="H3701"\w* tan magnífico \w en|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* han tasado!». \w Tomé|strong="H3947"\w* \w las|strong="H5921"\w* \w treinta|strong="H7970"\w* piezas \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* arrojé \w al|strong="H5921"\w* alfarero \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Yahvé.  
\v 14 Luego \w quebré|strong="H1438"\w* mi \w segundo|strong="H8145"\w* cayado, Unión, para romper la hermandad entre \w Judá|strong="H3063"\w* \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*.   
\p
\v 15 \w Y|strong="H3068"\w* Yahvé me dijo: «\w Toma|strong="H3947"\w* \w de|strong="H5750"\w* nuevo los aperos \w de|strong="H5750"\w* un \w pastor|strong="H7462"\w* insensato.  
\v 16 \w Porque|strong="H3588"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* voy \w a|strong="H3068"\w* \w levantar|strong="H6965"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w a|strong="H3068"\w* un \w pastor|strong="H7462"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* preocupará \w de|strong="H3588"\w* \w la|strong="H3588"\w* oveja perdida, \w ni|strong="H3808"\w* \w buscará|strong="H1245"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* pequeña, \w ni|strong="H3808"\w* \w curará|strong="H7495"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* herida, \w ni|strong="H3808"\w* alimentará \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w sana|strong="H7495"\w*; \w sino|strong="H3588"\w* \w que|strong="H3588"\w* comerá \w la|strong="H3588"\w* \w carne|strong="H1320"\w* \w de|strong="H3588"\w* las \w más|strong="H3588"\w* gordas \w y|strong="H3588"\w* les arrancará hasta las pezuñas.  
\v 17 ¡\w Ay|strong="H1945"\w* \w del|strong="H5921"\w* pastor inútil \w que|strong="H5921"\w* abandona \w el|strong="H5921"\w* \w rebaño|strong="H6629"\w*! \w La|strong="H5921"\w* \w espada|strong="H2719"\w* herirá su \w brazo|strong="H2220"\w* \w y|strong="H5921"\w* su \w ojo|strong="H5869"\w* \w derecho|strong="H3225"\w*. Su \w brazo|strong="H2220"\w* \w se|strong="H5921"\w* \w secará|strong="H3001"\w* \w por|strong="H5921"\w* completo \w y|strong="H5921"\w* su \w ojo|strong="H5869"\w* \w derecho|strong="H3225"\w* quedará totalmente ciego».   
\c 12
\p
\v 1 Profecía \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H5921"\w* Yahvé \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: Yahvé, \w que|strong="H5921"\w* \w extiende|strong="H5186"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*, funda \w la|strong="H5921"\w* tierra \w y|strong="H5921"\w* forma \w el|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w del|strong="H5921"\w* hombre \w dentro|strong="H7130"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, declara:  
\v 2 “He \w aquí|strong="H2009"\w*, \w yo|strong="H2009"\w* \w haré|strong="H7760"\w* \w de|strong="H5921"\w* Jerusalén una copa \w de|strong="H5921"\w* vértigo \w para|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* \w alrededor|strong="H5439"\w*; \w y|strong="H1571"\w* \w el|strong="H5921"\w* asedio \w contra|strong="H5921"\w* Jerusalén \w también|strong="H1571"\w* \w será|strong="H1961"\w* \w contra|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 3 \w Sucederá|strong="H1961"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H1931"\w* \w haré|strong="H7760"\w* \w de|strong="H5921"\w* Jerusalén una piedra \w pesada|strong="H4614"\w* \w para|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w*. \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H1931"\w* intenten cargarla \w serán|strong="H1961"\w* gravemente heridos, \w y|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w se|strong="H1961"\w* reunirán \w contra|strong="H5921"\w* \w ella|strong="H1931"\w*.  
\v 4 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* — \w dice|strong="H5002"\w* \w el|strong="H1931"\w* \w Señor|strong="H3068"\w* — \w heriré|strong="H5221"\w* \w de|strong="H5921"\w* pánico \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w caballo|strong="H5483"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* locura \w a|strong="H3068"\w* \w su|strong="H1931"\w* jinete. \w Abriré|strong="H6491"\w* mis \w ojos|strong="H5869"\w* \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, pero \w heriré|strong="H5221"\w* \w con|strong="H5921"\w* ceguera \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w caballos|strong="H5483"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w*.  
\v 5 Entonces \w los|strong="H3427"\w* jefes de \w Judá|strong="H3063"\w* dirán en su \w corazón|strong="H3820"\w*: «\w Los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Jerusalén son \w mi|strong="H3389"\w* fuerza en Yahvé de \w los|strong="H3427"\w* \w Ejércitos|strong="H6635"\w*, su \w Dios|strong="H3068"\w*».   
\p
\v 6 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w haré|strong="H7760"\w* \w que|strong="H1931"\w* \w los|strong="H3427"\w* jefes \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* sean \w como|strong="H5921"\w* un brasero \w de|strong="H5921"\w* fuego \w entre|strong="H5921"\w* \w la|strong="H1931"\w* \w leña|strong="H6086"\w*, \w y|strong="H5921"\w* \w como|strong="H5921"\w* una antorcha encendida \w entre|strong="H5921"\w* \w las|strong="H5921"\w* gavillas. Devorarán \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* \w alrededor|strong="H5439"\w*, \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w izquierda|strong="H8040"\w*; \w y|strong="H5921"\w* Jerusalén \w volverá|strong="H7760"\w* \w a|strong="H3068"\w* ser \w habitada|strong="H3427"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* propio \w lugar|strong="H8478"\w*, \w en|strong="H5921"\w* Jerusalén.   
\p
\v 7 \w El|strong="H5921"\w* \w Señor|strong="H3068"\w* \w salvará|strong="H3467"\w* \w primero|strong="H7223"\w* \w las|strong="H5921"\w* tiendas \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w para|strong="H4616"\w* \w que|strong="H3808"\w* \w la|strong="H5921"\w* \w gloria|strong="H8597"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w gloria|strong="H8597"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén \w no|strong="H3808"\w* \w se|strong="H5921"\w* engrandezcan \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.  
\v 8 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* \w Señor|strong="H3068"\w* \w defenderá|strong="H1598"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H6440"\w* Jerusalén. \w El|strong="H1931"\w* más débil entre \w ellos|strong="H1931"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w David|strong="H1732"\w*, y \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w David|strong="H1732"\w* \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w Dios|strong="H3068"\w*, \w como|strong="H1961"\w* \w el|strong="H1931"\w* \w ángel|strong="H4397"\w* \w de|strong="H6440"\w* Yahvé \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H1931"\w*.  
\v 9 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H1931"\w* yo \w me|strong="H5921"\w* dispondré \w a|strong="H3068"\w* \w destruir|strong="H8045"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w que|strong="H1931"\w* vengan \w contra|strong="H5921"\w* Jerusalén.   
\p
\v 10 \w Derramaré|strong="H8210"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* Jerusalén un \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w gracia|strong="H2580"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* súplica. Mirarán \w hacia|strong="H5921"\w* \w mí|strong="H5921"\w*\f + \fr 12:10 \ft Después de «mí», el hebreo tiene las dos letras «Aleph Tav» (la primera y la última del alfabeto hebreo), no como una palabra, sino como un marcador gramatical.\f* \w a|strong="H3068"\w* quien \w traspasaron|strong="H1856"\w*; \w y|strong="H5921"\w* llorarán \w por|strong="H5921"\w* \w él|strong="H5921"\w* \w como|strong="H5921"\w* \w se|strong="H5921"\w* llora \w por|strong="H5921"\w* un hijo \w único|strong="H3173"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* afligirán amargamente \w por|strong="H5921"\w* \w él|strong="H5921"\w* \w como|strong="H5921"\w* \w se|strong="H5921"\w* hace duelo \w por|strong="H5921"\w* un \w primogénito|strong="H1060"\w*.  
\v 11 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w habrá|strong="H3117"\w* un gran luto en Jerusalén, \w como|strong="H1931"\w* \w el|strong="H1931"\w* luto de Hadad-rimón en \w el|strong="H1931"\w* valle de Meguido.  
\v 12 La tierra hará duelo, cada \w familia|strong="H1004"\w* por su lado; la \w familia|strong="H1004"\w* de la \w casa|strong="H1004"\w* de \w David|strong="H1732"\w* por su lado, y sus mujeres por el suyo; la \w familia|strong="H1004"\w* de la \w casa|strong="H1004"\w* de Natán por su lado, y sus mujeres por el suyo;  
\v 13 la \w familia|strong="H1004"\w* de la \w casa|strong="H1004"\w* de \w Leví|strong="H3878"\w* por su lado, y sus mujeres por el suyo; la \w familia|strong="H1004"\w* de los simeítas por su lado, y sus mujeres por el suyo;  
\v 14 y \w todas|strong="H3605"\w* las demás \w familias|strong="H4940"\w* \w que|strong="H3605"\w* queden, \w cada|strong="H3605"\w* \w familia|strong="H4940"\w* por su lado, y sus mujeres por \w el|strong="H3605"\w* suyo.   
\c 13
\p
\v 1 “En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1961"\w* \w abrirá|strong="H6605"\w* un \w manantial|strong="H4726"\w* \w para|strong="H1961"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* de \w David|strong="H1732"\w* y \w para|strong="H1961"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Jerusalén, \w para|strong="H1961"\w* lavar \w el|strong="H1931"\w* \w pecado|strong="H2403"\w* y \w la|strong="H1931"\w* impureza.   
\p
\v 2 \w En|strong="H4480"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* — \w dice|strong="H5002"\w* \w el|strong="H1931"\w* \w Señor|strong="H3068"\w* \w de|strong="H4480"\w* \w los|strong="H1931"\w* \w Ejércitos|strong="H6635"\w* —, \w haré|strong="H3772"\w* desaparecer \w de|strong="H4480"\w* \w la|strong="H1931"\w* tierra \w los|strong="H1931"\w* \w nombres|strong="H8034"\w* \w de|strong="H4480"\w* \w los|strong="H1931"\w* \w ídolos|strong="H6091"\w*, \w y|strong="H1571"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w serán|strong="H1961"\w* recordados. \w También|strong="H1571"\w* \w haré|strong="H3772"\w* \w que|strong="H4480"\w* desaparezcan \w de|strong="H4480"\w* \w la|strong="H1931"\w* tierra \w los|strong="H1931"\w* falsos \w profetas|strong="H5030"\w* \w y|strong="H1571"\w* \w el|strong="H1931"\w* \w espíritu|strong="H7307"\w* \w de|strong="H4480"\w* impureza.  
\v 3 \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H3588"\w* \w si|strong="H3588"\w* \w alguno|strong="H5750"\w* \w profetiza|strong="H5012"\w* \w todavía|strong="H5750"\w*, \w su|strong="H3588"\w* padre \w y|strong="H3588"\w* \w su|strong="H3588"\w* madre \w que|strong="H3588"\w* \w lo|strong="H3808"\w* \w engendraron|strong="H3205"\w* le dirán: ‘Debes morir, \w porque|strong="H3588"\w* hablas \w mentiras|strong="H8267"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* Yahvé’; \w y|strong="H3588"\w* sus propios padres \w lo|strong="H3808"\w* traspasarán \w mientras|strong="H5750"\w* \w profetiza|strong="H5012"\w*.  
\v 4 \w Sucederá|strong="H1961"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H1931"\w* \w los|strong="H1931"\w* \w profetas|strong="H5030"\w* \w se|strong="H1961"\w* avergonzarán, \w cada|strong="H3117"\w* uno \w de|strong="H3847"\w* \w su|strong="H1931"\w* propia \w visión|strong="H2384"\w* \w cuando|strong="H3117"\w* \w profetice|strong="H5012"\w*; \w ni|strong="H3808"\w* \w se|strong="H1961"\w* vestirán con \w el|strong="H1931"\w* manto \w de|strong="H3847"\w* \w pelo|strong="H8181"\w* \w para|strong="H4616"\w* engañar,  
