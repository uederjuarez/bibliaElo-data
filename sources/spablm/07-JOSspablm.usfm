\v 14 «\w Y|strong="H3068"\w* he \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w yo|strong="H4480"\w* \w voy|strong="H1980"\w* \w hoy|strong="H3117"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w de|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra; \w reconoced|strong="H3045"\w*, \w pues|strong="H3588"\w*, \w con|strong="H5921"\w* \w todo|strong="H3605"\w* vuestro \w corazón|strong="H3824"\w* \w y|strong="H3588"\w* \w con|strong="H5921"\w* \w toda|strong="H3605"\w* vuestra \w alma|strong="H5315"\w*, \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w ha|strong="H3808"\w* faltado una sola \w palabra|strong="H1697"\w* \w de|strong="H4480"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w buenas|strong="H2896"\w* \w palabras|strong="H1697"\w* \w que|strong="H3588"\w* Yahvé vuestro \w Dios|strong="H3068"\w* \w había|strong="H3588"\w* \w dicho|strong="H1697"\w* \w de|strong="H4480"\w* vosotros; \w todas|strong="H3605"\w* \w os|strong="H4480"\w* han acontecido, \w no|strong="H3808"\w* \w ha|strong="H3808"\w* faltado \w ninguna|strong="H3605"\w* \w de|strong="H4480"\w* \w ellas|strong="H5921"\w*.  
\v 15 Pero \w así|strong="H3651"\w* \w como|strong="H1961"\w* ha venido \w sobre|strong="H5921"\w* vosotros \w toda|strong="H3605"\w* \w palabra|strong="H1697"\w* \w buena|strong="H2896"\w* \w que|strong="H5921"\w* Yahvé vuestro \w Dios|strong="H3068"\w* \w os|strong="H5921"\w* \w había|strong="H1961"\w* \w dicho|strong="H1697"\w*, \w también|strong="H3651"\w* traerá Yahvé \w sobre|strong="H5921"\w* vosotros \w toda|strong="H3605"\w* \w palabra|strong="H1697"\w* \w mala|strong="H7451"\w*, \w hasta|strong="H5704"\w* exterminaros \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w esta|strong="H2063"\w* \w buena|strong="H2896"\w* tierra \w que|strong="H5921"\w* Yahvé vuestro \w Dios|strong="H3068"\w* \w os|strong="H5921"\w* ha \w dado|strong="H5414"\w*,  
\v 16 \w si|strong="H5921"\w* quebrantareis \w el|strong="H5921"\w* \w pacto|strong="H1285"\w* \w de|strong="H5921"\w* Yahvé vuestro \w Dios|strong="H3068"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w os|strong="H5921"\w* ha \w mandado|strong="H6680"\w*, \w yendo|strong="H1980"\w* \w a|strong="H3068"\w* \w servir|strong="H5647"\w* \w a|strong="H3068"\w* dioses ajenos \w e|strong="H3068"\w* inclinándoos ante \w ellos|strong="H1992"\w*. Entonces \w la|strong="H5921"\w* \w ira|strong="H1980"\w* \w de|strong="H5921"\w* Yahvé \w se|strong="H5921"\w* encenderá \w contra|strong="H5921"\w* vosotros, \w y|strong="H5921"\w* pereceréis prontamente \w de|strong="H5921"\w* \w esta|strong="H1992"\w* \w buena|strong="H2896"\w* tierra \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w os|strong="H5921"\w* ha \w dado|strong="H5414"\w*».   
\c 24
\p
\v 1 \w Josué|strong="H3091"\w* reunió \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* en Siquem, y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* sus \w cabezas|strong="H7218"\w*, \w a|strong="H3068"\w* sus \w jueces|strong="H8199"\w* y \w a|strong="H3068"\w* sus \w oficiales|strong="H7860"\w*; y se presentaron \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Dios.  
\v 2 \w Y|strong="H3068"\w* dijo \w Josué|strong="H3091"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*: “\w Así|strong="H3541"\w* dice Yahvé, \w Dios|strong="H3068"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*: “\w Vuestros|strong="H5647"\w* padres \w habitaron|strong="H3427"\w* \w antiguamente|strong="H5769"\w* al otro \w lado|strong="H5676"\w* del \w río|strong="H5104"\w*, \w esto|strong="H3541"\w* \w es|strong="H3541"\w*, Taré, padre \w de|strong="H5971"\w* Abraham \w y|strong="H3541"\w* \w de|strong="H5971"\w* Nacor; \w y|strong="H3541"\w* servían \w a|strong="H3068"\w* otros dioses.  
\v 3 Pero yo \w tomé|strong="H3947"\w* \w a|strong="H3068"\w* vuestro padre Abraham del otro \w lado|strong="H5676"\w* del \w río|strong="H5104"\w*, y \w lo|strong="H3605"\w* conduje \w por|strong="H5414"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5414"\w* \w Canaán|strong="H3667"\w*, y multipliqué su \w simiente|strong="H2233"\w*\f + \fr 24:3 \ft o, descendencia\f* y le \w di|strong="H5414"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*.  
\v 4 \w A|strong="H3068"\w* \w Isaac|strong="H3327"\w* le \w di|strong="H5414"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* y \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w*. \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w* le \w di|strong="H5414"\w* \w el|strong="H1121"\w* \w monte|strong="H2022"\w* \w de|strong="H1121"\w* \w Seir|strong="H8165"\w* \w para|strong="H5414"\w* \w que|strong="H1121"\w* lo poseyese; pero \w Jacob|strong="H3290"\w* y sus \w hijos|strong="H1121"\w* \w descendieron|strong="H3381"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 5 “\w Y|strong="H3068"\w* \w yo|strong="H6213"\w* \w envié|strong="H7971"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón, y herí \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* con las plagas que \w hice|strong="H6213"\w* \w en|strong="H3318"\w* \w medio|strong="H7130"\w* de ellos, y después os \w saqué|strong="H3318"\w*.  
\v 6 \w Saqué|strong="H3318"\w* \w a|strong="H3068"\w* vuestros padres de \w Egipto|strong="H4714"\w*, y llegasteis al \w mar|strong="H3220"\w*; y \w los|strong="H7291"\w* \w egipcios|strong="H4713"\w* \w siguieron|strong="H7291"\w* \w a|strong="H3068"\w* vuestros padres hasta el \w Mar|strong="H3220"\w* Rojo con \w carros|strong="H7393"\w* y caballería.  
\v 7 \w Cuando|strong="H3117"\w* \w ellos|strong="H5921"\w* \w clamaron|strong="H6817"\w* \w a|strong="H3068"\w* Yahvé, \w él|strong="H5921"\w* \w puso|strong="H7760"\w* \w oscuridad|strong="H3990"\w* \w entre|strong="H5921"\w* vosotros \w y|strong="H5921"\w* \w los|strong="H3427"\w* \w egipcios|strong="H4713"\w*, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* venir \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w el|strong="H5921"\w* cual \w los|strong="H3427"\w* \w cubrió|strong="H3680"\w*; \w y|strong="H5921"\w* vuestros \w ojos|strong="H5869"\w* \w vieron|strong="H7200"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w hice|strong="H6213"\w* \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w*. \w Después|strong="H5921"\w* estuvisteis vosotros habitando \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*.   
\p
\v 8 “Yo os introduje en la tierra \w de|strong="H6440"\w* \w los|strong="H3427"\w* amorreos, \w que|strong="H3027"\w* \w habitaban|strong="H3427"\w* al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*; \w ellos|strong="H3027"\w* \w pelearon|strong="H3898"\w* \w contra|strong="H6440"\w* vosotros, mas yo \w los|strong="H3427"\w* \w entregué|strong="H5414"\w* en vuestra \w mano|strong="H3027"\w*, y poseísteis su tierra, y yo \w los|strong="H3427"\w* \w destruí|strong="H8045"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros.  
\v 9 Después se \w levantó|strong="H6965"\w* \w Balac|strong="H1111"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zipor, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Moab|strong="H4124"\w*, y \w peleó|strong="H3898"\w* \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w*; y \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* \w Balaam|strong="H1109"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Beor, para \w que|strong="H1121"\w* os maldijese.  
\v 10 \w Mas|strong="H3808"\w* yo \w no|strong="H3808"\w* quise \w escuchar|strong="H8085"\w* \w a|strong="H3068"\w* \w Balaam|strong="H1109"\w*, \w por|strong="H3027"\w* \w lo|strong="H3808"\w* cual os \w bendijo|strong="H1288"\w* repetidamente, y os \w libré|strong="H5337"\w* de su \w mano|strong="H3027"\w*.   
\p
\v 11 «Pasasteis \w el|strong="H5674"\w* \w Jordán|strong="H3383"\w* y llegasteis \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*; y \w los|strong="H1167"\w* moradores \w de|strong="H5414"\w* \w Jericó|strong="H3405"\w* \w pelearon|strong="H3898"\w* contra vosotros: \w los|strong="H1167"\w* amorreos, ferezeos, \w cananeos|strong="H3669"\w*, hititas, \w gergeseos|strong="H1622"\w*, \w heveos|strong="H2340"\w* y \w jebuseos|strong="H2983"\w*, y yo \w los|strong="H1167"\w* \w entregué|strong="H5414"\w* en vuestra \w mano|strong="H3027"\w*.  
\v 12 \w Y|strong="H3068"\w* \w envié|strong="H7971"\w* \w tábanos|strong="H6880"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros, los cuales los arrojaron \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros, \w a|strong="H3068"\w* saber, \w a|strong="H3068"\w* los \w dos|strong="H8147"\w* \w reyes|strong="H4428"\w* \w de|strong="H6440"\w* los amorreos; \w no|strong="H3808"\w* con tu \w espada|strong="H2719"\w* \w ni|strong="H3808"\w* con tu \w arco|strong="H7198"\w*.  
\v 13 \w Y|strong="H3068"\w* os \w di|strong="H5414"\w* tierra \w por|strong="H5414"\w* la cual \w no|strong="H3808"\w* \w trabajasteis|strong="H3021"\w*, y \w ciudades|strong="H5892"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w edificasteis|strong="H1129"\w*, en las cuales ahora \w habitáis|strong="H3427"\w*; y coméis \w de|strong="H5414"\w* \w viñas|strong="H3754"\w* y \w olivares|strong="H2132"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w plantasteis|strong="H5193"\w*».   
\p
\v 14 «\w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w temed|strong="H3372"\w* \w a|strong="H3068"\w* Yahvé, y servidle con integridad y \w en|strong="H8549"\w* verdad; \w quitad|strong="H5493"\w* \w de|strong="H3372"\w* entre vosotros los dioses \w a|strong="H3068"\w* los cuales \w sirvieron|strong="H5647"\w* \w vuestros|strong="H5647"\w* padres al otro \w lado|strong="H5676"\w* del \w río|strong="H5104"\w* y \w en|strong="H8549"\w* \w Egipto|strong="H4714"\w*, y \w servid|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé.  
\v 15 \w Y|strong="H3068"\w* si \w mal|strong="H7451"\w* \w os|strong="H5869"\w* parece \w servir|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé, escogeos \w hoy|strong="H3117"\w* \w a|strong="H3068"\w* \w quién|strong="H4310"\w* \w sirváis|strong="H5647"\w*; si \w a|strong="H3068"\w* \w los|strong="H3427"\w* dioses \w a|strong="H3068"\w* \w quienes|strong="H4310"\w* \w sirvieron|strong="H5647"\w* \w vuestros|strong="H5647"\w* padres, \w cuando|strong="H3117"\w* \w estuvieron|strong="H3427"\w* al otro \w lado|strong="H5676"\w* del \w río|strong="H5104"\w*, \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* dioses \w de|strong="H5869"\w* \w los|strong="H3427"\w* amorreos en \w cuya|strong="H4310"\w* tierra \w habitáis|strong="H3427"\w*; pero yo y mi \w casa|strong="H1004"\w* \w serviremos|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé».   
\p
\v 16 Entonces el \w pueblo|strong="H5971"\w* \w respondió|strong="H6030"\w* y dijo: «\w Nunca|strong="H2486"\w* tal acontezca, \w que|strong="H5971"\w* dejemos \w a|strong="H3068"\w* Yahvé \w para|strong="H5971"\w* \w servir|strong="H5647"\w* \w a|strong="H3068"\w* otros dioses;  
\v 17 \w porque|strong="H3588"\w* Yahvé nuestro \w Dios|strong="H3068"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w que|strong="H3588"\w* nos \w sacó|strong="H5927"\w* \w a|strong="H3068"\w* \w nosotros|strong="H3605"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* nuestros padres \w de|strong="H3588"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* servidumbre; \w el|strong="H1931"\w* \w que|strong="H3588"\w* ha \w hecho|strong="H6213"\w* \w estas|strong="H6213"\w* \w grandes|strong="H1419"\w* señales \w delante|strong="H5869"\w* \w de|strong="H3588"\w* nuestros \w ojos|strong="H5869"\w*, \w y|strong="H3588"\w* nos ha \w guardado|strong="H8104"\w* \w en|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w por|strong="H3588"\w* \w donde|strong="H1931"\w* hemos \w andado|strong="H1980"\w*, \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* \w por|strong="H3588"\w* \w los|strong="H3605"\w* cuales \w pasamos|strong="H5674"\w*.  
\v 18 \w Y|strong="H3068"\w* Yahvé arrojó \w de|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w pueblos|strong="H5971"\w*, \w y|strong="H1571"\w* al amorreo \w que|strong="H3588"\w* \w habitaba|strong="H3427"\w* \w en|strong="H3588"\w* \w la|strong="H1931"\w* tierra; \w nosotros|strong="H3605"\w*, \w pues|strong="H3588"\w*, \w también|strong="H1571"\w* \w serviremos|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w es|strong="H1931"\w* nuestro \w Dios|strong="H3068"\w*».   
\p
\v 19 \w Entonces|strong="H3588"\w* \w Josué|strong="H3091"\w* dijo al \w pueblo|strong="H5971"\w*: «\w No|strong="H3808"\w* \w podréis|strong="H3201"\w* \w servir|strong="H5647"\w* \w a|strong="H3068"\w* Yahvé, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w es|strong="H1931"\w* \w Dios|strong="H3068"\w* \w santo|strong="H6918"\w*, \w y|strong="H3588"\w* \w Dios|strong="H3068"\w* \w celoso|strong="H7072"\w*; \w no|strong="H3808"\w* \w sufrirá|strong="H5375"\w* vuestras \w rebeliones|strong="H6588"\w* \w ni|strong="H3808"\w* \w vuestros|strong="H5647"\w* \w pecados|strong="H2403"\w*.  
\v 20 \w Si|strong="H3588"\w* \w dejareis|strong="H5800"\w* \w a|strong="H3068"\w* Yahvé \w y|strong="H3588"\w* sirviereis \w a|strong="H3068"\w* dioses \w ajenos|strong="H5236"\w*, \w él|strong="H3588"\w* se \w volverá|strong="H7725"\w* \w y|strong="H3588"\w* os \w hará|strong="H3190"\w* \w mal|strong="H7489"\w*, \w y|strong="H3588"\w* os \w consumirá|strong="H3615"\w*, después \w que|strong="H3588"\w* os ha hecho \w bien|strong="H3190"\w*».   
\p
\v 21 \w El|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w entonces|strong="H3588"\w* dijo \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: «\w No|strong="H3808"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* Yahvé \w serviremos|strong="H5647"\w*».  
\v 22 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* respondió al \w pueblo|strong="H5971"\w*: «Vosotros sois \w testigos|strong="H5707"\w* contra vosotros mismos, \w de|strong="H3588"\w* \w que|strong="H3588"\w* habéis elegido \w a|strong="H3068"\w* Yahvé \w para|strong="H3588"\w* servirle». \w Y|strong="H3068"\w* ellos respondieron: «\w Testigos|strong="H5707"\w* somos».   
\p
\v 23 «\w Quitad|strong="H5493"\w*, \w pues|strong="H6258"\w*, \w ahora|strong="H6258"\w* los dioses \w ajenos|strong="H5236"\w* \w que|strong="H6258"\w* \w están|strong="H3824"\w* \w entre|strong="H7130"\w* vosotros, \w e|strong="H3068"\w* \w inclinad|strong="H5186"\w* vuestro \w corazón|strong="H3824"\w* \w a|strong="H3068"\w* Yahvé \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*».   
\p
\v 24 \w Y|strong="H3068"\w* el \w pueblo|strong="H5971"\w* respondió \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: «\w A|strong="H3068"\w* Yahvé nuestro \w Dios|strong="H3068"\w* \w serviremos|strong="H5647"\w*, y su \w voz|strong="H6963"\w* \w obedeceremos|strong="H8085"\w*».   
\p
\v 25 \w Entonces|strong="H3117"\w* \w Josué|strong="H3091"\w* \w concertó|strong="H3772"\w* un \w pacto|strong="H1285"\w* con \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*, y les \w dio|strong="H7760"\w* \w estatutos|strong="H2706"\w* y \w ordenanzas|strong="H4941"\w* en Siquem.  
\v 26 \w Y|strong="H3068"\w* \w escribió|strong="H3789"\w* \w Josué|strong="H3091"\w* estas \w palabras|strong="H1697"\w* \w en|strong="H8478"\w* el \w libro|strong="H5612"\w* \w de|strong="H8478"\w* la \w ley|strong="H8451"\w* \w de|strong="H8478"\w* \w Dios|strong="H3068"\w*; y \w tomando|strong="H3947"\w* una \w gran|strong="H1419"\w* piedra, la \w levantó|strong="H6965"\w* \w allí|strong="H8033"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* la encina \w que|strong="H1697"\w* estaba junto \w al|strong="H8478"\w* \w santuario|strong="H4720"\w* \w de|strong="H8478"\w* Yahvé.  
\v 27 \w Y|strong="H3068"\w* \w dijo|strong="H1696"\w* \w Josué|strong="H3091"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w*: «He \w aquí|strong="H2009"\w* \w esta|strong="H2063"\w* piedra \w servirá|strong="H1961"\w* \w de|strong="H3588"\w* \w testigo|strong="H5713"\w* \w contra|strong="H5973"\w* \w nosotros|strong="H3605"\w*, \w porque|strong="H3588"\w* \w ella|strong="H1931"\w* ha \w oído|strong="H8085"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1696"\w* \w que|strong="H3588"\w* Yahvé nos ha \w hablado|strong="H1696"\w*; \w será|strong="H1961"\w*, \w pues|strong="H3588"\w*, \w testigo|strong="H5713"\w* \w contra|strong="H5973"\w* \w vosotros|strong="H8085"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H6435"\w* faltéis \w a|strong="H3068"\w* vuestro \w Dios|strong="H3068"\w*».  
\v 28 \w Y|strong="H3068"\w* \w despidió|strong="H7971"\w* \w Josué|strong="H3091"\w* al \w pueblo|strong="H5971"\w*, cada uno \w a|strong="H3068"\w* su \w heredad|strong="H5159"\w*.   
\p
\v 29 \w Después|strong="H1961"\w* \w de|strong="H1121"\w* estas \w cosas|strong="H1697"\w* \w murió|strong="H4191"\w* \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, \w siervo|strong="H5650"\w* \w de|strong="H1121"\w* Yahvé, siendo \w de|strong="H1121"\w* \w edad|strong="H8141"\w* \w de|strong="H1121"\w* \w ciento|strong="H3967"\w* \w diez|strong="H6235"\w* \w años|strong="H8141"\w*.  
\v 30 \w Y|strong="H3068"\w* lo \w sepultaron|strong="H6912"\w* \w en|strong="H6912"\w* su \w heredad|strong="H5159"\w*, \w en|strong="H6912"\w* Timnat-sera, que está \w en|strong="H6912"\w* el \w monte|strong="H2022"\w* de Efraín, al \w norte|strong="H6828"\w* del \w monte|strong="H2022"\w* \w Gaas|strong="H1608"\w*.  
\v 31 \w Y|strong="H3068"\w* \w sirvió|strong="H5647"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* Yahvé \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w tiempo|strong="H3117"\w* de \w Josué|strong="H3091"\w*, y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w tiempo|strong="H3117"\w* de \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w que|strong="H3045"\w* sobrevivieron \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* y \w que|strong="H3045"\w* \w sabían|strong="H3045"\w* \w todas|strong="H3605"\w* las \w obras|strong="H4639"\w* \w que|strong="H3045"\w* Yahvé \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* por \w Israel|strong="H3478"\w*.  
\v 32 \w Y|strong="H3068"\w* enterraron \w en|strong="H6912"\w* Siquem \w los|strong="H1121"\w* \w huesos|strong="H6106"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*, \w que|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w habían|strong="H1961"\w* \w subido|strong="H5927"\w* \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, \w en|strong="H6912"\w* la \w parte|strong="H2513"\w* del \w campo|strong="H7704"\w* \w que|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w compró|strong="H7069"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hamor|strong="H2544"\w* padre \w de|strong="H1121"\w* Siquem, \w por|strong="H7069"\w* \w cien|strong="H3967"\w* quesitás;\f + \fr 24:32 \ft El término hebreo es «quesitás». Una quesitá era una cierta moneda de plata.\f* y \w fue|strong="H1961"\w* \w posesión|strong="H5159"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*.  
\v 33 También \w murió|strong="H4191"\w* Eleazar \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, y lo enterraron \w en|strong="H6912"\w* \w el|strong="H1121"\w* \w monte|strong="H2022"\w* \w de|strong="H1121"\w* su \w hijo|strong="H1121"\w* Finees, \w que|strong="H1121"\w* le fue \w dado|strong="H5414"\w* \w en|strong="H6912"\w* \w el|strong="H1121"\w* \w monte|strong="H2022"\w* \w de|strong="H1121"\w* Efraín.   