\p
\v 3 \w Y|strong="H3068"\w* \w volviendo|strong="H7725"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, le dijeron: «\w No|strong="H3588"\w* \w suba|strong="H5927"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*, \w sino|strong="H3588"\w* suban \w como|strong="H3588"\w* dos \w o|strong="H3068"\w* \w tres|strong="H7969"\w* mil hombres, \w y|strong="H3588"\w* tomarán \w a|strong="H3068"\w* \w Hai|strong="H5857"\w*; \w no|strong="H3588"\w* \w fatigues|strong="H3021"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* haciéndole ir \w allá|strong="H8033"\w*, \w porque|strong="H3588"\w* \w son|strong="H3588"\w* \w pocos|strong="H4592"\w*».  
\v 4 Así \w subieron|strong="H5927"\w* \w allá|strong="H8033"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* como \w tres|strong="H7969"\w* mil hombres, los cuales \w huyeron|strong="H5127"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* los \w de|strong="H4480"\w* \w Hai|strong="H5857"\w*.  
\v 5 \w Y|strong="H3068"\w* \w los|strong="H1992"\w* \w de|strong="H6440"\w* \w Hai|strong="H5857"\w* \w mataron|strong="H5221"\w* \w a|strong="H3068"\w* \w unos|strong="H1992"\w* \w treinta|strong="H7970"\w* \w y|strong="H5704"\w* \w seis|strong="H8337"\w* hombres \w de|strong="H6440"\w* \w ellos|strong="H1992"\w*, \w y|strong="H5704"\w* \w los|strong="H1992"\w* \w siguieron|strong="H7291"\w* \w desde|strong="H5704"\w* la \w puerta|strong="H8179"\w* \w hasta|strong="H5704"\w* \w Sebarim|strong="H7671"\w*, \w y|strong="H5704"\w* \w los|strong="H1992"\w* derrotaron \w en|strong="H5704"\w* la bajada; \w por|strong="H6440"\w* \w lo|strong="H5704"\w* \w que|strong="H5704"\w* \w el|strong="H1992"\w* \w corazón|strong="H3824"\w* del \w pueblo|strong="H5971"\w* desfalleció \w y|strong="H5704"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* ser \w como|strong="H1961"\w* \w agua|strong="H4325"\w*.  
\v 6 Entonces \w Josué|strong="H3091"\w* \w rasgó|strong="H7167"\w* \w sus|strong="H1931"\w* \w vestidos|strong="H8071"\w*, \w y|strong="H5921"\w* \w se|strong="H1931"\w* postró \w en|strong="H5921"\w* \w tierra|strong="H6083"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* \w rostro|strong="H6440"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* arca \w de|strong="H5921"\w* Yahvé \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w caer|strong="H5307"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w tarde|strong="H6153"\w*, \w él|strong="H1931"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*; \w y|strong="H5921"\w* \w echaron|strong="H5307"\w* \w polvo|strong="H6083"\w* \w sobre|strong="H5921"\w* \w sus|strong="H1931"\w* \w cabezas|strong="H7218"\w*.  
\v 7 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* dijo: «¡Ah, Señor Yahvé! ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* hiciste \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w el|strong="H5674"\w* \w Jordán|strong="H3383"\w*, \w para|strong="H5414"\w* entregarnos en \w manos|strong="H3027"\w* \w de|strong="H5971"\w* \w los|strong="H3427"\w* amorreos, \w para|strong="H5414"\w* \w que|strong="H4100"\w* \w nos|strong="H4100"\w* destruyan? ¡\w Ojalá|strong="H3863"\w* \w nos|strong="H4100"\w* hubiéramos contentado con quedarnos al \w otro|strong="H2088"\w* \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*!  
\v 8 ¡Ay, Señor! ¿\w Qué|strong="H4100"\w* diré, ya \w que|strong="H4100"\w* \w Israel|strong="H3478"\w* ha vuelto la espalda \w delante|strong="H6440"\w* \w de|strong="H6440"\w* sus enemigos?  
\v 9 \w Porque|strong="H5921"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra \w se|strong="H5921"\w* enterarán, \w y|strong="H5921"\w* \w nos|strong="H5921"\w* rodearán, \w y|strong="H5921"\w* borrarán nuestro \w nombre|strong="H8034"\w* \w de|strong="H4480"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra; \w y|strong="H5921"\w* entonces, ¿\w qué|strong="H4100"\w* \w harás|strong="H6213"\w* \w tú|strong="H6213"\w* \w por|strong="H5921"\w* \w tu|strong="H6213"\w* \w gran|strong="H1419"\w* \w nombre|strong="H8034"\w*?».   
\p
\v 10 \w Y|strong="H3068"\w* Yahvé dijo \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: “¡\w Levántate|strong="H6965"\w*! ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w te|strong="H5921"\w* \w postras|strong="H5307"\w* \w así|strong="H2088"\w* \w sobre|strong="H5921"\w* tu \w rostro|strong="H6440"\w*?  
