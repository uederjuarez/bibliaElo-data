\v 10 Pero \w no|strong="H3808"\w* arrojaron \w al|strong="H5704"\w* \w cananeo|strong="H3669"\w* \w que|strong="H3808"\w* \w habitaba|strong="H3427"\w* \w en|strong="H5704"\w* \w Gezer|strong="H1507"\w*; \w por|strong="H2088"\w* \w lo|strong="H2088"\w* cual \w el|strong="H3427"\w* \w cananeo|strong="H3669"\w* \w habitó|strong="H3427"\w* \w en|strong="H5704"\w* \w medio|strong="H7130"\w* \w de|strong="H5704"\w* Efraín \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*, \w y|strong="H5704"\w* \w fue|strong="H1961"\w* puesto bajo \w tributo|strong="H4522"\w* \w de|strong="H5704"\w* servicio.   
\c 17
\p
\v 1 \w Esta|strong="H1931"\w* \w fue|strong="H1961"\w* \w la|strong="H1931"\w* \w suerte|strong="H1486"\w* \w que|strong="H3588"\w* correspondió \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w tribu|strong="H4294"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w era|strong="H1961"\w* \w el|strong="H1931"\w* \w primogénito|strong="H1060"\w* \w de|strong="H3588"\w* \w José|strong="H3130"\w*. Maquir, \w primogénito|strong="H1060"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w* \w y|strong="H3588"\w* padre \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w*, \w por|strong="H3588"\w* ser hombre \w de|strong="H3588"\w* \w guerra|strong="H4421"\w*, \w tuvo|strong="H1961"\w* \w Galaad|strong="H1568"\w* \w y|strong="H3588"\w* \w Basán|strong="H1316"\w*.  
\v 2 \w Se|strong="H1961"\w* dio también suerte al resto \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w* conforme \w a|strong="H3068"\w* sus \w familias|strong="H4940"\w*: \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Abiezer, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Helec, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Asriel, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Siquem, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hefer y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Semida; estos \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w varones|strong="H2145"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*, por sus \w familias|strong="H4940"\w*.  
\v 3 \w Pero|strong="H3588"\w* Zelofehad \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Hefer, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w*, \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w*, \w sino|strong="H3588"\w* \w hijas|strong="H1323"\w*, \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H3588"\w* las cuales \w son|strong="H1961"\w* estos: \w Maalá|strong="H4244"\w*, \w Noa|strong="H5270"\w*, \w Hoglá|strong="H2295"\w*, \w Milca|strong="H4435"\w* \w y|strong="H3588"\w* Tirsa.  
\v 4 Estas vinieron \w ante|strong="H6440"\w* \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Eleazar y \w ante|strong="H6440"\w* \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Nun|strong="H5126"\w*, y \w ante|strong="H6440"\w* \w los|strong="H1121"\w* \w príncipes|strong="H5387"\w*, y dijeron: «Yahvé \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w que|strong="H1121"\w* nos \w diese|strong="H5414"\w* \w heredad|strong="H5159"\w* \w entre|strong="H8432"\w* nuestros hermanos». \w Él|strong="H1121"\w*, pues, \w les|strong="H6680"\w* \w dio|strong="H5414"\w* \w heredad|strong="H5159"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* hermanos \w de|strong="H6440"\w* su padre, \w conforme|strong="H6310"\w* al \w dicho|strong="H6310"\w* \w de|strong="H6440"\w* Yahvé.  
\v 5 \w Y|strong="H3068"\w* \w cayeron|strong="H5307"\w* \w a|strong="H3068"\w* \w Manasés|strong="H4519"\w* \w diez|strong="H6235"\w* \w partes|strong="H2256"\w*, además de la tierra de \w Galaad|strong="H1568"\w* y de \w Basán|strong="H1316"\w* que está al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*;  
\v 6 \w porque|strong="H3588"\w* las \w hijas|strong="H1323"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w* \w tuvieron|strong="H1961"\w* \w heredad|strong="H5159"\w* \w entre|strong="H8432"\w* sus \w hijos|strong="H1121"\w*; \w y|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* \w fue|strong="H1961"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* otros \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w*.  
\v 7 \w Y|strong="H3068"\w* \w fue|strong="H1961"\w* \w el|strong="H5921"\w* límite \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w* \w desde|strong="H6440"\w* Aser \w hasta|strong="H5921"\w* Micmetat, \w que|strong="H5921"\w* \w está|strong="H1961"\w* frente \w a|strong="H3068"\w* Siquem; \w y|strong="H5921"\w* \w va|strong="H3068"\w* \w el|strong="H5921"\w* límite \w a|strong="H3068"\w* \w la|strong="H5921"\w* mano \w derecha|strong="H3225"\w*, \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H5921"\w* En-tapúa.  
\v 8 \w La|strong="H1366"\w* tierra \w de|strong="H1121"\w* Tapúa \w fue|strong="H1961"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*; pero \w la|strong="H1366"\w* ciudad \w de|strong="H1121"\w* Tapúa, \w que|strong="H1121"\w* \w está|strong="H1961"\w* en \w el|strong="H1121"\w* límite \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w es|strong="H1961"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Efraín.  
\v 9 \w Y|strong="H3068"\w* \w baja|strong="H3381"\w* \w este|strong="H1961"\w* límite al \w torrente|strong="H5158"\w* de Caná, al \w mediodía|strong="H5045"\w* del \w torrente|strong="H5158"\w*. Estas \w ciudades|strong="H5892"\w* de Efraín \w están|strong="H1961"\w* \w entre|strong="H8432"\w* las \w ciudades|strong="H5892"\w* de \w Manasés|strong="H4519"\w*; y el límite de \w Manasés|strong="H4519"\w* \w está|strong="H1961"\w* al \w norte|strong="H6828"\w* del \w torrente|strong="H5158"\w*, y sale al \w mar|strong="H3220"\w*.  
\v 10 El \w mediodía|strong="H5045"\w* \w es|strong="H1961"\w* de Efraín, y el \w norte|strong="H6828"\w* de \w Manasés|strong="H4519"\w*, y el \w mar|strong="H3220"\w* \w es|strong="H1961"\w* su límite; y \w se|strong="H1961"\w* encuentran con Aser al \w norte|strong="H6828"\w*, y con Isacar al \w oriente|strong="H4217"\w*.  
\v 11 \w Tuvo|strong="H1961"\w* también \w Manasés|strong="H4519"\w* en Isacar y en Aser \w a|strong="H3068"\w* Bet-seán y sus \w aldeas|strong="H1323"\w*, \w a|strong="H3068"\w* Ibleam y sus \w aldeas|strong="H1323"\w*, \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de \w Dor|strong="H1756"\w* y sus \w aldeas|strong="H1323"\w*, \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de En-dor y sus \w aldeas|strong="H1323"\w*, \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Taanac y sus \w aldeas|strong="H1323"\w*, y \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de Meguido y sus \w aldeas|strong="H1323"\w*; \w tres|strong="H7969"\w* regiones.  
\v 12 \w Mas|strong="H3808"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* arrojar \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H1121"\w* aquellas \w ciudades|strong="H5892"\w*; y \w el|strong="H1121"\w* \w cananeo|strong="H3669"\w* persistió en \w habitar|strong="H3427"\w* en \w aquella|strong="H2063"\w* tierra.   
\p
\v 13 \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* \w hicieron|strong="H5414"\w* \w fuertes|strong="H1121"\w*, \w pusieron|strong="H5414"\w* al \w cananeo|strong="H3669"\w* bajo \w tributo|strong="H4522"\w* \w de|strong="H3588"\w* servicio, \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* arrojaron del todo.  
\v 14 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w José|strong="H3130"\w* \w hablaron|strong="H1696"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w diciendo|strong="H1696"\w*: «¿\w Por|strong="H4069"\w* \w qué|strong="H5704"\w* \w me|strong="H3541"\w* \w has|strong="H5414"\w* \w dado|strong="H5414"\w* \w por|strong="H4069"\w* \w heredad|strong="H5159"\w* una sola \w suerte|strong="H1486"\w* \w y|strong="H5704"\w* una sola parte, siendo yo un \w pueblo|strong="H5971"\w* tan \w numeroso|strong="H7227"\w*, \w y|strong="H5704"\w* \w que|strong="H5704"\w* Yahvé \w me|strong="H3541"\w* \w ha|strong="H3541"\w* bendecido \w hasta|strong="H5704"\w* \w ahora|strong="H3541"\w*?».   
\p
\v 15 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* les respondió: «\w Si|strong="H3588"\w* sois \w pueblo|strong="H5971"\w* tan \w numeroso|strong="H7227"\w*, \w subid|strong="H5927"\w* vosotros al \w monte|strong="H2022"\w*, \w y|strong="H3588"\w* talad \w para|strong="H3588"\w* vosotros \w allí|strong="H8033"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w los|strong="H3588"\w* ferezeos \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* refaítas, ya \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w monte|strong="H2022"\w* \w de|strong="H3588"\w* Efraín \w es|strong="H3588"\w* estrecho \w para|strong="H3588"\w* vosotros».   
\p
\v 16 \w Y|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w* dijeron: «\w No|strong="H3808"\w* nos bastará \w a|strong="H3068"\w* \w nosotros|strong="H3605"\w* este \w monte|strong="H2022"\w*; y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3808"\w* \w habitan|strong="H3427"\w* \w la|strong="H3605"\w* tierra \w de|strong="H1121"\w* \w la|strong="H3605"\w* llanura tienen \w carros|strong="H7393"\w* \w de|strong="H1121"\w* \w hierro|strong="H1270"\w*, \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w están|strong="H3427"\w* en Bet-seán y en sus \w aldeas|strong="H1323"\w*, y \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w están|strong="H3427"\w* en \w el|strong="H3605"\w* \w valle|strong="H6010"\w* \w de|strong="H1121"\w* \w Jezreel|strong="H3157"\w*».   
\p
\v 17 Entonces \w Josué|strong="H3091"\w* respondió \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5971"\w* \w José|strong="H3130"\w*, \w a|strong="H3068"\w* Efraín y \w a|strong="H3068"\w* \w Manasés|strong="H4519"\w*, diciendo: «Tú \w eres|strong="H1961"\w* un \w pueblo|strong="H5971"\w* \w numeroso|strong="H7227"\w* y tienes \w gran|strong="H1419"\w* \w poder|strong="H3581"\w*; \w no|strong="H3808"\w* \w tendrás|strong="H1961"\w* una sola \w suerte|strong="H1486"\w*,  
\v 18 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w aquel|strong="H1931"\w* \w monte|strong="H2022"\w* \w será|strong="H1961"\w* tuyo; \w pues|strong="H3588"\w* \w aunque|strong="H3588"\w* \w es|strong="H1931"\w* \w bosque|strong="H3293"\w*, tú \w lo|strong="H1931"\w* talarás \w y|strong="H3588"\w* \w serán|strong="H1961"\w* tuyos \w sus|strong="H1931"\w* \w términos|strong="H8444"\w*; \w porque|strong="H3588"\w* tú arrojarás al \w cananeo|strong="H3669"\w*, \w aunque|strong="H3588"\w* \w tenga|strong="H1961"\w* \w carros|strong="H7393"\w* \w de|strong="H3588"\w* \w hierro|strong="H1270"\w* \w y|strong="H3588"\w* \w aunque|strong="H3588"\w* \w sea|strong="H1961"\w* \w fuerte|strong="H2389"\w*».   
\c 18
\p
\v 1 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* se reunió en \w Silo|strong="H7887"\w*, y erigieron \w allí|strong="H8033"\w* \w el|strong="H3605"\w* Tabernáculo \w de|strong="H6440"\w* \w la|strong="H3605"\w* reunión, después \w que|strong="H1121"\w* \w la|strong="H3605"\w* tierra les fue sometida.  
\v 2 Pero habían quedado \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w siete|strong="H7651"\w* \w tribus|strong="H7626"\w* \w a|strong="H3068"\w* las cuales \w aún|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* les había repartido su \w heredad|strong="H5159"\w*.  
\v 3 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* dijo \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*: «¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* seréis negligentes \w para|strong="H5704"\w* venir \w a|strong="H3068"\w* poseer la tierra \w que|strong="H5704"\w* \w os|strong="H5704"\w* \w ha|strong="H3423"\w* \w dado|strong="H5414"\w* Yahvé \w el|strong="H1121"\w* \w Dios|strong="H3068"\w* \w de|strong="H5704"\w* vuestros padres?  
\v 4 Elegid de entre vosotros \w tres|strong="H7969"\w* hombres de cada \w tribu|strong="H7626"\w*, para \w que|strong="H6310"\w* yo los \w envíe|strong="H7971"\w*, y \w que|strong="H6310"\w* ellos se levanten y recorran la tierra, y la delineen \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* su \w heredad|strong="H5159"\w*, y vuelvan \w a|strong="H3068"\w* mí.  
\v 5 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* dividirán \w en|strong="H5921"\w* \w siete|strong="H7651"\w* \w partes|strong="H2505"\w*; \w Judá|strong="H3063"\w* \w estará|strong="H5975"\w* \w en|strong="H5921"\w* su territorio \w al|strong="H5921"\w* \w mediodía|strong="H5045"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* suyo \w al|strong="H5921"\w* \w norte|strong="H6828"\w*.  
\v 6 Vosotros, pues, \w delinearéis|strong="H3789"\w* la tierra en \w siete|strong="H7651"\w* partes y me traeréis la descripción \w aquí|strong="H6311"\w*, y yo os echaré \w suertes|strong="H1486"\w* \w aquí|strong="H6311"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé nuestro \w Dios|strong="H3068"\w*.  
\v 7 \w Porque|strong="H3588"\w* \w los|strong="H3588"\w* \w levitas|strong="H3881"\w* ninguna \w parte|strong="H2677"\w* tienen \w entre|strong="H7130"\w* vosotros, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w el|strong="H3588"\w* \w sacerdocio|strong="H3550"\w* \w de|strong="H3588"\w* Yahvé \w es|strong="H3588"\w* \w su|strong="H3588"\w* \w heredad|strong="H5159"\w*; \w Gad|strong="H1410"\w* también \w y|strong="H3588"\w* \w Rubén|strong="H7205"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* media \w tribu|strong="H7626"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w* \w recibieron|strong="H3947"\w* \w su|strong="H3588"\w* \w heredad|strong="H5159"\w* \w al|strong="H7130"\w* otro \w lado|strong="H5676"\w* \w del|strong="H2677"\w* \w Jordán|strong="H3383"\w*, \w al|strong="H7130"\w* \w oriente|strong="H4217"\w*, \w la|strong="H3588"\w* \w cual|strong="H3588"\w* les \w dio|strong="H5414"\w* \w Moisés|strong="H4872"\w* \w siervo|strong="H5650"\w* \w de|strong="H3588"\w* Yahvé».   
\p
\v 8 \w Levantándose|strong="H6965"\w*, pues, aquellos hombres, \w fueron|strong="H3212"\w*; y \w mandó|strong="H6680"\w* \w Josué|strong="H3091"\w* \w a|strong="H3068"\w* los que \w iban|strong="H1980"\w* para delinear la tierra, diciéndoles: «\w Id|strong="H3212"\w*, \w recorred|strong="H1980"\w* la tierra y delineadla, y \w volved|strong="H7725"\w* \w a|strong="H3068"\w* mí, para que \w yo|strong="H6680"\w* os \w eche|strong="H7993"\w* \w suertes|strong="H1486"\w* \w aquí|strong="H6311"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé \w en|strong="H3212"\w* \w Silo|strong="H7887"\w*».   
\p
\v 9 \w Fueron|strong="H3212"\w*, pues, aquellos hombres \w y|strong="H5921"\w* recorrieron \w la|strong="H5921"\w* tierra, \w delineándola|strong="H3789"\w* \w por|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w en|strong="H5921"\w* \w siete|strong="H7651"\w* partes \w en|strong="H5921"\w* un \w libro|strong="H5612"\w*, \w y|strong="H5921"\w* volvieron \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* \w al|strong="H5921"\w* \w campamento|strong="H4264"\w* \w en|strong="H5921"\w* \w Silo|strong="H7887"\w*.  
\v 10 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* les \w echó|strong="H7993"\w* \w suertes|strong="H1486"\w* en \w Silo|strong="H7887"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé; y \w allí|strong="H8033"\w* \w repartió|strong="H2505"\w* \w Josué|strong="H3091"\w* la tierra \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w por|strong="H6440"\w* sus porciones.   
\p
\v 11 \w Y|strong="H3068"\w* \w salió|strong="H3318"\w* \w la|strong="H1366"\w* \w suerte|strong="H1486"\w* \w de|strong="H1121"\w* \w la|strong="H1366"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w* por sus \w familias|strong="H4940"\w*; y \w el|strong="H1121"\w* territorio \w de|strong="H1121"\w* su \w suerte|strong="H1486"\w* quedó entre \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*.  
\v 12 \w Fue|strong="H1961"\w* su límite \w por|strong="H4480"\w* el \w lado|strong="H3802"\w* \w del|strong="H4480"\w* \w norte|strong="H6828"\w* \w desde|strong="H4480"\w* el \w Jordán|strong="H3383"\w*; y \w sube|strong="H5927"\w* el límite \w al|strong="H4480"\w* \w lado|strong="H3802"\w* \w de|strong="H4480"\w* \w Jericó|strong="H3405"\w* \w al|strong="H4480"\w* \w norte|strong="H6828"\w*; \w sube|strong="H5927"\w* \w después|strong="H1961"\w* \w por|strong="H4480"\w* el \w monte|strong="H2022"\w* \w hacia|strong="H4480"\w* el occidente, y \w viene|strong="H5927"\w* \w a|strong="H3068"\w* \w salir|strong="H8444"\w* \w al|strong="H4480"\w* \w desierto|strong="H4057"\w* \w de|strong="H4480"\w* Bet-aven.  
\v 13 \w De|strong="H5921"\w* \w allí|strong="H8033"\w* \w pasa|strong="H5674"\w* \w el|strong="H1931"\w* límite \w a|strong="H3068"\w* \w Luz|strong="H3870"\w*, \w al|strong="H5921"\w* \w lado|strong="H3802"\w* sur \w de|strong="H5921"\w* \w Luz|strong="H3870"\w* (\w que|strong="H1931"\w* \w es|strong="H1931"\w* Bet-el), \w y|strong="H5921"\w* \w desciende|strong="H3381"\w* \w de|strong="H5921"\w* Atarot-adar \w al|strong="H5921"\w* \w monte|strong="H2022"\w* \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w al|strong="H5921"\w* \w mediodía|strong="H5045"\w* \w de|strong="H5921"\w* Bet-horón \w de|strong="H5921"\w* abajo.  
\v 14 \w Y|strong="H3068"\w* rodea \w el|strong="H1931"\w* límite \w y|strong="H5921"\w* da \w la|strong="H1931"\w* \w vuelta|strong="H5437"\w* \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w lado|strong="H6285"\w* \w del|strong="H4480"\w* occidente \w hacia|strong="H5921"\w* \w el|strong="H1931"\w* \w mediodía|strong="H5045"\w*, \w desde|strong="H4480"\w* \w el|strong="H1931"\w* \w monte|strong="H2022"\w* \w que|strong="H4480"\w* \w está|strong="H2063"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* Bet-horón \w al|strong="H5921"\w* \w mediodía|strong="H5045"\w*; \w y|strong="H5921"\w* viene \w a|strong="H3068"\w* \w salir|strong="H8444"\w* \w a|strong="H3068"\w* Quiriat-baal (\w que|strong="H4480"\w* \w es|strong="H1931"\w* Quiriat-jearim), \w ciudad|strong="H5892"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*. \w Este|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w lado|strong="H6285"\w* \w del|strong="H4480"\w* occidente.  
\v 15 El \w lado|strong="H6285"\w* del \w mediodía|strong="H5045"\w* es desde el \w extremo|strong="H7097"\w* \w de|strong="H4325"\w* Quiriat-jearim, y \w sale|strong="H3318"\w* el \w límite|strong="H7097"\w* al occidente \w a|strong="H3068"\w* \w la|strong="H1366"\w* \w fuente|strong="H4599"\w* \w de|strong="H4325"\w* las \w aguas|strong="H4325"\w* \w de|strong="H4325"\w* Neftoa;  
