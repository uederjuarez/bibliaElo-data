\c 5
\p
\v 1 \w Cuando|strong="H5704"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* amorreos \w que|strong="H3808"\w* \w estaban|strong="H1961"\w* \w al|strong="H5921"\w* \w otro|strong="H5750"\w* \w lado|strong="H5676"\w* \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w*, \w al|strong="H5921"\w* occidente, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3808"\w* \w estaban|strong="H1961"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w mar|strong="H3220"\w*, \w oyeron|strong="H8085"\w* \w cómo|strong="H1961"\w* Yahvé \w había|strong="H1961"\w* secado \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* hubimos \w pasado|strong="H5674"\w*, desfalleció su \w corazón|strong="H3824"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w más|strong="H5750"\w* aliento \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 2 En \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* Yahvé dijo \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: «\w Hazte|strong="H6213"\w* \w cuchillos|strong="H2719"\w* \w de|strong="H1121"\w* \w pedernal|strong="H6697"\w* y \w vuelve|strong="H7725"\w* \w a|strong="H3068"\w* circuncidar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* por \w segunda|strong="H8145"\w* \w vez|strong="H6256"\w*».  
\v 3 \w Josué|strong="H3091"\w* se \w hizo|strong="H6213"\w* \w cuchillos|strong="H2719"\w* \w de|strong="H1121"\w* \w pedernal|strong="H6697"\w* y circuncidó \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* en \w el|strong="H1121"\w* \w collado|strong="H1389"\w* \w de|strong="H1121"\w* Aralot.  
\v 4 \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* \w la|strong="H3605"\w* \w causa|strong="H1697"\w* \w por|strong="H1870"\w* \w la|strong="H3605"\w* cual \w Josué|strong="H3091"\w* \w los|strong="H3605"\w* circuncidó: \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* había \w salido|strong="H3318"\w* \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*, \w los|strong="H3605"\w* \w varones|strong="H2145"\w*, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5971"\w* \w guerra|strong="H4421"\w*, habían \w muerto|strong="H4191"\w* \w en|strong="H3318"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w*, \w por|strong="H1870"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w*, después \w que|strong="H5971"\w* \w salieron|strong="H3318"\w* \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*.  
\v 5 \w Pues|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* del \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* \w salieron|strong="H3318"\w* \w estaban|strong="H1961"\w* circuncidados; \w mas|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w habían|strong="H1961"\w* nacido \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*, \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w*, \w después|strong="H1961"\w* \w que|strong="H3588"\w* \w salieron|strong="H3318"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w no|strong="H3808"\w* \w habían|strong="H1961"\w* \w sido|strong="H1961"\w* circuncidados.  
\v 6 \w Porque|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w anduvieron|strong="H1980"\w* cuarenta \w años|strong="H8141"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*, \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* pereció \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w nación|strong="H1471"\w*, \w es|strong="H3588"\w* \w decir|strong="H8085"\w*, \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* \w guerra|strong="H4421"\w* \w que|strong="H3588"\w* habían \w salido|strong="H3318"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w no|strong="H3808"\w* \w obedecieron|strong="H8085"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* Yahvé; \w por|strong="H3588"\w* \w lo|strong="H3808"\w* \w cual|strong="H3588"\w* Yahvé les \w juró|strong="H7650"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* les dejaría \w ver|strong="H7200"\w* \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* Yahvé \w había|strong="H3588"\w* \w jurado|strong="H7650"\w* \w a|strong="H3068"\w* sus padres \w que|strong="H3588"\w* nos \w daría|strong="H5414"\w*, tierra \w que|strong="H3588"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* \w y|strong="H3588"\w* \w miel|strong="H1706"\w*.  
\v 7 \w A|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* ellos, \w que|strong="H3588"\w* \w él|strong="H3588"\w* \w había|strong="H1961"\w* levantado \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w lugar|strong="H8478"\w*, \w Josué|strong="H3091"\w* \w los|strong="H1121"\w* circuncidó; \w pues|strong="H3588"\w* \w eran|strong="H1961"\w* \w incircuncisos|strong="H6189"\w*, \w por|strong="H3588"\w* \w no|strong="H3808"\w* haberlos \w circuncidado|strong="H4135"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w*.  
\v 8 \w Y|strong="H3068"\w* \w cuando|strong="H5704"\w* acabaron \w de|strong="H8478"\w* circuncidar \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w nación|strong="H1471"\w*, \w se|strong="H1961"\w* \w quedaron|strong="H1961"\w* \w en|strong="H5704"\w* sus mismos puestos \w en|strong="H5704"\w* \w el|strong="H3605"\w* \w campamento|strong="H4264"\w* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* sanaron.   
\p
\v 9 \w Entonces|strong="H3117"\w* Yahvé dijo \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: «\w Hoy|strong="H3117"\w* he quitado \w de|strong="H5921"\w* vosotros \w el|strong="H1931"\w* \w oprobio|strong="H2781"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*»; \w por|strong="H5921"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w el|strong="H1931"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* \w fue|strong="H1931"\w* \w llamado|strong="H8034"\w* \w Gilgal|strong="H1537"\w*\f + \fr 5:9 \ft «Gilgal» suena como el término hebreo para «rodar» o «círculo».\f* \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w hoy|strong="H3117"\w*.  
\v 10 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* acamparon en \w Gilgal|strong="H1537"\w*, y celebraron la \w Pascua|strong="H6453"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* catorce \w días|strong="H3117"\w* del \w mes|strong="H2320"\w*, al atardecer, en las estepas \w de|strong="H1121"\w* \w Jericó|strong="H3405"\w*.  
\v 11 Al \w día|strong="H3117"\w* \w siguiente|strong="H4283"\w* de la \w Pascua|strong="H6453"\w* comieron de los frutos de la tierra, panes \w ázimos|strong="H4682"\w* y \w espigas|strong="H2088"\w* tostadas en \w aquel|strong="H2088"\w* \w mismo|strong="H6106"\w* \w día|strong="H3117"\w*.  
\v 12 \w Y|strong="H3068"\w* \w el|strong="H1931"\w* \w maná|strong="H4478"\w* \w cesó|strong="H7673"\w* al \w día|strong="H1121"\w* \w siguiente|strong="H4283"\w*, desde \w que|strong="H1931"\w* comenzaron \w a|strong="H3068"\w* comer del \w fruto|strong="H8393"\w* \w de|strong="H5750"\w* \w la|strong="H1931"\w* tierra; y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w tuvieron|strong="H1961"\w* \w maná|strong="H4478"\w*, \w sino|strong="H3808"\w* \w que|strong="H1931"\w* comieron \w de|strong="H5750"\w* \w los|strong="H1121"\w* productos \w de|strong="H5750"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5750"\w* \w Canaán|strong="H3667"\w* \w aquel|strong="H1931"\w* \w año|strong="H8141"\w*.   
\p
\v 13 \w Estando|strong="H1961"\w* \w Josué|strong="H3091"\w* cerca \w de|strong="H5048"\w* \w Jericó|strong="H3405"\w*, \w alzó|strong="H5375"\w* sus \w ojos|strong="H5869"\w* y \w vio|strong="H7200"\w* \w a|strong="H3068"\w* un hombre \w que|strong="H1961"\w* \w estaba|strong="H1961"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* él, el cual \w tenía|strong="H1961"\w* una \w espada|strong="H2719"\w* desenvainada \w en|strong="H5975"\w* su \w mano|strong="H3027"\w*. \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w yendo|strong="H3212"\w* hacia él, \w le|strong="H5869"\w* dijo: «¿\w Eres|strong="H1961"\w* \w de|strong="H5048"\w* \w los|strong="H1961"\w* nuestros \w o|strong="H3068"\w* \w de|strong="H5048"\w* nuestros \w enemigos|strong="H6862"\w*?».   
\p
\v 14 \w Él|strong="H3588"\w* respondió: «\w No|strong="H3808"\w*; \w mas|strong="H3588"\w* \w yo|strong="H3588"\w* soy \w el|strong="H3588"\w* \w Príncipe|strong="H8269"\w* del \w ejército|strong="H6635"\w* \w de|strong="H3588"\w* Yahvé, \w que|strong="H3588"\w* \w ahora|strong="H6258"\w* he venido». \w Entonces|strong="H3588"\w* \w Josué|strong="H3091"\w*, \w postrándose|strong="H5307"\w* sobre \w su|strong="H3588"\w* \w rostro|strong="H6440"\w* \w en|strong="H3588"\w* tierra, le \w adoró|strong="H7812"\w* \w y|strong="H3588"\w* le \w dijo|strong="H1696"\w*: «¿\w Qué|strong="H3588"\w* \w dice|strong="H1696"\w* mi \w Señor|strong="H3068"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w siervo|strong="H5650"\w*?».   
\p
\v 15 \w Y|strong="H3068"\w* \w el|strong="H1931"\w* \w Príncipe|strong="H8269"\w* \w del|strong="H5921"\w* \w ejército|strong="H6635"\w* \w de|strong="H5921"\w* Yahvé respondió \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: «\w Quita|strong="H5394"\w* \w el|strong="H1931"\w* calzado \w de|strong="H5921"\w* tus \w pies|strong="H7272"\w*, \w porque|strong="H3588"\w* \w el|strong="H1931"\w* \w lugar|strong="H4725"\w* \w donde|strong="H5921"\w* \w estás|strong="H5975"\w* \w es|strong="H1931"\w* \w santo|strong="H6944"\w*». \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* \w lo|strong="H1931"\w* \w hizo|strong="H6213"\w* \w así|strong="H3651"\w*.   
\c 6
\p
\v 1 \w Jericó|strong="H3405"\w* estaba \w cerrada|strong="H5462"\w*, bien \w cerrada|strong="H5462"\w*, \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*; nadie \w salía|strong="H3318"\w* ni entraba.  
\v 2 Mas Yahvé dijo \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: «\w Mira|strong="H7200"\w*, yo he \w entregado|strong="H5414"\w* en tu \w mano|strong="H3027"\w* \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w* y \w a|strong="H3068"\w* su \w rey|strong="H4428"\w*, con sus varones \w de|strong="H5414"\w* guerra.  
\v 3 Rodearéis, pues, \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres de \w guerra|strong="H4421"\w*, yendo \w alrededor|strong="H5437"\w* de \w ella|strong="H3605"\w* \w una|strong="H6471"\w* \w vez|strong="H6471"\w*; \w y|strong="H3541"\w* \w esto|strong="H3541"\w* \w haréis|strong="H6213"\w* durante \w seis|strong="H8337"\w* \w días|strong="H3117"\w*.  
\v 4 \w Y|strong="H3068"\w* \w siete|strong="H7651"\w* \w sacerdotes|strong="H3548"\w* \w llevarán|strong="H5375"\w* \w siete|strong="H7651"\w* \w bocinas|strong="H7782"\w* \w de|strong="H6440"\w* cuernos \w de|strong="H6440"\w* carnero \w delante|strong="H6440"\w* del arca; y al \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w* \w daréis|strong="H5437"\w* \w siete|strong="H7651"\w* \w vueltas|strong="H6471"\w* \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w*, y los \w sacerdotes|strong="H3548"\w* \w tocarán|strong="H8628"\w* las \w bocinas|strong="H7782"\w*.  
\v 5 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* toquen prolongadamente \w el|strong="H3605"\w* \w cuerno|strong="H7161"\w* \w de|strong="H8478"\w* carnero, así \w que|strong="H5971"\w* \w oigáis|strong="H8085"\w* \w el|strong="H3605"\w* \w sonido|strong="H6963"\w* \w de|strong="H8478"\w* \w la|strong="H3605"\w* \w bocina|strong="H7782"\w*, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w gritará|strong="H7321"\w* \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*, y \w el|strong="H3605"\w* \w muro|strong="H2346"\w* \w de|strong="H8478"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w caerá|strong="H5307"\w* \w de|strong="H8478"\w* plano; entonces \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w subirá|strong="H5927"\w*, \w cada|strong="H3605"\w* uno derecho hacia adelante».   
\p
\v 6 \w Llamando|strong="H7121"\w*, pues, \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Nun|strong="H5126"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, les dijo: «\w Tomad|strong="H5375"\w* \w el|strong="H1121"\w* arca del \w pacto|strong="H1285"\w*, y \w que|strong="H1121"\w* \w siete|strong="H7651"\w* \w sacerdotes|strong="H3548"\w* \w lleven|strong="H5375"\w* \w siete|strong="H7651"\w* \w bocinas|strong="H7782"\w* \w de|strong="H6440"\w* cuernos \w de|strong="H6440"\w* carnero \w delante|strong="H6440"\w* del arca \w de|strong="H6440"\w* Yahvé».   
\p
\v 7 \w Y|strong="H3068"\w* dijo al \w pueblo|strong="H5971"\w*: «\w Pasad|strong="H5674"\w*, y rodead la \w ciudad|strong="H5892"\w*; y los \w que|strong="H5971"\w* están \w armados|strong="H2502"\w* \w pasarán|strong="H5674"\w* \w delante|strong="H6440"\w* del arca \w de|strong="H6440"\w* Yahvé».   
\p
\v 8 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H5971"\w* \w cuando|strong="H1961"\w* \w Josué|strong="H3091"\w* \w hubo|strong="H1961"\w* hablado al \w pueblo|strong="H5971"\w*, \w los|strong="H1961"\w* \w siete|strong="H7651"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H5971"\w* \w llevaban|strong="H5375"\w* las \w siete|strong="H7651"\w* \w bocinas|strong="H7782"\w* \w de|strong="H6440"\w* cuernos \w de|strong="H6440"\w* carnero \w pasaron|strong="H5674"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé y \w tocaron|strong="H8628"\w* las \w bocinas|strong="H7782"\w*; y \w el|strong="H5674"\w* arca del \w pacto|strong="H1285"\w* \w de|strong="H6440"\w* Yahvé \w los|strong="H1961"\w* \w seguía|strong="H1961"\w*.  
\v 9 \w Y|strong="H3068"\w* los hombres \w armados|strong="H2502"\w* \w iban|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* los \w sacerdotes|strong="H3548"\w* que \w tocaban|strong="H8628"\w* las \w bocinas|strong="H7782"\w*, y la retaguardia \w iba|strong="H1980"\w* tras el arca, mientras las \w bocinas|strong="H7782"\w* sonaban continuamente.   
\p
\v 10 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* \w mandó|strong="H6680"\w* \w al|strong="H5704"\w* \w pueblo|strong="H5971"\w*, diciendo: “\w Vosotros|strong="H8085"\w* \w no|strong="H3808"\w* gritaréis, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* \w oirá|strong="H8085"\w* vuestra \w voz|strong="H6963"\w*, \w ni|strong="H3808"\w* \w saldrá|strong="H3318"\w* \w palabra|strong="H1697"\w* \w de|strong="H5704"\w* vuestra \w boca|strong="H6310"\w*, \w hasta|strong="H5704"\w* el \w día|strong="H3117"\w* \w en|strong="H5704"\w* \w que|strong="H3808"\w* \w yo|strong="H6680"\w* \w os|strong="H5704"\w* diga: «¡\w Gritad|strong="H7321"\w*!»; \w entonces|strong="H3117"\w* gritaréis”.  
\v 11 Así hizo que \w el|strong="H3885"\w* arca de Yahvé diera \w una|strong="H6471"\w* \w vuelta|strong="H5362"\w* \w alrededor|strong="H5437"\w* de la \w ciudad|strong="H5892"\w*; y volvieron al \w campamento|strong="H4264"\w*, y allí pasaron la noche.  
\v 12 \w Josué|strong="H3091"\w* se \w levantó|strong="H5375"\w* muy de \w mañana|strong="H1242"\w*, y los \w sacerdotes|strong="H3548"\w* \w tomaron|strong="H5375"\w* el arca de Yahvé.  
