\v 22 “\w El|strong="H1931"\w* \w Dios|strong="H3068"\w* de \w los|strong="H1931"\w* dioses, Yahvé, \w el|strong="H1931"\w* \w Dios|strong="H3068"\w* de \w los|strong="H1931"\w* dioses, Yahvé, \w él|strong="H1931"\w* \w lo|strong="H1931"\w* \w sabe|strong="H3045"\w*, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w lo|strong="H1931"\w* \w sabrá|strong="H3045"\w*: \w si|strong="H1931"\w* \w fue|strong="H1931"\w* \w por|strong="H2088"\w* rebelión \w o|strong="H3068"\w* \w por|strong="H2088"\w* \w prevaricación|strong="H4604"\w* \w contra|strong="H3478"\w* Yahvé, no nos \w salve|strong="H3467"\w* \w hoy|strong="H3117"\w*.  
\v 23 \w Si|strong="H1931"\w* \w nos|strong="H5921"\w* hemos \w edificado|strong="H1129"\w* \w altar|strong="H4196"\w* \w para|strong="H5921"\w* apartarnos \w de|strong="H5921"\w* seguir \w a|strong="H3068"\w* Yahvé, \w o|strong="H3068"\w* \w para|strong="H5921"\w* ofrecer \w holocaustos|strong="H5930"\w* u ofrendas, \w o|strong="H3068"\w* \w para|strong="H5921"\w* \w hacer|strong="H6213"\w* \w sacrificios|strong="H2077"\w* \w de|strong="H5921"\w* paz, Yahvé \w mismo|strong="H1931"\w* \w nos|strong="H5921"\w* \w lo|strong="H1931"\w* demande.   
\p
\v 24 \w Lo|strong="H1697"\w* \w hicimos|strong="H6213"\w* \w más|strong="H3808"\w* bien \w por|strong="H1697"\w* temor \w de|strong="H1121"\w* \w que|strong="H4100"\w* \w mañana|strong="H4279"\w* vuestros \w hijos|strong="H1121"\w* digan \w a|strong="H3068"\w* \w los|strong="H1121"\w* nuestros: «¿\w Qué|strong="H4100"\w* tenéis vosotros \w que|strong="H4100"\w* ver con Yahvé \w Dios|strong="H3068"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*?  
