\v 23 \w Entonces|strong="H7725"\w* \w los|strong="H1121"\w* \w dos|strong="H8147"\w* \w hombres|strong="H1121"\w* \w volvieron|strong="H7725"\w*, \w descendieron|strong="H3381"\w* del \w monte|strong="H2022"\w* y \w pasaron|strong="H5674"\w* \w el|strong="H3605"\w* río, y \w vinieron|strong="H3381"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, y le \w contaron|strong="H5608"\w* \w todas|strong="H3605"\w* las \w cosas|strong="H8147"\w* \w que|strong="H1121"\w* les habían acontecido.  
\v 24 \w Y|strong="H3068"\w* dijeron \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: «Yahvé ha \w entregado|strong="H5414"\w* \w toda|strong="H3605"\w* \w la|strong="H1571"\w* tierra \w en|strong="H3588"\w* nuestras \w manos|strong="H3027"\w*; \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* del país desmayan \w ante|strong="H6440"\w* \w nosotros|strong="H3605"\w*».   
\c 3
\p
\v 1 \w Josué|strong="H3091"\w* \w se|strong="H1931"\w* levantó muy \w de|strong="H5704"\w* \w mañana|strong="H1242"\w*; \w partieron|strong="H5265"\w* \w de|strong="H5704"\w* Sitim \w y|strong="H5704"\w* llegaron \w al|strong="H5704"\w* \w Jordán|strong="H3383"\w*, \w él|strong="H1931"\w* \w y|strong="H5704"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5704"\w* acamparon \w allí|strong="H8033"\w* \w antes|strong="H2962"\w* \w de|strong="H5704"\w* \w pasar|strong="H5674"\w* \w al|strong="H5704"\w* otro lado.  
\v 2 \w Pasados|strong="H7097"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w*, \w los|strong="H1961"\w* \w oficiales|strong="H7860"\w* recorrieron \w el|strong="H5674"\w* \w campamento|strong="H4264"\w*  
\v 3 y dieron órdenes al \w pueblo|strong="H5971"\w*, diciendo: «Cuando \w veáis|strong="H7200"\w* el arca del \w pacto|strong="H1285"\w* \w de|strong="H5971"\w* Yahvé vuestro \w Dios|strong="H3068"\w*, y \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* \w levitas|strong="H3881"\w* \w que|strong="H5971"\w* la \w llevan|strong="H5375"\w*, dejad vuestro \w lugar|strong="H4725"\w* y marchad tras ella.  
\v 4 \w Pero|strong="H3588"\w* \w que|strong="H3588"\w* \w haya|strong="H1961"\w* \w entre|strong="H3808"\w* vosotros \w y|strong="H3588"\w* ella una \w distancia|strong="H7350"\w* \w de|strong="H3588"\w* unos dos mil codos\f + \fr 3:4 \ft Un codo es la longitud desde el codo hasta la punta del dedo corazón de un hombre, esto es, unos 45 centímetros; por tanto, dos mil codos equivalen a unos 900 metros. No os acerquéis a ella.\f* \w por|strong="H3588"\w* \w medida|strong="H4060"\w*; \w no|strong="H3808"\w* os acerquéis \w a|strong="H3068"\w* ella, \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w sepáis|strong="H3045"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w por|strong="H3588"\w* donde debéis \w ir|strong="H3212"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* vosotros \w no|strong="H3808"\w* habéis \w pasado|strong="H5674"\w* \w antes|strong="H3588"\w* \w de|strong="H3588"\w* ahora \w por|strong="H3588"\w* \w este|strong="H1961"\w* \w camino|strong="H1870"\w*».   
\p
