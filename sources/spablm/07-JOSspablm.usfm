\mt2 El libro de  
\mt1 Josué  
\c 1
\p
\v 1 \w Después|strong="H1961"\w* \w de|strong="H1121"\w* la \w muerte|strong="H4194"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*, \w siervo|strong="H5650"\w* \w de|strong="H1121"\w* Yahvé,\f + \fr 1:1 \ft «Yahvé» es el nombre propio de Dios, a veces vertido como «SEÑOR» (en mayúsculas) en otras traducciones.\f* Yahvé habló \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, servidor \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*, diciendo:  
\v 2 “\w Moisés|strong="H4872"\w*, mi \w siervo|strong="H5650"\w*, ha \w muerto|strong="H4191"\w*. \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w levántate|strong="H6965"\w* y \w pasa|strong="H5674"\w* \w este|strong="H2088"\w* \w Jordán|strong="H3383"\w*, tú y \w todo|strong="H3605"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, hacia \w la|strong="H3605"\w* tierra \w que|strong="H6258"\w* yo les \w doy|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.  
\v 3 Os he \w dado|strong="H5414"\w*, tal \w como|strong="H7272"\w* \w dije|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w todo|strong="H3605"\w* \w lugar|strong="H4725"\w* \w que|strong="H1869"\w* pise \w la|strong="H3605"\w* planta \w de|strong="H5414"\w* vuestro \w pie|strong="H7272"\w*.  
\v 4 \w Desde|strong="H5704"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w* \w y|strong="H5704"\w* \w el|strong="H3605"\w* \w Líbano|strong="H3844"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w gran|strong="H1419"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*, \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5704"\w* \w los|strong="H3605"\w* hititas \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w gran|strong="H1419"\w* \w mar|strong="H3220"\w* donde \w se|strong="H1961"\w* pone \w el|strong="H3605"\w* \w sol|strong="H8121"\w*, \w será|strong="H1961"\w* vuestro territorio.  
\v 5 \w Nadie|strong="H3808"\w* \w te|strong="H5973"\w* \w podrá|strong="H3808"\w* hacer frente \w en|strong="H5973"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H6440"\w* tu \w vida|strong="H2416"\w*. \w Como|strong="H5973"\w* \w estuve|strong="H1961"\w* \w con|strong="H5973"\w* \w Moisés|strong="H4872"\w*, estaré \w contigo|strong="H5973"\w*; \w no|strong="H3808"\w* \w te|strong="H5973"\w* \w dejaré|strong="H5800"\w* \w ni|strong="H3808"\w* \w te|strong="H5973"\w* desampararé.   
\p
\v 6 “\w Esfuérzate|strong="H2388"\w* \w y|strong="H3588"\w* \w sé|strong="H5971"\w* valiente, \w porque|strong="H3588"\w* tú \w repartirás|strong="H5157"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w como|strong="H3588"\w* heredad \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w juré|strong="H7650"\w* \w a|strong="H3068"\w* sus padres \w que|strong="H3588"\w* \w se|strong="H5971"\w* \w la|strong="H3588"\w* \w daría|strong="H5414"\w* \w a|strong="H3068"\w* ellos.  
\v 7 \w Solo|strong="H7535"\w* \w esfuérzate|strong="H2388"\w* y \w sé|strong="H4480"\w* \w muy|strong="H3966"\w* valiente, \w para|strong="H4616"\w* cuidar \w de|strong="H4480"\w* obrar conforme \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H8104"\w* \w ley|strong="H8451"\w* \w que|strong="H4480"\w* mi \w siervo|strong="H5650"\w* \w Moisés|strong="H4872"\w* \w te|strong="H4480"\w* \w mandó|strong="H6680"\w*; \w no|strong="H6213"\w* \w te|strong="H4480"\w* apartes \w de|strong="H4480"\w* \w ella|strong="H4480"\w* ni \w a|strong="H3068"\w* \w la|strong="H8104"\w* \w derecha|strong="H3225"\w* ni \w a|strong="H3068"\w* \w la|strong="H8104"\w* \w izquierda|strong="H8040"\w*, \w para|strong="H4616"\w* \w que|strong="H4480"\w* seas prosperado \w en|strong="H4480"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H4480"\w* emprendas.  
\v 8 \w Nunca|strong="H3808"\w* \w se|strong="H3808"\w* apartará \w de|strong="H3588"\w* \w tu|strong="H6213"\w* \w boca|strong="H6310"\w* \w este|strong="H2088"\w* \w libro|strong="H5612"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w ley|strong="H8451"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w de|strong="H3588"\w* \w día|strong="H3119"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w noche|strong="H3915"\w* \w meditarás|strong="H1897"\w* \w en|strong="H3588"\w* \w él|strong="H3588"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w guardes|strong="H6213"\w* \w y|strong="H3588"\w* \w hagas|strong="H6213"\w* \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H2088"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w él|strong="H3588"\w* \w está|strong="H2088"\w* \w escrito|strong="H3789"\w*; \w porque|strong="H3588"\w* \w entonces|strong="H3588"\w* \w harás|strong="H6213"\w* \w prosperar|strong="H6743"\w* \w tu|strong="H6213"\w* \w camino|strong="H1870"\w*, \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w te|strong="H3588"\w* saldrá \w bien|strong="H3588"\w*.  
\v 9 ¿\w No|strong="H3808"\w* \w te|strong="H3588"\w* \w lo|strong="H3808"\w* he \w mandado|strong="H6680"\w* \w yo|strong="H3588"\w*? \w Esfuérzate|strong="H2388"\w* \w y|strong="H3588"\w* \w sé|strong="H3808"\w* valiente; \w no|strong="H3808"\w* \w temas|strong="H2865"\w* \w ni|strong="H3808"\w* \w desmayes|strong="H2865"\w*, \w porque|strong="H3588"\w* Yahvé, tu \w Dios|strong="H3068"\w*,\f + \fr 1:9 \ft El término hebreo traducido por «Dios» es «אֱלֹהִ֑ים» (Elohim).\f* \w estará|strong="H3605"\w* \w contigo|strong="H5973"\w* \w en|strong="H5973"\w* dondequiera \w que|strong="H3588"\w* \w vayas|strong="H3212"\w*”.   
\p
\v 10 Entonces \w Josué|strong="H3091"\w* \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* los \w oficiales|strong="H7860"\w* del \w pueblo|strong="H5971"\w*, diciendo:  
\v 11 «\w Pasad|strong="H5674"\w* \w por|strong="H3588"\w* \w medio|strong="H7130"\w* del \w campamento|strong="H4264"\w* \w y|strong="H3588"\w* \w dad|strong="H5414"\w* órdenes \w al|strong="H7130"\w* \w pueblo|strong="H5971"\w*, diciendo: «Preparad \w víveres|strong="H6720"\w*, \w porque|strong="H3588"\w* \w dentro|strong="H7130"\w* \w de|strong="H3588"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w pasaréis|strong="H5674"\w* \w este|strong="H2088"\w* \w Jordán|strong="H3383"\w* \w para|strong="H3588"\w* entrar \w a|strong="H3068"\w* poseer \w la|strong="H3588"\w* tierra \w que|strong="H3588"\w* Yahvé vuestro \w Dios|strong="H3068"\w* os \w da|strong="H5414"\w* \w en|strong="H3588"\w* posesión»».   
\p
\v 12 También habló \w Josué|strong="H3091"\w* \w a|strong="H3068"\w* los rubenitas y \w gaditas|strong="H1425"\w* y \w a|strong="H3068"\w* la media \w tribu|strong="H7626"\w* de \w Manasés|strong="H4519"\w*, diciendo:  
\v 13 “\w Acordaos|strong="H2142"\w* \w de|strong="H1697"\w* \w la|strong="H2063"\w* \w palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w Moisés|strong="H4872"\w*, \w siervo|strong="H5650"\w* \w de|strong="H1697"\w* Yahvé, os \w mandó|strong="H6680"\w* diciendo: «Yahvé vuestro \w Dios|strong="H3068"\w* os ha \w dado|strong="H5414"\w* \w reposo|strong="H5117"\w*, y os ha \w dado|strong="H5414"\w* \w esta|strong="H2063"\w* tierra».  
\v 14 Vuestras mujeres, vuestros \w niños|strong="H2945"\w* y vuestros \w ganados|strong="H4735"\w* \w quedarán|strong="H3427"\w* en \w la|strong="H3605"\w* tierra \w que|strong="H3605"\w* \w Moisés|strong="H4872"\w* os \w dio|strong="H5414"\w* \w a|strong="H3068"\w* este \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*; mas vosotros, \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w valientes|strong="H1368"\w* y \w fuertes|strong="H2428"\w*, \w pasaréis|strong="H5674"\w* \w armados|strong="H2571"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vuestros hermanos, y les ayudaréis,  
\v 15 \w hasta|strong="H5704"\w* tanto \w que|strong="H5704"\w* Yahvé haya \w dado|strong="H5414"\w* \w reposo|strong="H5117"\w* \w a|strong="H3068"\w* vuestros hermanos, \w como|strong="H1571"\w* \w a|strong="H3068"\w* vosotros, \w y|strong="H1571"\w* \w ellos|strong="H1992"\w* \w también|strong="H1571"\w* \w posean|strong="H3423"\w* \w la|strong="H1571"\w* tierra \w que|strong="H5704"\w* Yahvé vuestro \w Dios|strong="H3068"\w* \w les|strong="H1992"\w* \w da|strong="H5414"\w*; \w después|strong="H5704"\w* \w volveréis|strong="H7725"\w* vosotros \w a|strong="H3068"\w* \w la|strong="H1571"\w* tierra \w de|strong="H5704"\w* vuestra herencia, \w la|strong="H1571"\w* cual \w Moisés|strong="H4872"\w* \w siervo|strong="H5650"\w* \w de|strong="H5704"\w* Yahvé \w os|strong="H5704"\w* \w ha|strong="H3423"\w* \w dado|strong="H5414"\w* \w a|strong="H3068"\w* \w este|strong="H4217"\w* \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, hacia donde \w nace|strong="H4217"\w* \w el|strong="H1571"\w* \w sol|strong="H8121"\w*, \w y|strong="H1571"\w* entraréis \w en|strong="H5704"\w* \w posesión|strong="H3425"\w* \w de|strong="H5704"\w* ella”.   
\p
\v 16 Entonces \w respondieron|strong="H6030"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, diciendo: «\w Nosotros|strong="H3605"\w* \w haremos|strong="H6213"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H3605"\w* nos has \w mandado|strong="H6680"\w*, \w e|strong="H3068"\w* \w iremos|strong="H3212"\w* adondequiera \w que|strong="H3605"\w* nos envíes.  
\v 17 \w De|strong="H5973"\w* \w la|strong="H3605"\w* manera \w que|strong="H1961"\w* \w obedecimos|strong="H8085"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w en|strong="H5973"\w* \w todas|strong="H3605"\w* las cosas, \w así|strong="H3651"\w* \w te|strong="H5973"\w* \w obedeceremos|strong="H8085"\w* \w a|strong="H3068"\w* \w ti|strong="H5973"\w*; \w solamente|strong="H7535"\w* \w que|strong="H1961"\w* Yahvé tu \w Dios|strong="H3068"\w* \w esté|strong="H1961"\w* \w contigo|strong="H5973"\w*, \w como|strong="H5973"\w* \w estuvo|strong="H1961"\w* \w con|strong="H5973"\w* \w Moisés|strong="H4872"\w*.  
\v 18 \w Cualquiera|strong="H3605"\w* \w que|strong="H3808"\w* fuere rebelde \w a|strong="H3068"\w* tu \w mandamiento|strong="H6310"\w*, y \w no|strong="H3808"\w* \w obedeciere|strong="H8085"\w* \w a|strong="H3068"\w* tus \w palabras|strong="H1697"\w* en \w todas|strong="H3605"\w* las \w cosas|strong="H1697"\w* \w que|strong="H3808"\w* le mandes, \w que|strong="H3808"\w* \w muera|strong="H4191"\w*; \w solamente|strong="H7535"\w* \w esfuérzate|strong="H2388"\w* y \w sé|strong="H3808"\w* valiente».   
\c 2
\p
\v 1 \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Nun|strong="H5126"\w* \w envió|strong="H7971"\w* \w desde|strong="H4480"\w* Sitim \w secretamente|strong="H2791"\w* \w a|strong="H3068"\w* \w dos|strong="H8147"\w* \w espías|strong="H7270"\w*, diciéndoles: «\w Id|strong="H3212"\w*, \w reconoced|strong="H7200"\w* la tierra y especialmente \w Jericó|strong="H3405"\w*». \w Ellos|strong="H4480"\w* \w fueron|strong="H3212"\w* y \w entraron|strong="H3212"\w* \w en|strong="H4480"\w* \w casa|strong="H1004"\w* \w de|strong="H4480"\w* una prostituta \w que|strong="H4480"\w* \w se|strong="H4480"\w* \w llamaba|strong="H8034"\w* \w Rahab|strong="H7343"\w*, y posaron \w allí|strong="H8033"\w*.   
\p
\v 2 \w Y|strong="H3068"\w* se dio aviso \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Jericó|strong="H3405"\w*, diciendo: “He \w aquí|strong="H2008"\w*,\f + \fr 2:2 \ft «He aquí», del hebreo «hinneh», es una interjección que invita a observar con atención, fijarse o contemplar.\f* \w que|strong="H1121"\w* unos \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* han venido \w aquí|strong="H2008"\w* esta \w noche|strong="H3915"\w* para espiar la tierra”.   
\p
\v 3 \w Entonces|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Jericó|strong="H3405"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w Rahab|strong="H7343"\w*: «\w Saca|strong="H3318"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* hombres \w que|strong="H3588"\w* han venido \w a|strong="H3068"\w* ti \w y|strong="H3588"\w* han entrado \w en|strong="H3588"\w* tu \w casa|strong="H1004"\w*, \w porque|strong="H3588"\w* han venido \w para|strong="H3588"\w* espiar \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra».   
\p
\v 4 Pero la mujer había \w tomado|strong="H3947"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w dos|strong="H8147"\w* \w hombres|strong="H8147"\w* y \w los|strong="H1992"\w* había escondido; y dijo: «Es \w verdad|strong="H3651"\w* \w que|strong="H3808"\w* \w unos|strong="H1992"\w* \w hombres|strong="H8147"\w* vinieron \w a|strong="H3068"\w* mí, pero \w no|strong="H3808"\w* \w supe|strong="H3045"\w* de dónde \w eran|strong="H3808"\w*.  
\v 5 \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w se|strong="H3045"\w* \w iba|strong="H1980"\w* \w a|strong="H3068"\w* cerrar \w la|strong="H3588"\w* \w puerta|strong="H8179"\w*, siendo ya oscuro, \w los|strong="H7291"\w* hombres \w salieron|strong="H3318"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w sé|strong="H3045"\w* \w a|strong="H3068"\w* dónde \w se|strong="H3045"\w* han ido; perseguidlos \w de|strong="H3588"\w* prisa, \w que|strong="H3588"\w* \w los|strong="H7291"\w* alcanzaréis».  
\v 6 \w Mas|strong="H5921"\w* \w ella|strong="H1931"\w* \w los|strong="H5921"\w* había hecho \w subir|strong="H5927"\w* \w al|strong="H5921"\w* \w terrado|strong="H1406"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* había escondido \w entre|strong="H5921"\w* \w los|strong="H5921"\w* manojos \w de|strong="H5921"\w* \w lino|strong="H6593"\w* \w que|strong="H1931"\w* \w tenía|strong="H1931"\w* puestos \w en|strong="H5921"\w* orden \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w terrado|strong="H1406"\w*.  
\v 7 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* hombres \w fueron|strong="H7291"\w* tras \w ellos|strong="H5921"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w* \w hasta|strong="H5921"\w* \w los|strong="H5921"\w* vados; \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* fue \w cerrada|strong="H5462"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w que|strong="H5921"\w* \w salieron|strong="H3318"\w* \w los|strong="H5921"\w* \w perseguidores|strong="H7291"\w*.  
\v 8 \w Antes|strong="H2962"\w* \w de|strong="H5921"\w* \w que|strong="H1931"\w* \w ellos|strong="H1992"\w* \w se|strong="H1931"\w* acostasen, \w ella|strong="H1931"\w* \w subió|strong="H5927"\w* \w al|strong="H5921"\w* \w terrado|strong="H1406"\w* \w donde|strong="H5921"\w* \w ellos|strong="H1992"\w* estaban,  
\v 9 \w y|strong="H3588"\w* dijo \w a|strong="H3068"\w* \w los|strong="H3427"\w* hombres: «\w Sé|strong="H3045"\w* \w que|strong="H3588"\w* Yahvé \w os|strong="H5921"\w* ha \w dado|strong="H5414"\w* \w esta|strong="H3427"\w* tierra; \w porque|strong="H3588"\w* \w el|strong="H5921"\w* temor \w de|strong="H5921"\w* vosotros ha \w caído|strong="H5307"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w*, \w y|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w del|strong="H5921"\w* país ya han desmayado \w por|strong="H5921"\w* vuestra \w causa|strong="H6440"\w*.  
\v 10 \w Porque|strong="H3588"\w* hemos \w oído|strong="H8085"\w* \w que|strong="H3588"\w* Yahvé \w hizo|strong="H6213"\w* secar las \w aguas|strong="H4325"\w* del \w mar|strong="H3220"\w* Rojo \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w vosotros|strong="H8085"\w* \w cuando|strong="H3588"\w* \w salisteis|strong="H3318"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H3588"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* habéis \w hecho|strong="H6213"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w dos|strong="H8147"\w* \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* amorreos \w que|strong="H3588"\w* \w estaban|strong="H4325"\w* \w al|strong="H4428"\w* otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, \w a|strong="H3068"\w* \w Sehón|strong="H5511"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w Og|strong="H5747"\w*, \w a|strong="H3068"\w* \w los|strong="H3588"\w* cuales habéis destruido \w por|strong="H3588"\w* completo.  
\v 11 \w Oyendo|strong="H8085"\w* \w esto|strong="H1931"\w*, \w ha|strong="H3808"\w* desmayado nuestro \w corazón|strong="H3824"\w*; \w ni|strong="H3808"\w* \w ha|strong="H3808"\w* quedado \w más|strong="H5750"\w* aliento \w en|strong="H5921"\w* hombre \w alguno|strong="H5750"\w* \w por|strong="H5921"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w vosotros|strong="H8085"\w*, \w porque|strong="H3588"\w* Yahvé vuestro \w Dios|strong="H3068"\w* \w es|strong="H1931"\w* \w Dios|strong="H3068"\w* \w arriba|strong="H4605"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w* \w y|strong="H3588"\w* \w abajo|strong="H8478"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* tierra.  
