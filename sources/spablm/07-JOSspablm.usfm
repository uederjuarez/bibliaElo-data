\v 27 \w Estaba|strong="H1961"\w*, \w pues|strong="H1961"\w*, Yahvé con \w Josué|strong="H3091"\w*, y su fama \w se|strong="H1961"\w* divulgó por \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra.   
\c 7
\p
\v 1 Pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w cometieron|strong="H4604"\w* una \w prevaricación|strong="H4603"\w* \w en|strong="H4480"\w* cuanto \w al|strong="H4480"\w* \w anatema|strong="H2764"\w*; porque Acán \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Carmi|strong="H3756"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Zabdi|strong="H2067"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Zera|strong="H2226"\w*, \w de|strong="H4480"\w* la \w tribu|strong="H4294"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w tomó|strong="H3947"\w* \w del|strong="H4480"\w* \w anatema|strong="H2764"\w*; y la ira \w de|strong="H4480"\w* Yahvé \w se|strong="H4480"\w* encendió \w contra|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*.  
