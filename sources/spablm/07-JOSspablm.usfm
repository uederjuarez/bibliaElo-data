\c 22
\p
\v 1 Entonces \w Josué|strong="H3091"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* los rubenitas, \w a|strong="H3068"\w* los \w gaditas|strong="H1425"\w* y \w a|strong="H3068"\w* la media \w tribu|strong="H4294"\w* de \w Manasés|strong="H4519"\w*,  
\v 2 y \w les|strong="H6680"\w* dijo: «Habéis \w guardado|strong="H8104"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* \w Moisés|strong="H4872"\w*, \w siervo|strong="H5650"\w* de Yahvé, os \w mandó|strong="H6680"\w*, y habéis escuchado mi \w voz|strong="H6963"\w* en \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* os he \w ordenado|strong="H6680"\w*.  
\v 3 \w No|strong="H3808"\w* habéis \w desamparado|strong="H5800"\w* \w a|strong="H3068"\w* vuestros hermanos \w en|strong="H5704"\w* \w este|strong="H2088"\w* largo \w tiempo|strong="H3117"\w* \w hasta|strong="H5704"\w* el \w día|strong="H3117"\w* \w de|strong="H5704"\w* \w hoy|strong="H3117"\w*, \w sino|strong="H3808"\w* \w que|strong="H3808"\w* habéis cumplido \w la|strong="H8104"\w* obligación del \w mandamiento|strong="H4687"\w* \w de|strong="H5704"\w* Yahvé vuestro \w Dios|strong="H3068"\w*.  
\v 4 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w que|strong="H6258"\w* Yahvé vuestro \w Dios|strong="H3068"\w* ha \w dado|strong="H5414"\w* \w reposo|strong="H5117"\w* \w a|strong="H3068"\w* vuestros hermanos, como les había prometido, \w volveos|strong="H6437"\w* \w ahora|strong="H6258"\w* \w e|strong="H3068"\w* \w id|strong="H3212"\w* \w a|strong="H3068"\w* vuestras tiendas, \w a|strong="H3068"\w* la tierra \w de|strong="H5414"\w* vuestra posesión \w que|strong="H6258"\w* \w Moisés|strong="H4872"\w*, \w siervo|strong="H5650"\w* \w de|strong="H5414"\w* Yahvé, os \w dio|strong="H5414"\w* al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*.  
\v 5 \w Solamente|strong="H7535"\w* \w cuidad|strong="H8104"\w* con diligencia de poner \w en|strong="H3212"\w* práctica \w el|strong="H3605"\w* \w mandamiento|strong="H4687"\w* y \w la|strong="H8104"\w* \w ley|strong="H8451"\w* \w que|strong="H3605"\w* \w Moisés|strong="H4872"\w*, \w siervo|strong="H5650"\w* de Yahvé, os \w mandó|strong="H6680"\w*: \w que|strong="H3605"\w* améis \w a|strong="H3068"\w* Yahvé vuestro \w Dios|strong="H3068"\w*, y \w andéis|strong="H3212"\w* \w en|strong="H3212"\w* \w todos|strong="H3605"\w* sus \w caminos|strong="H1870"\w*; \w que|strong="H3605"\w* \w guardéis|strong="H8104"\w* sus \w mandamientos|strong="H4687"\w*, y os asgáis \w a|strong="H3068"\w* \w él|strong="H3605"\w*, y le \w sirváis|strong="H5647"\w* con \w todo|strong="H3605"\w* vuestro \w corazón|strong="H3824"\w* y con \w toda|strong="H3605"\w* vuestra \w alma|strong="H5315"\w*».   
\p
\v 6 \w Y|strong="H3068"\w* bendiciéndolos \w Josué|strong="H3091"\w*, los \w despidió|strong="H7971"\w*; y ellos se \w fueron|strong="H3212"\w* \w a|strong="H3068"\w* sus tiendas.  
\v 7 \w A|strong="H3068"\w* \w la|strong="H1571"\w* media \w tribu|strong="H7626"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w* \w había|strong="H3588"\w* \w dado|strong="H5414"\w* \w Moisés|strong="H4872"\w* heredad \w en|strong="H5973"\w* \w Basán|strong="H1316"\w*; \w mas|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* otra mitad \w dio|strong="H5414"\w* \w Josué|strong="H3091"\w* heredad \w entre|strong="H5973"\w* sus hermanos \w a|strong="H3068"\w* este \w lado|strong="H5676"\w* \w del|strong="H5973"\w* \w Jordán|strong="H3383"\w*, hacia \w el|strong="H5973"\w* occidente. \w Asimismo|strong="H1571"\w*, \w cuando|strong="H3588"\w* \w Josué|strong="H3091"\w* \w los|strong="H5973"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* sus tiendas, \w los|strong="H5973"\w* \w bendijo|strong="H1288"\w*  
\v 8 y \w les|strong="H5973"\w* habló diciendo: «\w Volved|strong="H7725"\w* \w a|strong="H3068"\w* vuestras tiendas \w con|strong="H5973"\w* \w grandes|strong="H7227"\w* \w riquezas|strong="H5233"\w*, \w con|strong="H5973"\w* \w mucho|strong="H3966"\w* \w ganado|strong="H4735"\w*, \w con|strong="H5973"\w* \w plata|strong="H3701"\w*, \w con|strong="H5973"\w* \w oro|strong="H2091"\w*, \w con|strong="H5973"\w* bronce, \w con|strong="H5973"\w* \w hierro|strong="H1270"\w* y \w con|strong="H5973"\w* \w muchos|strong="H7227"\w* \w vestidos|strong="H8008"\w*. Repartid \w con|strong="H5973"\w* vuestros hermanos \w el|strong="H5973"\w* botín \w de|strong="H5973"\w* vuestros enemigos».   
\p
\v 9 Así \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Rubén|strong="H7205"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Gad|strong="H1410"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* media \w tribu|strong="H7626"\w* \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w* \w se|strong="H5921"\w* \w volvieron|strong="H7725"\w*, separándose \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w desde|strong="H5921"\w* \w Silo|strong="H7887"\w*, \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w*, \w para|strong="H5921"\w* irse \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*, \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* sus posesiones, \w de|strong="H5921"\w* \w las|strong="H5921"\w* cuales \w se|strong="H5921"\w* habían posesionado \w conforme|strong="H6310"\w* \w al|strong="H5921"\w* \w mandato|strong="H6310"\w* \w de|strong="H5921"\w* Yahvé \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*.  
