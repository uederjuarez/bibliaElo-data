\v 39 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w heredad|strong="H5159"\w* \w de|strong="H1121"\w* \w la|strong="H2063"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Neftalí conforme \w a|strong="H3068"\w* sus \w familias|strong="H4940"\w*; \w estas|strong="H2063"\w* \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 40 La séptima \w suerte|strong="H1486"\w* correspondió \w a|strong="H3068"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w* conforme \w a|strong="H3068"\w* sus \w familias|strong="H4940"\w*.  
\v 41 \w Y|strong="H3068"\w* \w fue|strong="H1961"\w* el territorio de su \w heredad|strong="H5159"\w* Zora, Estaol, Ir-semes,  
\v 42 Saalabín, Ajalón, Jetla,  
\v 43 Elón, Timnat, \w Ecrón|strong="H6138"\w*,  
\v 44 Elteque, Gibetón, Baalat,  
\v 45 Jehúd, Bene-berac, Gat-rimón,  
\v 46 Mejarcón y Racón, \w con|strong="H5973"\w* \w el|strong="H5973"\w* territorio frente \w a|strong="H3068"\w* Jope.  
\v 47 \w Y|strong="H3068"\w* \w les|strong="H1992"\w* faltó territorio \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Dan|strong="H1835"\w*; por \w lo|strong="H1992"\w* \w cual|strong="H5973"\w* \w subieron|strong="H5927"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Dan|strong="H1835"\w* y combatieron \w contra|strong="H5973"\w* Lesem, y tomándola \w la|strong="H1366"\w* \w hirieron|strong="H5221"\w* \w a|strong="H3068"\w* filo \w de|strong="H5973"\w* \w espada|strong="H2719"\w*, y \w la|strong="H1366"\w* \w poseyeron|strong="H3423"\w* y \w habitaron|strong="H3427"\w* \w en|strong="H5973"\w* ella; y \w llamaron|strong="H7121"\w* \w a|strong="H3068"\w* Lesem, \w Dan|strong="H1835"\w*, por \w el|strong="H5973"\w* \w nombre|strong="H8034"\w* \w de|strong="H5973"\w* \w Dan|strong="H1835"\w* \w su|strong="H1992"\w* padre.  
\v 48 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w heredad|strong="H5159"\w* \w de|strong="H1121"\w* \w la|strong="H2063"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w* conforme \w a|strong="H3068"\w* sus \w familias|strong="H4940"\w*; \w estas|strong="H2063"\w* \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 49 \w Y|strong="H3068"\w* después \w que|strong="H1121"\w* \w acabaron|strong="H3615"\w* \w de|strong="H1121"\w* repartir la tierra \w en|strong="H8432"\w* \w heredad|strong="H5159"\w* \w por|strong="H5414"\w* sus límites, \w dieron|strong="H5414"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w heredad|strong="H5159"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* ellos.  
\v 50 \w Conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w palabra|strong="H6310"\w* \w de|strong="H5921"\w* Yahvé, \w le|strong="H5921"\w* \w dieron|strong="H5414"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w pidió|strong="H7592"\w*, Timnat-sera, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w monte|strong="H2022"\w* \w de|strong="H5921"\w* Efraín; \w y|strong="H5921"\w* \w él|strong="H5921"\w* \w edificó|strong="H1129"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w y|strong="H5921"\w* \w habitó|strong="H3427"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w*.  
\v 51 Estas son las \w heredades|strong="H5159"\w* \w que|strong="H1121"\w* \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Eleazar, \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Nun|strong="H5126"\w* y las \w cabezas|strong="H7218"\w* \w de|strong="H6440"\w* las casas paternas \w de|strong="H6440"\w* las \w tribus|strong="H4294"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* repartieron \w por|strong="H6440"\w* \w suerte|strong="H1486"\w* en \w Silo|strong="H7887"\w*, \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Yahvé, \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* del Tabernáculo \w de|strong="H6440"\w* la reunión. \w Y|strong="H3068"\w* así \w acabaron|strong="H3615"\w* \w de|strong="H6440"\w* repartir la tierra.   
\c 20
\p
\v 1 Yahvé \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w diciendo|strong="H1696"\w*:  
\v 2 “\w Habla|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w diles|strong="H1696"\w*: «\w Señalaos|strong="H5414"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* refugio, \w de|strong="H1121"\w* las cuales os \w hablé|strong="H1696"\w* \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*,  
\v 3 \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w se|strong="H1961"\w* acoja \w allí|strong="H8033"\w* el \w homicida|strong="H7523"\w* \w que|strong="H1961"\w* \w matare|strong="H7523"\w* \w a|strong="H3068"\w* alguna \w persona|strong="H5315"\w* \w por|strong="H5127"\w* error \w o|strong="H3068"\w* inadvertidamente; y os \w servirán|strong="H1961"\w* \w de|strong="H1818"\w* refugio \w contra|strong="H1961"\w* el vengador \w de|strong="H1818"\w* la \w sangre|strong="H1818"\w*.  
\v 4 \w El|strong="H1931"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* acogiere \w a|strong="H3068"\w* alguna \w de|strong="H5973"\w* aquellas \w ciudades|strong="H5892"\w* \w se|strong="H1931"\w* \w presentará|strong="H5975"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w puerta|strong="H6607"\w* \w de|strong="H5973"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w*, y expondrá \w su|strong="H1931"\w* \w causa|strong="H1697"\w* ante \w los|strong="H3427"\w* oídos \w de|strong="H5973"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5973"\w* \w aquella|strong="H1931"\w* \w ciudad|strong="H5892"\w*; \w ellos|strong="H1931"\w* \w lo|strong="H1931"\w* recibirán \w consigo|strong="H5973"\w* dentro \w de|strong="H5973"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* y \w le|strong="H1931"\w* \w darán|strong="H5414"\w* un \w lugar|strong="H4725"\w* \w para|strong="H5414"\w* \w que|strong="H1931"\w* habite \w con|strong="H5973"\w* \w ellos|strong="H1931"\w*.  
\v 5 \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w el|strong="H1931"\w* vengador \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w* \w lo|strong="H1931"\w* \w siguiere|strong="H7291"\w*, \w no|strong="H3808"\w* \w entregarán|strong="H5462"\w* \w en|strong="H3588"\w* \w su|strong="H1931"\w* \w mano|strong="H3027"\w* al \w homicida|strong="H7523"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w hirió|strong="H5221"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w prójimo|strong="H7453"\w* \w sin|strong="H3808"\w* intención \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w le|strong="H1931"\w* \w tenía|strong="H1931"\w* odio \w antes|strong="H3588"\w*.  
\v 6 \w Y|strong="H3068"\w* \w habitará|strong="H3427"\w* \w en|strong="H5704"\w* \w aquella|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w hasta|strong="H5704"\w* \w que|strong="H1931"\w* comparezca \w en|strong="H5704"\w* \w juicio|strong="H4941"\w* \w ante|strong="H6440"\w* \w la|strong="H1931"\w* congregación, \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* \w la|strong="H1931"\w* \w muerte|strong="H4194"\w* del \w que|strong="H1931"\w* \w fuere|strong="H1961"\w* \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* \w en|strong="H5704"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H3117"\w*; \w entonces|strong="H3117"\w* \w el|strong="H1931"\w* \w homicida|strong="H7523"\w* podrá \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w casa|strong="H1004"\w*, \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w de|strong="H6440"\w* \w donde|strong="H8033"\w* \w huyó|strong="H5127"\w*»».   
\p
\v 7 Entonces señalaron \w a|strong="H3068"\w* Cedes en Galilea, en \w el|strong="H1931"\w* \w monte|strong="H2022"\w* de Neftalí; \w a|strong="H3068"\w* Siquem, en \w el|strong="H1931"\w* \w monte|strong="H2022"\w* de Efraín; y \w a|strong="H3068"\w* Quiriat-arba (\w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Hebrón|strong="H2275"\w*), en \w el|strong="H1931"\w* \w monte|strong="H2022"\w* de \w Judá|strong="H3063"\w*.  
\v 8 \w Y|strong="H3068"\w* al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, al \w oriente|strong="H4217"\w* \w de|strong="H5414"\w* \w Jericó|strong="H3405"\w*, \w señalaron|strong="H5414"\w* \w a|strong="H3068"\w* \w Beser|strong="H1221"\w* en el \w desierto|strong="H4057"\w*, en la llanura \w de|strong="H5414"\w* la \w tribu|strong="H4294"\w* \w de|strong="H5414"\w* \w Rubén|strong="H7205"\w*; \w a|strong="H3068"\w* Ramot en \w Galaad|strong="H1568"\w*, \w de|strong="H5414"\w* la \w tribu|strong="H4294"\w* \w de|strong="H5414"\w* \w Gad|strong="H1410"\w*; y \w a|strong="H3068"\w* Golán en \w Basán|strong="H1316"\w*, \w de|strong="H5414"\w* la \w tribu|strong="H4294"\w* \w de|strong="H5414"\w* \w Manasés|strong="H4519"\w*.  
\v 9 \w Estas|strong="H5975"\w* \w fueron|strong="H1961"\w* las \w ciudades|strong="H5892"\w* designadas \w para|strong="H5704"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5704"\w* \w para|strong="H5704"\w* \w el|strong="H3605"\w* \w extranjero|strong="H1616"\w* \w que|strong="H3808"\w* morase \w entre|strong="H8432"\w* \w ellos|strong="H3027"\w*, \w para|strong="H5704"\w* \w que|strong="H3808"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H3808"\w* \w matare|strong="H4191"\w* \w a|strong="H3068"\w* alguien \w por|strong="H6440"\w* error pudiera huir \w allí|strong="H8033"\w*, \w y|strong="H5704"\w* \w no|strong="H3808"\w* \w muriese|strong="H4191"\w* \w por|strong="H6440"\w* \w mano|strong="H3027"\w* del vengador \w de|strong="H6440"\w* \w la|strong="H3605"\w* \w sangre|strong="H1818"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* compareciese \w ante|strong="H6440"\w* \w la|strong="H3605"\w* congregación.   
\c 21
\p
\v 1 Las \w cabezas|strong="H7218"\w* \w de|strong="H1121"\w* las casas paternas \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* se acercaron al \w sacerdote|strong="H3548"\w* Eleazar, \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w* y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las casas paternas \w de|strong="H1121"\w* las \w tribus|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*,  
\v 2 y \w les|strong="H6680"\w* \w hablaron|strong="H1696"\w* en \w Silo|strong="H7887"\w*, en la tierra \w de|strong="H5414"\w* \w Canaán|strong="H3667"\w*, \w diciendo|strong="H1696"\w*: «Yahvé \w mandó|strong="H6680"\w* \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H5414"\w* \w Moisés|strong="H4872"\w* \w que|strong="H3027"\w* nos fuesen \w dadas|strong="H5414"\w* \w ciudades|strong="H5892"\w* donde \w habitar|strong="H3427"\w*, con sus \w ejidos|strong="H4054"\w* \w para|strong="H5414"\w* nuestros ganados».   
\p
\v 3 Entonces \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w dieron|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w de|strong="H1121"\w* su propia \w herencia|strong="H5159"\w*, \w conforme|strong="H6310"\w* al \w mandato|strong="H6310"\w* \w de|strong="H1121"\w* Yahvé, estas \w ciudades|strong="H5892"\w* con sus \w ejidos|strong="H4054"\w*.  
\v 4 \w Y|strong="H3068"\w* cayó la \w suerte|strong="H1486"\w* \w para|strong="H4480"\w* las \w familias|strong="H4940"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* coatitas; y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H4480"\w* \w sacerdote|strong="H3548"\w* Aarón, \w que|strong="H4480"\w* \w eran|strong="H1961"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, obtuvieron \w por|strong="H4480"\w* \w suerte|strong="H1486"\w* \w trece|strong="H7969"\w* \w ciudades|strong="H5892"\w* \w de|strong="H4480"\w* la \w tribu|strong="H4294"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w de|strong="H4480"\w* la \w tribu|strong="H4294"\w* \w de|strong="H4480"\w* \w Simeón|strong="H8099"\w* y \w de|strong="H4480"\w* la \w tribu|strong="H4294"\w* \w de|strong="H4480"\w* \w Benjamín|strong="H1144"\w*.  
\v 5 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* demás \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat obtuvieron por \w suerte|strong="H1486"\w* \w diez|strong="H6235"\w* \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Efraín, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w* y \w de|strong="H1121"\w* la media \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*.  
\v 6 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gersón|strong="H1648"\w* obtuvieron por \w suerte|strong="H1486"\w* \w trece|strong="H7969"\w* \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Isacar, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Aser, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Neftalí y \w de|strong="H1121"\w* la media \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w* en \w Basán|strong="H1316"\w*.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w*, según sus \w familias|strong="H4940"\w*, obtuvieron \w doce|strong="H8147"\w* \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Zabulón|strong="H2074"\w*.  
\v 8 \w Dieron|strong="H5414"\w*, pues, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* estas \w ciudades|strong="H5892"\w* con sus \w ejidos|strong="H4054"\w* \w por|strong="H3027"\w* \w suerte|strong="H1486"\w*, como Yahvé había \w mandado|strong="H6680"\w* \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*.  
\v 9 \w De|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* y \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Simeón|strong="H8095"\w*, \w dieron|strong="H5414"\w* estas \w ciudades|strong="H5892"\w* \w que|strong="H1121"\w* fueron nombradas,  
