\v 8 Tú, pues, \w mandarás|strong="H6680"\w* \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* \w que|strong="H5704"\w* \w llevan|strong="H5375"\w* el arca del \w pacto|strong="H1285"\w*, diciendo: «\w Cuando|strong="H5704"\w* hayáis llegado \w al|strong="H5704"\w* borde del \w agua|strong="H4325"\w* del \w Jordán|strong="H3383"\w*, \w os|strong="H5704"\w* detendréis \w en|strong="H5704"\w* el \w Jordán|strong="H3383"\w*»».   
\p
\v 9 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* dijo \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: «\w Acercaos|strong="H5066"\w* y \w escuchad|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* Yahvé vuestro \w Dios|strong="H3068"\w*».  
\v 10 \w Y|strong="H3068"\w* añadió \w Josué|strong="H3091"\w*: “\w En|strong="H3588"\w* \w esto|strong="H2063"\w* \w conoceréis|strong="H3045"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* Dios \w vivo|strong="H2416"\w* \w está|strong="H2063"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* vosotros, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* echará \w de|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* vosotros \w al|strong="H7130"\w* \w cananeo|strong="H3669"\w*, \w al|strong="H7130"\w* hitita, \w al|strong="H7130"\w* \w heveo|strong="H2340"\w*, \w al|strong="H7130"\w* ferezeo, \w al|strong="H7130"\w* gergeseo, \w al|strong="H7130"\w* amorreo \w y|strong="H3588"\w* \w al|strong="H7130"\w* \w jebuseo|strong="H2983"\w*.  
\v 11 He \w aquí|strong="H2009"\w*, \w el|strong="H3605"\w* arca del \w pacto|strong="H1285"\w* del Señor\f + \fr 3:11 \ft El término traducido como «Señor» es «Adonai».\f* \w de|strong="H6440"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w va|strong="H3068"\w* \w a|strong="H3068"\w* \w pasar|strong="H5674"\w* \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* vosotros.  
\v 12 \w Tomad|strong="H3947"\w*, \w pues|strong="H6258"\w*, \w ahora|strong="H6258"\w* \w doce|strong="H8147"\w* \w hombres|strong="H8147"\w* de las \w tribus|strong="H7626"\w* de \w Israel|strong="H3478"\w*, uno de cada \w tribu|strong="H7626"\w*.  
\v 13 \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* las plantas \w de|strong="H4325"\w* \w los|strong="H3605"\w* \w pies|strong="H7272"\w* \w de|strong="H4325"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H4325"\w* \w llevan|strong="H5375"\w* \w el|strong="H3605"\w* arca \w de|strong="H4325"\w* Yahvé, \w Señor|strong="H3068"\w* \w de|strong="H4325"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra, \w se|strong="H1961"\w* asienten \w en|strong="H5975"\w* las \w aguas|strong="H4325"\w* del \w Jordán|strong="H3383"\w*, las \w aguas|strong="H4325"\w* del \w Jordán|strong="H3383"\w* \w se|strong="H1961"\w* dividirán; porque las \w aguas|strong="H4325"\w* \w que|strong="H4325"\w* vienen \w de|strong="H4325"\w* \w arriba|strong="H4605"\w* \w se|strong="H1961"\w* detendrán \w en|strong="H5975"\w* un \w montón|strong="H5067"\w*”.   
\p
\v 14 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H5971"\w* \w cuando|strong="H1961"\w* \w partió|strong="H5265"\w* \w el|strong="H5674"\w* \w pueblo|strong="H5971"\w* \w de|strong="H6440"\w* sus tiendas \w para|strong="H1961"\w* \w pasar|strong="H5674"\w* \w el|strong="H5674"\w* \w Jordán|strong="H3383"\w*, con \w los|strong="H1961"\w* \w sacerdotes|strong="H3548"\w* \w delante|strong="H6440"\w* del \w pueblo|strong="H5971"\w* \w llevando|strong="H5375"\w* \w el|strong="H5674"\w* arca del \w pacto|strong="H1285"\w*,  
