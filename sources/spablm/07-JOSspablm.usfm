\v 3 Mas \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de \w Gabaón|strong="H1391"\w*, cuando \w oyeron|strong="H8085"\w* \w lo|strong="H6213"\w* que \w Josué|strong="H3091"\w* \w había|strong="H6213"\w* \w hecho|strong="H6213"\w* \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w* y \w a|strong="H3068"\w* \w Hai|strong="H5857"\w*,  
\v 4 usaron \w también|strong="H1571"\w* de astucia; \w pues|strong="H1571"\w* \w fueron|strong="H3212"\w* \w y|strong="H1571"\w* \w se|strong="H1992"\w* fingieron embajadores, \w y|strong="H1571"\w* \w tomaron|strong="H3947"\w* \w sacos|strong="H8242"\w* \w viejos|strong="H1087"\w* sobre \w sus|strong="H1992"\w* \w asnos|strong="H2543"\w*, \w y|strong="H1571"\w* odres \w viejos|strong="H1087"\w* de \w vino|strong="H3196"\w*, \w rotos|strong="H1234"\w* \w y|strong="H1571"\w* remendados,  
\v 5 \w y|strong="H5921"\w* calzado viejo \w y|strong="H5921"\w* recosido \w en|strong="H5921"\w* sus \w pies|strong="H7272"\w*, \w con|strong="H5921"\w* \w vestidos|strong="H8008"\w* \w viejos|strong="H1087"\w* \w sobre|strong="H5921"\w* \w sí|strong="H1961"\w*; \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pan|strong="H3899"\w* \w que|strong="H5921"\w* \w traían|strong="H5921"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* camino \w estaba|strong="H1961"\w* \w seco|strong="H3001"\w* \w y|strong="H5921"\w* enmohecido.  
\v 6 \w Y|strong="H3068"\w* vinieron \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* al \w campamento|strong="H4264"\w* \w en|strong="H3212"\w* \w Gilgal|strong="H1537"\w*, y le dijeron \w a|strong="H3068"\w* \w él|strong="H4264"\w* y \w a|strong="H3068"\w* los de \w Israel|strong="H3478"\w*: «Nosotros venimos de tierra lejana; \w haced|strong="H3772"\w*, \w pues|strong="H6258"\w*, \w ahora|strong="H6258"\w* \w alianza|strong="H1285"\w* con nosotros».   
\p
\v 7 \w Y|strong="H3068"\w* \w los|strong="H3427"\w* de \w Israel|strong="H3478"\w* respondieron \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w heveos|strong="H2340"\w*: «Quizá \w habitáis|strong="H3427"\w* en \w medio|strong="H7130"\w* de nosotros; ¿cómo, pues, podremos concertar \w alianza|strong="H1285"\w* con vosotros?».   
\p
\v 8 Ellos respondieron \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: «Nosotros somos tus \w siervos|strong="H5650"\w*». \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* les dijo: «¿\w Quiénes|strong="H4310"\w* sois vosotros, y de dónde venís?».   
\p
\v 9 \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* respondieron: “Tus \w siervos|strong="H5650"\w* han venido \w de|strong="H3588"\w* tierra \w muy|strong="H3966"\w* lejana, \w por|strong="H3588"\w* causa del \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* Yahvé \w tu|strong="H6213"\w* \w Dios|strong="H3068"\w*; \w porque|strong="H3588"\w* hemos \w oído|strong="H8085"\w* \w su|strong="H3588"\w* \w fama|strong="H8034"\w*, \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w hizo|strong="H6213"\w* \w en|strong="H3588"\w* \w Egipto|strong="H4714"\w*,  
\v 10 y \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w dos|strong="H8147"\w* \w reyes|strong="H4428"\w* de \w los|strong="H3605"\w* amorreos \w que|strong="H3605"\w* estaban \w al|strong="H4428"\w* otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*: \w a|strong="H3068"\w* \w Sehón|strong="H5511"\w* \w rey|strong="H4428"\w* de \w Hesbón|strong="H2809"\w*, y \w a|strong="H3068"\w* \w Og|strong="H5747"\w* \w rey|strong="H4428"\w* de \w Basán|strong="H1316"\w*, \w que|strong="H3605"\w* estaba en Astarot.  
\v 11 \w Por|strong="H1870"\w* \w lo|strong="H3605"\w* cual nuestros \w ancianos|strong="H2205"\w* y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* de nuestra tierra nos dijeron: «\w Tomad|strong="H3947"\w* \w en|strong="H3212"\w* vuestras \w manos|strong="H3027"\w* \w provisión|strong="H6720"\w* \w para|strong="H6258"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w*, \w e|strong="H3068"\w* \w id|strong="H3212"\w* al encuentro de \w ellos|strong="H3027"\w*, y decidles: \w Nosotros|strong="H3605"\w* somos vuestros \w siervos|strong="H5650"\w*; \w haced|strong="H3772"\w* \w ahora|strong="H6258"\w* \w alianza|strong="H1285"\w* con \w nosotros|strong="H3605"\w*».  
\v 12 \w Este|strong="H2088"\w* nuestro \w pan|strong="H3899"\w* \w lo|strong="H2088"\w* tomamos caliente de nuestras \w casas|strong="H1004"\w* \w para|strong="H1961"\w* el camino el \w día|strong="H3117"\w* \w que|strong="H6258"\w* \w salimos|strong="H3318"\w* \w para|strong="H1961"\w* \w venir|strong="H3212"\w* \w a|strong="H3068"\w* vosotros; y helos \w aquí|strong="H2009"\w* \w ahora|strong="H6258"\w* \w ya|strong="H2088"\w* \w seco|strong="H3001"\w* y enmohecido.  
\v 13 Estos odres de \w vino|strong="H3196"\w* también los llenamos \w nuevos|strong="H2319"\w*; helos \w aquí|strong="H2009"\w* ya \w rotos|strong="H1234"\w*; también estos nuestros \w vestidos|strong="H8008"\w* y nuestro calzado \w están|strong="H2009"\w* viejos \w a|strong="H3068"\w* causa de lo \w muy|strong="H3966"\w* \w largo|strong="H7230"\w* del \w camino|strong="H1870"\w*”.   
\p
\v 14 \w Y|strong="H3068"\w* los hombres de Israel \w tomaron|strong="H3947"\w* de las provisiones de ellos, y \w no|strong="H3808"\w* \w consultaron|strong="H7592"\w* \w a|strong="H3068"\w* la \w boca|strong="H6310"\w* de Yahvé.  
\v 15 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* \w hizo|strong="H6213"\w* \w paz|strong="H7965"\w* con ellos, y \w concertó|strong="H3772"\w* con ellos \w alianza|strong="H1285"\w* concediéndoles la \w vida|strong="H2421"\w*; y también los \w príncipes|strong="H5387"\w* de la congregación les \w juraron|strong="H7650"\w*.  
\v 16 \w Pasados|strong="H7097"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w después|strong="H3427"\w* \w que|strong="H3588"\w* concertaron \w la|strong="H3588"\w* \w alianza|strong="H1285"\w* \w con|strong="H3588"\w* \w ellos|strong="H1992"\w*, \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w eran|strong="H1961"\w* \w sus|strong="H1992"\w* \w vecinos|strong="H7138"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w habitaban|strong="H3427"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*.  
\v 17 \w Y|strong="H3068"\w* \w partieron|strong="H5265"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y al tercer \w día|strong="H3117"\w* llegaron \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* ellos; y sus \w ciudades|strong="H5892"\w* eran \w Gabaón|strong="H1391"\w*, Quefira, Beerot y Quiriat-jearim.  
\v 18 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w mataron|strong="H5221"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \w los|strong="H1121"\w* \w príncipes|strong="H5387"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* congregación \w les|strong="H5921"\w* habían \w jurado|strong="H7650"\w* \w por|strong="H5921"\w* Yahvé \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación \w murmuraba|strong="H3885"\w* \w contra|strong="H5921"\w* \w los|strong="H1121"\w* \w príncipes|strong="H5387"\w*.  
\v 19 \w Mas|strong="H6258"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w príncipes|strong="H5387"\w* respondieron \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación: «\w Nosotros|strong="H3605"\w* les hemos \w jurado|strong="H7650"\w* por Yahvé \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*; por tanto, \w ahora|strong="H6258"\w* \w no|strong="H3808"\w* \w podemos|strong="H3201"\w* tocarlos.  
\v 20 \w Esto|strong="H2063"\w* \w haremos|strong="H6213"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w*: \w les|strong="H5921"\w* dejaremos \w vivir|strong="H2421"\w*, \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w venga|strong="H1961"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w la|strong="H5921"\w* \w ira|strong="H7110"\w* \w por|strong="H5921"\w* causa \w del|strong="H5921"\w* \w juramento|strong="H7621"\w* \w que|strong="H3808"\w* \w les|strong="H5921"\w* hemos prestado».  
\v 21 \w Y|strong="H3068"\w* les \w dijeron|strong="H1696"\w* \w los|strong="H3605"\w* \w príncipes|strong="H5387"\w*: «Dejadlos \w vivir|strong="H2421"\w*; y \w sean|strong="H1961"\w* \w leñadores|strong="H2404"\w* y aguadores \w para|strong="H1961"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación, \w como|strong="H1961"\w* \w los|strong="H3605"\w* \w príncipes|strong="H5387"\w* les han \w dicho|strong="H1696"\w*».   
\p
\v 22 \w Y|strong="H3068"\w* llamándolos \w Josué|strong="H3091"\w*, les \w habló|strong="H1696"\w* \w diciendo|strong="H1696"\w*: “¿\w Por|strong="H4480"\w* \w qué|strong="H4100"\w* \w nos|strong="H4480"\w* habéis \w engañado|strong="H7411"\w*, \w diciendo|strong="H1696"\w*: «\w Habitamos|strong="H3427"\w* \w muy|strong="H3966"\w* \w lejos|strong="H7350"\w* \w de|strong="H4480"\w* vosotros», siendo \w así|strong="H1696"\w* \w que|strong="H4100"\w* vivís \w en|strong="H4480"\w* \w medio|strong="H7130"\w* \w de|strong="H4480"\w* nosotros?  
\v 23 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, malditos sois, y \w no|strong="H3808"\w* \w faltará|strong="H3772"\w* \w de|strong="H4480"\w* \w entre|strong="H3808"\w* vosotros quien sea \w siervo|strong="H5650"\w*, y leñador y aguador \w para|strong="H4480"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* mi Dios”.   
\p
\v 24 \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* \w respondieron|strong="H6030"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* \w y|strong="H3588"\w* \w dijeron|strong="H1697"\w*: «\w Como|strong="H3588"\w* fue \w dado|strong="H5414"\w* \w a|strong="H3068"\w* entender \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w* \w que|strong="H3588"\w* Yahvé \w tu|strong="H6213"\w* \w Dios|strong="H3068"\w* \w había|strong="H3588"\w* \w mandado|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w su|strong="H3588"\w* \w siervo|strong="H5650"\w* \w que|strong="H3588"\w* os \w diese|strong="H5414"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra, \w y|strong="H3588"\w* \w que|strong="H3588"\w* hubiese \w de|strong="H3588"\w* \w destruir|strong="H8045"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w delante|strong="H6440"\w* \w de|strong="H3588"\w* vosotros, \w por|strong="H3588"\w* \w esto|strong="H2088"\w* \w temimos|strong="H3372"\w* \w en|strong="H3588"\w* \w gran|strong="H3966"\w* \w manera|strong="H1697"\w* \w por|strong="H3588"\w* nuestras \w vidas|strong="H5315"\w* \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H3588"\w* vosotros, \w e|strong="H3068"\w* \w hicimos|strong="H6213"\w* \w esto|strong="H2088"\w*.  
\v 25 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, helos \w aquí|strong="H2005"\w* en \w tu|strong="H6213"\w* \w mano|strong="H3027"\w*; \w lo|strong="H6213"\w* \w que|strong="H6258"\w* \w te|strong="H5869"\w* \w pareciere|strong="H5869"\w* \w bueno|strong="H2896"\w* y \w recto|strong="H3477"\w* \w hacer|strong="H6213"\w* \w de|strong="H5869"\w* nosotros, \w hazlo|strong="H6213"\w*».   
\p
\v 26 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* \w lo|strong="H3808"\w* \w hizo|strong="H6213"\w* \w así|strong="H3651"\w* con \w ellos|strong="H3027"\w*, \w pues|strong="H3651"\w* \w los|strong="H1121"\w* \w libró|strong="H5337"\w* \w de|strong="H1121"\w* la \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w mataron|strong="H2026"\w*.  
\v 27 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* \w los|strong="H1931"\w* destinó \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w a|strong="H3068"\w* ser \w leñadores|strong="H2404"\w* \w y|strong="H5704"\w* aguadores \w para|strong="H5704"\w* \w la|strong="H1931"\w* congregación, \w y|strong="H5704"\w* \w para|strong="H5704"\w* \w el|strong="H1931"\w* \w altar|strong="H4196"\w* \w de|strong="H5704"\w* Yahvé, \w en|strong="H5704"\w* \w el|strong="H1931"\w* \w lugar|strong="H4725"\w* \w que|strong="H1931"\w* Yahvé eligiese, \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\c 10
\p
\v 1 \w Cuando|strong="H3588"\w* Adoni-Zedec, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Jerusalén, \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* \w Josué|strong="H3091"\w* \w había|strong="H1961"\w* tomado \w a|strong="H3068"\w* \w Hai|strong="H5857"\w* \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w había|strong="H1961"\w* destruido \w por|strong="H3588"\w* completo (\w como|strong="H3588"\w* \w había|strong="H1961"\w* \w hecho|strong="H6213"\w* \w con|strong="H3588"\w* \w Jericó|strong="H3405"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w rey|strong="H4428"\w*, \w así|strong="H3651"\w* \w había|strong="H1961"\w* \w hecho|strong="H6213"\w* \w con|strong="H3588"\w* \w Hai|strong="H5857"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w rey|strong="H4428"\w*), \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w los|strong="H3427"\w* \w moradores|strong="H3427"\w* \w de|strong="H3588"\w* \w Gabaón|strong="H1391"\w* \w habían|strong="H1961"\w* \w hecho|strong="H6213"\w* \w la|strong="H3588"\w* \w paz|strong="H7999"\w* \w con|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w estaban|strong="H1961"\w* \w entre|strong="H7130"\w* ellos,  
\v 2 tuvieron \w gran|strong="H1419"\w* \w temor|strong="H3372"\w*; \w porque|strong="H3588"\w* \w Gabaón|strong="H1391"\w* \w era|strong="H1931"\w* una \w gran|strong="H1419"\w* \w ciudad|strong="H5892"\w*, \w como|strong="H3588"\w* una \w de|strong="H4480"\w* las \w ciudades|strong="H5892"\w* \w reales|strong="H4467"\w*, \w y|strong="H3588"\w* \w era|strong="H1931"\w* \w mayor|strong="H1419"\w* \w que|strong="H3588"\w* \w Hai|strong="H5857"\w*, \w y|strong="H3588"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w hombres|strong="H1368"\w* eran \w valientes|strong="H1368"\w*.  
\v 3 \w Por|strong="H4428"\w* lo cual Adoni-Zedec, \w rey|strong="H4428"\w* de Jerusalén, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Hoham \w rey|strong="H4428"\w* de \w Hebrón|strong="H2275"\w*, \w a|strong="H3068"\w* Piream \w rey|strong="H4428"\w* de Jarmut, \w a|strong="H3068"\w* Jafía \w rey|strong="H4428"\w* de Laquis y \w a|strong="H3068"\w* \w Debir|strong="H1688"\w* \w rey|strong="H4428"\w* de \w Eglón|strong="H5700"\w*, diciendo:  
\v 4 «\w Subid|strong="H5927"\w* \w a|strong="H3068"\w* mí \w y|strong="H3588"\w* ayudadme, \w y|strong="H3588"\w* combatamos \w a|strong="H3068"\w* \w Gabaón|strong="H1391"\w*; \w porque|strong="H3588"\w* ha hecho \w paz|strong="H7999"\w* \w con|strong="H3588"\w* \w Josué|strong="H3091"\w* \w y|strong="H3588"\w* \w con|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*».  
