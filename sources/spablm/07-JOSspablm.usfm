\v 27 \w sino|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* sea \w testimonio|strong="H5707"\w* \w entre|strong="H3808"\w* \w nosotros|strong="H1931"\w* \w y|strong="H3588"\w* vosotros, \w y|strong="H3588"\w* \w entre|strong="H3808"\w* nuestros descendientes después \w de|strong="H3588"\w* \w nosotros|strong="H1931"\w*, \w de|strong="H3588"\w* \w que|strong="H3588"\w* podemos hacer \w el|strong="H1931"\w* servicio \w de|strong="H3588"\w* Yahvé \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w él|strong="H1931"\w* \w con|strong="H3588"\w* nuestros \w holocaustos|strong="H5930"\w*, \w con|strong="H3588"\w* nuestros \w sacrificios|strong="H2077"\w* \w y|strong="H3588"\w* \w con|strong="H3588"\w* nuestras ofrendas \w de|strong="H3588"\w* paz; \w y|strong="H3588"\w* \w no|strong="H3808"\w* digan \w mañana|strong="H4279"\w* \w vuestros|strong="H5647"\w* \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* nuestros: ‘Vosotros \w no|strong="H3808"\w* tenéis \w parte|strong="H2506"\w* \w en|strong="H3588"\w* Yahvé’”.   
\p
\v 28 Dijimos, \w pues|strong="H3588"\w*: “\w Si|strong="H3588"\w* \w aconteciere|strong="H1931"\w* \w que|strong="H3588"\w* nos digan tal cosa \w a|strong="H3068"\w* \w nosotros|strong="H1931"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* nuestras \w generaciones|strong="H1755"\w* \w en|strong="H3588"\w* \w lo|strong="H1931"\w* \w por|strong="H3588"\w* venir, \w entonces|strong="H3588"\w* responderemos: ‘\w Ved|strong="H7200"\w* \w el|strong="H1931"\w* modelo \w del|strong="H4196"\w* \w altar|strong="H4196"\w* \w de|strong="H3588"\w* Yahvé \w que|strong="H3588"\w* \w hicieron|strong="H6213"\w* nuestros padres, \w no|strong="H3808"\w* \w para|strong="H3588"\w* \w holocaustos|strong="H5930"\w* \w ni|strong="H3808"\w* \w para|strong="H3588"\w* \w sacrificios|strong="H2077"\w*, \w sino|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w fuese|strong="H1961"\w* \w testimonio|strong="H5707"\w* \w entre|strong="H3808"\w* \w nosotros|strong="H1931"\w* \w y|strong="H3588"\w* vosotros’”.   
