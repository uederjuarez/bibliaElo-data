\v 15 \w Los|strong="H1121"\w* cuales fueron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w a|strong="H3068"\w* la media \w tribu|strong="H7626"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w a|strong="H3068"\w* la tierra \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, y les \w hablaron|strong="H1696"\w* \w diciendo|strong="H1696"\w*:  
\v 16 “\w Toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación de Yahvé dice \w así|strong="H3541"\w*: «¿\w Qué|strong="H4100"\w* \w prevaricación|strong="H4603"\w* \w es|strong="H2088"\w* \w esta|strong="H2088"\w* \w que|strong="H4100"\w* habéis cometido \w contra|strong="H3478"\w* \w el|strong="H3605"\w* \w Dios|strong="H3068"\w* de \w Israel|strong="H3478"\w*, para apartaros \w hoy|strong="H3117"\w* de seguir \w a|strong="H3068"\w* Yahvé, \w edificándoos|strong="H1129"\w* un \w altar|strong="H4196"\w* para rebelaros \w hoy|strong="H3117"\w* \w contra|strong="H3478"\w* Yahvé?  
\v 17 ¿\w Es|strong="H1961"\w* \w poco|strong="H4592"\w* \w para|strong="H5704"\w* nosotros la \w maldad|strong="H5771"\w* \w de|strong="H4480"\w* Peor, \w de|strong="H4480"\w* la \w que|strong="H4480"\w* \w no|strong="H3808"\w* estamos limpios \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*, \w por|strong="H4480"\w* la cual \w vino|strong="H1961"\w* la \w plaga|strong="H5063"\w* \w en|strong="H4480"\w* la congregación \w de|strong="H4480"\w* Yahvé,  
\v 18 \w para|strong="H1961"\w* \w que|strong="H3117"\w* vosotros os apartéis \w hoy|strong="H3117"\w* de seguir \w a|strong="H3068"\w* Yahvé? \w Y|strong="H3068"\w* \w sucederá|strong="H1961"\w* \w que|strong="H3117"\w* \w si|strong="H1961"\w* vosotros os rebeláis \w hoy|strong="H3117"\w* \w contra|strong="H3478"\w* Yahvé, \w mañana|strong="H4279"\w* \w se|strong="H1961"\w* encenderá su ira \w contra|strong="H3478"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación de \w Israel|strong="H3478"\w*.  
\v 19 Si os parece \w que|strong="H1107"\w* la tierra de vuestra posesión es \w inmunda|strong="H2931"\w*, \w pasaos|strong="H5674"\w* \w a|strong="H3068"\w* la tierra de la posesión de Yahvé, \w en|strong="H8432"\w* la cual \w está|strong="H7931"\w* \w el|strong="H5674"\w* \w Tabernáculo|strong="H4908"\w* de la reunión de Yahvé, y tomad posesión \w entre|strong="H8432"\w* nosotros; pero no os rebeléis contra Yahvé, \w ni|strong="H8432"\w* os rebeléis contra nosotros, \w edificándoos|strong="H1129"\w* un \w altar|strong="H4196"\w* además \w del|strong="H4196"\w* \w altar|strong="H4196"\w* de Yahvé nuestro \w Dios|strong="H3068"\w*.  
\v 20 ¿\w No|strong="H3808"\w* \w cometió|strong="H4604"\w* Acán \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Zera|strong="H2226"\w* una \w prevaricación|strong="H4603"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w anatema|strong="H2764"\w*, \w y|strong="H5921"\w* cayó \w la|strong="H1931"\w* \w ira|strong="H7110"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* congregación \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*? \w Y|strong="H3068"\w* \w aquel|strong="H1931"\w* \w hombre|strong="H1121"\w* \w no|strong="H3808"\w* \w pereció|strong="H1478"\w* \w solo|strong="H1931"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w iniquidad|strong="H5771"\w*»».   
\p
