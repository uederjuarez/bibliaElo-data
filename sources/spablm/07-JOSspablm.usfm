\v 2 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H3605"\w* tierra \w que|strong="H3605"\w* todavía \w queda|strong="H7604"\w*: \w todos|strong="H3605"\w* \w los|strong="H3605"\w* distritos de \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* territorio de \w los|strong="H3605"\w* gesuritas;  
