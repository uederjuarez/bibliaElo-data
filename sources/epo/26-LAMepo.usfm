\id LAM  
\h Plorkanto 
\toc1 PLORKANTO DE JEREMIA 
\toc2 Plorkanto 
\mt1 PLORKANTO DE JEREMIA  
\c 1
\p  
\q1
\v 1 Kiel solece sidas la urbo, kiu estis tiel multehoma!  
\q1 La estrino de la nacioj fariĝis kiel vidvino,  
\q1 La princino de landoj fariĝis tributulino!   
\q1
\v 2 Senĉese ŝi ploras en la nokto, kaj ŝiaj larmoj estas sur ŝiaj vangoj;  
\q1 Ŝi havas neniun konsolanton inter ĉiuj siaj amintoj,  
\q1 Ĉiuj ŝiaj amikoj ŝin perfidis, fariĝis ŝiaj malamikoj.   
\q1
\v 3 Elmigris Jehuda pro mizero kaj tro malfacila laborado;  
\q1 Li ekloĝis inter la nacioj, sed ne trovas ripozon;  
\q1 Ĉiuj liaj persekutantoj atingis lin en malvastaj lokoj.   
\q1
\v 4 La vojoj de Cion estas malĝojaj, ĉar neniu iras al festoj;  
\q1 Ĉiuj ĝiaj pordegoj dezertiĝis, ĝiaj pastroj ĝemas;  
\q1 Ĝiaj virgulinoj ploras, kaj al ĝi mem estas tre maldolĉe.   
\q1
\v 5 Ĝiaj kontraŭuloj fariĝis ĉefoj, ĝiaj malamikoj ĝuas bonstaton;  
\q1 Ĉar la Eternulo ĵetis sur ĝin mizeron pro la multo de ĝiaj malbonagoj;  
\q1 Ĝiaj infanoj iris en kaptitecon, pelataj de la malamiko.   
\q1
\v 6 Foriĝis de la filino de Cion ŝia tuta beleco;  
\q1 Ŝiaj princoj fariĝis kiel cervoj, kiuj ne trovas paŝtejon,  
\q1 Kaj ili iras senforte antaŭ la pelanto.   
\q1
\v 7 En la tagoj de sia mizero kaj suferoj Jerusalem rememoras ĉiujn ĉarmaĵojn, kiujn ŝi havis en la tempoj pasintaj;  
\q1 Dume nun ŝia popolo enfalis en la manon de premanto, kaj neniu ŝin helpas,  
\q1 La malamikoj ŝin rigardas kaj ridas pri ŝia ruiniĝo.   
\q1
\v 8 Pekis, pekis Jerusalem, tial ŝi fariĝis kiel hontindulino;  
\q1 Ĉiuj, kiuj ŝin estimis, nun malestimas ŝin, ĉar ili vidas ŝian malhonoron;  
\q1 Kaj ŝi mem ĝemas kaj turnas sin malantaŭen.   
\q1
\v 9 Ŝia malpuraĵo estas sur la rando de ŝia vesto; ŝi ne pensis pri sia estonteco;  
\q1 Tial ŝi terure malaltiĝis, kaj ŝi havas neniun konsolanton:  
\q1 Rigardu, ho Eternulo, mian mizeron, ĉar la malamiko forte fieras.   
\q1
\v 10 La malamiko etendis sian manon sur ĉiujn ŝiajn grandvaloraĵojn;  
\q1 Ŝi vidas, kiel en ŝian sanktejon eniras nacioj,  
\q1 Pri kiuj Vi ordonis, ke ili ne eniru en Vian komunumon.   
\q1
\v 11 Ŝia tuta popolo ĝemas, ili serĉas panon,  
\q1 Ili fordonas siajn grandvaloraĵojn pro manĝaĵo, por revigligi sian animon:  
\q1 Rigardu, ho Eternulo, kaj vidu, kiel malestimata mi fariĝis!   
\q1
\v 12 Ho vi, ĉiuj, kiuj preteriras la vojon, rigardu kaj vidu,  
\q1 Ĉu ekzistas sufero simila al mia sufero,  
\q1 Kiu trafis min kaj kiun la Eternulo ĵetis sur min en la tago de Lia flama kolero.   
\q1
\v 13 De supre Li ĵetis fajron en miajn ostojn, kaj ĝi ekregis en ili;  
\q1 Li etendis reton antaŭ miaj piedoj, renversis min malantaŭen;  
\q1 Li ruinigis min, faris min dolorplena dum la tuta tago.   
\q1
\v 14 Kunplektiĝis per Lia mano la jugo de miaj pekoj;  
\q1 Ili kunplektiĝis, suriris sur mian kolon; Li faligis mian forton;  
\q1 La Sinjoro transdonis min en tiajn manojn, el kiuj mi ne povas leviĝi.   
\q1
\v 15 La Sinjoro dispremis per la piedoj ĉiujn miajn fortulojn interne de mi;  
\q1 Li kunvokis festan kunvenon kontraŭ min, por disbati miajn junulojn;  
\q1 Kiel en vinpremejo la Sinjoro piedpremis la virgulinon-filinon de Jehuda.   
\q1
\v 16 Pro tio mi ploras kaj miaj ambaŭ okuloj abunde fluigas akvon;  
\q1 Ĉar malproksime de mi estas konsolanto, kiu povus revigligi mian animon;  
\q1 Miaj infanoj pereis, ĉar la malamiko venkis.   
\q1
\v 17 Cion etendas siajn manojn, sed ĝi ne trovas konsolanton;  
\q1 La Eternulo vokis kontraŭ Jakobon liajn malamikojn de ĉiuj flankoj;  
\q1 Jerusalem fariĝis inter ili kiel hontindulino.   
\q1
\v 18 Justa Li estas, la Eternulo, ĉar mi malobeis Liajn vortojn.  
\q1 Aŭskultu, ho ĉiuj popoloj, kaj rigardu mian suferadon:  
\q1 Miaj virgulinoj kaj junuloj iris en kaptitecon.   
\q1
\v 19 Mi vokis miajn amikojn, sed ili min trompis;  
\q1 Miaj pastroj kaj miaj plejaĝuloj estas mortantaj en la urbo,  
\q1 Ili serĉas por si panon, por revigligi sian animon.   
\q1
\v 20 Rigardu, ho Eternulo, en kia mizero mi estas!  
\q1 Miaj internaĵoj ŝvelis, mia koro renversiĝis en mi, ĉar mi forte malobeis.  
\q1 Ekstere seninfanigis min la glavo, kaj en la domo la morto.   
\q1
\v 21 Oni aŭdas, kiel mi ĝemas, sed neniu min konsolas;  
\q1 Ĉiuj miaj malamikoj aŭdis pri mia malfeliĉo, kaj ekĝojis, ĉar Vi tion faris;  
\q1 Venigu do la tagon, kiam Vi proklamos, ke ili fariĝu kiel mi.   
\q1
\v 22 Ilia tuta malboneco venu antaŭ Vin;  
\q1 Kaj agu kun ili tiel, kiel Vi agis kun mi pro ĉiuj miaj pekoj;  
\q1 Ĉar granda estas mia ĝemado, kaj mia koro doloras.   
\c 2
\p  
\q1
\v 1 Kiele la Sinjoro en Sia kolero kovris per mallumo la filinon de Cion!  
\q1 De la ĉielo sur la teron Li ĵetegis la belecon de Izrael,  
\q1 Kaj ne rememoris Sian piedbenketon en la tago de Sia kolero.   
\q1
\v 2 Senindulge ekstermis la Sinjoro ĉiujn loĝejojn de Jakob;  
\q1 Li detruis en Sia kolero la fortikaĵojn de la filino de Jehuda, alniveligis ilin al la tero;  
\q1 Li frapis la regnon kaj ĝiajn regantojn.   
\q1
\v 3 En flama kolero Li rompis ĉiujn kornojn de Izrael;  
\q1 Li tiris Sian dekstran manon malantaŭen, kiam venis la malamiko;  
\q1 Kaj Li ekbruligis en Jakob kvazaŭ flamantan fajron, kiu ekstermas ĉion ĉirkaŭe.   
\q1
\v 4 Li streĉis Sian pafarkon kiel malamiko, direktis Sian dekstran manon kiel atakanto,  
\q1 Kaj mortigis ĉion, kio estis ĉarma por la okuloj;  
\q1 En la tendo de la filino de Cion Li elverŝis Sian koleron kiel fajron.   
\q1
\v 5 La Sinjoro fariĝis kiel malamiko,  
\q1 Li ekstermis Izraelon, ekstermis ĉiujn liajn palacojn, detruis liajn fortikaĵojn;  
\q1 Kaj al la filino de Jehuda Li donis multe da plorado kaj ĝemado.   
\q1
\v 6 Kiel ĝardenon Li ruinigis lian tendon, detruis lian kunvenejon;  
\q1 La Eternulo forgesigis en Cion feston kaj sabaton,  
\q1 Kaj forpuŝis en la indigno de Sia kolero reĝon kaj pastron.   
\q1
\v 7 La Sinjoro forlasis Sian altaron, abomenis Sian sanktejon,  
\q1 Transdonis en la manojn de malamikoj la murojn de ĝiaj palacoj;  
\q1 Ili faris bruon en la domo de la Eternulo kiel en tago de festo.   
\q1
\v 8 La Eternulo decidis ekstermi la muregon de la filino de Cion;  
\q1 Li eltiris la mezurŝnuron, ne detenis Sian manon de ekstermado;  
\q1 Li funebrigis la fortikaĵon kaj muregon, ambaŭ havas nun mizeran aspekton.   
\q1
\v 9 Enprofundiĝis en la teron ĝiaj pordegoj; Li detruis kaj rompis ĝiajn riglilojn;  
\q1 Ĝia reĝo kaj ĝiaj princoj estas inter la nacioj;  
\q1 La leĝoj jam ne ekzistas, kaj ĝiaj profetoj ne plu ricevas vizion de la Eternulo.   
\q1
\v 10 Silente sidas sur la tero la plejaĝuloj de la filino de Cion;  
\q1 Polvon ili metis sur sian kapon, zonis sin per sakaĵo;  
\q1 Al la tero klinis sian kapon la virgulinoj de Jerusalem.   
\q1
\v 11 Konsumiĝis de larmoj miaj okuloj, ŝvelis miaj internaĵoj,  
\q1 Elverŝiĝis sur la teron mia hepato, pro la pereo de la filino de mia popolo,  
\q1 Kiam infanoj kaj suĉinfanoj senfortiĝis de malsato sur la stratoj de la urbo.   
\q1
\v 12 Al siaj patrinoj ili diris: Kie estas pano kaj vino?  
\q1 Ili falis kiel vunditaj sur la stratoj de la urbo,  
\q1 Kaj eligis sian animon sur la brusto de siaj patrinoj.   
\q1
\v 13 Kiun mi povas montri al vi, kun kiu mi povas kompari vin, ho filino de Jerusalem?  
\q1 Kiun similan mi povas montri al vi, por konsoli vin, ho virgulino-filino de Cion?  
\q1 Ĉar granda kiel la maro estas via malfeliĉo; kiu vin resanigos?   
\q1
\v 14 Viaj profetoj profetis al vi malveraĵon kaj sensencaĵon,  
\q1 Kaj ne montris al vi viajn malbonagojn, por antaŭgardi vin kontraŭ kaptiteco;  
\q1 Ili predikis al vi viziojn malverajn, kiuj alportis al vi elpelon.   
\q1
\v 15 Kunfrapas pri vi siajn manojn ĉiuj preterirantoj;  
\q1 Ili fajfas kaj balancas la kapon pri la filino de Jerusalem, dirante:  
\q1 Ĉu tio estas la urbo, kiun oni nomis perfektaĵo de beleco, ĝojo de la tuta tero?   
\q1
\v 16 Malfermegas kontraŭ vi sian buŝon ĉiuj viaj malamikoj;  
\q1 Ili fajfas kaj grincigas la dentojn, dirante: Ni englutis ŝin;  
\q1 Ĉi tiun tagon ni atendis, ni ĝin atingis, ni ĝin vidas.   
\q1
\v 17 La Eternulo plenumis tion, kion Li intencis;  
\q1 Li plenumis Sian vorton, kiun Li eldiris antaŭ longa tempo;  
\q1 Li detruis senindulge, Li ĝojigis pri vi la malamikon, Li altigis la kornon de viaj kontraŭuloj.   
\q1
\v 18 Ilia koro krias al la Sinjoro:  
\q1 Ho murego de la filino de Cion, verŝu larmojn kiel torento tage kaj nokte;  
\q1 Ne ripozu, la pupilo de via okulo ne silentu.   
\q1
\v 19 Leviĝu, ploregu en la nokto en la komenco de ĉiu gardoparto;  
\q1 Elverŝu kiel akvon vian koron antaŭ la vizaĝo de la Sinjoro;  
\q1 Levu al Li viajn manojn pro la animo de viaj infanoj, kiuj senfortiĝas de malsato en la komenco de ĉiuj stratoj.   
\q1
\v 20 Rigardu, ho Eternulo, kaj vidu, kun kiu Vi agis tiamaniere!  
\q1 Ĉu ie aliloke manĝis virinoj sian frukton, siajn dorlotitajn infanojn?  
\q1 Ĉu ie estis mortigataj en la sanktejo de la Sinjoro pastroj kaj profetoj?   
\q1
\v 21 Surtere sur la stratoj kuŝis junuloj kaj maljunuloj;  
\q1 Miaj junulinoj kaj junuloj falis de glavo;  
\q1 Vi mortigis en la tago de Via kolero, buĉis kaj ne kompatis.   
\q1
\v 22 Kiel por festa tago Vi kunvokis de ĉirkaŭe miajn terurajn najbarojn,  
\q1 Kaj en la tago de la kolero de la Eternulo neniu saviĝis, neniu restis;  
\q1 Tiujn, kiujn mi dorlotis kaj edukis, ĉiujn ekstermis mia malamiko.   
\c 3
\p  
\q1
\v 1 Mi estas la viro, kiu spertis suferon sub la vergo de Lia kolero.   
\q1
\v 2 Min Li kondukis kaj irigis en mallumon, ne en lumon.   
\q1
\v 3 Nur sur min Li turnas Sian manon ĉiutage denove.   
\p  
\b  
\q1
\v 4 Li maljunigis mian karnon kaj haŭton, rompis miajn ostojn.   
\q1
\v 5 Li konstruis ĉirkaŭ mi, ĉirkaŭis min per maldolĉaĵoj kaj malfacilaĵoj.   
\q1
\v 6 En mallumon Li lokis min, kiel porĉiamajn mortintojn.   
\p  
\b  
\q1
\v 7 Li ĉirkaŭbaris min, ke mi ne povu eliri; Li ligis min per pezaj ĉenoj.   
\q1
\v 8 Kvankam mi krias kaj vokas, Li kovras Siajn orelojn antaŭ mia preĝo.   
\q1
\v 9 Li baris miajn vojojn per hakitaj ŝtonoj; Li kurbigis miajn vojetojn.   
\p  
\b  
\q1
\v 10 Li estas por mi kiel urso en embusko, kiel leono en kaŝita loko.   
\q1
\v 11 Li depuŝis min de miaj vojoj, kaj disŝiris min; Li faris min objekto de teruro.   
\q1
\v 12 Li streĉis Sian pafarkon, kaj starigis min kiel celon por Siaj sagoj.   
\p  
\b  
\q1
\v 13 En miajn renojn Li pafis la filojn de Sia sagujo.   
\q1
\v 14 Mi fariĝis mokataĵo por mia tuta popolo, ilia ĉiutaga rekantaĵo.   
\q1
\v 15 Li satigis min per maldolĉaĵo, trinkoplenigis min per vermuto.   
\p  
\b  
\q1
\v 16 Li disrompis miajn dentojn en malgrandajn pecojn, Li enpuŝis min en cindron.   
\q1
\v 17 Mia animo estas forpuŝita for de paco; bonstaton mi forgesis.   
\q1
\v 18 Kaj mi diris: Pereis mia forto kaj mia espero al la Eternulo.   
\p  
\b  
\q1
\v 19 La memoro pri mia mizero kaj miaj suferoj estas vermuto kaj galo.   
\q1
\v 20 Konstante rememorante tion, senfortiĝas en mi mia animo.   
\q1
\v 21 Sed tion mi respondas al mia koro, kaj tial mi esperas:   
\p  
\b  
\q1
\v 22 Ĝi estas favorkoreco de la Eternulo, ke ni ne tute pereis; ĉar Lia kompatemeco ne finiĝis,   
\q1
\v 23 Sed ĉiumatene ĝi renoviĝas; granda estas Via fideleco.   
\q1
\v 24 Mia parto estas la Eternulo, diras mia animo; tial mi esperas al Li.   
\p  
\b  
\q1
\v 25 La Eternulo estas bona por tiuj, kiuj esperas al Li, por la animo, kiu serĉas Lin.   
\q1
\v 26 Bone estas esperi pacience helpon de la Eternulo.   
\q1
\v 27 Bone estas al la homo, kiu portas jugon en sia juneco;   
\p  
\b  
\q1
\v 28 Li sidas solece kaj silentas, kiam li estas ŝarĝita;   
\q1
\v 29 Li metas sian buŝon en polvon, kredante, ke ekzistas espero;   
\q1
\v 30 Li donas sian vangon al tiu, kiu lin batas; li satigas sin per malhonoro.   
\p  
\b  
\q1
\v 31 Ĉar ne por eterne forlasas la Sinjoro;   
\q1
\v 32 Se Li iun suferigas, Li ankaŭ kompatas pro Sia granda favorkoreco;   
\q1
\v 33 Ĉar ne el Sia koro Li sendas mizeron kaj suferon al la homoj.   
\p  
\b  
\q1
\v 34 Kiam oni premas sub siaj piedoj ĉiujn malliberulojn de la tero,   
\q1
\v 35 Kiam oni forklinas la rajton de homo antaŭ la vizaĝo de la Plejaltulo,   
\q1
\v 36 Kiam oni estas maljusta kontraŭ homo en lia juĝa afero — Ĉu la Sinjoro tion ne vidas?   
\p  
\b  
\q1
\v 37 Kiu povas per sia diro atingi, ke io fariĝu, se la Sinjoro tion ne ordonis?   
\q1
\v 38 Ĉu ne el la buŝo de la Plejaltulo eliras la decidoj pri malbono kaj pri bono?   
\q1
\v 39 Kial murmuras homo vivanta? Ĉiu murmuru kontraŭ siaj pekoj.   
\p  
\b  
\q1
\v 40 Ni trarigardu kaj esploru nian konduton, kaj ni revenu al la Eternulo;   
\q1
\v 41 Ni levu nian koron kaj niajn manojn al Dio en la ĉielo.   
\q1
\v 42 Ni pekis kaj malobeis, kaj Vi ne pardonis.   
\p  
\b  
\q1
\v 43 Vi kovris Vin per kolero kaj persekutis nin; Vi mortigis, Vi ne kompatis.   
\q1
\v 44 Vi kovris Vin per nubo, por ke ne atingu Vin la preĝo.   
\q1
\v 45 Vi faris nin balaindaĵo kaj abomenindaĵo inter la popoloj.   
\p  
\b  
\q1
\v 46 Malfermegis kontraŭ ni sian buŝon ĉiuj niaj malamikoj.   
\q1
\v 47 Teruro kaj pereo trafis nin, ruinigo kaj malfeliĉo.   
\q1
\v 48 Torentojn da akvo verŝas mia okulo pri la malfeliĉo de la filino de mia popolo.   
\p  
\b  
\q1
\v 49 Mia okulo fluigas kaj ne ĉesas, ne ekzistas por ĝi halto,   
\q1
\v 50 Ĝis la Eternulo ekrigardos kaj ekvidos de la ĉielo.   
\q1
\v 51 Mia okulo suferigas mian animon pri ĉiuj filinoj de mia urbo.   
\p  
\b  
\q1
\v 52 Senkaŭze ĉasas min kiel birdon miaj malamikoj;   
\q1
\v 53 Ili pereigas mian vivon en kavo, ili ĵetas sur min ŝtonojn.   
\q1
\v 54 Akvo leviĝis kontraŭ mian kapon, kaj mi diris: Mi tute pereis.   
\p  
\b  
\q1
\v 55 Mi vokis Vian nomon, ho Eternulo, el la profunda kavo;   
\q1
\v 56 Vi aŭdis mian voĉon; ne kovru Vian orelon antaŭ mia vokado pri liberigo.   
\q1
\v 57 Vi alproksimiĝis, kiam mi vokis al Vi; Vi diris: Ne timu.   
\p  
\b  
\q1
\v 58 Vi, ho Sinjoro, defendis mian juĝaferon; Vi liberigis mian vivon.   
\q1
\v 59 Vi vidis, ho Eternulo, la maljustaĵon, kiun mi suferas; juĝu mian aferon.   
\q1
\v 60 Vi vidis ilian tutan venĝon, ĉiujn iliajn intencojn kontraŭ mi.   
\p  
\b  
\q1
\v 61 Vi aŭdis ilian insultadon, ho Eternulo, ĉiujn iliajn intencojn kontraŭ mi,   
\q1
\v 62 La parolojn de tiuj, kiuj leviĝis kontraŭ min, kaj iliajn pensojn kontraŭ mi dum la tuta tago.   
\q1
\v 63 Rigardu, kiam ili sidas kaj kiam ili leviĝas; mi ĉiam estas ilia rekantaĵo.   
\p  
\b  
\q1
\v 64 Redonu al ili repagon, ho Eternulo, laŭ la faroj de iliaj manoj.   
\q1
\v 65 Donu al ili doloron en la koro, sentigu al ili Vian malbenon.   
\q1
\v 66 Persekutu ilin en kolero, kaj ekstermu ilin el sub la ĉielo de la Eternulo.   
\c 4
\p  
\q1
\v 1 Kiele senbriliĝis la oro, ŝanĝiĝis la bonega metalo!  
\q1 La ŝtonoj de la sanktejo kuŝas disĵetitaj en la komenco de ĉiuj stratoj!   
\q1
\v 2 La karaj filoj de Cion, havantaj la valoron de plej pura oro,  
\q1 Kiele ili similiĝis al argilaj potoj, faritaĵo de potisto!   
\q1
\v 3 Eĉ ŝakaloj donas siajn mamojn kaj nutras siajn idojn;  
\q1 Sed la filino de mia popolo fariĝis kruela, kiel strutoj en la dezerto.   
\q1
\v 4 La lango de suĉinfano algluiĝis al ĝia palato pro soifo;  
\q1 Infanoj petas panon, sed neniu donas al ili.   
\q1
\v 5 Kiuj antaŭe manĝadis frandaĵojn, tiuj senfortiĝas nun pro malsato sur la stratoj;  
\q1 Kiuj estis edukitaj sur purpuro, tiuj ruliĝas nun sur sterko.   
\q1
\v 6 La pekoj de la filino de mia popolo estas pli grandaj, ol la pekoj de Sodom,  
\q1 Kiu estis renversita momente, kaj manoj ĝin ne turmentis.   
\q1
\v 7 Ŝiaj princoj estis pli puraj ol neĝo, pli klaraj ol lakto;  
\q1 Ilia vizaĝo estis pli ruĝa ol koraloj, ili aspektis kiel safiro;   
\q1
\v 8 Nun ilia vizaĝo estas pli nigra ol karbo; oni ne rekonas ilin sur la stratoj;  
\q1 Ilia haŭto alpendiĝis al iliaj ostoj, velksekiĝis kiel ligno.   
\q1
\v 9 Pli bone estis al tiuj, kiuj mortis de glavo, ol al tiuj, kiuj mortas de malsato,  
\q1 Kiuj senfortiĝas kaj pereas pro manko de produktaĵoj de kampo.   
\q1
\v 10 La manoj de kompatemaj virinoj kuiris iliajn infanojn;  
\q1 Kaj ĉi tiuj fariĝis ilia manĝaĵo en la mizerego de la filino de mia popolo.   
\q1
\v 11 La Eternulo plene elĉerpis Sian koleron, Li elverŝis la flamon de Sia indigno;  
\q1 Li ekbruligis en Cion fajron, kiu ekstermis ĝiajn fundamentojn.   
\q1
\v 12 Ne kredis la reĝoj de la tero, nek ĉiuj loĝantoj de la mondo,  
\q1 Ke malamiko kaj kontraŭulo eniros en la pordegojn de Jerusalem.   
\q1
\v 13 Tio fariĝis pro la pekoj de ĝiaj profetoj, pro la malbonagoj de ĝiaj pastroj,  
\q1 Kiuj verŝadis en ĝi sangon de virtuloj.   
\q1
\v 14 Kiel blinduloj ili vagadis sur la stratoj,  
\q1 Malpurigis sin per sango tiel, ke oni ne povis tuŝi iliajn vestojn.   
\q1
\v 15 Oni kriis al ili: For, malpuruloj! for, for, ne altuŝiĝu!  
\q1 Kiam ili foriĝadis kaj vagadis, oni diradis inter la nacioj: Ili ne plu loĝos tie.   
\q1
\v 16 La vizaĝo de la Eternulo ilin disĵetis, kaj jam ne volas rigardi ilin;  
\q1 Pastrojn ili ne respektis, plejaĝulojn ili ne kompatis.   
\q1
\v 17 Ankoraŭ laciĝadis niaj okuloj, atendante senvaloran helpon;  
\q1 Streĉe ni atendis nacion, kiu ne povas helpi.   
\q1
\v 18 Ili glitigis niajn paŝojn, ke ni ne povu iri sur niaj stratoj.  
\q1 Alproksimiĝis nia fino; pleniĝis nia tempo, ĉar venis nia fino.   
\q1
\v 19 Pli rapidaj ol agloj de la ĉielo estis niaj persekutantoj;  
\q1 Sur la montoj ili postkuris nin, en la dezerto ili faris embuskojn kontraŭ ni.   
\q1
\v 20 La spiro de nia vivo, la sanktoleito de la Eternulo, kaptiĝis en iliajn kavojn,  
\q1 Pri kiu ni diris: Sub lia ombro ni vivos inter la nacioj.   
\q1
\v 21 Ĝoju kaj estu gaja, ho filino de Edom, kiu loĝas en la lando Uc;  
\q1 Ankaŭ al vi venos la kaliko, vi ebriiĝos kaj nudiĝos.   
\q1
\v 22 Finiĝis viaj malbonagoj, ho filino de Cion; Li vin ne plu forkondukigos;  
\q1 Sed viajn malbonagojn, ho filino de Edom, Li punos, Li malkovros viajn pekojn.   
\c 5
\p  
\q1
\v 1 Rememoru, ho Eternulo, kio fariĝis al ni;  
\q1 Rigardu kaj vidu nian malhonoron!   
\q1
\v 2 Nia heredaĵo transiris al fremduloj,  
\q1 Niaj domoj al aligentuloj.   
\q1
\v 3 Ni fariĝis orfoj senpatraj,  
\q1 Niaj patrinoj estas kiel vidvinoj.   
\q1
\v 4 Nian akvon ni trinkas pro mono;  
\q1 Nian lignon ni ricevas nur pro pago.   
\q1
\v 5 Oni pelas nin je nia kolo;  
\q1 Ni laciĝis, sed oni ne permesas al ni ripozi.   
\q1
\v 6 Al Egiptujo ni etendis la manon,  
\q1 Al Asirio, por satiĝi per pano.   
\q1
\v 7 Niaj patroj pekis, sed ili jam ne ekzistas;  
\q1 Kaj ni devas suferi pro iliaj malbonagoj.   
\q1
\v 8 Sklavoj regas super ni;  
\q1 Kaj neniu liberigas nin el iliaj manoj.   
\q1
\v 9 Kun danĝero por nia vivo ni akiras nian panon,  
\q1 Pro la glavo en la dezerto.   
\q1
\v 10 Nia haŭto varmegiĝis kiel forno,  
\q1 Por la kruela malsato.   
\q1
\v 11 La virinojn en Cion ili senhonorigis,  
\q1 La virgulinojn en la urboj de Judujo.   
\q1
\v 12 La princoj estas pendigitaj je siaj manoj;  
\q1 La maljunulojn oni ne respektis.   
\q1
\v 13 La junuloj devas porti muelŝtonojn;  
\q1 La knaboj falas sub la lignoŝarĝoj.   
\q1
\v 14 La maljunuloj jam ne sidas ĉe la pordegoj,  
\q1 La junuloj jam ne kantas.   
\q1
\v 15 Malaperis la gajeco de nia koro;  
\q1 Niaj dancrondoj aliformiĝis en funebron.   
\q1
\v 16 Defalis la krono de nia kapo;  
\q1 Ho ve al ni, ke ni pekis!   
\q1
\v 17 Pro tio senfortiĝis nia koro,  
\q1 Pro tio senlumiĝis niaj okuloj:   
\q1
\v 18 Pro la monto Cion, ke ĝi fariĝis dezerta,  
\q1 Ke vulpoj vagas sur ĝi.   
\q1
\v 19 Sed Vi, ho Eternulo, kiu restas eterne  
\q1 Kaj kies trono staras de generacio al generacio,   
\q1
\v 20 Kial Vi forgesis nin kvazaŭ por eterne,  
\q1 Forlasis nin por longa tempo?   
\q1
\v 21 Reirigu nin, ho Eternulo, al Vi, ke ni revenu;  
\q1 Renovigu niajn tagojn kiel en la tempo antaŭa.   
\q1
\v 22 Ĉar ĉu Vi nin tute forpuŝis?  
\q1 Vi tre forte ekkoleris kontraŭ ni.   
\p  
\b  